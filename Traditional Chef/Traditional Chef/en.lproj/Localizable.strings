"recipe.us_tx_chili_con_carne.drink.body" = "Peppery Syrah or a robust amber ale matches the chile heat and beefy richness without tasting thin. For a non-alcoholic option, serve iced tea or sparkling water with lime to refresh the palate between bites.";
"recipe.us_tx_chili_con_carne.drink.summary" = "Red wine (Syrah)";
"recipe.us_tx_chili_con_carne.info" = "Texas chili con carne is the classic Texas bowl of red: chunks of beef simmered slowly in a rich, deep chile sauce built from toasted dried chiles, onions, garlic, and warm spices. Traditionally it contains no beans, focusing on tender beef and a smooth, brick-red gravy that thickens as it cooks and is finished with a touch of masa for body. Served hot and hearty, it’s a staple of Texas cook-offs and home tables alike, often eaten with crackers alongside.";
"recipe.us_tx_chili_con_carne.info.summary" = "Texas bowl of red";
"recipe.us_tx_chili_con_carne.name" = "Chili con carne";
"recipe.us_tx_chili_con_carne.step1.body" = "Stem and seed the %i5, %i6, and %i7. Toast them briefly in a dry skillet until fragrant, turning often so they do not scorch.";
"recipe.us_tx_chili_con_carne.step1.title" = "Toast the dried chiles";
"recipe.us_tx_chili_con_carne.step2.body" = "Cover the toasted chiles with %i8 and let them soften until pliable.";
"recipe.us_tx_chili_con_carne.step2.title" = "Soak the chiles";
"recipe.us_tx_chili_con_carne.step3.body" = "Blend the softened chiles with enough soaking liquid to make a smooth, pourable puree.";
"recipe.us_tx_chili_con_carne.step3.title" = "Blend the chile sauce";
"recipe.us_tx_chili_con_carne.step4.body" = "Heat the pot and brown the %i1 in batches in the %i2 until well colored. Return all beef to the pot.";
"recipe.us_tx_chili_con_carne.step4.title" = "Brown the beef";
"recipe.us_tx_chili_con_carne.step5.body" = "Add %i3 to the pot and cook until softened, scraping up browned bits. Stir in %i4 until fragrant.";
"recipe.us_tx_chili_con_carne.step5.title" = "Cook the aromatics";
"recipe.us_tx_chili_con_carne.step6.body" = "Stir in %i10, %i11, %i12, and %i13, then pour in the chile puree and %i9. Bring to a steady simmer, stirring to combine.";
"recipe.us_tx_chili_con_carne.step6.title" = "Build the chili base";
"recipe.us_tx_chili_con_carne.step7.body" = "Maintain a gentle simmer, stirring occasionally, until the beef is very tender and the chili becomes deeply red and cohesive.";
"recipe.us_tx_chili_con_carne.step7.title" = "Slow simmer until tender";
"recipe.us_tx_chili_con_carne.step8.body" = "Whisk %i14 with a little hot liquid from the pot until smooth, then stir it back into the chili and simmer until slightly thickened and velvety.";
"recipe.us_tx_chili_con_carne.step8.title" = "Thicken with masa";
"recipe.us_tx_chili_con_carne.step9.body" = "Ladle the chili into bowls and serve hot with %i15.";
"recipe.us_tx_chili_con_carne.step9.title" = "Serve";
