"recipe.fr_creme_brulee.drink.body" = "Pair with a sweet wine such as Sauternes or a late-harvest white that complements vanilla and caramel. Champagne can also work for a lighter contrast. For a non-alcoholic option, serve espresso, black tea, or sparkling water.";
"recipe.fr_creme_brulee.drink.summary" = "Dessert wine (Sauternes)";
"recipe.fr_creme_brulee.info" = "Crème brûlée is a classic French dessert of rich vanilla-scented custard baked gently in a water bath until just set, then chilled and topped with a thin layer of sugar that is caramelized into a crisp glassy crust. It is served cold with the warm crackling caramel top made just before serving.";
"recipe.fr_creme_brulee.info.summary" = "Crackling caramel custard";
"recipe.fr_creme_brulee.name" = "Crème brûlée";
"recipe.fr_creme_brulee.step1.body" = "Split %i4, add it to %i1 with a pinch of %i5, and warm until steaming. Remove it from the heat and let it infuse briefly.";
"recipe.fr_creme_brulee.step1.title" = "Infuse the cream";
"recipe.fr_creme_brulee.step2.body" = "Whisk %i2 with %i3 until smooth and slightly lighter.";
"recipe.fr_creme_brulee.step2.title" = "Whisk the yolks and sugar";
"recipe.fr_creme_brulee.step3.body" = "Remove the vanilla pod, whisk the warm cream into the yolks gradually, then strain the custard through a fine sieve.";
"recipe.fr_creme_brulee.step3.title" = "Temper and strain";
"recipe.fr_creme_brulee.step4.body" = "Pour the custard into ramekins and place them in a roasting pan.";
"recipe.fr_creme_brulee.step4.title" = "Fill the ramekins";
"recipe.fr_creme_brulee.step5.body" = "Pour hot water into the roasting pan to come partway up the sides of the ramekins.";
"recipe.fr_creme_brulee.step5.title" = "Add the water bath";
"recipe.fr_creme_brulee.step6.body" = "Bake until the custards are just set with a slight wobble in the centre.";
"recipe.fr_creme_brulee.step6.title" = "Bake the custards";
"recipe.fr_creme_brulee.step7.body" = "Cool, then chill until fully cold and set.";
"recipe.fr_creme_brulee.step7.title" = "Chill the custards";
"recipe.fr_creme_brulee.step8.body" = "Sprinkle an even layer of %i6 on each custard and caramelize with a torch until deep golden and glassy.";
"recipe.fr_creme_brulee.step8.title" = "Caramelize the tops";
"recipe.fr_creme_brulee.step9.body" = "Serve immediately so the caramel stays crisp.";
"recipe.fr_creme_brulee.step9.title" = "Serve immediately";
