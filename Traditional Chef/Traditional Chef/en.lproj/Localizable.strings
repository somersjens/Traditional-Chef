"recipe.pt_porco_a_alentejana.drink.body" = "A crisp Portuguese white such as Alvarinho or a dry Arinto handles the briny clams and cuts the richness of pork and fried potatoes. If you prefer red, choose a light Portuguese red served slightly cool. Non-alcoholic pairing: sparkling water with lemon or a chilled alcohol-free pilsner.";
"recipe.pt_porco_a_alentejana.drink.summary" = "White wine (Alvarinho)";
"recipe.pt_porco_a_alentejana.info" = "Carne de Porco a Alentejana is a classic Portuguese dish combining marinated pork with clams, fried potatoes, and a garlicky, paprika-tinged sauce brightened with white wine and coriander. Traditionally, the pork is browned first, then the clams are steamed in at the end so they open into the sauce. It is served hot with lemon and often finished with black olives and chopped coriander.";
"recipe.pt_porco_a_alentejana.info.summary" = "Pork and clams classic";
"recipe.pt_porco_a_alentejana.name" = "Pork Alentejana";
"recipe.pt_porco_a_alentejana.step1.body" = "Place the %i2 in a bowl with cold %i16 and enough %i14 to make it pleasantly salty. Leave to purge, then lift the clams out, rinse well, and drain.";
"recipe.pt_porco_a_alentejana.step1.title" = "Purge the clams";
"recipe.pt_porco_a_alentejana.step2.body" = "Cut %i1 into bite-size cubes. Mix with sliced %i5, %i8, %i9, %i14, %i15, %i6, and %i7, and leave to marinate.";
"recipe.pt_porco_a_alentejana.step2.title" = "Marinate the pork";
"recipe.pt_porco_a_alentejana.step3.body" = "Peel the %i3 and cut into small cubes. Rinse, drain, and dry thoroughly so they fry crisp.";
"recipe.pt_porco_a_alentejana.step3.title" = "Prepare the potatoes";
"recipe.pt_porco_a_alentejana.step4.body" = "Heat %i4 and fry the potatoes in batches until golden and cooked through. Drain on paper towels and season lightly.";
"recipe.pt_porco_a_alentejana.step4.title" = "Fry the potatoes";
"recipe.pt_porco_a_alentejana.step5.body" = "Heat %i10 in a large skillet over medium-high heat. Add the pork and cook until well browned, leaving the marinade behind for the moment.";
"recipe.pt_porco_a_alentejana.step5.title" = "Brown the pork";
"recipe.pt_porco_a_alentejana.step6.body" = "Pour the reserved marinade into the skillet and let it bubble, scraping the pan, until the pork is coated in a savory sauce.";
"recipe.pt_porco_a_alentejana.step6.title" = "Build the sauce";
"recipe.pt_porco_a_alentejana.step7.body" = "Add the clams, cover, and cook until they open and release their juices into the sauce. Discard any that do not open.";
"recipe.pt_porco_a_alentejana.step7.title" = "Steam in the clams";
"recipe.pt_porco_a_alentejana.step8.body" = "Fold in the fried potatoes so they are coated with the sauce while keeping some crispness.";
"recipe.pt_porco_a_alentejana.step8.title" = "Combine with potatoes";
"recipe.pt_porco_a_alentejana.step9.body" = "Scatter with chopped %i11 and %i12, squeeze %i13 over the top, and serve immediately on a platter.";
"recipe.pt_porco_a_alentejana.step9.title" = "Finish and serve";
