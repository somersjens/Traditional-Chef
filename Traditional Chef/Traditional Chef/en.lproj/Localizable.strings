"recipe.de_koenigsberger_klopse.drink.body" = "Pair with a crisp, high-acid dry white such as Riesling trocken to complement the capers and lemon while cutting through the creamy sauce. A light German lager also pairs well. For a non-alcoholic option, serve sparkling water with lemon or an alcohol-free pils.";
"recipe.de_koenigsberger_klopse.drink.summary" = "White wine (Riesling)";
"recipe.de_koenigsberger_klopse.info" = "Königsberger Klopse are traditional German meatballs from the former East Prussian city of Königsberg: finely mixed minced meat with soaked bread and anchovy, gently poached, then served in a creamy white sauce brightened with capers and lemon. The dish is classically served with boiled potatoes, which soak up the tangy caper sauce.";
"recipe.de_koenigsberger_klopse.info.summary" = "Capers in cream sauce";
"recipe.de_koenigsberger_klopse.name" = "Königsberger Klopse";
"recipe.de_koenigsberger_klopse.step1.body" = "Soak %i3 in %i4 until soft, then squeeze out the excess milk and crumble it finely.";
"recipe.de_koenigsberger_klopse.step1.title" = "Soak the bread";
"recipe.de_koenigsberger_klopse.step10.body" = "Stir in %i20, then add %i21 and %i22. Season with %i23 and %i24.";
"recipe.de_koenigsberger_klopse.step10.title" = "Finish with cream and capers";
"recipe.de_koenigsberger_klopse.step11.body" = "Return the meatballs to the sauce and warm them gently without boiling. Serve with boiled potatoes.";
"recipe.de_koenigsberger_klopse.step11.title" = "Warm and serve";
"recipe.de_koenigsberger_klopse.step2.body" = "Finely chop %i6 and %i9. Mix %i1 and %i2 with the soaked bread, %i5, the onion, anchovies, %i7, and %i8 until uniform.";
"recipe.de_koenigsberger_klopse.step2.title" = "Make the meatball mixture";
"recipe.de_koenigsberger_klopse.step3.body" = "With wet hands, shape the mixture into evenly sized meatballs.";
"recipe.de_koenigsberger_klopse.step3.title" = "Form the klopse";
"recipe.de_koenigsberger_klopse.step4.body" = "Bring %i10 to a gentle simmer with %i11, %i12, %i13, %i14, %i15, and %i16.";
"recipe.de_koenigsberger_klopse.step4.title" = "Start the poaching broth";
"recipe.de_koenigsberger_klopse.step5.body" = "Slide the meatballs into the barely simmering broth and poach them gently until cooked through, keeping the liquid below a boil.";
"recipe.de_koenigsberger_klopse.step5.title" = "Poach the meatballs";
"recipe.de_koenigsberger_klopse.step6.body" = "Boil the potatoes in salted water until tender, then drain and keep them warm.";
"recipe.de_koenigsberger_klopse.step6.title" = "Cook the potatoes";
"recipe.de_koenigsberger_klopse.step7.body" = "Lift out the meatballs and strain the poaching liquid, keeping enough broth for the sauce.";
"recipe.de_koenigsberger_klopse.step7.title" = "Strain the broth";
"recipe.de_koenigsberger_klopse.step8.body" = "Melt %i17 in a saucepan, whisk in %i18, and cook briefly while whisking so it stays pale.";
"recipe.de_koenigsberger_klopse.step8.title" = "Make the roux";
"recipe.de_koenigsberger_klopse.step9.body" = "Whisk in %i19 gradually and simmer until smooth and lightly thickened, stirring so it does not catch.";
"recipe.de_koenigsberger_klopse.step9.title" = "Cook the sauce";
