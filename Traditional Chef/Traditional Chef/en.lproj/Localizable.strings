"recipe.ve_dulce_de_lechosa.drink.body" = "Serve with a light sweet dessert wine or demi-sec sparkling wine that complements the spiced syrup and fruit. For a non-alcoholic option, serve black coffee or hot black tea.";
"recipe.ve_dulce_de_lechosa.drink.summary" = "Sweet dessert wine";
"recipe.ve_dulce_de_lechosa.info" = "Dulce de lechosa is a traditional Venezuelan dessert made from green papaya slowly cooked in a spiced syrup of papelón, sugar, cinnamon, and cloves until the fruit becomes tender and translucent. It is especially associated with Christmas and Holy Week and is served cold or at room temperature as a classic home dessert.";
"recipe.ve_dulce_de_lechosa.info.summary" = "Papaya preserve sweet";
"recipe.ve_dulce_de_lechosa.name" = "Dulce de lechosa";
"recipe.ve_dulce_de_lechosa.step1.body" = "Peel %i1, remove the seeds, and cut the flesh into thin traditional strips.";
"recipe.ve_dulce_de_lechosa.step1.title" = "Prepare the papaya";
"recipe.ve_dulce_de_lechosa.step2.body" = "Rub the papaya strips with %i2 and leave them to rest so they firm up and keep their shape during cooking.";
"recipe.ve_dulce_de_lechosa.step2.title" = "Rest with baking soda";
"recipe.ve_dulce_de_lechosa.step3.body" = "Rinse the papaya very well to remove the baking soda, then drain it thoroughly.";
"recipe.ve_dulce_de_lechosa.step3.title" = "Rinse and drain";
"recipe.ve_dulce_de_lechosa.step4.body" = "Place %i3, %i4, %i5, %i6, and %i7 in a large pot and bring everything to a boil until the sweeteners dissolve fully.";
"recipe.ve_dulce_de_lechosa.step4.title" = "Make the syrup";
"recipe.ve_dulce_de_lechosa.step5.body" = "Add the papaya strips to the syrup and cook gently until they become tender, translucent, and evenly infused with the spiced syrup.";
"recipe.ve_dulce_de_lechosa.step5.title" = "Cook the papaya";
"recipe.ve_dulce_de_lechosa.step6.body" = "Remove the pot from the heat and let the dulce cool completely in the syrup so the fruit absorbs more flavor and the syrup settles.";
"recipe.ve_dulce_de_lechosa.step6.title" = "Cool in the syrup";
"recipe.ve_dulce_de_lechosa.step7.body" = "Transfer the dulce de lechosa to a serving bowl and serve it cold or at room temperature with some of the syrup.";
"recipe.ve_dulce_de_lechosa.step7.title" = "Serve";
"recipe.ve_dulce_de_lechosa.tool.t1" = "Large pot";
