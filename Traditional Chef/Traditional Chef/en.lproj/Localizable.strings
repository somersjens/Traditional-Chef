"recipe.pe_cuy_chactado.drink.body" = "Pair with a medium-bodied Garnacha or Tempranillo to balance the savory, fried crunch and garlic spice. A crisp lager also works well. For a non-alcoholic option, serve chicha morada or sparkling water with lime.";
"recipe.pe_cuy_chactado.drink.summary" = "Red wine (Garnacha)";
"recipe.pe_cuy_chactado.info" = "Cuy Chactado is a traditional Andean-Peruvian preparation of guinea pig split and flattened, seasoned with garlic and spices, dusted with flour, then fried under pressure until exceptionally crisp while staying juicy. It is classically served hot with boiled potatoes and a simple salad, with a bright ají and huacatay sauce on the side to cut through the richness.";
"recipe.pe_cuy_chactado.info.summary" = "Crispy pressed cuy";
"recipe.pe_cuy_chactado.name" = "Fried guinea pig";
"recipe.pe_cuy_chactado.step1.body" = "Split the %i1 open along the belly, remove any remaining innards, rinse, and pat dry. Press firmly to flatten so they cook evenly under weight.";
"recipe.pe_cuy_chactado.step1.title" = "Prepare and flatten the cuy";
"recipe.pe_cuy_chactado.step2.body" = "Crush the %i5 and mix it with %i2, %i4, %i3, and %i6. Rub the seasoning all over the cuy, including the skin side.";
"recipe.pe_cuy_chactado.step2.title" = "Season the cuy";
"recipe.pe_cuy_chactado.step3.body" = "Cover and refrigerate so the seasoning penetrates and the surface dries slightly for crisp frying.";
"recipe.pe_cuy_chactado.step3.title" = "Marinate";
"recipe.pe_cuy_chactado.step4.body" = "Cook the %i15 in salted %i19 until tender, then drain and keep warm.";
"recipe.pe_cuy_chactado.step4.title" = "Boil the potatoes";
"recipe.pe_cuy_chactado.step5.body" = "Blend the %i9, %i10, %i11, garlic, %i13, and %i14 until smooth and pourable. Taste and adjust with a little more lime or salt if needed.";
"recipe.pe_cuy_chactado.step5.title" = "Make the ají huacatay sauce";
"recipe.pe_cuy_chactado.step6.body" = "Slice the %i17 thinly and the %i16 into wedges, then toss with %i18 so it stays crisp and fresh.";
"recipe.pe_cuy_chactado.step6.title" = "Prepare the salad";
"recipe.pe_cuy_chactado.step7.body" = "Coat the cuy evenly with %i7, shaking off excess so the crust fries thin and crisp.";
"recipe.pe_cuy_chactado.step7.title" = "Dredge for frying";
"recipe.pe_cuy_chactado.step8.body" = "Heat the %i8 in a heavy skillet. Lay the cuy skin-side down, set a weight on top, and fry until deeply golden and crisp, then turn, reapply the weight, and fry until fully cooked and crisp.";
"recipe.pe_cuy_chactado.step8.title" = "Fry under pressure";
"recipe.pe_cuy_chactado.step9.body" = "Drain briefly on paper towels, then serve immediately with boiled potatoes, the salad, and the ají huacatay sauce on the side.";
"recipe.pe_cuy_chactado.step9.title" = "Drain and serve";
