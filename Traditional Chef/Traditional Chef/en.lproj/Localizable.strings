"recipe.cz_ovocne_knedliky.drink.body" = "A lightly sweet white wine such as late harvest Moravian wine pairs gently with the fruit and butter. For a non-alcoholic pairing, serve black tea or still water.";
"recipe.cz_ovocne_knedliky.drink.summary" = "Sweet wine";
"recipe.cz_ovocne_knedliky.info" = "Ovocné knedlíky are traditional Czech sweet dumplings made from soft yeast dough filled with seasonal fruit. They are boiled gently, then served warm with crumbled quark, melted butter, and a dusting of sugar, most often as a sweet main dish or home-style dessert in summer.";
"recipe.cz_ovocne_knedliky.info.summary" = "Sweet fruit dumplings";
"recipe.cz_ovocne_knedliky.name" = "Fruit dumplings";
"recipe.cz_ovocne_knedliky.step1.body" = "Warm %i2 until lukewarm, crumble in %i3, add a little of %i4, and let it become active. In a bowl, combine %i1, the remaining sugar, %i5, softened %i6, %i7, and the yeast mixture, then work into a smooth soft dough.";
"recipe.cz_ovocne_knedliky.step1.title" = "Make the dough base";
"recipe.cz_ovocne_knedliky.step2.body" = "Cover the dough and leave it in a warm place until doubled and airy.";
"recipe.cz_ovocne_knedliky.step2.title" = "Let the dough rise";
"recipe.cz_ovocne_knedliky.step3.body" = "Wash %i8, dry them well, and halve them if needed so they can be enclosed neatly in the dough.";
"recipe.cz_ovocne_knedliky.step3.title" = "Prepare the fruit";
"recipe.cz_ovocne_knedliky.step4.body" = "Divide the dough into even pieces, flatten each piece in your hand, place a piece of plum in the center, then seal the dough completely around the fruit and shape it into smooth dumplings.";
"recipe.cz_ovocne_knedliky.step4.title" = "Shape the dumplings";
"recipe.cz_ovocne_knedliky.step5.body" = "Cover the shaped dumplings briefly so the dough relaxes before cooking.";
"recipe.cz_ovocne_knedliky.step5.title" = "Rest the dumplings";
"recipe.cz_ovocne_knedliky.step6.body" = "Bring %i9 to a gentle boil, add the dumplings in batches, and cook until they are puffed and cooked through, turning them once during cooking.";
"recipe.cz_ovocne_knedliky.step6.title" = "Boil the dumplings";
"recipe.cz_ovocne_knedliky.step7.body" = "Crumble %i10 and melt %i11 gently in the small saucepan.";
"recipe.cz_ovocne_knedliky.step7.title" = "Prepare the topping";
"recipe.cz_ovocne_knedliky.step8.body" = "Lift out the dumplings, place them on plates, scatter over the quark, drizzle with melted butter, and finish with %i12.";
"recipe.cz_ovocne_knedliky.step8.title" = "Serve";
