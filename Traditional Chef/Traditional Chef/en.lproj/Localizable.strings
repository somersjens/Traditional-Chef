"recipe.kr_bibimbap.step4.title" = "Make the sauce";
"recipe.kr_bibimbap.step5.body" = "Bring water to a boil in a large pot, blanch the %i9 briefly, drain, and squeeze out excess water. Cut into shorter lengths.";
"recipe.kr_bibimbap.step5.title" = "Blanch the spinach";
"recipe.kr_bibimbap.step6.body" = "Mix the spinach with the %i10, %i11, %i12, and %i13, then set aside.";
"recipe.kr_bibimbap.step6.title" = "Season the spinach";
"recipe.kr_bibimbap.step7.body" = "Blanch the %i14 until just cooked but still crisp, then drain very well.";
"recipe.kr_bibimbap.step7.title" = "Blanch the bean sprouts";
"recipe.kr_bibimbap.step8.body" = "Mix the bean sprouts with the %i15, %i16, %i17, and %i18, then set aside.";
"recipe.kr_bibimbap.step8.title" = "Season the bean sprouts";
