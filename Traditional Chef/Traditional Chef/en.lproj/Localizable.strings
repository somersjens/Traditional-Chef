"recipe.lb_kibbeh_labanieh.step1.title" = "Soak the bulgur";
"recipe.lb_kibbeh_labanieh.step10.body" = "Spoon the kibbeh and yogurt sauce into a serving bowl, drizzle with the mint butter, and serve hot with vermicelli rice.";
"recipe.lb_kibbeh_labanieh.step10.title" = "Serve";
"recipe.lb_kibbeh_labanieh.step2.body" = "Melt %i10 in a skillet and sauté the chopped %i8 until softened. Add %i9 and cook until lightly golden, then add %i7, %i11, %i13, and %i12 and cook until browned and dry. Spread out to cool.";
"recipe.lb_kibbeh_labanieh.step2.title" = "Cook the meat stuffing";
