"recipe.eg_fatta.drink.body" = "Pair with a medium-bodied red such as Grenache or a fruity Syrah that can handle the tomato-garlic sauce and rich broth. A crisp lager also works well with the hearty layers. Non-alcoholic option: sparkling water with lemon or mint tea.";
"recipe.eg_fatta.drink.summary" = "Red wine (Grenache)";
"recipe.eg_fatta.info" = "Egyptian fatta is a celebratory layered dish of crisp toasted pita, fragrant rice cooked with rich meat broth, and tender boiled beef, finished with a sharp garlic-vinegar tomato sauce poured over the top. Traditionally prepared for Eid and special occasions, it is served hot as a centerpiece meal, with the tangy sauce cutting through the richness of broth-soaked rice and bread.";
"recipe.eg_fatta.info.summary" = "Eid layered rice feast";
"recipe.eg_fatta.name" = "Fatta";
"recipe.eg_fatta.step1.body" = "Put %i1 in a pot and cover with %i2. Bring up slowly to a gentle simmer and skim any foam so the broth stays clean.";
"recipe.eg_fatta.step1.title" = "Start the meat broth";
"recipe.eg_fatta.step10.body" = "Pour the hot garlic-vinegar tomato sauce over the assembled layers and serve immediately.";
"recipe.eg_fatta.step10.title" = "Sauce and serve";
"recipe.eg_fatta.step2.body" = "Add %i3, %i4, %i5, and %i6. Keep at a very gentle simmer until the beef is tender and the broth is richly flavored.";
"recipe.eg_fatta.step2.title" = "Simmer until tender";
"recipe.eg_fatta.step3.body" = "Lift out the beef and strain the broth. Keep the broth hot for cooking the rice and for assembling the dish.";
"recipe.eg_fatta.step3.title" = "Strain and portion the broth";
"recipe.eg_fatta.step4.body" = "Melt %i8 in a saucepan, add %i7 and stir to coat. Add hot broth and %i9, bring to a gentle boil, then cover and reduce to low.";
"recipe.eg_fatta.step4.title" = "Cook the rice in broth";
"recipe.eg_fatta.step5.body" = "Cook covered until the rice is tender and the liquid is absorbed. Rest covered so it finishes steaming.";
"recipe.eg_fatta.step5.title" = "Steam rice until tender";
"recipe.eg_fatta.step6.body" = "Cut %i10 into bite-size pieces. Melt %i11 in a skillet and toast the bread until crisp and golden, turning so it browns evenly.";
"recipe.eg_fatta.step6.title" = "Toast the pita in ghee";
