"recipe.ch_capuns.drink.body" = "Serve with a dry Swiss white wine such as Chasselas or Pinot Blanc, which complements the creamy broth and savory filling. A light amber beer also works well. For a non-alcoholic option, serve hot black tea or sparkling apple juice.";
"recipe.ch_capuns.drink.summary" = "White wine (Chasselas)";
"recipe.ch_capuns.info" = "Capuns are a traditional dish from Graubünden made by wrapping a herb-rich Spätzle-style dough with cured meat in chard leaves, then poaching the rolls in a mixture of bouillon and milk. They are served hot with some of the cooking liquid and grated alpine cheese, as a hearty mountain meal from eastern Switzerland.";
"recipe.ch_capuns.info.summary" = "Graubünden chard rolls";
"recipe.ch_capuns.name" = "Capuns";
"recipe.ch_capuns.step1.body" = "Dice %i1, %i2, %i3, and %i6, then finely chop %i4 and %i5.";
"recipe.ch_capuns.step1.title" = "Prepare the filling base";
"recipe.ch_capuns.step2.body" = "Melt %i7 in a frying pan, add the onion and bacon, and cook gently until softened. Stir in the salsiz and bread, cook briefly, then remove from the heat.";
"recipe.ch_capuns.step2.title" = "Cook the aromatics";
"recipe.ch_capuns.step3.body" = "Combine %i8 and %i9 in a bowl. Add %i10, %i11, and %i12, then mix into a thick Spätzle-style dough. Fold in the cooked filling mixture, parsley, and chives.";
"recipe.ch_capuns.step3.title" = "Make the dough";
"recipe.ch_capuns.step4.body" = "Trim the thick ribs from %i13 and blanch the leaves briefly until flexible, then drain them.";
"recipe.ch_capuns.step4.title" = "Prepare the leaves";
"recipe.ch_capuns.step5.body" = "Place a portion of dough on each leaf, fold in the sides, and roll into compact parcels until all the dough is used.";
"recipe.ch_capuns.step5.title" = "Form the capuns";
"recipe.ch_capuns.step6.body" = "Pour %i14 and %i15 into a large pot and bring the liquid just to a gentle simmer.";
"recipe.ch_capuns.step6.title" = "Heat the poaching liquid";
"recipe.ch_capuns.step7.body" = "Place the capuns in the simmering liquid and cook gently until they are firm and cooked through.";
"recipe.ch_capuns.step7.title" = "Poach the capuns";
"recipe.ch_capuns.step8.body" = "Lift the capuns out carefully, arrange them on warm plates, spoon over a little of the cooking liquid, and cover with grated %i16 before serving hot.";
"recipe.ch_capuns.step8.title" = "Finish and serve";
