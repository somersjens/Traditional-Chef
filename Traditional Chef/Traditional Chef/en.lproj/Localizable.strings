"recipe.mt_prinjolata.drink.body" = "A light dessert wine such as Moscato d'Asti pairs well with the rich cream and sponge. A good non-alcoholic option is black coffee or chilled sparkling water.";
"recipe.mt_prinjolata.drink.summary" = "Dessert wine (Moscato d'Asti)";
"recipe.mt_prinjolata.info" = "Prinjolata is a traditional Maltese Carnival dessert built as a tall mound of sponge cake, crushed biscuits, pastry cream, whipped cream, and meringue, then finished lavishly with pine nuts, chocolate, and glacé cherries. It is served chilled in generous slices as a festive centrepiece during Carnival season.";
"recipe.mt_prinjolata.info.summary" = "Carnival cream mountain";
"recipe.mt_prinjolata.name" = "Prinjolata";
"recipe.mt_prinjolata.step1.body" = "Beat %i3 and %i2 until thick and airy, fold in %i1, then fold in the melted %i4. Bake the batter in the cake tin until the sponge is risen and set, then cool it completely.";
"recipe.mt_prinjolata.step1.title" = "Bake the sponge";
"recipe.mt_prinjolata.step10.body" = "Bring the prinjolata to the table well chilled and cut it into thick slices.";
"recipe.mt_prinjolata.step10.title" = "Serve";
"recipe.mt_prinjolata.step2.body" = "Whisk %i5 until foamy, add %i6 gradually, and continue whisking until glossy and firm. Spread the meringue on the lined tray and bake it slowly until dry and crisp, then cool it completely.";
"recipe.mt_prinjolata.step2.title" = "Make the meringue";
"recipe.mt_prinjolata.step3.body" = "Heat %i7 with %i11. Whisk %i8 with %i9 and %i10, pour in the hot milk, then return the mixture to the saucepan and cook until thick. Cool the pastry cream fully.";
"recipe.mt_prinjolata.step3.title" = "Cook the pastry cream";
"recipe.mt_prinjolata.step4.body" = "Break the sponge into small pieces and crush %i12 coarsely. Break the baked meringue into irregular pieces and set them aside.";
"recipe.mt_prinjolata.step4.title" = "Prepare the base pieces";
"recipe.mt_prinjolata.step5.body" = "Whip %i14 with %i15 until soft but stable.";
"recipe.mt_prinjolata.step5.title" = "Whip the cream";
"recipe.mt_prinjolata.step6.body" = "Fold part of the whipped cream into the cooled pastry cream, then add the sponge pieces, crushed biscuits, broken meringue, and %i13 and combine gently.";
"recipe.mt_prinjolata.step6.title" = "Make the filling mixture";
"recipe.mt_prinjolata.step7.body" = "Pile the mixture onto the serving platter and shape it into a high rounded mound.";
"recipe.mt_prinjolata.step7.title" = "Shape the prinjolata";
"recipe.mt_prinjolata.step8.body" = "Cover the mound with the remaining whipped cream, then finish with %i16, %i17, %i19, and grated %i18.";
"recipe.mt_prinjolata.step8.title" = "Decorate the dessert";
"recipe.mt_prinjolata.step9.body" = "Chill the prinjolata until it is firm enough to slice neatly and the flavours have settled.";
"recipe.mt_prinjolata.step9.title" = "Chill the dessert";
