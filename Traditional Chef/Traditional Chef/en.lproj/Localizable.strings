"recipe.cn_liangban_haizhe_pi.drink.body" = "A light dry white wine such as Sauvignon Blanc pairs well with the crisp texture and tangy dressing, while chilled jasmine tea is a classic non-alcoholic pairing that keeps the palate clean.";
"recipe.cn_liangban_haizhe_pi.drink.summary" = "White wine (Sauvignon)";
"recipe.cn_liangban_haizhe_pi.info" = "Liangban haizhe pi is a traditional Chinese cold appetizer made with salted jellyfish, commonly dressed with vinegar, soy sauce, sesame oil, garlic, and a little sugar, often paired with cucumber for freshness and crunch. It is typically served chilled at banquets and family meals as a refreshing contrast to richer hot dishes.";
"recipe.cn_liangban_haizhe_pi.info.summary" = "Tangy jellyfish salad";
"recipe.cn_liangban_haizhe_pi.name" = "Jellyfish salad";
"recipe.cn_liangban_haizhe_pi.step1.body" = "Rinse the %i1 thoroughly, then soak it in %i2, changing the water as needed, until the excess salt is reduced and the texture is springy.";
"recipe.cn_liangban_haizhe_pi.step1.title" = "Soak and desalinate the jellyfish";
"recipe.cn_liangban_haizhe_pi.step2.body" = "Cut the %i4 into thin shreds, toss with %i5, and let it stand briefly to draw out excess moisture.";
"recipe.cn_liangban_haizhe_pi.step2.title" = "Prepare the cucumber";
"recipe.cn_liangban_haizhe_pi.step3.body" = "Squeeze or press out excess liquid from the cucumber and set it aside for assembling the salad.";
"recipe.cn_liangban_haizhe_pi.step3.title" = "Rinse and drain the cucumber";
"recipe.cn_liangban_haizhe_pi.step4.body" = "Bring %i3 to a near boil, blanch the jellyfish very briefly until it tightens slightly, then transfer immediately to cold water and drain well.";
"recipe.cn_liangban_haizhe_pi.step4.title" = "Blanch and chill the jellyfish";
"recipe.cn_liangban_haizhe_pi.step5.body" = "Slice the jellyfish into even bite-size strips if needed so it mixes evenly with the dressing and cucumber.";
"recipe.cn_liangban_haizhe_pi.step5.title" = "Cut the jellyfish";
"recipe.cn_liangban_haizhe_pi.step6.body" = "Mince the %i6, then mix it with %i7, %i8, %i9, %i10, and %i11 until the sugar dissolves.";
"recipe.cn_liangban_haizhe_pi.step6.title" = "Make the dressing";
"recipe.cn_liangban_haizhe_pi.step7.body" = "Combine the jellyfish and cucumber, pour over the dressing, and toss thoroughly so everything is evenly coated.";
"recipe.cn_liangban_haizhe_pi.step7.title" = "Dress the salad";
"recipe.cn_liangban_haizhe_pi.step8.body" = "Let the dressed salad chill so the flavors meld and the texture stays crisp.";
"recipe.cn_liangban_haizhe_pi.step8.title" = "Chill before serving";
"recipe.cn_liangban_haizhe_pi.step9.body" = "Transfer to a serving platter and finish with %i12 and %i13 before serving cold.";
