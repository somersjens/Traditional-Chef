"recipe.kr_doenjang_jjigae.step11.body" = "Fluff the rested rice and divide it into serving bowls.";
"recipe.kr_doenjang_jjigae.step11.title" = "Fluff the rice";
"recipe.kr_doenjang_jjigae.step12.body" = "Ladle the stew into serving bowls or serve in the pot, top with the remaining scallion, and serve hot with rice.";
"recipe.kr_doenjang_jjigae.step12.title" = "Serve";
