"recipe.uz_dimlama.drink.body" = "A light fruity red such as Pinot Noir or a young Grenache works well with the lamb and sweet vegetables. If you prefer white, choose a dry aromatic white with good acidity. Non-alcoholic pairing: hot black tea is traditional and excellent.";
"recipe.uz_dimlama.drink.summary" = "Red wine (Pinot Noir)";
"recipe.uz_dimlama.info" = "Dimlama is a traditional Uzbek layered stew of lamb and seasonal vegetables cooked slowly in a tightly covered pot until everything becomes tender in its own juices. It is commonly served family-style on a large platter with bread for sharing.";
"recipe.uz_dimlama.info.summary" = "Layered lamb stew";
"recipe.uz_dimlama.name" = "Dimlama";
"recipe.uz_dimlama.step1.body" = "Cut the %i2 into large pieces. Slice the %i3, %i4, %i5, %i6, and %i7 into thick pieces. Peel the %i8 cloves. Cut the %i9 into large wedges and keep a few outer leaves whole. Chop the %i14 and %i15.";
"recipe.uz_dimlama.step1.title" = "Prepare ingredients";
"recipe.uz_dimlama.step2.body" = "Heat the heavy pot with the %i1 over medium heat. Add the lamb in a single layer and brown well on multiple sides to build flavor.";
"recipe.uz_dimlama.step2.title" = "Brown lamb";
"recipe.uz_dimlama.step3.body" = "Sprinkle in the %i10, %i11, %i12, and %i13. Add the onions over the lamb and cook briefly until they begin to soften.";
"recipe.uz_dimlama.step3.title" = "Season base";
"recipe.uz_dimlama.step4.body" = "Layer the carrots, potatoes, tomatoes, bell pepper, and garlic over the meat and onions. Finish with the cabbage wedges, then cover the top with the reserved whole cabbage leaves to trap steam. Do not stir.";
"recipe.uz_dimlama.step4.title" = "Layer vegetables";
"recipe.uz_dimlama.step5.body" = "Cover tightly and cook on low heat until the lamb is tender and the vegetables are fully soft, letting the stew cook in its own juices. Keep the layers intact and do not stir during cooking.";
"recipe.uz_dimlama.step5.title" = "Slow cook covered";
"recipe.uz_dimlama.step6.body" = "Turn off the heat and let the dimlama rest covered so the juices settle and the flavors meld.";
"recipe.uz_dimlama.step6.title" = "Rest off heat";
"recipe.uz_dimlama.step7.body" = "Warm the %i16 briefly until soft and fragrant, then cut or tear it for serving.";
"recipe.uz_dimlama.step7.title" = "Warm bread";
"recipe.uz_dimlama.step8.body" = "Remove the top cabbage leaves. Transfer the dimlama carefully to a large plate, keeping the layered look as much as possible. Scatter dill and parsley on top and serve immediately with the bread.";
"recipe.uz_dimlama.step8.title" = "Serve dimlama";
