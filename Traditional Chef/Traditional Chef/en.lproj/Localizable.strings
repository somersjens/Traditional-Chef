"recipe.eg_mahashi.step6.title" = "Arrange in the pot";
"recipe.eg_mahashi.step7.body" = "Pour hot tomato broth over the mahashi. Cover and simmer gently until the rice is tender and the vegetables are cooked through, adding water if needed to keep the liquid level steady.";
"recipe.eg_mahashi.step7.title" = "Simmer until tender";
"recipe.eg_mahashi.step8.body" = "Remove from heat and let the pot rest so the liquid settles and the stuffing finishes steaming. Serve hot with plenty of the tomato broth.";
"recipe.eg_mahashi.step8.title" = "Rest and serve";
