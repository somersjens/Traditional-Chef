"recipe.lb_sayyadiyeh.info" = "Lebanese sayyadiyeh is a coastal classic of spiced rice cooked in fragrant fish stock and deeply caramelized onions, topped with fried fish and finished with toasted nuts. It is served hot as a centerpiece dish, traditionally accompanied by a tangy tahini sauce to balance the rich, savory flavors.";
"recipe.lb_sayyadiyeh.info.summary" = "Coastal fish rice";
"recipe.lb_sayyadiyeh.name" = "Sayyadiyeh";
"recipe.lb_sayyadiyeh.step1.body" = "Place the %i1 with %i2, %i3, %i4, and %i5 in a pot. Bring to a boil, skim any foam, then simmer until the fish is just cooked and the stock is flavorful. Lift out the fish and strain the stock.";
"recipe.lb_sayyadiyeh.step1.title" = "Make the fish stock";
"recipe.lb_sayyadiyeh.step2.body" = "When cool enough to handle, separate the fish into serving pieces and remove any bones. Pat the pieces dry so they fry well.";
"recipe.lb_sayyadiyeh.step2.title" = "Cool and portion the fish";
"recipe.lb_sayyadiyeh.step3.body" = "Slice the %i6 thinly and cook them slowly in %i7, stirring often, until deeply golden and sweet. Remove a portion for topping and keep the rest in the pan for the rice base.";
"recipe.lb_sayyadiyeh.step3.title" = "Caramelize the onions";
"recipe.lb_sayyadiyeh.step4.body" = "Toast the %i21 in a dry pan until golden and fragrant, then set aside.";
"recipe.lb_sayyadiyeh.step4.title" = "Toast the pine nuts";
"recipe.lb_sayyadiyeh.step5.body" = "Rinse the %i8. In a pot, warm the caramelized onions left in the pan, add %i9, %i10, %i11, %i12, and %i13, then add the rice and stir to coat. Add hot fish stock and cook covered at a gentle simmer until the rice is tender and the liquid is absorbed, then rest covered before fluffing.";
"recipe.lb_sayyadiyeh.step5.title" = "Cook the sayyadiyeh rice";
"recipe.lb_sayyadiyeh.step6.body" = "Heat %i14 in a pan. Lightly coat the fish pieces in %i15 and fry until crisp and golden, then drain on paper towels.";
"recipe.lb_sayyadiyeh.step6.title" = "Fry the fish";
"recipe.lb_sayyadiyeh.step7.body" = "Whisk %i16 with %i17 and %i20 until thickened, then whisk in crushed %i18. Add %i19 gradually while whisking until smooth and pourable.";
"recipe.lb_sayyadiyeh.step7.title" = "Make the tahini sauce";
