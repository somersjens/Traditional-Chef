"recipe.lk_watalappan.info" = "Watalappan is a traditional Sri Lankan Muslim dessert custard made with coconut milk, jaggery, eggs, and warm spices, then steamed or baked until just set. It is commonly served chilled or at room temperature for festive meals, especially during celebrations and family gatherings.";
"recipe.lk_watalappan.info.summary" = "Spiced jaggery custard";
