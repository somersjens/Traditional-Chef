"recipe.ua_kyiv_cake.drink.body" = "A lightly sweet dessert wine such as Muscat pairs well with the nutty meringue and rich buttercream. For a non-alcoholic pairing, serve black tea or strong coffee.";
"recipe.ua_kyiv_cake.drink.summary" = "Dessert wine (Muscat)";
"recipe.ua_kyiv_cake.info" = "Kyiv Cake is a traditional Ukrainian dessert from Kyiv made with two crisp hazelnut meringue layers and rich Charlotte buttercream, usually finished with cocoa cream and classic piped decoration. It became an iconic celebratory cake in Ukraine and is traditionally served in slices with tea or coffee for holidays, birthdays, and festive visits.";
"recipe.ua_kyiv_cake.info.summary" = "Kyiv nut meringue cake";
"recipe.ua_kyiv_cake.name" = "Kyiv cake";
