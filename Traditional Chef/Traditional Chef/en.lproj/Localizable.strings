"recipe.sr_pom.drink.summary" = "White wine";
"recipe.sr_pom.info" = "Pom is a traditional Surinamese oven dish made from pomtajer with citrus and a savory chicken filling, baked until golden and served in slices. It is one of the best-known festive dishes in Suriname and is traditionally eaten hot, commonly with rice and pickled accompaniments.";
"recipe.sr_pom.info.summary" = "Festive pom casserole";
"recipe.sr_pom.name" = "Pom";
