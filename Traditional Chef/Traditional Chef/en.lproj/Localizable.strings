"recipe.se_prinsesstarta.step1.title" = "Prepare the tin and batter";
"recipe.se_prinsesstarta.step10.body" = "Shape %i14 into a rose and place it on top of the cake. Dust lightly with icing sugar.";
"recipe.se_prinsesstarta.step10.title" = "Finish the decoration";
"recipe.se_prinsesstarta.step11.body" = "Refrigerate the cake so it firms up and the layers settle before slicing and serving.";
"recipe.se_prinsesstarta.step11.title" = "Chill before serving";
"recipe.se_prinsesstarta.step2.body" = "Pour the batter into the tin and bake until the sponge is risen, golden, and set through. Cool the cake completely.";
"recipe.se_prinsesstarta.step2.title" = "Bake the sponge";
"recipe.se_prinsesstarta.step3.body" = "Whisk %i5, %i6, %i7, %i8, %i9, and %i10 in a saucepan. Cook gently while stirring until thick, then pass through a fine sieve.";
"recipe.se_prinsesstarta.step3.title" = "Make the pastry cream";
"recipe.se_prinsesstarta.step4.body" = "Cool the pastry cream thoroughly until cold and firm enough to spread.";
"recipe.se_prinsesstarta.step4.title" = "Chill the pastry cream";
"recipe.se_prinsesstarta.step5.body" = "Cut the sponge into three even layers with a serrated knife.";
"recipe.se_prinsesstarta.step5.title" = "Slice the sponge";
"recipe.se_prinsesstarta.step6.body" = "Place the bottom sponge layer on a cake plate and spread it with %i11, then cover with a layer of pastry cream.";
"recipe.se_prinsesstarta.step6.title" = "Fill the first layer";
"recipe.se_prinsesstarta.step7.body" = "Add the middle sponge layer and spread over more pastry cream, shaping it slightly higher in the centre in the traditional style.";
"recipe.se_prinsesstarta.step7.title" = "Fill the second layer";
"recipe.se_prinsesstarta.step8.body" = "Whip %i12 until firm, spread a generous layer over the filling, then place the final sponge layer on top and cover the whole cake with the remaining whipped cream in a neat dome.";
"recipe.se_prinsesstarta.step8.title" = "Add the cream and top layer";
"recipe.se_prinsesstarta.step9.body" = "Roll %i13 into a thin round using a little %i15, drape it over the cake, smooth it over the dome, and trim the excess.";
"recipe.se_prinsesstarta.step9.title" = "Cover with marzipan";
