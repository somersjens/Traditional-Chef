"recipe.in_rogan_josh.step5.title" = "Prepare the spice mixture";
"recipe.in_rogan_josh.step6.body" = "Heat %i5 in a heavy pot until hot, lower the heat, then add %i6, %i7, %i8, %i9, and %i10 until fragrant.";
"recipe.in_rogan_josh.step6.title" = "Heat oil and whole spices";
"recipe.in_rogan_josh.step7.body" = "Add the marinated mutton and cook on medium heat, stirring often, until the meat changes color and the yogurt begins to reduce and cling.";
"recipe.in_rogan_josh.step7.title" = "Bhuna the mutton";
"recipe.in_rogan_josh.step8.body" = "Stir in the prepared spice paste and cook briefly so the oil takes on a deep red color and the spices bloom without burning.";
"recipe.in_rogan_josh.step8.title" = "Add the ground spice paste";
"recipe.in_rogan_josh.step9.body" = "Add %i17 and the remaining %i16, cover, and simmer gently until the mutton becomes tender and the gravy thickens.";
"recipe.in_rogan_josh.step9.title" = "Slow-cook the curry";
