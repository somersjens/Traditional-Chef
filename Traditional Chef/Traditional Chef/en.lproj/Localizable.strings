"recipe.hu_porkolt.step2.title" = "Sweat the onions";
"recipe.hu_porkolt.step3.body" = "Take the pot off the heat, stir in %i4, %i5, and %i10, then add a splash of %i11 and stir quickly so the paprika does not scorch.";
"recipe.hu_porkolt.step3.title" = "Bloom the paprika and caraway";
"recipe.hu_porkolt.step4.body" = "Return to the heat, add the beef and garlic, and stir until the meat is coated and begins to change colour.";
"recipe.hu_porkolt.step4.title" = "Start the stew";
"recipe.hu_porkolt.step5.body" = "Add the tomatoes, peppers, %i9, and water, cover, and braise gently until the beef is very tender and the sauce is thick, stirring occasionally.";
"recipe.hu_porkolt.step5.title" = "Braise until tender";
"recipe.hu_porkolt.step6.body" = "Mix %i12 and %i15, add %i13, then add %i14 gradually to make a thick, sticky batter.";
"recipe.hu_porkolt.step6.title" = "Mix the nokedli batter";
"recipe.hu_porkolt.step7.body" = "Bring a large pot of water to a boil, season it with %i17, and press or grate the batter into the water. Cook until the dumplings float and are tender, then lift them out with a slotted spoon.";
"recipe.hu_porkolt.step7.title" = "Cook the nokedli";
"recipe.hu_porkolt.step8.body" = "Serve the pörkölt hot with nokedli and plenty of sauce.";
"recipe.hu_porkolt.step8.title" = "Serve the pörkölt";
