"recipe.be_moules_frites.drink.body" = "Pair with a crisp dry white such as Muscadet or Sauvignon Blanc, or enjoy a Belgian blond beer alongside the mussels and fries. For a non-alcoholic option, serve sparkling water with lemon or a crisp alcohol-free pils to match the briny, buttery broth.";
"recipe.be_moules_frites.drink.summary" = "White wine (Muscadet)";
"recipe.be_moules_frites.info" = "Moules-frites is Belgium’s iconic brasserie meal: fresh mussels steamed quickly with aromatic vegetables, butter, parsley, and dry white wine, served straight from the pot with crisp double-fried Belgian frites and mayonnaise. It is eaten immediately while the mussels are hot and the fries are crisp, with the fragrant cooking liquor spooned over as you go.";
"recipe.be_moules_frites.info.summary" = "Belgian pot of mussels";
"recipe.be_moules_frites.name" = "Mussels and fries";
