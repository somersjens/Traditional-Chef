"recipe.in_tandoori_chicken.drink.body" = "A crisp lager or off-dry Riesling pairs well with the smoky spice marinade and charred chicken. A dry rosé also works. For a non-alcoholic option, serve chilled masala soda or salted lassi.";
"recipe.in_tandoori_chicken.drink.summary" = "Beer (Lager)";
"recipe.in_tandoori_chicken.info" = "Tandoori chicken is a classic North Indian dish of bone-in chicken marinated in yogurt, ginger, garlic, and warm spices, then roasted at high heat until smoky, charred, and juicy. It is traditionally served hot as a starter with mint chutney, onion rings, and lemon wedges at restaurants, gatherings, and festive meals.";
"recipe.in_tandoori_chicken.info.summary" = "Charred spiced chicken";
"recipe.in_tandoori_chicken.name" = "Tandoori chicken";
"recipe.in_tandoori_chicken.step1.body" = "Pat the %i1 dry and make deep slashes so the marinades penetrate to the bone.";
"recipe.in_tandoori_chicken.step1.title" = "Prepare the chicken";
"recipe.in_tandoori_chicken.step10.body" = "Cook the chicken at high heat until charred in spots and nearly cooked through, turning once for even color.";
"recipe.in_tandoori_chicken.step10.title" = "Roast the chicken";
"recipe.in_tandoori_chicken.step11.body" = "Brush the chicken with melted %i15 and roast briefly again until fully cooked and glossy.";
"recipe.in_tandoori_chicken.step11.title" = "Baste and finish";
"recipe.in_tandoori_chicken.step12.body" = "Slice the %i16 into rings and cut the %i17 into wedges for serving.";
"recipe.in_tandoori_chicken.step12.title" = "Prepare accompaniments";
"recipe.in_tandoori_chicken.step13.body" = "Sprinkle %i18 over the hot tandoori chicken and serve immediately with mint chutney, onion rings, and lemon wedges.";
"recipe.in_tandoori_chicken.step13.title" = "Season and serve";
"recipe.in_tandoori_chicken.step2.body" = "Rub the chicken with %i2, %i3, and %i4, working it into the slashes.";
"recipe.in_tandoori_chicken.step2.title" = "Apply the first marinade";
"recipe.in_tandoori_chicken.step3.body" = "Let the chicken rest so the initial seasoning penetrates and firms the surface.";
"recipe.in_tandoori_chicken.step3.title" = "Rest the first marinade";
"recipe.in_tandoori_chicken.step4.body" = "Dry-roast the %i13 in a small pan until aromatic, then cool briefly.";
"recipe.in_tandoori_chicken.step4.title" = "Roast the gram flour";
"recipe.in_tandoori_chicken.step5.body" = "Mix %i5, %i6, %i7, %i8, %i9, %i10, %i11, %i12, roasted gram flour, and salt into a thick smooth marinade.";
"recipe.in_tandoori_chicken.step5.title" = "Make the second marinade";
"recipe.in_tandoori_chicken.step6.body" = "Cover the chicken thoroughly with the second marinade, pressing it well into all slashes and surfaces.";
"recipe.in_tandoori_chicken.step6.title" = "Coat the chicken";
"recipe.in_tandoori_chicken.step7.body" = "Cover and refrigerate so the yogurt and spices deeply flavor the chicken.";
"recipe.in_tandoori_chicken.step7.title" = "Marinate the chicken";
"recipe.in_tandoori_chicken.step8.body" = "Blend %i19, %i20, %i21, %i22, yogurt, lemon juice, salt, and %i26 into a smooth chutney, then chill.";
"recipe.in_tandoori_chicken.step8.title" = "Make the mint chutney";
"recipe.in_tandoori_chicken.step9.body" = "Preheat the grill or oven to high heat and set a rack over a tray for roasting.";
"recipe.in_tandoori_chicken.step9.title" = "Preheat the cooker";
