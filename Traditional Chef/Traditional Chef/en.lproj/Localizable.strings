"recipe.th_yam_woon_sen.drink.body" = "A dry to off-dry Riesling pairs well with the sharp lime, chili heat, and savory seafood flavors while staying refreshing. For a non-alcoholic option, serve cold water, unsweetened iced tea, or chilled jasmine tea.";
"recipe.th_yam_woon_sen.drink.summary" = "White wine (Riesling)";
"recipe.th_yam_woon_sen.info" = "Yam Woon Sen is a traditional Thai warm salad of glass noodles tossed with shrimp, minced pork, shallots, tomatoes, celery, and a hot-sour dressing of lime juice, fish sauce, and chili. It is commonly served as a shared starter or side dish and is eaten immediately while the noodles are still springy.";
"recipe.th_yam_woon_sen.info.summary" = "Glass noodle salad";
"recipe.th_yam_woon_sen.name" = "Glass noodle salad";
"recipe.th_yam_woon_sen.step1.body" = "Thinly slice the %i11, cut the %i12 into wedges, slice the %i13, chop the %i14, and finely chop the %i9 and %i10.";
"recipe.th_yam_woon_sen.step1.title" = "Prepare vegetables and aromatics";
"recipe.th_yam_woon_sen.step2.body" = "Combine the %i6, %i7, %i8, chopped bird's eye chili, and garlic in a bowl and stir until the sugar dissolves.";
"recipe.th_yam_woon_sen.step2.title" = "Make the dressing";
"recipe.th_yam_woon_sen.step3.body" = "Soak the %i1 in water until pliable, then drain well.";
"recipe.th_yam_woon_sen.step3.title" = "Soak the noodles";
"recipe.th_yam_woon_sen.step4.body" = "Cook the %i4 with %i5 in a wok or skillet, stirring to break it up until just cooked through.";
"recipe.th_yam_woon_sen.step4.title" = "Cook the pork";
"recipe.th_yam_woon_sen.step5.body" = "Bring %i2 to a boil in a pot for cooking the noodles and shrimp.";
"recipe.th_yam_woon_sen.step5.title" = "Boil water";
"recipe.th_yam_woon_sen.step6.body" = "Add the %i3 to the boiling water and cook until just done, then lift out and drain.";
"recipe.th_yam_woon_sen.step6.title" = "Cook the shrimp";
"recipe.th_yam_woon_sen.step7.body" = "Add the soaked glass noodles to the same boiling water and cook until just tender, then drain well.";
"recipe.th_yam_woon_sen.step7.title" = "Cook the noodles";
"recipe.th_yam_woon_sen.step8.body" = "In a mixing bowl, combine the warm noodles, cooked pork, shrimp, shallots, tomatoes, celery, and coriander, then pour over the dressing and toss thoroughly.";
"recipe.th_yam_woon_sen.step8.title" = "Toss the warm salad";
"recipe.th_yam_woon_sen.step9.body" = "Transfer the yam woon sen to a serving plate and serve immediately while the noodles are still springy.";
"recipe.th_yam_woon_sen.step9.title" = "Serve";
