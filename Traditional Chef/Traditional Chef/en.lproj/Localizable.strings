"recipe.gr_kleftiko.drink.body" = "Pair with a medium-bodied Greek red such as Agiorgitiko or Xinomavro to stand up to lamb and garlic. A dry rosé also works well. For a non-alcoholic option, serve sparkling water with lemon or a chilled herbal iced tea.";
"recipe.gr_kleftiko.drink.summary" = "Red wine (Agiorgitiko)";
"recipe.gr_kleftiko.info" = "Kleftiko is a traditional Greek method of slow-roasting lamb sealed with potatoes, garlic, lemon, and oregano so it steams in its own juices until falling apart. The parcels are opened near the end to brown slightly, concentrating the lemony, garlicky juices that coat the lamb and potatoes. It is served hot with bread to mop up the rich pan juices.";
"recipe.gr_kleftiko.info.summary" = "Sealed lamb parcels";
"recipe.gr_kleftiko.name" = "Lamb kleftiko";
"recipe.gr_kleftiko.step1.body" = "Cut %i2 into chunks and slice %i3. Season %i1 with %i7, %i8, %i6, %i5, and %i4 juice.";
"recipe.gr_kleftiko.step1.title" = "Prep and season";
"recipe.gr_kleftiko.step2.body" = "Arrange the lamb, potatoes, and garlic in a baking dish, add %i9, and seal tightly with foil so the steam stays trapped.";
"recipe.gr_kleftiko.step2.title" = "Assemble the parcels";
"recipe.gr_kleftiko.step3.body" = "Roast slowly until the lamb is very tender and the potatoes are cooked through in the juices.";
"recipe.gr_kleftiko.step3.title" = "Slow-roast the lamb";
"recipe.gr_kleftiko.step4.body" = "Uncover and roast until the top edges brown lightly and the juices reduce slightly.";
"recipe.gr_kleftiko.step4.title" = "Open and brown";
"recipe.gr_kleftiko.step5.body" = "Serve hot with %i10 for mopping up the juices.";
"recipe.gr_kleftiko.step5.title" = "Serve the kleftiko";
