"recipe.jp_sukiyaki.step6.title" = "Add vegetables tofu and noodles";
"recipe.jp_sukiyaki.step7.body" = "Add shungiku near the end and cook the remaining beef in batches, briefly simmering each addition so it stays tender and flavorful.";
"recipe.jp_sukiyaki.step7.title" = "Add delicate greens and remaining beef";
"recipe.jp_sukiyaki.step8.body" = "Continue adding ingredients and warishita in rounds as the pan empties, keeping a gentle simmer and serving each cooked item immediately for best texture.";
"recipe.jp_sukiyaki.step8.title" = "Cook and eat in rounds";
"recipe.jp_sukiyaki.step9.body" = "Dip the cooked beef and vegetables in the beaten egg and eat with cooked rice while the sukiyaki is hot.";
