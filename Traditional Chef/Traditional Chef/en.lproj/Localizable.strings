"recipe.de_schweinshaxe.step2.title" = "Set up the roasting base";
"recipe.de_schweinshaxe.step3.body" = "Place the knuckles on top of the vegetables and roast until the meat is very tender, basting occasionally and topping up with liquid if needed so the base does not burn.";
"recipe.de_schweinshaxe.step3.title" = "Slow-roast the pork";
"recipe.de_schweinshaxe.step4.body" = "Increase the oven heat and roast until the skin turns blistered and crisp, watching closely so it does not burn.";
"recipe.de_schweinshaxe.step4.title" = "Crisp the skin";
"recipe.de_schweinshaxe.step5.body" = "Boil the potatoes until very tender, drain them, and let them steam dry briefly.";
"recipe.de_schweinshaxe.step5.title" = "Boil the potatoes";
"recipe.de_schweinshaxe.step6.body" = "Rice the hot potatoes and mix them with %i13, %i14, %i16, and %i15 until a smooth dough forms.";
"recipe.de_schweinshaxe.step6.title" = "Make the dumpling dough";
"recipe.de_schweinshaxe.step7.body" = "Shape the dough into dumplings with wet hands, keeping them compact so they hold together.";
