"recipe.th_tom_kha_gai.drink.body" = "A crisp Sauvignon Blanc pairs well with the citrusy herbs and creamy coconut broth without overwhelming the soup. For a non-alcoholic option, serve hot jasmine tea or plain warm water.";
"recipe.th_tom_kha_gai.drink.summary" = "White wine (Sauvignon)";
"recipe.th_tom_kha_gai.info" = "Tom Kha Gai is a traditional Thai coconut soup with chicken simmered in coconut milk and broth infused with galangal, lemongrass, and makrut lime leaves, then balanced with fish sauce and lime juice. It is commonly served hot as part of a shared meal with jasmine rice.";
"recipe.th_tom_kha_gai.info.summary" = "Coconut chicken soup";
"recipe.th_tom_kha_gai.name" = "Tom kha gai";
"recipe.th_tom_kha_gai.step1.body" = "Slice the %i1 into bite-size pieces. Slice the %i4, trim and bruise the %i5, tear the %i6, trim the %i7, slice the %i8, and chop the %i11.";
"recipe.th_tom_kha_gai.step1.title" = "Prepare ingredients";
"recipe.th_tom_kha_gai.step2.body" = "Rinse the %i12 until the water runs mostly clear. Put it in a saucepan with %i13 and bring it to a boil.";
"recipe.th_tom_kha_gai.step2.title" = "Start the rice";
"recipe.th_tom_kha_gai.step3.body" = "Cover and cook on low heat until the liquid is absorbed and the rice is tender. Rest covered off the heat.";
"recipe.th_tom_kha_gai.step3.title" = "Cook the rice";
"recipe.th_tom_kha_gai.step4.body" = "Add %i3, galangal, lemongrass, and makrut lime leaves to the soup pot and bring to a gentle simmer so the aromatics release their flavor.";
"recipe.th_tom_kha_gai.step4.title" = "Infuse the broth";
"recipe.th_tom_kha_gai.step5.body" = "Pour in the %i2 and heat gently, keeping the soup just below a hard boil.";
"recipe.th_tom_kha_gai.step5.title" = "Add coconut milk";
"recipe.th_tom_kha_gai.step6.body" = "Add the chicken and mushrooms and simmer gently until the chicken is cooked through and the mushrooms are tender.";
"recipe.th_tom_kha_gai.step6.title" = "Cook the chicken and mushrooms";
"recipe.th_tom_kha_gai.step7.body" = "Season with %i9 and bird eye chili, then simmer briefly so the flavors combine.";
"recipe.th_tom_kha_gai.step7.title" = "Season the soup";
"recipe.th_tom_kha_gai.step8.body" = "Turn off the heat and stir in the %i10 and most of the coriander leaves.";
"recipe.th_tom_kha_gai.step8.title" = "Finish with lime and herbs";
"recipe.th_tom_kha_gai.step9.body" = "Ladle the tom kha gai into a serving bowl, top with the remaining coriander leaves, and serve hot with jasmine rice.";
"recipe.th_tom_kha_gai.step9.title" = "Serve";
