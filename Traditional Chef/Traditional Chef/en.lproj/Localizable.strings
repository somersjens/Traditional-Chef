"recipe.kh_samlor_kari.step4.title" = "Cook rice";
"recipe.kh_samlor_kari.step5.body" = "Turn off the heat and let the covered rice rest, then fluff before serving.";
"recipe.kh_samlor_kari.step5.title" = "Rest rice";
