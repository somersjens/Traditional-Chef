"recipe.bo_sajta_de_pollo.step4.title" = "Blend the chili base";
"recipe.bo_sajta_de_pollo.step5.body" = "Heat %i9 in the large pot and brown the chicken pieces on both sides until lightly colored.";
"recipe.bo_sajta_de_pollo.step5.title" = "Brown the chicken";
"recipe.bo_sajta_de_pollo.step6.body" = "Add the onion and cook until softened, then pour in the blended chili base and cook until the sauce turns fragrant and glossy.";
"recipe.bo_sajta_de_pollo.step6.title" = "Build the stew";
"recipe.bo_sajta_de_pollo.step7.body" = "Add water and bring the stew to a gentle boil. Lower the heat and simmer until the chicken is tender and the sauce has developed full flavor.";
"recipe.bo_sajta_de_pollo.step7.title" = "Simmer the chicken";
"recipe.bo_sajta_de_pollo.step8.body" = "Add the potatoes and %i6 to the stew and continue cooking until the potatoes are tender and the sauce has thickened around the chicken.";
"recipe.bo_sajta_de_pollo.step8.title" = "Cook the potatoes and peas";
"recipe.bo_sajta_de_pollo.step9.body" = "Boil the soaked chuño in water until tender, then drain and keep warm.";
"recipe.bo_sajta_de_pollo.step9.title" = "Cook the chuño";
