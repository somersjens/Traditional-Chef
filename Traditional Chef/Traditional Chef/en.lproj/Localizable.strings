"recipe.gb_summer_pudding.drink.summary" = "Dessert wine";
"recipe.gb_summer_pudding.info" = "A traditional British summer pudding made by lining a basin with white bread, filling it with cooked mixed summer berries and their juices, then pressing and chilling until set. It is unmoulded and served cold in slices, classically with pouring cream.";
"recipe.gb_summer_pudding.info.summary" = "Summer berry pudding";
"recipe.gb_summer_pudding.name" = "Summer pudding";
"recipe.gb_summer_pudding.step1.body" = "Hull the %i1 and cut larger ones, strip the %i3 from their stalks, and combine all the berries.";
"recipe.gb_summer_pudding.step1.title" = "Prepare berries";
"recipe.gb_summer_pudding.step10.body" = "Slice and serve cold with the %i8 poured alongside.";
"recipe.gb_summer_pudding.step10.title" = "Serve with cream";
