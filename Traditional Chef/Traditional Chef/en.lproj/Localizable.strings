"recipe.bo_pique_macho.drink.body" = "A cold light lager is the classic match for pique macho because it cuts through the richness of the beef, sausage, and fried potatoes. A young fruity red wine can also work. For a non-alcoholic option, serve sparkling lime water.";
"recipe.bo_pique_macho.drink.summary" = "Beer (Lager)";
"recipe.bo_pique_macho.info" = "Pique Macho is a traditional Bolivian dish from Cochabamba made with fried potatoes topped with sautéed beef, sausage, onion, tomato, locoto, and hard-boiled egg. It is served hot as a generous shared platter, usually with the classic table condiments that define its customary presentation.";
"recipe.bo_pique_macho.info.summary" = "Loaded beef platter";
"recipe.bo_pique_macho.name" = "Pique macho";
"recipe.bo_pique_macho.step1.body" = "Cut %i1 into bite-size pieces, slice %i2, peel and cut %i3 into thick fries, slice %i4, cut %i5 into wedges, and slice %i6.";
"recipe.bo_pique_macho.step1.title" = "Prepare the ingredients";
"recipe.bo_pique_macho.step2.body" = "Place %i7 in a pot, bring to a boil, and cook until hard-boiled. Cool, peel, and cut them into wedges.";
"recipe.bo_pique_macho.step2.title" = "Boil the eggs";
"recipe.bo_pique_macho.step3.body" = "Heat %i8 in the deep pan and fry the potatoes in batches until golden and cooked through. Drain and season with part of %i10.";
"recipe.bo_pique_macho.step3.title" = "Fry the potatoes";
"recipe.bo_pique_macho.step4.body" = "Cook the sausage slices in the skillet until browned, then remove and keep warm.";
"recipe.bo_pique_macho.step4.title" = "Cook the sausage";
"recipe.bo_pique_macho.step5.body" = "Season the beef with %i9, the remaining salt, and %i11. Cook it in the same skillet over high heat until browned and just cooked through.";
"recipe.bo_pique_macho.step5.title" = "Cook the beef";
"recipe.bo_pique_macho.step6.body" = "Return the sausage to the skillet and add the red onion, tomatoes, and locoto. Toss briefly over the heat so the vegetables stay fresh but warm slightly.";
"recipe.bo_pique_macho.step6.title" = "Combine the topping";
"recipe.bo_pique_macho.step7.body" = "Spread the fried potatoes on a large platter and pile the beef and sausage mixture over them. Arrange the egg wedges on top.";
"recipe.bo_pique_macho.step7.title" = "Assemble the platter";
"recipe.bo_pique_macho.step8.body" = "Serve the pique macho immediately with %i12, %i13, and %i14 over the top or at the side in the traditional style.";
"recipe.bo_pique_macho.step8.title" = "Serve traditionally";
