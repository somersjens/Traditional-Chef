"recipe.pe_pachamanca.drink.body" = "Pair with a medium-bodied Tempranillo or Malbec that can handle the smoky, herbaceous marinade and mixed meats. A crisp lager also works well outdoors. For a non-alcoholic option, serve chicha morada or sparkling water with lime.";
"recipe.pe_pachamanca.drink.summary" = "Red wine (Tempranillo)";
"recipe.pe_pachamanca.info" = "Pachamanca is a traditional Andean Peruvian feast where marinated meats and native tubers are cooked together in an earth oven over superheated stones, creating smoky, herbal, deeply savory flavors. The meats are seasoned with huacatay and Andean herbs, ají pastes, garlic, and spices, then cooked alongside potatoes, sweet potatoes, corn, and fava beans, and served with a spicy uchucuta-style ají sauce.";
"recipe.pe_pachamanca.info.summary" = "Earth-oven feast";
"recipe.pe_pachamanca.name" = "Pachamanca";
"recipe.pe_pachamanca.step1.body" = "Dig a pit and build a strong fire inside it. Arrange the stones in the fire so they heat thoroughly until very hot.";
"recipe.pe_pachamanca.step1.title" = "Prepare the earth oven";
"recipe.pe_pachamanca.step10.body" = "Grind %i18 with %i19, %i20, %i24, %i21, %i22, and %i23 into a thick, spicy sauce.";
"recipe.pe_pachamanca.step10.title" = "Make uchucuta ají";
"recipe.pe_pachamanca.step11.body" = "Uncover the earth, remove the plastic and cloth carefully, then lift out the meats and vegetables. Serve immediately with the uchucuta ají on the side.";
"recipe.pe_pachamanca.step11.title" = "Open and serve";
"recipe.pe_pachamanca.step2.body" = "Grind the %i1 and %i2 with %i5, %i3, %i4, %i6, %i7, %i8, %i9, and %i10 into a thick marinade.";
"recipe.pe_pachamanca.step2.title" = "Make the herb marinade";
"recipe.pe_pachamanca.step3.body" = "Coat the %i11, %i12, and %i13 thoroughly with the marinade, working it into the surfaces so they season evenly.";
"recipe.pe_pachamanca.step3.title" = "Marinate the meats";
"recipe.pe_pachamanca.step4.body" = "Refrigerate the marinated meats so the flavors penetrate.";
"recipe.pe_pachamanca.step4.title" = "Rest the marinade";
"recipe.pe_pachamanca.step5.body" = "Scrub the %i14 and %i15 and keep them whole. Husk and trim the %i16, and rinse the %i17.";
"recipe.pe_pachamanca.step5.title" = "Prep the vegetables";
"recipe.pe_pachamanca.step6.body" = "Soak the cotton cloth with %i25 and wring it so it is wet but not dripping, ready to trap steam in the pit.";
"recipe.pe_pachamanca.step6.title" = "Prepare the cover";
"recipe.pe_pachamanca.step7.body" = "When the stones are blazing hot and the fire has burned down, spread the hottest stones in the pit. Arrange the meats on the stones, then layer in potatoes, sweet potatoes, corn, and fava beans, adding more hot stones between layers to keep heat throughout.";
"recipe.pe_pachamanca.step7.title" = "Layer the pachamanca";
"recipe.pe_pachamanca.step8.body" = "Cover everything with the wet cloth, then seal tightly with the plastic sheet, and finally bury with earth so no steam escapes.";
"recipe.pe_pachamanca.step8.title" = "Seal the pit";
"recipe.pe_pachamanca.step9.body" = "Leave sealed to steam-roast until the meats are cooked through and the vegetables are tender.";
"recipe.pe_pachamanca.step9.title" = "Cook in the earth oven";
