"recipe.eg_koshari.step1.title" = "Prep onions and garlic";
"recipe.eg_koshari.step2.body" = "Heat %i26 in a skillet and fry the onions until deeply golden and crisp, stirring so they brown evenly. Drain well and season lightly with %i27.";
"recipe.eg_koshari.step2.title" = "Fry the onions";
"recipe.eg_koshari.step3.body" = "Rinse the %i1, cover with %i2, season with %i3, and simmer until tender but not mushy. Drain and set aside.";
"recipe.eg_koshari.step3.title" = "Cook the lentils";
"recipe.eg_koshari.step4.body" = "Warm %i6 in a pot, toast %i5 until golden, then stir in %i4 to coat. Add water and salt, bring to a boil, cover, and cook on low until tender, then rest covered.";
"recipe.eg_koshari.step4.title" = "Cook rice with vermicelli";
"recipe.eg_koshari.step5.body" = "Warm %i16 in a saucepan, add minced garlic briefly, then add %i13 and %i14. Simmer until thick and smooth, then season with %i17, %i18, and %i19.";
"recipe.eg_koshari.step5.title" = "Simmer the tomato sauce";
