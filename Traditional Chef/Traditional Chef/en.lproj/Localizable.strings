"recipe.se_prinsesstarta.drink.body" = "A light dessert wine such as late harvest Riesling pairs well with the sweet marzipan and cream. Coffee is also a classic match. For a non-alcoholic option, serve black coffee or hot tea.";
"recipe.se_prinsesstarta.drink.summary" = "Dessert wine";
"recipe.se_prinsesstarta.info" = "Prinsesstårta is a classic Swedish celebration cake made from layers of light sponge, raspberry jam, vanilla pastry cream, and whipped cream, all covered with green marzipan and finished with a pink marzipan rose. It is strongly associated with birthdays, festive gatherings, and fika tables across Sweden.";
"recipe.se_prinsesstarta.info.summary" = "Swedish princess cake";
"recipe.se_prinsesstarta.name" = "Princess cake";
