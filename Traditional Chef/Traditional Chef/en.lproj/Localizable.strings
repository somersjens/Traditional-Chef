"recipe.ma_couscous.drink.body" = "A medium-bodied red such as Grenache or Syrah pairs well with the warm spices and savory lamb broth without overwhelming the vegetables. For a non-alcoholic option, serve Moroccan mint tea or sparkling water with lemon.";
"recipe.ma_couscous.drink.summary" = "Red wine (Grenache)";
"recipe.ma_couscous.info" = "Moroccan couscous with seven vegetables is a traditional Friday-style family meal featuring steamed semolina grains served with a fragrant lamb and chickpea broth and a variety of tender vegetables arranged on top. The couscous is steamed in stages to become light and fluffy, then finished with butter and served with the hot broth ladled over the grains and vegetables for a communal platter.";
"recipe.ma_couscous.info.summary" = "Friday couscous platter";
"recipe.ma_couscous.name" = "Vegetable couscous";
"recipe.ma_couscous.step1.body" = "Rinse the %i1, cover them with %i2, and leave to soak until fully hydrated. Drain before cooking.";
"recipe.ma_couscous.step1.title" = "Soak chickpeas";
"recipe.ma_couscous.step10.body" = "Add the remaining vegetables and continue simmering until all vegetables and lamb are tender and the broth is fragrant.";
"recipe.ma_couscous.step10.title" = "Cook the quick vegetables";
"recipe.ma_couscous.step11.body" = "Steam the couscous a final time until fully tender and airy, then return it to the bowl.";
"recipe.ma_couscous.step11.title" = "Final steaming";
"recipe.ma_couscous.step12.body" = "Fold %i23 into the hot couscous until melted and glossy. Mound the couscous on a platter, arrange lamb and vegetables on top, and ladle broth over and around before serving.";
"recipe.ma_couscous.step12.title" = "Finish and serve";
"recipe.ma_couscous.step2.body" = "Cut the %i4 into large serving pieces. Chop the %i5 and %i6. Peel and cut the %i13, %i14, %i15, %i16, and %i17 into large, even pieces suitable for simmering. Tie the %i18 and %i19 into a small bundle.";
"recipe.ma_couscous.step2.title" = "Prep meat and vegetables";
"recipe.ma_couscous.step3.body" = "Heat %i3 in the bottom of a couscoussier over medium heat. Add onion and cook until softened, then add tomato, %i7, %i8, %i9, %i10, and %i11 and cook until fragrant.";
"recipe.ma_couscous.step3.title" = "Start the broth";
"recipe.ma_couscous.step4.body" = "Add lamb and drained chickpeas, turn to coat, then add %i12 and bring to a steady simmer. Add the herb bundle, cover, and cook until the lamb begins to tenderize.";
"recipe.ma_couscous.step4.title" = "Simmer lamb and chickpeas";
"recipe.ma_couscous.step5.body" = "Place %i20 in a wide bowl, loosen the grains with your hands, then moisten gradually with %i21 and %i24 while rubbing to separate the grains. Drizzle in %i22 and mix until fluffy. Let it rest covered briefly.";
"recipe.ma_couscous.step5.title" = "Prepare couscous for first steam";
"recipe.ma_couscous.step6.body" = "Transfer the couscous to the steamer basket and steam over the simmering broth until hot and expanded. Return the couscous to the bowl and fluff thoroughly.";
"recipe.ma_couscous.step6.title" = "First steaming";
"recipe.ma_couscous.step7.body" = "Moisten the couscous again with water while rubbing the grains to keep them separate, then cover and let it rest briefly before steaming again.";
"recipe.ma_couscous.step7.title" = "Second hydration";
"recipe.ma_couscous.step8.body" = "Steam the couscous again until light and tender, then return it to the bowl and fluff well.";
"recipe.ma_couscous.step8.title" = "Second steaming";
"recipe.ma_couscous.step9.body" = "Add the firm vegetables to the broth and simmer until they are well on their way to tenderness, keeping the broth at a gentle simmer.";
"recipe.ma_couscous.step9.title" = "Cook the firm vegetables";
