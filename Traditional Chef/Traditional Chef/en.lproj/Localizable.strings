"recipe.hr_brudet.drink.body" = "A dry coastal white such as Pošip or Malvazija matches the tomatoy broth and delicate fish. For a non-alcoholic pairing, serve sparkling water or still water with lemon.";
"recipe.hr_brudet.drink.summary" = "White wine (Pošip)";
"recipe.hr_brudet.info" = "Brudet is a traditional Adriatic fish stew from the Croatian coast, especially Dalmatia and Kvarner. It is made by gently simmering several kinds of fish with onion, garlic, tomato, olive oil, wine, vinegar, parsley, and bay leaf, then served hot with soft polenta that absorbs the rich sea-flavored sauce.";
"recipe.hr_brudet.info.summary" = "Adriatic fish stew";
"recipe.hr_brudet.name" = "Brudet";
"recipe.hr_brudet.step1.body" = "Clean %i1, %i2, and %i3, cut them into large pieces, and season lightly with %i13 and %i14. Slice %i5, mince %i6, chop %i11, and crush %i7.";
"recipe.hr_brudet.step1.title" = "Prepare the fish";
"recipe.hr_brudet.step2.body" = "Warm %i4 in the wide pot and cook the onion gently until soft and translucent, stirring often so it does not brown.";
"recipe.hr_brudet.step2.title" = "Cook the onion base";
"recipe.hr_brudet.step3.body" = "Add the tomatoes, %i8, %i9, %i12, and most of the parsley, then cook until the mixture smells rounded and slightly reduced.";
"recipe.hr_brudet.step3.title" = "Build the broth";
"recipe.hr_brudet.step4.body" = "Arrange the fish pieces in the pot in a single layer, then add %i10 and season with the remaining salt and black pepper.";
"recipe.hr_brudet.step4.title" = "Add the fish";
"recipe.hr_brudet.step5.body" = "Bring the stew to a gentle simmer and cook uncovered until the fish is tender and the broth is rich. Do not stir with a spoon: shake the pot gently from time to time so the fish stays in large pieces.";
"recipe.hr_brudet.step5.title" = "Simmer without stirring";
"recipe.hr_brudet.step6.body" = "Bring %i16 to a boil in the saucepan, add %i17, then rain in %i15 while whisking constantly.";
"recipe.hr_brudet.step6.title" = "Start the polenta";
"recipe.hr_brudet.step7.body" = "Cook the polenta over low heat, stirring often, until thick, smooth, and soft enough to spoon.";
"recipe.hr_brudet.step7.title" = "Cook the polenta";
"recipe.hr_brudet.step8.body" = "Taste the stew, adjust the seasoning if needed, and scatter over the remaining parsley.";
"recipe.hr_brudet.step8.title" = "Finish the brudet";
"recipe.hr_brudet.step9.body" = "Spoon the polenta onto warm plates or shallow bowls and ladle the brudet over or alongside it, making sure each serving gets broth and different pieces of fish.";
"recipe.hr_brudet.step9.title" = "Serve";
"recipe.hr_brudet.tool.t1" = "Chef knife";
"recipe.hr_brudet.tool.t2" = "Cutting board";
"recipe.hr_brudet.tool.t3" = "Wide shallow pot";
"recipe.hr_brudet.tool.t4" = "Wooden spoon";
"recipe.hr_brudet.tool.t5" = "Large saucepan";
"recipe.hr_brudet.tool.t6" = "Whisk";
"recipe.hr_brudet.tool.t7" = "Ladle";
"recipe.hr_crni_rizot.drink.body" = "A dry Dalmatian white wine such as Pošip or Malvazija pairs well with the briny, inky depth of the dish. For a non-alcoholic option, serve chilled sparkling water with lemon.";
"recipe.hr_crni_rizot.drink.summary" = "White wine (Pošip)";
"recipe.hr_crni_rizot.info" = "Crni rižot is a traditional Adriatic rice dish from the Croatian coast, especially Dalmatia and Istria. It is made with cuttlefish, its ink, rice, olive oil, onion, garlic, white wine, parsley, and hot fish stock, then cooked slowly until loose, glossy, and deeply savory. It is typically served as a seaside main course, hot and freshly made.";
"recipe.hr_crni_rizot.info.summary" = "Adriatic black risotto";
"recipe.hr_crni_rizot.name" = "Black risotto";
"recipe.hr_crni_rizot.step1.body" = "Clean %i1, reserving the ink sacs if whole, then cut the flesh into small pieces. Finely chop %i2, mince %i4, and chop %i9. Keep %i7 hot in a separate saucepan.";
"recipe.hr_crni_rizot.step1.title" = "Prepare the cuttlefish";
"recipe.hr_crni_rizot.step10.body" = "Spoon the black risotto onto warm plates and serve immediately while still loose and silky.";
"recipe.hr_crni_rizot.step10.title" = "Serve";
"recipe.hr_crni_rizot.step2.body" = "Warm %i3 in the large pan and cook the onion gently until soft and translucent, stirring often so it does not brown.";
"recipe.hr_crni_rizot.step2.title" = "Start the base";
"recipe.hr_crni_rizot.step3.body" = "Add the cuttlefish and cook over medium heat until it firms up and starts releasing its juices. Stir in the garlic and cook briefly.";
"recipe.hr_crni_rizot.step3.title" = "Cook the cuttlefish";
"recipe.hr_crni_rizot.step4.body" = "Pour in %i5 and cook until the raw alcohol smell disappears and the liquid reduces.";
"recipe.hr_crni_rizot.step4.title" = "Deglaze with wine";
"recipe.hr_crni_rizot.step5.body" = "Add a ladle of hot stock and simmer the cuttlefish gently, adding more stock as needed, until it begins to soften.";
"recipe.hr_crni_rizot.step5.title" = "Tenderize the cuttlefish";
"recipe.hr_crni_rizot.step6.body" = "Add %i6 to the pan and stir until every grain is coated and slightly translucent at the edges.";
"recipe.hr_crni_rizot.step6.title" = "Toast the rice";
"recipe.hr_crni_rizot.step7.body" = "Stir in %i8 and begin adding hot stock a ladle at a time, stirring regularly and adding more only when the previous ladle is mostly absorbed. Keep the risotto loose rather than dry.";
"recipe.hr_crni_rizot.step7.title" = "Cook the risotto";
"recipe.hr_crni_rizot.step8.body" = "When the rice is just tender and the texture is creamy and flowing, stir in the parsley, then season with %i10 and %i11. Remove from the heat.";
"recipe.hr_crni_rizot.step8.title" = "Season and finish";
"recipe.hr_crni_rizot.step9.body" = "Let the risotto stand briefly so the starch settles and the texture turns glossy and unified.";
"recipe.hr_crni_rizot.step9.title" = "Rest briefly";
"recipe.hr_crni_rizot.tool.t1" = "Chef knife";
"recipe.hr_crni_rizot.tool.t2" = "Cutting board";
"recipe.hr_crni_rizot.tool.t3" = "Large sauté pan";
"recipe.hr_crni_rizot.tool.t4" = "Saucepan";
"recipe.hr_crni_rizot.tool.t5" = "Ladle";
"recipe.hr_crni_rizot.tool.t6" = "Wooden spoon";
"recipe.hr_gregada.drink.body" = "A dry Dalmatian white such as Bogdanuša, Pošip, or Malvazija pairs well with the delicate fish and olive-oil broth. For a non-alcoholic pairing, serve chilled sparkling water or still water with lemon.";
"recipe.hr_gregada.drink.summary" = "White wine (Bogdanuša)";
"recipe.hr_gregada.info" = "Gregada is a traditional fish and potato stew from the island of Hvar and the central Dalmatian islands. It is an old fishermen’s dish made by layering white fish with potatoes, onion, garlic, parsley, olive oil, white wine, and bay leaf, then simmering it gently without stirring so the fish stays in large pieces. It is served hot with bread to soak up the fragrant broth.";
"recipe.hr_gregada.info.summary" = "Hvar island fish stew";
"recipe.hr_gregada.name" = "Gregada";
"recipe.hr_gregada.step1.body" = "Clean %i1 and %i2 and cut them into large pieces. Peel and slice %i3, slice %i4, mince %i5, and chop %i10. Season the fish lightly with %i11 and %i12.";
"recipe.hr_gregada.step1.title" = "Prepare the ingredients";
"recipe.hr_gregada.step2.body" = "Coat the bottom of the pot with some %i6, then layer in some onion, potatoes, garlic, parsley, and fish. Repeat the layers until everything is used, finishing with parsley, %i9, the remaining salt, black pepper, and the rest of the olive oil.";
"recipe.hr_gregada.step2.title" = "Layer the pot";
"recipe.hr_gregada.step3.body" = "Pour in %i7 and %i8 gently around the side of the pot so the layers stay in place.";
"recipe.hr_gregada.step3.title" = "Add the liquids";
"recipe.hr_gregada.step4.body" = "Bring the stew to a gentle simmer and cook uncovered until the potatoes are tender and the fish is cooked through. Do not stir with a spoon: shake the pot gently from time to time to keep the fish pieces whole.";
"recipe.hr_gregada.step4.title" = "Simmer gently";
"recipe.hr_gregada.step5.body" = "Take the pot off the heat and let the gregada stand briefly so the broth settles and the flavors come together.";
"recipe.hr_gregada.step5.title" = "Rest briefly";
"recipe.hr_gregada.step6.body" = "Ladle the gregada into shallow bowls with broth, potatoes, and pieces of fish, then serve immediately with %i13 alongside.";
"recipe.hr_gregada.step6.title" = "Serve";
"recipe.hr_gregada.tool.t1" = "Chef knife";
"recipe.hr_gregada.tool.t2" = "Cutting board";
"recipe.hr_gregada.tool.t3" = "Wide shallow pot";
"recipe.hr_gregada.tool.t4" = "Wooden spoon";
"recipe.hr_gregada.tool.t5" = "Ladle";
"recipe.hr_pasticada.drink.body" = "A mature Dalmatian red such as Plavac Mali works well with the deep sweet-sour sauce and long-braised beef. For a non-alcoholic pairing, serve sparkling mineral water or still water with lemon.";
"recipe.hr_pasticada.drink.summary" = "Red wine (Plavac Mali)";
"recipe.hr_pasticada.info" = "Pašticada is a traditional Dalmatian celebratory dish of beef that is larded, marinated, then slowly braised in a rich sweet-sour sauce with wine, root vegetables, prunes, and aromatics. It is classically served for Sunday lunches, weddings, and feast days with homemade potato gnocchi to catch the glossy sauce.";
"recipe.hr_pasticada.info.summary" = "Dalmatian festive braise";
"recipe.hr_pasticada.name" = "Pašticada";
"recipe.hr_pasticada.step1.body" = "Cut deep slits all over %i1. Insert about half of %i2, about half of %i3, several %i4 batons, and %i11 into the slits so the meat is well seasoned from within.";
"recipe.hr_pasticada.step1.title" = "Lard the beef";
"recipe.hr_pasticada.step10.body" = "Slice the beef into thick pieces, return the slices to the sauce, and simmer gently so the meat absorbs the flavor and the sauce turns glossy.";
"recipe.hr_pasticada.step10.title" = "Slice and glaze the beef";
"recipe.hr_pasticada.step11.body" = "Place %i22 in a large pot, cover with %i25, and boil until tender enough to pierce easily.";
"recipe.hr_pasticada.step11.title" = "Cook the potatoes";
"recipe.hr_pasticada.step12.body" = "Drain the potatoes, peel them while still warm, and pass them through the ricer. Mix with %i23, %i24, and a little salt to form a soft dough without overworking it.";
"recipe.hr_pasticada.step12.title" = "Make the gnocchi dough";
"recipe.hr_pasticada.step13.body" = "Divide the dough, roll it into ropes, cut into small pieces, and shape them lightly so they will hold the sauce well.";
"recipe.hr_pasticada.step13.title" = "Shape the gnocchi";
"recipe.hr_pasticada.step14.body" = "Bring water back to a boil, add the gnocchi in batches, and cook until they rise to the surface, then lift them out with a slotted spoon.";
"recipe.hr_pasticada.step14.title" = "Boil the gnocchi";
"recipe.hr_pasticada.step15.body" = "Arrange the gnocchi on warm plates, top with slices of pašticada, and spoon over plenty of sauce.";
"recipe.hr_pasticada.step15.title" = "Serve";
"recipe.hr_pasticada.step2.body" = "Slice %i6 and %i5, add the remaining carrot, %i9, %i10, some %i12, and some %i13, then place everything around the beef in a deep dish. Pour over %i7 and %i8.";
"recipe.hr_pasticada.step2.title" = "Build the marinade";
"recipe.hr_pasticada.step3.body" = "Cover and refrigerate the beef overnight, turning it once so the meat takes on the sweet-sour aromatic marinade evenly.";
"recipe.hr_pasticada.step3.title" = "Marinate overnight";
"recipe.hr_pasticada.step4.body" = "Lift out the beef and pat it dry. Reserve the marinade and separate out the vegetables and herbs.";
"recipe.hr_pasticada.step4.title" = "Prepare for braising";
"recipe.hr_pasticada.step5.body" = "Heat %i14 and %i15 in the Dutch oven and brown the beef thoroughly on all sides until richly colored.";
"recipe.hr_pasticada.step5.title" = "Brown the beef";
"recipe.hr_pasticada.step6.body" = "Remove the beef briefly. Add the remaining pancetta, the marinated vegetables, and the remaining garlic to the pot and cook until softened and lightly caramelized.";
"recipe.hr_pasticada.step6.title" = "Cook the aromatic base";
"recipe.hr_pasticada.step7.body" = "Stir in %i17, %i16, %i21, and %i20, then pour in %i18, part of the reserved marinade, and %i19. Return the beef to the pot.";
"recipe.hr_pasticada.step7.title" = "Enrich the sauce base";
"recipe.hr_pasticada.step8.body" = "Cover and braise gently until the beef is very tender and the sauce is dark, fragrant, and concentrated. Turn the meat from time to time during cooking.";
"recipe.hr_pasticada.step8.title" = "Braise until tender";
"recipe.hr_pasticada.step9.body" = "Lift out the beef and keep it warm. Remove the bay leaf and rosemary, then strain and blend the sauce until smooth. Return it to the pot and adjust with the remaining salt and black pepper.";
"recipe.hr_pasticada.step9.title" = "Finish the sauce";
"recipe.hr_pasticada.tool.t1" = "Chef knife";
"recipe.hr_pasticada.tool.t10" = "Slotted spoon";
"recipe.hr_pasticada.tool.t2" = "Cutting board";
"recipe.hr_pasticada.tool.t3" = "Deep casserole dish";
