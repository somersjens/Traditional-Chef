"recipe.ma_kefta_tagine.drink.body" = "A medium-bodied red such as Grenache or Syrah pairs well with the tomato richness and warm spices. For a non-alcoholic option, serve Moroccan mint tea or sparkling water with lemon.";
"recipe.ma_kefta_tagine.drink.summary" = "Red wine (Grenache)";
"recipe.ma_kefta_tagine.info" = "Moroccan kefta tagine is a classic dish of spiced minced-meat meatballs simmered in a fragrant tomato sauce with onions, garlic, and herbs, then finished by gently poaching eggs directly in the bubbling sauce. It is traditionally served straight from the tagine for sharing, with Moroccan khobz to scoop up the meatballs, sauce, and soft eggs.";
"recipe.ma_kefta_tagine.info.summary" = "Meatballs in tagine";
"recipe.ma_kefta_tagine.name" = "Kefta tagine";
"recipe.ma_kefta_tagine.step1.body" = "Combine %i20, %i21, and %i22, then add %i23 and knead until smooth and elastic. Cover with a towel.";
"recipe.ma_kefta_tagine.step1.title" = "Mix khobz dough";
"recipe.ma_kefta_tagine.step10.body" = "Make small wells in the sauce and crack %i19 into them. Cover and cook gently until the whites set and the yolks are softly cooked.";
"recipe.ma_kefta_tagine.step10.title" = "Poach the eggs";
"recipe.ma_kefta_tagine.step11.body" = "Serve the kefta tagine hot with khobz for scooping up the meatballs, sauce, and eggs.";
"recipe.ma_kefta_tagine.step11.title" = "Serve with khobz";
"recipe.ma_kefta_tagine.step2.body" = "Leave the dough covered in a warm spot until clearly risen and airy.";
"recipe.ma_kefta_tagine.step2.title" = "Rise the dough";
"recipe.ma_kefta_tagine.step3.body" = "Chop the %i11 and %i12. Grate or finely mince the %i13 and %i14. Grate the %i4 to a pulp, discarding tough skins.";
"recipe.ma_kefta_tagine.step3.title" = "Prep herbs and aromatics";
"recipe.ma_kefta_tagine.step4.body" = "In a bowl, combine the %i10 with part of the onion, garlic, chopped herbs, %i15, %i16, %i17, and %i18. Mix until evenly seasoned.";
"recipe.ma_kefta_tagine.step4.title" = "Mix the kefta";
"recipe.ma_kefta_tagine.step5.body" = "Roll the kefta mixture into small meatballs and set aside so they are ready to drop into the sauce.";
"recipe.ma_kefta_tagine.step5.title" = "Form meatballs";
"recipe.ma_kefta_tagine.step6.body" = "Heat %i1 in the tagine base over medium heat. Add the remaining %i2 and cook until softened, then add %i3 briefly. Add tomatoes, %i5, %i6, %i7, %i8, and %i9 and bring to a gentle simmer.";
"recipe.ma_kefta_tagine.step6.title" = "Start the tomato sauce";
"recipe.ma_kefta_tagine.step7.body" = "Nestle the meatballs into the simmering sauce, cover, and cook at a gentle simmer until the meatballs are cooked through and the sauce thickens, spooning sauce over occasionally.";
"recipe.ma_kefta_tagine.step7.title" = "Simmer the meatballs";
"recipe.ma_kefta_tagine.step8.body" = "Punch down the risen dough, shape into round loaves on a baking sheet, cover briefly, and heat the oven.";
"recipe.ma_kefta_tagine.step8.title" = "Shape khobz and heat oven";
"recipe.ma_kefta_tagine.step9.body" = "Bake until the loaves are well risen and browned. Remove and let cool slightly for serving.";
"recipe.ma_kefta_tagine.step9.title" = "Bake khobz";
