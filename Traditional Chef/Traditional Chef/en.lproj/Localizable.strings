"recipe.uy_asado_con_cuero.drink.body" = "Pair with Uruguayan Tannat, whose structure matches the rich, smoky beef and rendered fat. A medium-bodied Tempranillo also works well. For a non-alcoholic option, serve sparkling water with lemon or a cold yerba mate infusion.";
"recipe.uy_asado_con_cuero.drink.summary" = "Red wine (Tannat)";
"recipe.uy_asado_con_cuero.info" = "Asado con Cuero is a traditional rural Uruguayan barbecue where a large cut of beef is cooked slowly over wood embers with the hide left on, protecting the meat so it stays exceptionally juicy while the exterior browns and the fat renders. It is served sliced and shared family-style, typically accompanied by crusty bread and classic Uruguayan condiments like chimichurri and salsa criolla.";
"recipe.uy_asado_con_cuero.info.summary" = "Hide-on roast beef";
"recipe.uy_asado_con_cuero.name" = "Asado con cuero";
"recipe.uy_asado_con_cuero.step1.body" = "Light the firewood and let it burn down until you have a large bed of glowing embers. Maintain a separate fire to keep producing fresh embers for the long cook.";
"recipe.uy_asado_con_cuero.step1.title" = "Build the fire and embers";
"recipe.uy_asado_con_cuero.step2.body" = "Trim only loose bits of fat and sinew from the %i1, keeping the hide intact. Pat the surface dry and season the meat side generously with %i2.";
"recipe.uy_asado_con_cuero.step2.title" = "Prepare the beef";
"recipe.uy_asado_con_cuero.step3.body" = "Arrange the beef on the parrilla with the hide facing the heat and cook slowly over gentle embers, adding embers as needed to keep steady heat without flames licking the meat.";
"recipe.uy_asado_con_cuero.step3.title" = "Slow-cook hide-side down";
"recipe.uy_asado_con_cuero.step4.body" = "Turn the beef so the meat side faces the heat and continue cooking until the exterior browns and the fat renders while the inside stays juicy.";
"recipe.uy_asado_con_cuero.step4.title" = "Finish on the meat side";
"recipe.uy_asado_con_cuero.step5.body" = "Finely chop the %i3 and %i4, then mix with %i5, %i6, %i7, %i8, %i9, %i10, and %i11 until spoonable and well combined.";
"recipe.uy_asado_con_cuero.step5.title" = "Make chimichurri";
"recipe.uy_asado_con_cuero.step6.body" = "Dice the %i12 and %i13 small, then mix with %i14, %i15, and %i16 until glossy and lightly dressed.";
"recipe.uy_asado_con_cuero.step6.title" = "Make salsa criolla";
"recipe.uy_asado_con_cuero.step7.body" = "Remove the beef from the grill and rest so the juices redistribute before slicing.";
"recipe.uy_asado_con_cuero.step7.title" = "Rest the beef";
"recipe.uy_asado_con_cuero.step8.body" = "Slice the beef across the grain and serve on a platter with %i17, chimichurri, and salsa criolla.";
"recipe.uy_asado_con_cuero.step8.title" = "Slice and serve";
