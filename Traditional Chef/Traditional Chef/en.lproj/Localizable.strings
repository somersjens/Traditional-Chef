"recipe.pk_mutton_karahi.drink.body" = "A medium-bodied red such as Syrah or Tempranillo pairs well with the rich mutton and tomato masala. A crisp lager also works well. Non-alcoholic pairing: salted lassi or hot black tea are both excellent choices.";
"recipe.pk_mutton_karahi.drink.summary" = "Red wine (Syrah)";
"recipe.pk_mutton_karahi.info" = "Mutton Karahi is a traditional Pakistani karahi dish made by slowly cooking bone-in mutton with tomatoes, ginger, garlic, green chilies, and aromatic spices in a karahi until the meat is tender and the masala is thick and glossy. It is served hot as a shared main dish with naan for scooping up the rich gravy.";
"recipe.pk_mutton_karahi.info.summary" = "Tomato mutton karahi";
"recipe.pk_mutton_karahi.name" = "Mutton karahi";
"recipe.pk_mutton_karahi.step1.body" = "Cut the %i1 into serving pieces if needed. Chop the %i3. Finely chop the %i4 and half of the %i5. Slice the %i6. Julienne the remaining %i15 for garnish and chop the %i14.";
"recipe.pk_mutton_karahi.step1.title" = "Prepare ingredients";
"recipe.pk_mutton_karahi.step10.body" = "Transfer the mutton karahi to a serving bowl, top with cilantro and julienned ginger, and serve hot with naan.";
"recipe.pk_mutton_karahi.step10.title" = "Serve";
"recipe.pk_mutton_karahi.step2.body" = "Heat the karahi over medium-high heat and add the %i2. Add the mutton and cook until the surface changes color and begins to brown lightly.";
"recipe.pk_mutton_karahi.step2.title" = "Brown mutton";
"recipe.pk_mutton_karahi.step3.body" = "Add the chopped garlic, chopped ginger, %i10, part of the %i8, %i9, %i11, and %i12. Cook briefly until fragrant.";
"recipe.pk_mutton_karahi.step3.title" = "Add aromatics and spices";
"recipe.pk_mutton_karahi.step4.body" = "Add the tomatoes and remaining salt, then cook while stirring and pressing until the tomatoes begin to break down into a masala.";
"recipe.pk_mutton_karahi.step4.title" = "Add tomatoes";
"recipe.pk_mutton_karahi.step5.body" = "Add %i7, cover, and cook on low heat until the mutton becomes tender and the masala is fully developed, stirring occasionally to prevent sticking.";
"recipe.pk_mutton_karahi.step5.title" = "Cook covered until tender";
"recipe.pk_mutton_karahi.step6.body" = "Uncover and cook on medium-high heat until excess moisture evaporates and the masala turns thick and glossy with oil separating around the edges. Stir in the green chilies.";
"recipe.pk_mutton_karahi.step6.title" = "Reduce and roast masala";
"recipe.pk_mutton_karahi.step7.body" = "Sprinkle in the %i13 and cook briefly so the aroma blooms without overcooking the spices.";
"recipe.pk_mutton_karahi.step7.title" = "Finish with garam masala";
"recipe.pk_mutton_karahi.step8.body" = "Turn off the heat and let the karahi rest briefly so the meat settles in the masala.";
"recipe.pk_mutton_karahi.step8.title" = "Rest karahi";
"recipe.pk_mutton_karahi.step9.body" = "Warm the %i16 briefly until soft and fragrant for serving.";
"recipe.pk_mutton_karahi.step9.title" = "Warm naan";
