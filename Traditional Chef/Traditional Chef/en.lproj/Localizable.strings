"recipe.tr_icli_kofte.step1.title" = "Prep onions and herbs";
"recipe.tr_icli_kofte.step2.body" = "Sauté the onions in %i8 until soft, add the %i6 and cook until browned, then stir in spices, %i14, walnuts, and parsley until the mixture is fragrant and fairly dry. Let it cool.";
"recipe.tr_icli_kofte.step2.title" = "Cook the filling";
