"recipe.au_pavlova.drink.body" = "A dry sparkling wine pairs well with the pavlova's sweetness and fresh fruit. A light late-harvest white also works, and chilled passionfruit soda is a good non-alcoholic pairing.";
"recipe.au_pavlova.drink.summary" = "Sparkling wine";
"recipe.au_pavlova.info" = "Pavlova is a traditional Australian dessert of crisp meringue with a soft marshmallow-like centre, topped with whipped cream and fresh fruit. It is a classic summer and festive dessert, especially popular at Christmas and warm-weather family gatherings.";
"recipe.au_pavlova.info.summary" = "Australian pavlova";
"recipe.au_pavlova.name" = "Pavlova";
"recipe.au_pavlova.step1.body" = "Line a baking tray with baking paper and mark a round guide. Heat the oven for slow baking.";
"recipe.au_pavlova.step1.title" = "Prepare the oven and tray";
"recipe.au_pavlova.step2.body" = "Beat the %i1 until soft peaks form, then add the %i2 gradually and keep beating until the mixture is thick and glossy.";
"recipe.au_pavlova.step2.title" = "Whip the meringue";
"recipe.au_pavlova.step3.body" = "Sprinkle in the %i3, %i4, and %i5 and fold them in gently.";
"recipe.au_pavlova.step3.title" = "Finish the mixture";
"recipe.au_pavlova.step4.body" = "Pile the meringue onto the marked circle and shape it into a round with a slight hollow in the centre.";
"recipe.au_pavlova.step4.title" = "Shape the pavlova";
"recipe.au_pavlova.step5.body" = "Bake the pavlova at low heat until the outside is dry and crisp.";
"recipe.au_pavlova.step5.title" = "Bake the shell";
"recipe.au_pavlova.step6.body" = "Turn off the oven and leave the pavlova inside to cool completely so the shell stays intact.";
"recipe.au_pavlova.step6.title" = "Cool in the oven";
"recipe.au_pavlova.step7.body" = "Whip the %i6 to soft peaks, hull and slice the %i7, and scoop out the %i8 pulp.";
"recipe.au_pavlova.step7.title" = "Prepare the topping";
"recipe.au_pavlova.step8.body" = "Place the cooled pavlova on a serving plate, spoon the whipped cream into the centre, then top with the strawberries and passionfruit.";
"recipe.au_pavlova.step8.title" = "Assemble the pavlova";
"recipe.au_pavlova.step9.body" = "Serve the pavlova immediately after topping so the shell stays crisp.";
"recipe.au_pavlova.step9.title" = "Serve";
