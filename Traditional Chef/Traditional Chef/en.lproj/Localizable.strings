"recipe.de_kaesespaetzle.drink.body" = "Pair with a dry white such as Pinot Blanc or Silvaner to cut through the richness and complement the cheese. A German lager also fits the dish well. For a non-alcoholic option, serve sparkling water with lemon or an alcohol-free lager.";
"recipe.de_kaesespaetzle.drink.summary" = "White wine (Pinot Blanc)";
"recipe.de_kaesespaetzle.info" = "Käsespätzle is a traditional German comfort dish from the south, especially Swabia and the Allgäu: tender fresh spätzle layered with robust melted cheese and butter, then topped with deeply golden fried onions. It is served hot as a hearty main, where the cheese coats the spätzle and the onions add sweetness and crunch.";
"recipe.de_kaesespaetzle.info.summary" = "Allgäu cheese noodles";
"recipe.de_kaesespaetzle.name" = "Käsespätzle";
"recipe.de_kaesespaetzle.step1.body" = "Mix %i1 and %i4 in a bowl. Add %i2 and stir strongly, adding %i3 gradually, until the batter is thick, glossy, and pulls away from the bowl when beaten.";
"recipe.de_kaesespaetzle.step1.title" = "Make the spätzle batter";
"recipe.de_kaesespaetzle.step2.body" = "Let the batter rest so it relaxes and becomes smoother for pressing.";
"recipe.de_kaesespaetzle.step2.title" = "Rest the batter";
"recipe.de_kaesespaetzle.step3.body" = "Grate %i5 and %i6 and slice %i8 into thin rings.";
"recipe.de_kaesespaetzle.step3.title" = "Prep the cheese and onions";
"recipe.de_kaesespaetzle.step4.body" = "Melt %i9 in a skillet and fry the onions slowly until deep golden and sweet, stirring regularly so they brown evenly without burning.";
"recipe.de_kaesespaetzle.step4.title" = "Fry the onions";
"recipe.de_kaesespaetzle.step5.body" = "Bring a large pot of water to a boil and season it with %i11.";
"recipe.de_kaesespaetzle.step5.title" = "Boil the water";
"recipe.de_kaesespaetzle.step6.body" = "Press or scrape the batter into the boiling water in batches. When the spätzle float, cook them briefly, lift them out with a slotted spoon, and drain.";
"recipe.de_kaesespaetzle.step6.title" = "Cook the spätzle";
"recipe.de_kaesespaetzle.step7.body" = "Place a layer of spätzle in a baking dish, scatter over cheese, and dot with %i7. Repeat with the remaining spätzle, cheese, and butter, then season with %i12.";
"recipe.de_kaesespaetzle.step7.title" = "Layer with cheese";
"recipe.de_kaesespaetzle.step8.body" = "Warm the dish in the oven until the cheese is fully melted and the spätzle are hot throughout.";
"recipe.de_kaesespaetzle.step8.title" = "Melt and bind";
"recipe.de_kaesespaetzle.step9.body" = "Top with the fried onions and serve immediately while hot.";
"recipe.de_kaesespaetzle.step9.title" = "Serve the spätzle";
