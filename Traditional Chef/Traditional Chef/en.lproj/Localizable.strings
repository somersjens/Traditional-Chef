"recipe.tr_imam_bayildi.drink.body" = "A crisp Sauvignon Blanc or dry Assyrtiko balances the rich olive oil and sweet onions, while a light rosé also works. For a non-alcoholic option, serve sparkling water with lemon or a glass of cold ayran.";
"recipe.tr_imam_bayildi.drink.summary" = "White wine (Sauvignon)";
"recipe.tr_imam_bayildi.info" = "İmam Bayıldı is a classic Turkish zeytinyağlı dish of whole eggplants fried in olive oil and stuffed with a slow-cooked onion, garlic, and tomato filling, then gently braised until silky. It is traditionally served at room temperature or slightly cool with lemon, as part of mezze or as a light main alongside bread.";
"recipe.tr_imam_bayildi.info.summary" = "Olive-oil stuffed eggplant";
"recipe.tr_imam_bayildi.name" = "İmam bayıldı";
"recipe.tr_imam_bayildi.step1.body" = "Peel %i1 in stripes, slit them lengthwise to form a pocket, season with %i3, and let them sit so they release bitterness, then pat dry.";
"recipe.tr_imam_bayildi.step1.title" = "Prep the eggplants";
"recipe.tr_imam_bayildi.step2.body" = "Fry the eggplants in %i2 until softened and lightly golden, then transfer to a pot for braising.";
"recipe.tr_imam_bayildi.step2.title" = "Fry the eggplants";
"recipe.tr_imam_bayildi.step3.body" = "Sauté %i4 in %i9 until very soft, add %i5 and %i7, then add %i6, %i10, and %i11 and cook until jammy. Stir in %i8.";
"recipe.tr_imam_bayildi.step3.title" = "Cook the stuffing";
"recipe.tr_imam_bayildi.step4.body" = "Open the eggplant slits and fill each with the onion-tomato mixture. Top with %i12 slices.";
"recipe.tr_imam_bayildi.step4.title" = "Stuff and top";
"recipe.tr_imam_bayildi.step5.body" = "Add %i13 to the pot, cover, and braise on low heat until the eggplants are silky and the flavors meld.";
"recipe.tr_imam_bayildi.step5.title" = "Braise gently";
"recipe.tr_imam_bayildi.step6.body" = "Let the imam bayıldı cool to room temperature so the olive oil and stuffing set into the eggplants.";
"recipe.tr_imam_bayildi.step6.title" = "Cool for serving";
"recipe.tr_imam_bayildi.step7.body" = "Serve at room temperature with %i14.";
"recipe.tr_imam_bayildi.step7.title" = "Serve";
