"recipe.pk_shami_kebab.drink.body" = "A light to medium red such as Pinot Noir or Grenache pairs well with the spiced fried patties without overpowering them. A crisp lager also works well. Non-alcoholic pairing: salted lassi or hot black tea are both excellent choices.";
"recipe.pk_shami_kebab.drink.summary" = "Red wine (Pinot Noir)";
"recipe.pk_shami_kebab.info" = "Shami Kebab is a traditional Pakistani kebab made by cooking meat with chana dal and whole spices, then grinding the mixture into a smooth paste, shaping patties, coating them with egg, and shallow-frying until golden. It is commonly served hot with naan and mint chutney as a snack, appetizer, or main meal.";
"recipe.pk_shami_kebab.info.summary" = "Shallow-fried shami";
"recipe.pk_shami_kebab.name" = "Shami kebab";
"recipe.pk_shami_kebab.step1.body" = "Rinse the %i2 and soak it in %i7 until it hydrates and cooks evenly.";
"recipe.pk_shami_kebab.step1.title" = "Soak chana dal";
"recipe.pk_shami_kebab.step10.body" = "Move the shami kebabs off the heat and let them rest briefly so they firm up and the crust stays crisp.";
"recipe.pk_shami_kebab.step10.title" = "Rest kebabs";
"recipe.pk_shami_kebab.step11.body" = "Warm the %i27 briefly until soft and fragrant for serving.";
"recipe.pk_shami_kebab.step11.title" = "Warm naan";
"recipe.pk_shami_kebab.step12.body" = "Serve the hot shami kebabs with sliced red onion, naan bread, and mint chutney.";
"recipe.pk_shami_kebab.step12.title" = "Serve";
"recipe.pk_shami_kebab.step2.body" = "Chop the %i3, %i4, %i5, and %i6 for the shami base. Chop the %i16 and %i17 for mixing later. Slice the %i28 for serving. Keep the chutney herbs and aromatics separate.";
"recipe.pk_shami_kebab.step2.title" = "Prepare ingredients";
"recipe.pk_shami_kebab.step3.body" = "Place the %i1, soaked chana dal, onion, garlic, ginger, green chili, %i8, %i9, %i10, %i11, %i12, %i13, %i14, %i15, and water in a pot. Bring to a boil and skim if needed.";
"recipe.pk_shami_kebab.step3.title" = "Cook meat and dal";
"recipe.pk_shami_kebab.step4.body" = "Cover and simmer on low heat until the beef is tender and the chana dal is soft and starting to break down.";
"recipe.pk_shami_kebab.step4.title" = "Simmer until tender";
"recipe.pk_shami_kebab.step5.body" = "Uncover and cook on medium heat, stirring, until excess moisture evaporates and the mixture becomes dry enough to grind without becoming watery.";
"recipe.pk_shami_kebab.step5.title" = "Dry the mixture";
"recipe.pk_shami_kebab.step6.body" = "Remove the whole bay leaves and cinnamon stick. Grind the cooked meat and dal mixture to a smooth cohesive paste.";
"recipe.pk_shami_kebab.step6.title" = "Grind shami mixture";
"recipe.pk_shami_kebab.step7.body" = "Mix the ground shami paste with the chopped cilantro and mint. Beat the %i18 in a bowl, reserving some for dipping. Shape the shami mixture into flat round patties.";
"recipe.pk_shami_kebab.step7.title" = "Mix and shape patties";
"recipe.pk_shami_kebab.step8.body" = "Blend the %i20, %i21, %i22, %i23, %i24, %i25, and %i26 until smooth and spoonable.";
"recipe.pk_shami_kebab.step8.title" = "Make mint chutney";
"recipe.pk_shami_kebab.step9.body" = "Heat the %i19 in a frying pan over medium heat. Dip each patty in the reserved beaten egg, then shallow-fry in batches until golden brown on both sides and heated through.";
"recipe.pk_shami_kebab.step9.title" = "Fry shami kebabs";
