"recipe.my_asam_laksa.info" = "Penang asam laksa is a traditional Malaysian noodle soup from Penang with a tangy fish broth built from mackerel, tamarind, aromatic herbs, and a spicy paste. It is typically served as a complete bowl meal with thick rice noodles, fresh herbs and vegetables, pineapple, and sweet shrimp paste on top.";
"recipe.my_asam_laksa.info.summary" = "Penang sour fish noodles";
"recipe.my_asam_laksa.name" = "Asam laksa";
