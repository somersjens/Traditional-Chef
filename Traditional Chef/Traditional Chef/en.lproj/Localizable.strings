"recipe.id_opor_ayam.drink.summary" = "White wine (Riesling)";
"recipe.id_opor_ayam.info" = "Opor ayam is a traditional Indonesian chicken stew gently simmered in a fragrant coconut milk sauce with shallots, garlic, candlenuts, and warm spices. It is especially associated with Javanese home cooking and festive meals such as Lebaran, commonly served with rice cakes and sambal.";
"recipe.id_opor_ayam.info.summary" = "Coconut chicken stew";
"recipe.id_opor_ayam.name" = "Opor ayam";
"recipe.id_opor_ayam.step1.body" = "Grind the %i2, %i3, %i4, %i5, %i6, %i7, %i8, %i9, %i10, and %i11 into a smooth paste.";
"recipe.id_opor_ayam.step1.title" = "Prepare the spice paste";
"recipe.id_opor_ayam.step2.body" = "Heat %i16 in a heavy pot and fry the spice paste until fragrant and slightly deeper in color, stirring regularly so it does not scorch.";
"recipe.id_opor_ayam.step2.title" = "Fry the aromatics";
"recipe.id_opor_ayam.step3.body" = "Add the %i1 and turn them in the spices, then add %i12, %i13, %i14, and %i15.";
"recipe.id_opor_ayam.step3.title" = "Start the stew";
"recipe.id_opor_ayam.step4.body" = "Pour in %i17, bring to a gentle simmer, and cook until the chicken is partly tender and the broth is aromatic.";
"recipe.id_opor_ayam.step4.title" = "Simmer with water";
"recipe.id_opor_ayam.step5.body" = "Lower the heat, add %i18, and simmer gently until the chicken is fully tender and the sauce is rich and smooth. Stir occasionally and do not boil hard.";
"recipe.id_opor_ayam.step5.title" = "Add coconut milk and finish cooking";
"recipe.id_opor_ayam.step6.body" = "Taste the sauce and adjust seasoning if needed, then let the opor rest briefly so the flavors settle.";
"recipe.id_opor_ayam.step6.title" = "Adjust and rest";
"recipe.id_opor_ayam.step7.body" = "Slice the %i19 into serving pieces and arrange it with %i21 in serving bowls or on a platter.";
"recipe.id_opor_ayam.step7.title" = "Prepare accompaniments";
"recipe.id_opor_ayam.step8.body" = "Ladle the opor ayam and sauce over or beside the rice cake, then finish with %i20 and serve hot with sambal.";
"recipe.id_opor_ayam.step8.title" = "Serve";
