"recipe.th_tub_tim_krob.drink.body" = "A lightly sweet white wine such as late-harvest Riesling can match the coconut sweetness without overpowering the delicate texture. For a non-alcoholic pairing, serve unsweetened jasmine tea or plain cold water.";
"recipe.th_tub_tim_krob.drink.summary" = "Sweet wine";
"recipe.th_tub_tim_krob.info" = "Tub Tim Krob is a traditional Thai dessert of crunchy water chestnut cubes coated in tapioca starch and boiled until translucent, then served chilled in sweet coconut syrup with crushed ice. It is a classic hot-weather dessert and is commonly served after meals or as a market sweet.";
"recipe.th_tub_tim_krob.info.summary" = "Red ruby dessert";
"recipe.th_tub_tim_krob.name" = "Tub tim krob";
"recipe.th_tub_tim_krob.step1.body" = "Drain the %i1 and cut them into small cubes so they resemble ruby-sized pieces.";
"recipe.th_tub_tim_krob.step1.title" = "Prepare the water chestnuts";
"recipe.th_tub_tim_krob.step10.body" = "Divide %i12 into serving bowls, ladle the tub tim krob with coconut syrup over the ice, and serve immediately.";
"recipe.th_tub_tim_krob.step10.title" = "Serve over ice";
"recipe.th_tub_tim_krob.step2.body" = "Mix the water chestnut cubes with %i2 and a little %i3, then let them sit so the color is absorbed.";
"recipe.th_tub_tim_krob.step2.title" = "Color the cubes";
"recipe.th_tub_tim_krob.step3.body" = "Transfer the colored cubes to a bowl of %i4 and toss until fully coated, then shake off excess starch through a sieve.";
"recipe.th_tub_tim_krob.step3.title" = "Coat with tapioca starch";
"recipe.th_tub_tim_krob.step4.body" = "Combine %i7, %i8, %i9, %i10, and %i11 in a saucepan and heat gently until the sugar dissolves and the mixture is fragrant.";
"recipe.th_tub_tim_krob.step4.title" = "Make the coconut syrup";
"recipe.th_tub_tim_krob.step5.body" = "Remove the pandan leaves, strain if needed, and let the coconut syrup cool completely before serving.";
"recipe.th_tub_tim_krob.step5.title" = "Cool the syrup";
"recipe.th_tub_tim_krob.step6.body" = "Bring a pot of boiling %i5 to a full boil for cooking the coated water chestnut pieces.";
"recipe.th_tub_tim_krob.step6.title" = "Boil water for red rubies";
"recipe.th_tub_tim_krob.step7.body" = "Add the coated pieces and cook until they float and the tapioca coating turns translucent.";
"recipe.th_tub_tim_krob.step7.title" = "Cook the red rubies";
"recipe.th_tub_tim_krob.step8.body" = "Lift the cooked red rubies out and transfer them into a bowl of cool %i6 to stop cooking and keep them chewy.";
"recipe.th_tub_tim_krob.step8.title" = "Shock in cool water";
"recipe.th_tub_tim_krob.step9.body" = "Drain the red rubies well and add them to the cooled coconut syrup.";
"recipe.th_tub_tim_krob.step9.title" = "Drain and combine";
