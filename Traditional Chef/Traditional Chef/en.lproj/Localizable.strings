"recipe.us_tn_hot_chicken.drink.body" = "A citrusy pale ale or a slightly off-dry rosé can stand up to the heat and fried crust. For a non-alcoholic option, serve cold milk or a lightly sweet lemonade to cool the spice and refresh the palate.";
"recipe.us_tn_hot_chicken.drink.summary" = "Beer (Pale ale)";
"recipe.us_tn_hot_chicken.info" = "Nashville hot chicken is Tennessee’s signature fried chicken: marinated in buttermilk, dredged in seasoned flour, fried until crisp, then brushed with a fiery cayenne-laced hot oil paste that stains the crust red and brings a lingering heat. Traditionally it’s served simply on white bread with dill pickle chips, which soak up drippings and temper the spice. It’s bold, crunchy, and meant to be eaten hot and messy.";
"recipe.us_tn_hot_chicken.info.summary" = "Fiery Nashville chicken";
"recipe.us_tn_hot_chicken.name" = "Hot chicken";
"recipe.us_tn_hot_chicken.step1.body" = "Season %i1 with %i3 and %i4. Coat with %i2 in a bowl, cover, and refrigerate so the chicken is well seasoned and tenderized.";
"recipe.us_tn_hot_chicken.step1.title" = "Season and marinate";
"recipe.us_tn_hot_chicken.step2.body" = "Keep the chicken marinating in the refrigerator so the seasoning penetrates and the buttermilk clings well for dredging.";
"recipe.us_tn_hot_chicken.step2.title" = "Chill the marinade";
"recipe.us_tn_hot_chicken.step3.body" = "Mix %i5 with %i6, %i7, %i8, and %i9 in a wide bowl.";
"recipe.us_tn_hot_chicken.step3.title" = "Make the dredge";
"recipe.us_tn_hot_chicken.step4.body" = "Lift chicken from buttermilk, let excess drip off, then press firmly into the seasoned flour. Let the coated chicken rest on a rack so the coating hydrates and sets.";
"recipe.us_tn_hot_chicken.step4.title" = "Dredge the chicken";
"recipe.us_tn_hot_chicken.step5.body" = "Heat %i10 in a heavy pot to a steady frying temperature and keep a rack-lined pan ready for draining.";
"recipe.us_tn_hot_chicken.step5.title" = "Heat the frying oil";
"recipe.us_tn_hot_chicken.step6.body" = "Fry the chicken in batches until deeply golden, crisp, and cooked through, adjusting heat to maintain steady frying.";
"recipe.us_tn_hot_chicken.step6.title" = "Fry the chicken";
"recipe.us_tn_hot_chicken.step7.body" = "In a bowl, whisk %i11, %i12, %i13, and %i14. Whisk in %i15 until you have a smooth, spoonable paste.";
"recipe.us_tn_hot_chicken.step7.title" = "Mix the hot paste";
"recipe.us_tn_hot_chicken.step8.body" = "Brush the hot paste over the fried chicken while it is still hot, coating all sides so the crust turns red and glossy.";
"recipe.us_tn_hot_chicken.step8.title" = "Coat with hot paste";
"recipe.us_tn_hot_chicken.step9.body" = "Place chicken on %i16, top with %i17, and serve immediately while the crust is crisp and the heat is lively.";
"recipe.us_tn_hot_chicken.step9.title" = "Serve Nashville-style";
