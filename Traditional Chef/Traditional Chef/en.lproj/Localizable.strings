"recipe.nz_kanga_waru.drink.body" = "Sweet black tea suits the gentle sweetness of the corn and kūmara. For an alcoholic pairing, a late harvest Riesling works well. For a non-alcoholic option, serve hot black tea or warm milk tea.";
"recipe.nz_kanga_waru.drink.summary" = "Tea";
"recipe.nz_kanga_waru.info" = "Kānga waru is a traditional Māori steamed pudding from Aotearoa New Zealand, made from grated corn and kūmara mixed into a sweet batter, wrapped, and steamed until firm. It is closely linked with home cooking, seasonal corn harvests, and shared family meals, and is traditionally served warm in slices.";
"recipe.nz_kanga_waru.info.summary" = "Steamed corn pudding";
"recipe.nz_kanga_waru.name" = "Kānga waru";
"recipe.nz_kanga_waru.step1.body" = "Pull back the husks from %i1 and keep the best whole husks for wrapping. Remove the silk, then grate the corn from the cobs into a bowl.";
"recipe.nz_kanga_waru.step1.title" = "Prepare the corn and husks";
"recipe.nz_kanga_waru.step2.body" = "Peel %i2 and grate it finely so it blends evenly through the pudding mixture.";
"recipe.nz_kanga_waru.step2.title" = "Prepare the kūmara";
"recipe.nz_kanga_waru.step3.body" = "Add the kūmara, %i3, %i4, melted %i5, %i6, and %i7 to the grated corn and mix until a thick, even batter forms.";
"recipe.nz_kanga_waru.step3.title" = "Make the pudding mixture";
"recipe.nz_kanga_waru.step4.body" = "Lay out overlapping corn husks, spoon the mixture onto them, fold them into tight parcels, and tie securely with kitchen string.";
"recipe.nz_kanga_waru.step4.title" = "Wrap the parcels";
"recipe.nz_kanga_waru.step5.body" = "Set the parcels on a rack over boiling water in a large pot, cover tightly, and steam until the pudding is firm and fully cooked through.";
"recipe.nz_kanga_waru.step5.title" = "Steam the kānga waru";
"recipe.nz_kanga_waru.step6.body" = "Lift the parcels from the pot and let them rest briefly so the pudding sets and slices cleanly.";
"recipe.nz_kanga_waru.step6.title" = "Rest before serving";
"recipe.nz_kanga_waru.step7.body" = "Unwrap the kānga waru, cut it into pieces, and serve warm in the traditional style.";
"recipe.nz_kanga_waru.step7.title" = "Serve";
