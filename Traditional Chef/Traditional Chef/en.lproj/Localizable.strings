"recipe.th_massaman_nuea.step10.body" = "Stir in the roasted peanuts and simmer briefly so they absorb the curry flavor.";
"recipe.th_massaman_nuea.step10.title" = "Finish with peanuts";
"recipe.th_massaman_nuea.step11.body" = "Transfer the massaman beef curry to a serving bowl and serve hot with jasmine rice.";
"recipe.th_massaman_nuea.step11.title" = "Serve";
