"recipe.sn_yassa_poisson.drink.body" = "A zesty white wine such as Sauvignon Blanc pairs well with the lemony onion sauce. For a non-alcoholic option, serve chilled ginger drink or bissap (hibiscus drink).";
"recipe.sn_yassa_poisson.drink.summary" = "White wine (Sauvignon)";
"recipe.sn_yassa_poisson.info" = "Yassa Poisson is a traditional Senegalese dish of fish marinated in sharp lemon and mustard, then cooked with plenty of slowly softened onions until tangy and savory, and it is traditionally served over plain white rice to soak up the sauce.";
"recipe.sn_yassa_poisson.info.summary" = "Lemon onion fish";
"recipe.sn_yassa_poisson.name" = "Yassa fish";
"recipe.sn_yassa_poisson.step1.body" = "Slice the %i3 thinly. Juice the %i4 and mix the juice with %i5, crushed %i6, %i8, %i7, and the whole %i9.";
"recipe.sn_yassa_poisson.step1.title" = "Prep onions and marinade";
"recipe.sn_yassa_poisson.step2.body" = "Coat the %i2 with the lemon-mustard mixture, then cover and let it marinate so the flavor penetrates.";
"recipe.sn_yassa_poisson.step2.title" = "Marinate the fish";
"recipe.sn_yassa_poisson.step3.body" = "Rinse the %i1 repeatedly in a bowl with water, then drain well.";
"recipe.sn_yassa_poisson.step3.title" = "Wash the rice";
"recipe.sn_yassa_poisson.step4.body" = "Cook the rinsed rice in a saucepan with %i11 until tender, then keep covered off the heat.";
"recipe.sn_yassa_poisson.step4.title" = "Cook the rice";
"recipe.sn_yassa_poisson.step5.body" = "Heat %i10 in a skillet and add the onions with a pinch of salt, stirring until they begin to soften and release their juices.";
"recipe.sn_yassa_poisson.step5.title" = "Start the onion base";
"recipe.sn_yassa_poisson.step6.body" = "Cover and cook the onions gently, stirring occasionally, until very soft and lightly golden, adding a little water if they start to stick.";
"recipe.sn_yassa_poisson.step6.title" = "Cook the onions down";
"recipe.sn_yassa_poisson.step7.body" = "Nestle the fish into the onions, add the remaining marinade, cover, and cook gently, turning once, until the fish is just cooked through and the sauce is tangy and savory.";
"recipe.sn_yassa_poisson.step7.title" = "Cook the fish in the sauce";
"recipe.sn_yassa_poisson.step8.body" = "Remove the chili, taste and adjust seasoning, then serve the fish and onion sauce over rice.";
"recipe.sn_yassa_poisson.step8.title" = "Serve";
