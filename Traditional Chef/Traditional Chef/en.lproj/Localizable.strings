"recipe.ro_varza_a_la_cluj.drink.body" = "A light to medium-bodied Romanian red such as Fetească Neagră pairs well with the pork, sour cabbage, and baked tomato notes. For a non-alcoholic pairing, serve sparkling water or still water.";
"recipe.ro_varza_a_la_cluj.drink.summary" = "Red wine (Fetească Neagră)";
"recipe.ro_varza_a_la_cluj.info" = "Varză a la Cluj is a traditional Transylvanian baked casserole of sour cabbage layered with pork, rice, onion, thyme, and tomato, then finished with sour cream and baked until rich and fragrant. It is often described as deconstructed sarmale and is served hot as a hearty family main course.";
"recipe.ro_varza_a_la_cluj.info.summary" = "Transylvanian cabbage bake";
"recipe.ro_varza_a_la_cluj.name" = "Layered cabbage";
"recipe.ro_varza_a_la_cluj.step1.body" = "Rinse %i1 briefly only if it is very salty, drain it well, and slice it into thin shreds.";
"recipe.ro_varza_a_la_cluj.step1.title" = "Prepare the cabbage";
"recipe.ro_varza_a_la_cluj.step2.body" = "Heat part of %i5 in the frying pan, add the cabbage, and cook until softened. Add part of %i6, some %i7, and a little %i10, then cook until the cabbage is lightly tender and aromatic.";
"recipe.ro_varza_a_la_cluj.step2.title" = "Cook the cabbage";
"recipe.ro_varza_a_la_cluj.step3.body" = "Finely chop %i3. Heat the remaining oil in the pan and cook the onion until soft.";
"recipe.ro_varza_a_la_cluj.step3.title" = "Start the meat base";
"recipe.ro_varza_a_la_cluj.step4.body" = "Add %i2 and cook until crumbly and no longer raw. Stir in %i4, the remaining tomato puree, the remaining thyme, %i8, %i9, and water, then cook briefly so everything is well combined.";
"recipe.ro_varza_a_la_cluj.step4.title" = "Cook the pork and rice";
"recipe.ro_varza_a_la_cluj.step5.body" = "Spread a layer of cabbage in the baking dish, cover with a layer of the pork and rice mixture, and continue layering until everything is used, finishing with cabbage on top.";
"recipe.ro_varza_a_la_cluj.step5.title" = "Layer the casserole";
"recipe.ro_varza_a_la_cluj.step6.body" = "Spread %i11 evenly over the top of the casserole.";
"recipe.ro_varza_a_la_cluj.step6.title" = "Add the topping";
"recipe.ro_varza_a_la_cluj.step7.body" = "Bake until the rice is fully cooked, the layers are unified, and the top is lightly colored and bubbling.";
"recipe.ro_varza_a_la_cluj.step7.title" = "Bake until rich and tender";
"recipe.ro_varza_a_la_cluj.step8.body" = "Let the casserole stand for a short time so the layers settle and slice more neatly.";
"recipe.ro_varza_a_la_cluj.step8.title" = "Rest briefly";
"recipe.ro_varza_a_la_cluj.step9.body" = "Serve the varză a la Cluj hot with some of the baked sour cream from the top in each portion.";
"recipe.ro_varza_a_la_cluj.step9.title" = "Serve";
