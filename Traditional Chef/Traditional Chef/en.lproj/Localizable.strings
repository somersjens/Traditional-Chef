"recipe.ve_bienmesabe.drink.body" = "Serve with a light sweet dessert wine or demi-sec sparkling wine that complements the coconut cream and syrup. For a non-alcoholic option, serve black coffee or hot black tea.";
"recipe.ve_bienmesabe.drink.summary" = "Sweet dessert wine";
"recipe.ve_bienmesabe.info" = "Bienmesabe is a traditional Venezuelan dessert made from layers of sponge cake soaked with syrup, filled with coconut cream, and topped with meringue and cinnamon. It is served chilled as a festive dessert and is especially associated with family celebrations and classic home pastry.";
"recipe.ve_bienmesabe.info.summary" = "Layered coconut dessert";
"recipe.ve_bienmesabe.name" = "Bienmesabe";
"recipe.ve_bienmesabe.step1.body" = "Beat %i1 with %i2 until very light and voluminous, then fold in %i3 gently so the batter stays airy.";
"recipe.ve_bienmesabe.step1.title" = "Make the sponge batter";
"recipe.ve_bienmesabe.step10.body" = "Refrigerate the bienmesabe until fully cold so the layers settle and the dessert slices cleanly.";
"recipe.ve_bienmesabe.step10.title" = "Chill before serving";
"recipe.ve_bienmesabe.step2.body" = "Pour the batter into the cake pan and bake until the sponge is golden and springs back lightly when touched.";
"recipe.ve_bienmesabe.step2.title" = "Bake the sponge";
"recipe.ve_bienmesabe.step3.body" = "Let the sponge cool completely so it can be cut and layered without breaking.";
"recipe.ve_bienmesabe.step3.title" = "Cool the sponge";
"recipe.ve_bienmesabe.step4.body" = "Whisk %i4, %i5, %i6, %i7, %i8, and %i9 in a saucepan and cook gently, stirring constantly, until the cream is thick and smooth.";
"recipe.ve_bienmesabe.step4.title" = "Cook the coconut cream";
"recipe.ve_bienmesabe.step5.body" = "Remove the coconut cream from the heat and let it cool until thick but still spreadable.";
"recipe.ve_bienmesabe.step5.title" = "Cool the cream";
"recipe.ve_bienmesabe.step6.body" = "Cook %i10 with %i11 until dissolved, then remove from the heat and stir in %i12.";
"recipe.ve_bienmesabe.step6.title" = "Make the syrup";
"recipe.ve_bienmesabe.step7.body" = "Beat %i13 until foamy, then add %i14 gradually and continue beating until the meringue is thick, glossy, and firm.";
"recipe.ve_bienmesabe.step7.title" = "Prepare the meringue";
"recipe.ve_bienmesabe.step8.body" = "Cut the sponge into layers, place the first layer in the serving dish, moisten it with some syrup, spread over part of the coconut cream, and repeat until all layers are used.";
"recipe.ve_bienmesabe.step8.title" = "Assemble the dessert";
"recipe.ve_bienmesabe.step9.body" = "Cover the dessert with the meringue and dust it evenly with %i15.";
"recipe.ve_bienmesabe.step9.title" = "Finish the top";
"recipe.ve_bienmesabe.tool.t1" = "Mixing bowl";
"recipe.ve_bienmesabe.tool.t2" = "Electric mixer";
