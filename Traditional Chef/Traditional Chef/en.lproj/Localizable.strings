"recipe.pt_cataplana_de_marisco.drink.body" = "A crisp Portuguese white such as Vinho Verde (Loureiro) or a dry Arinto complements the briny shellfish and bright tomato-pepper broth without adding weight. Serve well chilled. Non-alcoholic pairing: sparkling water with lemon or a chilled alcohol-free pilsner.";
"recipe.pt_cataplana_de_marisco.drink.summary" = "White wine (Vinho Verde)";
"recipe.pt_cataplana_de_marisco.info" = "Cataplana de Marisco is a traditional Algarve seafood stew cooked in the distinctive lidded copper cataplana, where the aromatics, tomatoes, peppers, and wine create a fragrant broth that gently steams a mix of shellfish and fish. Served straight from the cataplana while sizzling hot, it is finished with fresh coriander and lemon, and traditionally accompanied by crusty bread to soak up the rich juices.";
"recipe.pt_cataplana_de_marisco.info.summary" = "Algarve seafood cataplana";
"recipe.pt_cataplana_de_marisco.name" = "Seafood cataplana";
"recipe.pt_cataplana_de_marisco.step1.body" = "Place the %i1 in a bowl with cold %i22 and enough %i17 to make it pleasantly salty. Leave to purge, then lift the clams out, rinse well, and drain.";
"recipe.pt_cataplana_de_marisco.step1.title" = "Purge the clams";
"recipe.pt_cataplana_de_marisco.step2.body" = "Clean the %i2 and discard any that are cracked. Clean the %i4 and cut into rings. Shell and devein the %i3. Cut the %i5 into chunks. Chop %i6, slice %i7, dice %i8, chop %i9 and %i19. Cut %i20 for juice and serving.";
"recipe.pt_cataplana_de_marisco.step2.title" = "Prep seafood and vegetables";
"recipe.pt_cataplana_de_marisco.step3.body" = "Warm %i11 in the cataplana over medium heat. Add the onion and cook until softened, then add the garlic and cook until fragrant. Stir in the pepper, %i14, %i15, and %i16.";
"recipe.pt_cataplana_de_marisco.step3.title" = "Build the aromatic base";
"recipe.pt_cataplana_de_marisco.step4.body" = "Add the tomatoes and %i10, season with %i18, and cook until the tomatoes soften and the mixture becomes saucy.";
"recipe.pt_cataplana_de_marisco.step4.title" = "Cook the tomato base";
"recipe.pt_cataplana_de_marisco.step5.body" = "Pour in %i12 and let it bubble briefly, then add %i13 to create a simmering sauce.";
"recipe.pt_cataplana_de_marisco.step5.title" = "Add wine and start the broth";
"recipe.pt_cataplana_de_marisco.step6.body" = "Add the clams, mussels, squid, prawns, and monkfish. Close the cataplana and cook until the shellfish open and the fish is just cooked through, shaking the pan once or twice during cooking.";
"recipe.pt_cataplana_de_marisco.step6.title" = "Steam the seafood";
"recipe.pt_cataplana_de_marisco.step7.body" = "Discard any clams or mussels that did not open. Stir in most of the coriander and squeeze in lemon juice to brighten the broth.";
"recipe.pt_cataplana_de_marisco.step7.title" = "Finish with herbs and lemon";
"recipe.pt_cataplana_de_marisco.step8.body" = "Sprinkle the remaining coriander on top and serve immediately straight from the cataplana with lemon on the side and %i21 for dipping.";
"recipe.pt_cataplana_de_marisco.step8.title" = "Serve with bread";
