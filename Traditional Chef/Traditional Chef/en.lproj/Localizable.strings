"recipe.fr_confit_de_canard.drink.body" = "Pair with a southern French red such as Madiran or Cahors that can handle rich duck and crisped skin. A farmhouse-style amber beer also works well. For a non-alcoholic option, serve sparkling water or a tart blackcurrant spritz.";
"recipe.fr_confit_de_canard.drink.summary" = "Red wine (Madiran)";
"recipe.fr_confit_de_canard.info" = "Confit de canard is a traditional French preparation from the southwest: duck legs are cured with salt, garlic, and herbs, then slowly cooked while submerged in duck fat until meltingly tender. Before serving, the legs are crisped so the skin turns golden and crackly. It is traditionally served with pommes sarladaises, potatoes sautéed in duck fat with garlic and parsley.";
"recipe.fr_confit_de_canard.info.summary" = "Duck confit classic";
"recipe.fr_confit_de_canard.name" = "Duck confit";
"recipe.fr_confit_de_canard.step1.body" = "Rub %i1 thoroughly with %i2, %i6, crushed %i3, %i4, and %i5. Place it in a dish, cover, and refrigerate.";
"recipe.fr_confit_de_canard.step1.title" = "Cure the duck";
"recipe.fr_confit_de_canard.step10.body" = "Stir in the garlic briefly, then season with %i12 and %i13 and toss with parsley off the heat.";
"recipe.fr_confit_de_canard.step10.title" = "Finish the potatoes";
"recipe.fr_confit_de_canard.step11.body" = "Serve the crisp confit legs hot with pommes sarladaises alongside.";
"recipe.fr_confit_de_canard.step11.title" = "Serve the confit";
"recipe.fr_confit_de_canard.step2.body" = "Leave the duck to cure in the refrigerator so it seasons evenly.";
"recipe.fr_confit_de_canard.step2.title" = "Chill the cure";
"recipe.fr_confit_de_canard.step3.body" = "Rinse off the cure, pat the legs very dry, and let them air-dry briefly so moisture is reduced before cooking.";
"recipe.fr_confit_de_canard.step3.title" = "Rinse and dry";
"recipe.fr_confit_de_canard.step4.body" = "Melt %i7 gently in a heavy pot and keep it at a low, steady temperature without bubbling.";
"recipe.fr_confit_de_canard.step4.title" = "Melt the duck fat";
"recipe.fr_confit_de_canard.step5.body" = "Submerge the duck legs completely in the fat and cook gently until the meat is very tender and pulls away easily from the bone.";
"recipe.fr_confit_de_canard.step5.title" = "Confit the duck";
"recipe.fr_confit_de_canard.step6.body" = "Let the duck legs cool in the fat so they stay moist and firm up for crisping.";
"recipe.fr_confit_de_canard.step6.title" = "Cool in the fat";
"recipe.fr_confit_de_canard.step7.body" = "Lift the legs from the fat, drain them well, place them skin-side up in a roasting pan, and roast until the skin is deeply golden and crisp.";
"recipe.fr_confit_de_canard.step7.title" = "Crisp the skin";
"recipe.fr_confit_de_canard.step8.body" = "Peel %i8 and slice it into even rounds. Mince %i10 and chop %i11.";
"recipe.fr_confit_de_canard.step8.title" = "Prep the potatoes";
"recipe.fr_confit_de_canard.step9.body" = "Heat %i9 in a skillet and cook the potatoes until golden and tender, turning so they colour evenly.";
"recipe.fr_confit_de_canard.step9.title" = "Cook the potatoes";
