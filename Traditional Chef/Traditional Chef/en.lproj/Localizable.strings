"recipe.gr_revithada.step3.title" = "Slow-bake the chickpeas";
"recipe.gr_revithada.step4.body" = "Let them rest so the liquid settles and thickens slightly before serving.";
"recipe.gr_revithada.step4.title" = "Rest the chickpeas";
