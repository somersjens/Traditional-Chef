"recipe.th_tom_yum_goong.drink.body" = "A crisp Sauvignon Blanc pairs well with the citrusy herbs and sharp lime acidity while staying fresh with the shrimp. For a non-alcoholic option, serve chilled jasmine tea or plain cold water.";
"recipe.th_tom_yum_goong.drink.summary" = "White wine (Sauvignon)";
"recipe.th_tom_yum_goong.info" = "Tom Yum Goong is a traditional Thai hot and sour soup made with shrimp in a fragrant broth infused with lemongrass, galangal, and makrut lime leaves, then balanced with fish sauce and lime juice. It is commonly served hot as part of a shared meal with jasmine rice, with a bright spicy-sour flavor.";
"recipe.th_tom_yum_goong.info.summary" = "Hot sour shrimp soup";
"recipe.th_tom_yum_goong.name" = "Tom yum goong";
"recipe.th_tom_yum_goong.step1.body" = "Peel and clean the %i1, keeping them whole or halved as preferred. Trim and bruise the %i3, slice the %i4, tear the %i5, trim the %i6, slice the %i7, and chop the %i10.";
"recipe.th_tom_yum_goong.step1.title" = "Prepare ingredients";
"recipe.th_tom_yum_goong.step2.body" = "Rinse the %i11 until the water runs mostly clear. Put it in a saucepan with %i12 and bring it to a boil.";
"recipe.th_tom_yum_goong.step2.title" = "Start the rice";
"recipe.th_tom_yum_goong.step3.body" = "Cover and cook on low heat until the water is absorbed and the rice is tender. Rest covered off the heat.";
"recipe.th_tom_yum_goong.step3.title" = "Cook the rice";
"recipe.th_tom_yum_goong.step4.body" = "Add soup %i2, lemongrass, galangal, and makrut lime leaves to the soup pot and bring to a gentle simmer so the aromatics release their flavor.";
"recipe.th_tom_yum_goong.step4.title" = "Infuse the soup base";
"recipe.th_tom_yum_goong.step5.body" = "Add the mushrooms and simmer until they begin to soften and the broth becomes fragrant.";
"recipe.th_tom_yum_goong.step5.title" = "Cook the mushrooms";
"recipe.th_tom_yum_goong.step6.body" = "Add the shrimp and simmer gently until just cooked through and still tender.";
"recipe.th_tom_yum_goong.step6.title" = "Cook the shrimp";
"recipe.th_tom_yum_goong.step7.body" = "Add the %i8 and bird's eye chili and simmer briefly so the flavors combine.";
"recipe.th_tom_yum_goong.step7.title" = "Season the soup";
"recipe.th_tom_yum_goong.step8.body" = "Turn off the heat and stir in the %i9 and most of the coriander leaves to keep the aroma bright.";
"recipe.th_tom_yum_goong.step8.title" = "Finish with lime and herbs";
"recipe.th_tom_yum_goong.step9.body" = "Ladle the tom yum goong into a serving bowl, top with the remaining coriander leaves, and serve hot with jasmine rice.";
"recipe.th_tom_yum_goong.step9.title" = "Serve";
