"recipe.us_ky_burgoo.step3.title" = "Build the stew";
"recipe.us_ky_burgoo.step4.body" = "Keep the pot at a gentle simmer, stirring occasionally, until the meats are very tender and begin to fall apart.";
"recipe.us_ky_burgoo.step4.title" = "Slow simmer until tender";
"recipe.us_ky_burgoo.step5.body" = "Remove the meat pieces, pull them into bite-size shreds, discard bones and excess fat, then return the shredded meat to the pot.";
"recipe.us_ky_burgoo.step5.title" = "Shred the meats";
"recipe.us_ky_burgoo.step6.body" = "Add %i8 and simmer until they are nearly tender, stirring occasionally so nothing sticks as the stew thickens.";
"recipe.us_ky_burgoo.step6.title" = "Cook potatoes";
"recipe.us_ky_burgoo.step7.body" = "Add %i10, %i11, and %i9 and simmer until the vegetables are tender and the stew is thick and cohesive.";
"recipe.us_ky_burgoo.step7.title" = "Finish with vegetables";
"recipe.us_ky_burgoo.step8.body" = "Stir in %i17, then adjust salt and pepper so the stew tastes bold and balanced.";
"recipe.us_ky_burgoo.step8.title" = "Season to taste";
"recipe.us_ky_burgoo.step9.body" = "Heat the oven with the cast-iron skillet inside so the pan gets very hot.";
"recipe.us_ky_burgoo.step9.title" = "Heat the skillet for cornbread";
