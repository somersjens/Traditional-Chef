"recipe.th_pad_thai.drink.body" = "A cold light lager pairs well with the sweet-sour-savory noodle flavors and wok aroma. For a non-alcoholic option, serve chilled jasmine tea, unsweetened iced tea, or cold water with lime.";
"recipe.th_pad_thai.drink.summary" = "Beer (Lager)";
"recipe.th_pad_thai.info" = "Pad Thai is a traditional Thai stir-fried rice noodle dish made with a tamarind palm sugar fish sauce seasoning, shrimp, tofu, egg, bean sprouts, garlic chives, and peanuts. It is cooked quickly over high heat and served immediately with lime wedges and chili flakes as a complete street-food style meal.";
"recipe.th_pad_thai.info.summary" = "Thai fried noodles";
"recipe.th_pad_thai.name" = "Pad Thai";
"recipe.th_pad_thai.step1.body" = "Soak the %i1 in %i2 until pliable but not fully soft, then drain well and set aside.";
"recipe.th_pad_thai.step1.title" = "Soak the noodles";
"recipe.th_pad_thai.step10.body" = "Divide the pad thai onto serving plates and top with the crushed peanuts.";
"recipe.th_pad_thai.step10.title" = "Plate the noodles";
"recipe.th_pad_thai.step11.body" = "Serve immediately with the remaining bean sprouts, %i18 wedges, and %i19 on the side.";
"recipe.th_pad_thai.step11.title" = "Serve with condiments";
"recipe.th_pad_thai.step2.body" = "Soak the %i13 in warm %i14, mash well, and strain. Combine the tamarind extract with %i15 and %i16 in a small saucepan and cook gently until smooth and balanced.";
"recipe.th_pad_thai.step2.title" = "Prepare the pad thai sauce";
"recipe.th_pad_thai.step3.body" = "Peel and clean the %i3, cut the %i4 into small pieces, chop the %i5 and %i6, chop the %i8, cut the %i11 into short lengths, and lightly crush the %i17.";
"recipe.th_pad_thai.step3.title" = "Prepare the ingredients";
"recipe.th_pad_thai.step4.body" = "Heat the wok over high heat until very hot, then add part of the %i12.";
"recipe.th_pad_thai.step4.title" = "Heat the wok";
"recipe.th_pad_thai.step5.body" = "Add the garlic and shallots and stir-fry briefly until fragrant. Add the %i7, dried shrimp, and preserved radish, then stir-fry until aromatic.";
"recipe.th_pad_thai.step5.title" = "Fry aromatics and tofu";
"recipe.th_pad_thai.step6.body" = "Add the shrimp and stir-fry until almost cooked through.";
"recipe.th_pad_thai.step6.title" = "Cook the shrimp";
"recipe.th_pad_thai.step7.body" = "Add the soaked noodles and pour in most of the pad thai sauce. Toss and stir-fry so the noodles absorb the sauce and begin to soften.";
"recipe.th_pad_thai.step7.title" = "Add noodles and sauce";
"recipe.th_pad_thai.step8.body" = "Push the noodles aside, add a little oil if needed, crack in the %i9, and scramble lightly, then fold into the noodles.";
"recipe.th_pad_thai.step8.title" = "Add egg";
"recipe.th_pad_thai.step9.body" = "Add most of the %i10 and garlic chives, then toss quickly until just wilted and the noodles are tender and glossy. Add a little more sauce if needed.";
"recipe.th_pad_thai.step9.title" = "Finish with sprouts and chives";
