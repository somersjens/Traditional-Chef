"recipe.ru_ukha.drink.body" = "A crisp dry white such as Riesling or Sauvignon Blanc pairs well with the clean fish broth and herbs. If you prefer spirits, a small shot of chilled vodka is also traditional. Non-alcoholic pairing: hot black tea or sparkling water.";
"recipe.ru_ukha.drink.summary" = "White wine (Riesling)";
"recipe.ru_ukha.info" = "Ukha is a traditional Russian clear fish soup made by gently simmering fish with aromatics to produce a clean, fragrant broth, then adding potatoes and finishing with herbs. It is served hot as a light first course, often with rye bread, and valued for its clarity and delicate fish flavor.";
"recipe.ru_ukha.info.summary" = "Clear fish broth";
"recipe.ru_ukha.name" = "Ukha";
"recipe.ru_ukha.step1.body" = "Rinse %i1 and remove any bones as needed. Peel and dice %i2, slice %i3 and %i4, mince %i5, and set aside the herbs for finishing.";
"recipe.ru_ukha.step1.title" = "Prep the fish and vegetables";
"recipe.ru_ukha.step2.body" = "Bring %i10 to a gentle simmer in a pot. Add fish with onion, carrot, %i6, and %i7, and skim carefully so the broth stays clear.";
"recipe.ru_ukha.step2.title" = "Start a clear broth";
"recipe.ru_ukha.step3.body" = "Simmer gently until the fish is just cooked. Remove the fish to a plate and strain the broth to remove aromatics and spices.";
"recipe.ru_ukha.step3.title" = "Cook the fish and strain";
"recipe.ru_ukha.step4.body" = "Return the clear broth to the pot, add potatoes, and simmer until the potatoes are tender.";
"recipe.ru_ukha.step4.title" = "Cook the potatoes";
"recipe.ru_ukha.step5.body" = "Return pieces of fish to the soup, add garlic and %i8, adjust %i9, and serve hot with %i11.";
"recipe.ru_ukha.step5.title" = "Finish and serve";
