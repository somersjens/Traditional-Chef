"recipe.pl_ryba_po_grecku.step1.title" = "Prepare the fish";
"recipe.pl_ryba_po_grecku.step2.body" = "Heat %i5 in a skillet and fry the fish until golden and cooked through, turning carefully. Transfer to a dish to cool slightly.";
"recipe.pl_ryba_po_grecku.step2.title" = "Fry the fish";
