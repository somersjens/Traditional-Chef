"recipe.nl_erwtensoep.info" = "Erwtensoep, also known as snert, is a traditional Dutch thick pea soup made by slowly simmering split peas with pork, smoked sausage, and winter vegetables until creamy and hearty. It is served steaming hot, typically with slices of rye bread spread with butter, making it a classic cold-weather main meal.";
"recipe.nl_erwtensoep.info.summary" = "Dutch winter pea soup";
"recipe.nl_erwtensoep.name" = "Pea soup";
