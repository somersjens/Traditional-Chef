"recipe.pt_bacalhau_a_gomes_de_sa.drink.body" = "A fresh Portuguese white such as a Douro Branco or an Arinto highlights the cod and stands up to the olive oil richness. If you prefer red, choose a light, low-tannin Portuguese red served slightly cool. Non-alcoholic pairing: sparkling water with lemon or a crisp alcohol-free white grape spritzer.";
"recipe.pt_bacalhau_a_gomes_de_sa.drink.summary" = "White wine (Douro)";
"recipe.pt_bacalhau_a_gomes_de_sa.info" = "Bacalhau a Gomes de Sa is a traditional Porto-style baked casserole of desalted salt cod and sliced potatoes layered with softened onions and garlic and generously moistened with olive oil. The cod is traditionally flaked and briefly softened in milk before being combined and baked, then finished with hard-boiled eggs, black olives, and parsley. Serve hot as a hearty main course, straight from the oven.";
"recipe.pt_bacalhau_a_gomes_de_sa.info.summary" = "Porto cod potato bake";
"recipe.pt_bacalhau_a_gomes_de_sa.name" = "Bacalhau à Gomes de Sá";
"recipe.pt_bacalhau_a_gomes_de_sa.step1.body" = "Rinse the %i1, then soak it in plenty of cold %i12 in the refrigerator, changing the water several times, until properly desalinated.";
"recipe.pt_bacalhau_a_gomes_de_sa.step1.title" = "Desalt the cod";
"recipe.pt_bacalhau_a_gomes_de_sa.step10.body" = "Top with sliced eggs, %i8, and chopped %i9, then serve hot.";
"recipe.pt_bacalhau_a_gomes_de_sa.step10.title" = "Finish and serve";
"recipe.pt_bacalhau_a_gomes_de_sa.step2.body" = "Place the soaked cod in a pot, cover with water, bring to a gentle simmer, and cook until it flakes easily. Drain and let it cool enough to handle.";
"recipe.pt_bacalhau_a_gomes_de_sa.step2.title" = "Cook cod and cool";
"recipe.pt_bacalhau_a_gomes_de_sa.step3.body" = "Flake the cod into small pieces, removing skin and bones. Cover the cod with %i2 in a bowl and let it stand to soften, then drain well.";
"recipe.pt_bacalhau_a_gomes_de_sa.step3.title" = "Soften cod in milk";
"recipe.pt_bacalhau_a_gomes_de_sa.step4.body" = "Boil the %i3 in %i12 until just tender. Drain, let cool slightly, then peel and slice into thick rounds.";
"recipe.pt_bacalhau_a_gomes_de_sa.step4.title" = "Boil and slice potatoes";
"recipe.pt_bacalhau_a_gomes_de_sa.step5.body" = "Boil the %i7 until hard-set, cool, peel, and slice.";
"recipe.pt_bacalhau_a_gomes_de_sa.step5.title" = "Boil the eggs";
"recipe.pt_bacalhau_a_gomes_de_sa.step6.body" = "Warm %i6 in a skillet over medium-low heat. Add %i4 and cook until very soft, then add %i5 and cook until fragrant. Season with %i11.";
"recipe.pt_bacalhau_a_gomes_de_sa.step6.title" = "Cook onions and garlic";
"recipe.pt_bacalhau_a_gomes_de_sa.step7.body" = "Add the drained cod to the skillet and gently fold to coat with the onions and oil, warming it through and tasting for %i10.";
"recipe.pt_bacalhau_a_gomes_de_sa.step7.title" = "Combine cod with onions";
"recipe.pt_bacalhau_a_gomes_de_sa.step8.body" = "Spread a layer of potatoes in a baking dish, add a layer of the cod-onion mixture, and repeat until used up, finishing with potatoes. Drizzle with olive oil.";
"recipe.pt_bacalhau_a_gomes_de_sa.step8.title" = "Layer the casserole";
"recipe.pt_bacalhau_a_gomes_de_sa.step9.body" = "Bake until the casserole is hot through and the top is lightly golden and edges are bubbling with olive oil.";
"recipe.pt_bacalhau_a_gomes_de_sa.step9.title" = "Bake";
