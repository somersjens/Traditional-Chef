"recipe.th_miang_kham.drink.body" = "A dry sparkling wine refreshes the palate between the sweet salty herbal bites without overpowering the aromatics. For a non-alcoholic option, serve chilled pandan tea, unsweetened jasmine tea, or cold water.";
"recipe.th_miang_kham.drink.summary" = "Sparkling wine";
"recipe.th_miang_kham.info" = "Miang Kham is a traditional Thai bite-size appetizer of cha plu leaves wrapped around toasted coconut, peanuts, dried shrimp, lime, shallot, ginger, and chili, finished with a thick sweet-salty sauce. It is served as a shared platter for guests, with each person assembling small wraps to taste.";
"recipe.th_miang_kham.info.summary" = "Thai leaf-wrap bites";
"recipe.th_miang_kham.name" = "Miang kham";
