"recipe.ch_alplermagronen.drink.body" = "Serve with a dry Swiss white wine such as Chasselas, which balances the rich cheese and cream. A light lager also pairs well. For a non-alcoholic option, serve sparkling apple juice or hot black tea.";
"recipe.ch_alplermagronen.drink.summary" = "White wine (Chasselas)";
"recipe.ch_alplermagronen.info" = "Älplermagronen is a traditional Swiss alpine dish made with macaroni, potatoes, cream, cheese, and fried onions, and it is classically served with applesauce on the side. It is a hearty mountain meal associated with central Swiss rural cooking and is served hot as a substantial main course.";
"recipe.ch_alplermagronen.info.summary" = "Alpine macaroni classic";
"recipe.ch_alplermagronen.name" = "Älplermagronen";
