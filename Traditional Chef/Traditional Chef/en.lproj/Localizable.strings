"recipe.ru_kotlety_pozharskie.drink.body" = "A dry, medium-bodied white such as Chardonnay or a crisp high-acid white pairs well with the buttery richness and crisp crust. A light red can also work if served slightly cool. Non-alcoholic pairing: sparkling water or strong black tea.";
"recipe.ru_kotlety_pozharskie.drink.summary" = "White wine (Chardonnay)";
"recipe.ru_kotlety_pozharskie.info" = "Kotlety Pozharskie are a classic Russian dish of very tender chopped chicken cutlets enriched with butter, shaped and coated in breadcrumbs, then fried and finished gently so they stay juicy inside with a crisp crust. Traditionally served hot with mashed potatoes so the buttery juices and crust can be enjoyed together.";
"recipe.ru_kotlety_pozharskie.info.summary" = "Buttery chicken cutlets";
"recipe.ru_kotlety_pozharskie.name" = "Pozharsky cutlets";
"recipe.ru_kotlety_pozharskie.step1.body" = "Peel and cut the %i12 into even chunks and set them ready for boiling.";
"recipe.ru_kotlety_pozharskie.step1.title" = "Prep for mashed potatoes";
"recipe.ru_kotlety_pozharskie.step2.body" = "Cook the potatoes in salted %i16 until very tender, then drain well and let them steam dry briefly.";
"recipe.ru_kotlety_pozharskie.step2.title" = "Boil potatoes";
"recipe.ru_kotlety_pozharskie.step3.body" = "Warm %i13. Mash the potatoes with %i14 and warm milk until smooth, season with %i15, and keep warm.";
"recipe.ru_kotlety_pozharskie.step3.title" = "Mash the potatoes";
"recipe.ru_kotlety_pozharskie.step4.body" = "Soak %i4 in %i5, then squeeze it gently. Finely chop %i3 and sauté it in a little %i2 until soft, then cool. Chop %i1 finely, then mix with the soaked bread, onion, %i7, %i8, and %i6 until cohesive.";
"recipe.ru_kotlety_pozharskie.step4.title" = "Make the cutlet mixture";
"recipe.ru_kotlety_pozharskie.step5.body" = "Cut butter into small pieces and fold it through the mixture. Chill briefly so it firms and shapes cleanly.";
"recipe.ru_kotlety_pozharskie.step5.title" = "Chill the mixture";
"recipe.ru_kotlety_pozharskie.step6.body" = "Form oval cutlets, then coat them thoroughly in %i9, pressing so the coating adheres.";
"recipe.ru_kotlety_pozharskie.step6.title" = "Shape and bread";
"recipe.ru_kotlety_pozharskie.step7.body" = "Heat %i10 with %i11 in a skillet over medium heat. Fry the cutlets until deeply golden on both sides, turning carefully so the crust stays intact.";
"recipe.ru_kotlety_pozharskie.step7.title" = "Pan fry";
"recipe.ru_kotlety_pozharskie.step8.body" = "Lower the heat, cover, and cook until the cutlets are just cooked through and remain juicy.";
"recipe.ru_kotlety_pozharskie.step8.title" = "Finish gently";
"recipe.ru_kotlety_pozharskie.step9.body" = "Serve the cutlets immediately with mashed potatoes.";
"recipe.ru_kotlety_pozharskie.step9.title" = "Serve";
"recipe.ru_kotlety_pozharskie.tool.t1" = "Cutting board";
