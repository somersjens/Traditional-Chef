"recipe.bd_shorshe_ilish.drink.body" = "An off-dry Riesling or crisp aromatic white balances the assertive mustard heat and rich oily fish. If you prefer red, choose a very light, low-tannin red served well chilled. Non-alcoholic pairing: chilled lime soda or unsweetened black tea.";
"recipe.bd_shorshe_ilish.drink.summary" = "White wine (Riesling)";
"recipe.bd_shorshe_ilish.info" = "Shorshe ilish is an iconic Bengali-Bangladeshi dish where prized hilsa is gently cooked in a pungent mustard paste gravy, brightened with turmeric and green chilies and finished with the aroma of mustard oil. The fish is simmered carefully so it stays intact while absorbing the sharp, nutty mustard flavor. It is traditionally served hot with plain steamed rice.";
"recipe.bd_shorshe_ilish.info.summary" = "Mustard hilsa classic";
"recipe.bd_shorshe_ilish.name" = "Shorshe ilish";
"recipe.bd_shorshe_ilish.step1.body" = "Rub the %i1 with %i3 and %i2 and let them sit briefly.";
"recipe.bd_shorshe_ilish.step1.title" = "Season the fish";
"recipe.bd_shorshe_ilish.step2.body" = "Soak the %i5 briefly in %i8, then grind to a smooth paste with %i7 and a pinch of salt, adding water only as needed.";
"recipe.bd_shorshe_ilish.step2.title" = "Make the mustard paste";
"recipe.bd_shorshe_ilish.step3.body" = "Heat some %i4 in a wide pan and lightly fry the fish pieces just until the surface firms, then remove carefully.";
"recipe.bd_shorshe_ilish.step3.title" = "Lightly fry the fish";
"recipe.bd_shorshe_ilish.step4.body" = "Add the remaining mustard oil to the pan and temper with %i6 until they crackle.";
"recipe.bd_shorshe_ilish.step4.title" = "Temper the oil";
"recipe.bd_shorshe_ilish.step5.body" = "Lower the heat and add the mustard paste, stirring gently, then add water and bring to a gentle simmer.";
"recipe.bd_shorshe_ilish.step5.title" = "Cook the mustard gravy";
"recipe.bd_shorshe_ilish.step6.body" = "Slide the fish into the simmering gravy along with extra green chilies, cover, and cook gently until the fish is cooked through without breaking.";
"recipe.bd_shorshe_ilish.step6.title" = "Simmer the fish";
"recipe.bd_shorshe_ilish.step7.body" = "Drizzle a little raw mustard oil over the curry, then turn off the heat and keep covered briefly so the aroma settles.";
"recipe.bd_shorshe_ilish.step7.title" = "Finish with mustard aroma";
"recipe.bd_shorshe_ilish.step8.body" = "Rinse the %i9. Combine it with %i10 and a pinch of salt, bring to a simmer, then cover and cook gently until tender.";
"recipe.bd_shorshe_ilish.step8.title" = "Cook the rice";
"recipe.bd_shorshe_ilish.step9.body" = "Rest the rice covered so it fluffs up. Serve the shorshe ilish hot with steamed rice.";
"recipe.bd_shorshe_ilish.step9.title" = "Rest and serve";
