"recipe.sa_saleeg.drink.summary" = "White wine (Viognier)";
"recipe.sa_saleeg.info" = "Saleeg is a traditional Saudi main dish from the Hejaz, especially associated with Taif, made with chicken broth, milk, butter, and rice cooked to a soft creamy texture and topped with roasted chicken. It is a comforting communal dish served hot for family meals and hospitality, traditionally accompanied by fresh daqoos on the side.";
"recipe.sa_saleeg.info.summary" = "Creamy milk rice";
"recipe.sa_saleeg.name" = "Saleeg";
"recipe.sa_saleeg.step1.body" = "Put %i1 in a large pot with %i2, %i3, %i4, %i5, %i6, part of %i7, %i8, and %i9.";
"recipe.sa_saleeg.step1.title" = "Start the broth";
"recipe.sa_saleeg.step10.body" = "Spread the saleeg on a serving platter, place the roasted chicken on top, and serve immediately with daqoos on the side.";
"recipe.sa_saleeg.step10.title" = "Serve the dish";
"recipe.sa_saleeg.step2.body" = "Bring the pot to a boil, skim the surface, then simmer gently until the chicken is tender and the broth is rich and fragrant.";
"recipe.sa_saleeg.step2.title" = "Simmer the chicken";
"recipe.sa_saleeg.step3.body" = "Lift out the chicken, rub it with some of %i10 and a little of the broth seasoning, then place it in a roasting pan.";
"recipe.sa_saleeg.step3.title" = "Prepare the chicken for roasting";
"recipe.sa_saleeg.step4.body" = "Roast the chicken until golden and lightly crisp on the outside while keeping it moist inside.";
"recipe.sa_saleeg.step4.title" = "Roast the chicken";
"recipe.sa_saleeg.step5.body" = "Strain the broth and keep it hot. Rinse %i11 until the water runs mostly clear, then drain it well.";
"recipe.sa_saleeg.step5.title" = "Strain the broth and rinse the rice";
"recipe.sa_saleeg.step6.body" = "Return enough hot broth to the pot, add the rice, and cook it gently until very soft and beginning to break down.";
"recipe.sa_saleeg.step6.title" = "Cook the rice in broth";
"recipe.sa_saleeg.step7.body" = "Add %i12 gradually with %i13 and the rest of the salt, then stir steadily until the rice becomes creamy, smooth, and porridge-like.";
"recipe.sa_saleeg.step7.title" = "Add the milk and enrich the saleeg";
