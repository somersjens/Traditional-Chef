"recipe.jp_nigiri_zushi.drink.body" = "Dry sake or a crisp Japanese lager pairs well with the clean flavors of vinegared rice and fresh seafood. For a non-alcoholic pairing, serve hot green tea or chilled barley tea.";
"recipe.jp_nigiri_zushi.drink.summary" = "Sake";
"recipe.jp_nigiri_zushi.info" = "Nigiri zushi is a traditional Japanese sushi style of hand-pressed vinegared rice topped with sliced seafood, usually served with wasabi, soy sauce, and pickled ginger. It is commonly enjoyed at sushi counters and home celebrations, where the balance of rice texture, fresh fish, and precise shaping is central to the dish.";
"recipe.jp_nigiri_zushi.info.summary" = "Hand-pressed sushi";
"recipe.jp_nigiri_zushi.name" = "Nigiri sushi";
"recipe.jp_nigiri_zushi.step1.body" = "Rinse the %i1 until the water runs mostly clear, then soak briefly and drain well for even cooking.";
"recipe.jp_nigiri_zushi.step1.title" = "Rinse and soak the rice";
"recipe.jp_nigiri_zushi.step2.body" = "Cook the rice with %i2 until tender, then let it rest covered so the grains finish steaming.";
"recipe.jp_nigiri_zushi.step2.title" = "Cook the rice";
"recipe.jp_nigiri_zushi.step3.body" = "Warm the %i3, %i4, and %i5 gently until dissolved, then cool slightly.";
"recipe.jp_nigiri_zushi.step3.title" = "Make sushi seasoning";
"recipe.jp_nigiri_zushi.step4.body" = "Transfer the hot rice to a wide bowl and fold in the seasoning gently until glossy, then cool to warm body temperature.";
"recipe.jp_nigiri_zushi.step4.title" = "Season and cool the rice";
"recipe.jp_nigiri_zushi.step5.body" = "Slice the %i6, %i7, and %i8 into nigiri topping pieces, prepare the %i9, and cook the %i10 in hot water until just done, then cool and split for topping.";
"recipe.jp_nigiri_zushi.step5.title" = "Prepare seafood toppings";
"recipe.jp_nigiri_zushi.step6.body" = "Set out %i11, %i12, and %i13, and place %i15 in a small bowl for moistening your hands while shaping.";
"recipe.jp_nigiri_zushi.step6.title" = "Prepare condiments and hand water";
"recipe.jp_nigiri_zushi.step7.body" = "With lightly moistened hands, form small oval rice portions and keep them uniform so they hold together without being compressed too tightly.";
"recipe.jp_nigiri_zushi.step7.title" = "Shape the nigiri rice";
"recipe.jp_nigiri_zushi.step8.body" = "Place a small amount of wasabi between each topping and rice oval, then press and shape gently into neat nigiri. Use narrow %i14 bands only where needed to secure delicate toppings.";
"recipe.jp_nigiri_zushi.step8.title" = "Assemble the nigiri";
"recipe.jp_nigiri_zushi.step9.body" = "Arrange the nigiri on a tray or plates and serve immediately with soy sauce and pickled ginger on the side.";
"recipe.jp_nigiri_zushi.step9.title" = "Arrange and serve";
