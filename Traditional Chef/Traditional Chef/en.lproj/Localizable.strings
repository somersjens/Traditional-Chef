"recipe.gr_pastitsio.step6.title" = "Assemble the layers";
"recipe.gr_pastitsio.step7.body" = "Bake until the top is golden and the casserole is bubbling at the edges.";
"recipe.gr_pastitsio.step7.title" = "Bake the pastitsio";
"recipe.gr_pastitsio.step8.body" = "Let the pastitsio rest so the layers set, then cut it into squares and serve hot.";
