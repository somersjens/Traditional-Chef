"recipe.ph_crispy_pata.drink.body" = "A light red wine such as Pinot Noir can pair with the rich pork and savory crust, while a crisp lager is a classic match. For a non-alcoholic option, serve calamansi juice or iced tea.";
"recipe.ph_crispy_pata.drink.summary" = "Red wine (Pinot Noir)";
"recipe.ph_crispy_pata.info" = "Crispy pata is a traditional Filipino dish of pork hock simmered with aromatics until tender, dried, then deep-fried until the skin becomes blistered and crisp while the meat stays succulent. It is commonly served as a celebratory main or shared dish with a sharp soy-vinegar dipping sauce and steamed rice.";
"recipe.ph_crispy_pata.info.summary" = "Crispy pork hock";
"recipe.ph_crispy_pata.name" = "Crispy pata";
"recipe.ph_crispy_pata.step1.body" = "Rinse the %i1. Peel and quarter the %i3, lightly crush the %i4, and set out the %i5 and %i6.";
"recipe.ph_crispy_pata.step1.title" = "Prepare pork and aromatics";
"recipe.ph_crispy_pata.step10.body" = "Carefully lower the dried pork hock into the hot oil and fry, turning as needed, until the skin is blistered and crisp and the exterior is deeply golden.";
"recipe.ph_crispy_pata.step10.title" = "Deep-fry pork hock";
"recipe.ph_crispy_pata.step11.body" = "Remove the crispy pata and let it drain briefly on a rack so excess oil runs off.";
"recipe.ph_crispy_pata.step11.title" = "Drain and rest";
"recipe.ph_crispy_pata.step12.body" = "Chop or carve the crispy pata into serving pieces and serve hot with steamed rice and the dipping sauce.";
"recipe.ph_crispy_pata.step12.title" = "Serve";
"recipe.ph_crispy_pata.step2.body" = "Place the pork hock in a stockpot with %i2, onion, garlic, bay leaves, peppercorns, and %i7. Bring to a boil, skim as needed, then simmer gently until the pork is tender.";
"recipe.ph_crispy_pata.step2.title" = "Simmer pork hock";
"recipe.ph_crispy_pata.step3.body" = "Lift out the pork hock, drain it very well, and rub the skin all over with %i8.";
"recipe.ph_crispy_pata.step3.title" = "Drain and season";
"recipe.ph_crispy_pata.step4.body" = "Place the pork hock on a wire rack and let the surface dry thoroughly so the skin will crisp during frying.";
"recipe.ph_crispy_pata.step4.title" = "Air-dry pork hock";
"recipe.ph_crispy_pata.step5.body" = "Combine %i10, %i11, %i12, chopped %i13, and sliced %i14 in a small bowl and set aside.";
"recipe.ph_crispy_pata.step5.title" = "Make dipping sauce";
"recipe.ph_crispy_pata.step6.body" = "Rinse the %i15 until the water runs mostly clear, then drain.";
"recipe.ph_crispy_pata.step6.title" = "Wash rice";
"recipe.ph_crispy_pata.step7.body" = "Place the rice in a saucepan with %i16, bring to a boil, cover, and cook gently until the rice is tender and the water is absorbed.";
"recipe.ph_crispy_pata.step7.title" = "Cook rice";
"recipe.ph_crispy_pata.step8.body" = "Turn off the heat and let the covered rice rest, then fluff before serving.";
"recipe.ph_crispy_pata.step8.title" = "Rest rice";
"recipe.ph_crispy_pata.step9.body" = "Heat the %i9 in a deep heavy pot until hot enough for deep-frying and ready for a steady fry.";
