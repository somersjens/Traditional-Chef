"recipe.sa_hanini.drink.body" = "A lightly sweet dessert wine such as Muscat pairs well with the caramel depth of dates and the warm spice of cardamom and saffron. For a non-alcoholic pairing, serve Arabic coffee or hot black tea.";
"recipe.sa_hanini.drink.summary" = "Dessert wine (Muscat)";
"recipe.sa_hanini.info" = "Hanini is a traditional Saudi dessert from Najd, especially associated with Qassim, made by mashing soft dates with crumbled brown bread, ghee, cardamom, and saffron into a warm, rich winter sweet. It is served hot for family gatherings and cold-weather hospitality, traditionally shaped on a platter and eaten communally.";
"recipe.sa_hanini.info.summary" = "Dates and torn bread";
"recipe.sa_hanini.name" = "Hanini";
"recipe.sa_hanini.step1.body" = "Tear %i1 into pieces and dry it in the oven until firm and crisp so it can be crumbled finely.";
"recipe.sa_hanini.step1.title" = "Dry the bread";
"recipe.sa_hanini.step2.body" = "Soak %i5 in a little %i6 so its color and fragrance bloom before it is added to the dessert.";
"recipe.sa_hanini.step2.title" = "Prepare the saffron";
"recipe.sa_hanini.step3.body" = "Crush the dried bread into fine crumbs so it mixes evenly with the dates.";
"recipe.sa_hanini.step3.title" = "Crumble the bread";
"recipe.sa_hanini.step4.body" = "Heat part of %i3 in the skillet, add %i2, and stir until they loosen and become easy to mash.";
"recipe.sa_hanini.step4.title" = "Warm the dates";
"recipe.sa_hanini.step5.body" = "Add the bread crumbs, %i4, the saffron with its soaking liquid, and the remaining ghee, then mash and stir until the mixture becomes smooth, thick, and evenly combined.";
"recipe.sa_hanini.step5.title" = "Mash and season the mixture";
"recipe.sa_hanini.step6.body" = "Keep cooking over low heat, stirring constantly, until the hanini is hot, aromatic, and glossy and pulls together into a soft mass.";
"recipe.sa_hanini.step6.title" = "Cook until glossy";
"recipe.sa_hanini.step7.body" = "Pile the hanini onto a serving platter and serve it hot in the traditional style.";
"recipe.sa_hanini.step7.title" = "Shape and serve";
