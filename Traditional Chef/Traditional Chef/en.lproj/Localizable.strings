"recipe.tw_niu_rou_mian.drink.body" = "A light-bodied red such as Pinot Noir or a soft Grenache can match the savory braised beef and spice without overpowering the broth. For a non-alcoholic option, serve hot oolong tea or unsweetened barley tea.";
"recipe.tw_niu_rou_mian.drink.summary" = "Red wine (Pinot Noir)";
"recipe.tw_niu_rou_mian.info" = "Niu Rou Mian is a traditional Taiwanese red-braised beef noodle soup with tender beef shank, wheat noodles, and a deep soy-based broth scented with ginger, garlic, scallion, and warm spices. It is a staple comfort meal in Taiwan and is commonly served hot with pickled mustard greens and fresh scallion.";
"recipe.tw_niu_rou_mian.info.summary" = "Taiwan beef noodle soup";
"recipe.tw_niu_rou_mian.name" = "Beef noodle soup";
