"recipe.tr_iskender_kebab.step7.title" = "Sear the meat slices";
"recipe.tr_iskender_kebab.step8.body" = "Spread the warm bread on a platter, layer the hot meat over it, and spoon hot tomato-butter sauce generously on top.";
"recipe.tr_iskender_kebab.step8.title" = "Assemble";
