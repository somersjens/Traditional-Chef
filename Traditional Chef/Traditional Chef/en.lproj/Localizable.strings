"recipe.pk_chicken_karahi.drink.body" = "A light to medium red such as Grenache or Pinot Noir can work with the tomato-rich spicy masala without overwhelming it. A crisp lager also pairs well. Non-alcoholic pairing: salted lassi or hot black tea are both excellent choices.";
"recipe.pk_chicken_karahi.drink.summary" = "Red wine (Grenache)";
"recipe.pk_chicken_karahi.info" = "Chicken Karahi is a traditional Pakistani curry, especially associated with Lahore and Peshawar, cooked in a karahi with chicken, tomatoes, garlic, ginger, green chilies, and bold spices. It is served hot as a shared main dish with naan for scooping up the thick masala.";
"recipe.pk_chicken_karahi.info.summary" = "Tomato chicken karahi";
"recipe.pk_chicken_karahi.name" = "Chicken karahi";
"recipe.pk_chicken_karahi.step1.body" = "Cut the %i1 into serving pieces if needed. Chop the %i3. Finely chop the %i4 and part of the %i5. Slice the %i6. Julienne the remaining %i15 for garnish and chop the %i14.";
"recipe.pk_chicken_karahi.step1.title" = "Prepare ingredients";
"recipe.pk_chicken_karahi.step10.body" = "Transfer the chicken karahi to a serving bowl, top with cilantro and julienned ginger, and serve hot with naan.";
"recipe.pk_chicken_karahi.step10.title" = "Serve";
"recipe.pk_chicken_karahi.step2.body" = "Heat the karahi over medium-high heat and add the %i2. Add the chicken and cook, stirring, until the surface changes color and begins to lightly brown.";
"recipe.pk_chicken_karahi.step2.title" = "Heat oil and start chicken";
"recipe.pk_chicken_karahi.step3.body" = "Add the chopped garlic, chopped ginger, and %i11. Cook until fragrant, stirring so the aromatics do not burn.";
"recipe.pk_chicken_karahi.step3.title" = "Add aromatics";
"recipe.pk_chicken_karahi.step4.body" = "Add the tomatoes, %i8, %i9, %i10, and %i12. Cook over medium heat, stirring and pressing the tomatoes until they break down into a thick masala.";
"recipe.pk_chicken_karahi.step4.title" = "Add tomatoes and spices";
"recipe.pk_chicken_karahi.step5.body" = "Cover and cook on medium-low heat until the chicken releases juices and becomes mostly tender. Stir occasionally to prevent sticking.";
"recipe.pk_chicken_karahi.step5.title" = "Cook covered";
"recipe.pk_chicken_karahi.step6.body" = "Uncover and cook on higher heat until the masala thickens and the oil begins to separate. Stir in the %i7 and sliced green chilies, then continue cooking until the sauce is glossy.";
"recipe.pk_chicken_karahi.step6.title" = "Reduce and roast masala";
"recipe.pk_chicken_karahi.step7.body" = "Sprinkle in the %i13 and cook briefly so the aroma blooms without overcooking the spices.";
"recipe.pk_chicken_karahi.step7.title" = "Finish with garam masala";
"recipe.pk_chicken_karahi.step8.body" = "Turn off the heat and let the karahi rest briefly so the chicken reabsorbs some of the masala.";
"recipe.pk_chicken_karahi.step8.title" = "Rest karahi";
"recipe.pk_chicken_karahi.step9.body" = "Warm the %i16 briefly until soft and fragrant for serving.";
"recipe.pk_chicken_karahi.step9.title" = "Warm naan";
"recipe.pk_chicken_karahi.tool.t1" = "Karahi or deep frying pan";
"recipe.pk_chicken_karahi.tool.t2" = "Lid";
"recipe.pk_chicken_karahi.tool.t3" = "Knife";
"recipe.pk_chicken_karahi.tool.t4" = "Cutting board";
"recipe.pk_chicken_karahi.tool.t5" = "Wooden spoon";
"recipe.pk_chicken_karahi.tool.t6" = "Serving bowl";
"recipe.pk_gajrela.drink.body" = "A lightly sweet dessert wine such as Moscato can match the richness in small portions. Non-alcoholic pairing: hot chai or black tea is the traditional and best companion.";
"recipe.pk_gajrela.drink.summary" = "Dessert wine";
"recipe.pk_gajrela.info" = "Gajrela is a traditional Pakistani winter dessert made by slow-cooking grated carrots with milk until thick, then finishing with sugar, ghee, cardamom, and khoya. It is served warm or at room temperature on festive tables and family gatherings, often garnished with nuts.";
"recipe.pk_gajrela.info.summary" = "Carrot milk pudding";
"recipe.pk_gajrela.name" = "Gajrela";
"recipe.pk_gajrela.step1.body" = "Peel and grate the %i1. Slice the %i7 and %i8 for garnish.";
"recipe.pk_gajrela.step1.title" = "Prepare carrots and nuts";
"recipe.pk_gajrela.step2.body" = "Place the grated carrots and %i2 in a heavy pot or karahi and bring to a gentle boil, stirring so nothing catches.";
"recipe.pk_gajrela.step2.title" = "Start cooking";
"recipe.pk_gajrela.step3.body" = "Cook on medium-low heat, stirring regularly, until the milk reduces and the carrots become soft and concentrated.";
"recipe.pk_gajrela.step3.title" = "Reduce with milk";
"recipe.pk_gajrela.step4.body" = "Add the %i3 and cook, stirring, until the mixture loosens briefly and then thickens again as moisture cooks off.";
"recipe.pk_gajrela.step4.title" = "Add sugar and continue cooking";
"recipe.pk_gajrela.step5.body" = "Stir in the %i4 and %i6 and cook until the ghee is absorbed and the mixture turns glossy.";
"recipe.pk_gajrela.step5.title" = "Add ghee and cardamom";
"recipe.pk_gajrela.step6.body" = "Crumble in the %i5 and add the %i9, then cook while stirring until the gajrela is thick, cohesive, and aromatic.";
"recipe.pk_gajrela.step6.title" = "Finish with khoya and raisins";
"recipe.pk_gajrela.step7.body" = "Turn off the heat and let the gajrela rest briefly so it settles and thickens slightly.";
"recipe.pk_gajrela.step7.title" = "Rest briefly";
"recipe.pk_gajrela.step8.body" = "Transfer to a serving dish, garnish with almonds and pistachios, and serve warm or at room temperature.";
"recipe.pk_gajrela.step8.title" = "Garnish and serve";
"recipe.pk_gajrela.tool.t1" = "Heavy pot or karahi";
"recipe.pk_gajrela.tool.t2" = "Box grater";
"recipe.pk_gajrela.tool.t3" = "Knife";
"recipe.pk_gajrela.tool.t4" = "Cutting board";
"recipe.pk_gajrela.tool.t5" = "Wooden spoon";
"recipe.pk_gajrela.tool.t6" = "Serving dish";
"recipe.pk_haleem.drink.body" = "A light to medium red such as Grenache or Pinot Noir can work with the warm spices and rich texture without overpowering the dish. A crisp lager is also suitable. Non-alcoholic pairing: salted lassi or hot black tea are traditional and excellent choices.";
"recipe.pk_haleem.drink.summary" = "Red wine (Grenache)";
"recipe.pk_haleem.info" = "Haleem is a traditional Pakistani slow-cooked stew made with meat, wheat, barley, lentils, and spices, cooked until thick and silky, then finished with shredded meat and a rich tempering. It is a festive and communal dish, especially popular in Ramadan and Muharram, served hot with naan and classic garnishes.";
"recipe.pk_haleem.info.summary" = "Slow-cooked haleem";
"recipe.pk_haleem.name" = "Haleem";
"recipe.pk_haleem.step1.body" = "Rinse the %i6, %i7, %i8, %i9, %i10, and %i11, then soak them in %i5 until softened for slow cooking.";
"recipe.pk_haleem.step1.title" = "Soak grains and lentils";
"recipe.pk_haleem.step10.body" = "Turn off the heat and let the haleem rest briefly so the texture settles.";
"recipe.pk_haleem.step10.title" = "Rest";
"recipe.pk_haleem.step11.body" = "Warm the %i28 briefly until soft and fragrant for serving.";
"recipe.pk_haleem.step11.title" = "Warm naan";
"recipe.pk_haleem.step12.body" = "Transfer the haleem to a serving bowl, top with the remaining tempering, cilantro, mint, green chili, and lemon wedges, and serve hot with naan.";
"recipe.pk_haleem.step12.title" = "Garnish and serve";
"recipe.pk_haleem.step2.body" = "Slice the %i2 and %i14 separately. Chop the %i3 and %i4 for broth and the %i15 and %i16 for tempering separately. Chop the %i24, %i25, and %i26, and cut the %i27 into wedges.";
"recipe.pk_haleem.step2.title" = "Prepare aromatics and garnishes";
"recipe.pk_haleem.step3.body" = "Place the %i1 in a large pot with the broth onion, broth ginger, broth garlic, %i23, part of the %i17, and water. Bring slowly to a boil and skim well.";
"recipe.pk_haleem.step3.title" = "Start meat broth";
"recipe.pk_haleem.step4.body" = "Cook at a gentle simmer until the beef is very tender and the broth is flavorful.";
"recipe.pk_haleem.step4.title" = "Simmer meat";
"recipe.pk_haleem.step5.body" = "Add the soaked grains and lentils to the pot and stir well. Continue cooking, adding more water if needed to keep the mixture loose enough to stir.";
"recipe.pk_haleem.step5.title" = "Cook grains and lentils";
"recipe.pk_haleem.step6.body" = "Cook on low heat, stirring regularly, until the grains and lentils break down and the mixture becomes thick and porridge-like.";
"recipe.pk_haleem.step6.title" = "Slow cook and soften";
"recipe.pk_haleem.step7.body" = "Remove the beef, shred it finely, and discard any tough pieces. Return the meat to the pot and mash or whisk the haleem until smooth and cohesive.";
"recipe.pk_haleem.step7.title" = "Shred meat and smooth haleem";
"recipe.pk_haleem.step8.body" = "Heat the %i13 in a deep pan or karahi. Fry the tempering onion until deep golden, then add the tempering ginger, tempering garlic, %i20, %i18, %i19, %i21, and %i22, cooking briefly until fragrant.";
"recipe.pk_haleem.step8.title" = "Prepare tempering";
"recipe.pk_haleem.step9.body" = "Add most of the tempering to the haleem and stir thoroughly. Simmer gently, stirring, until the texture is thick, glossy, and well blended. Adjust with a little water only if it becomes too stiff.";
"recipe.pk_haleem.step9.title" = "Finish haleem";
