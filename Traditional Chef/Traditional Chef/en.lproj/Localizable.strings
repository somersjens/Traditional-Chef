"recipe.ru_shchi.drink.body" = "A crisp dry white such as Riesling or Sauvignon Blanc can work with the savory broth and cabbage sweetness, though many prefer tea with soup. Non-alcoholic pairing: hot black tea or sparkling water.";
"recipe.ru_shchi.drink.summary" = "White wine (Riesling)";
"recipe.ru_shchi.info" = "Shchi is a traditional Russian cabbage soup built on a long-simmered meat broth with onions, carrots, potatoes, and plenty of shredded cabbage, finished with herbs and served hot. It is a staple home dish across Russia, commonly brought to the table with a spoon of sour cream and rye bread, making a hearty first course that can also anchor a simple meal.";
"recipe.ru_shchi.info.summary" = "Russian cabbage soup";
"recipe.ru_shchi.name" = "Cabbage soup";
"recipe.ru_shchi.step1.body" = "Place the %i1 in a large pot and cover with %i2. Bring to a gentle simmer and skim well until the broth looks clear.";
"recipe.ru_shchi.step1.title" = "Start the broth";
"recipe.ru_shchi.step2.body" = "Add %i3, %i4, %i5, %i6, and a little %i12. Cover partially and simmer gently until the beef is very tender and the broth is flavorful.";
"recipe.ru_shchi.step2.title" = "Simmer the broth";
"recipe.ru_shchi.step3.body" = "Shred the %i7, peel and dice the %i8, and mince the %i9. Chop the herbs and set aside for finishing.";
"recipe.ru_shchi.step3.title" = "Prep vegetables";
"recipe.ru_shchi.step4.body" = "Remove the beef and strain the broth to remove aromatics and spices. Return the clear broth to the pot and bring back to a simmer.";
"recipe.ru_shchi.step4.title" = "Strain and return broth";
"recipe.ru_shchi.step5.body" = "Add the potatoes and simmer until they begin to turn tender.";
"recipe.ru_shchi.step5.title" = "Cook potatoes";
"recipe.ru_shchi.step6.body" = "Add the cabbage and simmer until it is tender and the soup tastes rounded.";
"recipe.ru_shchi.step6.title" = "Cook cabbage";
"recipe.ru_shchi.step7.body" = "Slice or shred the beef and return it to the pot. Stir in the garlic and most of the herbs, then adjust salt.";
"recipe.ru_shchi.step7.title" = "Finish the soup";
"recipe.ru_shchi.step8.body" = "Ladle the soup into bowls, top with the remaining herbs, and serve hot with %i13 and %i14.";
"recipe.ru_shchi.step8.title" = "Serve";
