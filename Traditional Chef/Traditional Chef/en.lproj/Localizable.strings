"recipe.us_ky_burgoo.drink.body" = "A ripe, peppery red like Zinfandel can stand up to the smoky, savory stew, and a brown ale also works well. For a non-alcoholic option, serve iced tea or a glass of cold apple cider to complement the hearty, tangy flavors.";
"recipe.us_ky_burgoo.drink.summary" = "Red wine (Zinfandel)";
"recipe.us_ky_burgoo.info" = "Kentucky burgoo is a slow-simmered, festival-style stew built on a mix of meats cooked until tender, then finished with a medley of vegetables like potatoes, corn, lima beans, okra, and tomatoes. It’s traditionally made in a big pot and stirred for hours until the flavors meld into a rich, thick, comforting bowl meant for sharing, most often served with cornbread alongside.";
"recipe.us_ky_burgoo.info.summary" = "Festival burgoo stew";
"recipe.us_ky_burgoo.name" = "Burgoo";
"recipe.us_ky_burgoo.step1.body" = "Pat the %i1, %i2, %i3, and %i4 dry, then brown them in batches in the heavy pot, turning to color well. Transfer browned pieces back into the pot as you go.";
"recipe.us_ky_burgoo.step1.title" = "Brown the meats";
"recipe.us_ky_burgoo.step10.body" = "Whisk %i22, %i23, %i24, %i25, and %i26. Whisk in %i28 and %i27 until just combined.";
"recipe.us_ky_burgoo.step10.title" = "Mix cornbread batter";
"recipe.us_ky_burgoo.step11.body" = "Carefully remove the hot skillet, melt %i29 in it, then pour in the batter and bake until the top is set and browned.";
"recipe.us_ky_burgoo.step11.title" = "Bake the cornbread";
"recipe.us_ky_burgoo.step12.body" = "Let the cornbread cool slightly, then ladle burgoo into bowls and serve with warm wedges of cornbread.";
"recipe.us_ky_burgoo.step12.title" = "Rest and serve";
"recipe.us_ky_burgoo.step2.body" = "Add %i5, %i6, and %i7 to the pot and cook, scraping up browned bits, until the vegetables soften and the bottom is clean.";
"recipe.us_ky_burgoo.step2.title" = "Start the base";
