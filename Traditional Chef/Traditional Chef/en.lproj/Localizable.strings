"recipe.gr_fasolada.drink.body" = "Pair with a crisp Greek white such as Savatiano or Assyrtiko that stays fresh with tomato and olive oil. A light lager also works well. For a non-alcoholic option, serve sparkling water or a chilled lemon soda.";
"recipe.gr_fasolada.drink.summary" = "White wine (Savatiano)";
"recipe.gr_fasolada.info" = "Fasolada is Greece’s classic hearty white bean soup simmered with onions, carrots, celery, and tomato until the beans are tender and the broth is rich. It is finished with generous olive oil and typically served with crusty bread and olives, making it a staple home-cooked main especially in cooler months.";
"recipe.gr_fasolada.info.summary" = "Greek bean pot classic";
"recipe.gr_fasolada.name" = "Fasolada";
"recipe.gr_fasolada.step1.body" = "Cover %i1 generously with %i10 and soak until fully hydrated.";
"recipe.gr_fasolada.step1.title" = "Soak the beans";
"recipe.gr_fasolada.step2.body" = "Drain the beans. Chop %i2, %i3, and %i4 and keep %i6 ready.";
"recipe.gr_fasolada.step2.title" = "Prep the vegetables";
"recipe.gr_fasolada.step3.body" = "Simmer the beans with water until they begin to soften, then add the vegetables and tomato paste and continue simmering gently until the beans are tender and the soup is rich.";
"recipe.gr_fasolada.step3.title" = "Simmer the soup";
"recipe.gr_fasolada.step4.body" = "Stir in %i7, %i8, and %i9 and warm briefly.";
"recipe.gr_fasolada.step4.title" = "Finish with olive oil";
"recipe.gr_fasolada.step5.body" = "Serve hot with %i11 and %i12.";
"recipe.gr_fasolada.step5.title" = "Serve the fasolada";
