"recipe.pt_caldo_verde.drink.body" = "A crisp Vinho Verde or dry Arinto pairs well with the smoky chouriço and the clean, olive-oil finish of the soup. Serve chilled. Non-alcoholic pairing: sparkling water or a lightly sweet iced tea with lemon.";
"recipe.pt_caldo_verde.drink.summary" = "White wine (Vinho Verde)";
"recipe.pt_caldo_verde.info" = "Caldo Verde is a traditional Portuguese soup from the Minho region, made by cooking potatoes with onion and garlic, blending to a silky base, then simmering very thinly sliced couve galega until tender and bright. It is flavored with olive oil and served hot with slices of chouriço, and traditionally accompanied by broa for dipping into the broth.";
"recipe.pt_caldo_verde.info.summary" = "Minho green soup";
"recipe.pt_caldo_verde.name" = "Caldo verde";
"recipe.pt_caldo_verde.step1.body" = "Peel and cut the %i1 into small chunks. Slice %i2 and mince %i3. Remove tough stems from %i4 and slice the leaves into very thin strips.";
"recipe.pt_caldo_verde.step1.title" = "Prepare vegetables";
"recipe.pt_caldo_verde.step2.body" = "Warm %i6 in a large pot over medium heat. Add the onion and cook until softened, then add the garlic and cook until fragrant.";
"recipe.pt_caldo_verde.step2.title" = "Start the flavor base";
"recipe.pt_caldo_verde.step3.body" = "Add the potatoes, %i5, and %i9. Bring to a simmer and cook until the potatoes are very tender and beginning to break down.";
"recipe.pt_caldo_verde.step3.title" = "Simmer potatoes and sausage";
"recipe.pt_caldo_verde.step4.body" = "Remove the chouriço from the pot and slice it. Set the slices aside for serving.";
"recipe.pt_caldo_verde.step4.title" = "Slice the chouriço";
"recipe.pt_caldo_verde.step5.body" = "Blend the potato broth in the pot until smooth and creamy.";
"recipe.pt_caldo_verde.step5.title" = "Blend the soup";
"recipe.pt_caldo_verde.step6.body" = "Add the sliced couve galega and simmer until tender and the soup turns a deep green.";
"recipe.pt_caldo_verde.step6.title" = "Cook the greens";
"recipe.pt_caldo_verde.step7.body" = "Season with %i7 and %i8, and stir in a small drizzle of olive oil for a glossy finish.";
