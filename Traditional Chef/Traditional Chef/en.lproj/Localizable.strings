"recipe.bg_tikvenik.step1.title" = "Prepare the filling";
"recipe.bg_tikvenik.step2.body" = "Lay out %i5 and keep them covered with a clean kitchen towel so they stay flexible while you work.";
"recipe.bg_tikvenik.step2.title" = "Prepare the pastry";
"recipe.bg_tikvenik.step3.body" = "Brush each filo sheet with %i6, spread some filling over it, then roll it up and place it in the baking tray in the traditional coiled or lined shape.";
"recipe.bg_tikvenik.step3.title" = "Fill and roll the tikvenik";
"recipe.bg_tikvenik.step4.body" = "Brush the assembled tikvenik with the remaining sunflower oil so the pastry bakes crisp and golden.";
"recipe.bg_tikvenik.step4.title" = "Finish the top";
"recipe.bg_tikvenik.step5.body" = "Bake the tikvenik until the pastry is deeply golden and crisp and the pumpkin filling is tender.";
"recipe.bg_tikvenik.step5.title" = "Bake until golden";
"recipe.bg_tikvenik.step6.body" = "Leave the tikvenik to cool briefly so the filling settles and the pastry stays crisp when cut.";
"recipe.bg_tikvenik.step6.title" = "Cool slightly";
"recipe.bg_tikvenik.step7.body" = "Dust the top with %i7, cut into portions, and serve warm or at room temperature.";
"recipe.bg_tikvenik.step7.title" = "Dust and serve";
