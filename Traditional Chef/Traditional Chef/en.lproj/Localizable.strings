"recipe.pe_anticuchos.drink.body" = "Pair with a juicy Malbec or a medium-bodied Zinfandel to stand up to the smoky chili marinade. If you prefer beer, a crisp lager works well. For a non-alcoholic option, serve chicha morada or sparkling water with lime.";
"recipe.pe_anticuchos.drink.summary" = "Red wine (Malbec)";
"recipe.pe_anticuchos.info" = "Anticuchos de Corazón are iconic Peruvian street-food skewers made from beef heart, marinated in ají panca, vinegar, garlic, and spices, then grilled over high heat and basted for a glossy, smoky finish. They are traditionally served hot with boiled potatoes and choclo (large-kernel corn), alongside a spicy ají sauce for dipping.";
"recipe.pe_anticuchos.info.summary" = "Grilled heart skewers";
"recipe.pe_anticuchos.name" = "Heart anticuchos";
"recipe.pe_anticuchos.step1.body" = "Trim away any tough membranes, veins, and excess fat from the %i1, then cut it into even cubes suitable for skewering.";
"recipe.pe_anticuchos.step1.title" = "Clean and cut the heart";
"recipe.pe_anticuchos.step2.body" = "In a bowl, whisk together %i2, crushed %i3, %i4, %i5, %i6, %i7, %i8, and %i9 until smooth.";
"recipe.pe_anticuchos.step2.title" = "Make the marinade";
"recipe.pe_anticuchos.step3.body" = "Add the heart cubes to the marinade, mix thoroughly to coat, cover, and refrigerate to marinate.";
"recipe.pe_anticuchos.step3.title" = "Marinate the heart";
"recipe.pe_anticuchos.step4.body" = "In a small bowl, mix %i10 with %i11, minced %i12, %i14, %i13, and %i15 until emulsified. Set aside for grilling.";
"recipe.pe_anticuchos.step4.title" = "Make the basting sauce";
"recipe.pe_anticuchos.step5.body" = "In a small bowl, combine %i16, %i17, finely grated %i18, %i19, and %i20, mixing until smooth. Set aside for serving.";
"recipe.pe_anticuchos.step5.title" = "Prepare the ají sauce";
"recipe.pe_anticuchos.step6.body" = "Bring %i23 to a boil in a large pot, salt it, then cook the %i21 until tender. Add the %i22 to cook until hot and tender, then drain both and keep warm.";
"recipe.pe_anticuchos.step6.title" = "Boil potatoes and corn";
"recipe.pe_anticuchos.step7.body" = "Thread the marinated heart cubes onto skewers, packing them snugly so they cook evenly.";
"recipe.pe_anticuchos.step7.title" = "Skewer the heart";
"recipe.pe_anticuchos.step8.body" = "Grill the skewers over high heat, turning frequently. Baste with the basting sauce as they cook until nicely charred outside and still juicy.";
"recipe.pe_anticuchos.step8.title" = "Grill and baste";
"recipe.pe_anticuchos.step9.body" = "Serve the anticuchos immediately with boiled potatoes and corn, and offer the ají sauce on the side for dipping.";
"recipe.pe_anticuchos.step9.title" = "Serve";
