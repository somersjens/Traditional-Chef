"recipe.pk_sheer_khurma.drink.body" = "A lightly sweet dessert wine such as Moscato can match the rich milk and dried fruit sweetness in small servings. Non-alcoholic pairing: chai or plain black tea is the traditional and best companion.";
"recipe.pk_sheer_khurma.drink.summary" = "Dessert wine";
"recipe.pk_sheer_khurma.info" = "Sheer Khurma is a traditional Pakistani Eid dessert made by simmering roasted vermicelli in milk with dates, nuts, cardamom, and khoya until rich and fragrant. It is served warm or chilled in bowls during Eid gatherings and family celebrations.";
"recipe.pk_sheer_khurma.info.summary" = "Eid milk vermicelli";
"recipe.pk_sheer_khurma.name" = "Sheer khurma";
"recipe.pk_sheer_khurma.step1.body" = "Slice the %i6 and remove pits if needed. Slice the %i7, %i8, and %i9. Keep the %i10 and %i11 ready. Soak the %i14 in a little warm milk taken from the milk base.";
"recipe.pk_sheer_khurma.step1.title" = "Prepare dates and nuts";
"recipe.pk_sheer_khurma.step10.body" = "Ladle into serving bowls and serve warm, or cool and chill before serving if preferred for Eid-style dessert service.";
"recipe.pk_sheer_khurma.step10.title" = "Serve";
"recipe.pk_sheer_khurma.step2.body" = "Place the remaining %i1 in a heavy pot and bring it to a gentle simmer, stirring occasionally so it does not catch on the bottom.";
"recipe.pk_sheer_khurma.step2.title" = "Heat milk";
"recipe.pk_sheer_khurma.step3.body" = "Heat the %i3 in another pan or in a cleared section of the pot and roast the %i2 over medium heat until golden and fragrant, stirring constantly to prevent burning.";
"recipe.pk_sheer_khurma.step3.title" = "Roast vermicelli";
"recipe.pk_sheer_khurma.step4.body" = "Add the roasted vermicelli to the simmering milk and stir well so the strands separate and begin to soften.";
"recipe.pk_sheer_khurma.step4.title" = "Combine base";
"recipe.pk_sheer_khurma.step5.body" = "Cook gently until the vermicelli softens and the milk starts to thicken slightly, stirring regularly.";
"recipe.pk_sheer_khurma.step5.title" = "Simmer vermicelli";
"recipe.pk_sheer_khurma.step6.body" = "Crumble in the %i5 and add the %i4. Stir until the khoya dissolves and the mixture becomes smooth and richer.";
"recipe.pk_sheer_khurma.step6.title" = "Add khoya and sugar";
"recipe.pk_sheer_khurma.step7.body" = "Add the dates, almonds, pistachios, cashews, raisins, and chironji. Simmer gently until the dried fruit plumps and the nuts soften slightly.";
"recipe.pk_sheer_khurma.step7.title" = "Add dates nuts and raisins";
"recipe.pk_sheer_khurma.step8.body" = "Stir in the %i12, %i13, and soaked saffron, then cook briefly so the aroma spreads through the dessert.";
"recipe.pk_sheer_khurma.step8.title" = "Finish with aromatics";
"recipe.pk_sheer_khurma.step9.body" = "Turn off the heat and let the sheer khurma rest so it thickens slightly and the flavors meld.";
"recipe.pk_sheer_khurma.step9.title" = "Rest";
