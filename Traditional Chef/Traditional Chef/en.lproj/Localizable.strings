"recipe.co_mondongo.drink.body" = "Pair with a fruity, medium-bodied Tempranillo or young Malbec that complements the savory broth and meats without overwhelming the herbs. A crisp lager also pairs well. Non-alcoholic option: sparkling water with lime or a cold agua de panela with lemon.";
"recipe.co_mondongo.drink.summary" = "Red wine (Tempranillo)";
"recipe.co_mondongo.info" = "Colombian mondongo is a hearty soup centered on tender tripe simmered for a long time with aromatics, then cooked with potatoes, cassava, and vegetables until rich and comforting. It is traditionally finished with cilantro and served hot with white rice and avocado on the side, making it a classic family meal found across Colombia.";
"recipe.co_mondongo.info.summary" = "Hearty tripe soup";
"recipe.co_mondongo.name" = "Mondongo soup";
