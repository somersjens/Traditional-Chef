"recipe.us_la_gumbo.drink.body" = "A juicy Zinfandel or a malty amber ale stands up to the smoky sausage, dark roux, and spice. For a non-alcoholic option, serve iced tea or sparkling water with lemon to refresh the palate and balance the richness.";
"recipe.us_la_gumbo.drink.summary" = "Red wine (Zinfandel)";
"recipe.us_la_gumbo.info" = "Louisiana gumbo is a cornerstone of Cajun and Creole cooking: a deep, dark roux-based stew built on the trinity of onion, celery, and bell pepper, then simmered with smoked sausage and chicken into a richly seasoned, savory broth. It’s finished with sliced okra and served over steamed white rice, with filé powder traditionally stirred in at the table for an earthy thickening and aroma. Gumbo is made to be shared, tasting even better once the flavors have melded.";
"recipe.us_la_gumbo.info.summary" = "Dark roux gumbo";
"recipe.us_la_gumbo.name" = "Gumbo";
"recipe.us_la_gumbo.step1.body" = "Rinse the %i17 until the water runs mostly clear. Combine rice with %i18 and %i19, bring to a boil, cover, and cook on low heat until tender. Remove from heat and keep covered.";
"recipe.us_la_gumbo.step1.title" = "Cook the rice";
"recipe.us_la_gumbo.step10.body" = "Spoon rice into bowls, ladle gumbo over the top, and serve %i20 at the table to stir in just before eating.";
"recipe.us_la_gumbo.step10.title" = "Serve with filé";
"recipe.us_la_gumbo.step2.body" = "In the heavy pot, whisk %i1 and %i2 over medium heat and cook, stirring constantly, until the roux turns deep chocolate brown and smells nutty, watching closely so it does not burn.";
"recipe.us_la_gumbo.step2.title" = "Make a dark roux";
"recipe.us_la_gumbo.step3.body" = "Stir in %i3, %i4, and %i5 and cook until softened, scraping and stirring so the vegetables stop the roux from darkening too fast.";
"recipe.us_la_gumbo.step3.title" = "Cook the trinity";
"recipe.us_la_gumbo.step4.body" = "Stir in %i6, %i12, %i13, %i14, %i15, and %i16 until fragrant.";
"recipe.us_la_gumbo.step4.title" = "Add garlic and spices";
"recipe.us_la_gumbo.step5.body" = "Add %i7 and %i8 and stir so they are coated, letting them cook briefly to pick up flavor from the roux base.";
"recipe.us_la_gumbo.step5.title" = "Add sausage and chicken";
"recipe.us_la_gumbo.step6.body" = "Add %i9 and %i11, bring to a gentle simmer, and stir well to make a smooth, rich broth.";
"recipe.us_la_gumbo.step6.title" = "Build the gumbo";
"recipe.us_la_gumbo.step7.body" = "Maintain a low simmer, stirring occasionally, until the chicken is tender and the gumbo tastes cohesive and deeply savory.";
"recipe.us_la_gumbo.step7.title" = "Simmer until chicken is tender";
"recipe.us_la_gumbo.step8.body" = "Stir in %i10 and simmer until it is tender and the gumbo thickens slightly.";
"recipe.us_la_gumbo.step8.title" = "Cook the okra";
"recipe.us_la_gumbo.step9.body" = "Stir in %i21 and %i22, then remove bay leaves and taste for salt and heat.";
"recipe.us_la_gumbo.step9.title" = "Finish with herbs";
