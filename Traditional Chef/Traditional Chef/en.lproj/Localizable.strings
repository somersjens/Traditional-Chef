"recipe.pe_arroz_chaufa.drink.body" = "Pair with an off-dry Riesling or a crisp Sauvignon Blanc to balance the salty umami and wok-seared flavors. If you prefer beer, a light lager works well. For a non-alcoholic option, serve Inca Kola or sparkling water with lime.";
"recipe.pe_arroz_chaufa.drink.summary" = "White wine (Riesling)";
"recipe.pe_arroz_chaufa.info" = "Arroz Chaufa is the classic Chifa-style Peruvian fried rice, built on fluffy, cooled rice tossed in a hot wok with chicken, scrambled egg, scallions, garlic, ginger, and savory soy-based seasoning. It is traditionally cooked fast over high heat for a smoky, toasty finish and served immediately with a bright, spicy ají sauce on the side.";
"recipe.pe_arroz_chaufa.info.summary" = "Peruvian fried rice";
"recipe.pe_arroz_chaufa.name" = "Arroz chaufa";
"recipe.pe_arroz_chaufa.step1.body" = "Rinse the %i1, then cook it in a pot with %i2 until tender and fluffy. Spread it out to release steam so the grains dry and separate.";
"recipe.pe_arroz_chaufa.step1.title" = "Cook the rice";
"recipe.pe_arroz_chaufa.step10.body" = "Serve immediately while hot, offering the ají sauce on the side for spooning over each portion.";
"recipe.pe_arroz_chaufa.step10.title" = "Serve";
"recipe.pe_arroz_chaufa.step2.body" = "Let the rice cool completely until dry to the touch and no longer steamy, so it fries instead of clumping.";
"recipe.pe_arroz_chaufa.step2.title" = "Cool the rice";
"recipe.pe_arroz_chaufa.step3.body" = "Cut the %i3 into bite-size pieces. Slice the %i5, keeping the white and green parts separate. Finely chop the %i6 and grate the %i7.";
"recipe.pe_arroz_chaufa.step3.title" = "Prep the stir-fry";
"recipe.pe_arroz_chaufa.step4.body" = "Stir together the %i14, %i15, garlic, %i17, and %i18 until smooth. Set aside for serving.";
"recipe.pe_arroz_chaufa.step4.title" = "Mix the ají sauce";
"recipe.pe_arroz_chaufa.step5.body" = "Heat the wok with a little oil, add the %i4, and scramble just until set. Remove to a plate.";
"recipe.pe_arroz_chaufa.step5.title" = "Scramble the eggs";
"recipe.pe_arroz_chaufa.step6.body" = "Heat the wok until very hot, add %i8, then stir-fry the chicken until cooked through and lightly browned at the edges.";
"recipe.pe_arroz_chaufa.step6.title" = "Brown the chicken";
"recipe.pe_arroz_chaufa.step7.body" = "Add the garlic, ginger, and the white parts of the green onions to the wok and toss quickly until fragrant.";
"recipe.pe_arroz_chaufa.step7.title" = "Aromatics and onions";
"recipe.pe_arroz_chaufa.step8.body" = "Add the cooled rice and toss constantly over high heat, pressing and breaking up any clumps so the grains toast and separate.";
"recipe.pe_arroz_chaufa.step8.title" = "Fry the rice";
"recipe.pe_arroz_chaufa.step9.body" = "Add the %i9 and %i10 and toss until evenly coated, then drizzle in %i11. Return the eggs, add the green parts of the onions, and toss briefly: adjust with %i12 and %i13 if needed.";
"recipe.pe_arroz_chaufa.step9.title" = "Season and finish";
