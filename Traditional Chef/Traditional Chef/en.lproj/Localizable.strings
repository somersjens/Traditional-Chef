"recipe.bd_chingri_malai_curry.drink.body" = "An off-dry Riesling or aromatic white balances the coconut richness and gentle heat. If you prefer red, choose a light-bodied, low-tannin red served slightly chilled. Non-alcoholic pairing: chilled lime soda or unsweetened black tea.";
"recipe.bd_chingri_malai_curry.drink.summary" = "White wine (Riesling)";
"recipe.bd_chingri_malai_curry.info" = "Chingri malai curry is a classic Bengali-style curry beloved in Bangladesh, featuring prawns cooked in a rich, fragrant coconut-milk gravy. The prawns are lightly seasoned, quickly fried, then finished in a gently simmered sauce built on aromatic whole spices, onion, ginger, and warm masala, resulting in a creamy, delicately spiced dish traditionally served hot with plain steamed rice.";
"recipe.bd_chingri_malai_curry.info.summary" = "Coconut prawn curry";
"recipe.bd_chingri_malai_curry.name" = "Chingri malai curry";
"recipe.bd_chingri_malai_curry.step1.body" = "Rinse and drain the %i1. Slice the %i5 and slit the %i8. Season the prawns with %i3 and some of the %i2.";
"recipe.bd_chingri_malai_curry.step1.title" = "Prep and season";
"recipe.bd_chingri_malai_curry.step10.body" = "Rest the rice covered so it fluffs up. Serve the chingri malai curry hot with steamed rice.";
"recipe.bd_chingri_malai_curry.step10.title" = "Rest and serve";
"recipe.bd_chingri_malai_curry.step2.body" = "Blend onion with %i6 and %i7, adding %i18 only as needed to make a smooth paste.";
"recipe.bd_chingri_malai_curry.step2.title" = "Make the aromatics paste";
"recipe.bd_chingri_malai_curry.step3.body" = "Heat %i4 in a pan and fry the prawns briefly until they just turn opaque. Remove and set aside.";
"recipe.bd_chingri_malai_curry.step3.title" = "Fry the prawns briefly";
"recipe.bd_chingri_malai_curry.step4.body" = "In a heavy pot, heat %i9 and add %i10, %i11, %i12, and %i13, frying until fragrant.";
"recipe.bd_chingri_malai_curry.step4.title" = "Start the gravy";
"recipe.bd_chingri_malai_curry.step5.body" = "Add the onion-ginger-garlic paste and cook, stirring, until it deepens in colour and the raw smell is gone.";
"recipe.bd_chingri_malai_curry.step5.title" = "Bhuna the paste";
"recipe.bd_chingri_malai_curry.step6.body" = "Stir in %i14, remaining turmeric, and remaining salt, frying briefly so the spices bloom.";
"recipe.bd_chingri_malai_curry.step6.title" = "Add ground spices";
"recipe.bd_chingri_malai_curry.step7.body" = "Pour in %i16 and bring to a gentle simmer, stirring so the sauce becomes smooth and slightly thickened.";
"recipe.bd_chingri_malai_curry.step7.title" = "Simmer with coconut milk";
"recipe.bd_chingri_malai_curry.step8.body" = "Add the fried prawns and green chilies and simmer gently until the prawns are cooked through. Stir in %i15 at the end.";
"recipe.bd_chingri_malai_curry.step8.title" = "Finish the curry";
"recipe.bd_chingri_malai_curry.step9.body" = "Rinse the %i17. Combine it with %i18 and a pinch of salt, bring to a simmer, then cover and cook gently until tender.";
