"recipe.ch_raclette.drink.body" = "Serve with a dry Swiss white wine such as Fendant or Chasselas, which matches the rich melted cheese. A light lager can also work. For a non-alcoholic option, hot black tea is a classic traditional choice with raclette.";
"recipe.ch_raclette.drink.summary" = "White wine (Fendant)";
"recipe.ch_raclette.info" = "Swiss raclette is a traditional communal meal from the canton of Valais in which hot melted raclette cheese is scraped over boiled potatoes and eaten with cornichons, pickled onions, and cured meat. It is served directly at the table and is especially associated with cold-weather gatherings in the Alps.";
"recipe.ch_raclette.info.summary" = "Swiss raclette table";
"recipe.ch_raclette.name" = "Raclette";
"recipe.ch_raclette.step1.body" = "Arrange %i1, %i3, %i4, and %i5 on serving platters and set up the raclette grill at the table.";
"recipe.ch_raclette.step1.title" = "Prepare the table";
"recipe.ch_raclette.step2.body" = "Boil %i2 in their skins until tender, then drain them and keep them hot for serving.";
"recipe.ch_raclette.step2.title" = "Cook the potatoes";
"recipe.ch_raclette.step3.body" = "Cut the raclette cheese into pieces that fit the raclette pans or the grill so they melt evenly.";
"recipe.ch_raclette.step3.title" = "Prepare the cheese";
"recipe.ch_raclette.step4.body" = "Place a portion of cheese in the raclette pans and heat it until fully melted and lightly bubbling at the edges.";
"recipe.ch_raclette.step4.title" = "Melt the cheese";
"recipe.ch_raclette.step5.body" = "Peel the hot potatoes at the table, place them on plates, and scrape the melted cheese over them. Add cornichons, pickled onions, and Bündnerfleisch on the side, then season with %i6.";
"recipe.ch_raclette.step5.title" = "Serve the first plates";
"recipe.ch_raclette.step6.body" = "Repeat the melting and scraping process throughout the meal, serving fresh hot cheese over potatoes and eating it with the pickles and cured meat.";
"recipe.ch_raclette.step6.title" = "Continue serving";
