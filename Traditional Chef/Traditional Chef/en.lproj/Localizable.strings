"recipe.kr_bulgogi.step2.title" = "Make the marinade";
"recipe.kr_bulgogi.step3.body" = "Mix the sliced beef thoroughly with the marinade and let it rest in the refrigerator.";
"recipe.kr_bulgogi.step3.title" = "Marinate the beef";
