"recipe.ca_cipaille.drink.body" = "A dry Quebec cider pairs well with the rich pastry and slow-cooked meat filling. A light red wine such as Gamay also works well, and sparkling apple cider is a good non-alcoholic pairing.";
"recipe.ca_cipaille.drink.summary" = "Cider";
"recipe.ca_cipaille.info" = "Cipaille is a traditional Quebec meat pie from Gaspésie and Bas-Saint-Laurent made with several layers of pastry, cubed meats, potatoes, onion, and broth baked slowly until rich and tender. It is a festive cold-weather dish closely tied to holiday and family gatherings.";
"recipe.ca_cipaille.info.summary" = "Layered holiday meat pie";
"recipe.ca_cipaille.name" = "Cipaille";
"recipe.ca_cipaille.step1.body" = "Combine the %i1 and %i3 in a bowl, cut in the %i2 until the mixture is crumbly, then add %i4 and bring the dough together. Divide it for the base, inner layers, and top crust.";
"recipe.ca_cipaille.step1.title" = "Make the pastry";
"recipe.ca_cipaille.step2.body" = "Cut the %i5, %i6, and %i7 into small cubes. Peel and dice the %i8, then finely chop the %i9 and combine everything with the %i11, %i12, %i13, and %i14.";
"recipe.ca_cipaille.step2.title" = "Prepare the filling";
"recipe.ca_cipaille.step3.body" = "Roll out part of the dough and line a deep baking dish, leaving enough overhang to seal the final top crust.";
"recipe.ca_cipaille.step3.title" = "Line the dish";
"recipe.ca_cipaille.step4.body" = "Spread part of the meat mixture in the dish, add part of the potatoes and onion, cover with a sheet of dough, and repeat the layering until all the filling is used, finishing with a top crust.";
"recipe.ca_cipaille.step4.title" = "Build the layers";
"recipe.ca_cipaille.step5.body" = "Cut a small opening in the top crust and pour in the %i10 so the filling will cook slowly and stay moist.";
"recipe.ca_cipaille.step5.title" = "Add the broth";
"recipe.ca_cipaille.step6.body" = "Seal the edges well, mix the %i15 with %i16, and brush the top crust evenly.";
"recipe.ca_cipaille.step6.title" = "Seal and glaze";
"recipe.ca_cipaille.step7.body" = "Bake the cipaille at low heat until the meats are tender, the potatoes are fully cooked, and the crust is deeply golden.";
"recipe.ca_cipaille.step7.title" = "Bake slowly";
"recipe.ca_cipaille.step8.body" = "Let the cipaille rest so the juices settle and the layers hold together when served.";
"recipe.ca_cipaille.step8.title" = "Rest the pie";
"recipe.ca_cipaille.step9.body" = "Cut into portions and serve hot.";
"recipe.ca_cipaille.step9.title" = "Serve";
