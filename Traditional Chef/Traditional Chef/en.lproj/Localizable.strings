"recipe.ua_varenyky.step5.title" = "Rest the dough";
"recipe.ua_varenyky.step6.body" = "Roll the dough thinly and cut it into rounds for filling.";
"recipe.ua_varenyky.step6.title" = "Roll and cut the dough";
"recipe.ua_varenyky.step7.body" = "Place some filling on each round, fold the dough over, and press the edges firmly closed.";
"recipe.ua_varenyky.step7.title" = "Fill and seal the varenyky";
