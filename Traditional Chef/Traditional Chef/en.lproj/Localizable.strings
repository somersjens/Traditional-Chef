"recipe.tr_patlican_ezmesi.step1.title" = "Char the eggplants";
"recipe.tr_patlican_ezmesi.step2.body" = "Peel the eggplants, discard the skins, chop the flesh finely, and let it drain so the salad stays thick.";
"recipe.tr_patlican_ezmesi.step2.title" = "Peel and drain";
"recipe.tr_patlican_ezmesi.step3.body" = "Mix the chopped eggplant with crushed %i2, %i4, %i6, and %i3 until well combined, then fold in %i5.";
"recipe.tr_patlican_ezmesi.step3.title" = "Season and mix";
"recipe.tr_patlican_ezmesi.step4.body" = "Let the patlıcan ezmesi rest so the flavors meld and the texture settles.";
"recipe.tr_patlican_ezmesi.step4.title" = "Rest to meld";
