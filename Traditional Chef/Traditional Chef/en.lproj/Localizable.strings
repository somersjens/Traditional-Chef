"recipe.ua_borshch.drink.summary" = "Red wine (Pinot Noir)";
"recipe.ua_borshch.info" = "Ukrainian borshch is a traditional beet-based soup cooked with meat broth, cabbage, potatoes, carrots, onions, and tomato, then finished with garlic, herbs, and sour cream. It is a central dish of Ukrainian home cooking and festive tables, and it is traditionally served hot with pampushky, the small garlic buns served alongside.";
"recipe.ua_borshch.info.summary" = "Ukrainian beet soup";
"recipe.ua_borshch.name" = "Borshch";
