"recipe.hk_lo_bak_go.drink.body" = "Lo bak go is traditionally paired with Chinese tea during dim sum, especially pu-erh or jasmine tea. If serving alcohol, a light lager can work with the savory cured flavors, while hot pu-erh tea is the classic non-alcoholic pairing.";
"recipe.hk_lo_bak_go.drink.summary" = "Pu-erh tea";
"recipe.hk_lo_bak_go.info" = "A traditional Cantonese dim sum dish made from daikon radish, rice flour, and savory cured ingredients, first steamed into a cake and then sliced and pan-fried until lightly crisp. In Hong Kong it is commonly served hot during yum cha as part of a shared table of dim sum dishes.";
"recipe.hk_lo_bak_go.info.summary" = "Pan-fried turnip cake";
"recipe.hk_lo_bak_go.name" = "Lo bak go";
"recipe.hk_lo_bak_go.step1.body" = "Soak the %i8 and %i9 until softened, then drain. Dice the %i7, mushrooms, and %i10, and chop the shrimp.";
"recipe.hk_lo_bak_go.step1.title" = "Prepare the savory ingredients";
"recipe.hk_lo_bak_go.step10.body" = "Remove the steamed cake and let it cool completely so it can be sliced cleanly.";
"recipe.hk_lo_bak_go.step10.title" = "Cool completely";
"recipe.hk_lo_bak_go.step11.body" = "Unmold the cake and cut it into thick rectangular slices.";
"recipe.hk_lo_bak_go.step11.title" = "Slice the cake";
"recipe.hk_lo_bak_go.step12.body" = "Heat %i14 in a skillet and pan-fry the slices on both sides until lightly crisp and golden.";
"recipe.hk_lo_bak_go.step12.title" = "Pan-fry until golden";
"recipe.hk_lo_bak_go.step13.body" = "Serve the lo bak go hot as a dim sum dish.";
"recipe.hk_lo_bak_go.step13.title" = "Serve hot";
"recipe.hk_lo_bak_go.step2.body" = "Peel and grate the %i1, then lightly squeeze and keep both the grated radish and released liquid.";
"recipe.hk_lo_bak_go.step2.title" = "Prepare the daikon";
"recipe.hk_lo_bak_go.step3.body" = "Mix the %i3, %i4, %i5, and %i6 with part of the %i2 into a smooth slurry with no lumps.";
"recipe.hk_lo_bak_go.step3.title" = "Make the flour slurry";
"recipe.hk_lo_bak_go.step4.body" = "Heat %i11 in a wok and stir-fry the shallot, Chinese sausage, dried shrimp, and mushrooms until fragrant, then add %i12 and %i13.";
"recipe.hk_lo_bak_go.step4.title" = "Cook the savory mix";
"recipe.hk_lo_bak_go.step5.body" = "Add the grated daikon and the remaining water to the wok and cook until the radish softens and releases sweetness.";
"recipe.hk_lo_bak_go.step5.title" = "Cook the daikon";
"recipe.hk_lo_bak_go.step6.body" = "Lower the heat, stir the flour slurry again, then pour it into the wok and mix continuously until a thick spoonable paste forms evenly with the radish and savory ingredients.";
"recipe.hk_lo_bak_go.step6.title" = "Combine into batter";
"recipe.hk_lo_bak_go.step7.body" = "Lightly oil the steaming tin, scrape in the mixture, and smooth the top.";
"recipe.hk_lo_bak_go.step7.title" = "Fill the steaming tin";
"recipe.hk_lo_bak_go.step8.body" = "Add %i15 to the steamer and bring it to a steady boil.";
"recipe.hk_lo_bak_go.step8.title" = "Prepare the steamer";
"recipe.hk_lo_bak_go.step9.body" = "Place the tin in the steamer, cover, and steam until the turnip cake is fully set and firm.";
"recipe.hk_lo_bak_go.step9.title" = "Steam the cake";
