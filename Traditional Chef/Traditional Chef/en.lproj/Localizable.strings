"recipe.th_bua_loy.drink.body" = "A lightly sweet white wine such as late harvest Riesling can match the coconut and palm sugar notes. A gentle jasmine tea or warm unsweetened pandan tea is a classic non-alcoholic pairing.";
"recipe.th_bua_loy.drink.summary" = "Sweet wine (Riesling)";
"recipe.th_bua_loy.info" = "Bua Loy is a traditional Thai dessert of chewy glutinous rice flour dumplings simmered and served in warm sweet coconut milk scented with pandan and balanced with a little salt. It is commonly enjoyed as a comforting dessert after meals or as a festive sweet.";
"recipe.th_bua_loy.info.summary" = "Sweet coconut dumplings";
"recipe.th_bua_loy.name" = "Bua loy";
"recipe.th_bua_loy.step1.body" = "Place the %i1 in a mixing bowl and gradually add the %i2 while mixing until a soft smooth dough forms. Knead until it is no longer crumbly and can be rolled easily.";
"recipe.th_bua_loy.step1.title" = "Make the dough";
"recipe.th_bua_loy.step2.body" = "Pinch small pieces of dough and roll them into small balls. Keep the shaped dumplings together on a tray or plate while you prepare the broth and boiling water.";
"recipe.th_bua_loy.step2.title" = "Shape the dumplings";
"recipe.th_bua_loy.step3.body" = "Add the %i3, %i4, %i5, %i6, and %i7 to a saucepan. Heat gently while stirring until the sugar dissolves and the broth is smooth.";
"recipe.th_bua_loy.step3.title" = "Start the coconut broth";
"recipe.th_bua_loy.step4.body" = "Keep the coconut broth at a gentle simmer so the pandan can infuse. Do not let it boil hard. Remove the pandan leaves when fragrant.";
"recipe.th_bua_loy.step4.title" = "Infuse the broth";
"recipe.th_bua_loy.step5.body" = "Bring the boiling %i8 to a full boil in a pot.";
"recipe.th_bua_loy.step5.title" = "Boil water";
"recipe.th_bua_loy.step6.body" = "Add the dumplings to the boiling water and stir gently so they do not stick. Cook until they float and look slightly translucent.";
"recipe.th_bua_loy.step6.title" = "Cook the dumplings";
"recipe.th_bua_loy.step7.body" = "Lift the cooked dumplings out with a slotted spoon and transfer them directly into the warm coconut broth.";
"recipe.th_bua_loy.step7.title" = "Transfer to coconut broth";
"recipe.th_bua_loy.step8.body" = "Simmer the dumplings briefly in the coconut broth so they absorb flavor and the dessert is evenly hot.";
"recipe.th_bua_loy.step8.title" = "Finish together";
"recipe.th_bua_loy.step9.body" = "Ladle the bua loy into serving bowls and serve warm.";
"recipe.th_bua_loy.step9.title" = "Serve";
