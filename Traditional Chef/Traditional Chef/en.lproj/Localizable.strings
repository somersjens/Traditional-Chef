"recipe.fr_mousse_au_chocolat.drink.body" = "Pair with a sweet red such as Banyuls or Maury that complements dark chocolate and keeps its fruitiness. A strong coffee can also be served alongside. For a non-alcoholic option, serve espresso, black tea, or sparkling water.";
"recipe.fr_mousse_au_chocolat.drink.summary" = "Red wine (Banyuls)";
"recipe.fr_mousse_au_chocolat.info" = "Mousse au chocolat is a traditional French dessert made by folding melted dark chocolate into whipped egg whites and enriched with butter and egg yolks for a rich yet airy texture. It is chilled until set and served cold, often simply on its own to highlight the deep chocolate flavor.";
"recipe.fr_mousse_au_chocolat.info.summary" = "Deep chocolate mousse";
"recipe.fr_mousse_au_chocolat.name" = "Chocolate mousse";
"recipe.fr_mousse_au_chocolat.step1.body" = "Melt %i1 and %i2 gently over a bain-marie until smooth, then let it cool slightly so it stays fluid.";
"recipe.fr_mousse_au_chocolat.step1.title" = "Melt the chocolate";
"recipe.fr_mousse_au_chocolat.step2.body" = "Separate %i3, keeping the whites and yolks in clean bowls so the whites will whip properly.";
"recipe.fr_mousse_au_chocolat.step2.title" = "Separate the eggs";
"recipe.fr_mousse_au_chocolat.step3.body" = "Whisk the yolks with part of %i4 until thicker and paler, then whisk in the melted chocolate mixture until smooth.";
"recipe.fr_mousse_au_chocolat.step3.title" = "Make the yolk base";
"recipe.fr_mousse_au_chocolat.step4.body" = "Whip the egg whites with a pinch of %i5, adding the remaining sugar gradually, until glossy stiff peaks form.";
"recipe.fr_mousse_au_chocolat.step4.title" = "Whip the egg whites";
"recipe.fr_mousse_au_chocolat.step5.body" = "Fold a portion of the whites into the chocolate base to loosen it, then fold in the remaining whites gently to keep the mousse airy.";
"recipe.fr_mousse_au_chocolat.step5.title" = "Fold the mousse";
"recipe.fr_mousse_au_chocolat.step6.body" = "Portion into glasses and chill until fully set and cold.";
"recipe.fr_mousse_au_chocolat.step6.title" = "Chill to set";
"recipe.fr_mousse_au_chocolat.step7.body" = "Serve cold and enjoy.";
"recipe.fr_mousse_au_chocolat.step7.title" = "Serve the mousse";
