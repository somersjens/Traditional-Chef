"recipe.th_larb.drink.summary" = "Rosé wine";
"recipe.th_larb.info" = "Larb Moo is a traditional Thai and Isan minced pork salad seasoned with fish sauce, lime juice, dried chili, and toasted rice powder, then mixed with shallots and fresh herbs. It is typically served warm or room temperature with sticky rice and fresh vegetables as a shared main dish.";
"recipe.th_larb.info.summary" = "Spicy pork salad";
"recipe.th_larb.name" = "Larb";
