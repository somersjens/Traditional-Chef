"recipe.cn_mapo_tofu.step1.title" = "Prepare tofu and aromatics";
"recipe.cn_mapo_tofu.step10.body" = "Sprinkle in the %i16 and most of the scallions, then fold gently to finish the dish with its numbing aroma.";
"recipe.cn_mapo_tofu.step10.title" = "Finish with pepper and scallions";
"recipe.cn_mapo_tofu.step11.body" = "Transfer to a serving bowl, top with the remaining scallion greens, and serve immediately with %i18.";
"recipe.cn_mapo_tofu.step11.title" = "Serve hot";
"recipe.cn_mapo_tofu.step2.body" = "Bring %i3 to a gentle simmer with %i4, add the tofu cubes carefully, and blanch briefly to firm the surface and warm the tofu.";
"recipe.cn_mapo_tofu.step2.title" = "Blanch the tofu";
"recipe.cn_mapo_tofu.step3.body" = "Lift out the tofu gently with a slotted spoon and set it aside so the cubes stay intact.";
"recipe.cn_mapo_tofu.step3.title" = "Drain the tofu";
"recipe.cn_mapo_tofu.step4.body" = "Heat the wok well, add the %i5, and swirl to coat the surface.";
"recipe.cn_mapo_tofu.step4.title" = "Heat the wok";
"recipe.cn_mapo_tofu.step5.body" = "Add the %i2 and stir-fry until it releases fat, then add the %i6 and %i7 and fry until the oil turns red and fragrant.";
"recipe.cn_mapo_tofu.step5.title" = "Fry the beef and sauce base";
"recipe.cn_mapo_tofu.step6.body" = "Add the ginger, garlic, %i13, %i10, and %i12, and stir-fry briefly until aromatic.";
"recipe.cn_mapo_tofu.step6.title" = "Add aromatics and seasonings";
"recipe.cn_mapo_tofu.step7.body" = "Add %i11, bring to a simmer, and stir so the sauce base becomes evenly combined.";
"recipe.cn_mapo_tofu.step7.title" = "Build the sauce";
"recipe.cn_mapo_tofu.step8.body" = "Slide the tofu into the sauce and gently simmer, nudging the wok rather than stirring hard so the tofu absorbs flavor without breaking.";
"recipe.cn_mapo_tofu.step8.title" = "Simmer the tofu";
"recipe.cn_mapo_tofu.step9.body" = "Mix the %i14 with %i15, pour it in gradually while gently moving the sauce, and cook until lightly thickened and glossy.";
"recipe.cn_mapo_tofu.step9.title" = "Thicken with slurry";
