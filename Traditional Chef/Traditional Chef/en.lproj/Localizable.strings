"recipe.in_rogan_josh.step10.title" = "Finish the rogan josh";
"recipe.in_rogan_josh.step11.body" = "Serve the rogan josh hot with steamed rice.";
"recipe.in_rogan_josh.step11.title" = "Serve";
"recipe.in_rogan_josh.step2.body" = "Cover and refrigerate the mutton so the yogurt seasons and tenderizes the meat.";
