"recipe.us_ca_cioppino.drink.body" = "A crisp Sauvignon Blanc or dry Vermentino pairs with the tomato-wine broth and sweet shellfish, and a pale ale also works well with the garlic and herbs. For a non-alcoholic option, serve sparkling water with lemon or unsweetened iced tea to keep the finish clean and refreshing.";
"recipe.us_ca_cioppino.drink.summary" = "White wine (Sauvignon)";
"recipe.us_ca_cioppino.info" = "San Francisco cioppino is an Italian-American fisherman’s stew from California, built on a fragrant tomato and white-wine broth and loaded with mixed Pacific-style seafood. The broth is simmered until aromatic, then shellfish and fish are added in stages so everything cooks just to tenderness, creating a rich, briny, brick-red bowl meant for sharing. It is traditionally served with plenty of San Francisco sourdough for dipping.";
"recipe.us_ca_cioppino.info.summary" = "Sourdough seafood stew";
"recipe.us_ca_cioppino.name" = "Cioppino";
"recipe.us_ca_cioppino.step1.body" = "Rinse and scrub %i16 and %i17, discarding any with cracked shells. Devein %i18, clean %i20, and cut %i21 into large bite-size pieces. Keep everything cold while you build the broth.";
"recipe.us_ca_cioppino.step1.title" = "Clean the seafood";
"recipe.us_ca_cioppino.step10.body" = "Toast %i22 until crisp on the outside but still chewy in the center.";
"recipe.us_ca_cioppino.step10.title" = "Toast the bread";
"recipe.us_ca_cioppino.step11.body" = "Ladle cioppino into wide bowls, making sure each serving gets a mix of seafood, and serve immediately with toasted sourdough for dipping.";
"recipe.us_ca_cioppino.step11.title" = "Serve";
"recipe.us_ca_cioppino.step2.body" = "Warm %i1 in the pot and cook %i2 and %i3 until softened and fragrant, stirring so they do not brown too hard.";
"recipe.us_ca_cioppino.step2.title" = "Start the aromatic base";
"recipe.us_ca_cioppino.step3.body" = "Stir in %i4 until fragrant, then cook %i5 until it darkens slightly and coats the vegetables.";
"recipe.us_ca_cioppino.step3.title" = "Bloom garlic and tomato paste";
"recipe.us_ca_cioppino.step4.body" = "Pour in %i7 and simmer briefly while scraping the bottom. Add %i6, %i8, %i9, %i10, %i11, %i12, and %i13, then bring to a steady simmer.";
"recipe.us_ca_cioppino.step4.title" = "Build the broth";
