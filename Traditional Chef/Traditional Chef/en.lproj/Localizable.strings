"recipe.sa_margoog.drink.body" = "A medium-bodied red wine such as Grenache or Syrah pairs well with the lamb, tomatoes, and warming spices. For a non-alcoholic pairing, serve hot black tea or a cold yogurt drink.";
"recipe.sa_margoog.drink.summary" = "Red wine (Grenache)";
"recipe.sa_margoog.info" = "Margoog is a traditional Saudi main dish from Najd made by simmering lamb with onions, tomatoes, and vegetables, then cooking thin sheets of whole wheat dough directly in the bubbling broth. It is a hearty communal dish served hot at family meals, especially in cooler weather, with the tender dough absorbing the rich meat and vegetable flavors.";
"recipe.sa_margoog.info.summary" = "Stewed dough platter";
"recipe.sa_margoog.name" = "Margoog";
"recipe.sa_margoog.step1.body" = "Heat %i2 in the heavy pot and brown %i1 well on several sides to build a deep savory base.";
"recipe.sa_margoog.step1.title" = "Brown the lamb";
"recipe.sa_margoog.step10.body" = "Cover the pot and cook gently until the dough is tender, the vegetables are fully cooked, and the broth has thickened around the lamb and dough.";
"recipe.sa_margoog.step10.title" = "Finish the dish";
"recipe.sa_margoog.step11.body" = "Take the pot off the heat and let the margoog stand briefly so the broth settles and the dough absorbs more flavor.";
"recipe.sa_margoog.step11.title" = "Rest before serving";
"recipe.sa_margoog.step12.body" = "Ladle the lamb, vegetables, dough, and broth into a large serving dish and serve immediately.";
"recipe.sa_margoog.step12.title" = "Serve hot";
