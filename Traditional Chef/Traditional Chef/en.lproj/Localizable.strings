"recipe.sy_dawood_basha.drink.body" = "A medium-bodied red such as Syrah pairs well with the warm spices and tomato sauce, while a light young Grenache also works nicely. For a non-alcoholic option, serve chilled ayran or a fresh mint lemonade alongside the meal.";
"recipe.sy_dawood_basha.drink.summary" = "Red wine (Syrah)";
"recipe.sy_dawood_basha.info" = "Dawood Basha is a classic Syrian home-style dish of tender spiced meatballs simmered in a rich tomato and garlic sauce, traditionally finished with toasted pine nuts and served with simple rice that soaks up the sauce.";
"recipe.sy_dawood_basha.info.summary" = "Tomato meatball stew";
"recipe.sy_dawood_basha.name" = "Dawood basha";
"recipe.sy_dawood_basha.step1.body" = "Finely grate the %i2 and mince the %i4. Chop the %i3 very finely. Keep the onion and garlic for the sauce separate from the ones for the meatballs.";
"recipe.sy_dawood_basha.step1.title" = "Prep the aromatics";
"recipe.sy_dawood_basha.step10.body" = "Melt the %i19 in a pot, toast the %i18 until golden, then add the drained rice and stir to coat the grains.";
"recipe.sy_dawood_basha.step10.title" = "Toast vermicelli and coat rice";
"recipe.sy_dawood_basha.step11.body" = "Add water and %i21, bring to a boil, then cover and cook on low heat until the liquid is absorbed and the rice is tender. Turn off the heat and let it rest covered, then fluff with a fork.";
"recipe.sy_dawood_basha.step11.title" = "Cook the rice";
"recipe.sy_dawood_basha.step12.body" = "Spoon the tomato-simmered meatballs over rice or serve alongside, then finish with toasted pine nuts.";
"recipe.sy_dawood_basha.step12.title" = "Serve";
"recipe.sy_dawood_basha.step2.body" = "In a bowl, combine the %i1 with the grated onion, minced garlic, parsley, %i5, %i6, %i7, and %i8. Mix until cohesive and slightly sticky.";
"recipe.sy_dawood_basha.step2.title" = "Mix the meatballs";
"recipe.sy_dawood_basha.step3.body" = "With lightly damp hands, roll the mixture into small, even meatballs and set them on a plate.";
"recipe.sy_dawood_basha.step3.title" = "Shape the meatballs";
"recipe.sy_dawood_basha.step4.body" = "Toast the %i22 in a dry skillet over medium heat, stirring often until golden. Remove immediately to a plate so they do not burn.";
"recipe.sy_dawood_basha.step4.title" = "Toast the pine nuts";
"recipe.sy_dawood_basha.step5.body" = "Heat %i9 in a large skillet and brown the meatballs in batches, turning gently to color most sides. Transfer the browned meatballs to a plate.";
"recipe.sy_dawood_basha.step5.title" = "Brown the meatballs";
"recipe.sy_dawood_basha.step6.body" = "In a saucepan, warm a little olive oil and sauté the %i10 until soft. Add the %i11 and cook briefly, then stir in the %i13 until it loosens and smells toasted.";
"recipe.sy_dawood_basha.step6.title" = "Start the tomato sauce";
"recipe.sy_dawood_basha.step7.body" = "Add the %i12 and %i14, season with %i16 and %i15, bring to a simmer, then cook gently until the sauce thickens slightly.";
"recipe.sy_dawood_basha.step7.title" = "Simmer the sauce";
"recipe.sy_dawood_basha.step8.body" = "Slide the browned meatballs into the simmering sauce. Cover partially and simmer until the meatballs are cooked through and the sauce is rich and glossy.";
"recipe.sy_dawood_basha.step8.title" = "Cook meatballs in sauce";
"recipe.sy_dawood_basha.step9.body" = "Rinse the %i17 in several changes of water until the water runs mostly clear, then drain well.";
"recipe.sy_dawood_basha.step9.title" = "Rinse and drain the rice";
