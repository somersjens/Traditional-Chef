"recipe.hk_char_siu.drink.body" = "A light fruity red such as Pinot Noir works with the sweet caramelized glaze and roasted pork fat. For a non-alcoholic option, serve hot oolong tea or warm chrysanthemum tea.";
"recipe.hk_char_siu.drink.summary" = "Red wine (Pinot Noir)";
"recipe.hk_char_siu.info" = "A traditional Cantonese siu mei roast pork dish with a glossy red-brown glaze, charred edges, and a sweet-savory flavor. In Hong Kong it is commonly served sliced with rice, noodles, or as part of a family meal with plain rice and greens.";
