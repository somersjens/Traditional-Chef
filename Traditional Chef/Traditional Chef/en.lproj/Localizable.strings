"recipe.ru_blini_s_ikroy.drink.body" = "Dry sparkling wine or a crisp, high-acid white balances the buttery blini and the salty pop of caviar. If serving spirits, chilled vodka is classic alongside. Non-alcoholic pairing: sparkling water with lemon or strong black tea.";
"recipe.ru_blini_s_ikroy.drink.summary" = "Sparkling wine";
"recipe.ru_blini_s_ikroy.info" = "Blini s ikroy are traditional Russian yeasted buckwheat-wheat pancakes served warm with butter, sour cream, and caviar. The batter is rested so the blini cook up tender and slightly airy, then they are offered at the table so each person can top them with a smear of butter, a spoon of sour cream, and caviar.";
"recipe.ru_blini_s_ikroy.info.summary" = "Blini with caviar";
"recipe.ru_blini_s_ikroy.name" = "Blini with caviar";
"recipe.ru_blini_s_ikroy.step1.body" = "Warm %i3 with a little %i4 until just warm. Stir in %i5 and %i6, then let it stand until foamy.";
"recipe.ru_blini_s_ikroy.step1.title" = "Make the starter";
"recipe.ru_blini_s_ikroy.step2.body" = "Whisk %i1, %i2, and %i7 in a bowl. Whisk in the yeast mixture, then whisk in %i8 until smooth.";
"recipe.ru_blini_s_ikroy.step2.title" = "Mix the batter";
"recipe.ru_blini_s_ikroy.step3.body" = "Cover the batter and leave it in a warm place until it becomes airy and lightly risen.";
"recipe.ru_blini_s_ikroy.step3.title" = "Rest and rise";
"recipe.ru_blini_s_ikroy.step4.body" = "Melt %i9 and whisk it into the batter. If needed, loosen with a little warm water so it pours easily from a ladle.";
"recipe.ru_blini_s_ikroy.step4.title" = "Finish the batter";
"recipe.ru_blini_s_ikroy.step5.body" = "Heat a skillet over medium heat and lightly grease it with butter. Ladle in small rounds of batter and cook until set and golden, then flip and cook briefly. Repeat, stacking the blini on a platter.";
"recipe.ru_blini_s_ikroy.step5.title" = "Cook the blini";
"recipe.ru_blini_s_ikroy.step6.body" = "Serve the blini warm with %i12, %i10, and %i11 so each portion can be topped at the table.";
"recipe.ru_blini_s_ikroy.step6.title" = "Serve with caviar";
"recipe.ru_blini_s_ikroy.tool.t1" = "Mixing bowl";
"recipe.ru_blini_s_ikroy.tool.t2" = "Whisk";
