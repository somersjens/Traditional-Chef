"recipe.kh_num_akor.drink.body" = "A lightly sweet white wine such as Moscato or late-harvest Riesling pairs well with the palm sugar sweetness and coconut cream. A light jasmine tea also matches the delicate texture. For a non-alcoholic option, serve hot pandan tea or unsweetened green tea.";
"recipe.kh_num_akor.drink.summary" = "Sweet wine (Moscato)";
"recipe.kh_num_akor.info" = "Num akor is a traditional Cambodian steamed rice cake made from fermented rice flour sweetened with palm sugar, then steamed in small molds until soft and springy. It is commonly eaten as a snack or dessert and is often served with a coconut cream topping.";
"recipe.kh_num_akor.info.summary" = "Steamed rice cake";
