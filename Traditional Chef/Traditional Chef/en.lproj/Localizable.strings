"recipe.kh_pleah_sach_ko.step3.title" = "Make dressing";
"recipe.kh_pleah_sach_ko.step4.body" = "Bring %i17 to a boil, lower the beef briefly just until the slices change color, then lift them out and transfer to %i18.";
"recipe.kh_pleah_sach_ko.step4.title" = "Blanch beef";
"recipe.kh_pleah_sach_ko.step5.body" = "Drain the beef well and gently squeeze off excess water so the dressing will cling properly.";
"recipe.kh_pleah_sach_ko.step5.title" = "Drain beef";
"recipe.kh_pleah_sach_ko.step6.body" = "Add the beef to the dressing with the lemongrass, shallots, and shredded makrut lime leaves, then toss thoroughly so the beef is evenly coated.";
"recipe.kh_pleah_sach_ko.step6.title" = "Dress beef";
"recipe.kh_pleah_sach_ko.step7.body" = "Add the mint and Thai basil and toss gently, then fold in half of the %i16.";
"recipe.kh_pleah_sach_ko.step7.title" = "Add herbs and finish";
"recipe.kh_pleah_sach_ko.step8.body" = "Arrange the pleah sach ko on a serving platter with the cucumber, bean sprouts, and lettuce.";
"recipe.kh_pleah_sach_ko.step8.title" = "Plate salad";
"recipe.kh_pleah_sach_ko.step9.body" = "Sprinkle the remaining roasted peanuts over the top and serve immediately.";
"recipe.kh_pleah_sach_ko.step9.title" = "Serve";
