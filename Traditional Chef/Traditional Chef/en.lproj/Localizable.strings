"recipe.cl_cazuela.drink.body" = "Pair with a light Chilean red such as País or a young Merlot that won’t overpower the delicate broth. If you prefer white, a dry Chardonnay works well. Non-alcoholic option: sparkling water with lemon or a chilled mint tea.";
"recipe.cl_cazuela.drink.summary" = "Red wine (País)";
"recipe.cl_cazuela.info" = "Chilean cazuela is a traditional home-style soup-stew made by simmering meat on the bone with aromatics to create a rich broth, then cooking potatoes, pumpkin, corn and vegetables in that broth until tender. Each bowl is served with a piece of meat, a whole potato, a chunk of squash, corn, and vegetables in clear, comforting broth, finished with chopped cilantro and often a squeeze of lemon.";
"recipe.cl_cazuela.info.summary" = "Chilean home-style cazuela";
"recipe.cl_cazuela.name" = "Cazuela";
"recipe.cl_cazuela.step1.body" = "Wash and cut the vegetables: leave %i9 whole, cut %i10 into large chunks, peel and cut %i11, trim %i12, and cut %i13 into serving pieces. Separate %i5 for the broth and chop %i14 for finishing.";
"recipe.cl_cazuela.step1.title" = "Prepare the ingredients";
"recipe.cl_cazuela.step2.body" = "Add %i1, %i3, %i4, cilantro stems, %i6, %i2, %i7, and %i8 to a large pot. Bring to a gentle simmer, skim any foam, and cook until the meat is starting to become tender and the broth is flavorful.";
"recipe.cl_cazuela.step2.title" = "Simmer the beef broth";
"recipe.cl_cazuela.step3.body" = "Add potatoes and squash to the simmering broth and cook until they begin to soften while keeping the broth gently bubbling.";
"recipe.cl_cazuela.step3.title" = "Cook potatoes and squash";
"recipe.cl_cazuela.step4.body" = "Add corn pieces and carrots and continue simmering until the vegetables are tender and the meat is fully tender.";
"recipe.cl_cazuela.step4.title" = "Add corn and carrots";
"recipe.cl_cazuela.step5.body" = "Add green beans and simmer until just tender and still bright, then taste and adjust salt.";
"recipe.cl_cazuela.step5.title" = "Finish with green beans";
"recipe.cl_cazuela.step6.body" = "Ladle into bowls, making sure each serving gets a piece of beef, potato, squash, corn, carrots, and beans with broth. Top with chopped cilantro and serve with %i15 and %i16.";
"recipe.cl_cazuela.step6.title" = "Serve the cazuela";
