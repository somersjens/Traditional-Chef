"recipe.lb_kibbeh_labanieh.drink.body" = "Pair with a crisp, high-acid white such as dry Riesling or Sauvignon Blanc to balance the tangy yogurt and rich butter. For a non-alcoholic option, serve chilled sparkling water with lemon or a salted yogurt drink.";
"recipe.lb_kibbeh_labanieh.drink.summary" = "White wine (Riesling)";
"recipe.lb_kibbeh_labanieh.info" = "Kibbeh labanieh is a beloved Lebanese main of stuffed kibbeh balls simmered in a warm, garlicky yogurt sauce scented with dried mint and finished with a buttery mint-garlic topping. It is commonly served hot with vermicelli rice to soak up the tangy sauce, making it a comforting centerpiece dish for family meals.";
"recipe.lb_kibbeh_labanieh.info.summary" = "Yogurt kibbeh stew";
"recipe.lb_kibbeh_labanieh.name" = "Kibbeh labanieh";
