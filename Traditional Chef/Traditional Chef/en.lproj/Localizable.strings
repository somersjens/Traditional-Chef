"recipe.cu_yuca_con_mojo.step2.title" = "Boil until tender";
"recipe.cu_yuca_con_mojo.step3.body" = "Drain the yuca well, discard any loosened tough cores, and arrange the yuca on a serving platter while still hot.";
"recipe.cu_yuca_con_mojo.step3.title" = "Drain and keep warm";
