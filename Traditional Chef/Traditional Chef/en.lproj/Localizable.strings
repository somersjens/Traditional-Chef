"recipe.dz_loubia.drink.body" = "A medium-bodied red like Grenache pairs well with the tomato-paprika sauce and beef without overwhelming the dish. If you prefer white, a fuller, aromatic white such as Viognier can match the spices. Non-alcoholic pairing: mint tea or sparkling water with lemon.";
"recipe.dz_loubia.drink.summary" = "Red wine (Grenache)";
"recipe.dz_loubia.info" = "Algerian loubia is a hearty white bean stew simmered in a paprika- and tomato-based sauce with beef and aromatics until the beans are creamy and the broth is rich and red. It is a classic home meal, commonly served hot with crusty Algerian bread for scooping up the thick sauce.";
"recipe.dz_loubia.info.summary" = "White bean tomato stew";
"recipe.dz_loubia.name" = "Loubia";
"recipe.dz_loubia.step1.body" = "Rinse the %i1, cover with plenty of %i12, and soak until fully hydrated. Drain and rinse well.";
"recipe.dz_loubia.step1.title" = "Soak the beans";
"recipe.dz_loubia.step10.body" = "Simmer uncovered until the sauce is thick and clings to the beans and meat, adjusting salt if needed.";
"recipe.dz_loubia.step10.title" = "Reduce to desired thickness";
"recipe.dz_loubia.step11.body" = "Serve loubia hot with slices of bread for dipping.";
"recipe.dz_loubia.step11.title" = "Serve";
"recipe.dz_loubia.step2.body" = "Mix %i13, %i14, %i15, and %i16. Add %i17, then add %i18 gradually and knead until smooth and elastic.";
"recipe.dz_loubia.step2.title" = "Make the bread dough";
"recipe.dz_loubia.step3.body" = "Cover the dough and let it rise until doubled and airy.";
"recipe.dz_loubia.step3.title" = "Proof the dough";
"recipe.dz_loubia.step4.body" = "Chop the %i3, mince the %i4, and chop or grate the %i5.";
"recipe.dz_loubia.step4.title" = "Prep aromatics and tomatoes";
"recipe.dz_loubia.step5.body" = "Heat %i11 in a heavy pot and brown the %i2 well, then add onion and cook until softened. Add garlic briefly.";
"recipe.dz_loubia.step5.title" = "Brown the beef";
"recipe.dz_loubia.step6.body" = "Stir in %i6 and cook until thickened, then add %i7, %i8, %i10, and %i9.";
"recipe.dz_loubia.step6.title" = "Build the sauce";
"recipe.dz_loubia.step7.body" = "Add the soaked beans and enough water to cover well. Bring to a gentle simmer, partially cover, and cook until beans are creamy and beef is tender, stirring occasionally.";
"recipe.dz_loubia.step7.title" = "Simmer the beans and beef";
"recipe.dz_loubia.step8.body" = "Turn the dough out, shape into a round loaf, place on a baking tray, and cover to rise again.";
"recipe.dz_loubia.step8.title" = "Shape the bread";
"recipe.dz_loubia.step9.body" = "Bake until well risen and browned, then cool slightly before slicing.";
"recipe.dz_loubia.step9.title" = "Bake the bread";
