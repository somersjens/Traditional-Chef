"recipe.ru_zharkoye.drink.body" = "A medium-bodied red such as Merlot or a мягкий Russian-style red pairs well with the rich braised meat and potatoes, while a crisp dry white can also work if you prefer. Non-alcoholic pairing: hot black tea or sparkling water.";
"recipe.ru_zharkoye.drink.summary" = "Red wine (Merlot)";
"recipe.ru_zharkoye.info" = "Zharkoye is a traditional Russian one-pot roast stew of browned meat slowly braised with onions, carrots, and potatoes until everything is tender and the broth is rich and savory. It is served hot as a comforting main course, often straight from the pot or in individual bowls, with the vegetables and meat coated in the concentrated cooking juices.";
"recipe.ru_zharkoye.info.summary" = "One-pot meat stew";
"recipe.ru_zharkoye.name" = "Zharkoye";
"recipe.ru_zharkoye.step1.body" = "Cut %i1 into chunks. Peel and cut %i2 into large pieces. Slice %i3, cut %i4, and mince %i5.";
"recipe.ru_zharkoye.step1.title" = "Prep";
"recipe.ru_zharkoye.step2.body" = "Heat %i6 in a heavy pot and brown the pork well on all sides, working in batches so it sears rather than steams.";
"recipe.ru_zharkoye.step2.title" = "Brown the pork";
"recipe.ru_zharkoye.step3.body" = "Add onion and carrot to the pot and cook until softened, scraping up browned bits. Add garlic and cook briefly.";
"recipe.ru_zharkoye.step3.title" = "Cook the aromatics";
"recipe.ru_zharkoye.step4.body" = "Add %i8, season with %i9 and %i10, add %i7, cover, and simmer gently until the pork is tender.";
"recipe.ru_zharkoye.step4.title" = "Braise";
"recipe.ru_zharkoye.step5.body" = "Add the potatoes and continue simmering until the potatoes are tender and the cooking liquid is rich and slightly thickened.";
"recipe.ru_zharkoye.step5.title" = "Cook the potatoes";
"recipe.ru_zharkoye.step6.body" = "Stir in %i11, adjust seasoning, and serve hot in bowls with the juices spooned over.";
"recipe.ru_zharkoye.step6.title" = "Finish and serve";
