"recipe.co_mondongo.step3.title" = "Prep the vegetables";
"recipe.co_mondongo.step4.body" = "Add cassava and potatoes to the soup and simmer until they begin to soften and the broth becomes richer.";
"recipe.co_mondongo.step4.title" = "Cook root vegetables";
"recipe.co_mondongo.step5.body" = "Add carrots, green beans, and cabbage and simmer until all vegetables are tender and the soup is hearty.";
"recipe.co_mondongo.step5.title" = "Add remaining vegetables";
