"recipe.ph_leche_flan.drink.body" = "A lightly sweet dessert wine such as Moscato dAsti pairs well with the rich custard and caramel. Coffee also complements leche flan nicely. For a non-alcoholic option, serve hot barako coffee or unsweetened black tea.";
"recipe.ph_leche_flan.drink.summary" = "Dessert wine (Moscato dAsti)";
"recipe.ph_leche_flan.info" = "Leche flan is a traditional Filipino caramel custard made with egg yolks, condensed milk, and evaporated milk, steamed gently until smooth and set. It is a classic celebration dessert served chilled and unmolded with its caramel syrup.";
"recipe.ph_leche_flan.info.summary" = "Silky celebration flan";
"recipe.ph_leche_flan.name" = "Leche flan";
"recipe.ph_leche_flan.step1.body" = "Bring %i5 to a gentle simmer in the steamer and set the llanera molds ready on the work surface.";
"recipe.ph_leche_flan.step1.title" = "Prepare steamer and molds";
"recipe.ph_leche_flan.step2.body" = "Heat the %i1 in a saucepan over medium heat until it melts and turns amber, then quickly pour a thin layer into each mold and swirl to coat the base.";
"recipe.ph_leche_flan.step2.title" = "Make caramel";
"recipe.ph_leche_flan.step3.body" = "In a mixing bowl, combine the %i2, %i3, and %i4, then whisk gently until fully blended without adding too much air.";
"recipe.ph_leche_flan.step3.title" = "Mix custard";
"recipe.ph_leche_flan.step4.body" = "Strain the custard mixture into the caramel-lined molds for a smooth texture, then cover each mold tightly with aluminum foil.";
"recipe.ph_leche_flan.step4.title" = "Strain into molds";
"recipe.ph_leche_flan.step5.body" = "Place the covered molds in the steamer over gently simmering water and steam until the custard is set but still slightly jiggly in the center.";
"recipe.ph_leche_flan.step5.title" = "Steam custards";
"recipe.ph_leche_flan.step6.body" = "Remove the molds and let them cool to room temperature before chilling.";
"recipe.ph_leche_flan.step6.title" = "Cool custards";
"recipe.ph_leche_flan.step7.body" = "Refrigerate the leche flan until fully cold and firm for clean unmolding.";
"recipe.ph_leche_flan.step7.title" = "Chill flan";
"recipe.ph_leche_flan.step8.body" = "Run a thin knife around the edge, invert each mold onto a serving plate, and let the caramel syrup flow over the flan before serving.";
"recipe.ph_leche_flan.step8.title" = "Unmold and serve";
"recipe.ph_leche_flan.tool.t1" = "Mixing bowl";
"recipe.ph_leche_flan.tool.t2" = "Whisk";
