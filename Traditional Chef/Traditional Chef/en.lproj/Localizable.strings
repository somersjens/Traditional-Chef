"recipe.tt_pelau.step10.title" = "Make the salad";
"recipe.tt_pelau.step11.body" = "Blend %i27 with %i28, %i29, %i30, %i31, and %i32 until smooth.";
"recipe.tt_pelau.step11.title" = "Blend pepper sauce";
"recipe.tt_pelau.step12.body" = "Serve pelau hot with the salad and pepper sauce on the side.";
"recipe.tt_pelau.step12.title" = "Serve";
"recipe.tt_pelau.step2.body" = "Heat %i7 in a heavy pot over medium heat, add %i6, and stir until it melts and turns deep mahogany, watching closely so it does not burn.";
"recipe.tt_pelau.step2.title" = "Caramelize the sugar";
"recipe.tt_pelau.step3.body" = "Add the chicken to the caramel and turn to coat, letting it brown well while the caramel clings to the pieces and the pot develops deep color.";
"recipe.tt_pelau.step3.title" = "Brown the chicken in burnt sugar";
