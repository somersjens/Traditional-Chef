"recipe.hu_palacsinta_gundel.step1.title" = "Make the crêpe batter";
"recipe.hu_palacsinta_gundel.step2.body" = "Let the batter rest so it cooks into tender crêpes.";
"recipe.hu_palacsinta_gundel.step2.title" = "Rest the batter";
