"recipe.pr_arroz_con_dulce.drink.body" = "A cream sherry or late-harvest white complements the coconut and warm spices, and a light porter can also pair nicely. For a non-alcoholic option, serve café con leche or hot cinnamon tea.";
"recipe.pr_arroz_con_dulce.drink.summary" = "Sweet sherry";
"recipe.pr_arroz_con_dulce.info" = "Arroz con dulce is a traditional Puerto Rican rice pudding simmered slowly until creamy, fragrant with cinnamon, cloves, and ginger, and enriched with coconut milk for a distinctive island flavor. It is commonly prepared for holidays and family gatherings, served chilled or at cool room temperature, and finished with a dusting of cinnamon and plump raisins.";
"recipe.pr_arroz_con_dulce.info.summary" = "Holiday coconut rice";
"recipe.pr_arroz_con_dulce.name" = "Arroz con dulce";
"recipe.pr_arroz_con_dulce.step1.body" = "Rinse %i1 in a strainer under cold water until the water runs clearer, then drain well.";
"recipe.pr_arroz_con_dulce.step1.title" = "Rinse the rice";
"recipe.pr_arroz_con_dulce.step10.body" = "Dust with %i13 and serve cold or at cool room temperature.";
"recipe.pr_arroz_con_dulce.step10.title" = "Serve";
"recipe.pr_arroz_con_dulce.step2.body" = "In a heavy pot, combine the rice with %i2, %i3, %i4, %i5, and %i6, then bring to a steady simmer.";
"recipe.pr_arroz_con_dulce.step2.title" = "Start the spice infusion";
"recipe.pr_arroz_con_dulce.step3.body" = "Simmer gently, stirring occasionally, until the rice is tender and most of the water is absorbed.";
"recipe.pr_arroz_con_dulce.step3.title" = "Cook the rice until tender";
"recipe.pr_arroz_con_dulce.step4.body" = "Stir in %i7 and %i8 and return to a gentle simmer, scraping the bottom as you stir.";
"recipe.pr_arroz_con_dulce.step4.title" = "Add coconut milk and evaporated milk";
"recipe.pr_arroz_con_dulce.step5.body" = "Stir in %i9 and %i10 until fully dissolved and the mixture tastes balanced.";
"recipe.pr_arroz_con_dulce.step5.title" = "Sweeten and season";
"recipe.pr_arroz_con_dulce.step6.body" = "Continue simmering, stirring frequently, until thick, creamy, and the rice pudding coats the spoon.";
"recipe.pr_arroz_con_dulce.step6.title" = "Simmer until creamy";
"recipe.pr_arroz_con_dulce.step7.body" = "Stir in %i11 and %i12 and simmer briefly so the raisins plump and the flavors round out.";
"recipe.pr_arroz_con_dulce.step7.title" = "Finish with raisins and vanilla";
"recipe.pr_arroz_con_dulce.step8.body" = "Fish out the cinnamon sticks, cloves, and orange peel, then stir well to even out the texture.";
"recipe.pr_arroz_con_dulce.step8.title" = "Remove whole spices and peel";
"recipe.pr_arroz_con_dulce.step9.body" = "Transfer to a serving dish, cool, then refrigerate until fully chilled and set.";
"recipe.pr_arroz_con_dulce.step9.title" = "Chill and set";
