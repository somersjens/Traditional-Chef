"recipe.uz_lagman.drink.body" = "A light to medium red such as Pinot Noir or a young Sangiovese pairs well with the savory meat and tomato-based sauce without overpowering the noodles. A dry lager also works. Non-alcoholic pairing: hot black tea is a classic choice.";
"recipe.uz_lagman.drink.summary" = "Red wine (Pinot Noir)";
"recipe.uz_lagman.info" = "Lagman is a traditional Uzbek noodle dish with hand-pulled wheat noodles served with a rich meat and vegetable sauce, often with some broth for a hearty bowl. It is a popular family meal and is served hot, with fresh herbs and bread at the table in many homes.";
"recipe.uz_lagman.info.summary" = "Hand-pulled noodle bowl";
"recipe.uz_lagman.name" = "Lagman";
"recipe.uz_lagman.step1.body" = "Combine the %i1, %i4, %i3, and %i2 in a bowl and knead until smooth and firm. Coat the dough lightly with %i5, cover, and shape into a resting ball.";
"recipe.uz_lagman.step1.title" = "Make the dough";
"recipe.uz_lagman.step10.body" = "Place noodles into bowls and ladle the hot meat and vegetable sauce over them with some broth. Finish with cilantro and serve immediately with the bread.";
"recipe.uz_lagman.step10.title" = "Assemble and serve";
"recipe.uz_lagman.step2.body" = "Let the dough rest so the gluten relaxes and the noodles can be stretched later.";
"recipe.uz_lagman.step2.title" = "Rest the dough";
"recipe.uz_lagman.step3.body" = "Cut the %i6 into small pieces. Slice the %i8, %i9, and %i10. Chop the %i11, %i13, %i14, %i15, and %i16 into bite-size pieces. Chop the %i23.";
"recipe.uz_lagman.step3.title" = "Prepare meat and vegetables";
"recipe.uz_lagman.step4.body" = "Divide the rested dough into ropes, oil them lightly, and stretch gradually into long noodles, resting briefly between pulls if needed so they do not tear.";
"recipe.uz_lagman.step4.title" = "Form and stretch noodles";
"recipe.uz_lagman.step5.body" = "Bring water to a boil in the large pot. Cook the noodles until just tender, then drain in a colander and toss lightly so they do not stick.";
"recipe.uz_lagman.step5.title" = "Boil noodles";
"recipe.uz_lagman.step6.body" = "Heat the %i7 in the deep pan or kazan. Brown the meat well, then add the onion, carrot, and bell pepper and cook until the vegetables begin to soften.";
"recipe.uz_lagman.step6.title" = "Brown meat and aromatics";
"recipe.uz_lagman.step7.body" = "Add the tomatoes, %i12, garlic, cabbage, green beans, and potato. Stir in the %i17, %i18, %i19, %i20, and %i21, and cook until fragrant.";
"recipe.uz_lagman.step7.title" = "Build the sauce";
"recipe.uz_lagman.step8.body" = "Add %i22, bring to a simmer, cover partially, and cook until the meat is tender and the vegetables are fully cooked and the broth is rich.";
"recipe.uz_lagman.step8.title" = "Simmer";
"recipe.uz_lagman.step9.body" = "Warm the %i24 briefly until soft and fragrant for serving at the table.";
"recipe.uz_lagman.step9.title" = "Warm bread";
