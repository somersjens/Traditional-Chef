"recipe.eg_hamam_mahshi.step1.title" = "Prep pigeons and onion";
"recipe.eg_hamam_mahshi.step2.body" = "Warm %i4 in a skillet, add the chopped onion, and cook until softened. Stir in %i2 and cook briefly so it is coated and fragrant.";
"recipe.eg_hamam_mahshi.step2.title" = "Start the freekeh base";
"recipe.eg_hamam_mahshi.step3.body" = "Add %i9 to the freekeh and cook gently until the grains are tender and the liquid is absorbed. Season with %i5, %i6, %i7, and %i8, then cool until just warm.";
"recipe.eg_hamam_mahshi.step3.title" = "Cook the freekeh";
"recipe.eg_hamam_mahshi.step4.body" = "Stuff each pigeon with freekeh, leaving room for expansion. Tie the legs and secure the cavity with kitchen twine so the stuffing stays inside.";
"recipe.eg_hamam_mahshi.step4.title" = "Stuff and secure";
"recipe.eg_hamam_mahshi.step5.body" = "Bring water to a gentle simmer with onion, %i11, %i12, and %i13. Skim any foam so the broth stays clean.";
"recipe.eg_hamam_mahshi.step5.title" = "Start the poaching broth";
"recipe.eg_hamam_mahshi.step6.body" = "Lower the stuffed pigeons into the simmering broth and cook gently until the meat is tender. Lift out and drain well.";
"recipe.eg_hamam_mahshi.step6.title" = "Poach the pigeons";
"recipe.eg_hamam_mahshi.step7.body" = "Heat the oven and place pigeons in a roasting pan. Brush or rub the skin with %i14 so it browns evenly.";
"recipe.eg_hamam_mahshi.step7.title" = "Prepare for roasting";
"recipe.eg_hamam_mahshi.step8.body" = "Roast until the skin is deeply golden and crisp, turning once for even color. Serve hot.";
"recipe.eg_hamam_mahshi.step8.title" = "Roast until golden";
