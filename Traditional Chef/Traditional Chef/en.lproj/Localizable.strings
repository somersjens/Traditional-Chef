"recipe.uy_massini.drink.body" = "Pair with a fragrant Muscat or a lightly sweet sparkling wine to complement the vanilla pastry cream and meringue. A tawny-style fortified wine also pairs well. For a non-alcoholic option, serve strong coffee, maté, or black tea.";
"recipe.uy_massini.drink.summary" = "Dessert wine (Muscat)";
"recipe.uy_massini.info" = "Massini is a traditional Uruguayan cake made with layers of light sponge cake filled with pastry cream and topped with glossy Italian meringue. It is served chilled in neat slices, often enjoyed at celebrations and alongside coffee or maté for a classic sweet finish.";
"recipe.uy_massini.info.summary" = "Sponge and meringue cake";
"recipe.uy_massini.name" = "Massini";
"recipe.uy_massini.step1.body" = "Heat the oven and line the cake pan so the sponge releases cleanly after baking.";
"recipe.uy_massini.step1.title" = "Prepare pan and oven";
"recipe.uy_massini.step10.body" = "Boil the %i12 and %i13 to a hot syrup, then whip the %i11 to soft peaks and slowly drizzle in the syrup while beating until glossy and cool.";
"recipe.uy_massini.step10.title" = "Make Italian meringue";
"recipe.uy_massini.step11.body" = "Cover the top and sides with the meringue, shaping decorative swirls, then chill to set before slicing.";
"recipe.uy_massini.step11.title" = "Frost and finish";
"recipe.uy_massini.step12.body" = "Refrigerate until firm and cold for clean slices and a stable meringue finish.";
"recipe.uy_massini.step12.title" = "Chill before serving";
"recipe.uy_massini.step2.body" = "Whip the %i1 with %i2 until very pale and thick, then fold in the %i3, %i4, and %i5 without deflating.";
"recipe.uy_massini.step2.title" = "Make the sponge batter";
"recipe.uy_massini.step3.body" = "Bake until risen and springy in the center, then remove from the oven.";
"recipe.uy_massini.step3.title" = "Bake the sponge";
"recipe.uy_massini.step4.body" = "Cool the sponge fully on a rack so it slices cleanly into layers.";
"recipe.uy_massini.step4.title" = "Cool completely";
"recipe.uy_massini.step5.body" = "Whisk the %i7 with %i8 and %i9, then cook with %i6 over medium heat, whisking until thick and smooth, and finish with %i10.";
"recipe.uy_massini.step5.title" = "Cook the pastry cream";
"recipe.uy_massini.step6.body" = "Strain the cream, cover the surface, and refrigerate until fully cold and set.";
"recipe.uy_massini.step6.title" = "Chill the pastry cream";
"recipe.uy_massini.step7.body" = "Dissolve the %i15 in %i14 over heat, then cool the syrup to room temperature.";
"recipe.uy_massini.step7.title" = "Make soaking syrup";
"recipe.uy_massini.step8.body" = "Slice the sponge into even layers and brush the cut sides lightly with syrup so the cake stays tender.";
"recipe.uy_massini.step8.title" = "Slice and moisten the cake";
"recipe.uy_massini.step9.body" = "Spread pastry cream between the cake layers, stacking neatly to keep the sides even.";
"recipe.uy_massini.step9.title" = "Fill with pastry cream";
