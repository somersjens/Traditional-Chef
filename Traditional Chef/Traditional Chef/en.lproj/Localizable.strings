"recipe.mu_mine_frite.drink.body" = "A crisp Sauvignon Blanc or dry Riesling pairs well with the savory sauces and chili heat, staying refreshing alongside the noodles. If you prefer red, choose a light-bodied red served slightly chilled, such as Grenache. Non-alcoholic pairing: chilled sparkling water with lime or unsweetened iced tea.";
"recipe.mu_mine_frite.drink.summary" = "White wine (Sauvignon)";
"recipe.mu_mine_frite.info" = "Mine frite is a classic Chinese-Mauritian fried noodle dish tossed over high heat with egg, chicken, prawns, and crisp vegetables, flavored with soy sauces and oyster sauce for a savory, slightly smoky finish. It is a beloved home and street-food staple in Mauritius, served hot and typically accompanied by piment crazé (a fiery crushed chili condiment) on the side.";
