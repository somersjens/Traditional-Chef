"recipe.sr_fiadoe.drink.body" = "Serve with a light sweet dessert wine or demi-sec sparkling wine that complements the rich fruit filling. For a non-alcoholic option, serve black coffee or hot black tea.";
"recipe.sr_fiadoe.drink.summary" = "Sweet dessert wine";
"recipe.sr_fiadoe.info" = "Fiadoe is a traditional Surinamese festive cake of Jewish-Surinamese origin, made from a rich yeast dough layered and rolled with butter, sugar, cinnamon, dried fruit, candied peel, pineapple, and almonds. It is baked until golden and finished with a sweet milk glaze, then served in slices once cooled.";
"recipe.sr_fiadoe.info.summary" = "Festive layered cake";
"recipe.sr_fiadoe.name" = "Fiadoe";
"recipe.sr_fiadoe.step1.body" = "Warm %i2 until lukewarm and dissolve %i3 in it. Mix %i1, %i4, %i5, %i6, and %i7 with the yeast mixture and knead until a smooth rich dough forms.";
"recipe.sr_fiadoe.step1.title" = "Make the dough";
"recipe.sr_fiadoe.step2.body" = "Cover the dough and leave it in a warm place until it has clearly risen and become light.";
"recipe.sr_fiadoe.step2.title" = "Let the dough rise";
"recipe.sr_fiadoe.step3.body" = "Cut %i10 into small pieces and combine it with %i8, %i9, %i11, and %i12. Mix %i14 and %i15 separately.";
"recipe.sr_fiadoe.step3.title" = "Prepare the filling";
"recipe.sr_fiadoe.step4.body" = "Roll out half of the dough and line the cake pan with it. Brush the dough generously with some of %i13, sprinkle over part of the cinnamon sugar, and distribute half of the fruit and almond filling.";
"recipe.sr_fiadoe.step4.title" = "Roll and fill the first layer";
"recipe.sr_fiadoe.step5.body" = "Roll out the remaining dough, brush it with the remaining butter, cover it with the remaining cinnamon sugar and filling, then cut it into strips and roll each strip into a tight spiral. Arrange the spirals closely over the base to form the traditional top.";
"recipe.sr_fiadoe.step5.title" = "Roll and shape the top";
"recipe.sr_fiadoe.step6.body" = "Cover the shaped fiadoe and leave it to rise again until slightly puffy.";
"recipe.sr_fiadoe.step6.title" = "Proof in the pan";
"recipe.sr_fiadoe.step7.body" = "Bake the fiadoe until it is fully cooked, golden brown, and fragrant.";
"recipe.sr_fiadoe.step7.title" = "Bake the cake";
"recipe.sr_fiadoe.step8.body" = "Heat %i16 with %i17 and %i18 until the butter melts and the sugar dissolves.";
"recipe.sr_fiadoe.step8.title" = "Make the sweet finish";
"recipe.sr_fiadoe.step9.body" = "Brush the hot fiadoe with the sweet milk finish and leave it to cool completely so the texture settles before slicing.";
"recipe.sr_fiadoe.step9.title" = "Brush and cool";
