"recipe.tt_pastelles.drink.body" = "Off-dry Riesling balances the sweet-salty filling and the annatto-tinted cornmeal dough, while a crisp lager is also a natural match. For a non-alcoholic option, serve chilled ginger beer or sorrel drink to cut through the richness.";
"recipe.tt_pastelles.drink.summary" = "White wine (Riesling)";
"recipe.tt_pastelles.info" = "Trinidad and Tobago pastelles are savory cornmeal parcels filled with seasoned minced beef, punctuated with raisins, capers, and olives, then wrapped in banana leaves, tied, and boiled until tender. A Christmas-season staple with Venezuelan roots, they’re typically made in batches for sharing and eaten warm as part of a festive spread.";
"recipe.tt_pastelles.info.summary" = "Christmas corn parcels";
"recipe.tt_pastelles.name" = "Pastelles";
"recipe.tt_pastelles.step1.body" = "Wipe the %i20 clean, briefly pass each over a flame or hot surface to soften, then cut into rectangles suitable for wrapping and set aside.";
"recipe.tt_pastelles.step1.title" = "Prep banana leaves";
"recipe.tt_pastelles.step10.body" = "Fold the banana leaf into a neat parcel around the filled dough and tie securely with twine so it stays closed during cooking.";
"recipe.tt_pastelles.step10.title" = "Wrap and tie";
"recipe.tt_pastelles.step11.body" = "Bring water in a large pot to a steady boil, add the parcels, and cook until heated through and firm. Keep them submerged as they cook.";
"recipe.tt_pastelles.step11.title" = "Boil the parcels";
"recipe.tt_pastelles.step12.body" = "Remove parcels, drain well, cut the twine, unwrap the leaves, and serve warm.";
"recipe.tt_pastelles.step12.title" = "Drain and serve";
"recipe.tt_pastelles.step2.body" = "Heat a little oil in a skillet, add %i2, %i3, %i4, %i5, and %i6 and cook until softened. Add %i1 and cook, breaking it up, until browned and no longer pink.";
"recipe.tt_pastelles.step2.title" = "Cook the meat filling";
"recipe.tt_pastelles.step3.body" = "Add %i7, %i8, %i9, and %i10, then stir in %i11, %i12, %i13, and %i14. Simmer until the mixture is cohesive and the liquid is reduced, then remove from heat.";
"recipe.tt_pastelles.step3.title" = "Season and finish filling";
"recipe.tt_pastelles.step4.body" = "Spread the filling out to cool so it won’t melt the dough during assembly.";
"recipe.tt_pastelles.step4.title" = "Cool the filling";
"recipe.tt_pastelles.step5.body" = "Warm %i19 in a small saucepan, add %i18, and heat gently until the oil turns deep orange. Strain out the seeds and keep the colored oil.";
"recipe.tt_pastelles.step5.title" = "Make annatto oil";
"recipe.tt_pastelles.step6.body" = "Bring %i16 to a simmer in a heavy saucepan and stir in %i17 and the annatto oil.";
"recipe.tt_pastelles.step6.title" = "Start the dough base";
"recipe.tt_pastelles.step7.body" = "Whisk in %i15 gradually to avoid lumps, then switch to a spoon and cook while stirring until thick, smooth, and pulling away from the sides.";
"recipe.tt_pastelles.step7.title" = "Cook the cornmeal dough";
"recipe.tt_pastelles.step8.body" = "Arrange banana leaves on a work surface and keep the cooled filling nearby. Prepare kitchen twine for tying.";
"recipe.tt_pastelles.step8.title" = "Set up for wrapping";
"recipe.tt_pastelles.step9.body" = "Place a portion of dough on the center of a leaf and press into a flat round. Spoon filling into the middle, then fold the dough over to enclose the filling completely.";
"recipe.tt_pastelles.step9.title" = "Form and fill pastelles";
