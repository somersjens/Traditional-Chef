"recipe.ru_pelmeni.drink.body" = "A crisp dry white or light red can work alongside buttery pelmeni, but many prefer tea or a small shot of vodka. Non-alcoholic pairing: hot black tea or sparkling water.";
"recipe.ru_pelmeni.drink.summary" = "White wine";
"recipe.ru_pelmeni.info" = "Pelmeni are classic Russian meat dumplings made from a simple flour-and-water dough rolled thin and filled with a seasoned mixture of minced meats and onion, then boiled until tender. They are traditionally served hot with butter and a spoon of sour cream, making them a staple comfort food across Russia.";
"recipe.ru_pelmeni.info.summary" = "Russian meat dumplings";
"recipe.ru_pelmeni.name" = "Pelmeni";
"recipe.ru_pelmeni.step1.body" = "Combine %i1 and %i4, add %i3 and %i2, and mix into a firm dough. Knead until smooth, then cover and rest.";
"recipe.ru_pelmeni.step1.title" = "Make the dough";
"recipe.ru_pelmeni.step2.body" = "Let the dough rest so it relaxes and rolls thinly without shrinking.";
"recipe.ru_pelmeni.step2.title" = "Rest the dough";
"recipe.ru_pelmeni.step3.body" = "Finely grate or mince %i7 and mix it with %i5, %i6, %i9, and %i8 until cohesive.";
"recipe.ru_pelmeni.step3.title" = "Make the filling";
"recipe.ru_pelmeni.step4.body" = "Roll the dough thin and cut rounds. Place filling in each round, fold to a half-moon, seal well, then join the ends to form pelmeni. Keep covered so they do not dry out.";
"recipe.ru_pelmeni.step4.title" = "Form the pelmeni";
"recipe.ru_pelmeni.step5.body" = "Bring %i12 to a boil, season it with %i13, then add pelmeni in batches. Stir so they do not stick and cook until they float and are cooked through.";
"recipe.ru_pelmeni.step5.title" = "Boil";
"recipe.ru_pelmeni.step6.body" = "Drain with a slotted spoon, toss with %i10, and serve immediately with %i11.";
"recipe.ru_pelmeni.step6.title" = "Serve";
