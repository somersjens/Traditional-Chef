"recipe.cn_songshu_guiyu.drink.body" = "A dry Riesling or light sparkling wine pairs well with the sweet-sour glaze and delicate fish, while hot green tea is a classic non-alcoholic pairing that refreshes the palate and balances the fried richness.";
"recipe.cn_songshu_guiyu.drink.summary" = "White wine (Riesling)";
"recipe.cn_songshu_guiyu.info" = "Songshu guiyu is a classic Jiangsu banquet dish, especially associated with Suzhou cuisine, made by scoring mandarin fish into a squirrel-like shape, coating it, deep-frying until crisp, and dressing it with a glossy sweet-and-sour sauce with peas and bamboo shoots. It is traditionally served as a festive shared centerpiece, prized for its dramatic presentation, crisp texture, and bright sauce.";
"recipe.cn_songshu_guiyu.info.summary" = "Squirrel fish banquet dish";
"recipe.cn_songshu_guiyu.name" = "Squirrel fish";
"recipe.cn_songshu_guiyu.step1.body" = "Scale and clean the %i1, remove the backbone while keeping head and tail attached, then open the flesh and score it crosswise and lengthwise to create the traditional squirrel pattern without cutting through the skin.";
"recipe.cn_songshu_guiyu.step1.title" = "Prepare and butterfly the fish";
"recipe.cn_songshu_guiyu.step10.body" = "Stir the slurry again, pour it into the boiling sauce while stirring, and cook until the sauce becomes glossy and lightly thickened.";
"recipe.cn_songshu_guiyu.step10.title" = "Thicken the sauce";
"recipe.cn_songshu_guiyu.step11.body" = "Spoon the hot sweet-and-sour sauce evenly over the fried fish so the shape remains visible, and serve immediately while crisp.";
"recipe.cn_songshu_guiyu.step11.title" = "Sauce and serve";
"recipe.cn_songshu_guiyu.step2.body" = "Rub the fish evenly with %i2, %i3, and %i4, working seasoning into the scored flesh, and let it stand briefly.";
"recipe.cn_songshu_guiyu.step2.title" = "Season the fish";
"recipe.cn_songshu_guiyu.step3.body" = "Cut the %i17 into small dice, mince the %i19 and %i20, and have the %i18 ready for the sweet-and-sour sauce.";
"recipe.cn_songshu_guiyu.step3.title" = "Prepare sauce ingredients";
"recipe.cn_songshu_guiyu.step4.body" = "Combine most of the %i5 with %i6 for dredging, then mix the remaining cornstarch with %i7 and %i8 into a smooth slurry for thickening the sauce.";
"recipe.cn_songshu_guiyu.step4.title" = "Mix coating and slurry";
"recipe.cn_songshu_guiyu.step5.body" = "Dust the fish thoroughly in the dry coating, making sure the scored cuts are opened and coated so the flesh fans out during frying.";
"recipe.cn_songshu_guiyu.step5.title" = "Coat the fish";
"recipe.cn_songshu_guiyu.step6.body" = "Heat the %i9 in a wok for deep-frying until ready, keeping enough depth to fry the shaped fish evenly.";
"recipe.cn_songshu_guiyu.step6.title" = "Heat the frying oil";
"recipe.cn_songshu_guiyu.step7.body" = "Hold the fish so the scored flesh spreads, fry briefly to set the squirrel shape, then lower it fully into the oil and fry until golden, crisp, and cooked through, including the head and tail.";
"recipe.cn_songshu_guiyu.step7.title" = "Deep-fry the fish to shape";
"recipe.cn_songshu_guiyu.step8.body" = "Lift out the fish and drain well, then place it on a serving platter in the traditional upright presentation.";
"recipe.cn_songshu_guiyu.step8.title" = "Drain the fish";
"recipe.cn_songshu_guiyu.step9.body" = "Pour off most of the oil from the wok, add a little %i16, stir-fry ginger and garlic, then add bamboo shoots and peas, followed by %i10, %i11, %i12, %i13, and %i14, and bring to a boil.";
"recipe.cn_songshu_guiyu.step9.title" = "Cook the sweet and sour sauce";
