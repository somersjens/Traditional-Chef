"recipe.lb_tabbouleh.drink.summary" = "White wine (Sauvignon)";
"recipe.lb_tabbouleh.info" = "Lebanese tabbouleh is a bright parsley-forward salad with mint, tomatoes, and onion, lightly bound with fine bulgur and dressed with plenty of lemon juice and olive oil. It is a cornerstone mezze served chilled or at cool room temperature, traditionally scooped with romaine leaves and enjoyed alongside other Lebanese dishes.";
"recipe.lb_tabbouleh.info.summary" = "Parsley-led herb salad";
"recipe.lb_tabbouleh.name" = "Tabbouleh";
"recipe.lb_tabbouleh.step1.body" = "Rinse the %i5, drain well, then soak it briefly in %i6 until softened. Squeeze out any excess liquid so the salad stays light.";
"recipe.lb_tabbouleh.step1.title" = "Soften the bulgur";
"recipe.lb_tabbouleh.step2.body" = "Wash and dry the %i1 and %i2 thoroughly, then chop very finely. Dice the %i3 small and finely slice the %i4.";
"recipe.lb_tabbouleh.step2.title" = "Prep herbs and vegetables";
"recipe.lb_tabbouleh.step3.body" = "In a large bowl, mix the chopped herbs with the tomatoes, green onions, and softened bulgur.";
"recipe.lb_tabbouleh.step3.title" = "Combine";
"recipe.lb_tabbouleh.step4.body" = "Add %i8 and drizzle in %i7, then toss thoroughly until evenly coated and glossy.";
"recipe.lb_tabbouleh.step4.title" = "Dress";
"recipe.lb_tabbouleh.step5.body" = "Arrange %i9 leaves on a platter and mound the tabbouleh alongside. Serve immediately while fresh.";
