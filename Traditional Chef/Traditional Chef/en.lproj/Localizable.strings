"recipe.mm_kyaukkyaw.drink.body" = "Kyauk kyaw is usually served with tea rather than wine, and plain green tea balances its sweetness well. Non-alcoholic pairing: hot Burmese green tea or chilled jasmine tea.";
"recipe.mm_kyaukkyaw.drink.summary" = "Green tea";
"recipe.mm_kyaukkyaw.info" = "Kyauk kyaw is a traditional Myanmar agar jelly dessert, commonly made in layered form with a coconut milk layer and a lightly scented clear layer, then chilled and cut into pieces. It is served cold as a refreshing sweet at home and on festive tables, especially in warm weather.";
"recipe.mm_kyaukkyaw.info.summary" = "Layered agar jelly";
"recipe.mm_kyaukkyaw.name" = "Kyauk kyaw";
"recipe.mm_kyaukkyaw.step1.body" = "Lightly rinse the tray and trim the %i4 into shorter lengths so they fit in the pot.";
"recipe.mm_kyaukkyaw.step1.title" = "Prepare the mold and pandan";
"recipe.mm_kyaukkyaw.step2.body" = "Combine the %i1, %i2, and %i3 in a saucepan and whisk well before heating so the agar disperses evenly.";
"recipe.mm_kyaukkyaw.step2.title" = "Dissolve the agar and sugar";
"recipe.mm_kyaukkyaw.step3.body" = "Add the pandan leaves and bring the mixture to a gentle boil, stirring until the agar fully dissolves and the liquid is clear.";
"recipe.mm_kyaukkyaw.step3.title" = "Cook the agar base with pandan";
"recipe.mm_kyaukkyaw.step4.body" = "Remove the pandan leaves and strain the hot agar mixture to ensure a smooth texture.";
"recipe.mm_kyaukkyaw.step4.title" = "Strain the base";
"recipe.mm_kyaukkyaw.step5.body" = "Pour about half of the hot agar base into the tray to form the first layer and leave it to begin setting.";
"recipe.mm_kyaukkyaw.step5.title" = "Pour the clear layer";
"recipe.mm_kyaukkyaw.step6.body" = "Return the remaining agar base to low heat, stir in the %i5 and %i6, and heat gently until smooth without boiling hard.";
"recipe.mm_kyaukkyaw.step6.title" = "Make the coconut layer";
"recipe.mm_kyaukkyaw.step7.body" = "When the first layer is set enough to hold, pour the coconut layer gently over it to keep the layers distinct.";
"recipe.mm_kyaukkyaw.step7.title" = "Pour the coconut layer";
"recipe.mm_kyaukkyaw.step8.body" = "Cool the tray, then refrigerate until the jelly is fully set and firm enough to cut cleanly.";
"recipe.mm_kyaukkyaw.step8.title" = "Chill until firm";
"recipe.mm_kyaukkyaw.step9.body" = "Unmold if needed, cut the kyauk kyaw into diamonds or squares, and serve chilled.";
"recipe.mm_kyaukkyaw.step9.title" = "Cut and serve";
