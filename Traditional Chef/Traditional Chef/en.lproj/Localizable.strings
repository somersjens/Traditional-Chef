"recipe.pe_mazamorra_morada.drink.body" = "Pair with a lightly sweet Moscato or a floral Gewürztraminer that echoes the warm spices and fruit. A mild amber ale can also work. For a non-alcoholic option, serve hot cinnamon tea or chilled chicha morada.";
"recipe.pe_mazamorra_morada.drink.summary" = "Dessert wine (Moscato)";
"recipe.pe_mazamorra_morada.info" = "Mazamorra Morada is a traditional Peruvian dessert made by simmering purple corn with pineapple peels, apple, cinnamon, and cloves to create a fragrant deep-purple infusion, then thickening it with sweet potato starch and finishing with fruit and lime. It is served cooled or at room temperature, often as part of the classic duo with arroz con leche.";
"recipe.pe_mazamorra_morada.info.summary" = "Purple corn pudding";
"recipe.pe_mazamorra_morada.name" = "Mazamorra morada";
"recipe.pe_mazamorra_morada.step1.body" = "Rinse the %i1. Peel and core the %i4, cut the %i5 into pieces, and remove the peel and core from the %i3, keeping them for the infusion.";
"recipe.pe_mazamorra_morada.step1.title" = "Prep the infusion ingredients";
"recipe.pe_mazamorra_morada.step2.body" = "Simmer the purple corn with %i2, pineapple peel and core, apple, quince, %i6, and %i7 until the liquid is deeply colored and fragrant.";
"recipe.pe_mazamorra_morada.step2.title" = "Simmer the purple corn";
"recipe.pe_mazamorra_morada.step3.body" = "Strain the liquid into a clean pot, pressing lightly to extract flavor, and discard the solids.";
"recipe.pe_mazamorra_morada.step3.title" = "Strain the infusion";
"recipe.pe_mazamorra_morada.step4.body" = "Add %i8 and stir until dissolved. Add the diced %i11 and chopped %i12 and bring back to a gentle simmer.";
"recipe.pe_mazamorra_morada.step4.title" = "Sweeten and add fruit";
"recipe.pe_mazamorra_morada.step5.body" = "Whisk %i9 with %i10 until completely smooth with no lumps.";
"recipe.pe_mazamorra_morada.step5.title" = "Make the starch slurry";
"recipe.pe_mazamorra_morada.step6.body" = "While the pot is simmering, whisk in the slurry in a steady stream and keep stirring until the pudding thickens and turns glossy.";
"recipe.pe_mazamorra_morada.step6.title" = "Thicken the mazamorra";
"recipe.pe_mazamorra_morada.step7.body" = "Stir in %i13 and simmer briefly so the flavor rounds out without thinning.";
"recipe.pe_mazamorra_morada.step7.title" = "Finish with lime";
"recipe.pe_mazamorra_morada.step8.body" = "Pour into a serving bowl and let it cool until fully set. Serve at room temperature or chilled.";
"recipe.pe_mazamorra_morada.step8.title" = "Cool to set";
