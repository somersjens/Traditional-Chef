"recipe.cn_chun_juan.step1.title" = "Soak dried ingredients";
"recipe.cn_chun_juan.step10.body" = "Fry the spring rolls in batches, turning as needed, until evenly golden and crisp, then lift out and drain well.";
"recipe.cn_chun_juan.step10.title" = "Fry until golden";
