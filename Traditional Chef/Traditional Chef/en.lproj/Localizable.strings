"recipe.ec_locro_de_papa.drink.body" = "A fresh white wine such as unoaked Chardonnay pairs well with the creamy potato and cheese texture without overpowering the soup. A light lager also works well. For a non-alcoholic option, serve sparkling water with lime.";
"recipe.ec_locro_de_papa.drink.summary" = "White wine (Chardonnay)";
"recipe.ec_locro_de_papa.info" = "Locro de Papa is a traditional Ecuadorian highland potato and cheese soup, built on a refrito of onion, garlic, cumin, and achiote. It is served hot with avocado and ají, and is especially associated with home lunches and cool weather.";
"recipe.ec_locro_de_papa.info.summary" = "Highland potato soup";
"recipe.ec_locro_de_papa.name" = "Locro de papa";
"recipe.ec_locro_de_papa.step1.body" = "Peel and cut %i1, finely chop %i3, mince %i4, chop %i10, slice %i12, and keep %i9 ready for the soup. Rinse %i13 and %i14 for the ají.";
"recipe.ec_locro_de_papa.step1.title" = "Prepare the ingredients";
"recipe.ec_locro_de_papa.step2.body" = "Bring %i18 to a boil in the small saucepan. Add the tree tomatoes and simmer until the skins loosen, then drain and peel them.";
"recipe.ec_locro_de_papa.step2.title" = "Soften the tree tomatoes";
"recipe.ec_locro_de_papa.step3.body" = "Blend the peeled tree tomatoes with the hot peppers, %i15, %i16, %i17, %i19, and water until smooth. Set the ají aside for serving.";
"recipe.ec_locro_de_papa.step3.title" = "Make the ají";
"recipe.ec_locro_de_papa.step4.body" = "Heat %i2 in the large pot. Cook the onion, then add the garlic, %i5, and %i6, stirring until the base is fragrant and softened.";
"recipe.ec_locro_de_papa.step4.title" = "Start the refrito";
"recipe.ec_locro_de_papa.step5.body" = "Add all the potatoes to the pot and stir them through the refrito. Pour in %i7, season with %i11, and bring the soup to a boil.";
"recipe.ec_locro_de_papa.step5.title" = "Add potatoes and water";
"recipe.ec_locro_de_papa.step6.body" = "Lower the heat and simmer until the potatoes are very tender and some pieces begin to break down naturally into the broth.";
"recipe.ec_locro_de_papa.step6.title" = "Simmer the soup";
"recipe.ec_locro_de_papa.step7.body" = "Mash part of the potatoes directly in the pot, leaving the rest in pieces. Stir in %i8 and cheese until the soup becomes creamy and the cheese is fully incorporated.";
"recipe.ec_locro_de_papa.step7.title" = "Create the creamy texture";
"recipe.ec_locro_de_papa.step8.body" = "Stir in most of the cilantro and taste for salt. Let the soup settle briefly so the texture becomes smooth and rich.";
"recipe.ec_locro_de_papa.step8.title" = "Finish the locro";
"recipe.ec_locro_de_papa.step9.body" = "Ladle the locro into bowls and top each serving with avocado and the remaining cilantro. Serve the ají alongside.";
"recipe.ec_locro_de_papa.step9.title" = "Serve traditionally";
