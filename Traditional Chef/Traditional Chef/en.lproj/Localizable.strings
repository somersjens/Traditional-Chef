"recipe.sy_fatteh.step6.title" = "Toast nuts in ghee";
"recipe.sy_fatteh.step7.body" = "Spread the crisp bread in a serving dish, spoon the hot chickpeas over it, then immediately cover with the yogurt sauce.";
"recipe.sy_fatteh.step7.title" = "Assemble the fatteh";
"recipe.sy_fatteh.step8.body" = "Drizzle the hot ghee over the top and scatter the toasted pine nuts. Serve right away while the bread is still crisp underneath.";
"recipe.sy_fatteh.step8.title" = "Finish and serve";
