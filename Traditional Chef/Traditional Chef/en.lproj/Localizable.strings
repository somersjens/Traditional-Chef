"recipe.es_cocido_madrileno.step2.title" = "Start the broth with meats";
"recipe.es_cocido_madrileno.step3.body" = "Keep the pot at a very gentle simmer so the broth stays clear and rich.";
"recipe.es_cocido_madrileno.step3.title" = "Simmer to build flavor";
"recipe.es_cocido_madrileno.step4.body" = "Drain the soaked chickpeas and add them to the pot. Return to a gentle simmer.";
"recipe.es_cocido_madrileno.step4.title" = "Add the chickpeas";
"recipe.es_cocido_madrileno.step5.body" = "Simmer gently until the chickpeas are close to tender, skimming and topping up with water if needed to keep ingredients covered.";
"recipe.es_cocido_madrileno.step5.title" = "Cook chickpeas until nearly tender";
"recipe.es_cocido_madrileno.step6.body" = "Add %i10, %i11, and %i12 to the pot and continue simmering gently.";
"recipe.es_cocido_madrileno.step6.title" = "Add vegetables";
"recipe.es_cocido_madrileno.step7.body" = "Add %i6 and %i7 and simmer gently until the vegetables are tender and the meats are fully cooked through.";
"recipe.es_cocido_madrileno.step7.title" = "Finish simmering and add sausages";
"recipe.es_cocido_madrileno.step8.body" = "Boil %i13 in water until tender, then drain well.";
"recipe.es_cocido_madrileno.step8.title" = "Cook the cabbage";
"recipe.es_cocido_madrileno.step9.body" = "Warm %i15 in a skillet, add sliced %i16, and cook until fragrant. Add the cabbage and %i17 and sauté briefly until well coated and hot.";
"recipe.es_cocido_madrileno.step9.title" = "Sauté the cabbage";
