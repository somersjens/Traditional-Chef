"recipe.ec_fanesca.drink.body" = "A fresh medium-bodied white wine such as unoaked Chardonnay works well with the creamy soup and salted cod. A pale lager is also a good match. For a non-alcoholic option, serve sparkling water with lime.";
"recipe.ec_fanesca.drink.summary" = "White wine (Chardonnay)";
"recipe.ec_fanesca.info" = "Fanesca is Ecuador’s traditional Holy Week soup, a rich and festive preparation built from sambo, zapallo, milk, salted cod, and a wide assortment of tender grains and legumes. It is served hot as a substantial midday meal and is traditionally finished with classic garnishes that make the dish both ceremonial and deeply communal.";
"recipe.ec_fanesca.info.summary" = "Holy Week grain soup";
"recipe.ec_fanesca.name" = "Fanesca";
"recipe.ec_fanesca.step1.body" = "Peel and cut %i1 and %i2, shred %i3, finely chop %i4, mince %i5, crumble %i11, and chop %i25. Keep the cooked grains and legumes ready to add later.";
"recipe.ec_fanesca.step1.title" = "Prepare the vegetables";
"recipe.ec_fanesca.step10.body" = "Slice %i24 and fry them until golden and caramelized. Drain well and reserve for garnish.";
"recipe.ec_fanesca.step10.title" = "Fry the plantain";
"recipe.ec_fanesca.step11.body" = "Ladle the fanesca into bowls and finish with egg, fried plantain, parsley, extra cheese, and empanaditas.";
"recipe.ec_fanesca.step11.title" = "Serve traditionally";
"recipe.ec_fanesca.step2.body" = "Place %i22 in the saucepan with %i8, bring it to a gentle simmer, then drain. Repeat with fresh water until the fish is seasoned but no longer overly salty, then flake it and reserve part of the cooking liquid.";
"recipe.ec_fanesca.step2.title" = "Desalt the cod";
"recipe.ec_fanesca.step3.body" = "Cover %i23 with water, bring to a boil, then cook until hard-boiled. Cool, peel, and cut them into slices for garnish.";
"recipe.ec_fanesca.step3.title" = "Cook the eggs";
"recipe.ec_fanesca.step4.body" = "Heat %i6 in the large pot. Cook the onion and garlic until soft, then add %i7 and stir until fragrant.";
"recipe.ec_fanesca.step4.title" = "Start the refrito";
"recipe.ec_fanesca.step5.body" = "Add the sambo, zapallo, cabbage, and water to the pot. Simmer until the vegetables are very tender and beginning to fall apart.";
"recipe.ec_fanesca.step5.title" = "Cook the squash base";
"recipe.ec_fanesca.step6.body" = "Mash the softened vegetables directly in the pot to form a thick base with some texture. Add %i9, %i10, %i21, and part of the cheese, stirring until fully combined.";
"recipe.ec_fanesca.step6.title" = "Mash and enrich the soup";
"recipe.ec_fanesca.step7.body" = "Stir in %i13, %i14, %i15, %i16, %i17, %i18, %i19, and %i20. Add a little of the cod cooking liquid, then simmer gently so the flavors come together.";
"recipe.ec_fanesca.step7.title" = "Add the grains and legumes";
"recipe.ec_fanesca.step8.body" = "Add the flaked cod and cook gently until the fish is fully integrated into the soup. Taste and adjust with salt only if needed.";
"recipe.ec_fanesca.step8.title" = "Finish with cod";
"recipe.ec_fanesca.step9.body" = "Mix %i26, %i27, %i28, and %i29 into a smooth dough. Fill with %i30, shape small empanaditas, and fry until golden. Set aside.";
"recipe.ec_fanesca.step9.title" = "Make the empanaditas";
