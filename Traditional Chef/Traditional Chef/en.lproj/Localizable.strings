"recipe.cu_arroz_con_pollo.drink.body" = "Pair with a dry Spanish-style white such as Albariño or a crisp Sauvignon Blanc to brighten the savory rice and chicken. For a non-alcoholic option, serve sparkling water with lime or a chilled citrus agua fresca.";
"recipe.cu_arroz_con_pollo.drink.summary" = "White wine (Albariño)";
"recipe.cu_arroz_con_pollo.info" = "Cuban arroz con pollo is a traditional one-pot dish where chicken is browned, then simmered with rice in a flavorful sofrito base of onion, pepper, garlic, tomato, and warm spices, often tinted with achiote and finished with peas, pimientos, and olives. It is served hot as a family meal, commonly alongside crisp tostones for contrast.";
"recipe.cu_arroz_con_pollo.info.summary" = "Cuban one-pot chicken rice";
"recipe.cu_arroz_con_pollo.name" = "Arroz con pollo";
"recipe.cu_arroz_con_pollo.step1.body" = "Chop the %i3 and %i4 finely and crush the %i5. Rinse the %i7 until the water runs clearer, then drain well.";
"recipe.cu_arroz_con_pollo.step1.title" = "Prep the sofrito ingredients";
"recipe.cu_arroz_con_pollo.step10.body" = "Fluff the arroz con pollo gently and transfer to a platter. Serve hot with the tostones on the side.";
"recipe.cu_arroz_con_pollo.step10.title" = "Serve";
"recipe.cu_arroz_con_pollo.step2.body" = "Heat %i2 in a large pot and brown the %i1 well on all sides. Remove the chicken to a plate.";
"recipe.cu_arroz_con_pollo.step2.title" = "Brown the chicken";
"recipe.cu_arroz_con_pollo.step3.body" = "In the same pot, cook the onion and bell pepper until softened, then add the garlic and cook briefly until fragrant. Stir in %i6, %i11, %i12, %i14, %i15, %i16, and %i13.";
"recipe.cu_arroz_con_pollo.step3.title" = "Cook the sofrito";
"recipe.cu_arroz_con_pollo.step4.body" = "Pour in %i8 and scrape up any browned bits from the bottom of the pot, letting it simmer briefly.";
"recipe.cu_arroz_con_pollo.step4.title" = "Deglaze";
"recipe.cu_arroz_con_pollo.step5.body" = "Return the chicken to the pot and add the rice. Stir to coat, then add %i9 and dissolve the %i10. Bring to a steady simmer, cover, and cook until the rice is nearly tender and the liquid is mostly absorbed.";
"recipe.cu_arroz_con_pollo.step5.title" = "Simmer the rice and chicken";
"recipe.cu_arroz_con_pollo.step6.body" = "Stir in %i17, %i18, and %i19, then cover and cook until the rice is fully tender and the chicken is cooked through.";
"recipe.cu_arroz_con_pollo.step6.title" = "Finish with vegetables";
"recipe.cu_arroz_con_pollo.step7.body" = "Turn off the heat and let the pot rest covered so the rice finishes steaming and sets.";
"recipe.cu_arroz_con_pollo.step7.title" = "Rest the pot";
"recipe.cu_arroz_con_pollo.step8.body" = "Peel the %i20 and cut into thick slices. Heat the %i21 in a pan and fry the slices until lightly golden and tender, then lift out to drain.";
"recipe.cu_arroz_con_pollo.step8.title" = "First fry the plantains";
"recipe.cu_arroz_con_pollo.step9.body" = "Smash each fried plantain slice into a flat round, then refry until crisp and deeply golden. Drain and season with %i22.";
"recipe.cu_arroz_con_pollo.step9.title" = "Smash and refry";
