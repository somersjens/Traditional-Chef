"recipe.hu_paprikas_csirke.step1.title" = "Prep the ingredients";
"recipe.hu_paprikas_csirke.step2.body" = "Melt %i3 in a pot and cook the onions slowly until soft and translucent, stirring so they do not brown.";
"recipe.hu_paprikas_csirke.step2.title" = "Sweat the onions";
"recipe.hu_paprikas_csirke.step3.body" = "Take the pot off the heat, stir in %i4, then add a splash of %i10 and stir quickly so the paprika does not scorch.";
"recipe.hu_paprikas_csirke.step3.title" = "Bloom the paprika";
"recipe.hu_paprikas_csirke.step4.body" = "Return to the heat, add the chicken and garlic, and stir to coat. Add the tomatoes and peppers and season with %i8 and %i9.";
"recipe.hu_paprikas_csirke.step4.title" = "Add the chicken and aromatics";
"recipe.hu_paprikas_csirke.step5.body" = "Add water, cover, and braise gently until the chicken is tender, turning the pieces occasionally and keeping the liquid below a boil.";
"recipe.hu_paprikas_csirke.step5.title" = "Braise the chicken";
"recipe.hu_paprikas_csirke.step6.body" = "Mix %i13 and %i16, add %i14, then add %i15 gradually to make a thick, sticky batter.";
"recipe.hu_paprikas_csirke.step6.title" = "Mix the nokedli batter";
"recipe.hu_paprikas_csirke.step7.body" = "Bring a large pot of water to a boil, season it with %i18, and press or grate the batter into the water. Cook until the dumplings float and are tender, then lift them out with a slotted spoon.";
"recipe.hu_paprikas_csirke.step7.title" = "Cook the nokedli";
