"recipe.hu_toltott_kaposzta.step3.title" = "Mix the filling";
"recipe.hu_toltott_kaposzta.step4.body" = "Place filling on each leaf, fold in the sides, and roll tightly. Use smaller leaves to patch any gaps.";
