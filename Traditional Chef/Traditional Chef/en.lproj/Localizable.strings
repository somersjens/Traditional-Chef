"recipe.th_sangkaya_fak_thong.drink.body" = "A lightly sweet late-harvest white wine can match the coconut and palm sugar richness, but this dessert is most traditionally served with hot unsweetened tea. For a non-alcoholic option, serve jasmine tea or pandan tea.";
"recipe.th_sangkaya_fak_thong.drink.summary" = "Tea";
"recipe.th_sangkaya_fak_thong.info" = "Sangkaya Fak Thong is a traditional Thai dessert of a whole pumpkin filled with sweet coconut egg custard and steamed until both the pumpkin and custard are set. It is cooled, sliced, and served in wedges or pieces at room temperature, often for markets, family gatherings, and festive occasions.";
"recipe.th_sangkaya_fak_thong.info.summary" = "Pumpkin coconut custard";
"recipe.th_sangkaya_fak_thong.name" = "Pumpkin custard";
"recipe.th_sangkaya_fak_thong.step1.body" = "Wash the %i1, cut a lid around the stem, and remove the seeds and fibers while keeping the shell intact. Trim the base slightly only if needed so it stands upright.";
"recipe.th_sangkaya_fak_thong.step1.title" = "Prepare the pumpkin";
"recipe.th_sangkaya_fak_thong.step2.body" = "Tie the %i6 into knots and warm them gently with the %i3 until fragrant, then remove from the heat and let it cool slightly.";
"recipe.th_sangkaya_fak_thong.step2.title" = "Prepare pandan coconut milk";
"recipe.th_sangkaya_fak_thong.step3.body" = "Combine the %i2, %i4, %i5, and the pandan-scented coconut milk in a mixing bowl and whisk until the sugar dissolves and the mixture is smooth.";
"recipe.th_sangkaya_fak_thong.step3.title" = "Make the custard mixture";
"recipe.th_sangkaya_fak_thong.step4.body" = "Strain the custard mixture through a fine sieve to remove foam and any solids for a smooth texture.";
"recipe.th_sangkaya_fak_thong.step4.title" = "Strain the custard";
"recipe.th_sangkaya_fak_thong.step5.body" = "Place the hollowed pumpkin upright in a heatproof bowl and pour in the custard mixture, leaving a little space at the top.";
"recipe.th_sangkaya_fak_thong.step5.title" = "Fill the pumpkin";
"recipe.th_sangkaya_fak_thong.step6.body" = "Add steaming %i7 to the steamer base and bring it to a steady boil.";
"recipe.th_sangkaya_fak_thong.step6.title" = "Boil steaming water";
"recipe.th_sangkaya_fak_thong.step7.body" = "Place the filled pumpkin in the steamer and steam gently until the pumpkin is tender and the custard is fully set in the center. Keep the heat steady and avoid hard boiling.";
"recipe.th_sangkaya_fak_thong.step7.title" = "Steam the pumpkin custard";
"recipe.th_sangkaya_fak_thong.step8.body" = "Remove the pumpkin carefully and let it cool completely until the custard firms for clean slicing.";
"recipe.th_sangkaya_fak_thong.step8.title" = "Cool completely";
"recipe.th_sangkaya_fak_thong.step9.body" = "Cut the sangkaya fak thong into wedges or pieces and serve at room temperature.";
"recipe.th_sangkaya_fak_thong.step9.title" = "Slice and serve";
