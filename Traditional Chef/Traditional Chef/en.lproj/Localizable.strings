"recipe.kr_galbi.step1.title" = "Prepare the ribs";
"recipe.kr_galbi.step10.body" = "Grill the remaining ribs in the same way, avoiding overcrowding so the meat sears instead of steams.";
"recipe.kr_galbi.step10.title" = "Grill the remaining ribs";
