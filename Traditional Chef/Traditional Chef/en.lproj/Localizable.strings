"recipe.ps_qidra.drink.body" = "A medium-bodied red wine such as Syrah or Cinsault pairs well with the rich lamb, warm spices, and buttery rice. For a non-alcoholic pairing, serve plain yogurt or cold mint tea.";
"recipe.ps_qidra.drink.summary" = "Red wine (Syrah)";
"recipe.ps_qidra.info" = "Qidra is a traditional Palestinian main dish of lamb, rice, chickpeas, garlic, and warming spices cooked together until the rice is deeply fragrant and the meat is tender. It is closely associated with festive gatherings and communal meals, especially in Hebron and Gaza, and is traditionally served hot with yogurt on the side.";
"recipe.ps_qidra.info.summary" = "Spiced lamb rice";
"recipe.ps_qidra.name" = "Qidra";
"recipe.ps_qidra.step1.body" = "Heat part of %i5 in the heavy pot and brown %i1 well on several sides to build a deep savory base.";
"recipe.ps_qidra.step1.title" = "Brown the lamb";
"recipe.ps_qidra.step2.body" = "Add %i2 and %i3 and cook until the onions soften slightly and become fragrant around the lamb.";
"recipe.ps_qidra.step2.title" = "Add the aromatics";
"recipe.ps_qidra.step3.body" = "Add %i4, %i6, %i7, and %i8, then bring to a boil, skim, and simmer until the lamb is tender and the broth is flavorful.";
"recipe.ps_qidra.step3.title" = "Simmer the lamb";
"recipe.ps_qidra.step4.body" = "Rinse %i9 until the water runs mostly clear, then drain it well and mix it with %i10, %i11, %i12, %i13, and the remaining salt.";
"recipe.ps_qidra.step4.title" = "Prepare the rice";
"recipe.ps_qidra.step5.body" = "Toast %i14 in a small amount of the remaining clarified butter until golden, then set them aside for serving.";
"recipe.ps_qidra.step5.title" = "Toast the almonds";
"recipe.ps_qidra.step6.body" = "Lift the lamb from the broth, measure enough broth for cooking the rice, then return the lamb to the pot and spread the rice evenly around and over it.";
"recipe.ps_qidra.step6.title" = "Combine the rice and lamb";
"recipe.ps_qidra.step7.body" = "Pour in the hot broth, add the rest of the clarified butter, bring the pot to a gentle boil, then cover and cook over low heat until the rice is tender and the liquid is absorbed.";
"recipe.ps_qidra.step7.title" = "Cook the qidra";
"recipe.ps_qidra.step8.body" = "Remove the pot from the heat and let the qidra rest covered so the rice finishes steaming and the layers settle.";
"recipe.ps_qidra.step8.title" = "Rest the pot";
"recipe.ps_qidra.step9.body" = "Spoon the rice onto a serving platter, arrange the lamb on top, scatter over the almonds, and serve immediately with %i15 on the side.";
"recipe.ps_qidra.step9.title" = "Turn and serve";
