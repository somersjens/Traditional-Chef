"recipe.tr_patlican_ezmesi.drink.body" = "A crisp Sauvignon Blanc or dry Riesling complements the smoky eggplant and bright lemon, while a light rosé also works. For a non-alcoholic option, serve ayran or sparkling water with lemon.";
"recipe.tr_patlican_ezmesi.drink.summary" = "White wine (Sauvignon)";
"recipe.tr_patlican_ezmesi.info" = "Patlıcan Ezmesi is a traditional Turkish meze of fire-roasted eggplant finely chopped and mixed with garlic, lemon, olive oil, and parsley, served as a smoky salad to scoop with bread. It is commonly part of a mezze spread and pairs especially well with grilled meats and simple flatbreads.";
"recipe.tr_patlican_ezmesi.info.summary" = "Smoky eggplant salad";
"recipe.tr_patlican_ezmesi.name" = "Eggplant dip";
