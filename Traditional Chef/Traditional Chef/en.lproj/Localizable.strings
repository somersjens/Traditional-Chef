"recipe.es_fabada_asturiana.drink.body" = "Pair with a medium-bodied Spanish red such as Rioja Crianza to stand up to the smoky compango and creamy beans. In Asturias, dry cider is also a classic accompaniment. Non-alcoholic option: sparkling water with lemon.";
"recipe.es_fabada_asturiana.drink.summary" = "Red wine (Rioja Crianza)";
"recipe.es_fabada_asturiana.info" = "Fabada asturiana is Asturias’ signature slow-simmered stew of large white fabes beans cooked until creamy with the traditional compango of smoked chorizo, morcilla, cured lacón, and pork belly. Gently flavored with bay leaf and a touch of saffron, it’s cooked low and slow until the broth turns rich and silky and the beans are tender without breaking, then served hot with crusty bread as a hearty northern Spanish classic.";
"recipe.es_fabada_asturiana.info.summary" = "Asturian bean pot";
"recipe.es_fabada_asturiana.name" = "Fabada";
"recipe.es_fabada_asturiana.step1.body" = "Rinse the %i1 and cover with plenty of %i2 in a bowl. Soak until fully hydrated.";
"recipe.es_fabada_asturiana.step1.title" = "Soak the beans";
"recipe.es_fabada_asturiana.step2.body" = "Drain the beans and place them in a heavy pot with %i3 and %i6. Cover with water and bring up slowly to a gentle simmer.";
"recipe.es_fabada_asturiana.step2.title" = "Start the pot";
"recipe.es_fabada_asturiana.step3.body" = "Skim any foam, then add %i8, %i9, %i10, and %i11. Keep the heat very low so the beans simmer gently without breaking.";
"recipe.es_fabada_asturiana.step3.title" = "Skim and add aromatics";
"recipe.es_fabada_asturiana.step4.body" = "Simmer gently, topping up with water as needed to keep everything covered, until the beans are nearly tender and the broth is turning creamy.";
"recipe.es_fabada_asturiana.step4.title" = "Slow-simmer until nearly tender";
"recipe.es_fabada_asturiana.step5.body" = "Add %i4 and %i5 and continue simmering gently so they flavor the stew without bursting.";
"recipe.es_fabada_asturiana.step5.title" = "Add the sausages";
"recipe.es_fabada_asturiana.step6.body" = "Continue simmering until the beans are fully tender and the broth is rich and silky. Season with %i12 and keep the heat gentle.";
"recipe.es_fabada_asturiana.step6.title" = "Finish cooking and season";
"recipe.es_fabada_asturiana.step7.body" = "Let the stew rest off the heat so the flavors meld and the broth settles. Serve hot with the meats and %i13.";
"recipe.es_fabada_asturiana.step7.title" = "Settle and serve";
