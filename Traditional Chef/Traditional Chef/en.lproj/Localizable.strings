"recipe.id_soto_betawi.step4.title" = "Fry the spice paste";
"recipe.id_soto_betawi.step5.body" = "Return the meats to the pot with fresh water, add the fried spice paste, galangal, lemongrass, %i13, %i14, %i15, %i16, %i17, %i18, and %i19, then simmer gently until tender.";
"recipe.id_soto_betawi.step5.title" = "Simmer the beef and tripe";
"recipe.id_soto_betawi.step6.body" = "Cut the %i23 into chunks and fry until golden and cooked through, then drain and set aside for garnish.";
"recipe.id_soto_betawi.step6.title" = "Fry the potatoes";
"recipe.id_soto_betawi.step7.body" = "Lower the heat and add %i20 and %i21, stirring gently until the broth is creamy and smooth. Do not boil hard.";
"recipe.id_soto_betawi.step7.title" = "Enrich the broth";
"recipe.id_soto_betawi.step8.body" = "Cook the %i25, %i26, %i27, and %i28 briefly in a little %i31 until softened, then crush with %i29 and %i30 into a coarse sambal.";
