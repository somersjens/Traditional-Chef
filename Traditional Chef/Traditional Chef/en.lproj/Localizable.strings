"recipe.ng_ofada_rice_and_ayamase.drink.body" = "A dry Riesling or crisp Chenin Blanc handles the heat and richness while staying refreshing against the peppery stew. If you prefer red, choose a light, low-tannin red served slightly chilled, such as Grenache. Non-alcoholic pairing: chilled zobo (hibiscus) or sparkling water with lime.";
"recipe.ng_ofada_rice_and_ayamase.drink.summary" = "White wine (Riesling)";
"recipe.ng_ofada_rice_and_ayamase.info" = "Ofada rice with ayamase (designer stew) is a Yoruba classic where local rice is thoroughly washed and cooked, then served with a dark green pepper stew made from green bell peppers and hot peppers cooked down in bleached palm oil with iru (fermented locust beans), crayfish, and assorted meats, finished with boiled eggs. It is a celebratory and restaurant-favorite main course in southwestern Nigeria, known for its bold aroma, deep palm-oil richness, and spicy heat.";
"recipe.ng_ofada_rice_and_ayamase.info.summary" = "Ofada rice with stew";
"recipe.ng_ofada_rice_and_ayamase.name" = "Ofada rice";
"recipe.ng_ofada_rice_and_ayamase.step1.body" = "Rinse the %i4, %i5, %i6, %i7, and %i8. Rinse the %i1 repeatedly, picking out any husk or grit, then drain.";
"recipe.ng_ofada_rice_and_ayamase.step1.title" = "Prep and rinse";
"recipe.ng_ofada_rice_and_ayamase.step10.body" = "Add the cooked meats and stockfish to the stew and simmer to coat them thoroughly, then add the boiled eggs and warm through gently.";
"recipe.ng_ofada_rice_and_ayamase.step10.title" = "Add meats and finish";
"recipe.ng_ofada_rice_and_ayamase.step11.body" = "Parboil the rinsed rice briefly in boiling %i2, drain, then rinse again until the water runs much clearer, and drain well.";
"recipe.ng_ofada_rice_and_ayamase.step11.title" = "Parboil and wash ofada rice";
"recipe.ng_ofada_rice_and_ayamase.step12.body" = "Add the washed rice to a pot with water and %i3, bring to a boil, then cover and cook on low heat until tender and the water is absorbed.";
"recipe.ng_ofada_rice_and_ayamase.step12.title" = "Cook the rice";
"recipe.ng_ofada_rice_and_ayamase.step13.body" = "Serve the ofada rice hot with ayamase stew on top, including meat pieces and eggs in each portion.";
"recipe.ng_ofada_rice_and_ayamase.step13.title" = "Serve";
"recipe.ng_ofada_rice_and_ayamase.step2.body" = "Boil the %i21 until hard, cool in water, peel, and set aside.";
"recipe.ng_ofada_rice_and_ayamase.step2.title" = "Boil the eggs";
"recipe.ng_ofada_rice_and_ayamase.step3.body" = "Add the meats, stockfish, %i10, %i11, and %i9 to a pot and simmer until tender and a flavorful stock forms.";
"recipe.ng_ofada_rice_and_ayamase.step3.title" = "Cook assorted meats";
"recipe.ng_ofada_rice_and_ayamase.step4.body" = "Add the smoked fish to the pot and simmer gently so it warms through and flavors the stock without breaking apart, then set the fish aside.";
"recipe.ng_ofada_rice_and_ayamase.step4.title" = "Warm smoked fish";
"recipe.ng_ofada_rice_and_ayamase.step5.body" = "Blend the %i12, %i13, %i14, and some %i15 with as little %i19 as needed to keep the blender moving, then set aside.";
"recipe.ng_ofada_rice_and_ayamase.step5.title" = "Blend green pepper mix";
"recipe.ng_ofada_rice_and_ayamase.step6.body" = "Heat %i16 in an uncovered pot over medium heat until it turns lighter and smells less raw, then let it cool slightly before continuing.";
"recipe.ng_ofada_rice_and_ayamase.step6.title" = "Bleach the palm oil";
"recipe.ng_ofada_rice_and_ayamase.step7.body" = "Return the pot to medium heat, add chopped onion, then add %i17 and stir until the aroma turns nutty and fragrant.";
"recipe.ng_ofada_rice_and_ayamase.step7.title" = "Start the stew base";
"recipe.ng_ofada_rice_and_ayamase.step8.body" = "Pour in the blended pepper mix and cook, stirring often, until it reduces, thickens, and the oil begins to separate on the surface.";
"recipe.ng_ofada_rice_and_ayamase.step8.title" = "Cook down the pepper mix";
"recipe.ng_ofada_rice_and_ayamase.step9.body" = "Stir in %i18 and %i20, then add some reserved meat stock to loosen the stew and cook until smooth and glossy.";
"recipe.ng_ofada_rice_and_ayamase.step9.title" = "Season and enrich";
