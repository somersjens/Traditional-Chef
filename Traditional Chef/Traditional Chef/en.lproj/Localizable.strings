"recipe.az_kufta_bozbash.step4.body" = "Mix %i8, %i9, finely grated %i10, %i11, %i12, and %i13 until evenly combined.";
"recipe.az_kufta_bozbash.step4.title" = "Make the meatball mixture";
"recipe.az_kufta_bozbash.step5.body" = "Divide the meat mixture into four large portions, place one %i14 in the center of each, and shape them into firm round meatballs.";
"recipe.az_kufta_bozbash.step5.title" = "Shape the kufta";
"recipe.az_kufta_bozbash.step6.body" = "Place the soaked chickpeas and sliced onions in a large pot with water and %i6, bring to a boil, and skim if needed.";
"recipe.az_kufta_bozbash.step6.title" = "Start the soup";
"recipe.az_kufta_bozbash.step7.body" = "Simmer the chickpeas until they are beginning to soften and the broth is flavorful.";
"recipe.az_kufta_bozbash.step7.title" = "Cook the chickpeas";
"recipe.az_kufta_bozbash.step8.body" = "Add the potatoes, grated tomatoes, and saffron infusion to the pot and return the broth to a gentle simmer.";
"recipe.az_kufta_bozbash.step8.title" = "Add the soup ingredients";
"recipe.az_kufta_bozbash.step9.body" = "Carefully lower the large meatballs into the broth one by one so they keep their shape.";
"recipe.az_kufta_bozbash.step9.title" = "Lower in the meatballs";
