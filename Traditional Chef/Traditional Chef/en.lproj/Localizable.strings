"recipe.cl_charquican.drink.body" = "Pair with a medium-bodied Chilean Carménère or a young Merlot that complements the savory mash and paprika notes. A dry rosé also works well. Non-alcoholic option: sparkling water with lemon or a lightly sweetened black tea with citrus.";
"recipe.cl_charquican.drink.summary" = "Red wine (Carménère)";
"recipe.cl_charquican.info" = "Charquicán is a traditional Chilean rustic stew-mash of potatoes and pumpkin cooked until soft, then mashed and mixed with sautéed onion, garlic, ají de color, and vegetables. In many homes it is served as a thick, hearty plate topped with fried eggs, making it a comforting everyday meal that highlights simple ingredients and countryside flavors.";
"recipe.cl_charquican.info.summary" = "Rustic potato mash";
"recipe.cl_charquican.name" = "Charquicán";
"recipe.cl_charquican.step1.body" = "Peel and cut the %i1 and %i2 into chunks. Dice the %i5 and mince the %i6. Peel and dice the %i11, trim and cut the %i12, and have the %i13 ready.";
"recipe.cl_charquican.step1.title" = "Prep the vegetables";
"recipe.cl_charquican.step2.body" = "Add potatoes and squash to a pot with %i3 and cook at a steady simmer until very tender.";
"recipe.cl_charquican.step2.title" = "Cook potatoes and squash";
"recipe.cl_charquican.step3.body" = "Add carrots and green beans to the pot and simmer until tender, then add peas and cook until heated through.";
"recipe.cl_charquican.step3.title" = "Cook carrots and beans";
"recipe.cl_charquican.step4.body" = "Drain the contents well and return to the pot. Mash to a rustic, slightly chunky texture.";
"recipe.cl_charquican.step4.title" = "Drain and mash";
"recipe.cl_charquican.step5.body" = "In a skillet, warm %i4 and cook onion until soft and lightly golden. Add garlic, then stir in %i7 and %i8 until fragrant.";
"recipe.cl_charquican.step5.title" = "Make the sofrito";
"recipe.cl_charquican.step6.body" = "Stir the sofrito into the mash, season with %i9 and %i10, and cook briefly while stirring until cohesive and thick.";
"recipe.cl_charquican.step6.title" = "Combine and season";
"recipe.cl_charquican.step7.body" = "In a pan, fry the %i14 until the whites are set and the yolks remain runny or to preference.";
"recipe.cl_charquican.step7.title" = "Fry the eggs";
"recipe.cl_charquican.step8.body" = "Spoon charquicán onto plates and top each portion with a fried egg.";
"recipe.cl_charquican.step8.title" = "Serve";
