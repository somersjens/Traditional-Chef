"recipe.us_ma_new_england_clam_chowder.drink.body" = "A lightly oaked Chardonnay or a crisp pilsner pairs with the creamy chowder and briny clams without tasting sharp. For a non-alcoholic option, serve hot black tea or sparkling water with lemon to keep the meal refreshing.";
"recipe.us_ma_new_england_clam_chowder.drink.summary" = "White wine (Chardonnay)";
"recipe.us_ma_new_england_clam_chowder.info" = "New England clam chowder is a Massachusetts classic: tender clams and potatoes in a creamy, peppery chowder enriched with bacon and onions. Traditionally thickened by the starch of simmered potatoes and finished with milk and cream, it’s served hot with oyster crackers for crunch. The flavor is briny, smoky, and comforting, and the chowder is meant to be hearty enough to eat as a meal.";
"recipe.us_ma_new_england_clam_chowder.info.summary" = "Creamy clam chowder";
"recipe.us_ma_new_england_clam_chowder.name" = "Clam chowder";
