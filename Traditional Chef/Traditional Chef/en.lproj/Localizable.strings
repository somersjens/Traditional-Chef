"recipe.es_pulpo_a_la_gallega.drink.body" = "Pair with a crisp, mineral Spanish white such as Albariño to complement the briny octopus and smoked paprika. A dry Cava also works well with the olive oil and potatoes. Non-alcoholic option: sparkling water with lemon.";
"recipe.es_pulpo_a_la_gallega.drink.summary" = "White wine (Albariño)";
"recipe.es_pulpo_a_la_gallega.info" = "Pulpo a la gallega is the classic Galician preparation of octopus simmered until tender, sliced into rounds, and served over boiled potatoes on a wooden platter, finished with extra virgin olive oil, smoked paprika, and coarse salt. It is traditionally served hot or warm as a shared dish in Galicia’s pulperías, with the seasoned oil soaking into the potatoes.";
"recipe.es_pulpo_a_la_gallega.info.summary" = "Galician octopus plate";
"recipe.es_pulpo_a_la_gallega.name" = "Galician octopus";
"recipe.es_pulpo_a_la_gallega.step1.body" = "Scrub %i3 and cut them into thick rounds. Put them in a pot, cover with %i2, and bring to a gentle boil.";
"recipe.es_pulpo_a_la_gallega.step1.title" = "Prepare the potatoes";
"recipe.es_pulpo_a_la_gallega.step2.body" = "Simmer until the potatoes are tender but hold their shape, then drain and keep warm.";
"recipe.es_pulpo_a_la_gallega.step2.title" = "Cook the potatoes";
"recipe.es_pulpo_a_la_gallega.step3.body" = "Fill a large pot with water and bring it to a steady boil.";
"recipe.es_pulpo_a_la_gallega.step3.title" = "Bring water to a boil for octopus";
"recipe.es_pulpo_a_la_gallega.step4.body" = "Holding %i1 by the head, dip it into the boiling water and lift it out, repeating several times so the tentacles curl.";
"recipe.es_pulpo_a_la_gallega.step4.title" = "Shock the octopus";
"recipe.es_pulpo_a_la_gallega.step5.body" = "Lower the heat so the water simmers gently. Cook the octopus until the thickest part of the tentacle is tender when pierced.";
"recipe.es_pulpo_a_la_gallega.step5.title" = "Simmer until tender";
"recipe.es_pulpo_a_la_gallega.step6.body" = "Remove the octopus from the pot and let it rest briefly so the juices settle.";
"recipe.es_pulpo_a_la_gallega.step6.title" = "Rest the octopus";
"recipe.es_pulpo_a_la_gallega.step7.body" = "Cut the octopus into rounds. Arrange the warm potato slices on a wooden platter and layer the octopus on top.";
"recipe.es_pulpo_a_la_gallega.step7.title" = "Slice and assemble";
"recipe.es_pulpo_a_la_gallega.step8.body" = "Drizzle generously with %i5, dust with %i6, and finish with %i7. Serve immediately while warm.";
"recipe.es_pulpo_a_la_gallega.step8.title" = "Season and serve";
