"recipe.hk_char_siu_bao.step11.body" = "Add %i18 to the steamer and bring it to a steady boil.";
"recipe.hk_char_siu_bao.step11.title" = "Prepare the steamer";
"recipe.hk_char_siu_bao.step12.body" = "Steam the buns in batches over boiling water until the dough is cooked through and soft.";
"recipe.hk_char_siu_bao.step12.title" = "Steam the buns";
"recipe.hk_char_siu_bao.step13.body" = "Turn off the heat and let the buns rest briefly before opening the lid to reduce wrinkling.";
"recipe.hk_char_siu_bao.step13.title" = "Rest before opening";
"recipe.hk_char_siu_bao.step14.body" = "Serve the char siu bao hot in the steamer basket or on a platter.";
"recipe.hk_char_siu_bao.step14.title" = "Serve hot";
"recipe.hk_char_siu_bao.step2.body" = "Cover the dough and let it rise until expanded and soft.";
"recipe.hk_char_siu_bao.step2.title" = "First rise";
"recipe.hk_char_siu_bao.step3.body" = "Dice the %i8 into small pieces and finely chop the %i9.";
"recipe.hk_char_siu_bao.step3.title" = "Prepare the filling ingredients";
"recipe.hk_char_siu_bao.step4.body" = "Heat %i10 in a small saucepan, cook the shallot until fragrant, then stir in %i11, %i12, %i13, %i14, %i15, and %i16.";
"recipe.hk_char_siu_bao.step4.title" = "Cook the filling base";
"recipe.hk_char_siu_bao.step5.body" = "Stir in the %i17 and cook while stirring until the sauce becomes thick and glossy, then fold in the diced char siu.";
"recipe.hk_char_siu_bao.step5.title" = "Thicken the filling";
"recipe.hk_char_siu_bao.step6.body" = "Spread or leave the filling to cool until no longer hot so it is easy to wrap.";
"recipe.hk_char_siu_bao.step6.title" = "Cool the filling";
"recipe.hk_char_siu_bao.step7.body" = "Turn out the dough, knead briefly to smooth it, then divide it into equal portions for buns.";
"recipe.hk_char_siu_bao.step7.title" = "Divide the dough";
"recipe.hk_char_siu_bao.step8.body" = "Roll each portion into a round wrapper with the center slightly thicker than the edge.";
"recipe.hk_char_siu_bao.step8.title" = "Shape wrappers";
"recipe.hk_char_siu_bao.step9.body" = "Place filling in the center of each wrapper, pleat and seal the top, then place each bun on a steamer liner square.";
"recipe.hk_char_siu_bao.step9.title" = "Fill and pleat the buns";
"recipe.hk_char_siu_bao.tool.t1" = "Mixing bowl";
