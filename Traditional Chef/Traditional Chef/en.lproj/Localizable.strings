"recipe.gb_christmas_pudding.drink.body" = "A small glass of tawny port or sweet sherry pairs well with the rich fruit and spice flavours. For a non-alcoholic option, serve hot black tea, coffee, or warm apple juice with spices.";
"recipe.gb_christmas_pudding.drink.summary" = "Port";
"recipe.gb_christmas_pudding.info" = "A traditional British Christmas pudding made with suet, breadcrumbs, flour, dark sugar, apple, citrus, spices, and mixed dried fruits, steamed until dark and rich, then steamed again to reheat before serving. It is the classic festive pudding for Christmas Day, served hot in slices with brandy butter.";
"recipe.gb_christmas_pudding.info.summary" = "Christmas steamed pudding";
"recipe.gb_christmas_pudding.name" = "Christmas pudding";
"recipe.gb_christmas_pudding.step1.body" = "Combine the %i1, %i2, %i3, %i4, %i19, and half the %i20 in a bowl, then zest and juice the %i10 and %i11 and grate the %i9.";
"recipe.gb_christmas_pudding.step1.title" = "Prepare fruit and flavourings";
"recipe.gb_christmas_pudding.step10.body" = "Remove the cover, run a knife around the edge if needed, and turn the pudding onto a warm serving plate.";
"recipe.gb_christmas_pudding.step10.title" = "Unmould pudding";
"recipe.gb_christmas_pudding.step11.body" = "Slice the hot Christmas pudding and serve with brandy butter.";
"recipe.gb_christmas_pudding.step11.title" = "Serve";
"recipe.gb_christmas_pudding.step2.body" = "Leave the dried fruit mixture to soak so the fruit plumps and the flavours blend.";
"recipe.gb_christmas_pudding.step2.title" = "Soak fruit mixture";
"recipe.gb_christmas_pudding.step3.body" = "Add the %i5, %i6, %i7, %i8, %i12, %i13, %i14, %i15, %i16, %i17, and %i18 to the soaked fruit and mix thoroughly.";
"recipe.gb_christmas_pudding.step3.title" = "Mix pudding basin ingredients";
"recipe.gb_christmas_pudding.step4.body" = "Grease the pudding basin lightly, spoon in the mixture, and press it down gently, leaving a little room at the top.";
"recipe.gb_christmas_pudding.step4.title" = "Fill pudding basin";
"recipe.gb_christmas_pudding.step5.body" = "Cover the basin with pleated parchment and foil, tie it tightly with string, and make a handle for lifting.";
"recipe.gb_christmas_pudding.step5.title" = "Cover basin securely";
"recipe.gb_christmas_pudding.step6.body" = "Set the basin on a trivet in a large saucepan with simmering %i25 reaching partway up the basin and steam until dark and firm, topping up water as needed.";
"recipe.gb_christmas_pudding.step6.title" = "Steam pudding";
"recipe.gb_christmas_pudding.step7.body" = "Lift out the basin, cool completely, replace the cover with fresh parchment and foil, and store in a cool place to mature.";
"recipe.gb_christmas_pudding.step7.title" = "Cool and store pudding";
"recipe.gb_christmas_pudding.step8.body" = "On the day of serving, steam the pudding again over simmering water until fully heated through.";
"recipe.gb_christmas_pudding.step8.title" = "Reheat by steaming";
"recipe.gb_christmas_pudding.step9.body" = "Beat the %i21 until soft, beat in the %i22, then beat in the remaining %i23 and %i24 until smooth and light.";
"recipe.gb_christmas_pudding.step9.title" = "Make brandy butter";
