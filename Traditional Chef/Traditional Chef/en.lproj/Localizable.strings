"recipe.mm_mohinga.step8.title" = "Prepare the garnishes";
"recipe.mm_mohinga.step9.body" = "Mix the %i20 with the %i21, %i22, %i23, %i24, and %i25 to form a spoonable batter.";
"recipe.mm_mohinga.step9.title" = "Make the fritter batter";
