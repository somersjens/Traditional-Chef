"recipe.tr_revani.drink.summary" = "Dessert wine (Muscat)";
"recipe.tr_revani.info" = "Revani is a traditional Turkish semolina sponge cake baked until golden, then soaked with lemon-scented sugar syrup so it becomes moist and aromatic. It is served in simple squares at tea time and celebrations, prized for its tender crumb and bright citrus perfume.";
"recipe.tr_revani.info.summary" = "Syrup-soaked semolina cake";
"recipe.tr_revani.name" = "Revani";
