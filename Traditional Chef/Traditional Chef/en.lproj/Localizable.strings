"recipe.kh_samlor_korko.drink.summary" = "White wine (Riesling)";
"recipe.kh_samlor_korko.info" = "Samlor korko is a deeply traditional Cambodian mixed-vegetable soup thickened with pounded vegetables and flavored with kroeung, prahok, toasted rice powder, and fish. It is a hearty home-style dish commonly served as a main meal with steamed rice, especially when many seasonal vegetables are available.";
