"recipe.cl_curanto.drink.body" = "Pair with a Chilean Chardonnay (unoaked or lightly oaked) to handle the richness and match the seafood, or a crisp Sauvignon Blanc for extra freshness. A light red such as País can also work with the smoked meats. Non-alcoholic option: sparkling water with lime or a cold ginger-lemon drink to cut through the richness.";
"recipe.cl_curanto.drink.summary" = "White wine (Chardonnay)";
"recipe.cl_curanto.info" = "Curanto is the iconic communal feast from Chiloé, traditionally cooked in an earth pit over heated stones. Layers of shellfish, meats, potatoes, and the potato breads milcao and chapaleles are covered with nalca leaves and sealed so everything steams together, mingling sea and smoke flavors. It is opened and served straight from the pit while hot, with each plate receiving a mix of seafood, meats, potatoes, and potato breads.";
"recipe.cl_curanto.info.summary" = "Chiloé earth feast";
"recipe.cl_curanto.name" = "Curanto";
"recipe.cl_curanto.step1.body" = "Dig a shallow cooking pit in firm ground and arrange stones inside. Build a strong fire over the stones and keep feeding it until the stones are thoroughly heated and the fire has burned down to embers.";
"recipe.cl_curanto.step1.title" = "Prepare the pit and stones";
"recipe.cl_curanto.step10.body" = "Uncover carefully to avoid hot steam. Transfer seafood, meats, potatoes, milcao, and chapaleles to platters and serve hot, giving each plate a balanced mix.";
"recipe.cl_curanto.step10.title" = "Open and serve";
"recipe.cl_curanto.step2.body" = "Scrub %i1 and rinse %i2 well, discarding any that are cracked or do not close when tapped. Rinse %i3 and keep everything chilled until layering.";
"recipe.cl_curanto.step2.title" = "Clean the shellfish";
"recipe.cl_curanto.step3.body" = "Grate %i8 and squeeze in a cloth to remove liquid. Mix the potato mass with %i9, %i10, and %i11, then shape into thick patties that will hold together.";
"recipe.cl_curanto.step3.title" = "Make the milcao";
"recipe.cl_curanto.step4.body" = "Grate %i12 and mix with %i13 and %i14 to form a firm dough. Shape into small oval dumplings.";
"recipe.cl_curanto.step4.title" = "Make the chapaleles";
"recipe.cl_curanto.step5.body" = "Pat %i4, %i5, and %i6 dry and keep them ready to layer. Scrub %i7 and keep them whole or halved so they steam evenly.";
"recipe.cl_curanto.step5.title" = "Ready the meats and potatoes";
"recipe.cl_curanto.step6.body" = "Rinse %i15. Heat %i16 until very hot so it can be added to generate steam once the pit is sealed.";
"recipe.cl_curanto.step6.title" = "Prepare the sealing materials";
"recipe.cl_curanto.step7.body" = "When the stones are hot, remove excess ash. Place a bed of nalca leaves over the stones, then layer potatoes, meats, and shellfish, adding milcao and chapaleles among the layers. Cover everything with more nalca leaves.";
"recipe.cl_curanto.step7.title" = "Layer the curanto";
"recipe.cl_curanto.step8.body" = "Cover with burlap or thick cloth, seal with earth so steam cannot escape, then pour hot water into the pit through a small opening and reseal immediately.";
"recipe.cl_curanto.step8.title" = "Seal and steam";
"recipe.cl_curanto.step9.body" = "Let the curanto steam until shellfish have opened and meats and potatoes are fully cooked through.";
"recipe.cl_curanto.step9.title" = "Cook the curanto";
