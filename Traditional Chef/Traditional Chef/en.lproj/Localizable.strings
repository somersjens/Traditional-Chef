"recipe.in_rogan_josh.drink.body" = "A medium-bodied red such as Pinot Noir or Grenache pairs well with the fragrant spices and rich mutton without overwhelming the curry. A malty lager also works. For a non-alcoholic option, serve salted lassi or plain lime water.";
"recipe.in_rogan_josh.drink.summary" = "Red wine (Pinot Noir)";
"recipe.in_rogan_josh.info" = "Rogan josh is a classic Kashmiri mutton curry in which meat is slow-cooked with yogurt and warming spices until tender in a deep red, aromatic gravy. It is traditionally served hot for lunch or dinner with steamed rice, especially at family meals and festive gatherings.";
"recipe.in_rogan_josh.info.summary" = "Aromatic red mutton";
"recipe.in_rogan_josh.name" = "Rogan josh";
