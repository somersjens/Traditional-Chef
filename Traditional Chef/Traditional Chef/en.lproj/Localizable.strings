"recipe.lk_lamprais.step11.title" = "Prepare banana leaves for wrapping";
"recipe.lk_lamprais.step12.body" = "Place rice on each banana leaf and top with mixed meat curry, ash plantain curry, brinjal pahi, seeni sambol, blachan, and frikkadels, then fold into tight parcels.";
"recipe.lk_lamprais.step12.title" = "Assemble the parcels";
"recipe.lk_lamprais.step13.body" = "Arrange the parcels on a tray and bake until heated through and the banana leaf becomes aromatic.";
"recipe.lk_lamprais.step13.title" = "Bake the lamprais";
"recipe.lk_lamprais.step14.body" = "Serve the lamprais hot in the banana leaf parcels.";
"recipe.lk_lamprais.step14.title" = "Serve";
"recipe.lk_lamprais.step2.body" = "Heat %i16 in a pot and cook the %i17, %i18, %i19, %i20, %i21, and %i22 until fragrant, then add the %i23, %i24, %i25, and %i26.";
