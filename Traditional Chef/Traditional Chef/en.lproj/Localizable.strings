"recipe.kh_bor_bor_thnaut.step1.title" = "Soak rice";
"recipe.kh_bor_bor_thnaut.step2.body" = "Drain the soaked rice well and set it aside.";
"recipe.kh_bor_bor_thnaut.step2.title" = "Drain rice";
"recipe.kh_bor_bor_thnaut.step3.body" = "Drain the %i6 and slice them into bite-size pieces.";
"recipe.kh_bor_bor_thnaut.step3.title" = "Prepare palm seeds";
"recipe.kh_bor_bor_thnaut.step4.body" = "Combine the rice, water, %i3, %i4, and %i5 in a heavy pot and bring gently to a simmer while stirring.";
"recipe.kh_bor_bor_thnaut.step4.title" = "Start pudding base";
"recipe.kh_bor_bor_thnaut.step5.body" = "Simmer slowly, stirring regularly so the rice softens and the mixture thickens into a porridge.";
"recipe.kh_bor_bor_thnaut.step5.title" = "Cook rice pudding";
"recipe.kh_bor_bor_thnaut.step6.body" = "Stir in the sliced toddy palm seeds and continue cooking until they are heated through and the pudding is glossy and thick.";
"recipe.kh_bor_bor_thnaut.step6.title" = "Add palm seeds";
"recipe.kh_bor_bor_thnaut.step7.body" = "In a saucepan, heat %i7 with %i8 and %i9, stirring until smooth and lightly thickened.";
"recipe.kh_bor_bor_thnaut.step7.title" = "Cook coconut topping";
"recipe.kh_bor_bor_thnaut.step8.body" = "Ladle the warm bor bor thnaut into bowls and spoon the coconut cream topping over each serving.";
"recipe.kh_bor_bor_thnaut.step8.title" = "Serve";
