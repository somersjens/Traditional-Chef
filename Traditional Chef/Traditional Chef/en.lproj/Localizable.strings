"recipe.sr_saoto_soep.step1.title" = "Start the broth";
"recipe.sr_saoto_soep.step10.body" = "Ladle the hot broth over the bowls and serve immediately with the ketjap sambal.";
"recipe.sr_saoto_soep.step10.title" = "Finish and serve";
