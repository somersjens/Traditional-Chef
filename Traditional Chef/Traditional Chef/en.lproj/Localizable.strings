"recipe.bd_kacchi_biryani.drink.body" = "An off-dry Riesling or aromatic white balances the rich ghee, warm spices, and slight sweetness from prunes. If you prefer red, choose a light-bodied, low-tannin red served slightly chilled. Non-alcoholic pairing: chilled borhani or a lemon-mint soda.";
"recipe.bd_kacchi_biryani.drink.summary" = "White wine (Riesling)";
"recipe.bd_kacchi_biryani.info" = "Bangladeshi kacchi biryani is a celebratory dish where raw marinated mutton is layered with fragrant basmati rice, potatoes, prunes, herbs, and perfumed ghee, then sealed and cooked on dum so the meat becomes tender and the rice absorbs the rich, aromatic steam. It is traditionally served with chilled borhani, a spiced yogurt drink that cuts the richness, and a simple fresh salad.";
"recipe.bd_kacchi_biryani.info.summary" = "Festive kacchi biryani";
"recipe.bd_kacchi_biryani.name" = "Kacchi biryani";
"recipe.bd_kacchi_biryani.step1.body" = "Make a paste from %i3 and %i4. Mix %i2 with the paste, %i5, %i6 juice, %i7, %i8, %i9, %i10, %i11, %i12, %i13, %i15, and some %i14.";
"recipe.bd_kacchi_biryani.step1.title" = "Prepare the marinade";
"recipe.bd_kacchi_biryani.step10.body" = "Turn off the heat and let the pot stand sealed so the steam settles and the layers set.";
"recipe.bd_kacchi_biryani.step10.title" = "Rest before opening";
"recipe.bd_kacchi_biryani.step11.body" = "Blend %i31 with %i32, %i33, %i34, %i35, %i36, %i37, and %i38, then thin with %i43 to a drinkable consistency and chill.";
"recipe.bd_kacchi_biryani.step11.title" = "Make borhani";
"recipe.bd_kacchi_biryani.step12.body" = "Slice %i39, %i40, and %i41, then dress with %i42 juice and a pinch of salt.";
"recipe.bd_kacchi_biryani.step12.title" = "Make the salad";
"recipe.bd_kacchi_biryani.step13.body" = "Gently fluff the rice and lift out portions with mutton and potatoes from the bottom. Serve hot with chilled borhani and the fresh salad.";
"recipe.bd_kacchi_biryani.step13.title" = "Serve";
"recipe.bd_kacchi_biryani.step2.body" = "Coat the %i1 thoroughly in the marinade and massage it in so it clings to the meat.";
"recipe.bd_kacchi_biryani.step2.title" = "Marinate the mutton";
"recipe.bd_kacchi_biryani.step3.body" = "Cover and refrigerate so the mutton tenderises and absorbs flavour.";
"recipe.bd_kacchi_biryani.step3.title" = "Rest the marinade";
"recipe.bd_kacchi_biryani.step4.body" = "Slice %i18 thinly and fry slowly until deep golden and crisp, then drain well.";
"recipe.bd_kacchi_biryani.step4.title" = "Make birista";
"recipe.bd_kacchi_biryani.step5.body" = "Peel and halve the %i17. Pick %i19 and %i20 leaves and keep them ready with %i21 and %i22.";
"recipe.bd_kacchi_biryani.step5.title" = "Prep potatoes and herbs";
"recipe.bd_kacchi_biryani.step6.body" = "Warm %i24 and steep %i23 until deeply coloured and fragrant.";
"recipe.bd_kacchi_biryani.step6.title" = "Infuse saffron";
"recipe.bd_kacchi_biryani.step7.body" = "Rinse the %i16 until the water runs mostly clear. Boil %i43 with %i26, %i27, %i28, %i29, and %i30 and salt, add rice, and parboil until the grains are mostly cooked but still firm, then drain.";
"recipe.bd_kacchi_biryani.step7.title" = "Parboil the rice";
"recipe.bd_kacchi_biryani.step8.body" = "In the heavy pot, spread the marinated mutton, then arrange potatoes over it. Top with drained rice, then scatter birista, mint, coriander, prunes, and raisins. Drizzle remaining ghee and the saffron milk, then add %i25.";
"recipe.bd_kacchi_biryani.step8.title" = "Layer the biryani";
"recipe.bd_kacchi_biryani.step9.body" = "Seal the pot tightly and cook on low heat so the mutton cooks in its own steam and the rice finishes cooking without burning.";
"recipe.bd_kacchi_biryani.step9.title" = "Cook on dum";
