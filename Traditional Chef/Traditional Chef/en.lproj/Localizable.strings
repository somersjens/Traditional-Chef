"recipe.tr_adana_kebab.drink.body" = "A medium-bodied Syrah or a fruit-forward Grenache stands up to the smoky spice and rich lamb fat. For a non-alcoholic option, serve chilled ayran or sparkling water with lemon.";
"recipe.tr_adana_kebab.drink.summary" = "Red wine (Syrah)";
"recipe.tr_adana_kebab.info" = "Adana Kebab is a traditional Turkish kebab from Adana made by hand-mincing lamb with tail fat, hot red pepper, and salt, then kneading it until it clings to wide skewers and grilling over charcoal. It is classically served with lavash, grilled tomatoes and peppers, sumac onion salad, and a cooling spoon of strained yogurt to balance the heat.";
"recipe.tr_adana_kebab.info.summary" = "Adana lamb skewers";
"recipe.tr_adana_kebab.name" = "Adana kebab";
"recipe.tr_adana_kebab.step1.body" = "Finely mince %i3 and grate %i4. Thinly slice %i9 and chop %i10 for the sumac salad.";
"recipe.tr_adana_kebab.step1.title" = "Prep peppers and onions";
"recipe.tr_adana_kebab.step2.body" = "Combine %i1, %i2, minced peppers, garlic, %i6, and %i5. Knead vigorously until the mixture becomes sticky and uniform.";
"recipe.tr_adana_kebab.step2.title" = "Knead the kebab mixture";
"recipe.tr_adana_kebab.step3.body" = "Cover and chill the mixture so the fat firms and it holds well on skewers.";
"recipe.tr_adana_kebab.step3.title" = "Chill to firm";
"recipe.tr_adana_kebab.step4.body" = "Divide the mixture and press it evenly along wide skewers, shaping long ridges with wet hands.";
"recipe.tr_adana_kebab.step4.title" = "Skewer the kebabs";
"recipe.tr_adana_kebab.step5.body" = "Season the sliced onions with %i13 and rub them briefly to soften, then add %i11, %i12, and parsley and mix well.";
"recipe.tr_adana_kebab.step5.title" = "Prepare the sumac onions";
