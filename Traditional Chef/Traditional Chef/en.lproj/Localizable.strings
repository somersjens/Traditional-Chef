"recipe.ru_ptichye_moloko.drink.body" = "A lightly sweet dessert wine or late-harvest white complements the chocolate glaze and vanilla notes, while sparkling wine also works for celebrations. Non-alcoholic pairing: strong black tea with lemon or a mild coffee.";
"recipe.ru_ptichye_moloko.drink.summary" = "Dessert wine";
"recipe.ru_ptichye_moloko.info" = "Ptichye Moloko is a classic Russian cake with a thin baked base topped by a light, agar-set soufflé made from whipped egg whites and a butter–condensed milk cream, finished with a smooth chocolate glaze. It is served chilled so the soufflé slices cleanly and the glaze stays glossy, traditionally as a special-occasion dessert with tea.";
"recipe.ru_ptichye_moloko.info.summary" = "Agar soufflé cake";
"recipe.ru_ptichye_moloko.name" = "Ptichye Moloko cake";
"recipe.ru_ptichye_moloko.step1.body" = "Line the springform pan with parchment and preheat the oven. Separate the %i1 into yolks and whites, keeping the whites cold for later.";
"recipe.ru_ptichye_moloko.step1.title" = "Prepare the pan";
"recipe.ru_ptichye_moloko.step10.body" = "Pour the soufflé mixture over the cooled base in the pan and smooth the top quickly before it begins to set.";
"recipe.ru_ptichye_moloko.step10.title" = "Fill the cake";
"recipe.ru_ptichye_moloko.step11.body" = "Refrigerate until the soufflé is fully firm and sliceable.";
"recipe.ru_ptichye_moloko.step11.title" = "Chill to set";
"recipe.ru_ptichye_moloko.step12.body" = "Melt the %i13 with %i14 until smooth and glossy, stirring gently.";
"recipe.ru_ptichye_moloko.step12.title" = "Make the glaze";
"recipe.ru_ptichye_moloko.step13.body" = "Unmold the chilled cake, pour the glaze over the top, and spread evenly so it drips slightly. Refrigerate briefly until the glaze is set, then slice and serve cold.";
"recipe.ru_ptichye_moloko.step13.title" = "Glaze and finish";
"recipe.ru_ptichye_moloko.step2.body" = "Beat the %i4 with %i2 until creamy, then beat in the yolks and %i6. Sift in %i3 with %i5 and %i15 and mix into a smooth batter.";
"recipe.ru_ptichye_moloko.step2.title" = "Mix the base batter";
"recipe.ru_ptichye_moloko.step3.body" = "Spread the batter evenly in the pan and bake until set, lightly golden, and springy to the touch. Cool the base completely.";
"recipe.ru_ptichye_moloko.step3.title" = "Bake the base";
"recipe.ru_ptichye_moloko.step4.body" = "Beat the %i7 until pale and smooth, then gradually beat in %i8 until fully emulsified and glossy. Keep at cool room temperature.";
"recipe.ru_ptichye_moloko.step4.title" = "Make the butter cream";
"recipe.ru_ptichye_moloko.step5.body" = "Soak %i9 in %i11 in a saucepan, then bring to a simmer while stirring until the agar dissolves completely.";
"recipe.ru_ptichye_moloko.step5.title" = "Start the agar syrup";
"recipe.ru_ptichye_moloko.step6.body" = "Add the %i10 and cook the syrup while stirring until it reaches a hot syrup stage and thickens slightly. Remove from heat and add %i12 juice.";
"recipe.ru_ptichye_moloko.step6.title" = "Cook the syrup to stage";
"recipe.ru_ptichye_moloko.step7.body" = "Whip the egg whites to firm glossy peaks in a clean bowl.";
"recipe.ru_ptichye_moloko.step7.title" = "Whip the whites";
"recipe.ru_ptichye_moloko.step8.body" = "With the mixer running, slowly pour the hot agar syrup into the whipped whites in a thin stream, continuing to whip until the mixture becomes thick and stable.";
"recipe.ru_ptichye_moloko.step8.title" = "Stream in the hot syrup";
"recipe.ru_ptichye_moloko.step9.body" = "Whisk the butter cream briefly to loosen it, then fold it into the agar meringue in stages until smooth and uniform.";
"recipe.ru_ptichye_moloko.step9.title" = "Combine with butter cream";
