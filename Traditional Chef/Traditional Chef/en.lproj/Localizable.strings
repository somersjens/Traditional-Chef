"recipe.za_melktert.drink.body" = "A lightly chilled Muscat or late-harvest Chenin Blanc pairs well with the tart’s creamy custard and cinnamon. If you prefer something drier, a fruity Chenin Blanc works too. Non-alcoholic pairing: strong black tea or rooibos tea.";
"recipe.za_melktert.drink.summary" = "Sweet wine (Muscat)";
"recipe.za_melktert.info" = "Melktert is a traditional South African milk tart with a crisp pastry shell and a gently set, creamy milk custard thickened with flour and cornflour. It is delicately scented with vanilla and finished with a generous dusting of cinnamon, then served chilled in slices as a classic teatime dessert.";
"recipe.za_melktert.info.summary" = "Cinnamon milk tart";
"recipe.za_melktert.name" = "Milk tart";
"recipe.za_melktert.step1.body" = "Mix %i1, %i4, and %i2, then rub in the %i3 until fine crumbs form. Add the %i5 and mix, then add %i6 gradually just until a dough comes together.";
"recipe.za_melktert.step1.title" = "Make the pastry dough";
"recipe.za_melktert.step10.body" = "Cool to room temperature, then refrigerate until fully set and sliceable.";
"recipe.za_melktert.step10.title" = "Chill to set";
"recipe.za_melktert.step11.body" = "Dust the top evenly with %i14 before slicing and serving.";
"recipe.za_melktert.step11.title" = "Finish with cinnamon";
"recipe.za_melktert.step2.body" = "Flatten the dough, cover, and chill until firm.";
"recipe.za_melktert.step2.title" = "Chill the pastry";
"recipe.za_melktert.step3.body" = "Roll out the dough, line the tart tin, trim the edges, and dock the base with a fork.";
"recipe.za_melktert.step3.title" = "Line the tart tin";
"recipe.za_melktert.step4.body" = "Bake the lined crust with pie weights until set, then remove the weights and bake until lightly golden.";
"recipe.za_melktert.step4.title" = "Blind bake the crust";
"recipe.za_melktert.step5.body" = "Warm the %i7 with the %i12 and %i13 until steaming but not boiling.";
"recipe.za_melktert.step5.title" = "Start the milk base";
"recipe.za_melktert.step6.body" = "In a bowl, whisk %i8, %i9, and %i10 together, then whisk in the %i11 until smooth.";
"recipe.za_melktert.step6.title" = "Whisk the thickener";
"recipe.za_melktert.step7.body" = "Slowly whisk some hot milk into the egg mixture to warm it through.";
"recipe.za_melktert.step7.title" = "Temper the eggs";
"recipe.za_melktert.step8.body" = "Pour the warmed egg mixture back into the saucepan and cook, whisking constantly, until thick and smooth.";
"recipe.za_melktert.step8.title" = "Cook the custard";
"recipe.za_melktert.step9.body" = "Pour the custard through a sieve into the baked crust and smooth the top.";
"recipe.za_melktert.step9.title" = "Fill the tart";
