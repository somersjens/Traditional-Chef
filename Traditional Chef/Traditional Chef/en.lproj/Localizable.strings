"recipe.ma_rfissa.step10.body" = "Tear the cooked msemen into bite-size pieces and mound them on a serving platter.";
"recipe.ma_rfissa.step10.title" = "Tear and assemble";
"recipe.ma_rfissa.step11.body" = "Arrange chicken over the msemen and ladle the lentils and hot spiced broth generously over everything so the bread soaks it up. Serve immediately.";
"recipe.ma_rfissa.step11.title" = "Serve rfissa";
"recipe.ma_rfissa.step2.body" = "Heat %i4 and %i5 in a large pot over medium heat. Add onion and cook until softened, then add garlic and cook until fragrant.";
"recipe.ma_rfissa.step2.title" = "Start the chicken base";
"recipe.ma_rfissa.step3.body" = "Stir in the spices until aromatic.";
