"recipe.lb_baba_ghanoush.drink.body" = "Pair with a crisp, citrusy white such as Sauvignon Blanc or dry Assyrtiko to balance the tahini richness and smoke. For a non-alcoholic pairing, serve with cold sparkling water with lemon or unsweetened mint tea.";
"recipe.lb_baba_ghanoush.drink.summary" = "White wine (Sauvignon)";
"recipe.lb_baba_ghanoush.info" = "Lebanese baba ghanoush is a classic mezze made by charring eggplants until smoky and tender, then mixing the drained flesh with tahini, lemon, and garlic. It is served at room temperature with a drizzle of olive oil and herbs, typically alongside warm pita bread as part of a larger spread.";
"recipe.lb_baba_ghanoush.info.summary" = "Smoky tahini eggplant";
"recipe.lb_baba_ghanoush.name" = "Baba ghanoush";
"recipe.lb_baba_ghanoush.step1.body" = "Char the %i1 directly over a flame or hot grill, turning often with tongs, until the skins are blackened all over and the flesh is completely soft.";
"recipe.lb_baba_ghanoush.step1.title" = "Char the eggplants";
"recipe.lb_baba_ghanoush.step2.body" = "Let the eggplants cool until safe to handle, then split and scoop out the flesh. Place the flesh in a colander and let it drain well so the dip is not watery.";
"recipe.lb_baba_ghanoush.step2.title" = "Drain the eggplant";
"recipe.lb_baba_ghanoush.step3.body" = "In a bowl, stir %i2 with %i3 until it loosens and becomes creamy. Crush the %i4 and mix it in with %i5.";
"recipe.lb_baba_ghanoush.step3.title" = "Make the tahini base";
"recipe.lb_baba_ghanoush.step4.body" = "Add the drained eggplant flesh to the bowl and mash with a fork to keep some texture while fully combining with the tahini mixture. Taste and adjust with more lemon juice or salt if needed.";
"recipe.lb_baba_ghanoush.step4.title" = "Combine and mash";
"recipe.lb_baba_ghanoush.step5.body" = "Spoon into a serving bowl, drizzle with %i6, and scatter %i7 on top. Warm the %i8 briefly, then serve alongside the dip at room temperature.";
"recipe.lb_baba_ghanoush.step5.title" = "Finish and serve";
