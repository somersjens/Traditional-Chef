"recipe.ir_ranginak.drink.body" = "A nutty dessert wine such as Tawny Port or a sweet Muscat complements the dates, toasted flour, and warm spices. If you want something lighter, a late-harvest Riesling also works. Non-alcoholic: strong Persian black tea or cardamom tea.";
"recipe.ir_ranginak.drink.summary" = "Sweet wine (Port)";
"recipe.ir_ranginak.info" = "Ranginak is a traditional Iranian dessert, especially associated with southern regions, made by stuffing soft dates with walnuts and covering them with a fragrant toasted flour-and-butter topping scented with cinnamon and cardamom. It is typically pressed into a dish, chilled to set, then finished with a light dusting and chopped nuts, and served in small pieces alongside tea.";
"recipe.ir_ranginak.info.summary" = "Date walnut tea sweet";
"recipe.ir_ranginak.name" = "Ranginak";
"recipe.ir_ranginak.step1.body" = "Pit %i1 carefully to keep them intact, then fill each date with %i2 and arrange them snugly in a single layer in a serving dish.";
"recipe.ir_ranginak.step1.title" = "Prepare dates and walnuts";
"recipe.ir_ranginak.step2.body" = "Heat a skillet over medium heat and toast %i3, stirring constantly, until it turns lightly golden and smells nutty.";
"recipe.ir_ranginak.step2.title" = "Toast the flour";
"recipe.ir_ranginak.step3.body" = "Add %i4 to the toasted flour and cook while stirring until smooth and aromatic, then stir in %i5 and %i6 until evenly combined.";
"recipe.ir_ranginak.step3.title" = "Make the spiced topping";
"recipe.ir_ranginak.step4.body" = "Pour the warm flour-butter mixture over the stuffed dates, spread evenly, and press gently so the top is smooth and compact.";
"recipe.ir_ranginak.step4.title" = "Cover and smooth";
"recipe.ir_ranginak.step5.body" = "Refrigerate until firm enough to slice cleanly.";
"recipe.ir_ranginak.step5.title" = "Chill to set";
"recipe.ir_ranginak.step6.body" = "Chop %i7, dust the top with %i8 through a sieve, sprinkle with pistachios, then cut into pieces and serve.";
"recipe.ir_ranginak.step6.title" = "Finish and serve";
