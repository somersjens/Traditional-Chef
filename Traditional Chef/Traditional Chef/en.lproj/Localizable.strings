"recipe.ng_isi_ewu.drink.body" = "A medium-bodied red like Syrah or Grenache stands up to the heat and peppery spices without tasting harsh. If you prefer white, a dry Riesling can refresh between bites. Non-alcoholic pairing: chilled ginger drink or sparkling water with lime.";
"recipe.ng_isi_ewu.drink.summary" = "Red wine (Syrah)";
"recipe.ng_isi_ewu.info" = "Isi ewu is a classic Igbo dish of tender goat head pieces coated in a richly spiced, peppery palm-oil sauce emulsified with potash, then finished with sliced onions and bitter utazi leaves. It is traditionally served warm as a communal starter or bar food, eaten with fingers or toothpicks, with the sauce clinging to every piece.";
"recipe.ng_isi_ewu.info.summary" = "Spicy goat head";
"recipe.ng_isi_ewu.name" = "Isi ewu";
"recipe.ng_isi_ewu.step1.body" = "Rinse the %i1 thoroughly and scrape away any stray hairs. Slice the %i11 and thinly shred the %i12. Blend the %i8 to a smooth paste.";
"recipe.ng_isi_ewu.step1.title" = "Clean and prep";
"recipe.ng_isi_ewu.step2.body" = "Put the goat head in a pot with %i3, %i4, and %i2, then simmer until the meat and skin are tender and easily separate from the bone.";
"recipe.ng_isi_ewu.step2.title" = "Boil until tender";
"recipe.ng_isi_ewu.step3.body" = "Lift the goat head from the pot, cool briefly, then remove bones and chop the meat, skin, and soft parts into bite-size pieces. Reserve some cooking liquid.";
"recipe.ng_isi_ewu.step3.title" = "Debone and cut";
"recipe.ng_isi_ewu.step4.body" = "Dissolve the %i6 in %i7, let it settle, then strain to get a clear potash solution.";
"recipe.ng_isi_ewu.step4.title" = "Make potash solution";
"recipe.ng_isi_ewu.step5.body" = "In a bowl, combine %i5 with the strained potash solution and stir until it turns lighter and slightly thickened, then mix in %i9, %i10, and the blended pepper.";
"recipe.ng_isi_ewu.step5.title" = "Emulsify the sauce";
"recipe.ng_isi_ewu.step6.body" = "Add the chopped goat head to the sauce and toss thoroughly until every piece is well coated. Add small splashes of reserved cooking liquid only if needed to loosen the coating.";
"recipe.ng_isi_ewu.step6.title" = "Coat the goat head";
"recipe.ng_isi_ewu.step7.body" = "Fold in sliced onions and utazi leaves, taste and adjust salt, then serve warm.";
"recipe.ng_isi_ewu.step7.title" = "Finish and serve";
