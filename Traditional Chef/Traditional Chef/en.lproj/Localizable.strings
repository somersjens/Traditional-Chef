"recipe.al_fli.drink.body" = "A dry, fresh white wine such as Sauvignon Blanc pairs well with the rich dairy layers and toasted crust. A good non-alcoholic option is plain drinking yogurt or cold sparkling water.";
"recipe.al_fli.drink.summary" = "White wine (Sauvignon)";
"recipe.al_fli.info" = "Fli is a traditional layered Albanian dish from northern Albania, made from many thin baked layers of simple batter repeatedly brushed with a dairy mixture until richly browned. It is prepared for gatherings and family occasions and is traditionally served hot with sour cream or yogurt.";
"recipe.al_fli.info.summary" = "Layered batter pie";
"recipe.al_fli.name" = "Fli";
"recipe.al_fli.step1.body" = "Whisk %i1, %i2, %i3, and %i4 into a smooth pourable batter with no lumps.";
"recipe.al_fli.step1.title" = "Make the batter";
"recipe.al_fli.step2.body" = "Melt %i6 and mix it with %i5 and %i7 until evenly combined.";
"recipe.al_fli.step2.title" = "Prepare the brushing mixture";
"recipe.al_fli.step3.body" = "Heat the oven and place the round baking tray inside so it becomes very hot before the first layer is added.";
"recipe.al_fli.step3.title" = "Heat the tray";
"recipe.al_fli.step4.body" = "Pour a thin layer of batter into the hot tray and bake until set and lightly colored. Brush with some of the yogurt mixture, then repeat with more thin layers of batter and brushing mixture until all the batter and mixture are used.";
"recipe.al_fli.step4.title" = "Build the layers";
"recipe.al_fli.step5.body" = "Bake the completed fli until the top is deeply golden and the layers are fully cooked through.";
"recipe.al_fli.step5.title" = "Finish the fli";
"recipe.al_fli.step6.body" = "Let the fli stand briefly so the layers settle and slice more neatly.";
"recipe.al_fli.step6.title" = "Rest before serving";
"recipe.al_fli.step7.body" = "Cut the fli into wedges and serve it hot with %i8 alongside.";
"recipe.al_fli.step7.title" = "Serve";
"recipe.al_fli.tool.t1" = "Mixing bowl";
"recipe.al_fli.tool.t2" = "Whisk";
