"recipe.dk_citronfromage.drink.body" = "A lightly sweet dessert wine or a glass of dry sparkling wine pairs well with the bright lemon flavor and airy texture. For a non-alcoholic option, serve cold water or unsweetened black tea.";
"recipe.dk_citronfromage.drink.summary" = "Dessert wine";
"recipe.dk_citronfromage.info" = "Citronfromage is a classic Danish dessert made with eggs, sugar, fresh lemon, gelatin, and lightly whipped cream. It is chilled until softly set and traditionally served cold, often as a festive dessert after family meals and holiday lunches.";
"recipe.dk_citronfromage.info.summary" = "Light lemon mousse";
"recipe.dk_citronfromage.name" = "Lemon mousse";
"recipe.dk_citronfromage.step1.body" = "Finely grate %i1 zest and squeeze the lemon juice. Soak %i4 in cold water until softened.";
"recipe.dk_citronfromage.step1.title" = "Prepare the lemon and gelatin";
"recipe.dk_citronfromage.step10.body" = "Whip the remaining %i6 lightly and spoon a little on top of each serving just before serving cold.";
"recipe.dk_citronfromage.step10.title" = "Serve";
"recipe.dk_citronfromage.step2.body" = "Whisk %i2 and %i3 until very light and airy, then whisk in the lemon zest and lemon juice.";
"recipe.dk_citronfromage.step2.title" = "Whisk the egg base";
"recipe.dk_citronfromage.step3.body" = "Lift the softened gelatin from the water with a little moisture still clinging to it and melt it gently over low heat in the small saucepan.";
"recipe.dk_citronfromage.step3.title" = "Melt the gelatin";
"recipe.dk_citronfromage.step4.body" = "Stir a little of the lemon mixture into the melted gelatin, then whisk it back into the rest of the mixture so it stays smooth.";
"recipe.dk_citronfromage.step4.title" = "Combine the base";
"recipe.dk_citronfromage.step5.body" = "Leave the lemon mixture briefly until it begins to thicken lightly but is still fluid.";
"recipe.dk_citronfromage.step5.title" = "Let the mixture thicken slightly";
"recipe.dk_citronfromage.step6.body" = "Whip the larger portion of %i5 until soft and light.";
"recipe.dk_citronfromage.step6.title" = "Whip the cream";
"recipe.dk_citronfromage.step7.body" = "Gently fold the whipped cream into the lemon mixture until smooth and airy.";
"recipe.dk_citronfromage.step7.title" = "Fold the mousse";
"recipe.dk_citronfromage.step8.body" = "Spoon the citronfromage into serving glasses or one serving bowl.";
"recipe.dk_citronfromage.step8.title" = "Portion the dessert";
"recipe.dk_citronfromage.step9.body" = "Refrigerate the citronfromage until softly set and fully cold.";
"recipe.dk_citronfromage.step9.title" = "Chill until set";
