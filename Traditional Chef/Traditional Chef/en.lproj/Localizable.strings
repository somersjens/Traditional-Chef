"recipe.iq_tepsi_baytinijan.drink.body" = "A dry rosé or a light red such as Cinsault pairs well with the fried eggplant, tomato sauce, and meat. A light lager also works. For a non-alcoholic pairing, serve black tea with lemon or chilled ayran.";
"recipe.iq_tepsi_baytinijan.drink.summary" = "Rosé wine";
"recipe.iq_tepsi_baytinijan.info" = "Tepsi baytinijan is a traditional Iraqi oven-baked tray dish of fried eggplant, potatoes, tomatoes, onions, garlic, and small meatballs baked together in a light tomato sauce. It is a home-style main course usually served hot with rice, salad, and pickles for family lunch or dinner.";
"recipe.iq_tepsi_baytinijan.info.summary" = "Eggplant meatball tray";
"recipe.iq_tepsi_baytinijan.name" = "Tepsi baytinijan";
"recipe.iq_tepsi_baytinijan.step1.body" = "Slice %i1 and %i2 into rounds. Slice %i3 and %i4 and mince %i5.";
"recipe.iq_tepsi_baytinijan.step1.title" = "Prepare the vegetables";
"recipe.iq_tepsi_baytinijan.step10.body" = "Transfer the tepsi baytinijan to a serving platter and serve it hot with the rice alongside.";
"recipe.iq_tepsi_baytinijan.step10.title" = "Serve the dish";
"recipe.iq_tepsi_baytinijan.step2.body" = "Heat %i6 in a frying pan and fry the eggplant and potatoes in batches until lightly golden and partly tender. Drain them well.";
"recipe.iq_tepsi_baytinijan.step2.title" = "Fry the eggplant and potatoes";
"recipe.iq_tepsi_baytinijan.step3.body" = "Mix %i7 with %i8, %i9, %i10, and %i11, then shape the mixture into small meatballs.";
"recipe.iq_tepsi_baytinijan.step3.title" = "Make the meatballs";
"recipe.iq_tepsi_baytinijan.step4.body" = "Brown the meatballs lightly in the pan so they hold their shape, then remove them.";
"recipe.iq_tepsi_baytinijan.step4.title" = "Brown the meatballs";
"recipe.iq_tepsi_baytinijan.step5.body" = "Stir %i12 with %i13 and %i14 until smooth.";
"recipe.iq_tepsi_baytinijan.step5.title" = "Mix the sauce";
"recipe.iq_tepsi_baytinijan.step6.body" = "Arrange the eggplant, potatoes, onions, tomatoes, garlic, and meatballs in a deep baking tray in overlapping layers.";
"recipe.iq_tepsi_baytinijan.step6.title" = "Layer the tray";
"recipe.iq_tepsi_baytinijan.step7.body" = "Pour the tomato sauce over the tray and bake until the vegetables are fully tender, the meatballs are cooked through, and the sauce has reduced and coated the layers.";
"recipe.iq_tepsi_baytinijan.step7.title" = "Bake the tepsi";
"recipe.iq_tepsi_baytinijan.step8.body" = "Wash the basmati rice, add it to a saucepan with %i13 and %i14, bring to a boil, then cover and reduce the heat.";
"recipe.iq_tepsi_baytinijan.step8.title" = "Prepare the rice";
"recipe.iq_tepsi_baytinijan.step9.body" = "Cook the rice gently until the grains are tender and the liquid is absorbed, then let it rest covered.";
"recipe.iq_tepsi_baytinijan.step9.title" = "Cook the rice";
