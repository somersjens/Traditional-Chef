"recipe.tn_kammounia.drink.body" = "A medium-bodied red such as Grenache pairs well with the warm cumin and tomato richness. For a non-alcoholic option, serve hot Tunisian mint tea or sparkling water with lemon.";
"recipe.tn_kammounia.drink.summary" = "Red wine (Grenache)";
"recipe.tn_kammounia.info" = "Tunisian Kammounia is a traditional cumin-forward stew made with lamb liver simmered in a concentrated tomato-and-spice sauce, finished with fresh parsley and served hot with Tunisian bread for scooping and sharing at the table.";
"recipe.tn_kammounia.info.summary" = "Cumin liver stew";
"recipe.tn_kammounia.name" = "Kammounia";
"recipe.tn_kammounia.step1.body" = "Trim the %i1 and cut into bite-size pieces. Finely chop the %i2 and crush the %i3.";
"recipe.tn_kammounia.step1.title" = "Prep the liver";
"recipe.tn_kammounia.step2.body" = "Warm %i4 in a pot, add onion with a pinch of %i9, and cook until softened, then stir in garlic until fragrant.";
"recipe.tn_kammounia.step2.title" = "Start the base";
"recipe.tn_kammounia.step3.body" = "Stir in %i5 and cook until it darkens slightly, then add %i6, %i7, %i8, and %i10 and stir until the spices bloom.";
"recipe.tn_kammounia.step3.title" = "Toast tomato and spices";
"recipe.tn_kammounia.step4.body" = "Add %i12 and bring to a steady simmer, scraping the bottom so the sauce is smooth.";
"recipe.tn_kammounia.step4.title" = "Build the sauce";
"recipe.tn_kammounia.step5.body" = "Add the liver and simmer gently until just cooked and tender, stirring occasionally so it does not stick.";
"recipe.tn_kammounia.step5.title" = "Cook the liver";
"recipe.tn_kammounia.step6.body" = "Stir in %i11, taste and adjust salt, then serve hot with %i13 for scooping.";
"recipe.tn_kammounia.step6.title" = "Finish and serve";
"recipe.tn_kammounia.tool.t1" = "Heavy pot with lid";
"recipe.tn_kammounia.tool.t2" = "Cutting board";
"recipe.tn_kammounia.tool.t3" = "Chef knife";
