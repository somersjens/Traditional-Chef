"recipe.be_lapin_a_la_gueuze.step4.title" = "Cook the onions";
"recipe.be_lapin_a_la_gueuze.step5.body" = "Stir %i3 into the onions and cook briefly while stirring so it loses its raw taste.";
"recipe.be_lapin_a_la_gueuze.step5.title" = "Dust with flour";
