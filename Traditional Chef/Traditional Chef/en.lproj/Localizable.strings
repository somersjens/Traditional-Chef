"recipe.lb_warak_enab.drink.body" = "Pair with a crisp, citrusy white such as Sauvignon Blanc or dry Riesling to match the lemony finish and herbs. For a non-alcoholic option, serve plain yogurt drink or sparkling water with lemon.";
"recipe.lb_warak_enab.drink.summary" = "White wine (Sauvignon)";
"recipe.lb_warak_enab.info" = "Lebanese warak enab are grape leaves tightly rolled around a seasoned rice and meat filling, then gently simmered with lemon and garlic until tender and fragrant. They are served warm or at room temperature, traditionally with plain yogurt and pita bread, and are a staple on family tables and celebration spreads.";
"recipe.lb_warak_enab.info.summary" = "Stuffed grape leaves";
"recipe.lb_warak_enab.name" = "Stuffed grape leaves";
"recipe.lb_warak_enab.step1.body" = "Rinse the %i1 well to remove excess brine. Drain and set aside, trimming any tough stems.";
"recipe.lb_warak_enab.step1.title" = "Prepare the grape leaves";
"recipe.lb_warak_enab.step2.body" = "Rinse the %i2 and drain. Finely dice the %i4 and %i5, and chop the %i6 and %i7. Mix rice with %i3, tomatoes, onion, mint, parsley, %i8, %i9, %i10, and %i11 until evenly combined.";
"recipe.lb_warak_enab.step2.title" = "Make the filling";
"recipe.lb_warak_enab.step3.body" = "Lay a leaf vein-side up, place a small amount of filling near the base, fold in the sides, and roll tightly into a small cigar. Repeat until all filling is used.";
"recipe.lb_warak_enab.step3.title" = "Roll the warak enab";
"recipe.lb_warak_enab.step4.body" = "Lightly oil the bottom of the pot and scatter crushed %i12 over it. Pack the rolls snugly in layers so they cannot unravel.";
"recipe.lb_warak_enab.step4.title" = "Arrange in the pot";
"recipe.lb_warak_enab.step5.body" = "Mix %i14 with %i13 and pour over the rolls until they are just covered. Place a plate on top to keep them submerged and tightly packed.";
"recipe.lb_warak_enab.step5.title" = "Add cooking liquid";
"recipe.lb_warak_enab.step6.body" = "Bring to a gentle simmer, cover, and cook until the rice is fully tender and the leaves are soft, keeping the heat low so the rolls stay intact.";
"recipe.lb_warak_enab.step6.title" = "Simmer until tender";
"recipe.lb_warak_enab.step7.body" = "Let rest off the heat so the rolls set, then carefully lift onto a platter.";
"recipe.lb_warak_enab.step7.title" = "Rest and unmold";
"recipe.lb_warak_enab.step8.body" = "Serve warm or at room temperature with %i15 and warm %i16.";
"recipe.lb_warak_enab.step8.title" = "Serve";
