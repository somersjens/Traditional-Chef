"recipe.ng_moi_moi.drink.body" = "A crisp Chenin Blanc or dry Riesling pairs well with the peppery bean flavor and gentle sweetness from onions. If you prefer red, a light, low-tannin red served slightly chilled can work. Non-alcoholic pairing: chilled zobo (hibiscus) or sparkling water with lime.";
"recipe.ng_moi_moi.drink.summary" = "White wine (Chenin)";
"recipe.ng_moi_moi.info" = "Moi moi is a classic Nigerian steamed bean pudding made from peeled beans blended with peppers and onions, enriched with oil and seasoned, then steamed until set into a tender, savory cake. It is commonly served as a side or starter alongside rice dishes like jollof, but it can also stand alone, often with cooked egg and fish baked into each portion.";
"recipe.ng_moi_moi.info.summary" = "Steamed bean pudding";
"recipe.ng_moi_moi.name" = "Moi moi";
"recipe.ng_moi_moi.step1.body" = "Boil the %i9 until hard, cool in water, peel, and set aside.";
"recipe.ng_moi_moi.step1.title" = "Boil the eggs";
"recipe.ng_moi_moi.step2.body" = "Rinse the %i1. Roughly chop the %i2, %i3, and %i4. Flake the %i10 and remove any bones.";
"recipe.ng_moi_moi.step2.title" = "Prep and rinse";
"recipe.ng_moi_moi.step3.body" = "Blend the beans with the peppers, onion, %i6, %i7, and %i8 until very smooth, blending in batches if needed.";
"recipe.ng_moi_moi.step3.title" = "Blend the batter";
"recipe.ng_moi_moi.step4.body" = "Pour the blended batter into a bowl and stir in %i5 until fully incorporated and the batter looks slightly lighter.";
"recipe.ng_moi_moi.step4.title" = "Enrich the batter";
"recipe.ng_moi_moi.step5.body" = "Add %i11 to a large pot and bring to a steady simmer. Place a steamer rack inside.";
"recipe.ng_moi_moi.step5.title" = "Prepare steaming setup";
"recipe.ng_moi_moi.step6.body" = "Ladle batter into molds, add pieces of smoked fish and a portion of egg into each, then top with more batter and cover each mold.";
"recipe.ng_moi_moi.step6.title" = "Fill the molds";
"recipe.ng_moi_moi.step7.body" = "Arrange molds on the rack, cover the pot tightly, and steam until the moi moi is firm and set throughout, topping up the water if needed to prevent drying.";
"recipe.ng_moi_moi.step7.title" = "Steam until set";
"recipe.ng_moi_moi.step8.body" = "Turn off the heat and let the moi moi rest covered briefly so it firms up and releases cleanly.";
"recipe.ng_moi_moi.step8.title" = "Rest and cool slightly";
"recipe.ng_moi_moi.step9.body" = "Unmold and serve warm as a starter or side.";
"recipe.ng_moi_moi.step9.title" = "Serve";
