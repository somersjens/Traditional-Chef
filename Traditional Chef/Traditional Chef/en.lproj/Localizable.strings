"recipe.pe_lomo_saltado.step8.title" = "Sauce and combine";
"recipe.pe_lomo_saltado.step9.body" = "Turn off the heat, toss in the cilantro, then add the fries and mix quickly so they absorb some sauce but stay crisp.";
"recipe.pe_lomo_saltado.step9.title" = "Finish and add fries";
