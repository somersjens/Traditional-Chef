"recipe.uy_milanesa.drink.body" = "Pair with Uruguayan Tannat or a medium-bodied Malbec to match the savory, fried cutlet and beefy flavor. A crisp lager also works well. For a non-alcoholic option, serve sparkling water with lemon or a cold yerba mate infusion.";
"recipe.uy_milanesa.drink.summary" = "Red wine (Tannat)";
"recipe.uy_milanesa.info" = "Uruguayan milanesa is a thin slice of beef coated in flour, egg, and breadcrumbs, then fried until golden and crisp while staying tender inside. It is traditionally served immediately with French fries and lemon wedges to squeeze over the cutlet, a staple home and café dish across Uruguay.";
"recipe.uy_milanesa.info.summary" = "Crispy breaded cutlet";
"recipe.uy_milanesa.name" = "Milanesa";
"recipe.uy_milanesa.step1.body" = "Slice the %i1 into thin cutlets and pound them evenly so they cook fast and stay tender. Season both sides with %i6 and %i7.";
"recipe.uy_milanesa.step1.title" = "Prep the beef";
"recipe.uy_milanesa.step2.body" = "Place %i2 in one bowl. Beat the %i3 with minced %i4 and chopped %i5 in a second bowl. Place %i8 in a third bowl.";
"recipe.uy_milanesa.step2.title" = "Set up breading";
"recipe.uy_milanesa.step3.body" = "Coat each cutlet in flour, dip into the egg mixture, then press firmly into breadcrumbs so the coating adheres well. Let the breaded cutlets rest briefly so the crust sets.";
"recipe.uy_milanesa.step3.title" = "Bread the cutlets";
"recipe.uy_milanesa.step4.body" = "Cut the %i10 into fries, rinse briefly to remove surface starch, then dry thoroughly so they fry crisp.";
"recipe.uy_milanesa.step4.title" = "Cut and dry potatoes";
"recipe.uy_milanesa.step5.body" = "Fry the potatoes in %i11 until golden and crisp, turning as needed. Drain on paper towels and season with %i13 while hot.";
"recipe.uy_milanesa.step5.title" = "Fry the potatoes";
"recipe.uy_milanesa.step6.body" = "Heat %i9 in a skillet and fry the breaded cutlets until deep golden on one side, then turn and fry until cooked through and crisp. Drain on paper towels.";
"recipe.uy_milanesa.step6.title" = "Fry the milanesas";
"recipe.uy_milanesa.step7.body" = "Serve immediately with fries and %i12 wedges for squeezing over the milanesa.";
"recipe.uy_milanesa.step7.title" = "Serve";
