"recipe.mu_napolitaine.step4.body" = "Heat the oven. Roll the chilled dough out evenly and cut into matching round biscuits, re-rolling scraps as needed.";
"recipe.mu_napolitaine.step4.title" = "Roll and cut biscuits";
"recipe.mu_napolitaine.step5.body" = "Bake the biscuits until set and lightly firm, keeping them pale rather than browned, then remove from the oven.";
"recipe.mu_napolitaine.step5.title" = "Bake until pale";
"recipe.mu_napolitaine.step6.body" = "Cool the biscuits fully on a rack so they stay crisp and the filling will not melt.";
"recipe.mu_napolitaine.step6.title" = "Cool completely";
"recipe.mu_napolitaine.step7.body" = "Spread %i8 onto the flat side of half the biscuits and top with the remaining biscuits to form sandwiches.";
"recipe.mu_napolitaine.step7.title" = "Sandwich with jam";
"recipe.mu_napolitaine.step8.body" = "Whisk %i9 with %i10 and a small amount of %i11 to make a smooth, glossy pink icing that coats the top.";
"recipe.mu_napolitaine.step8.title" = "Mix pink icing";
"recipe.mu_napolitaine.step9.body" = "Dip or spread icing over the top of each sandwich biscuit, then immediately press the iced surface into %i12.";
