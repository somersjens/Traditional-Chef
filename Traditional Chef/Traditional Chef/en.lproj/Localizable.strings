"recipe.se_kottbullar.step2.title" = "Soak the breadcrumbs";
"recipe.se_kottbullar.step3.body" = "Combine %i1, %i2, onion, soaked breadcrumbs, %i6, %i7, %i8, and %i9. Mix until evenly combined, then shape into small meatballs.";
"recipe.se_kottbullar.step3.title" = "Mix the meatball mixture";
"recipe.se_kottbullar.step4.body" = "Peel %i18, cut them into even pieces, and boil them in salted water until tender.";
"recipe.se_kottbullar.step4.title" = "Start the potatoes";
"recipe.se_kottbullar.step5.body" = "Mix the cucumber with %i24, %i23, %i25, %i27, and dill, then leave it to pickle lightly while the rest cooks.";
"recipe.se_kottbullar.step5.title" = "Make the pressed cucumber";
"recipe.se_kottbullar.step6.body" = "Fry the meatballs in %i10, turning often, until browned all over and cooked through. Transfer them to a plate and keep the pan for the gravy.";
"recipe.se_kottbullar.step6.title" = "Brown the meatballs";
