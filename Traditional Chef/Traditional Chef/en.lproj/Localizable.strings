"recipe.vn_banh_da_lon.drink.body" = "A lightly sweet late-harvest white wine or demi-sec sparkling wine pairs well with the coconut and pandan aromas. For a non-alcoholic option, serve hot jasmine tea or unsweetened green tea.";
"recipe.vn_banh_da_lon.drink.summary" = "Dessert wine";
"recipe.vn_banh_da_lon.info" = "Banh da lon is a traditional southern Vietnamese steamed layer cake with alternating pandan-coconut and mung bean layers. It is soft, chewy, lightly sweet, and commonly served cut into small pieces for family gatherings, temple offerings, and festive snack tables.";
