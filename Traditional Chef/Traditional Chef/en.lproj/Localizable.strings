"recipe.ch_bundner_gerstensuppe.drink.body" = "A light Swiss red such as Pinot Noir pairs well with the smoky meat and creamy barley. A dry apple cider also fits. For a non-alcoholic option, serve hot black tea or sparkling apple juice.";
"recipe.ch_bundner_gerstensuppe.drink.summary" = "Red wine (Pinot Noir)";
"recipe.ch_bundner_gerstensuppe.info" = "Bündner Gerstensuppe is the classic barley soup of Graubünden, made with pearl barley, root vegetables, bacon, Bündnerfleisch, stock, and a little cream. It is traditionally served hot as a sustaining mountain meal, especially in cold weather, and is one of the best-known dishes of the canton.";
"recipe.ch_bundner_gerstensuppe.info.summary" = "Graubünden barley soup";
"recipe.ch_bundner_gerstensuppe.name" = "Barley soup";
"recipe.ch_bundner_gerstensuppe.step1.body" = "Slice %i4 and finely dice %i5, %i6, %i2, and %i3 so the soup cooks evenly and has a traditional rustic texture.";
"recipe.ch_bundner_gerstensuppe.step1.title" = "Prepare the ingredients";
"recipe.ch_bundner_gerstensuppe.step2.body" = "Melt %i1 in a large pot over medium heat. Add the bacon, Bündnerfleisch, leek, carrot, celery root, and %i7, then cook while stirring until the vegetables soften and the barley is well coated.";
"recipe.ch_bundner_gerstensuppe.step2.title" = "Sweat the base";
"recipe.ch_bundner_gerstensuppe.step3.body" = "Pour in %i8, stir well, and bring the soup to a boil.";
"recipe.ch_bundner_gerstensuppe.step3.title" = "Add the stock";
"recipe.ch_bundner_gerstensuppe.step4.body" = "Lower the heat and simmer gently until the barley is tender and the soup has thickened.";
"recipe.ch_bundner_gerstensuppe.step4.title" = "Simmer the soup";
"recipe.ch_bundner_gerstensuppe.step5.body" = "Stir in %i9 and season with %i10, %i11, and %i12. Cook briefly so the soup is fully hot and the seasoning is evenly distributed.";
"recipe.ch_bundner_gerstensuppe.step5.title" = "Finish the soup";
"recipe.ch_bundner_gerstensuppe.step6.body" = "Ladle the soup into warm bowls and serve immediately while hot.";
"recipe.ch_bundner_gerstensuppe.step6.title" = "Serve";
