"recipe.cn_chun_juan.step3.title" = "Marinate the pork";
"recipe.cn_chun_juan.step4.body" = "Heat the wok with a little oil, stir-fry the ginger and scallions until fragrant, add the pork and cook until separated, then add mushrooms, napa cabbage, and vermicelli.";
