"recipe.id_rendang.drink.body" = "A light-bodied Syrah or a crisp lager can stand up to the rich coconut reduction and warm spices. For a non-alcoholic pairing, serve hot jasmine tea or cold lime water.";
"recipe.id_rendang.drink.summary" = "Red wine (Syrah)";
"recipe.id_rendang.info" = "Rendang is a traditional Minangkabau beef dish from West Sumatra, Indonesia, slowly cooked in coconut milk and a rich spice paste until the sauce reduces and caramelizes onto tender meat. It is served for festive meals, ceremonies, and honored guests, typically with steamed rice and often with sambal on the side.";
"recipe.id_rendang.info.summary" = "Slow-cooked beef rendang";
"recipe.id_rendang.name" = "Beef rendang";
"recipe.id_rendang.step1.body" = "Cut the %i1 into large chunks. Slice the %i2, peel the %i3, and cut the fresh aromatics into smaller pieces for grinding.";
"recipe.id_rendang.step1.title" = "Prepare the beef and aromatics";
"recipe.id_rendang.step10.body" = "Serve the rendang hot with %i25 and %i26 on the side.";
"recipe.id_rendang.step10.title" = "Serve";
"recipe.id_rendang.step2.body" = "Grind the shallots, garlic, %i4, %i5, %i6, %i7, %i8, %i9, %i10, and %i11 into a smooth paste.";
"recipe.id_rendang.step2.title" = "Make the spice paste";
"recipe.id_rendang.step3.body" = "Toast the %i24 in a dry skillet until deep golden and fragrant, then grind or pound it into a coarse oily paste.";
"recipe.id_rendang.step3.title" = "Make toasted coconut paste";
"recipe.id_rendang.step4.body" = "Heat %i23 in a heavy pot and fry the spice paste until fragrant and darker, stirring constantly so it cooks through evenly.";
"recipe.id_rendang.step4.title" = "Fry the spice paste";
"recipe.id_rendang.step5.body" = "Add the beef and turn to coat in the paste, then add %i12, %i13, %i14, %i15, %i16, %i17, %i18, %i19, and %i20.";
"recipe.id_rendang.step5.title" = "Add beef and whole aromatics";
"recipe.id_rendang.step6.body" = "Pour in %i21 and %i22, bring to a gentle simmer, and cook uncovered over low heat, stirring occasionally as the sauce reduces.";
"recipe.id_rendang.step6.title" = "Start the slow simmer";
"recipe.id_rendang.step7.body" = "Continue cooking slowly until the liquid thickens and the oil begins to separate. Stir more frequently to prevent sticking as the sauce darkens.";
"recipe.id_rendang.step7.title" = "Reduce until thick";
"recipe.id_rendang.step8.body" = "Stir in the toasted coconut paste and keep cooking over low heat, stirring often, until the beef is very tender and coated in a dark rich rendang paste.";
"recipe.id_rendang.step8.title" = "Finish with toasted coconut";
"recipe.id_rendang.step9.body" = "Turn off the heat and let the rendang rest briefly so the seasoning settles and the paste clings fully to the meat.";
"recipe.id_rendang.step9.title" = "Rest the rendang";
