"recipe.pl_flaki.drink.body" = "Pair with a light-to-medium red such as Pinot Noir or Zweigelt, or a malty amber lager that complements the peppery, spiced broth. Non-alcoholic option: hot black tea with lemon or sparkling water.";
"recipe.pl_flaki.drink.summary" = "Red wine (Pinot Noir)";
"recipe.pl_flaki.info" = "Flaki is a classic Polish tripe soup built on a rich beef broth and heavily seasoned with marjoram, pepper, ginger, sweet paprika, and nutmeg. The tripe is cut into fine strips and simmered until tender, then combined with aromatic root vegetables and gently thickened for a warming, robust bowl often served as a hot course at celebrations and family gatherings, traditionally alongside a fresh bread roll.";
"recipe.pl_flaki.info.summary" = "Peppery tripe soup";
"recipe.pl_flaki.name" = "Tripe soup";
"recipe.pl_flaki.step1.body" = "Rinse the %i12 thoroughly, then cut it into thin strips. Crush the %i13 and keep it ready for later.";
"recipe.pl_flaki.step1.title" = "Rinse and prepare tripe";
"recipe.pl_flaki.step10.body" = "Whisk the loosened roux back into the pot and simmer gently until the soup thickens slightly and the flavors meld.";
"recipe.pl_flaki.step10.title" = "Thicken the soup";
"recipe.pl_flaki.step11.body" = "Stir in chopped %i22, then taste and adjust seasoning. Serve the soup hot with %i23.";
"recipe.pl_flaki.step11.title" = "Finish and serve";
"recipe.pl_flaki.step2.body" = "Put the tripe in a pot, cover with %i3, bring to a gentle simmer, and cook until the tripe is tender. Drain and set the tripe aside.";
"recipe.pl_flaki.step2.title" = "Tenderize the tripe";
"recipe.pl_flaki.step3.body" = "Put %i1 and %i2 in a stockpot, cover with %i3, and bring slowly to a simmer. Skim any foam from the surface.";
"recipe.pl_flaki.step3.title" = "Start the beef broth";
"recipe.pl_flaki.step4.body" = "Add %i4, %i5, %i6, %i7, %i8, %i9, %i10, and %i11. Simmer gently until the broth is rich and the beef is tender.";
"recipe.pl_flaki.step4.title" = "Simmer the broth with aromatics";
"recipe.pl_flaki.step5.body" = "Strain the broth into a clean pot. Pick out the cooked beef, discard bones and spent vegetables, and keep the clear broth hot.";
"recipe.pl_flaki.step5.title" = "Strain the broth";
"recipe.pl_flaki.step6.body" = "Add the cooked tripe to the hot broth. Shred the cooked beef and return it to the pot.";
"recipe.pl_flaki.step6.title" = "Combine broth and tripe";
"recipe.pl_flaki.step7.body" = "Grate the carrot, celery root, and parsley root into fine strands and stir them into the soup so they soften in the broth.";
"recipe.pl_flaki.step7.title" = "Add vegetables";
"recipe.pl_flaki.step8.body" = "Simmer gently until the vegetables are tender. Season with %i14, %i15, %i16, %i17, %i18, and %i19, then add the crushed garlic.";
"recipe.pl_flaki.step8.title" = "Simmer and season";
"recipe.pl_flaki.step9.body" = "Melt %i20 in a skillet, add %i21, and cook while whisking until smooth and lightly toasted. Whisk in a ladle of hot soup to loosen the roux.";
"recipe.pl_flaki.step9.title" = "Make a roux";
"recipe.pl_flaki.tool.t1" = "Large stockpot";
"recipe.pl_flaki.tool.t2" = "Fine sieve";
