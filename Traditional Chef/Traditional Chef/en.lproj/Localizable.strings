"recipe.be_waterzooi.step5.body" = "Lift out the chicken. Strain the broth and return it to the pot. Discard the aromatics and herb bundle.";
"recipe.be_waterzooi.step5.title" = "Strain the broth";
"recipe.be_waterzooi.step6.body" = "When cool enough to handle, remove the skin and bones and cut or pull the meat into serving pieces.";
"recipe.be_waterzooi.step6.title" = "Prepare the chicken";
"recipe.be_waterzooi.step7.body" = "Whisk %i12 with %i11 and %i13 until smooth.";
"recipe.be_waterzooi.step7.title" = "Make the liaison";
"recipe.be_waterzooi.step8.body" = "Whisk a ladle of hot broth into the liaison to warm it, then whisk it back into the pot off the heat.";
