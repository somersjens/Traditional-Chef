"recipe.sa_maqshush.drink.body" = "A lightly sweet dessert wine such as Muscat pairs well with the honey and rich ghee. For a non-alcoholic pairing, serve Arabic coffee or hot black tea.";
"recipe.sa_maqshush.drink.summary" = "Dessert wine (Muscat)";
"recipe.sa_maqshush.info" = "Maqshush is a traditional Saudi dessert and breakfast dish from Hail and northern Saudi Arabia, made from a yeasted batter of white and brown flour cooked into small soft pancakes, then torn and dressed generously with ghee and honey. It is especially associated with cold weather and family breakfasts, and is served hot so the topping soaks into the warm pieces.";
"recipe.sa_maqshush.info.summary" = "Honeyed small pancakes";
"recipe.sa_maqshush.name" = "Maqshush";
"recipe.sa_maqshush.step1.body" = "Whisk %i1, %i2, %i3, %i4, %i5, %i6, and %i7 together until the batter is smooth and pourable.";
"recipe.sa_maqshush.step1.title" = "Make the batter";
"recipe.sa_maqshush.step2.body" = "Leave the batter until it becomes airy and lightly risen.";
"recipe.sa_maqshush.step2.title" = "Let the batter rise";
"recipe.sa_maqshush.step3.body" = "Heat the griddle well so the batter sets quickly and cooks evenly.";
"recipe.sa_maqshush.step3.title" = "Heat the griddle";
"recipe.sa_maqshush.step4.body" = "Ladle small rounds of batter onto the griddle and cook until the tops show bubbles and the undersides are set and lightly golden.";
"recipe.sa_maqshush.step4.title" = "Cook the first side";
"recipe.sa_maqshush.step5.body" = "Turn the rounds and cook briefly on the second side until fully set and soft.";
"recipe.sa_maqshush.step5.title" = "Turn and finish cooking";
"recipe.sa_maqshush.step6.body" = "Continue cooking the rest of the batter in batches until all the maqshush rounds are ready.";
"recipe.sa_maqshush.step6.title" = "Cook the remaining batter";
"recipe.sa_maqshush.step7.body" = "Tear the warm maqshush rounds by hand into bite-sized pieces and spread them on a serving platter.";
"recipe.sa_maqshush.step7.title" = "Tear the bread pieces";
"recipe.sa_maqshush.step8.body" = "Heat %i8 gently just until fully melted and fluid.";
"recipe.sa_maqshush.step8.title" = "Warm the topping";
"recipe.sa_maqshush.step9.body" = "Pour the warm ghee and %i9 over the torn maqshush and serve immediately while hot.";
"recipe.sa_maqshush.step9.title" = "Finish and serve";
