"recipe.de_schweinshaxe.drink.summary" = "Beer (Märzen)";
"recipe.de_schweinshaxe.info" = "Schweinshaxe is a traditional German roasted pork knuckle with blistered, crackling skin and juicy meat, popular in Bavaria and served in beer halls. The knuckle is roasted slowly, then finished at higher heat for crisp skin, and it is traditionally accompanied by potato dumplings and sauerkraut, which balance the rich pork and catch the roasting juices.";
"recipe.de_schweinshaxe.info.summary" = "Bavarian crackling knuckle";
"recipe.de_schweinshaxe.name" = "Pork knuckle";
