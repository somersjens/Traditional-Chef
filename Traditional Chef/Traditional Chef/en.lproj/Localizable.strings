"recipe.ir_bastani_sonnati.drink.body" = "Fragrant dessert wines like Muscat or late-harvest Riesling complement the saffron and rose without masking them. If you prefer something less sweet, choose a sparkling wine with bright acidity. Non-alcoholic: strong Persian black tea or cold sparkling water with a squeeze of lime.";
"recipe.ir_bastani_sonnati.drink.summary" = "Sweet wine (Muscat)";
"recipe.ir_bastani_sonnati.info" = "Bastani Sonnati is Iran’s traditional saffron-and-rosewater ice cream, studded with pistachios and often flecked with frozen cream for a rich, slightly elastic texture. It’s a classic finish to a Persian meal and is commonly served as an ice cream sandwich between thin wafers, or scooped into bowls and enjoyed with tea.";
"recipe.ir_bastani_sonnati.info.summary" = "Rose-saffron ice cream";
"recipe.ir_bastani_sonnati.name" = "Bastani sonnati";
