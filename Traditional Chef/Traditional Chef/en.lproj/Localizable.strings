"recipe.ua_borshch.step13.title" = "Dress the buns";
"recipe.ua_borshch.step14.body" = "Stir %i13, %i14, and the garlic into the soup and cook briefly just until fragrant.";
"recipe.ua_borshch.step14.title" = "Finish the borshch";
"recipe.ua_borshch.step15.body" = "Take the pot off the heat and let the borshch stand so the flavors settle and deepen.";
"recipe.ua_borshch.step15.title" = "Rest before serving";
"recipe.ua_borshch.step16.body" = "Ladle the borshch into bowls, add %i15 on top, and serve immediately with the garlic pampushky.";
"recipe.ua_borshch.step16.title" = "Serve the dish";
"recipe.ua_borshch.step2.body" = "Cook the beef gently until the broth is rich and the meat is tender enough to pull from the bone.";
"recipe.ua_borshch.step2.title" = "Simmer the meat";
