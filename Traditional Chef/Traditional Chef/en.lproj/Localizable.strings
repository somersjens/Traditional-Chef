"recipe.th_gaeng_phet_ped_yang.drink.body" = "An off-dry Riesling works well with the rich duck, coconut milk, and sweet-spicy red curry flavors. For a non-alcoholic pairing, serve chilled jasmine tea or plain cold water with lime.";
"recipe.th_gaeng_phet_ped_yang.drink.summary" = "White wine (Riesling)";
"recipe.th_gaeng_phet_ped_yang.info" = "Gaeng Phet Ped Yang is a traditional Thai red curry made with roasted duck simmered in coconut milk with red curry paste, pineapple, tomatoes, makrut lime leaves, and Thai basil. It is typically served as part of a shared meal with jasmine rice, where the rich duck and sweet-fragrant curry sauce balance each other.";
"recipe.th_gaeng_phet_ped_yang.info.summary" = "Roast duck red curry";
