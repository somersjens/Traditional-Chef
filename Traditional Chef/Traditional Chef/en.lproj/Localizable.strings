"recipe.lk_fish_ambul_thiyal.step5.title" = "Marinate the fish";
"recipe.lk_fish_ambul_thiyal.step6.body" = "Line the clay pot with %i12, %i13, and %i14, then place the fish in a single layer and scrape in all remaining paste.";
"recipe.lk_fish_ambul_thiyal.step6.title" = "Arrange the pot";
"recipe.lk_fish_ambul_thiyal.step7.body" = "Add a little goraka liquid and water to loosen the paste around the fish, then season with the remaining %i15.";
"recipe.lk_fish_ambul_thiyal.step7.title" = "Add cooking liquid";
"recipe.lk_fish_ambul_thiyal.step8.body" = "Cook over low heat until the fish is done and the sauce reduces to a thick coating, gently shaking the pot occasionally instead of stirring hard.";
"recipe.lk_fish_ambul_thiyal.step8.title" = "Cook the ambul thiyal";
"recipe.lk_fish_ambul_thiyal.step9.body" = "Continue cooking briefly until the curry is nearly dry and intensely aromatic, then rest off the heat so the fish firms up.";
"recipe.lk_fish_ambul_thiyal.step9.title" = "Dry down and rest";
