"recipe.za_potjiekos.drink.body" = "A South African Pinotage or a medium-bodied Shiraz matches the beefy, slow-cooked depth and tomato richness. If you prefer white, choose a fuller Chenin Blanc. Non-alcoholic pairing: rooibos tea (hot or iced) with lemon.";
"recipe.za_potjiekos.drink.summary" = "Red wine (Pinotage)";
"recipe.za_potjiekos.info" = "Potjiekos is a traditional South African cast-iron pot stew cooked slowly over coals, built by browning meat, then layering vegetables and letting everything simmer gently without stirring so the flavours meld while the layers steam and braise. It is served straight from the pot as a hearty communal main course, traditionally accompanied by plain rice to soak up the rich gravy.";
"recipe.za_potjiekos.info.summary" = "Coal-pot stew";
"recipe.za_potjiekos.name" = "Potjiekos";
"recipe.za_potjiekos.step1.body" = "Cut the %i1 into even pieces if needed. Chop the %i2 and %i3, and cut the %i8, %i9, %i10, %i11, %i12, and %i13 into chunky pieces so they cook evenly.";
"recipe.za_potjiekos.step1.title" = "Prepare the ingredients";
"recipe.za_potjiekos.step2.body" = "Heat the potjie pot and add %i4. Brown the beef in batches until well coloured, seasoning with some of the %i5 and %i6 as it browns.";
"recipe.za_potjiekos.step2.title" = "Brown the beef";
"recipe.za_potjiekos.step3.body" = "Add the onion to the potjie and cook until softened, then add the garlic and cook briefly.";
"recipe.za_potjiekos.step3.title" = "Soften the onion and garlic";
"recipe.za_potjiekos.step4.body" = "Stir in %i14 and %i15, then return all the beef to the pot and tuck in the %i7.";
"recipe.za_potjiekos.step4.title" = "Build the base";
"recipe.za_potjiekos.step5.body" = "Layer the vegetables on top of the meat in this order: carrots, potatoes, butternut squash, green beans, cabbage, then tomatoes. Do not stir after layering.";
"recipe.za_potjiekos.step5.title" = "Layer the vegetables";
"recipe.za_potjiekos.step6.body" = "Pour in %i16 and enough %i18 to create simmering liquid at the bottom of the pot. Cover and simmer gently over low heat until the beef is tender and the vegetables are cooked through, keeping the lid on and not stirring.";
"recipe.za_potjiekos.step6.title" = "Slow cook without stirring";
"recipe.za_potjiekos.step7.body" = "Rinse the %i17. Combine it with water and a pinch of salt, bring to a simmer, then cover and cook gently until tender.";
"recipe.za_potjiekos.step7.title" = "Cook the rice";
"recipe.za_potjiekos.step8.body" = "Remove the rice from the heat and leave covered so it steams and fluffs up.";
"recipe.za_potjiekos.step8.title" = "Rest the rice";
"recipe.za_potjiekos.step9.body" = "Taste the gravy at the bottom and adjust seasoning with the remaining salt and pepper if needed. Serve the potjiekos straight from the pot with the rice.";
"recipe.za_potjiekos.step9.title" = "Finish and serve";
