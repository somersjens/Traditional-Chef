"recipe.fj_kokoda.drink.body" = "A chilled Chardonnay matches the citrus and coconut well. A crisp lager also works. For a non-alcoholic option, serve iced lemon water or chilled coconut water.";
"recipe.fj_kokoda.drink.summary" = "White wine (Chardonnay)";
"recipe.fj_kokoda.info" = "Kokoda is a traditional Fijian dish of very fresh white fish cured in lime and lemon juice, then folded with coconut milk, onion, tomato, chili, and fresh herbs. It is served well chilled and is commonly eaten at family gatherings, village meals, and seaside feasts, often with plain boiled cassava.";
"recipe.fj_kokoda.info.summary" = "Fijian citrus fish salad";
"recipe.fj_kokoda.name" = "Kokoda";
"recipe.fj_kokoda.step1.body" = "Trim the %i1 and cut it into small cubes. Finely dice the %i4 and %i6, mince the %i5, slice the %i7, and roughly chop the %i8.";
"recipe.fj_kokoda.step1.title" = "Prepare the fish and aromatics";
"recipe.fj_kokoda.step2.body" = "Squeeze the %i2 and %i3 until you have enough juice to fully cover the fish in a non-reactive bowl.";
"recipe.fj_kokoda.step2.title" = "Juice the citrus";
"recipe.fj_kokoda.step3.body" = "Add the fish to the citrus juice with half of the %i10, mix well, cover, and refrigerate until the flesh turns opaque all the way through.";
"recipe.fj_kokoda.step3.title" = "Cure the fish";
"recipe.fj_kokoda.step4.body" = "Peel the %i11, cut it into serving pieces, and place it in a saucepan with %i12 and the remaining %i13. Bring to a boil and cook until tender.";
"recipe.fj_kokoda.step4.title" = "Boil the cassava";
"recipe.fj_kokoda.step5.body" = "Drain the cured fish very well through a fine sieve and transfer it to a clean bowl so the finished dish stays creamy rather than sharp.";
"recipe.fj_kokoda.step5.title" = "Drain the fish";
"recipe.fj_kokoda.step6.body" = "Add the onion, tomato, chili, spring onion, coriander, and %i9 to the fish. Fold gently until everything is evenly combined.";
"recipe.fj_kokoda.step6.title" = "Mix the kokoda";
"recipe.fj_kokoda.step7.body" = "Refrigerate the kokoda again so it becomes thoroughly cold and the flavors settle together.";
"recipe.fj_kokoda.step7.title" = "Chill the dish";
"recipe.fj_kokoda.step8.body" = "Drain the cassava and arrange it alongside the chilled kokoda. Serve the kokoda in small bowls, traditionally coconut shells if available.";
"recipe.fj_kokoda.step8.title" = "Drain and serve";
"recipe.fj_kokoda.tool.t1" = "Chef knife";
"recipe.fj_kokoda.tool.t2" = "Cutting board";
"recipe.fj_kokoda.tool.t3" = "Mixing bowl";
"recipe.fj_kokoda.tool.t4" = "Fine sieve";
"recipe.fj_kokoda.tool.t5" = "Saucepan";
"recipe.fj_kokoda.tool.t6" = "Colander";
"recipe.fj_kokoda.tool.t7" = "Refrigerator";
"recipe.fj_kokoda.tool.t8" = "Serving bowls";
"recipe.fj_palusami.drink.body" = "An off-dry Riesling balances the rich coconut and savory filling. A light lager also pairs well. For a non-alcoholic option, serve chilled lemon water or unsweetened iced tea.";
"recipe.fj_palusami.drink.summary" = "White wine (Riesling)";
"recipe.fj_palusami.info" = "Fijian palusami is a feast dish of taro leaves wrapped around a rich filling of coconut cream, onion, and canned meat, then baked until soft and succulent. It is closely associated with lovo cooking and celebratory family meals, but it is also prepared in home ovens for communal gatherings and Sunday lunch.";
"recipe.fj_palusami.info.summary" = "Taro leaf feast parcels";
"recipe.fj_palusami.name" = "Palusami";
"recipe.fj_palusami.step1.body" = "Wash the %i1, trim away the tough stems and central stem area, and set them aside. Finely slice the %i3, then mix it with %i4, %i2, %i5, and %i6 until evenly combined.";
"recipe.fj_palusami.step1.title" = "Prepare the leaves and filling";
"recipe.fj_palusami.step2.body" = "Line each small bowl with several taro leaves, making sure they overlap well. Divide the filling between the leaf cups, fold the leaves up and over to enclose the filling, then wrap each parcel tightly in aluminium foil.";
"recipe.fj_palusami.step2.title" = "Form the parcels";
"recipe.fj_palusami.step3.body" = "Arrange the parcels in a roasting tray and bake until the taro leaves are fully tender and the filling is hot and fragrant.";
"recipe.fj_palusami.step3.title" = "Bake the palusami";
"recipe.fj_palusami.step4.body" = "Remove the tray from the oven and let the parcels sit briefly so the filling settles and the leaves hold together.";
"recipe.fj_palusami.step4.title" = "Rest the parcels";
"recipe.fj_palusami.step5.body" = "Open the parcels carefully and serve hot, spooning any rich coconut juices back over the palusami.";
"recipe.fj_palusami.step5.title" = "Serve";
"recipe.fj_palusami.tool.t1" = "Chef knife";
"recipe.fj_palusami.tool.t2" = "Cutting board";
"recipe.fj_palusami.tool.t3" = "Mixing bowl";
"recipe.fj_palusami.tool.t4" = "Small bowls";
"recipe.fj_palusami.tool.t5" = "Aluminium foil";
"recipe.fj_palusami.tool.t6" = "Roasting tray";
"recipe.fj_palusami.tool.t7" = "Oven";
"recipe.fj_vakalolo.drink.body" = "Sweet black tea suits the rich cassava and coconut well. For an alcoholic pairing, a late harvest Riesling works nicely in small glasses. For a non-alcoholic option, serve hot black tea or chilled coconut water.";
"recipe.fj_vakalolo.drink.summary" = "Tea";
"recipe.fj_vakalolo.info" = "Vakalolo is a traditional Fijian steamed dessert made by mixing grated cassava with coconut, sugar, and warming spices, then wrapping it in banana leaves and steaming until firm and fragrant. It is commonly served at family gatherings, village functions, and afternoon tea, and is eaten warm or at room temperature.";
"recipe.fj_vakalolo.info.summary" = "Cassava coconut pudding";
"recipe.fj_vakalolo.name" = "Vakalolo";
"recipe.fj_vakalolo.step1.body" = "Wash the %i6, trim them into wrapping pieces, and soften them briefly over heat so they bend without splitting. Peel the %i1 and grate it finely. Grate the %i4.";
"recipe.fj_vakalolo.step1.title" = "Prepare the leaves and cassava";
"recipe.fj_vakalolo.step2.body" = "Combine the grated cassava, %i2, %i3, ginger, and %i5 in a mixing bowl. Mix thoroughly until the sugar is evenly distributed.";
"recipe.fj_vakalolo.step2.title" = "Make the mixture";
"recipe.fj_vakalolo.step3.body" = "Divide the mixture into equal portions, place each portion on a banana leaf piece, fold into tight parcels, and secure them well so no filling escapes during steaming.";
"recipe.fj_vakalolo.step3.title" = "Wrap the parcels";
"recipe.fj_vakalolo.step4.body" = "Set the parcels in a steamer over boiling %i7 and steam until the cassava is fully cooked, firm, and fragrant.";
"recipe.fj_vakalolo.step4.title" = "Steam the vakalolo";
"recipe.fj_vakalolo.step5.body" = "Remove the parcels from the steamer and let them rest briefly so they set and become easier to unwrap.";
"recipe.fj_vakalolo.step5.title" = "Cool slightly";
"recipe.fj_vakalolo.step6.body" = "Open the banana leaves and serve the vakalolo warm or at room temperature.";
"recipe.fj_vakalolo.step6.title" = "Serve";
