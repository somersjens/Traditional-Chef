"recipe.pl_kluski_z_makiem.drink.body" = "Pair with a lightly sweet dessert wine such as late-harvest Riesling or a small glass of Tokaji to echo the honeyed poppy-seed flavors. A creamy porter can also complement the nutty notes. Non-alcoholic option: hot black tea with lemon or warm milk.";
"recipe.pl_kluski_z_makiem.drink.summary" = "Dessert wine (Riesling)";
"recipe.pl_kluski_z_makiem.info" = "Kluski z makiem is a traditional Polish Wigilia sweet served after the meatless supper: tender egg noodles folded into a rich poppy-seed mixture cooked with milk, butter, and honey, then studded with raisins and walnuts. The poppy seeds are ground to make a fragrant, creamy mass that coats every strand, creating a comforting, festive dessert often enjoyed slightly warm or chilled.";
"recipe.pl_kluski_z_makiem.info.summary" = "Wigilia poppy noodles";
"recipe.pl_kluski_z_makiem.name" = "Poppy seed noodles";
"recipe.pl_kluski_z_makiem.step1.body" = "Combine %i1 and %i4 in a bowl, make a well, add %i2 and %i3, and knead until smooth and elastic. Cover the dough so it does not dry out.";
"recipe.pl_kluski_z_makiem.step1.title" = "Make the noodle dough";
"recipe.pl_kluski_z_makiem.step2.body" = "Let the dough rest covered so it relaxes and rolls out evenly.";
"recipe.pl_kluski_z_makiem.step2.title" = "Rest the dough";
"recipe.pl_kluski_z_makiem.step3.body" = "Roll the dough thinly, then cut into small noodles. Spread them out so they do not stick together.";
"recipe.pl_kluski_z_makiem.step3.title" = "Roll and cut noodles";
"recipe.pl_kluski_z_makiem.step4.body" = "Warm %i8 in a saucepan. Grind the %i7 finely, then add them to the hot milk and cook gently while stirring.";
"recipe.pl_kluski_z_makiem.step4.title" = "Start the poppy mixture";
"recipe.pl_kluski_z_makiem.step5.body" = "Stir in %i9 until melted, then sweeten with %i10, %i11, and %i12. Add %i13 and chopped %i14 and cook briefly until everything is well combined.";
"recipe.pl_kluski_z_makiem.step5.title" = "Finish the poppy mass";
"recipe.pl_kluski_z_makiem.step6.body" = "Bring %i5 to a boil in a large pot and season it with %i6. Add the noodles and stir so they do not clump.";
"recipe.pl_kluski_z_makiem.step6.title" = "Boil the noodles";
"recipe.pl_kluski_z_makiem.step7.body" = "Cook until tender, then drain thoroughly in a colander and return the noodles to the pot.";
"recipe.pl_kluski_z_makiem.step7.title" = "Drain the noodles";
"recipe.pl_kluski_z_makiem.step8.body" = "Add the warm poppy-seed mixture to the noodles and mix gently until evenly coated. Serve warm or chill and serve cold.";
"recipe.pl_kluski_z_makiem.step8.title" = "Combine and serve";
