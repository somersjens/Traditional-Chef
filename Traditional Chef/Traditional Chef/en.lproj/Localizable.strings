"recipe.mt_aljotta.drink.body" = "A dry, crisp white wine such as Vermentino or Sauvignon Blanc pairs well with the bright lemony broth and delicate fish. A good non-alcoholic option is chilled sparkling water with lemon.";
"recipe.mt_aljotta.drink.summary" = "White wine (Vermentino)";
"recipe.mt_aljotta.info" = "Aljotta is Malta’s traditional fish soup, especially associated with coastal cooking and Lenten meals. It is a light but full-flavoured broth built on fish, garlic, onion, tomatoes, herbs, rice, and lemon, and is served hot as a complete main course.";
"recipe.mt_aljotta.info.summary" = "Maltese fish soup";
"recipe.mt_aljotta.name" = "Aljotta";
"recipe.mt_aljotta.step1.body" = "Peel and chop %i2 and %i3, chop %i5, and prepare %i6 and %i7.";
"recipe.mt_aljotta.step1.title" = "Prepare the base";
"recipe.mt_aljotta.step2.body" = "Heat %i4 in the pot and cook the onion and garlic gently until soft and fragrant without browning.";
"recipe.mt_aljotta.step2.title" = "Soften the aromatics";
"recipe.mt_aljotta.step3.body" = "Add the tomatoes, mint, and marjoram and cook briefly until the tomatoes start to break down.";
"recipe.mt_aljotta.step3.title" = "Build the soup";
"recipe.mt_aljotta.step4.body" = "Add %i1, %i8, %i11, and %i12. Bring to a gentle boil, lower the heat, and simmer until the fish is cooked and the broth is rich.";
"recipe.mt_aljotta.step4.title" = "Simmer the fish broth";
"recipe.mt_aljotta.step5.body" = "Lift out the fish and let it cool just enough to handle. Remove the skin and bones, keep the flesh in pieces, and strain the broth back into the pot.";
"recipe.mt_aljotta.step5.title" = "Clean and strain";
"recipe.mt_aljotta.step6.body" = "Bring the strained broth back to a simmer, add %i9, and cook until tender.";
"recipe.mt_aljotta.step6.title" = "Cook the rice";
"recipe.mt_aljotta.step7.body" = "Return the fish flesh to the pot and stir in %i10. Heat through gently without breaking up the fish too much.";
"recipe.mt_aljotta.step7.title" = "Finish the soup";
"recipe.mt_aljotta.step8.body" = "Taste and adjust the seasoning, then ladle the aljotta into bowls and serve immediately.";
"recipe.mt_aljotta.step8.title" = "Serve";
