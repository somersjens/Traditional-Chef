"recipe.nz_whitebait_fritter.drink.body" = "A crisp Sauvignon Blanc works well with the delicate fish and lemon. A light lager is also a traditional-style match. For a non-alcoholic option, serve sparkling water with lemon or hot black tea.";
"recipe.nz_whitebait_fritter.drink.summary" = "White wine (Sauvignon)";
"recipe.nz_whitebait_fritter.info" = "New Zealand whitebait fritters are a long-standing seasonal classic, especially associated with the West Coast and spring whitebait runs. The traditional version keeps the mixture simple so the delicate fish remain the focus, then serves the fritter hot between slices of buttered white bread with lemon.";
"recipe.nz_whitebait_fritter.info.summary" = "Seasonal whitebait fritter";
"recipe.nz_whitebait_fritter.name" = "Whitebait fritter";
"recipe.nz_whitebait_fritter.step1.body" = "Cut the %i8 into wedges and butter the %i9 with %i10 so it is ready for serving as soon as the fritters leave the pan.";
"recipe.nz_whitebait_fritter.step1.title" = "Prepare the serving ingredients";
"recipe.nz_whitebait_fritter.step2.body" = "Beat the %i2 in a mixing bowl, then stir in the %i3, %i4, and %i5 until smooth.";
"recipe.nz_whitebait_fritter.step2.title" = "Make the batter";
"recipe.nz_whitebait_fritter.step3.body" = "Add the %i1 and fold gently so the fish stay intact and are evenly coated with the egg mixture.";
"recipe.nz_whitebait_fritter.step3.title" = "Fold in the whitebait";
"recipe.nz_whitebait_fritter.step4.body" = "Heat the frying pan with %i6 and %i7 until the butter foams and the pan is hot but not smoking.";
"recipe.nz_whitebait_fritter.step4.title" = "Heat the pan";
"recipe.nz_whitebait_fritter.step5.body" = "Spoon the mixture into the pan as large fritters and cook gently until the underside is set and lightly golden.";
"recipe.nz_whitebait_fritter.step5.title" = "Cook the first side";
"recipe.nz_whitebait_fritter.step6.body" = "Turn the fritters carefully with a fish slice and cook until just set through, keeping them tender rather than dry.";
"recipe.nz_whitebait_fritter.step6.title" = "Turn and finish cooking";
"recipe.nz_whitebait_fritter.step7.body" = "Transfer the fritters to plates and serve immediately between slices of buttered white bread with lemon wedges for squeezing over.";
"recipe.nz_whitebait_fritter.step7.title" = "Serve traditionally";
