"recipe.ve_hallaca.drink.body" = "Serve with a fresh dry white wine that will not overpower the rich filling and aromatic corn dough. A light lager also works well. For a non-alcoholic option, serve papelón con limón or black tea.";
"recipe.ve_hallaca.drink.summary" = "White wine";
"recipe.ve_hallaca.info" = "Hallaca is the classic Venezuelan Christmas dish, made from annatto-colored corn dough filled with a rich guiso of beef, pork, and chicken, then garnished with raisins, olives, capers, onion, and pepper before being wrapped in plantain leaves and boiled. It is a festive preparation traditionally made in batches and served hot during holiday gatherings.";
"recipe.ve_hallaca.info.summary" = "Christmas hallaca parcels";
"recipe.ve_hallaca.name" = "Hallaca";
"recipe.ve_hallaca.step1.body" = "Cut %i1, %i2, and %i3 into small pieces. Chop %i4, %i5, %i6, %i7, and %i8.";
"recipe.ve_hallaca.step1.title" = "Prepare the guiso base";
"recipe.ve_hallaca.step10.body" = "Fold the banana leaves over the filling to enclose it completely, then tie each hallaca securely with kitchen twine.";
"recipe.ve_hallaca.step10.title" = "Wrap and tie";
"recipe.ve_hallaca.step11.body" = "Place the hallacas in a large pot of boiling %i27 and cook them until the dough is set and the parcels are fully heated through.";
"recipe.ve_hallaca.step11.title" = "Boil the hallacas";
"recipe.ve_hallaca.step12.body" = "Lift the hallacas from the water and leave them to rest briefly so the wrapping firms up and excess moisture drains away.";
"recipe.ve_hallaca.step12.title" = "Drain and rest";
"recipe.ve_hallaca.step13.body" = "Serve the hallacas hot in their leaves and unwrap them at the table.";
"recipe.ve_hallaca.step13.title" = "Serve";
