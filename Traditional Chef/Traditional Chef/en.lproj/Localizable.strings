"recipe.in_rasmalai.drink.body" = "A lightly sweet dessert wine such as Moscato dAsti complements the saffron-cardamom milk and delicate chenna without overwhelming it. Masala chai also pairs well. For a non-alcoholic option, serve plain chilled milk or light saffron milk.";
"recipe.in_rasmalai.drink.summary" = "Dessert wine (Moscato dAsti)";
"recipe.in_rasmalai.info" = "Rasmalai is a classic Indian dessert of soft chenna patties first cooked in light syrup and then soaked in thickened saffron-cardamom milk. It is traditionally served chilled at festive meals, weddings, and celebrations, often garnished with pistachios and almonds.";
"recipe.in_rasmalai.info.summary" = "Saffron milk patties";
"recipe.in_rasmalai.name" = "Rasmalai";
"recipe.in_rasmalai.step1.body" = "Slice the %i11 and %i12, and soak the %i10 in a little warm milk taken from the milk for the rabri.";
"recipe.in_rasmalai.step1.title" = "Prepare garnish and saffron";
"recipe.in_rasmalai.step10.body" = "Simmer the %i7 in a heavy pot, stirring and scraping the sides regularly.";
"recipe.in_rasmalai.step10.title" = "Start the rabri milk";
"recipe.in_rasmalai.step11.body" = "Continue simmering until the milk thickens noticeably and becomes rich and creamy.";
"recipe.in_rasmalai.step11.title" = "Reduce the rabri milk";
"recipe.in_rasmalai.step12.body" = "Add %i8, %i9, and the soaked saffron milk, then simmer until the sugar dissolves and the rabri is smooth.";
"recipe.in_rasmalai.step12.title" = "Sweeten and flavor the rabri";
"recipe.in_rasmalai.step13.body" = "Lift the cooked patties from the syrup, gently press lightly to release excess syrup, and place them into the warm rabri.";
"recipe.in_rasmalai.step13.title" = "Transfer patties to rabri";
"recipe.in_rasmalai.step14.body" = "Let the patties soak so they absorb the saffron-cardamom milk and soften further.";
"recipe.in_rasmalai.step14.title" = "Soak in rabri";
"recipe.in_rasmalai.step15.body" = "Cool and refrigerate until thoroughly chilled and the rabri thickens around the patties.";
"recipe.in_rasmalai.step15.title" = "Chill the rasmalai";
"recipe.in_rasmalai.step16.body" = "Top with sliced almonds and pistachios, then serve the rasmalai chilled.";
"recipe.in_rasmalai.step16.title" = "Garnish and serve";
"recipe.in_rasmalai.step2.body" = "Bring the %i1 to a boil in a large pot, stirring so it does not catch on the bottom.";
"recipe.in_rasmalai.step2.title" = "Boil the milk for chenna";
"recipe.in_rasmalai.step3.body" = "Mix the %i2 with %i3, lower the heat, and add it gradually until the curds separate clearly from the whey.";
"recipe.in_rasmalai.step3.title" = "Curdle the milk";
"recipe.in_rasmalai.step4.body" = "Pour through a cloth-lined colander and rinse the chenna under normal water to remove sourness.";
"recipe.in_rasmalai.step4.title" = "Strain and rinse the chenna";
"recipe.in_rasmalai.step5.body" = "Gather the cloth and let the chenna drain until soft and slightly moist but not wet.";
"recipe.in_rasmalai.step5.title" = "Drain the chenna";
"recipe.in_rasmalai.step6.body" = "Transfer the chenna to a bowl and knead until smooth and creamy with no grainy bits.";
"recipe.in_rasmalai.step6.title" = "Knead the chenna";
"recipe.in_rasmalai.step7.body" = "Divide and shape into smooth small discs, keeping them even for uniform cooking and leaving space for expansion.";
"recipe.in_rasmalai.step7.title" = "Shape the patties";
"recipe.in_rasmalai.step8.body" = "Boil %i4, %i5, and %i6 in a wide pot until dissolved and steadily bubbling.";
"recipe.in_rasmalai.step8.title" = "Make the cooking syrup";
"recipe.in_rasmalai.step9.body" = "Add the patties to the boiling syrup, cover, and cook until puffed, soft, and spongy.";
"recipe.in_rasmalai.step9.title" = "Cook the chenna patties";
