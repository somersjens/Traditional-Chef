"recipe.kr_doenjang_jjigae.drink.body" = "A crisp dry white such as Sauvignon Blanc or a light unoaked Chardonnay can balance the savory fermented depth of the stew. Beer pairing: clean pale lager. Non-alcoholic pairing: roasted barley tea.";
"recipe.kr_doenjang_jjigae.drink.summary" = "White wine (Sauvignon)";
"recipe.kr_doenjang_jjigae.info" = "Doenjang jjigae is a traditional Korean soybean paste stew made with anchovy-kelp broth, doenjang, tofu, and everyday vegetables such as potato, zucchini, and onion. It is a staple home-style dish, typically served bubbling hot with steamed rice as part of a Korean meal.";
"recipe.kr_doenjang_jjigae.info.summary" = "Soybean paste stew";
"recipe.kr_doenjang_jjigae.name" = "Doenjang jjigae";
