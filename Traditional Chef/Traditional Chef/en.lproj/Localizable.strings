"recipe.sr_saoto_soep.info" = "Saoto soep is a traditional Surinamese soup with Javanese roots, built from a fragrant chicken broth and served with shredded chicken, bean sprouts, boiled egg, fried potato sticks, rice vermicelli, celery, and a little ketjap sambal. It is assembled in the bowl and served hot as a complete meal, often for lunch or dinner.";
"recipe.sr_saoto_soep.info.summary" = "Javanese chicken soup";
"recipe.sr_saoto_soep.name" = "Saoto soup";
