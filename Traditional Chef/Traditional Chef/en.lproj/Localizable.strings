"recipe.fr_cassoulet.drink.body" = "Pair with a southern French red such as Cahors or a robust blend from the Languedoc that can stand up to duck confit and slow-cooked pork. A farmhouse-style amber beer also works well. For a non-alcoholic option, serve sparkling water or a tart blackcurrant spritz.";
"recipe.fr_cassoulet.drink.summary" = "Red wine (Cahors)";
"recipe.fr_cassoulet.info" = "Cassoulet is the signature slow-cooked dish of southwest France, built from white beans simmered until creamy and baked with a rich mix of pork, Toulouse sausages, and duck confit. The stew is finished in the oven so a savory crust forms on top, then broken and re-formed during baking for a deep, concentrated flavor. It is served piping hot as a hearty communal main.";
"recipe.fr_cassoulet.info.summary" = "Southwest bean cassoulet";
"recipe.fr_cassoulet.name" = "Cassoulet";
"recipe.fr_cassoulet.step1.body" = "Cover %i1 generously with %i12 and let them soak until fully hydrated.";
"recipe.fr_cassoulet.step1.title" = "Soak the beans";
"recipe.fr_cassoulet.step10.body" = "Serve the cassoulet hot, making sure each portion gets beans, sausage, pork, and duck with plenty of the rich sauce.";
"recipe.fr_cassoulet.step10.title" = "Serve the cassoulet";
"recipe.fr_cassoulet.step2.body" = "Rinse the soaked beans and %i5. Chop %i6 and %i7 and crush %i8.";
"recipe.fr_cassoulet.step2.title" = "Prep the aromatics and rind";
"recipe.fr_cassoulet.step3.body" = "Put the beans in a pot with the pork rind, the aromatics, %i9, water, and %i11 and simmer gently until the beans are tender and starting to turn creamy, keeping the liquid below a boil.";
"recipe.fr_cassoulet.step3.title" = "Simmer the beans and rind";
"recipe.fr_cassoulet.step4.body" = "Melt %i10 in a skillet and brown %i2 well on all sides, then transfer it to a plate.";
"recipe.fr_cassoulet.step4.title" = "Brown the pork";
"recipe.fr_cassoulet.step5.body" = "Brown %i3 in the same skillet so they take on colour, then transfer them to a plate.";
"recipe.fr_cassoulet.step5.title" = "Brown the sausages";
"recipe.fr_cassoulet.step6.body" = "Remove excess fat from %i4 and separate the pieces so they are ready to nestle into the beans.";
"recipe.fr_cassoulet.step6.title" = "Prepare the duck";
"recipe.fr_cassoulet.step7.body" = "Remove the bouquet garni and lift out the pork rind. Season the beans with %i13 and %i14. Layer the beans in the dutch oven with the pork belly and sausages, then tuck the duck confit on top. Add enough bean cooking liquid so everything is barely covered.";
"recipe.fr_cassoulet.step7.title" = "Assemble the cassoulet";
"recipe.fr_cassoulet.step8.body" = "Bake until bubbling and a dark crust forms on the surface. Break the crust down into the beans, let it reform, and repeat during baking so the top stays richly browned.";
"recipe.fr_cassoulet.step8.title" = "Bake and form the crust";
"recipe.fr_cassoulet.step9.body" = "Let the cassoulet rest so the bubbling subsides and the sauce thickens slightly.";
"recipe.fr_cassoulet.step9.title" = "Rest before serving";
