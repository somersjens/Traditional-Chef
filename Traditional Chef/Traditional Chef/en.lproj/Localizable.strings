"recipe.sr_moksi_alesi.drink.summary" = "Beer (Lager)";
"recipe.sr_moksi_alesi.info" = "Moksi alesi is a traditional Surinamese one-pot rice dish in which rice is cooked together with meat, aromatics, and vegetables so the flavors merge into a rich savory meal. A classic home-style version combines salt meat, chicken, cabbage, tomato, and seasonings, and it is served hot as a complete main dish.";
"recipe.sr_moksi_alesi.info.summary" = "One-pot rice dish";
"recipe.sr_moksi_alesi.name" = "Moksi alesi";
"recipe.sr_moksi_alesi.step1.body" = "Place %i1 in a pot with %i11, bring it to a boil, and cook until it is less salty and beginning to soften.";
"recipe.sr_moksi_alesi.step1.title" = "Soften the salt beef";
"recipe.sr_moksi_alesi.step2.body" = "Drain the salt beef and cut it into pieces. Cut %i2 into pieces, wash %i3, shred %i4, chop %i5, mince %i6, and dice %i7.";
"recipe.sr_moksi_alesi.step2.title" = "Prepare the ingredients";
"recipe.sr_moksi_alesi.step3.body" = "Heat %i9 and %i10 in a large pot, add the onion and garlic, and cook until fragrant. Add the tomato and %i8 and cook until the mixture darkens slightly.";
"recipe.sr_moksi_alesi.step3.title" = "Start the base";
"recipe.sr_moksi_alesi.step4.body" = "Add the salt beef and chicken to the pot, season with %i12 and %i13, and cook until the meat is lightly browned and coated with the seasoning base.";
"recipe.sr_moksi_alesi.step4.title" = "Brown the meat";
"recipe.sr_moksi_alesi.step5.body" = "Stir in the cabbage and cook until it starts to soften and reduce in volume.";
"recipe.sr_moksi_alesi.step5.title" = "Add the cabbage";
"recipe.sr_moksi_alesi.step6.body" = "Add the rice, %i14, %i15, and fresh water, then stir well and bring everything to a boil.";
"recipe.sr_moksi_alesi.step6.title" = "Add rice and liquid";
"recipe.sr_moksi_alesi.step7.body" = "Lower the heat, cover the pot, and cook gently until the rice is tender and the liquid has been absorbed.";
"recipe.sr_moksi_alesi.step7.title" = "Cook the rice";
"recipe.sr_moksi_alesi.step8.body" = "Turn off the heat and leave the moksi alesi covered so the grains finish steaming and the flavors settle.";
"recipe.sr_moksi_alesi.step8.title" = "Rest the dish";
"recipe.sr_moksi_alesi.step9.body" = "Fluff the rice carefully so the meat and cabbage are evenly distributed, then serve the moksi alesi hot.";
"recipe.sr_moksi_alesi.step9.title" = "Fluff and serve";
