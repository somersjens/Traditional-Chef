"recipe.jp_shabu_shabu.step7.title" = "Cook vegetables and tofu first";
"recipe.jp_shabu_shabu.step8.body" = "Cook the beef slices a few at a time by swishing them briefly in the simmering broth, then dip in ponzu or sesame sauce and eat immediately with the cooked vegetables.";
