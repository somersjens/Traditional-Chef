"recipe.bd_chui_jhal.drink.body" = "A light-bodied, low-tannin red such as Gamay works well with the peppery aromatics and mustard oil without tasting harsh. If you prefer white, an off-dry Riesling is a good match. Non-alcoholic pairing: chilled lemon soda or unsweetened black tea.";
"recipe.bd_chui_jhal.drink.summary" = "Red wine (Gamay)";
"recipe.bd_chui_jhal.info" = "Chui jhal is a regional Bangladeshi specialty, especially associated with the southwest, where beef is cooked with chui (pepper vine root) for its distinctive sharp, aromatic heat. The beef is braised until tender in a concentrated gravy with mustard oil, onions, and warm spices, while slices of chui soften and perfume the curry. It is traditionally served hot with plain steamed rice to balance the bold flavour.";
"recipe.bd_chui_jhal.info.summary" = "Pepper root beef";
"recipe.bd_chui_jhal.name" = "Beef chui jhal";
"recipe.bd_chui_jhal.step1.body" = "Slice the %i2, mince the %i4, grate the %i3, and slit the %i5. Peel the %i15 and cut into chunks. Peel the %i14 and cut it into thin pieces.";
"recipe.bd_chui_jhal.step1.title" = "Prep the ingredients";
"recipe.bd_chui_jhal.step2.body" = "Heat %i6 in a heavy pot and brown the %i1 well, turning so it colours on all sides and the pot develops browned bits.";
"recipe.bd_chui_jhal.step2.title" = "Brown the beef";
"recipe.bd_chui_jhal.step3.body" = "Add onion and cook until softened and lightly golden, then add ginger, garlic, and green chilies and cook until the raw smell is gone.";
"recipe.bd_chui_jhal.step3.title" = "Build the masala base";
"recipe.bd_chui_jhal.step4.body" = "Stir in %i7, %i8, %i9, %i10, %i11, %i12, and %i13, frying briefly, then add the chui jhal and coat it in the spiced oil.";
"recipe.bd_chui_jhal.step4.title" = "Bloom spices and add chui";
"recipe.bd_chui_jhal.step5.body" = "Add the potatoes and enough %i17 to maintain a steady simmer. Cover and cook gently until the beef is tender and the gravy is rich, stirring occasionally to prevent sticking.";
"recipe.bd_chui_jhal.step5.title" = "Braise until tender";
"recipe.bd_chui_jhal.step6.body" = "Rinse the %i16. Combine it with water and a pinch of salt, bring to a simmer, then cover and cook gently until tender.";
"recipe.bd_chui_jhal.step6.title" = "Cook the rice";
"recipe.bd_chui_jhal.step7.body" = "Remove from the heat and rest covered so the rice steams and fluffs up.";
"recipe.bd_chui_jhal.step7.title" = "Rest the rice";
"recipe.bd_chui_jhal.step8.body" = "Taste the curry and adjust seasoning if needed, then serve the chui jhal hot with steamed rice.";
"recipe.bd_chui_jhal.step8.title" = "Serve";
