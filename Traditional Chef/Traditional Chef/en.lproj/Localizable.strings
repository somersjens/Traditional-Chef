"recipe.au_oysters_kilpatrick.drink.body" = "A dry Riesling suits the briny oysters and smoky bacon without overwhelming the dish. A crisp sparkling wine also works well, and chilled sparkling water with lemon is a good non-alcoholic pairing.";
"recipe.au_oysters_kilpatrick.drink.summary" = "White wine (Riesling)";
"recipe.au_oysters_kilpatrick.info" = "Oysters Kilpatrick is a traditional Australian starter of oysters in the half shell topped with Worcestershire sauce and diced bacon, then grilled until the bacon is crisp and the oysters are just cooked. It is a classic seafood entrée, especially popular for festive meals and restaurant platters, and is traditionally served immediately with lemon wedges.";
"recipe.au_oysters_kilpatrick.info.summary" = "Grilled oyster starter";
"recipe.au_oysters_kilpatrick.name" = "Oysters Kilpatrick";
"recipe.au_oysters_kilpatrick.step1.body" = "Preheat the grill. Spread the %i5 thickly over a baking tray and nestle the %i1 into the salt so they sit level.";
"recipe.au_oysters_kilpatrick.step1.title" = "Prepare the grill tray";
"recipe.au_oysters_kilpatrick.step2.body" = "Finely dice the %i3 and chop the %i4. Spoon a little %i2 over each oyster and top evenly with the bacon.";
"recipe.au_oysters_kilpatrick.step2.title" = "Prepare the topping";
"recipe.au_oysters_kilpatrick.step3.body" = "Grill until the bacon is crisp and the oysters are hot and just cooked.";
"recipe.au_oysters_kilpatrick.step3.title" = "Grill the oysters";
"recipe.au_oysters_kilpatrick.step4.body" = "Sprinkle with the parsley and serve immediately with %i6 wedges.";
"recipe.au_oysters_kilpatrick.step4.title" = "Finish and serve";
