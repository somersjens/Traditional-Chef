"recipe.fr_crepes_suzette.drink.body" = "Pair with a sweet orange-friendly wine such as Muscat de Beaumes-de-Venise or a demi-sec Champagne for contrast with the citrus butter sauce. For a non-alcoholic option, serve espresso, black tea, or sparkling water with orange.";
"recipe.fr_crepes_suzette.drink.summary" = "Dessert wine (Muscat)";
"recipe.fr_crepes_suzette.info" = "Crêpes Suzette are classic French crêpes served in a buttery orange sauce made with caramelized sugar, fresh orange juice and zest, and Grand Marnier, traditionally flambéed. The crêpes are folded, warmed in the sauce, and served immediately while glossy and hot, with the bright citrus and liqueur balancing the rich butter.";
"recipe.fr_crepes_suzette.info.summary" = "Flambéed orange crêpes";
"recipe.fr_crepes_suzette.name" = "Crêpes Suzette";
"recipe.fr_crepes_suzette.step1.body" = "Melt %i7 gently and pour off the clear butter, leaving the milky solids behind, so the crêpes cook cleanly.";
"recipe.fr_crepes_suzette.step1.title" = "Make the clarified butter";
"recipe.fr_crepes_suzette.step2.body" = "Whisk %i1, %i5, and %i6, then whisk in %i2. Add %i3 and %i4 gradually until smooth, then whisk in some clarified butter for richness.";
"recipe.fr_crepes_suzette.step2.title" = "Mix the batter";
"recipe.fr_crepes_suzette.step3.body" = "Let the batter rest so the flour hydrates and the crêpes cook evenly.";
"recipe.fr_crepes_suzette.step3.title" = "Rest the batter";
"recipe.fr_crepes_suzette.step4.body" = "Finely zest %i9, then juice them and strain out the pulp and seeds.";
"recipe.fr_crepes_suzette.step4.title" = "Zest and juice the oranges";
"recipe.fr_crepes_suzette.step5.body" = "Heat the pan, brush it lightly with %i8, pour in batter, and cook each crêpe until set and lightly golden, flipping to cook the other side briefly. Stack them and keep them warm.";
"recipe.fr_crepes_suzette.step5.title" = "Cook the crêpes";
"recipe.fr_crepes_suzette.step6.body" = "In a large skillet, melt %i10 over medium heat until it becomes a deep amber caramel, swirling to colour evenly.";
"recipe.fr_crepes_suzette.step6.title" = "Caramelize the sugar";
"recipe.fr_crepes_suzette.step7.body" = "Carefully add the orange juice and zest to the caramel and simmer to dissolve it. Whisk in %i11 and a pinch of %i13 until glossy.";
"recipe.fr_crepes_suzette.step7.title" = "Build the orange sauce";
"recipe.fr_crepes_suzette.step8.body" = "Fold the crêpes into quarters and lay them in the sauce, turning to coat and warm through.";
"recipe.fr_crepes_suzette.step8.title" = "Warm the crêpes in sauce";
"recipe.fr_crepes_suzette.step9.body" = "Warm %i12, pour it over the crêpes, ignite it, and let the flame die out, then serve immediately with extra sauce spooned over.";
"recipe.fr_crepes_suzette.step9.title" = "Flambé and serve";
