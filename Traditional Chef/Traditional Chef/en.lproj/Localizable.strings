"recipe.jp_kuzumochi.drink.body" = "Hojicha or sencha pairs well with the subtle sweetness and roasted soybean flour. For a non-alcoholic pairing, serve cold barley tea or iced green tea.";
"recipe.jp_kuzumochi.drink.summary" = "Green tea (Hojicha)";
"recipe.jp_kuzumochi.info" = "Kuzumochi is a traditional Japanese dessert made by cooking kuzu starch into a smooth translucent cake, then chilling and cutting it into pieces. It is commonly served as a delicate wagashi with kuromitsu syrup and roasted soybean flour, especially in tea houses and home desserts during warm weather.";
"recipe.jp_kuzumochi.info.summary" = "Chilled kuzu cake";
"recipe.jp_kuzumochi.name" = "Kuzumochi";
"recipe.jp_kuzumochi.step1.body" = "Line or lightly wet a shallow tray so the cooked kuzumochi can be spread and released cleanly after chilling.";
"recipe.jp_kuzumochi.step1.title" = "Prepare the tray";
"recipe.jp_kuzumochi.step2.body" = "Whisk the %i1, %i2, and %i3 in a saucepan until completely smooth and no lumps remain.";
"recipe.jp_kuzumochi.step2.title" = "Mix the kuzumochi base";
"recipe.jp_kuzumochi.step3.body" = "Cook the mixture over medium-low heat, stirring constantly as it thickens, turns glossy, and becomes translucent and elastic.";
"recipe.jp_kuzumochi.step3.title" = "Cook the kuzumochi";
"recipe.jp_kuzumochi.step4.body" = "Transfer the hot kuzumochi mixture to the prepared tray and smooth the surface into an even layer.";
"recipe.jp_kuzumochi.step4.title" = "Spread into the tray";
"recipe.jp_kuzumochi.step5.body" = "Let the kuzumochi cool and chill until set and firm enough to cut neatly.";
"recipe.jp_kuzumochi.step5.title" = "Chill until firm";
"recipe.jp_kuzumochi.step6.body" = "Mix the %i4 with %i5 and %i6 in a bowl until evenly combined.";
"recipe.jp_kuzumochi.step6.title" = "Make the kinako topping";
"recipe.jp_kuzumochi.step7.body" = "Simmer the %i7, %i8, and water until dissolved and slightly thickened, then cool to a pourable syrup.";
"recipe.jp_kuzumochi.step7.title" = "Make the kuromitsu syrup";
"recipe.jp_kuzumochi.step8.body" = "Turn out the chilled kuzumochi and cut it into bite-size pieces for serving.";
"recipe.jp_kuzumochi.step8.title" = "Cut the kuzumochi";
"recipe.jp_kuzumochi.step9.body" = "Arrange the pieces on plates, dust generously with kinako topping, and serve with kuromitsu syrup poured over or alongside.";
"recipe.jp_kuzumochi.step9.title" = "Finish and serve";
