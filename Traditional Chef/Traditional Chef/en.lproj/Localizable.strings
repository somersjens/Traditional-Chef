"recipe.ru_selyodka_pod_shuboy.drink.body" = "Chilled vodka is the traditional pairing, and a crisp dry white also works with the salty herring and creamy layers. Non-alcoholic pairing: hot black tea or sparkling water with lemon.";
"recipe.ru_selyodka_pod_shuboy.drink.summary" = "Chilled vodka";
"recipe.ru_selyodka_pod_shuboy.info" = "Selyodka pod shuboy is a classic Russian layered salad built on chopped salted herring and onion, covered with grated boiled potatoes, carrots, and beets, each layer lightly bound with mayonnaise and finished with a beet-red top. It is traditionally prepared ahead so the layers meld in the refrigerator, then served cold in slices as a staple zakuska at festive tables.";
"recipe.ru_selyodka_pod_shuboy.info.summary" = "Layered herring salad";
"recipe.ru_selyodka_pod_shuboy.name" = "Herring under a fur coat";
"recipe.ru_selyodka_pod_shuboy.step1.body" = "Cook the %i3 in %i10 until tender. Drain and cool until easy to handle.";
"recipe.ru_selyodka_pod_shuboy.step1.title" = "Boil the beets";
"recipe.ru_selyodka_pod_shuboy.step2.body" = "Cook the %i4 and %i5 in water until tender. Drain and let them cool.";
"recipe.ru_selyodka_pod_shuboy.step2.title" = "Boil potatoes and carrots";
"recipe.ru_selyodka_pod_shuboy.step3.body" = "Boil the %i6 in water until hard-set, then drain.";
"recipe.ru_selyodka_pod_shuboy.step3.title" = "Boil the eggs";
"recipe.ru_selyodka_pod_shuboy.step4.body" = "Cool the vegetables and eggs, then peel the beets, potatoes, carrots, and eggs.";
"recipe.ru_selyodka_pod_shuboy.step4.title" = "Cool and peel";
"recipe.ru_selyodka_pod_shuboy.step5.body" = "Dice the %i1 into small pieces. Finely chop the %i2 and mix it with the herring.";
"recipe.ru_selyodka_pod_shuboy.step5.title" = "Prepare the herring base";
"recipe.ru_selyodka_pod_shuboy.step6.body" = "Grate the potatoes, carrots, beets, and eggs separately using a grater so each layer stays distinct.";
"recipe.ru_selyodka_pod_shuboy.step6.title" = "Grate the layers";
"recipe.ru_selyodka_pod_shuboy.step7.body" = "Spread the herring-onion mixture on the serving dish. Add a potato layer, spread a thin layer of %i7, then add carrots with mayonnaise, then eggs with mayonnaise, and finish with a beet layer and a final thin coat of mayonnaise. Season lightly with %i8 and %i9 between layers as needed.";
"recipe.ru_selyodka_pod_shuboy.step7.title" = "Assemble the salad";
"recipe.ru_selyodka_pod_shuboy.step8.body" = "Cover and refrigerate so the layers set and the flavors meld thoroughly.";
"recipe.ru_selyodka_pod_shuboy.step8.title" = "Chill to meld";
"recipe.ru_selyodka_pod_shuboy.step9.body" = "Uncover and slice or spoon portions, keeping the layers intact, and serve cold.";
"recipe.ru_selyodka_pod_shuboy.step9.title" = "Serve";
