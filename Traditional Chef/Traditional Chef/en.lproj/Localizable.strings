"recipe.th_khao_soi.step5.title" = "Build the broth";
"recipe.th_khao_soi.step6.body" = "Simmer gently until the chicken is tender and cooked through and the broth is rich and fragrant.";
"recipe.th_khao_soi.step6.title" = "Braise the chicken";
"recipe.th_khao_soi.step7.body" = "Bring the noodle boiling %i14 to a full boil in a large pot.";
"recipe.th_khao_soi.step7.title" = "Boil water for noodles";
