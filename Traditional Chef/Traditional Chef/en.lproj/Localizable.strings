"recipe.uy_pascualina.drink.body" = "Pair with an unoaked Chardonnay or a fresh Sauvignon Blanc to match the creamy ricotta and greens. A crisp lager also works well. For a non-alcoholic option, serve sparkling water with lemon or a cold yerba mate infusion.";
"recipe.uy_pascualina.drink.summary" = "White wine (Chardonnay)";
"recipe.uy_pascualina.info" = "Pascualina is a traditional Uruguayan savory pie of tender pastry encasing a rich spinach and ricotta filling, set with eggs and flavored with onion, Parmesan, and nutmeg. Whole eggs are tucked into the filling and baked so each slice reveals an egg center, and the pie is served warm or at room temperature as a classic family meal.";
"recipe.uy_pascualina.info.summary" = "Spinach ricotta pie";
"recipe.uy_pascualina.name" = "Pascualina";
"recipe.uy_pascualina.step1.body" = "Rub the %i2 into the %i1 and %i3 until sandy, then add %i4 and bring together into a smooth dough without overworking.";
"recipe.uy_pascualina.step1.title" = "Make the dough";
"recipe.uy_pascualina.step10.body" = "Bake until the pastry is deeply golden and the pie is set, with the eggs inside cooked.";
"recipe.uy_pascualina.step10.title" = "Bake";
"recipe.uy_pascualina.step11.body" = "Let the pascualina rest so it firms up for clean slices, then serve warm or at room temperature.";
"recipe.uy_pascualina.step11.title" = "Rest and slice";
"recipe.uy_pascualina.step2.body" = "Wrap the dough and refrigerate so it firms up and rolls cleanly.";
"recipe.uy_pascualina.step2.title" = "Rest the dough";
"recipe.uy_pascualina.step3.body" = "Chop the %i6 and roughly chop the %i5. Grate the %i9 and set the %i8 ready for mixing.";
"recipe.uy_pascualina.step3.title" = "Prep the filling ingredients";
"recipe.uy_pascualina.step4.body" = "Sauté the onion in %i7 until soft, then add the spinach and cook until fully wilted and the moisture has cooked off.";
"recipe.uy_pascualina.step4.title" = "Cook onion and wilt spinach";
"recipe.uy_pascualina.step5.body" = "Tip the greens into a colander and press out excess liquid, then let the mixture cool so it does not loosen the pastry.";
"recipe.uy_pascualina.step5.title" = "Drain and cool";
"recipe.uy_pascualina.step6.body" = "Combine the cooled spinach mixture with ricotta, Parmesan, two beaten %i10, %i11, %i12, and %i13 until evenly blended.";
"recipe.uy_pascualina.step6.title" = "Mix the filling";
"recipe.uy_pascualina.step7.body" = "Roll out most of the dough and line the pie dish, leaving an overhang for sealing.";
"recipe.uy_pascualina.step7.title" = "Line the pie dish";
"recipe.uy_pascualina.step8.body" = "Spread in the filling, make four deep wells, and crack an %i14 into each well so they bake inside the pie.";
"recipe.uy_pascualina.step8.title" = "Fill and add whole eggs";
"recipe.uy_pascualina.step9.body" = "Roll out the remaining dough, cover the pie, seal the edges firmly, and vent the top so steam can escape.";
"recipe.uy_pascualina.step9.title" = "Top and seal";
