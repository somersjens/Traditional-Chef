"recipe.hk_yang_zhi_gan_lu.drink.body" = "This dessert is traditionally paired with tea rather than wine, especially jasmine tea. If serving wine, a lightly sweet Moscato can work, while hot jasmine tea or cold barley water is a classic non-alcoholic pairing.";
"recipe.hk_yang_zhi_gan_lu.drink.summary" = "Jasmine tea";
"recipe.hk_yang_zhi_gan_lu.info" = "A traditional Hong Kong dessert soup made with ripe mango, pomelo, sago pearls, and a creamy milk-coconut base, served well chilled. It is commonly enjoyed in dessert shops as a refreshing warm-weather sweet with a smooth, fruity texture and chewy sago.";
"recipe.hk_yang_zhi_gan_lu.info.summary" = "Mango pomelo sago";
"recipe.hk_yang_zhi_gan_lu.name" = "Yang zhi gan lu";
"recipe.hk_yang_zhi_gan_lu.step1.body" = "Peel and cut the %i3 and %i9, separating one portion for blending and one portion for small serving cubes. Remove the %i8 into small segments and set aside.";
"recipe.hk_yang_zhi_gan_lu.step1.title" = "Prepare the fruit";
"recipe.hk_yang_zhi_gan_lu.step2.body" = "Bring %i2 to a rolling boil in a large saucepan.";
"recipe.hk_yang_zhi_gan_lu.step2.title" = "Boil water for sago";
"recipe.hk_yang_zhi_gan_lu.step3.body" = "Add the %i1 and cook while stirring occasionally until the centers are very small and mostly translucent.";
"recipe.hk_yang_zhi_gan_lu.step3.title" = "Cook the sago";
"recipe.hk_yang_zhi_gan_lu.step4.body" = "Turn off the heat, cover, and let the sago sit until fully translucent.";
"recipe.hk_yang_zhi_gan_lu.step4.title" = "Rest the sago off heat";
"recipe.hk_yang_zhi_gan_lu.step5.body" = "Drain the sago through a fine strainer and rinse well under cold water to remove excess starch, then let it drain thoroughly.";
"recipe.hk_yang_zhi_gan_lu.step5.title" = "Rinse and cool the sago";
"recipe.hk_yang_zhi_gan_lu.step6.body" = "Blend the mango portion for the base with %i4, %i5, %i6, and %i7 until smooth and creamy.";
"recipe.hk_yang_zhi_gan_lu.step6.title" = "Blend the mango base";
"recipe.hk_yang_zhi_gan_lu.step7.body" = "Pour the mango base into a mixing bowl, stir in the drained sago, then fold in the pomelo flesh and diced mango.";
"recipe.hk_yang_zhi_gan_lu.step7.title" = "Combine the dessert";
"recipe.hk_yang_zhi_gan_lu.step8.body" = "Refrigerate the dessert until well chilled and the flavors meld.";
"recipe.hk_yang_zhi_gan_lu.step8.title" = "Chill thoroughly";
"recipe.hk_yang_zhi_gan_lu.step9.body" = "Stir gently, divide into serving bowls, and serve cold.";
"recipe.hk_yang_zhi_gan_lu.step9.title" = "Serve cold";
