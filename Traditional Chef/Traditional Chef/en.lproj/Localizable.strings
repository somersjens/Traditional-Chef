"recipe.kr_sundubu_jjigae.drink.body" = "A crisp dry white such as Sauvignon Blanc or a light Riesling can balance the spicy broth and delicate seafood. Beer pairing: clean lager. Non-alcoholic pairing: roasted barley tea.";
"recipe.kr_sundubu_jjigae.drink.summary" = "White wine (Sauvignon)";
"recipe.kr_sundubu_jjigae.info" = "Sundubu jjigae is a traditional Korean spicy stew made with fresh soft tofu, anchovy-kelp stock, aromatics, and seafood, finished with egg and served bubbling hot. It is a classic home and restaurant dish, commonly eaten with steamed rice as part of a Korean meal.";
"recipe.kr_sundubu_jjigae.info.summary" = "Spicy soft tofu stew";
"recipe.kr_sundubu_jjigae.name" = "Sundubu jjigae";
"recipe.kr_sundubu_jjigae.step1.body" = "Rinse the %i16 in cold water until the water runs mostly clear, then drain well.";
"recipe.kr_sundubu_jjigae.step1.title" = "Rinse the rice";
"recipe.kr_sundubu_jjigae.step10.body" = "Crack the %i15 into the bubbling stew, cover briefly, and cook until the whites are set and the yolks remain soft.";
"recipe.kr_sundubu_jjigae.step10.title" = "Add the eggs";
"recipe.kr_sundubu_jjigae.step11.body" = "Fluff the rested rice and divide it into serving bowls.";
"recipe.kr_sundubu_jjigae.step11.title" = "Fluff the rice";
"recipe.kr_sundubu_jjigae.step12.body" = "Top the stew with the remaining scallion and serve bubbling hot with rice.";
"recipe.kr_sundubu_jjigae.step12.title" = "Serve";
"recipe.kr_sundubu_jjigae.step2.body" = "Combine the rice with %i17 in a pot, bring to a boil, cover, reduce heat, and cook until tender. Rest covered off the heat.";
"recipe.kr_sundubu_jjigae.step2.title" = "Cook the rice";
"recipe.kr_sundubu_jjigae.step3.body" = "Rinse the %i1 and wipe the %i2 clean for the stock.";
"recipe.kr_sundubu_jjigae.step3.title" = "Prepare stock ingredients";
"recipe.kr_sundubu_jjigae.step4.body" = "Combine the anchovies, kelp, and %i3 in a pot and simmer gently to make a light stock.";
"recipe.kr_sundubu_jjigae.step4.title" = "Make anchovy-kelp stock";
"recipe.kr_sundubu_jjigae.step5.body" = "Strain out the anchovies and kelp and keep the hot stock ready for the stew.";
"recipe.kr_sundubu_jjigae.step5.title" = "Strain the stock";
"recipe.kr_sundubu_jjigae.step6.body" = "Slice the %i4 and %i5, mince the %i6, slice the %i7 and %i8, clean the %i12 and %i13, and keep the %i14 ready.";
"recipe.kr_sundubu_jjigae.step6.title" = "Prepare the stew ingredients";
"recipe.kr_sundubu_jjigae.step7.body" = "Heat the stew pot with %i10, cook the pork belly and onion until the fat renders slightly, then add garlic and %i9 and stir briefly until fragrant.";
"recipe.kr_sundubu_jjigae.step7.title" = "Build the stew base";
"recipe.kr_sundubu_jjigae.step8.body" = "Add the stock and %i11, bring to a boil, then add the clams and shrimp and simmer until the seafood begins to cook.";
"recipe.kr_sundubu_jjigae.step8.title" = "Simmer the stew";
"recipe.kr_sundubu_jjigae.step9.body" = "Add the soft tofu in large spoonfuls, then add the green chili and most of the scallion and simmer gently until the tofu is hot and the clams open.";
"recipe.kr_sundubu_jjigae.step9.title" = "Add tofu and finish";
