"recipe.lk_watalappan.step1.title" = "Prepare the oven and dish";
"recipe.lk_watalappan.step10.body" = "Serve chilled or at room temperature in portions.";
"recipe.lk_watalappan.step10.title" = "Serve";
"recipe.lk_watalappan.step2.body" = "Heat the %i1 with a little %i2 until fully melted and smooth, then let it cool slightly.";
"recipe.lk_watalappan.step2.title" = "Make jaggery syrup";
"recipe.lk_watalappan.step3.body" = "Crack the %i3 into a bowl and whisk gently until evenly combined without creating too much foam.";
"recipe.lk_watalappan.step3.title" = "Whisk eggs";
"recipe.lk_watalappan.step4.body" = "Add %i4, the melted jaggery syrup, %i5, %i6, %i7, %i8, and %i9 to the eggs and whisk until smooth.";
"recipe.lk_watalappan.step4.title" = "Mix the custard base";
"recipe.lk_watalappan.step5.body" = "Strain the custard mixture into the custard dish and scatter %i10 and %i11 on top.";
"recipe.lk_watalappan.step5.title" = "Strain and fill";
"recipe.lk_watalappan.step6.body" = "Pour hot %i12 into the outer baking dish around the custard dish.";
"recipe.lk_watalappan.step6.title" = "Set the water bath";
"recipe.lk_watalappan.step7.body" = "Bake gently in the water bath until the custard is just set with a slight wobble in the center.";
"recipe.lk_watalappan.step7.title" = "Bake the watalappan";
"recipe.lk_watalappan.step8.body" = "Remove from the water bath and cool until no longer hot.";
"recipe.lk_watalappan.step8.title" = "Cool the custard";
"recipe.lk_watalappan.step9.body" = "Chill the watalappan until fully set and the flavors deepen.";
"recipe.lk_watalappan.step9.title" = "Chill before serving";
