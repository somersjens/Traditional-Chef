"recipe.iq_quzi.drink.body" = "A full-bodied red such as Syrah or a mature Grenache pairs well with the rich lamb and warm spices. A malty amber beer also suits the dish. For a non-alcoholic pairing, serve strong black tea or lightly salted ayran.";
"recipe.iq_quzi.drink.summary" = "Red wine (Syrah)";
"recipe.iq_quzi.info" = "Quzi is a celebratory Iraqi main dish of slow-cooked lamb served over aromatic rice with vermicelli, raisins, almonds, and boiled eggs. It is traditionally presented on a large platter for sharing at family gatherings, feasts, and special occasions.";
"recipe.iq_quzi.info.summary" = "Festive lamb rice";
"recipe.iq_quzi.name" = "Quzi";
"recipe.iq_quzi.step1.body" = "Trim %i1 into large serving pieces. Slice %i2 and crush %i3.";
"recipe.iq_quzi.step1.title" = "Prepare the lamb";
"recipe.iq_quzi.step10.body" = "Serve immediately as a shared main dish while the lamb is hot and the rice remains fluffy and aromatic.";
"recipe.iq_quzi.step10.title" = "Serve the quzi";
"recipe.iq_quzi.step2.body" = "Place the lamb in a heavy pot with the onions, garlic, %i4, %i5, %i6, %i7, %i8, %i9, and %i10. Bring to a boil and skim the surface.";
"recipe.iq_quzi.step2.title" = "Start the braise";
"recipe.iq_quzi.step3.body" = "Cover and simmer gently until the lamb is very tender and the broth is deeply flavored. Remove the lamb and strain the broth, keeping the stock for the rice.";
"recipe.iq_quzi.step3.title" = "Cook the lamb";
"recipe.iq_quzi.step4.body" = "Wash %i11 until the water runs clearer, then soak it in normal water. Drain it well before cooking.";
"recipe.iq_quzi.step4.title" = "Soak the rice";
"recipe.iq_quzi.step5.body" = "Heat part of %i13 and brown the cooked lamb pieces until lightly colored on the outside. Set them aside and keep warm.";
"recipe.iq_quzi.step5.title" = "Brown the lamb";
"recipe.iq_quzi.step6.body" = "Melt the rice ghee in a saucepan and toast %i12 until golden.";
"recipe.iq_quzi.step6.title" = "Toast the vermicelli";
"recipe.iq_quzi.step7.body" = "Add the drained rice, %i14, and %i15 to the toasted vermicelli, bring to a boil, then cover and cook on low heat until the rice is tender and the liquid is absorbed.";
"recipe.iq_quzi.step7.title" = "Cook the rice";
"recipe.iq_quzi.step8.body" = "Boil %i19 until firm, peel them, and halve them. In a frying pan, heat the remaining %i16 and fry %i17 until golden, then add %i18 and stir until they plump.";
"recipe.iq_quzi.step8.title" = "Prepare the garnish";
"recipe.iq_quzi.step9.body" = "Spread the rice onto a large serving platter, arrange the lamb on top, and scatter the almonds and raisins over the surface. Add the egg halves and chopped %i20.";
"recipe.iq_quzi.step9.title" = "Assemble the platter";
