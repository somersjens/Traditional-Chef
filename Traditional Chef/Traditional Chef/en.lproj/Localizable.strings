"recipe.ir_faloodeh_shirazi.drink.body" = "Fragrant, lightly sweet wines such as Muscat or off-dry Riesling complement the rosewater and citrus. If you prefer something drier, a crisp sparkling wine balances the sweetness. Non-alcoholic: chilled black tea with lemon or sparkling water with lime.";
"recipe.ir_faloodeh_shirazi.drink.summary" = "Sweet wine (Muscat)";
"recipe.ir_faloodeh_shirazi.info" = "Faloodeh Shirazi is a traditional Iranian semi-frozen dessert from Shiraz made with delicate starch vermicelli suspended in a rosewater-scented syrup that is frozen and fluffed into a granita-like texture. It is classically finished with fresh lime juice at the table and eaten as a cooling sweet after meals or on hot days.";
"recipe.ir_faloodeh_shirazi.info.summary" = "Shiraz lime granita";
"recipe.ir_faloodeh_shirazi.name" = "Faloodeh";
"recipe.ir_faloodeh_shirazi.step1.body" = "Combine %i3, %i4, and %i7 in a saucepan and heat until the sugar dissolves and the syrup is clear. Remove from the heat, stir in %i5 and %i6, then let it cool completely.";
"recipe.ir_faloodeh_shirazi.step1.title" = "Make the rose-lime syrup";
"recipe.ir_faloodeh_shirazi.step2.body" = "Fill a large bowl with %i8 and %i2 so the noodles can chill immediately after pressing.";
"recipe.ir_faloodeh_shirazi.step2.title" = "Prepare the ice bath";
"recipe.ir_faloodeh_shirazi.step3.body" = "Whisk %i1 with water in a saucepan until smooth, then cook while stirring until it becomes very thick, glossy, and translucent.";
"recipe.ir_faloodeh_shirazi.step3.title" = "Cook the starch paste";
"recipe.ir_faloodeh_shirazi.step4.body" = "While the paste is still hot, press it through a potato ricer directly into ice water to form fine strands, then let the strands firm up.";
"recipe.ir_faloodeh_shirazi.step4.title" = "Press noodles into ICE water";
"recipe.ir_faloodeh_shirazi.step5.body" = "Drain the strands, rinse briefly with cold water, and drain well so the noodles stay separate.";
"recipe.ir_faloodeh_shirazi.step5.title" = "Rinse and drain";
"recipe.ir_faloodeh_shirazi.step6.body" = "Mix the drained noodles with the cooled rose-lime syrup and spread the mixture in a shallow freezer-safe container.";
"recipe.ir_faloodeh_shirazi.step6.title" = "Combine with syrup";
"recipe.ir_faloodeh_shirazi.step7.body" = "Freeze until semi-frozen, then fluff and break up the crystals with a fork periodically until the texture is light and granita-like.";
"recipe.ir_faloodeh_shirazi.step7.title" = "Freeze and fluff";
"recipe.ir_faloodeh_shirazi.step8.body" = "Spoon into bowls and finish with %i9 squeezed over just before eating.";
"recipe.ir_faloodeh_shirazi.step8.title" = "Serve with lime";
