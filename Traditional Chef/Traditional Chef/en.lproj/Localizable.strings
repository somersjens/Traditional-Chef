"recipe.al_fli.tool.t7" = "Oven";
"recipe.al_kabuni.drink.body" = "A light dessert wine such as Moscato can work with the warm spice and raisin notes, though kabuni is often served without alcohol. A good non-alcoholic pairing is black coffee or cold water.";
"recipe.al_kabuni.drink.summary" = "Dessert wine (Moscato)";
"recipe.al_kabuni.info" = "Kabuni is a traditional Albanian dessert of rice cooked with butter, raisins, sugar, cinnamon, and cloves, often enriched with mutton broth in the classic old-style preparation. It is baked until darkened and aromatic, then served cold as a festive dessert with a dense, rich texture.";
"recipe.al_kabuni.info.summary" = "Sweet rice bake";
"recipe.al_kabuni.name" = "Kabuni";
"recipe.al_kabuni.step1.body" = "Place %i1 in a pot with %i2 and simmer gently until the broth is flavorful. Lift out the meat, strain the broth, and keep the broth for the dessert.";
"recipe.al_kabuni.step1.title" = "Make the broth";
"recipe.al_kabuni.step2.body" = "Melt %i4 in the large pot, add %i3, and stir it over medium heat until the grains are glossy and lightly coated.";
"recipe.al_kabuni.step2.title" = "Toast the rice";
"recipe.al_kabuni.step3.body" = "Stir in %i5, then pour in the hot mutton broth and add %i9.";
"recipe.al_kabuni.step3.title" = "Add the raisins and broth";
"recipe.al_kabuni.step4.body" = "Simmer gently until the rice has absorbed most of the liquid and is nearly tender.";
"recipe.al_kabuni.step4.title" = "Cook the rice";
"recipe.al_kabuni.step5.body" = "Stir in %i6, %i7, and %i8 until evenly distributed.";
"recipe.al_kabuni.step5.title" = "Season the kabuni";
"recipe.al_kabuni.step6.body" = "Transfer the rice mixture to the baking dish and spread it into an even layer.";
"recipe.al_kabuni.step6.title" = "Fill the dish";
"recipe.al_kabuni.step7.body" = "Bake until the top darkens slightly and the mixture is fully set with a rich baked aroma.";
"recipe.al_kabuni.step7.title" = "Bake the kabuni";
"recipe.al_kabuni.step8.body" = "Let the kabuni cool fully so it takes on its traditional dense texture.";
"recipe.al_kabuni.step8.title" = "Cool completely";
"recipe.al_kabuni.step9.body" = "Cut or spoon the kabuni into portions and serve it cold.";
"recipe.al_kabuni.step9.title" = "Serve";
