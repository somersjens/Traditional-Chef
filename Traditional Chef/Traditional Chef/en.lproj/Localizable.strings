"recipe.sn_mafe.drink.summary" = "Red wine (Grenache)";
"recipe.sn_mafe.info" = "Senegalese Mafe is a classic peanut-based stew where browned meat simmers in a tomato-tinged broth enriched with ground peanuts, alongside hearty vegetables, and is traditionally served over plain white rice for a filling family meal.";
"recipe.sn_mafe.info.summary" = "Peanut meat stew";
"recipe.sn_mafe.name" = "Mafé";
