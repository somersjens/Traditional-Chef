"recipe.eg_kunafa.drink.summary" = "Sweet wine (Moscato)";
"recipe.eg_kunafa.info" = "Kunafa is a classic Egyptian dessert of shredded pastry baked until deeply golden and crisp, then soaked with fragrant sugar syrup and layered or filled with thick ashta cream. Served warm or at room temperature after the syrup settles, it is a staple of Ramadan and celebrations, prized for its contrast of crunchy pastry, creamy filling, and perfumed sweetness.";
"recipe.eg_kunafa.info.summary" = "Crisp Ramadan pastry";
"recipe.eg_kunafa.name" = "Kunafa with cream";
"recipe.eg_kunafa.step1.body" = "Combine %i3 and %i4 in a saucepan and bring to a gentle boil, stirring until dissolved. Simmer until lightly thickened, then stir in %i5 and %i6 and let the syrup cool.";
"recipe.eg_kunafa.step1.title" = "Make the sugar syrup";
"recipe.eg_kunafa.step10.body" = "Cut into portions and serve warm or at room temperature.";
"recipe.eg_kunafa.step10.title" = "Serve";
"recipe.eg_kunafa.step2.body" = "Whisk %i7, %i8, and %i9 in a saucepan until smooth. Cook over medium heat, whisking, until thick and bubbling, then whisk in %i10 and cook briefly until silky. Cool until warm.";
"recipe.eg_kunafa.step2.title" = "Cook the ashta cream";
"recipe.eg_kunafa.step3.body" = "Loosen and cut the %i1 into short strands. Warm the %i2 until fluid and rub it thoroughly through the pastry so it is evenly coated.";
"recipe.eg_kunafa.step3.title" = "Prepare the kunafa";
"recipe.eg_kunafa.step4.body" = "Press most of the buttered kunafa firmly into the baking pan to form an even base with well-compacted edges.";
"recipe.eg_kunafa.step4.title" = "Form the base layer";
"recipe.eg_kunafa.step5.body" = "Spread the ashta evenly over the base, leaving a small clear border so the filling does not leak.";
"recipe.eg_kunafa.step5.title" = "Add the ashta";
"recipe.eg_kunafa.step6.body" = "Cover with the remaining kunafa and press firmly to seal and level the surface.";
"recipe.eg_kunafa.step6.title" = "Top and seal";
"recipe.eg_kunafa.step7.body" = "Bake until the kunafa is deeply golden and crisp, rotating the pan if needed for even browning.";
"recipe.eg_kunafa.step7.title" = "Bake until deep golden";
"recipe.eg_kunafa.step8.body" = "Remove from the oven and immediately ladle cooled syrup evenly over the hot kunafa so it absorbs throughout.";
"recipe.eg_kunafa.step8.title" = "Soak with syrup";
"recipe.eg_kunafa.step9.body" = "Let the kunafa rest so the syrup distributes and the layers settle for clean serving.";
"recipe.eg_kunafa.step9.title" = "Rest to set";
