"recipe.ps_knafeh_nabulsiya.drink.body" = "A lightly sweet dessert wine such as Muscat pairs well with the salty cheese and floral syrup. For a non-alcoholic pairing, serve Arabic coffee or black tea with mint.";
"recipe.ps_knafeh_nabulsiya.drink.summary" = "Dessert wine (Muscat)";
"recipe.ps_knafeh_nabulsiya.info" = "Knafeh Nabulsiya is the classic Palestinian dessert from Nablus, made with a soft semolina crust, melted Nabulsi cheese, and fragrant sugar syrup. It is traditionally served warm for celebrations, holidays, and family visits, with the pastry turned out and finished with pistachios.";
"recipe.ps_knafeh_nabulsiya.info.summary" = "Warm Nablus knafeh";
"recipe.ps_knafeh_nabulsiya.name" = "Knafeh";
"recipe.ps_knafeh_nabulsiya.step1.body" = "Slice %i1 and soak it in water so excess salt is drawn out and the cheese softens for baking.";
"recipe.ps_knafeh_nabulsiya.step1.title" = "Soak the cheese";
"recipe.ps_knafeh_nabulsiya.step2.body" = "Cook %i5 with water until fully dissolved and lightly thickened, then add %i7 and %i8 and leave the syrup to cool.";
"recipe.ps_knafeh_nabulsiya.step2.title" = "Make the syrup";
"recipe.ps_knafeh_nabulsiya.step3.body" = "Rub %i3 with %i4 until the grains are evenly coated and the mixture feels like damp sand.";
"recipe.ps_knafeh_nabulsiya.step3.title" = "Prepare the semolina base";
"recipe.ps_knafeh_nabulsiya.step4.body" = "Drain the soaked cheese very well and pat it dry so the filling melts evenly without releasing excess liquid.";
"recipe.ps_knafeh_nabulsiya.step4.title" = "Drain and prepare the cheese";
"recipe.ps_knafeh_nabulsiya.step5.body" = "Press most of the semolina mixture firmly into the baking pan, spread the cheese evenly over it, then cover with the remaining semolina mixture and press gently.";
"recipe.ps_knafeh_nabulsiya.step5.title" = "Assemble the knafeh";
"recipe.ps_knafeh_nabulsiya.step6.body" = "Bake the knafeh until the base is deep golden, the top is lightly colored, and the cheese has fully melted.";
"recipe.ps_knafeh_nabulsiya.step6.title" = "Bake until golden";
"recipe.ps_knafeh_nabulsiya.step7.body" = "Invert the hot knafeh onto a serving platter so the golden side faces upward in the traditional style.";
"recipe.ps_knafeh_nabulsiya.step7.title" = "Turn out the pastry";
"recipe.ps_knafeh_nabulsiya.step8.body" = "Pour the cooled syrup evenly over the hot knafeh so it is absorbed while the pastry stays crisp at the edges.";
"recipe.ps_knafeh_nabulsiya.step8.title" = "Finish with syrup";
"recipe.ps_knafeh_nabulsiya.step9.body" = "Scatter %i9 over the top and serve the knafeh warm.";
"recipe.ps_knafeh_nabulsiya.step9.title" = "Garnish and serve";
