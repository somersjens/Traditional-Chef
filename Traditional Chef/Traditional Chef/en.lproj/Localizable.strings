"recipe.ng_egusi_soup.drink.body" = "A fruity, low-tannin red like Grenache can handle the palm oil richness and spice without clashing. If you prefer white, a dry Riesling pairs well with pepper heat and the nutty egusi. Non-alcoholic pairing: chilled zobo (hibiscus) or sparkling water with lime.";
"recipe.ng_egusi_soup.drink.summary" = "Red wine (Grenache)";
"recipe.ng_egusi_soup.info" = "Egusi soup is a beloved Nigerian soup made by cooking ground melon seeds into a thick, richly flavored base with palm oil, pepper, crayfish, and an assortment of meats, then finishing with leafy greens. It is traditionally served as a main course with a swallow such as pounded yam, used to scoop up the hearty, nutty soup.";
"recipe.ng_egusi_soup.info.summary" = "Melon seed soup";
"recipe.ng_egusi_soup.name" = "Egusi soup";
"recipe.ng_egusi_soup.step1.body" = "Rinse the %i1, %i2, %i3, %i4, %i5, and %i6. Wash the %i15 and drain. Peel the %i16 and cut into chunks.";
"recipe.ng_egusi_soup.step1.title" = "Prep and rinse";
"recipe.ng_egusi_soup.step10.body" = "Stir in spinach and cook briefly until wilted, then taste and adjust seasoning.";
"recipe.ng_egusi_soup.step10.title" = "Finish with greens";
"recipe.ng_egusi_soup.step11.body" = "Boil the yam in %i17 with %i18 until very soft and easily mashed.";
"recipe.ng_egusi_soup.step11.title" = "Boil yam";
"recipe.ng_egusi_soup.step12.body" = "Drain the yam and mash vigorously until smooth, stretchy, and cohesive, adding small splashes of hot water as needed.";
"recipe.ng_egusi_soup.step12.title" = "Pound yam";
"recipe.ng_egusi_soup.step13.body" = "Serve egusi soup hot with pounded yam for scooping.";
"recipe.ng_egusi_soup.step13.title" = "Serve";
"recipe.ng_egusi_soup.step2.body" = "Blend the %i8 and %i9 into a smooth paste and set aside.";
"recipe.ng_egusi_soup.step2.title" = "Blend aromatics";
"recipe.ng_egusi_soup.step3.body" = "Add the beef, goat meat, tripe, and cow skin to the soup pot with %i12, %i13, and %i14, then simmer until tender and a rich stock forms.";
"recipe.ng_egusi_soup.step3.title" = "Cook meats to tender";
"recipe.ng_egusi_soup.step4.body" = "Add the stockfish and continue simmering until it softens and the stock tastes well infused.";
"recipe.ng_egusi_soup.step4.title" = "Soften stockfish";
"recipe.ng_egusi_soup.step5.body" = "Add the smoked fish and %i10 and simmer gently so the smoky flavor spreads through the broth.";
"recipe.ng_egusi_soup.step5.title" = "Add smoked fish and crayfish";
"recipe.ng_egusi_soup.step6.body" = "Pour in %i11 and simmer until the oil is well incorporated and the soup looks glossy.";
"recipe.ng_egusi_soup.step6.title" = "Add palm oil";
"recipe.ng_egusi_soup.step7.body" = "Stir in the blended pepper mixture and cook until the raw aroma fades and the broth tastes rounded.";
"recipe.ng_egusi_soup.step7.title" = "Cook pepper base";
"recipe.ng_egusi_soup.step8.body" = "Stir %i7 into the simmering soup, then cook without stirring too much at first so it sets into curds before gently mixing.";
"recipe.ng_egusi_soup.step8.title" = "Add egusi";
