"recipe.cl_caldillo_de_congrio.drink.body" = "Pair with a dry Chilean Sauvignon Blanc or an unoaked Chardonnay to match the sea flavor and cut through the cream. A light, crisp lager also works well. Non-alcoholic option: sparkling water with lemon or a chilled citrus tonic with plenty of ice.";
"recipe.cl_caldillo_de_congrio.drink.summary" = "White wine (Sauvignon)";
"recipe.cl_caldillo_de_congrio.info" = "Caldillo de congrio is a traditional Chilean coastal fish soup built on a flavorful stock made from congrio head and bones, then finished with a sautéed base of onion, garlic, tomato and ají de color. Potatoes and vegetables simmer in the broth, and tender pieces of congrio are added at the end, enriched with a touch of cream and finished with cilantro and lemon. It is served piping hot in bowls, commonly with crusty Chilean bread on the side.";
"recipe.cl_caldillo_de_congrio.info.summary" = "Conger fish soup";
"recipe.cl_caldillo_de_congrio.name" = "Caldillo de congrio";
"recipe.cl_caldillo_de_congrio.step1.body" = "Peel and cut the vegetables. Separate %i20 for the stock and chop cilantro leaves for finishing. Cut %i1 into serving portions and keep chilled.";
"recipe.cl_caldillo_de_congrio.step1.title" = "Prep the ingredients";
"recipe.cl_caldillo_de_congrio.step2.body" = "Add %i2 to a pot with %i3, %i4, %i5, %i6, and %i7. Bring to a gentle simmer and cook to extract a clean, flavorful broth.";
"recipe.cl_caldillo_de_congrio.step2.title" = "Cook the fish stock";
"recipe.cl_caldillo_de_congrio.step3.body" = "Strain the broth into a bowl, discarding solids. Return the clear stock to the pot and keep it hot over low heat.";
"recipe.cl_caldillo_de_congrio.step3.title" = "Strain the stock";
"recipe.cl_caldillo_de_congrio.step4.body" = "In the pot, warm %i8 and cook %i9 until soft. Stir in %i10, %i11, and %i12, then add %i14 and %i15 and cook briefly until fragrant.";
"recipe.cl_caldillo_de_congrio.step4.title" = "Build the soup base";
"recipe.cl_caldillo_de_congrio.step5.body" = "Add %i13 and cook until it breaks down into the base. Pour in %i17 and simmer to cook off the raw alcohol aroma.";
"recipe.cl_caldillo_de_congrio.step5.title" = "Add tomato and wine";
"recipe.cl_caldillo_de_congrio.step6.body" = "Pour in the hot fish stock and add %i18. Simmer until the potatoes are tender and the soup tastes cohesive.";
"recipe.cl_caldillo_de_congrio.step6.title" = "Simmer potatoes in the broth";
"recipe.cl_caldillo_de_congrio.step7.body" = "Add the congrio pieces and cook gently just until the fish turns opaque and flakes easily, keeping the broth at a calm simmer.";
"recipe.cl_caldillo_de_congrio.step7.title" = "Poach the fish";
"recipe.cl_caldillo_de_congrio.step8.body" = "Lower the heat and stir in %i19, warming the soup through without boiling hard. Taste and adjust salt and %i16.";
"recipe.cl_caldillo_de_congrio.step8.title" = "Enrich with cream";
"recipe.cl_caldillo_de_congrio.step9.body" = "Ladle into bowls, top with cilantro leaves, and serve with %i21 to squeeze over and %i22 on the side.";
"recipe.cl_caldillo_de_congrio.step9.title" = "Finish and serve";
