"recipe.us_mi_detroit_style_pizza.step4.title" = "Make the sauce";
"recipe.us_mi_detroit_style_pizza.step5.body" = "Rub the pan with %i14, then coat with %i15 to create a well-greased surface for a crisp, caramelized crust.";
"recipe.us_mi_detroit_style_pizza.step5.title" = "Prepare the pan";
