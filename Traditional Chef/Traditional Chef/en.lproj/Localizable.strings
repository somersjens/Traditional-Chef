"recipe.bd_beef_rezala.drink.body" = "An off-dry Riesling or aromatic white with a touch of sweetness balances the rich dairy sauce and warm spices without clashing. If you prefer red, choose a light-bodied, low-tannin red served slightly chilled. Non-alcoholic pairing: chilled lemon soda or unsweetened black tea.";
"recipe.bd_beef_rezala.drink.summary" = "White wine (Riesling)";
"recipe.bd_beef_rezala.info" = "Beef rezala is a traditional Bangladeshi Mughal-influenced curry where beef is simmered gently in a rich, pale sauce of yogurt, ghee, fried onions, and aromatic whole spices, thickened with a poppy-seed and nut paste for a smooth, creamy finish. It is typically served as a celebratory main with fragrant basmati polao, making a balanced plate of tender meat, mellow heat, and perfumed rice.";
"recipe.bd_beef_rezala.info.summary" = "Creamy white beef curry";
"recipe.bd_beef_rezala.name" = "Beef rezala";
"recipe.bd_beef_rezala.step1.body" = "Slice the %i3 thinly, mince the %i5, grate the %i4, and slit the %i6. Keep the %i13, %i14, %i15, and %i16 ready.";
"recipe.bd_beef_rezala.step1.title" = "Prep aromatics and spices";
"recipe.bd_beef_rezala.step10.body" = "Uncover to thicken the sauce to a creamy consistency, then stir in %i21 and adjust seasoning with the remaining salt if needed.";
"recipe.bd_beef_rezala.step10.title" = "Finish the rezala";
"recipe.bd_beef_rezala.step11.body" = "Rinse the %i22. Heat %i23 in a saucepan, fry the reserved %i24 until fragrant, then add %i25, %i26, %i27, and %i28 and stir briefly.";
"recipe.bd_beef_rezala.step11.title" = "Start the polao";
"recipe.bd_beef_rezala.step12.body" = "Add the rice and %i29, then add %i30 and bring to a simmer. Cover and cook gently until tender, then rest covered so the rice fluffs up.";
"recipe.bd_beef_rezala.step12.title" = "Cook and rest the polao";
"recipe.bd_beef_rezala.step13.body" = "Serve the beef rezala hot alongside the basmati polao.";
"recipe.bd_beef_rezala.step13.title" = "Serve";
"recipe.bd_beef_rezala.step2.body" = "Rinse the %i17, cover them with %i20, and let them soak until softened.";
"recipe.bd_beef_rezala.step2.title" = "Soak poppy seeds";
"recipe.bd_beef_rezala.step3.body" = "Drain the poppy seeds, then blend them with %i18 and %i19 until very smooth.";
"recipe.bd_beef_rezala.step3.title" = "Make the thickening paste";
"recipe.bd_beef_rezala.step4.body" = "Whisk the %i2 smooth, then mix it with ginger, garlic, green chilies, %i9, %i10, %i11, and %i12. Coat the %i1 thoroughly in this mixture.";
"recipe.bd_beef_rezala.step4.title" = "Marinate the beef";
"recipe.bd_beef_rezala.step5.body" = "Cover and refrigerate so the beef absorbs the yogurt and spices.";
"recipe.bd_beef_rezala.step5.title" = "Rest the marinade";
"recipe.bd_beef_rezala.step6.body" = "Heat %i7 with %i8 and fry the onions slowly until deep golden. Remove half for the polao and keep the rest for the rezala.";
"recipe.bd_beef_rezala.step6.title" = "Fry the onions";
"recipe.bd_beef_rezala.step7.body" = "In the same pot, add the cinnamon, cardamom, cloves, and bay leaves to the hot fat and fry briefly until aromatic.";
"recipe.bd_beef_rezala.step7.title" = "Bloom whole spices";
"recipe.bd_beef_rezala.step8.body" = "Add the marinated beef and cook, stirring, until the yogurt looks absorbed and the surface of the beef is lightly sealed.";
"recipe.bd_beef_rezala.step8.title" = "Seal the beef";
"recipe.bd_beef_rezala.step9.body" = "Add the poppy-and-cashew paste and enough water to maintain a gentle simmer. Cover and cook until the beef is tender, stirring occasionally to prevent sticking.";
"recipe.bd_beef_rezala.step9.title" = "Simmer until tender";
