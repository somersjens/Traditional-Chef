"recipe.bo_sajta_de_pollo.step10.title" = "Cook the rice";
"recipe.bo_sajta_de_pollo.step11.body" = "Taste the stew and adjust the salt, then stir in most of the parsley so the sauce stays bright and aromatic.";
"recipe.bo_sajta_de_pollo.step11.title" = "Finish the sajta";
"recipe.bo_sajta_de_pollo.step12.body" = "Serve the sajta de pollo hot with rice and chuño on the side, with the potatoes and sauce spooned over the chicken. Finish with the remaining parsley.";
"recipe.bo_sajta_de_pollo.step12.title" = "Serve traditionally";
"recipe.bo_sajta_de_pollo.step2.body" = "Cover %i2 with hot water and let them soften fully.";
"recipe.bo_sajta_de_pollo.step2.title" = "Soak the chili";
"recipe.bo_sajta_de_pollo.step3.body" = "Peel the soaked chuño, chop %i3, mince %i4, cut %i5, peel %i14, and chop %i13. Season %i1 with part of %i11 and %i12.";
"recipe.bo_sajta_de_pollo.step3.title" = "Prepare the ingredients";
