"recipe.be_boulets_a_la_liegeoise.drink.body" = "Pair with a malty Belgian brown ale or a fruity red such as Pinot Noir to match the sweet-and-sour syrup sauce and the browned meat. For a non-alcoholic option, serve sparkling water or a tart apple cider-style soft drink to cut through the richness.";
"recipe.be_boulets_a_la_liegeoise.drink.summary" = "Beer (Belgian)";
"recipe.be_boulets_a_la_liegeoise.info" = "Boulets à la Liégeoise are large Belgian meatballs from the Liège region, browned and then simmered in a sweet-and-sour sauce lapin made with onions, vinegar, raisins, and Sirop de Liège. They are traditionally served in pairs with Belgian fries and mayonnaise, letting the rich, tangy sauce coat both the meat and the frites.";
"recipe.be_boulets_a_la_liegeoise.info.summary" = "Liège meatballs and fries";
"recipe.be_boulets_a_la_liegeoise.name" = "Liège meatballs";
"recipe.be_boulets_a_la_liegeoise.step1.body" = "Tear %i3 into a bowl, pour over %i4, and let it soften completely. Squeeze out the excess milk before mixing.";
