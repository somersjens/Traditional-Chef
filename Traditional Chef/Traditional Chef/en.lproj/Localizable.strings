"recipe.tr_mercimek_corba.drink.summary" = "White wine (Sauvignon)";
"recipe.tr_mercimek_corba.info" = "Mercimek Çorbası is a traditional Turkish red lentil soup simmered with onion, carrot, and potato, then blended smooth and finished with a classic butter-and-pul-biber drizzle. It is served hot with lemon wedges and bread, commonly eaten as a comforting starter at home and in lokantas.";
"recipe.tr_mercimek_corba.info.summary" = "Red lentil soup";
