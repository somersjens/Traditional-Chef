"recipe.al_fergese.drink.body" = "A dry, fresh white wine such as Sauvignon Blanc or a light local white pairs well with the peppers, tomatoes, and tangy cheese. A good non-alcoholic option is sparkling water or a salted yogurt drink.";
"recipe.al_fergese.drink.summary" = "White wine (Sauvignon)";
"recipe.al_fergese.info" = "Fergese is a traditional Albanian baked dish, especially associated with Tirana, made from peppers, tomatoes, onions, basil, and gjize, the country’s salted curd cheese. It is served hot as a starter with bread, with a soft, rich texture somewhere between a baked spread and a thick vegetable casserole.";
"recipe.al_fergese.info.summary" = "Baked pepper cheese";
"recipe.al_fergese.name" = "Fërgesë";
"recipe.al_fergese.step1.body" = "Core and slice %i1 and %i2, peel and slice %i3, peel and chop %i4, and chop %i9.";
"recipe.al_fergese.step1.title" = "Prepare the vegetables";
"recipe.al_fergese.step2.body" = "Heat %i6 in the frying pan and cook the onions and peppers until softened. Add the tomatoes, %i10, and %i11 and cook until the mixture thickens and most of the moisture cooks away.";
"recipe.al_fergese.step2.title" = "Cook the vegetables";
"recipe.al_fergese.step3.body" = "Melt %i7 in the small saucepan, stir in %i8, and cook briefly until smooth without browning.";
"recipe.al_fergese.step3.title" = "Make the roux";
"recipe.al_fergese.step4.body" = "Stir the roux into the vegetable mixture, add the basil, then crumble in %i5 and mix until everything is thick and evenly combined.";
"recipe.al_fergese.step4.title" = "Finish the mixture";
"recipe.al_fergese.step5.body" = "Transfer the mixture to the ovenproof baking dish and spread it into an even layer.";
"recipe.al_fergese.step5.title" = "Fill the dish";
"recipe.al_fergese.step6.body" = "Bake until the top is lightly golden and the mixture is bubbling around the edges.";
"recipe.al_fergese.step6.title" = "Bake the fergese";
"recipe.al_fergese.step7.body" = "Let the fergese stand for a short time so it settles and thickens slightly before serving.";
"recipe.al_fergese.step7.title" = "Rest briefly";
"recipe.al_fergese.step8.body" = "Serve the fergese hot with %i12 alongside.";
"recipe.al_fergese.step8.title" = "Serve";
"recipe.al_fergese.tool.t1" = "Cutting board";
"recipe.al_fergese.tool.t2" = "Chef knife";
