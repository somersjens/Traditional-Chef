"recipe.ro_ostropel_de_pui.drink.body" = "A dry Romanian white such as Fetească Albă or Sauvignon Blanc pairs well with the bright tomato sauce and strong garlic notes. For a non-alcoholic pairing, serve sparkling water or still water.";
"recipe.ro_ostropel_de_pui.drink.summary" = "White wine (Fetească Albă)";
"recipe.ro_ostropel_de_pui.info" = "Ostropel de pui is a traditional Romanian chicken dish in which browned chicken is simmered in a garlicky tomato sauce until tender and deeply savory. It is a homestyle main course, especially associated with family cooking, and it is classically served hot with mămăligă to absorb the sauce.";
"recipe.ro_ostropel_de_pui.info.summary" = "Garlic tomato chicken";
"recipe.ro_ostropel_de_pui.name" = "Chicken ostropel";
"recipe.ro_ostropel_de_pui.step1.body" = "Pat %i1 dry and season it with %i10 and %i11. Finely chop %i3, crush %i4, chop %i9, and break up %i5.";
"recipe.ro_ostropel_de_pui.step1.title" = "Prepare the ingredients";
"recipe.ro_ostropel_de_pui.step2.body" = "Heat %i2 in the deep skillet and brown the chicken on both sides until lightly golden. Remove it to a plate.";
"recipe.ro_ostropel_de_pui.step2.title" = "Brown the chicken";
"recipe.ro_ostropel_de_pui.step3.body" = "Add the onion to the pan and cook until softened, then add the garlic and cook briefly until fragrant.";
"recipe.ro_ostropel_de_pui.step3.title" = "Cook the base";
"recipe.ro_ostropel_de_pui.step4.body" = "Stir in the tomatoes, %i6, %i7, %i8, and the remaining salt and black pepper, then bring the sauce to a gentle simmer.";
"recipe.ro_ostropel_de_pui.step4.title" = "Build the sauce";
"recipe.ro_ostropel_de_pui.step5.body" = "Return the chicken to the pan and cook gently until the meat is tender and the sauce is rich, garlicky, and slightly reduced.";
"recipe.ro_ostropel_de_pui.step5.title" = "Simmer the ostropel";
"recipe.ro_ostropel_de_pui.step6.body" = "Bring %i13 to a boil in the saucepan, add %i14, then pour in %i12 gradually while whisking.";
"recipe.ro_ostropel_de_pui.step6.title" = "Start the mămăligă";
"recipe.ro_ostropel_de_pui.step7.body" = "Cook over low heat, stirring often, until the mămăligă is thick, smooth, and pulls slightly from the sides of the pan.";
"recipe.ro_ostropel_de_pui.step7.title" = "Cook the mămăligă";
"recipe.ro_ostropel_de_pui.step8.body" = "Stir the parsley into the ostropel, then serve the chicken and sauce hot with the mămăligă alongside.";
"recipe.ro_ostropel_de_pui.step8.title" = "Finish and serve";
