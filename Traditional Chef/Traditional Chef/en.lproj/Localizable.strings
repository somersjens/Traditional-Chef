"recipe.ch_zurcher_geschnetzeltes.drink.body" = "Serve with a dry Swiss white wine such as Chasselas or Fendant, which matches the creamy veal sauce without overpowering it. A light lager also works well. For a non-alcoholic option, serve sparkling apple juice or hot black tea.";
"recipe.ch_zurcher_geschnetzeltes.drink.summary" = "White wine (Chasselas)";
"recipe.ch_zurcher_geschnetzeltes.info" = "Zürcher Geschnetzeltes is a traditional dish from Zürich made with thin strips of veal in a delicate sauce of white wine, stock, cream, onion, and mushrooms. It is classically served with rösti, making it a rich yet elegant Swiss main course for lunch or dinner.";
"recipe.ch_zurcher_geschnetzeltes.info.summary" = "Zürich veal classic";
"recipe.ch_zurcher_geschnetzeltes.name" = "Zürcher Geschnetzeltes";
"recipe.ch_zurcher_geschnetzeltes.step1.body" = "Place %i13 in a saucepan, cover with water, bring to a boil, and cook until just tender but still firm.";
"recipe.ch_zurcher_geschnetzeltes.step1.title" = "Boil the potatoes";
"recipe.ch_zurcher_geschnetzeltes.step10.body" = "Cut the rösti into portions and serve it immediately with the Zürcher Geschnetzeltes spooned over or alongside.";
"recipe.ch_zurcher_geschnetzeltes.step10.title" = "Serve";
"recipe.ch_zurcher_geschnetzeltes.step2.body" = "Drain the potatoes and leave them to cool until they can be peeled and grated without breaking apart.";
"recipe.ch_zurcher_geschnetzeltes.step2.title" = "Cool the potatoes";
"recipe.ch_zurcher_geschnetzeltes.step3.body" = "Peel and coarsely grate the potatoes. Slice %i1 into thin strips, slice %i2, finely chop %i3, and chop %i10.";
"recipe.ch_zurcher_geschnetzeltes.step3.title" = "Prepare the ingredients";
"recipe.ch_zurcher_geschnetzeltes.step4.body" = "Heat part of %i15 in a large frying pan, add the grated potatoes, season with some of %i11, press them into a round cake, and cook until the underside is golden.";
"recipe.ch_zurcher_geschnetzeltes.step4.title" = "Cook the rösti base";
"recipe.ch_zurcher_geschnetzeltes.step5.body" = "Flip the rösti, add the remaining clarified butter around the edge, and cook until crisp and golden on the other side. Keep it warm.";
"recipe.ch_zurcher_geschnetzeltes.step5.title" = "Turn and finish the rösti";
"recipe.ch_zurcher_geschnetzeltes.step6.body" = "Melt part of %i4 in a hot saute pan, add the veal in batches, season lightly, brown it quickly, and remove it from the pan.";
"recipe.ch_zurcher_geschnetzeltes.step6.title" = "Brown the veal";
"recipe.ch_zurcher_geschnetzeltes.step7.body" = "Add the remaining butter to the pan, cook the onion and mushrooms until softened, then sprinkle in %i5 and stir briefly.";
"recipe.ch_zurcher_geschnetzeltes.step7.title" = "Make the sauce base";
"recipe.ch_zurcher_geschnetzeltes.step8.body" = "Pour in %i6 and let it reduce slightly, then add %i7 and %i8 and simmer until the sauce thickens smoothly.";
"recipe.ch_zurcher_geschnetzeltes.step8.title" = "Build the sauce";
"recipe.ch_zurcher_geschnetzeltes.step9.body" = "Return the veal to the sauce, add %i9 and parsley, season with the remaining salt and %i12, and heat gently without boiling hard.";
"recipe.ch_zurcher_geschnetzeltes.step9.title" = "Finish the veal";
