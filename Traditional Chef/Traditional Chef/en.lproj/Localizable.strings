"recipe.bg_patatnik.drink.body" = "A fresh white wine such as Sauvignon Blanc or Pinot Grigio pairs well with the potatoes, salty cheese, and mint. For a non-alcoholic pairing, serve ayran or chilled yogurt drink.";
"recipe.bg_patatnik.drink.summary" = "White wine (Sauvignon)";
"recipe.bg_patatnik.info" = "Patatnik is a traditional Bulgarian potato pie from the Rhodope Mountains, made with grated potatoes, onion, eggs, sirene, and the characteristic aroma of spearmint. It is a rustic family dish traditionally cooked slowly until crisp outside and soft within, then served hot in wedges.";
"recipe.bg_patatnik.info.summary" = "Rhodope potato pie";
"recipe.bg_patatnik.name" = "Patatnik";
"recipe.bg_patatnik.step1.body" = "Peel %i1 and grate them coarsely with %i2 so the mixture stays moist and aromatic.";
"recipe.bg_patatnik.step1.title" = "Prepare the potatoes";
"recipe.bg_patatnik.step10.body" = "Cut the patatnik into wedges and serve it hot in the traditional way.";
"recipe.bg_patatnik.step10.title" = "Serve hot";
"recipe.bg_patatnik.step2.body" = "Wrap the grated potatoes and onion in a clean towel and squeeze out as much liquid as possible so the patatnik cooks evenly and browns well.";
"recipe.bg_patatnik.step2.title" = "Drain the mixture";
"recipe.bg_patatnik.step3.body" = "Transfer the drained mixture to a bowl and mix it with %i3, crumbled %i4, %i7, %i8, %i9, and %i10 until evenly combined.";
"recipe.bg_patatnik.step3.title" = "Make the filling mixture";
"recipe.bg_patatnik.step4.body" = "Heat %i5 with half of %i6 in the skillet so the base is well greased and ready to brown the pie.";
"recipe.bg_patatnik.step4.title" = "Heat the skillet";
"recipe.bg_patatnik.step5.body" = "Spread the potato mixture in the skillet in an even thick layer and press it gently so it holds together.";
"recipe.bg_patatnik.step5.title" = "Shape the patatnik";
"recipe.bg_patatnik.step6.body" = "Cover the skillet and cook slowly until the underside is deeply golden and the potatoes are softening through the center.";
"recipe.bg_patatnik.step6.title" = "Cook the first side";
"recipe.bg_patatnik.step7.body" = "Loosen the edges, invert the patatnik onto a large plate, then slide it back into the skillet with the remaining butter.";
"recipe.bg_patatnik.step7.title" = "Turn the pie";
"recipe.bg_patatnik.step8.body" = "Cover again and cook until the second side is golden and the center is fully set and tender.";
"recipe.bg_patatnik.step8.title" = "Cook the second side";
"recipe.bg_patatnik.step9.body" = "Take the patatnik off the heat and let it stand briefly so it firms up and slices cleanly.";
"recipe.bg_patatnik.step9.title" = "Rest before serving";
