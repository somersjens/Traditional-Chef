"recipe.bo_fricase_paceno.drink.body" = "A cold light lager is the classic match for the spicy pork broth and rich chuño and mote. A young crisp white wine can also work. For a non-alcoholic option, serve hot herbal tea or sparkling water with lime.";
"recipe.bo_fricase_paceno.drink.summary" = "Beer (Lager)";
"recipe.bo_fricase_paceno.info" = "Fricase Paceno is a traditional La Paz pork stew built on a vivid yellow chili broth with garlic, cumin, oregano, and hierbabuena. It is served hot with chuño and mote in the bowl, and is a classic morning or midday dish in the Bolivian highlands.";
"recipe.bo_fricase_paceno.info.summary" = "Yellow pork stew";
"recipe.bo_fricase_paceno.name" = "Fricase paceño";
