"recipe.fi_kaalilaatikko.drink.body" = "A light, fresh red wine such as Pinot Noir pairs well with the sweet-savory cabbage and browned meat. A good non-alcoholic option is cold milk or a tart lingonberry drink.";
"recipe.fi_kaalilaatikko.drink.summary" = "Red wine (Pinot Noir)";
"recipe.fi_kaalilaatikko.info" = "Kaalilaatikko is a traditional Finnish cabbage casserole baked slowly until the cabbage turns tender and lightly caramelized. The classic home-style version combines cabbage, ground meat, onion, porridge rice, marjoram, and syrup, and it is traditionally served hot with lingonberry jam.";
"recipe.fi_kaalilaatikko.info.summary" = "Cabbage meat casserole";
"recipe.fi_kaalilaatikko.name" = "Cabbage casserole";
"recipe.fi_kaalilaatikko.step1.body" = "Remove the core from %i1 and shred it. Bring %i2 and %i3 to a boil in the pot, add the cabbage, and cook until it softens.";
"recipe.fi_kaalilaatikko.step1.title" = "Prepare the cabbage";
"recipe.fi_kaalilaatikko.step2.body" = "Peel and chop %i4. Lift the cabbage out and reserve the cooking liquid. In the same pot, cook the onion and %i5 until the meat is browned and the onion is soft.";
"recipe.fi_kaalilaatikko.step2.title" = "Cook the meat and onion";
"recipe.fi_kaalilaatikko.step3.body" = "Add %i6, %i7, the remaining salt, and half of %i8 to the meat mixture and stir well.";
"recipe.fi_kaalilaatikko.step3.title" = "Season the mixture";
"recipe.fi_kaalilaatikko.step4.body" = "Butter the casserole dish with %i10. Layer in the cabbage, meat mixture, and %i9, then pour over enough reserved cooking liquid to keep the mixture moist.";
"recipe.fi_kaalilaatikko.step4.title" = "Assemble the casserole";
"recipe.fi_kaalilaatikko.step5.body" = "Drizzle the remaining dark syrup over the top so the casserole bakes to its traditional sweet browned finish.";
"recipe.fi_kaalilaatikko.step5.title" = "Finish the top";
"recipe.fi_kaalilaatikko.step6.body" = "Bake slowly until the rice is tender, the liquid is absorbed, and the top is deeply golden with caramelized edges.";
"recipe.fi_kaalilaatikko.step6.title" = "Bake the casserole";
"recipe.fi_kaalilaatikko.step7.body" = "Let the casserole stand briefly so it settles and serves neatly.";
"recipe.fi_kaalilaatikko.step7.title" = "Rest before serving";
"recipe.fi_kaalilaatikko.step8.body" = "Spoon the kaalilaatikko onto plates and serve it hot with %i11 on the side.";
"recipe.fi_kaalilaatikko.step8.title" = "Serve";
