"recipe.fi_karjalanpaisti.tool.t6" = "Ladle";
"recipe.fi_karjalanpaisti.tool.t7" = "Oven";
"recipe.fi_lohikeitto.drink.body" = "A dry, crisp white wine such as Sauvignon Blanc or unoaked Chardonnay pairs well with the salmon, cream, and dill. A good non-alcoholic option is cold sparkling water or chilled milk.";
"recipe.fi_lohikeitto.drink.summary" = "White wine (Sauvignon)";
"recipe.fi_lohikeitto.info" = "Lohikeitto is a traditional Finnish salmon soup made with salmon, potatoes, leek, carrot, cream, dill, and mild warming spice. It is served hot as a comforting family meal, especially in colder weather, and is traditionally accompanied by rye bread.";
"recipe.fi_lohikeitto.info.summary" = "Finnish salmon soup";
"recipe.fi_lohikeitto.name" = "Salmon soup";
"recipe.fi_lohikeitto.step1.body" = "Peel and cut %i2 and %i4 into bite-size pieces. Clean and slice %i3. Cut %i1 into large chunks and chop %i8.";
"recipe.fi_lohikeitto.step1.title" = "Prepare the ingredients";
"recipe.fi_lohikeitto.step2.body" = "Melt %i5 in the pot and cook the leek gently until softened without browning.";
"recipe.fi_lohikeitto.step2.title" = "Start the soup base";
"recipe.fi_lohikeitto.step3.body" = "Add the potatoes, carrot, %i6, %i9, %i10, and %i11. Bring to a boil, lower the heat, and simmer until the vegetables are nearly tender.";
"recipe.fi_lohikeitto.step3.title" = "Cook the vegetables";
"recipe.fi_lohikeitto.step4.body" = "Add the salmon to the pot, pour in %i7, and heat the soup gently so the fish starts to poach without breaking apart.";
"recipe.fi_lohikeitto.step4.title" = "Add the salmon and cream";
"recipe.fi_lohikeitto.step5.body" = "Simmer gently until the salmon is just cooked through and the vegetables are fully tender. Stir in the dill and adjust the seasoning with the remaining salt.";
"recipe.fi_lohikeitto.step5.title" = "Finish the soup";
"recipe.fi_lohikeitto.step6.body" = "Ladle the lohikeitto into bowls and serve it hot with %i12 alongside.";
"recipe.fi_lohikeitto.step6.title" = "Serve";
"recipe.fi_lohikeitto.tool.t1" = "Large pot";
"recipe.fi_lohikeitto.tool.t2" = "Cutting board";
"recipe.fi_lohikeitto.tool.t3" = "Chef knife";
"recipe.fi_lohikeitto.tool.t4" = "Wooden spoon";
"recipe.fi_lohikeitto.tool.t5" = "Ladle";
"recipe.fi_mammi.drink.body" = "A light dessert wine such as late harvest Riesling can work with the dark malt sweetness, though mammi is more traditionally served without alcohol. A good non-alcoholic pairing is cold milk or black coffee.";
"recipe.fi_mammi.drink.summary" = "Dessert wine (Riesling)";
"recipe.fi_mammi.info" = "Mammi is a traditional Finnish Easter dessert made from rye flour, malted rye, water, dark syrup, salt, and dried orange peel, then baked slowly until dark and set. It is served well chilled, traditionally with cream and sugar, as part of the Easter table.";
"recipe.fi_mammi.info.summary" = "Finnish rye Easter pudding";
"recipe.fi_mammi.name" = "Mämmi";
"recipe.fi_mammi.step1.body" = "Heat part of %i3 until warm and stir in %i2 and some of %i1 to make a loose mixture.";
"recipe.fi_mammi.step1.title" = "Mix the base";
"recipe.fi_mammi.step2.body" = "Keep the mixture warm so it sweetens naturally and darkens slightly.";
"recipe.fi_mammi.step2.title" = "Let it sweeten";
"recipe.fi_mammi.step3.body" = "Stir in more warm water and the remaining rye flour in batches until the mixture is smooth and thick.";
"recipe.fi_mammi.step3.title" = "Build the porridge";
"recipe.fi_mammi.step4.body" = "Keep the mixture warm once more so the malt develops its traditional sweetness.";
"recipe.fi_mammi.step4.title" = "Sweeten again";
"recipe.fi_mammi.step5.body" = "Stir in %i4, %i5, and %i6, then add enough water to make a thick but spoonable batter.";
"recipe.fi_mammi.step5.title" = "Season the mammi";
"recipe.fi_mammi.step6.body" = "Pour the mixture into the baking dish and bake slowly until it is dark, glossy, and fully set.";
"recipe.fi_mammi.step6.title" = "Bake slowly";
"recipe.fi_mammi.step7.body" = "Cool the mammi completely, then chill it well so the texture firms and the flavour matures before serving.";
"recipe.fi_mammi.step7.title" = "Chill the dessert";
"recipe.fi_mammi.step8.body" = "Spoon the mammi into bowls and serve it cold with %i7 and %i8.";
"recipe.fi_mammi.step8.title" = "Serve";
"recipe.fi_mammi.tool.t1" = "Large pot";
"recipe.fi_mammi.tool.t2" = "Wooden spoon";
"recipe.fi_mammi.tool.t3" = "Baking dish";
"recipe.fi_mammi.tool.t4" = "Oven";
