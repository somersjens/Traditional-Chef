"recipe.ph_lechon.drink.body" = "A light red wine such as Pinot Noir pairs well with the rich pork and crisp skin. A pale lager is also a classic match for lechon. For a non-alcoholic option, serve calamansi juice or iced tea.";
"recipe.ph_lechon.drink.summary" = "Red wine (Pinot Noir)";
"recipe.ph_lechon.info" = "Lechon is a traditional Filipino celebratory roast pork dish known for crackling skin and juicy, aromatic meat. This lechon belly version keeps the classic flavors of lemongrass, garlic, and spices in a size suitable for home preparation, and it is traditionally served with liver sauce and steamed rice.";
"recipe.ph_lechon.info.summary" = "Celebration roast pork";
"recipe.ph_lechon.name" = "Lechon belly";
"recipe.ph_lechon.step1.body" = "Bruise the %i2 and chop it roughly. Peel and crush the %i3, slice the %i4 and %i5, and crush the %i7 lightly. Score the meat side of the %i1 without cutting through the skin and pat the skin very dry.";
"recipe.ph_lechon.step1.title" = "Prepare aromatics and pork";
"recipe.ph_lechon.step10.body" = "Blend the cooked liver with part of the cooking liquid until smooth.";
"recipe.ph_lechon.step10.title" = "Blend liver base";
"recipe.ph_lechon.step11.body" = "Heat %i21 in a saucepan and cook the %i14 and %i15 until softened, then add the %i20.";
"recipe.ph_lechon.step11.title" = "Start liver sauce";
"recipe.ph_lechon.step12.body" = "Add the blended liver, %i16, %i17, %i18, %i19, and remaining cooking liquid as needed, then simmer while stirring until thick, smooth, and glossy.";
"recipe.ph_lechon.step12.title" = "Finish liver sauce";
"recipe.ph_lechon.step13.body" = "Rinse the %i22, then cook it in a saucepan with %i23 until tender and the water is absorbed.";
"recipe.ph_lechon.step13.title" = "Cook rice";
"recipe.ph_lechon.step14.body" = "Let the covered rice rest, then fluff before serving.";
"recipe.ph_lechon.step14.title" = "Rest rice";
"recipe.ph_lechon.step15.body" = "Remove the twine, slice the lechon into serving pieces, and serve hot with liver sauce and steamed rice.";
"recipe.ph_lechon.step15.title" = "Carve and serve";
"recipe.ph_lechon.step2.body" = "Rub the meat side with %i8, peppercorns, %i10, and %i9, then spread the lemongrass, garlic, onion, ginger, and %i6 over the meat side.";
"recipe.ph_lechon.step2.title" = "Season and stuff belly";
"recipe.ph_lechon.step3.body" = "Roll the pork belly tightly with the skin on the outside to enclose the aromatics, then tie securely with butchers twine at regular intervals.";
"recipe.ph_lechon.step3.title" = "Roll and tie belly";
"recipe.ph_lechon.step4.body" = "Place the rolled belly uncovered on a rack and refrigerate so the skin dries thoroughly for better crackling.";
"recipe.ph_lechon.step4.title" = "Air-dry pork";
"recipe.ph_lechon.step5.body" = "Place the pork on a rack in a roasting pan, add %i11 to the pan, and roast at moderate heat to begin rendering the fat and cooking the meat evenly.";
"recipe.ph_lechon.step5.title" = "Start roasting";
"recipe.ph_lechon.step6.body" = "Continue roasting, adding a little water to the pan if needed, until the pork is tender and the skin is drying and tightening.";
"recipe.ph_lechon.step6.title" = "Roast until tender";
"recipe.ph_lechon.step7.body" = "Increase the oven heat and roast until the skin is blistered, crisp, and deeply golden, turning the roast as needed for even coloring.";
"recipe.ph_lechon.step7.title" = "Crisp the skin";
"recipe.ph_lechon.step8.body" = "Transfer the roast to a board and let it rest so the juices settle and the skin stays crisp.";
"recipe.ph_lechon.step8.title" = "Rest lechon";
