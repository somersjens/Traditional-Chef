"recipe.mm_mohinga.step1.title" = "Prepare the aromatics and fish";
"recipe.mm_mohinga.step10.body" = "Heat the %i26 and fry small spoonfuls of batter until golden and crisp, then drain.";
"recipe.mm_mohinga.step10.title" = "Fry the fritters";
"recipe.mm_mohinga.step11.body" = "Boil the %i13 in %i14 until tender, then drain well.";
"recipe.mm_mohinga.step11.title" = "Cook the noodles";
"recipe.mm_mohinga.step12.body" = "Taste the mohinga broth and adjust with the remaining salt if needed, then keep it hot for serving.";
"recipe.mm_mohinga.step12.title" = "Adjust and finish the soup";
"recipe.mm_mohinga.step13.body" = "Divide the noodles into bowls, ladle over the hot mohinga broth, and top with egg, fritters, cilantro, crispy fried shallots, green chili, and lime wedges.";
"recipe.mm_mohinga.step13.title" = "Assemble and serve";
"recipe.mm_mohinga.step2.body" = "Heat a little %i10 in a stock pot and cook the onion, garlic, ginger, lemongrass, and %i7 until fragrant.";
"recipe.mm_mohinga.step2.title" = "Start the broth base";
"recipe.mm_mohinga.step3.body" = "Add the fish, %i2, %i8, and part of the %i9, bring to a boil, then simmer until the fish is cooked and the broth is aromatic.";
"recipe.mm_mohinga.step3.title" = "Simmer the fish broth";
"recipe.mm_mohinga.step4.body" = "Remove the fish from the pot, strain the broth, and pick the fish meat from the bones. Flake the fish and discard bones and solids.";
"recipe.mm_mohinga.step4.title" = "Separate fish and broth";
"recipe.mm_mohinga.step5.body" = "Finely shred the %i12 and mix the %i11 with a little cool water into a smooth slurry.";
"recipe.mm_mohinga.step5.title" = "Prepare the soup body";
"recipe.mm_mohinga.step6.body" = "Return the strained broth to the pot, add the flaked fish and banana stem, then stir in the chickpea flour slurry and simmer until lightly thickened.";
"recipe.mm_mohinga.step6.title" = "Thicken the mohinga broth";
"recipe.mm_mohinga.step7.body" = "Boil the %i15 until firm, cool them, peel, and halve them for topping.";
"recipe.mm_mohinga.step7.title" = "Boil the eggs";
