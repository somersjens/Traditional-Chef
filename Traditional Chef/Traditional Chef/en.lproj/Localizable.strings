"recipe.no_komle.drink.body" = "A light lager or a crisp dry cider pairs well with the rich meats, bacon, and earthy dumplings. A good non-alcoholic option is cold sparkling water or a lightly tart apple drink.";
"recipe.no_komle.drink.summary" = "Beer (Lager)";
"recipe.no_komle.info" = "Komle is a traditional western Norwegian dish of dense potato dumplings cooked in broth and served as a hearty main meal. In the classic coastal style it comes with salted lamb, smoked sausage, rutabaga mash, and crisp bacon with the cooking broth spooned over at the table.";
"recipe.no_komle.info.summary" = "Norwegian potato dumplings";
"recipe.no_komle.name" = "Komle";
"recipe.no_komle.step1.body" = "Place %i6 in the large pot, cover with %i8, bring to a gentle boil, then lower the heat and simmer until the meat is tender and the broth is flavorful.";
"recipe.no_komle.step1.title" = "Cook the lamb";
"recipe.no_komle.step2.body" = "Peel and cut %i9, place it in the medium pot with %i10, and boil until fully tender.";
"recipe.no_komle.step2.title" = "Cook the rutabaga";
"recipe.no_komle.step3.body" = "Peel and grate %i1, then squeeze off excess liquid. Mash %i2 until smooth and combine them with the grated potatoes in the bowl.";
"recipe.no_komle.step3.title" = "Prepare the potato base";
"recipe.no_komle.step4.body" = "Mix in %i3, %i4, and %i5 until you have a firm dough that holds its shape. Form even dumplings with wet hands.";
"recipe.no_komle.step4.title" = "Make the komle dough";
"recipe.no_komle.step5.body" = "Lift the lamb out and keep it warm. Bring the broth back to a gentle simmer, lower in the dumplings, and cook them steadily until they are firm and cooked through.";
"recipe.no_komle.step5.title" = "Cook the dumplings";
"recipe.no_komle.step6.body" = "Drain the rutabaga and mash it with %i11, %i12, and %i13. Cut %i7 into large pieces and warm it in the broth during the last part of the dumpling cooking.";
"recipe.no_komle.step6.title" = "Finish the accompaniments";
"recipe.no_komle.step7.body" = "Cut %i14 into pieces and fry until crisp. Add the remaining %i15 and let it foam with the bacon fat.";
"recipe.no_komle.step7.title" = "Fry the bacon";
"recipe.no_komle.step8.body" = "Lift out the komle and arrange them with the lamb, sausage, and rutabaga mash. Spoon over a little broth and finish with the bacon and butter mixture.";
"recipe.no_komle.step8.title" = "Serve";
