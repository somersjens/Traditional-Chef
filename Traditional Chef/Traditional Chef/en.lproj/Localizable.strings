"recipe.pk_nihari.drink.body" = "A medium-bodied red such as Syrah or Tempranillo can stand up to the rich spiced gravy without overwhelming it. A malty amber ale also works. Non-alcoholic pairing: salted lassi or hot black tea are both excellent choices.";
"recipe.pk_nihari.drink.summary" = "Red wine (Syrah)";
"recipe.pk_nihari.info" = "Nihari is a traditional Pakistani slow-cooked beef stew, especially associated with Lahore and Karachi, made with shank meat, marrow bones, a deeply spiced gravy, and a flour-thickened broth simmered until silky and rich. It is traditionally served hot with naan and fresh garnishes, often as a special breakfast or weekend meal.";
"recipe.pk_nihari.info.summary" = "Slow-cooked nihari";
"recipe.pk_nihari.name" = "Nihari";
"recipe.pk_nihari.step1.body" = "Slice the %i5. Finely chop the %i6 and part of the %i7 for cooking. Julienne the remaining %i24 for garnish. Chop the %i23 and %i25, and cut the %i26 into wedges.";
"recipe.pk_nihari.step1.title" = "Prepare ingredients";
"recipe.pk_nihari.step10.body" = "Turn off the heat and let the nihari rest briefly so the gravy settles and the flavors meld.";
"recipe.pk_nihari.step10.title" = "Rest stew";
"recipe.pk_nihari.step11.body" = "Warm the %i27 briefly until soft and fragrant for serving.";
"recipe.pk_nihari.step11.title" = "Warm naan";
"recipe.pk_nihari.step12.body" = "Transfer the nihari to a serving bowl, top with cilantro, julienned ginger, green chili, and lemon wedges, and serve hot with naan.";
"recipe.pk_nihari.step12.title" = "Garnish and serve";
"recipe.pk_nihari.step2.body" = "Heat the %i4 in a heavy pot over medium heat. Add the onion and cook until deep golden, stirring regularly so it browns evenly without burning.";
"recipe.pk_nihari.step2.title" = "Brown onions in ghee";
"recipe.pk_nihari.step3.body" = "Add the chopped garlic and chopped ginger and cook briefly. Add the %i9, %i10, %i11, %i12, %i13, %i14, %i16, %i17, %i18, %i19, %i20, and part of the %i8, then cook until fragrant.";
"recipe.pk_nihari.step3.title" = "Add aromatics and spices";
"recipe.pk_nihari.step4.body" = "Add the %i1 and %i2 and cook while stirring so the meat is coated with the spiced onion base and begins to brown lightly.";
"recipe.pk_nihari.step4.title" = "Add beef and bones";
"recipe.pk_nihari.step5.body" = "Add %i3 and the remaining salt, bring slowly to a boil, and skim the surface well for a cleaner gravy.";
"recipe.pk_nihari.step5.title" = "Add water and bring to boil";
"recipe.pk_nihari.step6.body" = "Cover and simmer on very low heat until the beef is very tender, the marrow flavors the broth, and the gravy becomes rich and developed.";
"recipe.pk_nihari.step6.title" = "Slow simmer";
"recipe.pk_nihari.step7.body" = "Whisk the %i21 with %i22 in a bowl until smooth with no lumps.";
"recipe.pk_nihari.step7.title" = "Make flour slurry";
"recipe.pk_nihari.step8.body" = "Stir the slurry into the simmering pot while mixing continuously. Add the %i15 and cook gently until the gravy thickens to a silky stew consistency.";
"recipe.pk_nihari.step8.title" = "Thicken nihari";
"recipe.pk_nihari.step9.body" = "Simmer uncovered on low heat so the flour cooks through and the oil rises slightly on top.";
"recipe.pk_nihari.step9.title" = "Final simmer";
