"recipe.pr_asopao_de_pollo.drink.body" = "A lightly oaked white like Viognier or an aromatic white such as Albariño pairs well with the savory sofrito and rich broth. A crisp lager also works nicely. For a non-alcoholic option, serve iced lime water or a cold tropical juice like passion fruit.";
"recipe.pr_asopao_de_pollo.drink.summary" = "White wine (Viognier)";
"recipe.pr_asopao_de_pollo.info" = "Asopao de pollo is a traditional Puerto Rican chicken-and-rice stew, thicker than soup but looser than arroz con pollo, built on fragrant sofrito and gently simmered until the rice turns creamy and the chicken is tender. It is commonly served hot as a comforting family meal, often with avocado on the side and crispy tostones for scooping.";
"recipe.pr_asopao_de_pollo.info.summary" = "Chicken rice stew";
"recipe.pr_asopao_de_pollo.name" = "Asopao";
"recipe.pr_asopao_de_pollo.step1.body" = "Warm %i23 with %i22 until the oil turns deep orange-red, then strain out the seeds and set the oil aside.";
"recipe.pr_asopao_de_pollo.step1.title" = "Make achiote oil";
"recipe.pr_asopao_de_pollo.step2.body" = "Blend %i6, %i7, %i8, %i9, %i10, and %i11 into a thick paste.";
"recipe.pr_asopao_de_pollo.step2.title" = "Make the sofrito";
"recipe.pr_asopao_de_pollo.step3.body" = "Season %i1 with %i4 and %i5, heat achiote oil in the pot, and brown the chicken on both sides.";
"recipe.pr_asopao_de_pollo.step3.title" = "Brown the chicken";
"recipe.pr_asopao_de_pollo.step4.body" = "Add %i13 and cook briefly, then stir in the sofrito until fragrant. Add %i14, %i15, %i16, %i18, and %i17.";
"recipe.pr_asopao_de_pollo.step4.title" = "Build the base";
"recipe.pr_asopao_de_pollo.step5.body" = "Add %i2 and %i3, bring to a gentle simmer, cover, and cook until the chicken is tender.";
"recipe.pr_asopao_de_pollo.step5.title" = "Simmer the chicken";
"recipe.pr_asopao_de_pollo.step6.body" = "Add %i19 and %i20 and simmer until they begin to soften.";
"recipe.pr_asopao_de_pollo.step6.title" = "Add vegetables";
"recipe.pr_asopao_de_pollo.step7.body" = "Stir in %i21 and simmer, stirring occasionally, until the rice is tender and the stew turns creamy. Adjust seasoning with salt.";
"recipe.pr_asopao_de_pollo.step7.title" = "Cook the rice";
"recipe.pr_asopao_de_pollo.step8.body" = "Peel and slice %i25, fry until softened, smash flat, then fry again until crisp and season with %i27.";
"recipe.pr_asopao_de_pollo.step8.title" = "Fry and smash the plantains";
"recipe.pr_asopao_de_pollo.step9.body" = "Remove bay leaves, rest briefly, then ladle into bowls. Serve hot with %i24 on the side and tostones for scooping.";
"recipe.pr_asopao_de_pollo.step9.title" = "Finish and serve";
