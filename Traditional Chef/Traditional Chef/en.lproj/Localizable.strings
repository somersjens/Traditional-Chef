"recipe.be_tarte_al_djote.step5.title" = "Cool the filling base";
"recipe.be_tarte_al_djote.step6.body" = "Crumble %i10 finely. Stir it into the chard mixture with %i11, chopped %i12, and %i13 until evenly combined.";
"recipe.be_tarte_al_djote.step6.title" = "Mix the filling";
