"recipe.kr_galbi.step3.title" = "Make the galbi marinade";
"recipe.kr_galbi.step4.body" = "Coat the ribs thoroughly with the marinade and refrigerate until seasoned and tenderized.";
"recipe.kr_galbi.step4.title" = "Marinate the ribs";
"recipe.kr_galbi.step5.body" = "Rinse the %i15 in cold water until the water runs mostly clear, then drain well.";
"recipe.kr_galbi.step5.title" = "Rinse the rice";
"recipe.kr_galbi.step6.body" = "Combine the rice with %i16 in a pot, bring to a boil, cover, reduce heat, and cook until tender. Rest covered off the heat.";
"recipe.kr_galbi.step6.title" = "Cook the rice";
