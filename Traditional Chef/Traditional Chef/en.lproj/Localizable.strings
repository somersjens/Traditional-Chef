"recipe.my_sago_gula_melaka.step2.body" = "Bring %i2 to a boil in a large pot and add the %i1, stirring to prevent clumping. Cook until the pearls are mostly translucent with only a small white center remaining.";
"recipe.my_sago_gula_melaka.step2.title" = "Cook the sago pearls";
"recipe.my_sago_gula_melaka.step3.body" = "Turn off the heat, cover the pot, and let the sago sit so the remaining white centers turn translucent. Check that the pearls are soft and evenly cooked.";
"recipe.my_sago_gula_melaka.step3.title" = "Rest to finish translucency";
"recipe.my_sago_gula_melaka.step4.body" = "Pour the sago into a fine strainer and rinse under water to remove excess starch. Drain well so the pearls stay glossy and separate.";
"recipe.my_sago_gula_melaka.step4.title" = "Rinse and drain the sago";
"recipe.my_sago_gula_melaka.step5.body" = "Spoon the warm sago into the molds or cups and press lightly to level the surface. Leave them to cool, then chill until set.";
"recipe.my_sago_gula_melaka.step5.title" = "Set the sago portions";
"recipe.my_sago_gula_melaka.step6.body" = "Heat the %i4, pandan leaves, and water in a small saucepan until the sugar dissolves completely. Simmer gently until the syrup is smooth and slightly thickened, then strain if needed.";
"recipe.my_sago_gula_melaka.step6.title" = "Make gula melaka syrup";
"recipe.my_sago_gula_melaka.step7.body" = "Heat the %i7, %i9, and %i8 gently in a small saucepan, stirring until smooth and lightly warmed. Do not let it boil hard.";
"recipe.my_sago_gula_melaka.step7.title" = "Prepare coconut sauce";
"recipe.my_sago_gula_melaka.step8.body" = "Turn out the chilled sago onto serving bowls and spoon over gula melaka syrup and coconut sauce. Serve chilled in the traditional style.";
"recipe.my_sago_gula_melaka.step8.title" = "Unmold and serve";
