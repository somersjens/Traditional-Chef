"recipe.ps_maqluba.drink.body" = "A light to medium-bodied red wine such as Pinot Noir or Cinsault pairs well with the warm spices and savory chicken. For a non-alcoholic pairing, serve salted yogurt drink or chilled mint tea.";
"recipe.ps_maqluba.drink.summary" = "Red wine (Pinot Noir)";
"recipe.ps_maqluba.info" = "Maqluba is a traditional Palestinian main dish of spiced rice layered with chicken, fried vegetables, and rich stock, then turned upside down for serving. It is a celebratory family dish often presented at the center of the table with yogurt on the side.";
"recipe.ps_maqluba.info.summary" = "Upside-down rice dish";
"recipe.ps_maqluba.name" = "Maqluba";
"recipe.ps_maqluba.step1.body" = "Cut %i1 into serving pieces and place them in a large pot with %i2, %i3, %i4, part of %i5, %i6, and %i7.";
"recipe.ps_maqluba.step1.title" = "Prepare the chicken";
"recipe.ps_maqluba.step10.body" = "Dice %i19 finely and mix it with %i18, %i20, and the rest of %i21 until smooth and well seasoned.";
"recipe.ps_maqluba.step10.title" = "Prepare the yogurt sauce";
"recipe.ps_maqluba.step11.body" = "Toast %i16 briefly until golden, then chop %i17.";
"recipe.ps_maqluba.step11.title" = "Toast the almonds";
"recipe.ps_maqluba.step12.body" = "Place a large platter over the pot and carefully invert the maqluba. Lift off the pot, scatter the almonds and parsley over the top, and serve with the yogurt sauce on the side.";
"recipe.ps_maqluba.step12.title" = "Turn and serve";
"recipe.ps_maqluba.step2.body" = "Bring the pot to a boil, skim well, then simmer until the chicken is tender and the broth is rich. Lift out the chicken pieces and strain the stock.";
"recipe.ps_maqluba.step2.title" = "Cook the stock";
"recipe.ps_maqluba.step3.body" = "Slice %i8 into rounds and break %i9 into florets so they cook evenly and layer neatly.";
"recipe.ps_maqluba.step3.title" = "Prepare the vegetables";
"recipe.ps_maqluba.step4.body" = "Heat most of %i10 and fry the eggplant and cauliflower in batches until golden and tender. Drain them well.";
"recipe.ps_maqluba.step4.title" = "Fry the vegetables";
"recipe.ps_maqluba.step5.body" = "Rinse %i11 until the water runs mostly clear, drain it, then mix it with %i12, %i13, %i14, and part of the remaining %i15.";
"recipe.ps_maqluba.step5.title" = "Wash and season the rice";
"recipe.ps_maqluba.step6.body" = "Spread a little olive oil in the heavy pot, then arrange the chicken pieces tightly across the bottom.";
"recipe.ps_maqluba.step6.title" = "Start the layering";
"recipe.ps_maqluba.step7.body" = "Arrange the fried eggplant and cauliflower over the chicken, then spread the rice over the top in an even layer without pressing too hard.";
"recipe.ps_maqluba.step7.title" = "Build the layers";
"recipe.ps_maqluba.step8.body" = "Pour in enough hot stock to cover the rice, then cook gently until the rice is tender and the liquid is absorbed.";
"recipe.ps_maqluba.step8.title" = "Cook the maqluba";
"recipe.ps_maqluba.step9.body" = "Take the pot off the heat and let the maqluba rest so the layers firm up before turning.";
"recipe.ps_maqluba.step9.title" = "Rest the pot";
