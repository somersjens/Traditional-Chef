"recipe.tr_baklava.drink.body" = "A lightly sweet Muscat or late-harvest Riesling complements the buttery pastry and pistachios without cloying. For a non-alcoholic option, serve strong Turkish tea or plain coffee alongside.";
"recipe.tr_baklava.drink.summary" = "Dessert wine (Muscat)";
"recipe.tr_baklava.info" = "Turkish baklava is a traditional dessert of many thin layers of filo pastry brushed with clarified butter, filled with finely chopped pistachios, baked until deeply golden, then soaked with a fragrant lemon sugar syrup. It is served in small diamond pieces at celebrations and with tea, prized for its crisp flakes, rich butter aroma, and syrupy nut center.";
"recipe.tr_baklava.info.summary" = "Pistachio filo classic";
"recipe.tr_baklava.name" = "Baklava";
"recipe.tr_baklava.step1.body" = "Combine %i1 and %i2 in a saucepan, bring to a boil, then simmer until slightly thickened. Stir in %i3 and let the syrup cool to room temperature.";
"recipe.tr_baklava.step1.title" = "Make the syrup";
"recipe.tr_baklava.step10.body" = "As soon as it comes out of the oven, pour the cooled syrup evenly over the hot baklava so it sizzles and absorbs into the layers.";
"recipe.tr_baklava.step10.title" = "Syrup the hot baklava";
"recipe.tr_baklava.step11.body" = "Let the baklava rest at room temperature until the syrup is fully absorbed and the layers turn crisp.";
"recipe.tr_baklava.step11.title" = "Rest to set";
"recipe.tr_baklava.step12.body" = "Separate the pieces and serve at room temperature.";
"recipe.tr_baklava.step12.title" = "Serve";
"recipe.tr_baklava.step2.body" = "Melt %i6 gently until the milk solids separate, skim the foam, then strain to get clear clarified butter for brushing.";
"recipe.tr_baklava.step2.title" = "Clarify the butter";
"recipe.tr_baklava.step3.body" = "Pulse %i4 until finely chopped and evenly textured, then set aside.";
"recipe.tr_baklava.step3.title" = "Prepare the pistachios";
"recipe.tr_baklava.step4.body" = "Brush the baking pan with clarified butter. Unwrap %i5 and keep it covered with a towel so it does not dry out while assembling.";
"recipe.tr_baklava.step4.title" = "Prepare the pan and filo";
"recipe.tr_baklava.step5.body" = "Lay filo sheets into the pan one by one, brushing each layer with clarified butter and smoothing out air pockets as you build the base.";
"recipe.tr_baklava.step5.title" = "Layer the first half";
"recipe.tr_baklava.step6.body" = "Spread the chopped pistachios evenly over the layered base in a single, even blanket.";
"recipe.tr_baklava.step6.title" = "Add the nut filling";
"recipe.tr_baklava.step7.body" = "Continue layering the remaining filo sheets on top, brushing each layer with clarified butter and keeping the surface flat and even.";
"recipe.tr_baklava.step7.title" = "Finish the top layers";
"recipe.tr_baklava.step8.body" = "Using a sharp knife, cut the baklava all the way through into traditional diamond or square pieces before baking.";
"recipe.tr_baklava.step8.title" = "Cut into pieces";
"recipe.tr_baklava.step9.body" = "Bake until the baklava is crisp, puffed, and deeply golden throughout.";
"recipe.tr_baklava.step9.title" = "Bake until deeply golden";
