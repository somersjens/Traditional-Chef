"recipe.cn_lanzhou_niurou_lamian.drink.body" = "A crisp light lager can stand up to the beef broth and chili oil, while hot jasmine tea or warm plain water are classic non-alcoholic pairings that keep the palate clear.";
"recipe.cn_lanzhou_niurou_lamian.drink.summary" = "Beer (Lager)";
"recipe.cn_lanzhou_niurou_lamian.info" = "Lanzhou niurou lamian is a traditional northwestern Chinese noodle soup centered on a clear beef broth simmered with beef and aromatics, served with hand-pulled wheat noodles, sliced beef, white radish, chili oil, and fresh herbs. It is a classic everyday meal and noodle-shop staple, prized for balanced broth, springy noodles, and the characteristic toppings served hot in a large bowl.";
"recipe.cn_lanzhou_niurou_lamian.info.summary" = "Lanzhou beef noodles";
"recipe.cn_lanzhou_niurou_lamian.name" = "Lanzhou beef noodles";
