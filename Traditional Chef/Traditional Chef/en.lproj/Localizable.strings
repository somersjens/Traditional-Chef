"recipe.hu_dobos_torta.drink.body" = "Pair with a sweet Tokaji that complements caramel and dark chocolate while staying fresh. A coffee stout can also work alongside. For a non-alcoholic option, serve espresso, black tea, or sparkling water.";
"recipe.hu_dobos_torta.drink.summary" = "Dessert wine (Tokaji)";
"recipe.hu_dobos_torta.info" = "Dobos torte is Hungary’s iconic layered sponge cake filled with rich chocolate buttercream and finished with a hard caramel glaze on the top layer. The sides are traditionally coated with finely ground nuts, and the caramel is cut into wedges to form the signature crown. Served sliced, it is a classic celebratory cake designed to keep well and stay luxurious.";
"recipe.hu_dobos_torta.info.summary" = "Caramel-crowned torte";
"recipe.hu_dobos_torta.name" = "Dobos torte";
"recipe.hu_dobos_torta.step1.body" = "Preheat the oven and line baking trays with parchment. Trace a round template on the parchment so each sponge layer is the same size.";
"recipe.hu_dobos_torta.step1.title" = "Prepare for the thin layers";
"recipe.hu_dobos_torta.step10.body" = "While the caramel is still workable, score and cut the caramel-topped layer into equal wedges using an oiled knife.";
"recipe.hu_dobos_torta.step10.title" = "Cut the caramel wedges";
"recipe.hu_dobos_torta.step11.body" = "Arrange the caramel wedges on top of the cake in a spoke pattern, slightly tilted to form the classic crown.";
"recipe.hu_dobos_torta.step11.title" = "Crown the cake";
"recipe.hu_dobos_torta.step12.body" = "Chill until the buttercream is firm and the cake slices cleanly.";
"recipe.hu_dobos_torta.step12.title" = "Chill to set";
"recipe.hu_dobos_torta.step13.body" = "Slice with a sharp knife and serve, keeping the caramel wedges intact.";
"recipe.hu_dobos_torta.step13.title" = "Serve the torte";
"recipe.hu_dobos_torta.step2.body" = "Separate %i1. Whip the yolks with %i2 and the scraped %i5 until thick and pale, then fold in the sifted %i3, %i4, and %i6. Whip the whites to glossy peaks and fold them in gently to keep the batter airy.";
"recipe.hu_dobos_torta.step2.title" = "Make the sponge batter";
"recipe.hu_dobos_torta.step3.body" = "Spread the batter thinly inside the traced circles and bake in batches until lightly golden and springy. Remove the layers from the trays and cool them completely on a rack.";
"recipe.hu_dobos_torta.step3.title" = "Bake the sponge layers";
"recipe.hu_dobos_torta.step4.body" = "Melt %i8 gently until smooth, then let it cool slightly so it stays fluid.";
"recipe.hu_dobos_torta.step4.title" = "Melt the chocolate";
"recipe.hu_dobos_torta.step5.body" = "Heat %i11 with %i12 to a syrup. Whisk %i10 and slowly stream in the hot syrup while whisking until thick, pale, and warm.";
"recipe.hu_dobos_torta.step5.title" = "Cook the yolk base";
"recipe.hu_dobos_torta.step6.body" = "Beat %i7 until creamy, then beat in the yolk mixture. Add %i9 and the melted chocolate and beat until smooth and spreadable, seasoning with a pinch of %i13.";
"recipe.hu_dobos_torta.step6.title" = "Finish the buttercream";
"recipe.hu_dobos_torta.step7.body" = "Choose the flattest sponge for the caramel top and set it aside. Stack the remaining layers with thin, even spreads of chocolate buttercream between them.";
"recipe.hu_dobos_torta.step7.title" = "Layer the torte";
"recipe.hu_dobos_torta.step8.body" = "Spread a thin coat of buttercream over the sides and smooth it. Press %i15 onto the sides so they adhere evenly.";
"recipe.hu_dobos_torta.step8.title" = "Coat and nut the sides";
"recipe.hu_dobos_torta.step9.body" = "Melt %i14 to a deep amber caramel, working carefully so it does not burn. Immediately spread the caramel over the reserved sponge layer in a thin, even sheet.";
"recipe.hu_dobos_torta.step9.title" = "Make the caramel top";
