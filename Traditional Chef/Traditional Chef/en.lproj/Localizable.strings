"recipe.fr_coq_au_vin.drink.body" = "Pair with a Burgundy Pinot Noir or another medium-bodied French red that echoes the braising wine without overpowering the chicken. A dark, malty beer can also work alongside. For a non-alcoholic option, serve sparkling water or a tart blackcurrant spritz.";
"recipe.fr_coq_au_vin.drink.summary" = "Red wine (Pinot Noir)";
"recipe.fr_coq_au_vin.info" = "Coq au vin is a classic French dish of chicken pieces browned with lardons, then slowly braised in red wine with aromatics until tender in a glossy, dark sauce. It is finished with the traditional garnish of sautéed mushrooms and glazed pearl onions, creating a rich, wine-scented stew served hot with boiled potatoes or crusty bread.";
"recipe.fr_coq_au_vin.info.summary" = "Chicken in red wine";
"recipe.fr_coq_au_vin.name" = "Coq au vin";
"recipe.fr_coq_au_vin.step1.body" = "Pat %i1 dry. Cut %i3 and %i4, and crush %i5.";
"recipe.fr_coq_au_vin.step1.title" = "Prep the ingredients";
"recipe.fr_coq_au_vin.step10.body" = "Remove the bouquet garni. Add the mushrooms and pearl onions to the stew and simmer briefly to combine the flavours, adjusting seasoning if needed.";
"recipe.fr_coq_au_vin.step10.title" = "Finish the stew";
"recipe.fr_coq_au_vin.step11.body" = "Serve the coq au vin hot with boiled potatoes alongside.";
"recipe.fr_coq_au_vin.step11.title" = "Serve the coq au vin";
"recipe.fr_coq_au_vin.step2.body" = "In a heavy pot, cook %i2 until they render their fat and are lightly browned. Lift them out and keep the fat in the pot.";
"recipe.fr_coq_au_vin.step2.title" = "Render the lardons";
"recipe.fr_coq_au_vin.step3.body" = "Brown the chicken pieces well in batches in the hot fat with a little %i13 if needed, then set them aside.";
"recipe.fr_coq_au_vin.step3.title" = "Brown the chicken";
"recipe.fr_coq_au_vin.step4.body" = "Add the onions and carrots to the pot and cook until lightly coloured, scraping up the browned bits. Stir in the garlic briefly.";
"recipe.fr_coq_au_vin.step4.title" = "Brown the vegetables";
"recipe.fr_coq_au_vin.step5.body" = "Return the chicken and lardons to the pot, sprinkle over %i6 and stir to coat, then cook briefly. Stir in %i9.";
"recipe.fr_coq_au_vin.step5.title" = "Add flour and tomato";
"recipe.fr_coq_au_vin.step6.body" = "Pour in %i7 and %i8 while stirring, bring to a gentle simmer, and add %i10. Season with %i11 and %i12.";
"recipe.fr_coq_au_vin.step6.title" = "Add wine and stock";
"recipe.fr_coq_au_vin.step7.body" = "Cover and braise gently until the chicken is tender and the sauce is rich, turning the pieces occasionally and keeping it below a boil.";
"recipe.fr_coq_au_vin.step7.title" = "Slow-braise the chicken";
"recipe.fr_coq_au_vin.step8.body" = "Sauté %i14 in %i16 until their moisture evaporates and they are lightly browned. In the same pan, cook %i15 in butter until tender and lightly glazed.";
"recipe.fr_coq_au_vin.step8.title" = "Prepare the garnish";
"recipe.fr_coq_au_vin.step9.body" = "Boil %i17 in salted water until tender, then drain and keep them warm.";
"recipe.fr_coq_au_vin.step9.title" = "Boil the potatoes";
