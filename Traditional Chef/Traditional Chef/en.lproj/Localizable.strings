"recipe.id_sate_lilit.info" = "Sate lilit is a traditional Balinese satay made by wrapping a fragrant spiced minced mixture around lemongrass stalks and grilling it until lightly charred and aromatic. It is commonly served as part of family meals and ceremonial spreads, with rice and a fresh sambal on the side.";
"recipe.id_sate_lilit.info.summary" = "Balinese lemongrass satay";
"recipe.id_sate_lilit.name" = "Sate lilit";
"recipe.id_sate_lilit.step1.body" = "Finely chop the %i1 and prepare the aromatics, %i17, and %i12 so everything is ready for the satay mixture.";
"recipe.id_sate_lilit.step1.title" = "Prepare the fish and aromatics";
"recipe.id_sate_lilit.step2.body" = "Grind the %i3, %i4, %i5, %i7, %i8, %i9, %i10, %i11, %i13, and %i14 into a smooth fragrant paste.";
"recipe.id_sate_lilit.step2.title" = "Make the spice paste";
"recipe.id_sate_lilit.step3.body" = "Heat %i18 and fry the spice paste until aromatic and no longer raw, then let it cool slightly.";
"recipe.id_sate_lilit.step3.title" = "Cook the spice paste";
"recipe.id_sate_lilit.step4.body" = "Combine the chopped fish with %i2, sliced kaffir lime leaves, the cooked spice paste, %i15, and %i16, then mix until sticky and well blended.";
"recipe.id_sate_lilit.step4.title" = "Mix the satay filling";
"recipe.id_sate_lilit.step5.body" = "Take portions of the mixture and press them around the lemongrass stalks, wrapping and smoothing each one into an even elongated satay shape.";
"recipe.id_sate_lilit.step5.title" = "Shape onto lemongrass stalks";
"recipe.id_sate_lilit.step6.body" = "Rest the shaped sate lilit briefly so the mixture firms up and holds better during grilling.";
"recipe.id_sate_lilit.step6.title" = "Chill to firm";
"recipe.id_sate_lilit.step7.body" = "Grill over medium-hot charcoal, turning carefully and brushing with %i19 until cooked through, lightly charred, and fragrant.";
"recipe.id_sate_lilit.step7.title" = "Grill the sate lilit";
"recipe.id_sate_lilit.step8.body" = "Combine %i20, %i21, %i22, and %i23 with %i25, %i26, and %i27. Heat %i24 until hot and pour it over, then toss well.";
"recipe.id_sate_lilit.step8.title" = "Make sambal matah";
"recipe.id_sate_lilit.step9.body" = "Arrange the sate lilit on a platter and serve hot with sambal matah and %i28.";
"recipe.id_sate_lilit.step9.title" = "Serve";
