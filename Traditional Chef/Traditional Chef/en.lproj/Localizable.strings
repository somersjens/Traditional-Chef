"recipe.bg_sarmi.step2.title" = "Cook the filling";
"recipe.bg_sarmi.step3.body" = "Take the filling off the heat and leave it to cool slightly so it is easier to wrap.";
"recipe.bg_sarmi.step3.title" = "Cool the mixture";
"recipe.bg_sarmi.step4.body" = "Separate %i10, trim any thick ribs, and cut very large leaves into smaller wrapping pieces.";
"recipe.bg_sarmi.step4.title" = "Prepare the cabbage leaves";
"recipe.bg_sarmi.step5.body" = "Place some filling in each leaf, fold in the sides, and roll into small tight parcels.";
"recipe.bg_sarmi.step5.title" = "Roll the sarmi";
"recipe.bg_sarmi.step6.body" = "Pack the sarmi seam side down in the pot in close layers so they hold their shape while cooking.";
"recipe.bg_sarmi.step6.title" = "Arrange in the pot";
"recipe.bg_sarmi.step7.body" = "Season the top with the remaining salt and pour in %i11 so the rolls can cook gently without drying out.";
"recipe.bg_sarmi.step7.title" = "Add the cooking liquid";
"recipe.bg_sarmi.step8.body" = "Cover the pot and cook slowly until the cabbage is fully tender, the rice is soft, and the flavors have blended deeply.";
"recipe.bg_sarmi.step8.title" = "Cook until tender";
"recipe.bg_sarmi.step9.body" = "Take the pot off the heat and let the sarmi stand so the rolls settle and the liquid is absorbed slightly.";
"recipe.bg_sarmi.step9.title" = "Rest before serving";
