"recipe.tr_asure.drink.body" = "A lightly sweet Muscat or a late-harvest Riesling complements the dried fruit and nutty grain base without overwhelming it. For a non-alcoholic option, serve Turkish tea or a glass of cold water alongside.";
"recipe.tr_asure.drink.summary" = "Dessert wine (Muscat)";
"recipe.tr_asure.info" = "Aşure, also known as Noah’s pudding, is a traditional Turkish dessert made by simmering wheat berries with legumes and rice until creamy, then sweetening and enriching it with dried fruits and nuts. It is especially associated with Muharram and shared with neighbors and family, served in bowls and finished with classic toppings like pomegranate, walnuts, and cinnamon.";
"recipe.tr_asure.info.summary" = "Noah’s pudding";
"recipe.tr_asure.name" = "Aşure";
"recipe.tr_asure.step1.body" = "Rinse the %i2 and %i3, cover generously with %i5, and set aside to soak.";
"recipe.tr_asure.step1.title" = "Rinse and soak legumes";
"recipe.tr_asure.step10.body" = "Ladle the hot aşure into serving bowls and let it settle.";
"recipe.tr_asure.step10.title" = "Portion into bowls";
"recipe.tr_asure.step11.body" = "Let the bowls cool until the surface sets and the texture becomes pudding-like.";
"recipe.tr_asure.step11.title" = "Cool to set";
"recipe.tr_asure.step12.body" = "Top with %i11, %i12, %i13, and a dusting of %i14, then serve.";
"recipe.tr_asure.step12.title" = "Garnish and serve";
"recipe.tr_asure.step2.body" = "Let the legumes soak until plump and hydrated, then drain and rinse.";
"recipe.tr_asure.step2.title" = "Soak overnight";
"recipe.tr_asure.step3.body" = "Simmer the drained chickpeas and beans in fresh water until fully tender, then drain and set aside.";
"recipe.tr_asure.step3.title" = "Cook the legumes";
"recipe.tr_asure.step4.body" = "Rinse the %i1, add it to a large pot with water, bring to a boil, then lower to a steady simmer.";
"recipe.tr_asure.step4.title" = "Start the wheat";
"recipe.tr_asure.step5.body" = "Cook the wheat until softened and the liquid turns starchy and creamy, stirring occasionally so it does not stick.";
"recipe.tr_asure.step5.title" = "Simmer until creamy";
"recipe.tr_asure.step6.body" = "Rinse the %i4 and stir it into the wheat pot, then continue simmering until the rice breaks down and thickens the mixture.";
"recipe.tr_asure.step6.title" = "Add and cook the rice";
"recipe.tr_asure.step7.body" = "Chop the %i7 and %i8 into small pieces and rinse the %i9.";
"recipe.tr_asure.step7.title" = "Prep the dried fruits";
"recipe.tr_asure.step8.body" = "Stir in the %i6 and %i10 until dissolved, then add the cooked chickpeas and beans and simmer gently to bring everything together.";
"recipe.tr_asure.step8.title" = "Sweeten and combine";
"recipe.tr_asure.step9.body" = "Add the chopped dried fruits and raisins and simmer until they soften and the aşure becomes thick and spoonable.";
"recipe.tr_asure.step9.title" = "Add dried fruits and finish";
