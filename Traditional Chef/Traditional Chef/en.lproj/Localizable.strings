"recipe.my_ayam_percik.step1.title" = "Prepare chicken and aromatics";
"recipe.my_ayam_percik.step2.body" = "Soak the %i10 until soft, then drain. Blend them with the fresh chilies and aromatics into a smooth paste using a little %i15.";
"recipe.my_ayam_percik.step2.title" = "Blend spice paste";
"recipe.my_ayam_percik.step3.body" = "Heat %i16 in a saucepan and cook the spice paste until fragrant and the raw smell fades. Stir regularly so the paste thickens without catching.";
"recipe.my_ayam_percik.step3.title" = "Cook the percik base";
"recipe.my_ayam_percik.step4.body" = "Add the %i11, %i12, %i13, %i14, and water to the pan and simmer gently until the sauce is smooth and lightly thickened. Taste for a balanced spicy, savory, and tangy flavor.";
"recipe.my_ayam_percik.step4.title" = "Simmer the sauce";
"recipe.my_ayam_percik.step5.body" = "Reserve about one third of the sauce for final basting and serving. Coat the chicken pieces with the remaining sauce and let the surface absorb the seasoning.";
"recipe.my_ayam_percik.step5.title" = "Coat the chicken";
"recipe.my_ayam_percik.step6.body" = "Place the chicken on a medium grill and cook until the first side is browned with light charring. Turn carefully with tongs.";
"recipe.my_ayam_percik.step6.title" = "Grill first side";
"recipe.my_ayam_percik.step7.body" = "Baste the chicken repeatedly with the reserved sauce while grilling and turning until fully cooked and glossy. Let the sauce set on the surface between bastings.";
"recipe.my_ayam_percik.step7.title" = "Baste and finish grilling";
"recipe.my_ayam_percik.step8.body" = "Serve the ayam percik hot with %i17 and spoon the remaining percik sauce over the chicken.";
