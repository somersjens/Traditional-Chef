"recipe.ua_holubtsi.step4.title" = "Make the filling";
"recipe.ua_holubtsi.step5.body" = "Trim the thick ribs from the cabbage leaves, place some filling on each leaf, fold in the sides, and roll them into neat cabbage rolls.";
"recipe.ua_holubtsi.step5.title" = "Fill and roll the holubtsi";
"recipe.ua_holubtsi.step6.body" = "Slice %i11 and cook them in %i12 until soft, then stir in %i13, %i14, and %i15.";
"recipe.ua_holubtsi.step6.title" = "Start the sauce";
"recipe.ua_holubtsi.step7.body" = "Spread some sauce in the baking dish, place the holubtsi seam side down in snug layers, and cover them with the rest of the sauce.";
"recipe.ua_holubtsi.step7.title" = "Arrange the rolls";
"recipe.ua_holubtsi.step8.body" = "Cover the dish and bake until the cabbage is tender, the filling is fully cooked, and the sauce is rich and settled around the rolls.";
"recipe.ua_holubtsi.step8.title" = "Bake until tender";
"recipe.ua_holubtsi.step9.body" = "Let the holubtsi stand out of the oven so the rolls firm up slightly and the sauce settles.";
"recipe.ua_holubtsi.step9.title" = "Rest before serving";
