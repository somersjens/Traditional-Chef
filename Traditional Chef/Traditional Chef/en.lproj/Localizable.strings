"recipe.tr_mercimek_corba.step3.body" = "Add lentils, %i6, %i7, and %i8, bring to a simmer, and cook until the lentils and vegetables are very soft.";
"recipe.tr_mercimek_corba.step3.title" = "Simmer until tender";
