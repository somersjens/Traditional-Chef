"recipe.fi_mammi.tool.t6" = "Serving spoon";
"recipe.fi_poronkaristys.drink.body" = "A light, fresh red wine such as Pinot Noir pairs well with the delicate game flavour and buttery potatoes. A good non-alcoholic option is cold water or a tart lingonberry drink.";
"recipe.fi_poronkaristys.drink.summary" = "Red wine (Pinot Noir)";
"recipe.fi_poronkaristys.info" = "Poronkäristys is a traditional dish from Finnish Lapland made from very thin slices of reindeer cooked slowly until tender in a light savoury gravy. It is classically served hot with mashed potatoes, lingonberries, and pickled cucumber as a hearty northern Finnish main course.";
"recipe.fi_poronkaristys.info.summary" = "Sautéed reindeer";
"recipe.fi_poronkaristys.name" = "Sautéed reindeer";
"recipe.fi_poronkaristys.step1.body" = "Peel and chop %i2. Peel %i7 and cut them into even pieces.";
"recipe.fi_poronkaristys.step1.title" = "Prepare the ingredients";
"recipe.fi_poronkaristys.step2.body" = "Melt half of %i3 in the frying pan and cook %i1 over high heat in batches until lightly browned. Lift it out as it is done.";
"recipe.fi_poronkaristys.step2.title" = "Brown the reindeer";
"recipe.fi_poronkaristys.step3.body" = "Add the onion and the remaining butter to the pan and cook gently until softened.";
"recipe.fi_poronkaristys.step3.title" = "Cook the onion";
"recipe.fi_poronkaristys.step4.body" = "Return the reindeer to the pan, add %i4, %i5, and %i6, cover, and simmer gently until the meat is fully tender and the liquid has become a light gravy.";
"recipe.fi_poronkaristys.step4.title" = "Simmer the saute";
"recipe.fi_poronkaristys.step5.body" = "Cook the potatoes in water until tender, then drain them well.";
"recipe.fi_poronkaristys.step5.title" = "Boil the potatoes";
"recipe.fi_poronkaristys.step6.body" = "Mash the potatoes with %i9 and %i10 until smooth and soft.";
"recipe.fi_poronkaristys.step6.title" = "Mash the potatoes";
"recipe.fi_poronkaristys.step7.body" = "Spoon the poronkäristys over the mashed potatoes and serve it hot with %i12 and %i13 on the side.";
"recipe.fi_poronkaristys.step7.title" = "Serve";
"recipe.fi_poronkaristys.tool.t1" = "Large frying pan";
"recipe.fi_poronkaristys.tool.t2" = "Wooden spoon";
"recipe.fi_poronkaristys.tool.t3" = "Large pot";
"recipe.fi_poronkaristys.tool.t4" = "Potato masher";
"recipe.fi_poronkaristys.tool.t5" = "Cutting board";
"recipe.fi_poronkaristys.tool.t6" = "Chef knife";
"recipe.fi_poronkaristys.tool.t7" = "Slotted spoon";
"recipe.fj_fish_suruwa.drink.body" = "A dry Riesling suits the spice and coconut without overpowering the fish. A light lager also works well. For a non-alcoholic pairing, serve chilled lime water or unsweetened iced tea.";
"recipe.fj_fish_suruwa.drink.summary" = "White wine (Riesling)";
"recipe.fj_fish_suruwa.info" = "Fish suruwa is a traditional Fijian fish curry with strong Indo-Fijian roots. Firm white fish is simmered in a tomato, spice, and coconut gravy, then served hot with plain steamed rice as a staple family meal.";
"recipe.fj_fish_suruwa.info.summary" = "Fijian fish curry";
"recipe.fj_fish_suruwa.name" = "Fish suruwa";
"recipe.fj_fish_suruwa.step1.body" = "Cut the %i1 into large pieces. Dice the %i3 and %i10, mince the %i4 and %i6, grate the %i5, chop the %i14, and juice the %i11.";
"recipe.fj_fish_suruwa.step1.title" = "Prepare the ingredients";
"recipe.fj_fish_suruwa.step10.body" = "Fluff the rice and spoon it into bowls or plates. Ladle the fish suruwa over or alongside the rice and finish with the remaining coriander.";
"recipe.fj_fish_suruwa.step10.title" = "Serve";
"recipe.fj_fish_suruwa.step2.body" = "Rinse the %i15 until the water runs mostly clear so it cooks into separate grains.";
"recipe.fj_fish_suruwa.step2.title" = "Rinse the rice";
"recipe.fj_fish_suruwa.step3.body" = "Put the rice in a saucepan with %i16 and %i17. Bring to a boil, cover, reduce the heat, and cook until the grains are tender and the water is absorbed.";
"recipe.fj_fish_suruwa.step3.title" = "Cook the rice";
"recipe.fj_fish_suruwa.step4.body" = "Heat %i2 in a deep pan and cook the onion until softened. Add the garlic, ginger, and chili, then stir until fragrant.";
"recipe.fj_fish_suruwa.step4.title" = "Start the curry base";
"recipe.fj_fish_suruwa.step5.body" = "Add %i7, %i8, and %i9 and stir briefly so the spices release their aroma without burning.";
"recipe.fj_fish_suruwa.step5.title" = "Bloom the spices";
"recipe.fj_fish_suruwa.step6.body" = "Add the tomatoes and cook, stirring regularly, until they break down into a thick sauce.";
"recipe.fj_fish_suruwa.step6.title" = "Cook the tomatoes";
"recipe.fj_fish_suruwa.step7.body" = "Nestle the fish into the sauce and pour in the lemon juice. Turn the pieces gently so they are coated.";
"recipe.fj_fish_suruwa.step7.title" = "Add fish and lemon";
"recipe.fj_fish_suruwa.step8.body" = "Pour in %i12, add %i13, and simmer gently until the fish is cooked through and the gravy is rich and smooth.";
"recipe.fj_fish_suruwa.step8.title" = "Finish with coconut milk";
"recipe.fj_fish_suruwa.step9.body" = "Stir in most of the coriander at the end, keeping a little back for serving.";
"recipe.fj_fish_suruwa.step9.title" = "Add fresh coriander";
"recipe.fj_fish_suruwa.tool.t1" = "Chef knife";
"recipe.fj_fish_suruwa.tool.t2" = "Cutting board";
