"recipe.hk_char_siu.step11.title" = "Rest the meat";
"recipe.hk_char_siu.step12.body" = "Slice the char siu across the grain and serve hot with rice or noodles.";
"recipe.hk_char_siu.step12.title" = "Slice and serve";
