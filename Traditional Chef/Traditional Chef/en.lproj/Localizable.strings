"recipe.ge_pkhali.drink.body" = "A dry Georgian amber wine such as Rkatsiteli pairs well with the walnut, garlic, and herb flavors. A light lager also works. For a non-alcoholic option, serve sparkling mineral water or chilled unsweetened black tea with lemon.";
"recipe.ge_pkhali.drink.summary" = "Amber wine (Rkatsiteli)";
"recipe.ge_pkhali.info" = "Pkhali is a traditional Georgian starter made by combining cooked greens with a walnut, garlic, herb, and spice mixture into a thick pâté-like salad, then shaping and garnishing it. This spinach version is commonly served at supras as part of a spread of cold appetizers, often with bread or mchadi.";
"recipe.ge_pkhali.info.summary" = "Spinach walnut pâté";
"recipe.ge_pkhali.name" = "Pkhali";
"recipe.ge_pkhali.step1.body" = "Bring %i2 to a boil in a large pot, add the %i1 and %i3, and cook briefly until wilted and tender.";
"recipe.ge_pkhali.step1.title" = "Blanch the spinach";
"recipe.ge_pkhali.step2.body" = "Drain the spinach in a colander, rinse with cold water, and squeeze very well to remove excess moisture.";
"recipe.ge_pkhali.step2.title" = "Drain and cool spinach";
"recipe.ge_pkhali.step3.body" = "Grind the %i4 with %i5, %i6, and %i7 until finely textured, then transfer to a bowl.";
"recipe.ge_pkhali.step3.title" = "Prepare the walnut mixture";
"recipe.ge_pkhali.step4.body" = "Add %i8, %i9, %i10, %i11, %i12, and %i13, and mix into a thick walnut paste.";
"recipe.ge_pkhali.step4.title" = "Season the mixture";
"recipe.ge_pkhali.step5.body" = "Finely chop the squeezed spinach and mix it thoroughly into the walnut paste until the mixture is uniform.";
"recipe.ge_pkhali.step5.title" = "Combine with spinach";
"recipe.ge_pkhali.step6.body" = "Shape the mixture into small mounds or balls on a serving platter and make a slight indentation on top of each.";
"recipe.ge_pkhali.step6.title" = "Shape the pkhali";
"recipe.ge_pkhali.step7.body" = "Chill the pkhali so it firms slightly and the flavors meld.";
"recipe.ge_pkhali.step7.title" = "Chill briefly";
"recipe.ge_pkhali.step8.body" = "Top with %i14 and serve cool with %i15.";
"recipe.ge_pkhali.step8.title" = "Garnish and serve";
