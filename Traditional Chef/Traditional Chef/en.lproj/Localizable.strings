"recipe.il_malabi.drink.body" = "Pair with a lightly sweet, aromatic dessert wine such as Muscat that echoes the floral rose notes without overpowering the pudding. For a non-alcoholic option, serve mint tea or chilled rose lemonade.";
"recipe.il_malabi.drink.summary" = "Sweet wine (Muscat)";
"recipe.il_malabi.info" = "Malabi is a beloved Israeli dessert of silky milk pudding thickened with starch, chilled until set, and topped with fragrant rose syrup and crunchy nuts. Commonly served in small cups at street stalls and at home, it is eaten cold and finished with pistachios and coconut for contrast to the creamy pudding.";
"recipe.il_malabi.info.summary" = "Rose milk pudding";
"recipe.il_malabi.name" = "Malabi";
"recipe.il_malabi.step1.body" = "Combine %i5 and %i6 in a saucepan and bring to a boil, stirring until dissolved. Simmer until slightly thickened, then remove from heat and stir in %i7 and %i8.";
"recipe.il_malabi.step1.title" = "Make the rose syrup";
"recipe.il_malabi.step2.body" = "Let the syrup cool to room temperature so it becomes pourable and fragrant.";
"recipe.il_malabi.step2.title" = "Cool the syrup";
"recipe.il_malabi.step3.body" = "In a bowl, whisk %i2 with a portion of the %i1 until completely smooth with no lumps.";
"recipe.il_malabi.step3.title" = "Mix the starch slurry";
"recipe.il_malabi.step4.body" = "Warm the remaining milk in a saucepan and stir in %i3 until dissolved, keeping the heat moderate so the milk does not scorch.";
"recipe.il_malabi.step4.title" = "Heat the milk and sugar";
"recipe.il_malabi.step5.body" = "Whisk in the cornstarch slurry and cook, whisking constantly, until the mixture thickens to a glossy pudding consistency and bubbles gently.";
"recipe.il_malabi.step5.title" = "Thicken the pudding";
"recipe.il_malabi.step6.body" = "Remove from heat and stir in %i4, mixing thoroughly for an even floral aroma.";
"recipe.il_malabi.step6.title" = "Finish with rose water";
"recipe.il_malabi.step7.body" = "Pour the hot pudding through a fine mesh strainer into serving cups to ensure a silky texture, then level the tops.";
"recipe.il_malabi.step7.title" = "Strain and portion";
"recipe.il_malabi.step8.body" = "Refrigerate the cups until fully chilled and set.";
"recipe.il_malabi.step8.title" = "Chill until set";
"recipe.il_malabi.step9.body" = "Spoon rose syrup over each cup and finish with %i9 and %i10 before serving cold.";
"recipe.il_malabi.step9.title" = "Top and serve";
