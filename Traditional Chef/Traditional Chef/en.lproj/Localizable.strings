"recipe.ps_sumagiyya.drink.body" = "A light to medium-bodied red wine such as Cinsault or Pinot Noir suits the tart sumac, sesame richness, and savory meat. For a non-alcoholic pairing, serve hot mint tea or plain cold yogurt drink.";
"recipe.ps_sumagiyya.drink.summary" = "Red wine (Cinsault)";
"recipe.ps_sumagiyya.info" = "Sumagiyya is a traditional Palestinian stew from Gaza made with meat, chickpeas, chard, tahini, and a deeply tart sumac sauce thickened with flour and perfumed with dill seeds, garlic, and chili. It is a festive communal dish, often prepared for Eid and special family gatherings, and is traditionally served at room temperature with flatbread for scooping.";
"recipe.ps_sumagiyya.info.summary" = "Tangy sumac stew";
"recipe.ps_sumagiyya.name" = "Sumagiyya";
"recipe.ps_sumagiyya.step1.body" = "Cut %i1 into medium cubes. Cook it in the large pot with %i2, %i3, %i4, %i5, and %i6, bringing it up slowly so the broth develops good flavor.";
"recipe.ps_sumagiyya.step1.title" = "Start the meat base";
"recipe.ps_sumagiyya.step10.body" = "Pour the hot garlic oil over the stew and stir it in so the flavor spreads through the whole pot.";
"recipe.ps_sumagiyya.step10.title" = "Finish the sumagiyya";
"recipe.ps_sumagiyya.step11.body" = "Let the sumagiyya cool until warm or room temperature, which is the traditional way to serve it.";
"recipe.ps_sumagiyya.step11.title" = "Cool before serving";
"recipe.ps_sumagiyya.step12.body" = "Ladle the sumagiyya into a serving dish and serve it with %i16 for scooping.";
"recipe.ps_sumagiyya.step12.title" = "Serve with bread";
"recipe.ps_sumagiyya.step2.body" = "Skim the surface, lower the heat, and simmer until the beef is tender and the broth is rich.";
"recipe.ps_sumagiyya.step2.title" = "Simmer the meat";
"recipe.ps_sumagiyya.step3.body" = "Put %i7 in a bowl with water and leave it to steep so the liquid becomes deeply tart and colored.";
"recipe.ps_sumagiyya.step3.title" = "Soak the sumac";
"recipe.ps_sumagiyya.step4.body" = "Wash and chop %i11 finely. Strain the soaked sumac liquid into a bowl, then whisk in %i8 and %i9 until smooth.";
"recipe.ps_sumagiyya.step4.title" = "Prepare the greens and sauce base";
"recipe.ps_sumagiyya.step5.body" = "Add %i10 and Swiss chard to the meat pot and cook until the chard softens and the broth takes on the flavor of the greens.";
"recipe.ps_sumagiyya.step5.title" = "Add the chickpeas and chard";
"recipe.ps_sumagiyya.step6.body" = "Stir %i12, %i13, and the rest of the salt into the pot so the stew becomes fragrant and balanced.";
"recipe.ps_sumagiyya.step6.title" = "Season the stew";
"recipe.ps_sumagiyya.step7.body" = "Pour the sumac, tahini, and flour mixture into the pot in a steady stream, stirring constantly so the stew thickens smoothly and turns silky.";
"recipe.ps_sumagiyya.step7.title" = "Thicken with the sumac mixture";
"recipe.ps_sumagiyya.step8.body" = "Simmer gently until the stew is thick, glossy, and fully integrated, stirring from time to time so it does not catch on the bottom.";
"recipe.ps_sumagiyya.step8.title" = "Cook until glossy";
"recipe.ps_sumagiyya.step9.body" = "Crush %i14 and fry it in %i15 until fragrant and just lightly colored.";
"recipe.ps_sumagiyya.step9.title" = "Make the garlic oil";
