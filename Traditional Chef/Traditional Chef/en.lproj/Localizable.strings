"recipe.rs_reform_torta.drink.body" = "A lightly sweet dessert wine pairs well with the deep chocolate and walnut richness without making the cake feel heavy. A dry sparkling wine also works well. For a non-alcoholic option, serve strong coffee or black tea.";
"recipe.rs_reform_torta.drink.summary" = "Dessert wine";
"recipe.rs_reform_torta.info" = "Reform Torta is a traditional Serbian layered cake made from thin walnut sponge layers and a rich chocolate buttercream based on egg yolks and butter. It is served chilled in neat slices for celebrations, holiday tables, and formal family gatherings.";
"recipe.rs_reform_torta.info.summary" = "Walnut chocolate cake";
"recipe.rs_reform_torta.name" = "Reform torte";
"recipe.rs_reform_torta.step1.body" = "Line the baking base with parchment, separate the eggs, grind %i3 finely, and keep %i8 at room temperature so the filling will become smooth later.";
"recipe.rs_reform_torta.step1.title" = "Prepare the pans and ingredients";
"recipe.rs_reform_torta.step2.body" = "Whip %i1 until foamy, add %i2 gradually, and beat until glossy and firm. Fold in the ground walnuts and %i4 gently so the mixture stays airy.";
"recipe.rs_reform_torta.step2.title" = "Make the sponge batter";
"recipe.rs_reform_torta.step3.body" = "Divide the batter evenly into thin layers and bake them one after another until lightly golden and dry to the touch. Cool the layers completely on a rack.";
"recipe.rs_reform_torta.step3.title" = "Bake the thin layers";
"recipe.rs_reform_torta.step4.body" = "Whisk %i5 with %i6 over a double boiler until thick and pale, then add %i7 and stir until fully melted and smooth.";
"recipe.rs_reform_torta.step4.title" = "Cook the yolk cream";
"recipe.rs_reform_torta.step5.body" = "Set the cooked chocolate yolk mixture aside until it is fully cool so it can be combined properly with the butter.";
"recipe.rs_reform_torta.step5.title" = "Cool the chocolate base";
"recipe.rs_reform_torta.step6.body" = "Beat the butter until light, then gradually add the cooled chocolate yolk mixture and beat until the filling is smooth, thick, and spreadable.";
"recipe.rs_reform_torta.step6.title" = "Finish the buttercream";
"recipe.rs_reform_torta.step7.body" = "Place one walnut layer on the serving base, spread part of the chocolate buttercream over it, and continue layering until all layers are stacked. Cover the top and sides with the remaining buttercream.";
"recipe.rs_reform_torta.step7.title" = "Assemble the cake";
"recipe.rs_reform_torta.step8.body" = "Refrigerate the assembled cake until the layers settle and the buttercream becomes firm enough for clean slicing.";
"recipe.rs_reform_torta.step8.title" = "Chill the torta";
"recipe.rs_reform_torta.step9.body" = "Decorate the top with %i9 and serve the Reform Torta chilled in neat slices.";
"recipe.rs_reform_torta.step9.title" = "Finish and serve";
