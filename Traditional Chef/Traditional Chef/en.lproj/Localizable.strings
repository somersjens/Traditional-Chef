"recipe.uz_shashlik.tool.t4" = "Knife";
"recipe.uz_shashlik.tool.t5" = "Cutting board";
"recipe.uz_shashlik.tool.t6" = "Tongs";
"recipe.uz_shashlik.tool.t7" = "Serving platter";
"recipe.uz_shurpa.drink.body" = "A light to medium red such as Pinot Noir or young Grenache pairs well with the lamb and sweet vegetables without overpowering the broth. A pale lager also works. Non-alcoholic pairing: hot black tea is the traditional and best match.";
"recipe.uz_shurpa.drink.summary" = "Red wine (Pinot Noir)";
"recipe.uz_shurpa.info" = "Uzbek Shurpa is a traditional lamb and vegetable soup with a rich clear broth, large-cut vegetables, and gentle spices, cooked slowly so the meat becomes tender and the broth fragrant. It is a classic home and festive dish served hot in bowls with fresh herbs, bread, and tea.";
"recipe.uz_shurpa.info.summary" = "Hearty lamb soup";
"recipe.uz_shurpa.name" = "Shurpa";
"recipe.uz_shurpa.step1.body" = "Rinse the %i9 and soak them in %i2 until fully hydrated for cooking.";
"recipe.uz_shurpa.step1.title" = "Soak chickpeas";
"recipe.uz_shurpa.step10.body" = "Ladle the broth, lamb, chickpeas, and vegetables into bowls. Finish with cilantro and dill, and serve hot with torn non bread.";
"recipe.uz_shurpa.step10.title" = "Serve shurpa";
"recipe.uz_shurpa.step2.body" = "Cut the %i1 into large pieces if needed. Peel and cut the %i3, %i4, and %i5 into large chunks. Cut the %i6 and %i7 into large pieces. Peel the %i8 and chop the %i14 and %i15.";
"recipe.uz_shurpa.step2.title" = "Prepare ingredients";
"recipe.uz_shurpa.step3.body" = "Place the lamb in the large pot with water and bring slowly to a boil. Skim the surface well to keep the broth clear.";
"recipe.uz_shurpa.step3.title" = "Start the broth";
"recipe.uz_shurpa.step4.body" = "Add the soaked chickpeas, half of the onion, %i13, and part of the %i10. Cover loosely and simmer gently until the lamb begins to soften and the chickpeas are nearly tender.";
"recipe.uz_shurpa.step4.title" = "Simmer lamb and chickpeas";
"recipe.uz_shurpa.step5.body" = "Add the carrots and potatoes to the broth and continue cooking at a gentle simmer.";
"recipe.uz_shurpa.step5.title" = "Add root vegetables";
"recipe.uz_shurpa.step6.body" = "Add the remaining onion, tomatoes, bell pepper, and garlic. Add the %i11, %i12, and the rest of the salt, then simmer without vigorous boiling.";
"recipe.uz_shurpa.step6.title" = "Add remaining vegetables and spices";
"recipe.uz_shurpa.step7.body" = "Cook until the lamb is fully tender, the chickpeas are soft, and the vegetables are cooked through while still holding their shape.";
"recipe.uz_shurpa.step7.title" = "Finish simmering";
"recipe.uz_shurpa.step8.body" = "Turn off the heat and let the shurpa rest briefly so the broth clears and the flavors settle.";
"recipe.uz_shurpa.step8.title" = "Rest the soup";
"recipe.uz_shurpa.step9.body" = "Warm the %i16 briefly until soft and fragrant for serving.";
"recipe.uz_shurpa.step9.title" = "Warm bread";
"recipe.uz_shurpa.tool.t1" = "Large pot";
"recipe.uz_shurpa.tool.t2" = "Lid";
"recipe.uz_shurpa.tool.t3" = "Knife";
"recipe.uz_shurpa.tool.t4" = "Cutting board";
"recipe.uz_shurpa.tool.t5" = "Ladle";
"recipe.uz_shurpa.tool.t6" = "Skimmer";
"recipe.uz_shurpa.tool.t7" = "Serving bowls";
"recipe.ve_asado_negro.drink.body" = "Serve with a medium-bodied red wine that can handle the sweet-savory sauce without overwhelming the beef. A dark lager also works well. For a non-alcoholic option, serve papelón con limón or chilled black tea.";
"recipe.ve_asado_negro.drink.summary" = "Red wine";
"recipe.ve_asado_negro.info" = "Asado negro is a traditional Venezuelan beef dish made from a whole cut of beef slowly braised in a dark sauce built from caramelized papelón, aromatics, red wine, and stock until the meat is tender and richly glazed. It is classically served in slices with white rice and fried ripe plantains as a festive Sunday or celebratory meal.";
"recipe.ve_asado_negro.info.summary" = "Dark glazed beef roast";
"recipe.ve_asado_negro.name" = "Asado negro";
"recipe.ve_asado_negro.step1.body" = "Season %i1 with %i10 and %i11. Slice %i2, %i3, %i4, and %i5.";
"recipe.ve_asado_negro.step1.title" = "Prepare the beef and vegetables";
"recipe.ve_asado_negro.step10.body" = "Arrange the sliced asado negro with its sauce, white rice, and fried ripe plantains on each plate and serve hot.";
"recipe.ve_asado_negro.step10.title" = "Serve";
"recipe.ve_asado_negro.step2.body" = "Heat some of %i9 in a heavy pot and brown the beef well on all sides until deeply colored, then remove it from the pot.";
"recipe.ve_asado_negro.step2.title" = "Brown the beef";
"recipe.ve_asado_negro.step3.body" = "Add %i6 to the pot and cook it carefully until it melts into a very dark caramel without burning.";
"recipe.ve_asado_negro.step3.title" = "Caramelize the papelon";
"recipe.ve_asado_negro.step4.body" = "Return the beef to the pot and add the onion, garlic, green bell pepper, celery, %i7, and %i8.";
"recipe.ve_asado_negro.step4.title" = "Build the braising base";
"recipe.ve_asado_negro.step5.body" = "Cover the pot and cook gently until the beef becomes very tender and the sauce turns dark, glossy, and concentrated.";
"recipe.ve_asado_negro.step5.title" = "Braise the beef";
"recipe.ve_asado_negro.step6.body" = "Remove the beef from the sauce, let it rest briefly, then slice it evenly.";
"recipe.ve_asado_negro.step6.title" = "Rest and slice the beef";
"recipe.ve_asado_negro.step7.body" = "Return the sliced beef to the pot and spoon the sauce over it so the slices absorb the dark braising liquid.";
"recipe.ve_asado_negro.step7.title" = "Finish the sauce";
"recipe.ve_asado_negro.step8.body" = "Place %i12 in a saucepan with %i13 and the remaining %i14, bring it to a boil, then cover and cook gently until tender.";
"recipe.ve_asado_negro.step8.title" = "Cook the rice";
"recipe.ve_asado_negro.step9.body" = "Slice %i15 lengthwise and fry them in the remaining %i16 until deep golden and soft inside.";
"recipe.ve_asado_negro.step9.title" = "Fry the plantains";
