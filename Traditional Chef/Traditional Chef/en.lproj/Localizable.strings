"recipe.it_crostata_di_marmellata.step1.title" = "Make the dough";
"recipe.it_crostata_di_marmellata.step2.body" = "Wrap the dough and refrigerate until firm so it rolls cleanly.";
"recipe.it_crostata_di_marmellata.step2.title" = "Chill the dough";
"recipe.it_crostata_di_marmellata.step3.body" = "Preheat the oven so it is fully hot before baking.";
