"recipe.bg_tikvenik.drink.body" = "A lightly sweet dessert wine such as Muscat pairs well with the spiced pumpkin and crisp pastry. For a non-alcoholic pairing, serve boza or hot black tea.";
"recipe.bg_tikvenik.drink.summary" = "Dessert wine (Muscat)";
"recipe.bg_tikvenik.info" = "Tikvenik is a traditional Bulgarian sweet pastry made by rolling thin filo sheets around a filling of grated pumpkin, sugar, walnuts, and cinnamon, then baking until crisp and golden. It is especially associated with autumn and winter and is commonly served for family gatherings, holidays, and festive meals, usually dusted with sugar and eaten warm or at room temperature.";
"recipe.bg_tikvenik.info.summary" = "Pumpkin filo pastry";
"recipe.bg_tikvenik.name" = "Tikvenik";
