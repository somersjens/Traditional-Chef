"recipe.jp_sashimi_moriawase.step5.title" = "Slice the sashimi";
"recipe.jp_sashimi_moriawase.step6.body" = "Spread daikon tsuma on the chilled platter, then arrange the assorted sashimi in balanced groups with shiso, cucumber, and wakame for color and separation.";
"recipe.jp_sashimi_moriawase.step6.title" = "Arrange the moriawase platter";
"recipe.jp_sashimi_moriawase.step7.body" = "Place %i11 and %i12 on the platter or alongside, pour %i10 into dipping bowls, and serve immediately while the sashimi is well chilled.";
"recipe.jp_sashimi_moriawase.step7.title" = "Add condiments and serve";
