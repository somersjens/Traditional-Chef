"recipe.lb_shish_tawook.step1.title" = "Prepare the chicken";
"recipe.lb_shish_tawook.step2.body" = "In a bowl, combine %i2, %i3, %i4, crushed %i5, %i6, %i7, %i8, and %i9 until smooth.";
"recipe.lb_shish_tawook.step2.title" = "Mix the marinade";
"recipe.lb_shish_tawook.step3.body" = "Coat the chicken thoroughly in the marinade, cover, and refrigerate to let the flavor penetrate.";
"recipe.lb_shish_tawook.step3.title" = "Marinate";
"recipe.lb_shish_tawook.step4.body" = "In a food processor, blend %i10 with %i13 until very fine, scraping down as needed.";
"recipe.lb_shish_tawook.step4.title" = "Make the toum base";
"recipe.lb_shish_tawook.step5.body" = "With the motor running, drizzle in %i11 very slowly to form a thick, pale emulsion, alternating with %i12 to keep it stable until a fluffy garlic sauce forms.";
"recipe.lb_shish_tawook.step5.title" = "Emulsify the toum";
"recipe.lb_shish_tawook.step6.body" = "Thread the marinated chicken pieces tightly onto skewers, leaving a little space at the ends for handling.";
"recipe.lb_shish_tawook.step6.title" = "Skewer the chicken";
"recipe.lb_shish_tawook.step7.body" = "Grill over medium-high heat, turning often, until lightly charred and cooked through.";
"recipe.lb_shish_tawook.step7.title" = "Grill";
"recipe.lb_shish_tawook.step8.body" = "Rest the skewers briefly, then serve hot with toum, warm %i14, and %i15.";
"recipe.lb_shish_tawook.step8.title" = "Serve";
