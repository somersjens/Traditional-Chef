"recipe.th_kanom_chan.drink.body" = "A light late-harvest white can match the coconut sweetness, but this dessert is most often paired with hot unsweetened jasmine tea. For a non-alcoholic option, serve warm jasmine tea or pandan tea.";
"recipe.th_kanom_chan.drink.summary" = "Tea";
"recipe.th_kanom_chan.info" = "Khanom Chan is a traditional Thai steamed layered dessert with a soft chewy texture made from starch flours, coconut milk, sugar, and pandan. It is commonly prepared in multiple layers, especially for auspicious occasions, and served in small bite-size pieces after cooling.";
"recipe.th_kanom_chan.info.summary" = "Layered pandan cake";
"recipe.th_kanom_chan.name" = "Khanom chan";
"recipe.th_kanom_chan.step1.body" = "Fill the steamer with %i10 and bring it to a steady boil. Place the empty heatproof tray inside to preheat.";
"recipe.th_kanom_chan.step1.title" = "Prepare the steamer";
"recipe.th_kanom_chan.step10.body" = "Steam the completed layered dessert a little longer so the center is fully cooked and the top is firm.";
"recipe.th_kanom_chan.step10.title" = "Steam to finish";
"recipe.th_kanom_chan.step11.body" = "Remove the tray from the steamer and let the dessert cool completely until firm enough to cut cleanly.";
"recipe.th_kanom_chan.step11.title" = "Cool completely";
"recipe.th_kanom_chan.step12.body" = "Lightly oil the knife, cut the khanom chan into bite-size pieces, and serve at room temperature.";
"recipe.th_kanom_chan.step12.title" = "Cut and serve";
"recipe.th_kanom_chan.step2.body" = "Blend the %i8 with %i9, then strain to obtain a smooth green pandan juice.";
"recipe.th_kanom_chan.step2.title" = "Make pandan juice";
"recipe.th_kanom_chan.step3.body" = "Combine the %i1, %i2, %i3, and %i4 in a mixing bowl and whisk until evenly blended.";
"recipe.th_kanom_chan.step3.title" = "Mix the dry ingredients";
"recipe.th_kanom_chan.step4.body" = "Add %i5, %i6, and %i7 to the flour mixture and whisk until smooth. Strain the batter to remove any lumps.";
"recipe.th_kanom_chan.step4.title" = "Make the batter base";
"recipe.th_kanom_chan.step5.body" = "Divide the batter into two equal portions. Mix the pandan juice into one portion and keep the other portion plain.";
"recipe.th_kanom_chan.step5.title" = "Divide and color the batter";
"recipe.th_kanom_chan.step6.body" = "Carefully remove the hot tray and lightly coat it with %i11, then return it to the steamer.";
"recipe.th_kanom_chan.step6.title" = "Grease the tray";
"recipe.th_kanom_chan.step7.body" = "Pour a thin layer of pandan batter into the hot tray and steam until the surface is set.";
"recipe.th_kanom_chan.step7.title" = "Steam the first layer";
"recipe.th_kanom_chan.step8.body" = "Pour a thin layer of plain batter over the set layer and steam until set again.";
"recipe.th_kanom_chan.step8.title" = "Steam the second layer";
"recipe.th_kanom_chan.step9.body" = "Continue alternating pandan and plain batter, steaming each layer until set before adding the next, until all layers are used.";
"recipe.th_kanom_chan.step9.title" = "Build the remaining layers";
