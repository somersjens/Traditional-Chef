"recipe.kr_bulgogi.step6.title" = "Prepare the bulgogi vegetables";
"recipe.kr_bulgogi.step7.body" = "Heat a large skillet with a little %i21 over high heat and cook half of the marinated beef with some of the sliced onion and mushrooms until browned and glossy.";
"recipe.kr_bulgogi.step7.title" = "Start cooking the bulgogi";
"recipe.kr_bulgogi.step8.body" = "Cook the remaining beef with the rest of the onion and mushrooms, then add the bulgogi scallion near the end so it stays fresh and aromatic.";
"recipe.kr_bulgogi.step8.title" = "Cook the remaining bulgogi";
"recipe.kr_bulgogi.step9.body" = "Return all cooked beef to the pan briefly to heat through evenly, then sprinkle with the finishing %i22.";
