"recipe.ng_jollof_rice.drink.body" = "A fruity, low-tannin red like Grenache works with the tomato stew, gentle smokiness, and spice without tasting harsh. If you prefer white, a dry Riesling can balance the heat and sweetness from ripe peppers and plantain. Non-alcoholic pairing: chilled zobo (hibiscus) or sparkling water with lime.";
"recipe.ng_jollof_rice.drink.summary" = "Red wine (Grenache)";
"recipe.ng_jollof_rice.info" = "Nigerian jollof rice is a smoky, tomato-pepper rice cooked in a rich stew base with warm spices, then steamed until each grain is deeply seasoned and slightly toasted at the bottom. It is a centerpiece dish for celebrations and family gatherings, commonly served with grilled chicken and fried ripe plantain for a full, satisfying plate.";
"recipe.ng_jollof_rice.info.summary" = "Party jollof rice";
"recipe.ng_jollof_rice.name" = "Jollof rice";
"recipe.ng_jollof_rice.step1.body" = "Rinse the %i1 and drain. Roughly chop the %i2, %i3, and %i4. Peel the %i16 and %i17. Prepare the %i14 and peel the %i23.";
"recipe.ng_jollof_rice.step1.title" = "Prep ingredients";
"recipe.ng_jollof_rice.step10.body" = "Add %i13, bring to a simmer, cover tightly, and cook on low heat until the rice is tender and the liquid is absorbed.";
"recipe.ng_jollof_rice.step10.title" = "Cook the jollof rice";
"recipe.ng_jollof_rice.step11.body" = "Keep covered and steam gently until the rice finishes evenly and the base develops a light smoky toast.";
"recipe.ng_jollof_rice.step11.title" = "Steam to finish";
"recipe.ng_jollof_rice.step12.body" = "Slice the ripe plantains and fry in hot %i24 until golden on both sides, then drain and season with %i25.";
"recipe.ng_jollof_rice.step12.title" = "Fry the plantain";
"recipe.ng_jollof_rice.step13.body" = "Fluff the jollof rice, then serve with grilled chicken and fried plantain.";
"recipe.ng_jollof_rice.step13.title" = "Serve";
"recipe.ng_jollof_rice.step2.body" = "Blend the tomatoes, bell pepper, most of the onion, and the %i5 to a smooth mixture and set aside.";
"recipe.ng_jollof_rice.step2.title" = "Blend pepper base";
"recipe.ng_jollof_rice.step3.body" = "Blend the %i15, garlic, and ginger to a paste, then rub onto the chicken with %i18, %i19, %i20, %i22, and %i21 until well coated.";
"recipe.ng_jollof_rice.step3.title" = "Season the chicken";
"recipe.ng_jollof_rice.step4.body" = "Let the seasoned chicken rest so the flavors penetrate while you start the rice.";
"recipe.ng_jollof_rice.step4.title" = "Rest the chicken";
"recipe.ng_jollof_rice.step5.body" = "Arrange the chicken on a tray and bake until cooked through and browned, turning once so it colors evenly.";
"recipe.ng_jollof_rice.step5.title" = "Grill the chicken";
"recipe.ng_jollof_rice.step6.body" = "Heat %i7 in the heavy pot, add %i6, and fry until it darkens slightly and smells sweet rather than raw.";
"recipe.ng_jollof_rice.step6.title" = "Fry tomato paste";
"recipe.ng_jollof_rice.step7.body" = "Add the blended pepper base and cook, stirring often, until it reduces to a thick stew and the oil begins to separate.";
"recipe.ng_jollof_rice.step7.title" = "Cook down the pepper base";
"recipe.ng_jollof_rice.step8.body" = "Stir in %i11, %i9, %i8, %i10, and %i12, then cook briefly so the spices bloom.";
"recipe.ng_jollof_rice.step8.title" = "Season the stew";
"recipe.ng_jollof_rice.step9.body" = "Stir the drained rice into the stew until every grain is well coated.";
"recipe.ng_jollof_rice.step9.title" = "Add rice to the stew";
