"recipe.tn_assida.drink.body" = "A lightly chilled Muscat pairs with the nutty sweetness and floral notes, while a non-alcoholic pairing is hot Tunisian mint tea or chilled rosewater lemonade.";
"recipe.tn_assida.drink.summary" = "Sweet wine (Muscat)";
"recipe.tn_assida.info" = "Assidat Zgougou is a traditional Tunisian dessert made for Mawlid celebrations, prepared by extracting the flavor of Aleppo pine seeds into a dark, silky cream thickened on the stove, then topped with a smooth white milk custard and decorated with nuts before chilling and serving in bowls.";
"recipe.tn_assida.info.summary" = "Pine cream dessert";
"recipe.tn_assida.name" = "Assidat zgougou";
"recipe.tn_assida.step1.body" = "Rinse the %i1, then grind them finely and mix with %i2 to form a dark slurry.";
"recipe.tn_assida.step1.title" = "Grind and mix seeds";
"recipe.tn_assida.step2.body" = "Cover the slurry and let it rest so the flavor infuses into the liquid.";
"recipe.tn_assida.step2.title" = "Rest for extraction";
"recipe.tn_assida.step3.body" = "Strain the mixture through a fine sieve lined with cheesecloth, pressing well, and repeat until the liquid is smooth and free of grit.";
"recipe.tn_assida.step3.title" = "Strain the extract";
"recipe.tn_assida.step4.body" = "Whisk %i3 and %i4 into the strained liquid until fully dissolved and smooth, then stir in %i5 and %i6.";
"recipe.tn_assida.step4.title" = "Blend in thickeners";
"recipe.tn_assida.step5.body" = "Cook over medium heat, stirring constantly, until thick, glossy, and pudding-like, then portion into serving bowls.";
"recipe.tn_assida.step5.title" = "Cook the zgougou cream";
"recipe.tn_assida.step6.body" = "Whisk %i8 and %i9 with %i7 until smooth, then whisk in the %i10 until uniform.";
"recipe.tn_assida.step6.title" = "Prepare custard base";
"recipe.tn_assida.step7.body" = "Cook over medium heat, whisking continuously, until thick and smooth, then whisk in %i11.";
"recipe.tn_assida.step7.title" = "Cook the custard";
"recipe.tn_assida.step8.body" = "Spread the hot custard over the zgougou layer, then decorate with chopped %i12 and %i13.";
"recipe.tn_assida.step8.title" = "Top and decorate";
"recipe.tn_assida.step9.body" = "Chill until fully cold and set, then serve straight from the bowls.";
"recipe.tn_assida.step9.title" = "Chill to set";
"recipe.tn_assida.tool.t1" = "Blender or food processor";
"recipe.tn_assida.tool.t10" = "Serving bowls";
"recipe.tn_assida.tool.t2" = "Large mixing bowl";
"recipe.tn_assida.tool.t3" = "Fine sieve";
"recipe.tn_assida.tool.t4" = "Cheesecloth";
"recipe.tn_assida.tool.t5" = "Large saucepan";
"recipe.tn_assida.tool.t6" = "Medium saucepan";
"recipe.tn_assida.tool.t7" = "Whisk";
"recipe.tn_assida.tool.t8" = "Wooden spoon";
"recipe.tn_assida.tool.t9" = "Ladle";
"recipe.tn_brik.drink.body" = "A crisp white wine such as Vermentino or Sauvignon Blanc cuts through the fried pastry and complements the tuna and capers. For a non-alcoholic option, serve hot Tunisian mint tea or fresh lemonade.";
"recipe.tn_brik.drink.summary" = "White wine (Vermentino)";
"recipe.tn_brik.info" = "Tunisian Brik à l’Oeuf is a classic street-food and home starter made by filling thin malsouka pastry with a savory tuna mixture, cracking an egg inside, then folding and deep-frying until the shell is crisp and the yolk stays soft, served immediately with lemon and harissa.";
"recipe.tn_brik.info.summary" = "Tuna egg pastry";
"recipe.tn_brik.name" = "Egg brik";
"recipe.tn_brik.step1.body" = "Finely chop the %i3 and %i4. In a bowl, mash the %i2 and mix with onion, parsley, %i5, %i10, and %i11 until evenly combined.";
"recipe.tn_brik.step1.title" = "Make the tuna mixture";
"recipe.tn_brik.step2.body" = "Pour %i7 into a deep skillet and heat until hot enough to fry so the pastry crisps quickly.";
"recipe.tn_brik.step2.title" = "Heat the frying oil";
"recipe.tn_brik.step3.body" = "Lay a %i1 flat, place some tuna mixture near the center, make a small well, crack in an %i6, then fold into a triangle and seal by pressing the pastry layers together.";
"recipe.tn_brik.step3.title" = "Assemble the first brik";
"recipe.tn_brik.step4.body" = "Slide the brik into the hot oil and fry, turning carefully once, until crisp and golden while keeping the yolk soft.";
"recipe.tn_brik.step4.title" = "Fry the brik";
"recipe.tn_brik.step5.body" = "Lift to paper towels to drain, then assemble and fry the remaining brik the same way, keeping finished ones warm and crisp.";
"recipe.tn_brik.step5.title" = "Drain and repeat";
"recipe.tn_brik.step6.body" = "Serve immediately with %i8 to squeeze over and %i9 on the side for dipping.";
"recipe.tn_brik.step6.title" = "Serve";
"recipe.tn_brik.tool.t1" = "Large deep skillet";
"recipe.tn_brik.tool.t2" = "Slotted spoon";
