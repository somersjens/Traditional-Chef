"recipe.eg_koshari.step6.title" = "Make the daqqa";
"recipe.eg_koshari.step7.body" = "Bring water to a boil, season with salt, and cook the %i9 until tender. Drain well.";
"recipe.eg_koshari.step7.title" = "Boil the pasta";
"recipe.eg_koshari.step8.body" = "Warm the %i12 in a little hot water just until heated through, then drain.";
"recipe.eg_koshari.step8.title" = "Warm chickpeas";
"recipe.eg_koshari.step9.body" = "Layer rice, lentils, pasta, and chickpeas in serving bowls. Spoon tomato sauce over the top, drizzle with daqqa, and finish with a generous handful of fried onions.";
"recipe.eg_koshari.step9.title" = "Assemble and serve";
