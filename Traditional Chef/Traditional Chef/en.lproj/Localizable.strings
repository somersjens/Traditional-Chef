"recipe.pt_polvo_a_lagareiro.drink.body" = "A crisp Portuguese white such as Alvarinho or Arinto stands up to the rich olive oil and garlic while keeping the seafood bright. If you prefer red, choose a very light Portuguese red served slightly cool. Non-alcoholic pairing: sparkling water with lemon or a chilled alcohol-free pilsner.";
"recipe.pt_polvo_a_lagareiro.drink.summary" = "White wine (Alvarinho)";
"recipe.pt_polvo_a_lagareiro.info" = "Polvo a Lagareiro is a traditional Portuguese dish where tender cooked octopus is roasted with plenty of olive oil and garlic, typically served with smashed roasted potatoes and finished with parsley. It is associated with olive-oil producing regions and is served hot, with the octopus lightly crisped at the edges and the potatoes soaked in garlicky olive oil.";
"recipe.pt_polvo_a_lagareiro.info.summary" = "Olive-oil roast octopus";
"recipe.pt_polvo_a_lagareiro.name" = "Octopus Lagareiro";
"recipe.pt_polvo_a_lagareiro.step1.body" = "Rinse the %i1 well and drain. Rinse the %i2 and set aside. Preheat the oven.";
"recipe.pt_polvo_a_lagareiro.step1.title" = "Prepare octopus and potatoes";
"recipe.pt_polvo_a_lagareiro.step2.body" = "Place the octopus in a pot with a small amount of %i8, cover, and cook gently until the octopus is tender. Remove and drain.";
"recipe.pt_polvo_a_lagareiro.step2.title" = "Cook the octopus";
"recipe.pt_polvo_a_lagareiro.step3.body" = "Boil the potatoes in salted water until tender. Drain and let them steam dry briefly.";
"recipe.pt_polvo_a_lagareiro.step3.title" = "Boil the potatoes";
"recipe.pt_polvo_a_lagareiro.step4.body" = "Place the cooked octopus on a roasting tray. Add the potatoes and lightly smash each one. Slice %i3 and scatter it over the octopus and potatoes.";
"recipe.pt_polvo_a_lagareiro.step4.title" = "Arrange for roasting";
"recipe.pt_polvo_a_lagareiro.step5.body" = "Season with %i6 and %i7 and drizzle generously with %i4 so everything is well coated.";
"recipe.pt_polvo_a_lagareiro.step5.title" = "Season and oil";
"recipe.pt_polvo_a_lagareiro.step6.body" = "Roast until the octopus edges lightly crisp and the potatoes take on golden spots, basting once with the pan oil.";
"recipe.pt_polvo_a_lagareiro.step6.title" = "Roast";
"recipe.pt_polvo_a_lagareiro.step7.body" = "Sprinkle with chopped %i5 and serve immediately, spooning the garlicky olive oil from the tray over the octopus and potatoes.";
"recipe.pt_polvo_a_lagareiro.step7.title" = "Finish and serve";
