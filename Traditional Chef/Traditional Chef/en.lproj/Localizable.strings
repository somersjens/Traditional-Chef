"recipe.jp_anmitsu.drink.body" = "Sencha or hojicha pairs well with the sweetness and varied textures. For a non-alcoholic pairing, serve cold barley tea or iced green tea.";
"recipe.jp_anmitsu.drink.summary" = "Green tea (Sencha)";
"recipe.jp_anmitsu.info" = "Anmitsu is a traditional Japanese dessert of kanten jelly cubes served with sweet red bean paste, fruit, and chewy mochi-like shiratama dumplings, finished with kuromitsu syrup. It is commonly enjoyed as a refreshing café dessert, especially in warm weather, and is served chilled in bowls.";
"recipe.jp_anmitsu.info.summary" = "Kanten fruit dessert";
"recipe.jp_anmitsu.name" = "Anmitsu";
"recipe.jp_anmitsu.step1.body" = "Combine %i1, %i2, and %i3 in a saucepan, whisk well, then bring to a boil and simmer until the agar is fully dissolved.";
"recipe.jp_anmitsu.step1.title" = "Make the kanten mixture";
"recipe.jp_anmitsu.step2.body" = "Pour the kanten mixture into a shallow tray and let it cool and set completely until firm.";
"recipe.jp_anmitsu.step2.title" = "Set the kanten jelly";
"recipe.jp_anmitsu.step3.body" = "Combine %i11, %i12, and %i13 in a saucepan and simmer until fully dissolved and slightly thickened, then cool.";
"recipe.jp_anmitsu.step3.title" = "Make the kuromitsu syrup";
"recipe.jp_anmitsu.step4.body" = "Drain the %i7, cut the %i8 and %i9 into bite-size pieces, and set the %i10 aside for assembly.";
"recipe.jp_anmitsu.step4.title" = "Prepare the fruit toppings";
"recipe.jp_anmitsu.step5.body" = "Mix the %i4 with %i5 gradually and knead until a smooth soft dough forms, then divide and shape into small round dumplings.";
"recipe.jp_anmitsu.step5.title" = "Make the shiratama dough";
"recipe.jp_anmitsu.step6.body" = "Boil the dumplings until they float, continue briefly until tender, then lift them out and cool them in cold water before draining.";
"recipe.jp_anmitsu.step6.title" = "Cook the shiratama";
"recipe.jp_anmitsu.step7.body" = "Turn out the set jelly if needed and cut it into small cubes for serving bowls.";
"recipe.jp_anmitsu.step7.title" = "Cut the kanten jelly";
"recipe.jp_anmitsu.step8.body" = "Divide kanten cubes into bowls, then add %i6, shiratama dumplings, fruit, and cherries in neat portions.";
"recipe.jp_anmitsu.step8.title" = "Assemble the anmitsu";
"recipe.jp_anmitsu.step9.body" = "Spoon kuromitsu syrup over each bowl just before serving and serve chilled.";
"recipe.jp_anmitsu.step9.title" = "Finish and serve";
