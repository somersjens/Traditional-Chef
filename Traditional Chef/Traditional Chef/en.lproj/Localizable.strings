"recipe.dk_risalamande.drink.body" = "A lightly sweet dessert wine or a glass of chilled sparkling wine pairs well with the creamy pudding and cherry sauce. For a non-alcoholic option, serve cold water or unsweetened black tea.";
"recipe.dk_risalamande.drink.summary" = "Dessert wine";
"recipe.dk_risalamande.info" = "Risalamande is the classic Danish Christmas dessert, made from chilled rice pudding folded with vanilla, chopped almonds, sugar, and lightly whipped cream. It is traditionally served cold with warm cherry sauce, and a single whole almond is hidden in the bowl as part of the Christmas almond-gift tradition.";
"recipe.dk_risalamande.info.summary" = "Danish Christmas rice";
"recipe.dk_risalamande.name" = "Risalamande";
"recipe.dk_risalamande.step1.body" = "Put %i1 and %i2 in the saucepan and bring to a boil, stirring until the water is mostly absorbed.";
"recipe.dk_risalamande.step1.title" = "Start the rice pudding";
"recipe.dk_risalamande.step10.body" = "Spoon the cold risalamande into bowls and serve with the warm cherry sauce over or alongside.";
"recipe.dk_risalamande.step10.title" = "Serve";
"recipe.dk_risalamande.step2.body" = "Add %i3 and %i4 seeds and pod, bring to a gentle simmer, then cook slowly with regular stirring until the rice is tender and the pudding is thick and creamy.";
"recipe.dk_risalamande.step2.title" = "Cook the pudding";
"recipe.dk_risalamande.step3.body" = "Remove the vanilla pod, transfer the rice pudding to a bowl, and let it cool completely until cold.";
"recipe.dk_risalamande.step3.title" = "Cool the rice pudding";
"recipe.dk_risalamande.step4.body" = "Blanch %i5 briefly, slip off the skins, then chop almost all of them coarsely and keep one whole almond aside.";
"recipe.dk_risalamande.step4.title" = "Prepare the almonds";
"recipe.dk_risalamande.step5.body" = "Whip %i7 lightly until thickened but still soft and not stiff.";
"recipe.dk_risalamande.step5.title" = "Whip the cream";
"recipe.dk_risalamande.step6.body" = "Stir %i6 and chopped almonds into the cold rice pudding, add the whole almond, then gently fold in the whipped cream until evenly combined.";
"recipe.dk_risalamande.step6.title" = "Fold the dessert";
"recipe.dk_risalamande.step7.body" = "Refrigerate the risalamande until well chilled and set into a soft, creamy texture.";
"recipe.dk_risalamande.step7.title" = "Chill the risalamande";
"recipe.dk_risalamande.step8.body" = "Put %i8, %i9, and %i10 in the small saucepan and bring to a gentle simmer until the fruit is heated through.";
"recipe.dk_risalamande.step8.title" = "Cook the cherry sauce";
"recipe.dk_risalamande.step9.body" = "Mix %i11 with the remaining %i12, stir it into the cherry sauce, and heat gently until the sauce turns glossy and lightly thickened.";
"recipe.dk_risalamande.step9.title" = "Thicken the sauce";
