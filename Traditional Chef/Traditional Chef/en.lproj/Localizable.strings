"recipe.co_patacones_con_hogao.drink.body" = "Pair with a crisp Sauvignon Blanc or a dry sparkling wine to match the bright tomato sauce and cut through the fried texture. A light lager is also a natural fit. Non-alcoholic option: sparkling water with lime or a cold lemonade with little sweetness.";
"recipe.co_patacones_con_hogao.drink.summary" = "White wine (Sauvignon)";
"recipe.co_patacones_con_hogao.info" = "Patacones con hogao are a classic Colombian appetizer of twice-fried green plantain rounds—crisp on the outside and tender within—served topped with or alongside warm hogao, the traditional tomato-and-scallion sauce. They are commonly enjoyed as a starter or snack, with the savory hogao balancing the mild sweetness of plantain.";
"recipe.co_patacones_con_hogao.info.summary" = "Hogao-topped patacones";
"recipe.co_patacones_con_hogao.name" = "Patacones with hogao";
"recipe.co_patacones_con_hogao.step1.body" = "Chop %i5 and %i6 finely and mince %i7 so the sauce cooks down evenly.";
"recipe.co_patacones_con_hogao.step1.title" = "Prep hogao ingredients";
"recipe.co_patacones_con_hogao.step2.body" = "Heat %i4 in a skillet and cook scallions and garlic until softened, then add tomatoes, %i8, %i9, and %i10 and cook until thick, jammy, and cohesive.";
"recipe.co_patacones_con_hogao.step2.title" = "Cook the hogao";
"recipe.co_patacones_con_hogao.step3.body" = "Peel %i1 and cut into thick rounds so they hold shape when fried and pressed.";
"recipe.co_patacones_con_hogao.step3.title" = "Prep the plantains";
"recipe.co_patacones_con_hogao.step4.body" = "Heat %i2 and fry the plantain rounds until lightly golden and just tender, then drain briefly.";
"recipe.co_patacones_con_hogao.step4.title" = "First fry";
"recipe.co_patacones_con_hogao.step5.body" = "Flatten each round firmly with a plate to form wide discs, then season with %i3.";
"recipe.co_patacones_con_hogao.step5.title" = "Press and salt";
"recipe.co_patacones_con_hogao.step6.body" = "Fry the flattened discs again until deeply golden and crisp, then drain on paper towels.";
"recipe.co_patacones_con_hogao.step6.title" = "Second fry until crisp";
"recipe.co_patacones_con_hogao.step7.body" = "Arrange patacones on a platter and spoon warm hogao over the top, serving immediately.";
"recipe.co_patacones_con_hogao.step7.title" = "Serve";
