"recipe.lk_bibikkan.drink.body" = "Hot Ceylon tea is the classic pairing for bibikkan and balances its rich coconut-treacle sweetness. A lightly sweet Moscato can also work in small servings. For a non-alcoholic option, serve plain hot Ceylon tea or black coffee.";
"recipe.lk_bibikkan.drink.summary" = "Tea (Ceylon tea)";
"recipe.lk_bibikkan.info" = "Bibikkan is a traditional Sri Lankan coconut cake, dark, moist, and richly spiced with treacle or jaggery. It is commonly prepared for festive occasions such as Sinhala and Tamil New Year and Christmas, and served in slices with tea.";
"recipe.lk_bibikkan.info.summary" = "Spiced coconut cake";
