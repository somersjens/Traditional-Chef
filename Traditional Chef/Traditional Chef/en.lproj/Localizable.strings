"recipe.pl_zurek.drink.body" = "Pair with a crisp dry white such as Riesling to brighten the soup’s tang and complement the sausage and marjoram. A clean pilsner-style lager also matches the smoky bacon and rye sourness. Non-alcoholic option: sparkling water with lemon or hot black tea.";
"recipe.pl_zurek.drink.summary" = "White wine (Riesling)";
"recipe.pl_zurek.info" = "Żurek is a traditional Polish sour rye soup built on zakwas (fermented rye starter) stirred into a hot, meaty broth scented with garlic, bay, allspice, and marjoram. It is enriched with white sausage and smoky bacon, then served hot with hard-boiled eggs and rye bread, especially during Easter but also as a hearty year-round first course.";
"recipe.pl_zurek.info.summary" = "Sour rye Easter soup";
"recipe.pl_zurek.name" = "Sour rye soup";
"recipe.pl_zurek.step1.body" = "Put %i1 in a stockpot and cover with cold %i2. Bring up slowly to a gentle simmer and skim any foam so the broth stays clean.";
"recipe.pl_zurek.step1.title" = "Start the pork broth";
"recipe.pl_zurek.step10.body" = "Ladle the hot żurek into bowls and add egg halves. Serve with %i17 alongside.";
"recipe.pl_zurek.step10.title" = "Serve";
"recipe.pl_zurek.step2.body" = "Add %i3, %i4, %i5, %i6, %i7, %i8, and %i9. Keep the simmer very gentle.";
"recipe.pl_zurek.step2.title" = "Add vegetables and spices";
"recipe.pl_zurek.step3.body" = "Simmer until the broth is rich and the ribs are tender, keeping the heat low so it does not boil hard.";
"recipe.pl_zurek.step3.title" = "Simmer the broth";
"recipe.pl_zurek.step4.body" = "Add %i10 and %i11 to the hot broth and simmer gently until the sausage is cooked through and the bacon has flavored the soup.";
"recipe.pl_zurek.step4.title" = "Add bacon and sausage";
"recipe.pl_zurek.step5.body" = "Lift out the sausage and bacon, then strain the broth into a clean pot. Slice the sausage and bacon and return them to the broth.";
"recipe.pl_zurek.step5.title" = "Strain and return to pot";
"recipe.pl_zurek.step6.body" = "Crush the %i13 and add it to the soup along with %i14. Simmer briefly so the aromatics bloom.";
"recipe.pl_zurek.step6.title" = "Add garlic and marjoram";
"recipe.pl_zurek.step7.body" = "Stir %i12 well, then add it gradually to the hot soup while stirring, until the sourness is balanced. Keep the soup hot but do not boil.";
"recipe.pl_zurek.step7.title" = "Sour the soup with zakwas";
"recipe.pl_zurek.step8.body" = "Season with %i15, tasting so the soup is pleasantly tangy, savory, and aromatic.";
"recipe.pl_zurek.step8.title" = "Season to taste";
"recipe.pl_zurek.step9.body" = "Boil the %i16 until hard, cool them, peel, and cut into halves.";
"recipe.pl_zurek.step9.title" = "Boil the eggs";
