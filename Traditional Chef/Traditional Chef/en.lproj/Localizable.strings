"recipe.sa_qursan.step10.title" = "Assemble the dish";
"recipe.sa_qursan.step11.body" = "Leave the assembled qursan briefly so the bread absorbs the broth and the layers settle together.";
"recipe.sa_qursan.step11.title" = "Set before serving";
"recipe.sa_qursan.step12.body" = "Bring the qursan to the table on the platter and serve immediately while the bread is soft and the stew is hot.";
"recipe.sa_qursan.step12.title" = "Serve hot";
