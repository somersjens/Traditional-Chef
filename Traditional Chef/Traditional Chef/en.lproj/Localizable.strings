"recipe.ma_briouats.drink.body" = "A dry rosé or a light red such as Grenache works well with the warm spices and fried pastry. For a non-alcoholic option, serve Moroccan mint tea or sparkling water with lemon.";
"recipe.ma_briouats.drink.summary" = "Rosé wine";
"recipe.ma_briouats.info" = "Moroccan briouats are crisp, golden pastries traditionally folded into tight triangles and filled with spiced kefta cooked with onions and fresh herbs, then sealed and fried until shatteringly crisp. They are commonly served as a starter on shared platters, often alongside lemon wedges to brighten the rich, aromatic filling.";
"recipe.ma_briouats.info.summary" = "Crispy meat pastries";
"recipe.ma_briouats.name" = "Kefta briouats";
"recipe.ma_briouats.step1.body" = "Finely chop the %i2, mince the %i3, and chop the %i4 and %i5. Keep everything ready near the stove.";
"recipe.ma_briouats.step1.title" = "Prep aromatics and herbs";
"recipe.ma_briouats.step2.body" = "In a skillet over medium heat, cook the %i1, breaking it up well. Add onion and cook until softened, then add garlic and cook until fragrant.";
"recipe.ma_briouats.step2.title" = "Cook the kefta filling";
"recipe.ma_briouats.step3.body" = "Stir in %i6, %i7, %i8, %i9, and %i10. Cook until the mixture is aromatic and any moisture has cooked off, then stir in parsley and cilantro and remove from heat.";
"recipe.ma_briouats.step3.title" = "Season and finish filling";
"recipe.ma_briouats.step4.body" = "Beat the %i11 in a bowl, then mix them into the warm filling. Return the pan to low heat and stir until the egg sets and the filling becomes cohesive. Let it cool.";
"recipe.ma_briouats.step4.title" = "Bind the filling";
"recipe.ma_briouats.step5.body" = "Lay out the %i12 and keep them covered with a slightly damp towel so they do not dry out. Melt the %i13 and keep a small bowl of %i14 for sealing.";
"recipe.ma_briouats.step5.title" = "Prepare pastry for folding";
"recipe.ma_briouats.step6.body" = "Cut the pastry into long strips. Brush lightly with butter, place filling near one end, and fold repeatedly into tight triangles. Seal the final edge with water so it stays closed.";
"recipe.ma_briouats.step6.title" = "Fold the briouats";
"recipe.ma_briouats.step7.body" = "Heat %i15 in a deep pot to a steady frying temperature so the pastries crisp quickly without soaking up oil.";
"recipe.ma_briouats.step7.title" = "Heat frying oil";
"recipe.ma_briouats.step8.body" = "Fry briouats in batches, turning as needed, until deep golden and crisp. Remove with a slotted spoon and drain on paper towels.";
"recipe.ma_briouats.step8.title" = "Fry until golden";
"recipe.ma_briouats.step9.body" = "Cut the %i16 into wedges and serve alongside the briouats on a platter for squeezing over each bite.";
"recipe.ma_briouats.step9.title" = "Serve with lemon";
