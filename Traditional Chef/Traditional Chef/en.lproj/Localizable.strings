"recipe.pt_cozido_a_portuguesa.drink.body" = "A medium-bodied Portuguese red such as a Dão or Douro pairs well with the savory meats and smoked sausages without overpowering the vegetables. If you prefer white, a structured Douro Branco also works. Non-alcoholic pairing: sparkling water with lemon or a lightly sweet iced tea.";
"recipe.pt_cozido_a_portuguesa.drink.summary" = "Red wine (Dão)";
"recipe.pt_cozido_a_portuguesa.info" = "Cozido a Portuguesa is a traditional Portuguese boiled meal where assorted meats and smoked sausages are gently simmered to create a rich broth, then vegetables and rice are cooked in that same broth. It is served family-style on platters, with sliced meats and sausages alongside tender cabbage and root vegetables, and a bowl of rice scented with the cooking juices.";
"recipe.pt_cozido_a_portuguesa.info.summary" = "Portuguese boiled feast";
"recipe.pt_cozido_a_portuguesa.name" = "Cozido";
"recipe.pt_cozido_a_portuguesa.step1.body" = "Rinse the meats and sausages. Peel and cut the %i8, %i9, and %i10 into large pieces. Cut %i11 into wedges. Peel %i13 and lightly crush %i14.";
"recipe.pt_cozido_a_portuguesa.step1.title" = "Prep meats and vegetables";
"recipe.pt_cozido_a_portuguesa.step10.body" = "Serve the rice in a bowl, drizzle %i16 over the vegetables, and bring everything to the table hot with a ladle of broth if needed.";
"recipe.pt_cozido_a_portuguesa.step10.title" = "Finish and serve";
"recipe.pt_cozido_a_portuguesa.step2.body" = "Put %i1, %i2, %i3, %i4, onion, garlic, %i15, %i17, %i18, and %i19 in a large pot and bring to a gentle simmer, skimming any foam.";
"recipe.pt_cozido_a_portuguesa.step2.title" = "Start the broth";
"recipe.pt_cozido_a_portuguesa.step3.body" = "Cover and simmer at a low boil until the meats are tender and the broth is flavorful, turning pieces as needed so everything cooks evenly.";
"recipe.pt_cozido_a_portuguesa.step3.title" = "Simmer until tender";
"recipe.pt_cozido_a_portuguesa.step4.body" = "Add %i5 and %i6 to the pot and simmer until heated through and cooked. Remove and reserve them.";
"recipe.pt_cozido_a_portuguesa.step4.title" = "Cook the sausages";
"recipe.pt_cozido_a_portuguesa.step5.body" = "Add %i7 and gently poach until cooked through without bursting, then remove and reserve.";
"recipe.pt_cozido_a_portuguesa.step5.title" = "Poach the farinheira";
"recipe.pt_cozido_a_portuguesa.step6.body" = "Add the cabbage to the broth and simmer until tender but still holding its shape, then lift it out and reserve.";
"recipe.pt_cozido_a_portuguesa.step6.title" = "Cook the cabbage";
"recipe.pt_cozido_a_portuguesa.step7.body" = "Add the carrots and turnip and simmer until nearly tender, then add the potatoes and continue until all are tender. Lift out and reserve the vegetables.";
"recipe.pt_cozido_a_portuguesa.step7.title" = "Cook root vegetables";
"recipe.pt_cozido_a_portuguesa.step8.body" = "Strain off enough hot broth into a saucepan, bring to a simmer, add %i12, and cook gently until tender and the grains are separate.";
"recipe.pt_cozido_a_portuguesa.step8.title" = "Cook rice in broth";
"recipe.pt_cozido_a_portuguesa.step9.body" = "Cut the meats into serving pieces and slice the sausages. Arrange meats and sausages on platters with the vegetables alongside.";
"recipe.pt_cozido_a_portuguesa.step9.title" = "Slice and arrange";
