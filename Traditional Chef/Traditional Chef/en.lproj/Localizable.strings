"recipe.ru_syrniki.drink.body" = "A lightly sweet sparkling wine or a crisp off-dry white pairs well with the browned dairy notes and gentle sweetness of syrniki. If you prefer something simpler, a mild dessert wine also works. Non-alcoholic pairing: strong black tea, served hot.";
"recipe.ru_syrniki.drink.summary" = "Sparkling wine";
"recipe.ru_syrniki.info" = "Syrniki are traditional Russian cottage-cheese pancakes made from tvorog mixed with egg, a little sugar and flour, shaped into small rounds, lightly floured, and pan-fried until golden with a tender, creamy center. They are served hot as a sweet dish, most commonly with sour cream spooned over the top.";
"recipe.ru_syrniki.info.summary" = "Curd breakfast pancakes";
"recipe.ru_syrniki.name" = "Syrniki";
"recipe.ru_syrniki.step1.body" = "Break up the %i1 in a bowl until it is fine and uniform, removing any large lumps so the syrniki hold together.";
"recipe.ru_syrniki.step1.title" = "Prepare the curd";
"recipe.ru_syrniki.step2.body" = "Add the %i2, %i3, and %i6 and mix until smooth. Mix in the %i4 until a soft, slightly sticky dough forms.";
"recipe.ru_syrniki.step2.title" = "Mix the dough";
"recipe.ru_syrniki.step3.body" = "Dust a plate with the %i5. Form the dough into small rounds and lightly coat each one in flour, shaking off excess.";
"recipe.ru_syrniki.step3.title" = "Shape and dredge";
"recipe.ru_syrniki.step4.body" = "Heat %i7 in a skillet over medium heat. Fry the syrniki until deeply golden on the first side, then flip and fry until golden and cooked through.";
"recipe.ru_syrniki.step4.title" = "Pan fry";
"recipe.ru_syrniki.step5.body" = "Drain briefly on paper towels and serve hot with %i8.";
"recipe.ru_syrniki.step5.title" = "Serve";
