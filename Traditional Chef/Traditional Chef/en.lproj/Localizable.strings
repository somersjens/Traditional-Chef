"recipe.jp_chawanmushi.drink.body" = "Dry sake pairs well with the subtle dashi and soft custard texture. For a non-alcoholic pairing, serve hot green tea or warm roasted barley tea.";
"recipe.jp_chawanmushi.drink.summary" = "Sake";
"recipe.jp_chawanmushi.info" = "Chawanmushi is a traditional Japanese steamed savory egg custard made with dashi and delicate fillings such as chicken, shrimp, shiitake, and kamaboko. It is commonly served hot or warm as an appetizer in kaiseki meals, home dinners, and special occasions, presented in lidded cups and eaten with a spoon.";
"recipe.jp_chawanmushi.info.summary" = "Savory steamed custard";
"recipe.jp_chawanmushi.name" = "Chawanmushi";
"recipe.jp_chawanmushi.step1.body" = "Cut the %i6 into small pieces, clean and slice the %i8, slice the %i9, trim the %i7, and cut the %i11 into short lengths for topping.";
"recipe.jp_chawanmushi.step1.title" = "Prepare the fillings";
"recipe.jp_chawanmushi.step2.body" = "Toss the chicken and shrimp with a little %i12 and %i13, then let them sit briefly while you make the custard base.";
"recipe.jp_chawanmushi.step2.title" = "Season the chicken and shrimp";
"recipe.jp_chawanmushi.step3.body" = "Whisk the %i1 gently, then combine with %i2, %i3, %i4, and %i5 without creating too much foam.";
"recipe.jp_chawanmushi.step3.title" = "Mix the custard base";
"recipe.jp_chawanmushi.step4.body" = "Strain the egg mixture through a fine strainer for a smooth custard and skim any surface bubbles.";
"recipe.jp_chawanmushi.step4.title" = "Strain the custard";
"recipe.jp_chawanmushi.step5.body" = "Divide the chicken, shrimp, shiitake, kamaboko, and %i10 among the cups, then pour in the strained custard mixture and cover with lids or foil.";
"recipe.jp_chawanmushi.step5.title" = "Fill the cups";
"recipe.jp_chawanmushi.step6.body" = "Add %i14 to the steamer pot and bring it to a gentle steam, keeping the heat moderate so the custard cooks evenly.";
"recipe.jp_chawanmushi.step6.title" = "Prepare the steamer";
"recipe.jp_chawanmushi.step7.body" = "Steam the covered cups gently until the custard is just set and softly jiggly in the center, adjusting the heat to avoid vigorous boiling.";
"recipe.jp_chawanmushi.step7.title" = "Steam the chawanmushi";
"recipe.jp_chawanmushi.step8.body" = "Open the cups, add mitsuba on top, and steam briefly so the herb softens and becomes fragrant.";
"recipe.jp_chawanmushi.step8.title" = "Finish with mitsuba";
"recipe.jp_chawanmushi.step9.body" = "Let the cups rest briefly off the heat, then serve hot or warm in the cups with spoons.";
"recipe.jp_chawanmushi.step9.title" = "Rest and serve";
