"recipe.bg_kavarma.drink.body" = "A medium-bodied red wine such as Mavrud or Merlot pairs well with the savory pork, sweet peppers, and slow-cooked onions. For a non-alcoholic pairing, serve ayran or sparkling water.";
"recipe.bg_kavarma.drink.summary" = "Red wine (Mavrud)";
"recipe.bg_kavarma.info" = "Kavarma is a traditional Bulgarian main dish of pork slowly cooked with onions, peppers, mushrooms, tomatoes, garlic, and white wine, then baked until rich and tender in a covered pot. It is a hearty family dish often served hot with crusty bread for soaking up the sauce.";
"recipe.bg_kavarma.info.summary" = "Slow-baked pork stew";
"recipe.bg_kavarma.name" = "Kavarma";
