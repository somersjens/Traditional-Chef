"recipe.ch_fondue.drink.body" = "Serve with a dry Swiss white wine such as Chasselas or Fendant. A crisp dry cider also works well. For a non-alcoholic option, offer hot black tea, which is a classic table pairing with fondue in Switzerland.";
"recipe.ch_fondue.drink.summary" = "White wine (Chasselas)";
"recipe.ch_fondue.info" = "Traditional Swiss cheese fondue is served communally in a caquelon at the table, with bread cubes dipped into a smooth mixture of Gruyère and Vacherin Fribourgeois. It is a classic cold-weather meal from western Switzerland and is eaten slowly over a burner so the cheese stays hot and fluid.";
"recipe.ch_fondue.info.summary" = "Swiss cheese fondue";
"recipe.ch_fondue.name" = "Cheese fondue";
"recipe.ch_fondue.step1.body" = "Cut %i9 into bite-size cubes and leave it aside for serving.";
"recipe.ch_fondue.step1.title" = "Prepare the bread";
"recipe.ch_fondue.step2.body" = "Rub the inside of the caquelon with the cut %i1. Grate or finely shred %i2 and %i3 and toss them in a bowl with %i5 until evenly coated.";
"recipe.ch_fondue.step2.title" = "Prepare the cheese mixture";
"recipe.ch_fondue.step3.body" = "Pour %i4 and %i6 into the caquelon and bring them just to a simmer over moderate heat.";
"recipe.ch_fondue.step3.title" = "Heat the base";
"recipe.ch_fondue.step4.body" = "Add the cheese mixture by handfuls, stirring constantly in a figure-eight motion so the cheese melts smoothly before the next addition. Stir in %i7 and season with %i8.";
"recipe.ch_fondue.step4.title" = "Melt the cheese";
"recipe.ch_fondue.step5.body" = "Set the caquelon over the rechaud and keep the heat low so the fondue stays gently molten without boiling. Dip the bread cubes into the cheese and stir the fondue from time to time while eating.";
"recipe.ch_fondue.step5.title" = "Serve at the table";
"recipe.ch_fondue.step6.body" = "Lower the heat near the end and let the crust form lightly on the bottom. Serve the toasted cheese crust in pieces once the fondue is finished.";
"recipe.ch_fondue.step6.title" = "Finish the pot";
