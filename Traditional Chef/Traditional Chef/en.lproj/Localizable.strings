"recipe.ec_hornado.drink.body" = "A young fruity red wine such as Pinot Noir pairs well with the rich pork without overwhelming the accompaniments. A light lager also matches the roasted flavors. For a non-alcoholic option, serve sparkling lime water.";
"recipe.ec_hornado.drink.summary" = "Red wine (Pinot Noir)";
"recipe.ec_hornado.info" = "Hornado is a traditional Ecuadorian highland pork dish of achiote and cumin marinated pork roasted slowly until tender inside and browned outside. It is classically served as a full plate with mote, llapingachos, curtido, and agrio, especially at markets, family gatherings, and weekend lunches.";
"recipe.ec_hornado.info.summary" = "Highland roast pork";
"recipe.ec_hornado.name" = "Hornado";
"recipe.ec_hornado.step1.body" = "Blend part of %i2 with %i3, %i4, %i5, %i6, %i7, %i9, and %i10 into a thick marinade.";
"recipe.ec_hornado.step1.title" = "Prepare the marinade";
"recipe.ec_hornado.step10.body" = "Remove the pork from the oven, let it rest briefly, then cut or pull it into serving portions. Spoon some of the roasting juices over the meat.";
"recipe.ec_hornado.step10.title" = "Finish the hornado";
"recipe.ec_hornado.step11.body" = "Serve the hornado with mote, llapingachos, curtido, and agrio on each plate.";
"recipe.ec_hornado.step11.title" = "Serve traditionally";
"recipe.ec_hornado.step2.body" = "Rub the marinade all over %i1, making sure it is well coated on every side. Place it in the roasting pan with the remaining red onion and let it rest.";
"recipe.ec_hornado.step2.title" = "Season the pork";
"recipe.ec_hornado.step3.body" = "Add %i11 to the pan and roast the pork covered until very tender. Uncover, baste with the pan juices and %i8, and continue roasting until the exterior is deeply browned.";
"recipe.ec_hornado.step3.title" = "Roast slowly";
"recipe.ec_hornado.step4.body" = "Thinly slice %i19 for the curtido and combine it with %i20, %i21, %i23, and %i22. Let it rest so the onion softens and the flavors meld.";
"recipe.ec_hornado.step4.title" = "Make the curtido";
"recipe.ec_hornado.step5.body" = "Finely chop %i24 and %i25, then mix with %i26, %i27, and %i28 to make the traditional tangy sauce. Set aside for serving.";
"recipe.ec_hornado.step5.title" = "Make the agrio";
"recipe.ec_hornado.step6.body" = "Boil %i14 in water until tender, then drain them well and mash until smooth.";
"recipe.ec_hornado.step6.title" = "Cook the potatoes";
"recipe.ec_hornado.step7.body" = "Cook %i15 in %i16 until soft, then mix it into the mashed potatoes with %i18. Form thick patties around %i17 filling.";
"recipe.ec_hornado.step7.title" = "Prepare the llapingachos";
"recipe.ec_hornado.step8.body" = "Cook the potato patties on the skillet until firm and browned on both sides, then keep them warm.";
"recipe.ec_hornado.step8.title" = "Cook the llapingachos";
"recipe.ec_hornado.step9.body" = "Warm %i12 with a little %i13 until hot and ready to serve.";
"recipe.ec_hornado.step9.title" = "Heat the mote";
