"recipe.lk_lamprais.info" = "Lamprais is a traditional Sri Lankan Burgher rice parcel of stock-cooked rice wrapped in banana leaf with mixed meat curry, ash plantain curry, brinjal pahi, seeni sambol, blachan, and frikkadels, then baked so the leaf perfumes the meal. It is a festive and labor-intensive dish commonly served for special family meals and celebrations.";
"recipe.lk_lamprais.info.summary" = "Banana-leaf rice parcel";
"recipe.lk_lamprais.name" = "Lamprais";
