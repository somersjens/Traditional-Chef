"recipe.my_bubur_cha_cha.info" = "Bubur cha cha is a traditional Malaysian and Nyonya sweet dessert soup made with sweet potato, taro, sago pearls, banana, and pandan-scented coconut milk. It is commonly served warm or chilled as a dessert, snack, or breakfast-style sweet porridge.";
"recipe.my_bubur_cha_cha.info.summary" = "Coconut root dessert";
