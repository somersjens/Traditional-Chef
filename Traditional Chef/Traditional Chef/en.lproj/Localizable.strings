"recipe.hk_sweet_red_bean_soup.drink.body" = "This warm dessert is traditionally paired with tea rather than wine, especially jasmine tea. If serving wine, a lightly sweet white can work, while hot jasmine tea or warm water is the classic non-alcoholic pairing.";
"recipe.hk_sweet_red_bean_soup.drink.summary" = "Jasmine tea";
"recipe.hk_sweet_red_bean_soup.info" = "A traditional Cantonese tong sui dessert made by simmering adzuki beans until soft and lightly broken, then sweetened and served warm. In Hong Kong it is commonly enjoyed after meals or in dessert shops, often with a smooth but still slightly textured consistency.";
"recipe.hk_sweet_red_bean_soup.info.summary" = "Warm red bean soup";
"recipe.hk_sweet_red_bean_soup.name" = "Red bean soup";
"recipe.hk_sweet_red_bean_soup.step1.body" = "Rinse the %i1 well, then cover with %i2 and soak to help them cook evenly.";
"recipe.hk_sweet_red_bean_soup.step1.title" = "Rinse and soak the beans";
"recipe.hk_sweet_red_bean_soup.step2.body" = "Leave the beans to soak until expanded, then drain and rinse again.";
"recipe.hk_sweet_red_bean_soup.step2.title" = "Soak the beans";
"recipe.hk_sweet_red_bean_soup.step3.body" = "Soak the %i4 in warm water until softened, then scrape off the bitter white pith and set the peel aside.";
"recipe.hk_sweet_red_bean_soup.step3.title" = "Prepare the tangerine peel";
"recipe.hk_sweet_red_bean_soup.step4.body" = "Place the soaked beans in a saucepan with %i3 and the prepared tangerine peel, then bring to a boil.";
"recipe.hk_sweet_red_bean_soup.step4.title" = "Start the soup";
"recipe.hk_sweet_red_bean_soup.step5.body" = "Lower to a gentle simmer and cook until the beans are very soft and beginning to break down, stirring occasionally.";
"recipe.hk_sweet_red_bean_soup.step5.title" = "Simmer until beans soften";
"recipe.hk_sweet_red_bean_soup.step6.body" = "Lightly mash or briefly blend part of the beans in the pot to create the traditional thicker texture while keeping some whole beans.";
"recipe.hk_sweet_red_bean_soup.step6.title" = "Partially thicken the soup";
"recipe.hk_sweet_red_bean_soup.step7.body" = "Add the %i5 and %i6, then stir until fully dissolved.";
"recipe.hk_sweet_red_bean_soup.step7.title" = "Sweeten the soup";
"recipe.hk_sweet_red_bean_soup.step8.body" = "Simmer briefly after sweetening so the flavor melds and the soup reaches a smooth, slightly thick consistency.";
"recipe.hk_sweet_red_bean_soup.step8.title" = "Finish simmering";
"recipe.hk_sweet_red_bean_soup.step9.body" = "Remove the tangerine peel, ladle the sweet red bean soup into bowls, and serve warm.";
"recipe.hk_sweet_red_bean_soup.step9.title" = "Serve warm";
