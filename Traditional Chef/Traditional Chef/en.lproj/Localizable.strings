"recipe.sn_ceebu_yapp.drink.body" = "A medium-bodied red wine such as Grenache or Cinsault pairs well with the savory tomato and spice notes, while a cold Senegalese-style bissap (hibiscus) or ginger drink makes an excellent non-alcoholic match.";
"recipe.sn_ceebu_yapp.drink.summary" = "Red wine (Grenache)";
"recipe.sn_ceebu_yapp.info" = "Ceebu Yapp is a traditional Senegalese one-pot dish of broken rice cooked in a richly seasoned tomato broth with tender meat and assorted vegetables, served family-style on a large platter with the meat and vegetables arranged on top of the rice and spooned with the cooking sauce.";
"recipe.sn_ceebu_yapp.info.summary" = "Senegal rice with meat";
"recipe.sn_ceebu_yapp.name" = "Ceebu yapp";
"recipe.sn_ceebu_yapp.step1.body" = "Blend the %i3, %i4, %i5, %i6, %i7, and %i8 into a smooth paste.";
"recipe.sn_ceebu_yapp.step1.title" = "Make nokoss paste";
"recipe.sn_ceebu_yapp.step10.body" = "Taste the broth and adjust seasoning, then bring it back to a lively simmer so the rice can cook evenly.";
"recipe.sn_ceebu_yapp.step10.title" = "Ready the rice broth";
"recipe.sn_ceebu_yapp.step11.body" = "Add the drained rice to the pot, stir once to distribute, then cover and cook until the rice has absorbed the broth and is tender.";
"recipe.sn_ceebu_yapp.step11.title" = "Cook the rice";
"recipe.sn_ceebu_yapp.step12.body" = "Let the rice rest covered, then mound the rice onto a platter, arrange the meat and vegetables on top, and spoon the sauce over the center before serving.";
"recipe.sn_ceebu_yapp.step12.title" = "Rest and serve";
"recipe.sn_ceebu_yapp.step2.body" = "Rub the %i2 with some of the nokoss paste, %i13, %i15, %i16, and %i17, then let it sit to absorb the seasoning.";
"recipe.sn_ceebu_yapp.step2.title" = "Season the meat";
"recipe.sn_ceebu_yapp.step3.body" = "Rinse the %i1 repeatedly in a bowl with water, then drain well in a colander and set aside.";
"recipe.sn_ceebu_yapp.step3.title" = "Wash the rice";
"recipe.sn_ceebu_yapp.step4.body" = "Heat the %i9 in the pot and brown the meat well on all sides, scraping up any flavorful bits from the bottom.";
"recipe.sn_ceebu_yapp.step4.title" = "Brown the meat";
"recipe.sn_ceebu_yapp.step5.body" = "Stir in the %i10 and cook it until it darkens slightly, then add the remaining nokoss paste and cook until fragrant.";
"recipe.sn_ceebu_yapp.step5.title" = "Build the sauce base";
"recipe.sn_ceebu_yapp.step6.body" = "Stir in the %i11 and %i12, then add %i25 and bring the pot to a steady simmer.";
"recipe.sn_ceebu_yapp.step6.title" = "Add tang and broth";
"recipe.sn_ceebu_yapp.step7.body" = "Cover and simmer until the meat begins to turn tender, occasionally stirring so the sauce does not stick.";
"recipe.sn_ceebu_yapp.step7.title" = "Simmer the meat";
"recipe.sn_ceebu_yapp.step8.body" = "Peel and cut the %i18, %i20, %i21, %i22, and %i23 into large chunks, cut the %i19 into wedges, and trim the %i24, keeping pieces large so they hold together.";
"recipe.sn_ceebu_yapp.step8.title" = "Prepare vegetables";
"recipe.sn_ceebu_yapp.step9.body" = "Add the vegetables to the simmering pot and cook until each is tender but still holds its shape, removing them as they finish and keeping them warm.";
"recipe.sn_ceebu_yapp.step9.title" = "Cook the vegetables in the sauce";
