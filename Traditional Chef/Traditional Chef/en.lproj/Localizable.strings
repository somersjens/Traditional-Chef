"recipe.mm_danbauk.drink.body" = "An aromatic white such as Riesling or Gewurztraminer pairs well with the mild spices and rich chicken rice. Beer pairing: light lager. Non-alcoholic pairing: lime soda or cold black tea.";
"recipe.mm_danbauk.drink.summary" = "White wine (Riesling)";
"recipe.mm_danbauk.info" = "Danbauk is a traditional Myanmar biryani-style rice dish of fragrant long-grain rice cooked with spiced chicken, yogurt, and aromatics, often enriched with fried onions, raisins, peas, and cashews. It is commonly served for gatherings and festive meals with a fresh salad and a light soup on the side.";
"recipe.mm_danbauk.info.summary" = "Burmese biryani plate";
"recipe.mm_danbauk.name" = "Danbauk";
"recipe.mm_danbauk.step1.body" = "Cut the %i1 into large pieces and mix with %i2, %i3, one %i4, %i5, %i6, %i7, %i8, part of the %i9, %i10, and a little %i11. Let it marinate.";
"recipe.mm_danbauk.step1.title" = "Prepare and marinate the chicken";
"recipe.mm_danbauk.step10.body" = "Finely slice the %i26, %i27, %i28, and %i29, then toss with %i30 and %i31.";
"recipe.mm_danbauk.step10.title" = "Prepare the salad";
"recipe.mm_danbauk.step11.body" = "Let the danbauk rest briefly off the heat, then fluff gently so the rice grains stay separate.";
"recipe.mm_danbauk.step11.title" = "Rest and fluff the danbauk";
"recipe.mm_danbauk.step12.body" = "Transfer the danbauk to a platter, top with the remaining cilantro, and serve hot with the fresh salad and light soup.";
"recipe.mm_danbauk.step12.title" = "Finish and serve";
"recipe.mm_danbauk.step2.body" = "Refrigerate the chicken so the yogurt and spices season the meat.";
"recipe.mm_danbauk.step2.title" = "Rest the marinade";
"recipe.mm_danbauk.step3.body" = "Rinse the %i13 until the water runs mostly clear, then soak it in water briefly and drain.";
"recipe.mm_danbauk.step3.title" = "Rinse and soak the rice";
"recipe.mm_danbauk.step4.body" = "Slice the %i20 and fry it in %i21 until deep golden. Remove and drain, then lightly fry the %i24 and %i23 in the same pan and set aside.";
"recipe.mm_danbauk.step4.title" = "Fry onions and nuts";
"recipe.mm_danbauk.step5.body" = "Cook the marinated chicken in a heavy pot with a little neutral oil until aromatic, then add %i12 and simmer until the chicken is mostly tender and the gravy thickens.";
"recipe.mm_danbauk.step5.title" = "Cook the chicken base";
"recipe.mm_danbauk.step6.body" = "Bring %i14 to a boil with %i15, %i16, %i17, %i18, and %i19. Add the soaked rice and boil until partially cooked, then drain well.";
"recipe.mm_danbauk.step6.title" = "Parboil the rice";
"recipe.mm_danbauk.step7.body" = "Spread part of the parboiled rice in the pot, add the chicken and gravy, %i22, and some fried onion, then cover with the remaining rice. Top with the rest of the fried onion, raisins, and cashews.";
"recipe.mm_danbauk.step7.title" = "Layer the danbauk";
"recipe.mm_danbauk.step8.body" = "Cover tightly and cook on low heat until the rice is fully tender and the chicken is cooked through, allowing the layers to steam together.";
"recipe.mm_danbauk.step8.title" = "Dum cook the rice";
"recipe.mm_danbauk.step9.body" = "Simmer the soup %i32 with %i33, %i34, part of the %i35, and %i36 until lightly flavored, then keep hot.";
"recipe.mm_danbauk.step9.title" = "Make the side soup";
