"recipe.mu_vindaye_poisson.step3.title" = "Fry the fish";
"recipe.mu_vindaye_poisson.step4.body" = "Heat oil in a pot, add %i8 and %i9, and let them sizzle until fragrant.";
"recipe.mu_vindaye_poisson.step4.title" = "Start the vindaye tempering";
