"recipe.pk_paya.drink.body" = "A medium-bodied red such as Syrah or Tempranillo can handle the rich spiced broth, though beer is often a better match with this dish. A malty amber ale works well. Non-alcoholic pairing: hot black tea or salted lassi are traditional choices.";
"recipe.pk_paya.drink.summary" = "Red wine (Syrah)";
"recipe.pk_paya.info" = "Paya is a traditional Pakistani slow-cooked stew made from trotters simmered for many hours with onions, ginger, garlic, and warming spices until the broth becomes rich, gelatinous, and deeply flavorful. It is commonly served hot as a special breakfast or weekend meal with naan for dipping.";
"recipe.pk_paya.info.summary" = "Slow-cooked paya";
"recipe.pk_paya.name" = "Paya";
"recipe.pk_paya.step1.body" = "Clean the %i1 thoroughly and trim any remaining rough bits if needed. Slice the %i4, finely chop the %i5 and part of the %i6, julienne the remaining %i20 for garnish, chop the %i19 and %i21, and cut the %i22 into wedges.";
"recipe.pk_paya.step1.title" = "Clean and prepare paya";
"recipe.pk_paya.step10.body" = "Transfer the paya to a serving bowl, top with cilantro, julienned ginger, green chili, and lemon wedges, and serve hot with naan.";
"recipe.pk_paya.step10.title" = "Garnish and serve";
"recipe.pk_paya.step2.body" = "Place the trotters in a large heavy pot with %i2 and bring slowly to a boil. Skim the surface well to remove foam and impurities.";
"recipe.pk_paya.step2.title" = "Start boiling";
"recipe.pk_paya.step3.body" = "Add %i14, %i15, %i16, %i17, %i18, half of the %i7, and half of the ginger and garlic. Cover and simmer on very low heat until the trotters are very tender and the broth becomes rich and gelatinous.";
"recipe.pk_paya.step3.title" = "Long simmer for stock";
"recipe.pk_paya.step4.body" = "In a deep pan, heat the %i3 over medium heat and fry the onion until deep golden brown, stirring regularly so it colors evenly.";
"recipe.pk_paya.step4.title" = "Brown onions in ghee";
"recipe.pk_paya.step5.body" = "Add the remaining ginger and garlic to the browned onion, then add %i8, %i9, %i10, %i11, %i12, and the remaining salt. Cook briefly until fragrant.";
"recipe.pk_paya.step5.title" = "Cook masala";
"recipe.pk_paya.step6.body" = "Add the cooked trotters to the masala and stir to coat well. Add some of the hot broth and cook while stirring so the masala roasts and blends into the liquid.";
"recipe.pk_paya.step6.title" = "Bhunna with paya and broth";
"recipe.pk_paya.step7.body" = "Return everything to the main pot if needed, add enough broth for a stew consistency, and simmer gently until the gravy is glossy and deeply flavored. Stir in the %i13 near the end.";
"recipe.pk_paya.step7.title" = "Final simmer";
"recipe.pk_paya.step8.body" = "Turn off the heat and let the paya rest briefly so the fat settles and the flavors meld.";
"recipe.pk_paya.step8.title" = "Rest paya";
"recipe.pk_paya.step9.body" = "Warm the %i23 briefly until soft and fragrant for serving.";
"recipe.pk_paya.step9.title" = "Warm naan";
