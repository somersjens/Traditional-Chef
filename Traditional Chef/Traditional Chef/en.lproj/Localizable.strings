"recipe.ge_odjakhuri.drink.body" = "A medium-bodied dry red wine such as Saperavi pairs well with the browned pork and potatoes. A crisp lager also matches the skillet-fried flavors. For a non-alcoholic option, serve sparkling water with lemon or chilled tarragon lemonade.";
"recipe.ge_odjakhuri.drink.summary" = "Red wine (Saperavi)";
"recipe.ge_odjakhuri.info" = "Odjakhuri is a traditional Georgian family-style dish of pork and potatoes fried and finished together with onions, garlic, and herbs in a hot skillet. It is served as a hearty main course, often brought to the table sizzling, with tart tkemali sauce and fresh onion.";
"recipe.ge_odjakhuri.info.summary" = "Pork potato skillet";
"recipe.ge_odjakhuri.name" = "Odjakhuri";
"recipe.ge_odjakhuri.step1.body" = "Cut the %i1 into serving pieces and the %i2 into wedges. Slice the %i3, mince the %i4, chop the %i10 and %i11, and slice the %i13 for serving.";
"recipe.ge_odjakhuri.step1.title" = "Prepare ingredients";
"recipe.ge_odjakhuri.step2.body" = "Season the pork with about half of the %i5, %i6, and %i7, and mix well.";
"recipe.ge_odjakhuri.step2.title" = "Season the pork";
"recipe.ge_odjakhuri.step3.body" = "Heat part of the %i8 in a large skillet and brown the pork on all sides over medium-high heat.";
"recipe.ge_odjakhuri.step3.title" = "Brown the pork";
"recipe.ge_odjakhuri.step4.body" = "Add %i9, cover, and cook gently until the pork is tender and the liquid is mostly gone.";
"recipe.ge_odjakhuri.step4.title" = "Cook the pork through";
"recipe.ge_odjakhuri.step5.body" = "Push the pork aside or remove it briefly, add the remaining oil, and fry the potatoes until golden and nearly tender.";
"recipe.ge_odjakhuri.step5.title" = "Fry the potatoes";
"recipe.ge_odjakhuri.step6.body" = "Add the yellow onions and garlic to the skillet and cook until the onions soften and begin to color.";
"recipe.ge_odjakhuri.step6.title" = "Add onions and garlic";
"recipe.ge_odjakhuri.step7.body" = "Return everything to the skillet, add the remaining salt, and stir so the pork and potatoes are evenly coated and browned.";
"recipe.ge_odjakhuri.step7.title" = "Combine and finish seasoning";
"recipe.ge_odjakhuri.step8.body" = "Add most of the cilantro and parsley, reserving a little for garnish, and toss briefly over the heat.";
"recipe.ge_odjakhuri.step8.title" = "Add fresh herbs";
"recipe.ge_odjakhuri.step9.body" = "Transfer to a serving platter or clay pan, top with the reserved herbs and red onion, and serve immediately with %i12.";
"recipe.ge_odjakhuri.step9.title" = "Serve hot";
