"recipe.dz_rechta.drink.body" = "A crisp, dry white like Vermentino suits the gentle spices and rich chicken broth without overpowering the dish. A light-bodied red served slightly cool can also work. Non-alcoholic pairing: mint tea or sparkling water with lemon.";
"recipe.dz_rechta.drink.summary" = "White wine (Vermentino)";
"recipe.dz_rechta.info" = "Rechta is a traditional Algerian celebratory dish of handmade flat noodles steamed until tender, then served with a delicately spiced white chicken sauce scented with cinnamon and chickpeas, and topped with chicken pieces. It is especially associated with family gatherings and holidays, served hot with the sauce ladled generously over the noodles.";
"recipe.dz_rechta.info.summary" = "Steamed noodles and chicken";
"recipe.dz_rechta.name" = "Rechta";
"recipe.dz_rechta.step1.body" = "Rinse the %i6, cover with plenty of %i13, and soak until fully hydrated. Drain and rinse well.";
"recipe.dz_rechta.step1.title" = "Soak the chickpeas";
"recipe.dz_rechta.step2.body" = "Mix %i1 and %i3, add %i2, then add %i4 gradually and knead until smooth and firm. Rest briefly so it relaxes.";
"recipe.dz_rechta.step2.title" = "Make the noodle dough";
"recipe.dz_rechta.step3.body" = "Roll the dough very thin, dust lightly, fold, and cut into fine flat noodles, then loosen and let them dry slightly so they separate.";
"recipe.dz_rechta.step3.title" = "Roll and cut rechta";
"recipe.dz_rechta.step4.body" = "In a pot, warm %i9 and %i8, add %i7 and cook until softened, then add %i10, %i11, and %i12.";
"recipe.dz_rechta.step4.title" = "Start the chicken sauce";
"recipe.dz_rechta.step5.body" = "Add %i5, soaked chickpeas, and water. Bring to a gentle simmer, cover partially, and cook until chickpeas are tender and chicken is cooked through.";
"recipe.dz_rechta.step5.title" = "Simmer chicken and chickpeas";
"recipe.dz_rechta.step6.body" = "Place the noodles in the steamer, steam until they begin to soften, then tip into a bowl and toss with a little %i14 to separate.";
"recipe.dz_rechta.step6.title" = "Steam the noodles first time";
"recipe.dz_rechta.step7.body" = "Return the noodles to the steamer and steam until fully tender and fluffy, then tip out and toss again to keep strands separate.";
"recipe.dz_rechta.step7.title" = "Steam the noodles again";
"recipe.dz_rechta.step8.body" = "When chicken is tender, remove pieces to serve and keep warm. Simmer the broth until slightly rich and silky, adjusting salt if needed.";
"recipe.dz_rechta.step8.title" = "Finish the sauce";
"recipe.dz_rechta.step9.body" = "Pile the steamed rechta on a platter, ladle sauce and chickpeas over the top, arrange chicken pieces on top, and serve hot.";
"recipe.dz_rechta.step9.title" = "Assemble and serve";
