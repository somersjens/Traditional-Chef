"recipe.ma_tagine_chicken_preserved_lemon_olives.step4.title" = "Build the aromatic base";
"recipe.ma_tagine_chicken_preserved_lemon_olives.step5.body" = "Nestle the %i1 into the onions, add %i10, cover, and simmer gently until the chicken is tender and the sauce is reduced, spooning the sauce over occasionally.";
"recipe.ma_tagine_chicken_preserved_lemon_olives.step5.title" = "Braise the chicken";
"recipe.ma_tagine_chicken_preserved_lemon_olives.step6.body" = "Add the sliced preserved lemon peel and olives to the tagine and simmer uncovered briefly so the flavors meld and the sauce becomes glossy. Stir in the chopped cilantro and parsley.";
"recipe.ma_tagine_chicken_preserved_lemon_olives.step6.title" = "Add preserved lemon and olives";
"recipe.ma_tagine_chicken_preserved_lemon_olives.step7.body" = "Punch down the risen dough, shape into round loaves on a baking sheet, cover briefly, and heat the oven.";
"recipe.ma_tagine_chicken_preserved_lemon_olives.step7.title" = "Shape khobz and heat oven";
"recipe.ma_tagine_chicken_preserved_lemon_olives.step8.body" = "Bake the loaves until well risen and browned, then remove and let cool slightly for serving.";
"recipe.ma_tagine_chicken_preserved_lemon_olives.step8.title" = "Bake the bread";
"recipe.ma_tagine_chicken_preserved_lemon_olives.step9.body" = "Serve the chicken tagine hot with khobz for scooping up the chicken, olives, preserved lemon, and sauce.";
"recipe.ma_tagine_chicken_preserved_lemon_olives.step9.title" = "Serve";
