"recipe.cz_kulajda.drink.body" = "A fresh dry white wine such as Grüner Veltliner or a light Moravian white pairs well with the creamy soup and herbs. For a non-alcoholic pairing, serve cold sparkling water or still water with lemon.";
"recipe.cz_kulajda.drink.summary" = "White wine (Grüner Veltliner)";
"recipe.cz_kulajda.info" = "Kulajda is a traditional South Bohemian soup made with potatoes, wild mushrooms, dill, cream, milk, and a gentle sour note from vinegar. It is finished with poached eggs and served hot as a classic first course in Czech home cooking, especially in mushroom season.";
"recipe.cz_kulajda.info.summary" = "South Bohemian dill soup";
"recipe.cz_kulajda.name" = "Kulajda";
"recipe.cz_kulajda.step1.body" = "Peel and dice %i1, clean and slice %i2, finely chop %i3, and chop %i8. Mix %i7 smoothly with a little of %i5 and set it aside.";
"recipe.cz_kulajda.step1.title" = "Prepare the ingredients";
"recipe.cz_kulajda.step2.body" = "Put the potatoes, mushrooms, onion, %i10, %i11, %i12, %i13, %i14, and %i4 into the pot. Bring to a boil and simmer until the potatoes are nearly tender.";
"recipe.cz_kulajda.step2.title" = "Cook the soup base";
"recipe.cz_kulajda.step3.body" = "Pour in the remaining milk, then whisk in the flour mixture. Simmer gently until the soup thickens and the flour is fully cooked.";
"recipe.cz_kulajda.step3.title" = "Thicken the soup";
"recipe.cz_kulajda.step4.body" = "Stir in %i6 and most of the dill, then heat the soup gently without letting it boil hard.";
"recipe.cz_kulajda.step4.title" = "Add the cream and dill";
"recipe.cz_kulajda.step5.body" = "Add %i9 and adjust the seasoning so the soup tastes creamy, lightly sour, and well balanced. Remove the bay leaf and allspice.";
"recipe.cz_kulajda.step5.title" = "Season with vinegar";
"recipe.cz_kulajda.step6.body" = "Bring water to a gentle simmer in the saucepan and poach %i15 until the whites are set and the yolks stay soft.";
"recipe.cz_kulajda.step6.title" = "Poach the eggs";
"recipe.cz_kulajda.step7.body" = "Ladle the kulajda into bowls, place a poached egg in each serving, and finish with the remaining dill.";
"recipe.cz_kulajda.step7.title" = "Serve";
