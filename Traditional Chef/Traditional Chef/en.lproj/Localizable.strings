"recipe.mt_stuffat_tal_fenek.drink.body" = "A medium-bodied red wine such as Merlot or a soft Syrah pairs well with the rich tomato and wine sauce. A good non-alcoholic option is sparkling water or a dark grape juice spritzer.";
"recipe.mt_stuffat_tal_fenek.drink.summary" = "Red wine (Merlot)";
"recipe.mt_stuffat_tal_fenek.info" = "Stuffat tal-Fenek is Malta’s traditional rabbit stew, a rich tomato-based dish slowly cooked with red wine, garlic, onion, bay leaves, and root vegetables. It is a classic fenkata main course, served hot with peas, potatoes, and crusty Maltese bread to soak up the sauce.";
"recipe.mt_stuffat_tal_fenek.info.summary" = "Maltese rabbit stew";
"recipe.mt_stuffat_tal_fenek.name" = "Rabbit stew";
"recipe.mt_stuffat_tal_fenek.step1.body" = "Joint %i1 if needed. Chop %i3 and %i4, slice %i5, cut %i6 into chunks, chop %i7, and prepare %i11.";
"recipe.mt_stuffat_tal_fenek.step1.title" = "Prepare the ingredients";
"recipe.mt_stuffat_tal_fenek.step2.body" = "Place the rabbit in a bowl with %i2, onion, garlic, %i10, and marjoram and leave it to marinate so the meat takes on the flavor.";
"recipe.mt_stuffat_tal_fenek.step2.title" = "Marinate the rabbit";
"recipe.mt_stuffat_tal_fenek.step3.body" = "Lift the rabbit from the marinade and reserve the marinade. Heat %i9 in the pot and brown the rabbit pieces well on all sides.";
"recipe.mt_stuffat_tal_fenek.step3.title" = "Brown the rabbit";
"recipe.mt_stuffat_tal_fenek.step4.body" = "Add the reserved onion and garlic from the marinade, then add the carrot, tomatoes, %i8, the reserved wine marinade, %i12, %i13, and %i14.";
"recipe.mt_stuffat_tal_fenek.step4.title" = "Build the stew";
"recipe.mt_stuffat_tal_fenek.step5.body" = "Cover the pot and simmer gently until the rabbit starts to become tender and the sauce is rich.";
"recipe.mt_stuffat_tal_fenek.step5.title" = "Simmer the stew";
"recipe.mt_stuffat_tal_fenek.step6.body" = "Add the potatoes to the pot and continue cooking until the rabbit is fully tender and the potatoes are cooked through.";
"recipe.mt_stuffat_tal_fenek.step6.title" = "Finish with potatoes";
"recipe.mt_stuffat_tal_fenek.step7.body" = "Boil %i15 until tender, drain them, and toss them with %i16 and %i17.";
"recipe.mt_stuffat_tal_fenek.step7.title" = "Cook the peas";
"recipe.mt_stuffat_tal_fenek.step8.body" = "Serve the rabbit stew hot with the peas and %i18 alongside so the sauce can be soaked up at the table.";
"recipe.mt_stuffat_tal_fenek.step8.title" = "Serve";
