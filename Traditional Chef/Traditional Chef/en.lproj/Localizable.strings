"recipe.tn_ojja.drink.body" = "A fruity, low-tannin red such as Grenache works with harissa heat and sausage richness. For a non-alcoholic option, serve hot Tunisian mint tea or sparkling water with lemon.";
"recipe.tn_ojja.drink.summary" = "Red wine (Grenache)";
"recipe.tn_ojja.info" = "Ojja is a traditional Tunisian skillet of peppers and tomatoes simmered with harissa and merguez sausage, then finished by poaching eggs directly in the bubbling sauce, served hot with Tunisian bread to scoop up the rich, spicy juices.";
"recipe.tn_ojja.info.summary" = "Harissa egg skillet";
"recipe.tn_ojja.name" = "Ojja merguez";
"recipe.tn_ojja.step1.body" = "Slice the %i3, crush the %i4, chop the %i5, and cut the %i6 into strips. Cut the %i1 into shorter lengths if needed.";
"recipe.tn_ojja.step1.title" = "Prep ingredients";
"recipe.tn_ojja.step2.body" = "Heat %i2 in a skillet and brown the merguez well, turning so it colors evenly, then push it to the side.";
"recipe.tn_ojja.step2.title" = "Brown the merguez";
"recipe.tn_ojja.step3.body" = "Add onion and cook until softened, then add garlic and bell pepper and cook until the pepper begins to soften.";
"recipe.tn_ojja.step3.title" = "Cook aromatics and peppers";
"recipe.tn_ojja.step4.body" = "Stir in %i7 and %i8, cook briefly, then add tomatoes and %i13 and simmer until the sauce thickens and turns glossy.";
"recipe.tn_ojja.step4.title" = "Build the spicy tomato sauce";
"recipe.tn_ojja.step5.body" = "Season the sauce with %i9 and %i10, spread it evenly, and make four shallow wells between the merguez pieces.";
"recipe.tn_ojja.step5.title" = "Make wells for eggs";
"recipe.tn_ojja.step6.body" = "Crack an %i11 into each well, cover, and cook until the whites are set and the yolks are still soft.";
"recipe.tn_ojja.step6.title" = "Poach the eggs";
"recipe.tn_ojja.step7.body" = "Serve immediately with %i12 for scooping up sauce, sausage, and egg.";
"recipe.tn_ojja.step7.title" = "Serve";
