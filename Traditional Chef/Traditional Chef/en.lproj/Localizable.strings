"recipe.pl_sledz_w_smietanie.drink.body" = "Pair with a crisp dry white such as Riesling or Grüner Veltliner to match the briny herring and tangy cream. A clean pilsner-style lager also works well with this chilled starter. Non-alcoholic option: sparkling water with lemon or unsweetened black tea.";
"recipe.pl_sledz_w_smietanie.drink.summary" = "White wine (Riesling)";
"recipe.pl_sledz_w_smietanie.info" = "Śledź w śmietanie is a classic Polish cold starter of salted herring fillets softened by soaking, then dressed in a thick sour-cream sauce with onion and apple. It is prepared ahead so the flavors meld into a tangy, gently sweet, briny salad and is commonly served chilled as part of festive spreads and family gatherings, traditionally with boiled potatoes.";
"recipe.pl_sledz_w_smietanie.info.summary" = "Creamy herring salad";
"recipe.pl_sledz_w_smietanie.name" = "Herring in sour cream";
"recipe.pl_sledz_w_smietanie.step1.body" = "Rinse the %i1, cover with %i2, and leave to soak so the salinity softens. Drain well and pat dry.";
"recipe.pl_sledz_w_smietanie.step1.title" = "Soak the herring";
"recipe.pl_sledz_w_smietanie.step2.body" = "Continue soaking until the herring tastes pleasantly briny rather than harsh, changing the water if needed, then drain thoroughly.";
"recipe.pl_sledz_w_smietanie.step2.title" = "Finish soaking";
"recipe.pl_sledz_w_smietanie.step3.body" = "Peel the %i10, cut into even pieces, cover with %i11, add %i12, and bring to a gentle boil.";
"recipe.pl_sledz_w_smietanie.step3.title" = "Prepare potatoes";
"recipe.pl_sledz_w_smietanie.step4.body" = "Simmer until the potatoes are tender, then drain and let them steam dry. Cool them for serving.";
"recipe.pl_sledz_w_smietanie.step4.title" = "Cook potatoes until tender";
"recipe.pl_sledz_w_smietanie.step5.body" = "Slice %i4 thinly. Peel and core the %i5 and cut them into small pieces.";
"recipe.pl_sledz_w_smietanie.step5.title" = "Prep onion and apple";
"recipe.pl_sledz_w_smietanie.step6.body" = "Mix %i3 with %i8, %i6, %i7, and chopped %i9 until smooth and well balanced.";
"recipe.pl_sledz_w_smietanie.step6.title" = "Make the sour-cream dressing";
"recipe.pl_sledz_w_smietanie.step7.body" = "Cut the herring into bite-size pieces and mix with onion and apple. Fold through the sour-cream dressing and transfer to a serving dish.";
"recipe.pl_sledz_w_smietanie.step7.title" = "Combine and arrange";
"recipe.pl_sledz_w_smietanie.step8.body" = "Cover and refrigerate so the onion softens and the flavors fully combine.";
"recipe.pl_sledz_w_smietanie.step8.title" = "Chill to meld flavors";
"recipe.pl_sledz_w_smietanie.step9.body" = "Serve chilled with boiled potatoes alongside.";
"recipe.pl_sledz_w_smietanie.step9.title" = "Serve";
