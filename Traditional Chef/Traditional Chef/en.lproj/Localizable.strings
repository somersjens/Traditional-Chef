"recipe.id_kolak_pisang.info" = "Kolak pisang is a traditional Indonesian dessert of bananas simmered in coconut milk with palm sugar and pandan until fragrant and silky. It is commonly served warm for iftar during Ramadan and also enjoyed as an everyday sweet snack or dessert.";
