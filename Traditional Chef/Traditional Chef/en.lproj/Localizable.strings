"recipe.jm_toto.drink.body" = "Pair with a lightly sweet Madeira or tawny Port to match the coconut and spice. For a non-alcoholic option, serve ginger tea or strong black tea.";
"recipe.jm_toto.drink.summary" = "Dessert wine (Madeira)";
"recipe.jm_toto.info" = "Jamaican toto is a traditional coconut cake made with grated coconut, warm spices, and a simple batter that bakes up moist and dense. It is commonly served in squares at home gatherings and as a nostalgic treat, enjoyed at room temperature with tea or a cold drink.";
"recipe.jm_toto.info.summary" = "Coconut spice cake";
"recipe.jm_toto.name" = "Toto";
"recipe.jm_toto.step1.body" = "Heat the oven and grease the baking pan so the cake releases cleanly.";
"recipe.jm_toto.step1.title" = "Prepare for baking";
