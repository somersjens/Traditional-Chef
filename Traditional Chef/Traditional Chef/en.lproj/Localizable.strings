"recipe.rs_sarma.drink.body" = "A light to medium-bodied red wine such as Pinot Noir pairs well with the rich filling and smoked meat without overwhelming the sour cabbage. A pale lager also works well. For a non-alcoholic option, serve sparkling water or plain yogurt.";
"recipe.rs_sarma.drink.summary" = "Red wine (Pinot Noir)";
"recipe.rs_sarma.info" = "Sarma is a traditional Serbian winter dish of fermented cabbage leaves filled with minced pork, beef, rice, onion, and garlic, then slowly cooked with smoked meat and shredded sour cabbage until deeply savory and tender. It is served hot for family meals, slavas, and festive cold-weather gatherings, usually with bread.";
"recipe.rs_sarma.info.summary" = "Serbian sour cabbage rolls";
"recipe.rs_sarma.name" = "Sarma";
"recipe.rs_sarma.step1.body" = "Separate %i1 carefully and trim the thick stems so they can be rolled easily. Slice the remaining cabbage finely for layering in the pot.";
"recipe.rs_sarma.step1.title" = "Prepare the cabbage";
"recipe.rs_sarma.step2.body" = "Heat %i7 in the skillet and cook %i5 until softened, then add %i6 and half of %i8 and cook briefly until fragrant.";
"recipe.rs_sarma.step2.title" = "Make the filling base";
"recipe.rs_sarma.step3.body" = "Combine the cooked onion mixture with %i2, %i3, %i4, part of %i9, and %i10. Mix well until the filling is evenly combined.";
"recipe.rs_sarma.step3.title" = "Mix the filling";
"recipe.rs_sarma.step4.body" = "Place filling on each cabbage leaf and roll tightly, folding in the sides to enclose the filling completely.";
"recipe.rs_sarma.step4.title" = "Roll the sarma";
"recipe.rs_sarma.step5.body" = "Spread some %i13 on the bottom of the pot, then add part of %i12 and %i11. Arrange the sarma snugly in layers, adding more shredded sauerkraut, smoked meat, %i14, and the remaining paprika between the layers.";
"recipe.rs_sarma.step5.title" = "Layer the pot";
"recipe.rs_sarma.step6.body" = "Pour in %i15 until the sarma is just covered, then bring gently to a simmer. Cover and cook slowly until the cabbage is very tender, the rice is fully cooked, and the smoked meat flavors the whole pot.";
"recipe.rs_sarma.step6.title" = "Simmer slowly";
"recipe.rs_sarma.step7.body" = "Turn off the heat and let the sarma rest in the pot so the flavors settle and the rolls hold their shape better for serving.";
"recipe.rs_sarma.step7.title" = "Rest the sarma";
"recipe.rs_sarma.step8.body" = "Serve the sarma hot with some of the shredded cabbage and smoked meat from the pot, with %i16 alongside.";
"recipe.rs_sarma.step8.title" = "Serve traditionally";
