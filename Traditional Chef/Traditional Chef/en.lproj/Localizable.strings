"recipe.hu_hortobagyi_palacsinta.drink.body" = "Pair with a crisp dry white such as Olaszrizling to balance paprika and rich sauce, or a light lager alongside. For a non-alcoholic option, serve sparkling water or a chilled apple spritz.";
"recipe.hu_hortobagyi_palacsinta.drink.summary" = "White wine (Olaszrizling)";
"recipe.hu_hortobagyi_palacsinta.info" = "Hortobágyi palacsinta are traditional Hungarian savory crêpes filled with minced meat stewed with onions and paprika, then folded, covered in a rich paprika sauce, and baked briefly until hot and cohesive. They are served as a hearty main, with the soft crêpes soaking up the peppery sauce.";
"recipe.hu_hortobagyi_palacsinta.info.summary" = "Savory paprika crêpes";
"recipe.hu_hortobagyi_palacsinta.name" = "Hortobágyi pancakes";
"recipe.hu_hortobagyi_palacsinta.step1.body" = "Whisk %i1 and %i5, whisk in %i2, then add %i3 and %i4 gradually until smooth. Melt %i6 and whisk it into the batter.";
"recipe.hu_hortobagyi_palacsinta.step1.title" = "Make the crêpe batter";
"recipe.hu_hortobagyi_palacsinta.step2.body" = "Let the batter rest so it cooks into tender crêpes.";
"recipe.hu_hortobagyi_palacsinta.step2.title" = "Rest the batter";
"recipe.hu_hortobagyi_palacsinta.step3.body" = "Cook thin crêpes in a lightly greased pan, stacking them as they cook so they stay pliable.";
"recipe.hu_hortobagyi_palacsinta.step3.title" = "Cook the crêpes";
"recipe.hu_hortobagyi_palacsinta.step4.body" = "Cook %i8 in %i9 until soft, stir in %i10 off the heat, then add %i7 and cook until no longer pink. Add %i11, %i12, and %i13 and simmer until thick.";
"recipe.hu_hortobagyi_palacsinta.step4.title" = "Cook the filling";
"recipe.hu_hortobagyi_palacsinta.step5.body" = "Melt %i14 in a saucepan, stir in %i16 to make a pale roux, then take it off the heat and stir in %i15.";
"recipe.hu_hortobagyi_palacsinta.step5.title" = "Start the paprika sauce";
"recipe.hu_hortobagyi_palacsinta.step6.body" = "Whisk in %i17 gradually and simmer until smooth and thickened, then whisk in %i18 off the heat so it stays smooth.";
"recipe.hu_hortobagyi_palacsinta.step6.title" = "Finish the sauce";
"recipe.hu_hortobagyi_palacsinta.step7.body" = "Fill each crêpe with the meat mixture, fold into neat parcels, and arrange them in a buttered baking dish.";
"recipe.hu_hortobagyi_palacsinta.step7.title" = "Fill and fold";
"recipe.hu_hortobagyi_palacsinta.step8.body" = "Pour the paprika sauce over the crêpes and bake until hot throughout and cohesive.";
"recipe.hu_hortobagyi_palacsinta.step8.title" = "Sauce and bake";
"recipe.hu_hortobagyi_palacsinta.step9.body" = "Serve immediately while hot, with extra sauce spooned over.";
"recipe.hu_hortobagyi_palacsinta.step9.title" = "Serve the crêpes";
