"recipe.pl_bigos.drink.body" = "Pair with a dry, medium-bodied red such as Pinot Noir that won’t overpower the cabbage and smoke. A malty amber lager also suits the stew’s smoky depth. Non-alcoholic option: unsweetened black tea or sparkling water with lemon.";
"recipe.pl_bigos.drink.summary" = "Red wine (Pinot Noir)";
"recipe.pl_bigos.info" = "Bigos is Poland’s iconic long-simmered stew of sauerkraut and fresh cabbage cooked with a mix of smoked and fresh meats, dried mushrooms, prunes, and warming spices. Traditionally it is cooked slowly, then cooled and reheated so the flavors deepen into a rich, tangy, smoky, slightly sweet stew served piping hot, most often with hearty rye bread.";
"recipe.pl_bigos.info.summary" = "Long-simmered cabbage stew";
"recipe.pl_bigos.name" = "Hunter's stew";
"recipe.pl_bigos.step1.body" = "Cover the %i6 with boiling %i9 and leave until softened. Strain, reserving the soaking liquid, then chop the mushrooms.";
"recipe.pl_bigos.step1.title" = "Soak the mushrooms";
"recipe.pl_bigos.step10.body" = "Simmer until the cabbage is very tender and the stew is deeply flavored. Taste and adjust %i18 and pepper so it is tangy, smoky, and well-seasoned.";
"recipe.pl_bigos.step10.title" = "Finish the cook and balance";
"recipe.pl_bigos.step11.body" = "Cool the stew, cover, and refrigerate overnight so the flavors meld and deepen.";
"recipe.pl_bigos.step11.title" = "Chill overnight";
"recipe.pl_bigos.step12.body" = "Reheat the bigos slowly over low heat, stirring occasionally until piping hot and glossy. Serve hot with %i20.";
"recipe.pl_bigos.step12.title" = "Reheat to serve";
"recipe.pl_bigos.step2.body" = "Shred the %i2. If the %i1 strands are long, chop them into shorter pieces and keep any sauerkraut juices for the pot.";
"recipe.pl_bigos.step2.title" = "Prepare the cabbage and sauerkraut";
"recipe.pl_bigos.step3.body" = "Heat the pot and render the %i4 until it releases fat and starts to brown. Add the %i3 and brown well, stirring so it colors on all sides.";
"recipe.pl_bigos.step3.title" = "Brown bacon and pork";
"recipe.pl_bigos.step4.body" = "Add %i7 to the pot and cook until softened and lightly golden. Add %i8 and cook briefly until fragrant.";
"recipe.pl_bigos.step4.title" = "Cook onions and garlic";
"recipe.pl_bigos.step5.body" = "Stir in the fresh cabbage and let it begin to wilt. Add the sauerkraut and mix thoroughly so the meats and cabbage are evenly combined.";
"recipe.pl_bigos.step5.title" = "Add cabbage and sauerkraut";
"recipe.pl_bigos.step6.body" = "Stir in %i11 until it coats the mixture. Pour in %i10 and let it simmer to cook off harshness, then add %i9 and the reserved mushroom liquid.";
"recipe.pl_bigos.step6.title" = "Build the stew liquid";
"recipe.pl_bigos.step7.body" = "Add %i14, %i15, %i16, chopped mushrooms, %i12, %i13, and %i17. Bring just to a gentle simmer.";
"recipe.pl_bigos.step7.title" = "Season and start simmering";
"recipe.pl_bigos.step8.body" = "Cover partially and simmer very gently, stirring from time to time so it does not catch. Keep the mixture moist with stock if needed, aiming for a thick stew rather than soup.";
"recipe.pl_bigos.step8.title" = "Slow-simmer until rich";
"recipe.pl_bigos.step9.body" = "Slice the %i5 and stir it into the stew. Continue simmering gently so the sausage flavors the pot without drying it out.";
"recipe.pl_bigos.step9.title" = "Add kielbasa";
