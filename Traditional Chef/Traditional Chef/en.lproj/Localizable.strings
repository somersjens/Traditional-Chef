"recipe.ma_tagine_chicken_preserved_lemon_olives.step2.body" = "Leave the dough covered in a warm spot until clearly risen and airy.";
"recipe.ma_tagine_chicken_preserved_lemon_olives.step2.title" = "Rise the dough";
"recipe.ma_tagine_chicken_preserved_lemon_olives.step3.body" = "Slice the %i2, mince the %i3, and chop the %i11 and %i12. Rinse the %i14, and rinse the %i13 and remove the pulp, keeping the peel for slicing.";
"recipe.ma_tagine_chicken_preserved_lemon_olives.step3.title" = "Prep tagine ingredients";
