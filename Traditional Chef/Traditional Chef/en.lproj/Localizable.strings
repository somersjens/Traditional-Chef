"recipe.tt_curry_duck.drink.body" = "A juicy, peppery Zinfandel or Grenache stands up to duck and curry spice, while a crisp lager also works well with the heat. For a non-alcoholic option, serve chilled ginger beer or sorrel drink to refresh the palate.";
"recipe.tt_curry_duck.drink.summary" = "Red wine (Zinfandel)";
"recipe.tt_curry_duck.info" = "Trinidad curry duck is a bold, celebratory dish where duck pieces are washed with citrus, seasoned with green seasoning and spices, then cooked in a properly “burnt” curry base until rich and tender. It’s commonly served for gatherings and weekend meals, with potatoes simmered in the gravy and soft roti on the side to scoop up the sauce.";
"recipe.tt_curry_duck.info.summary" = "Duck curry with roti";
"recipe.tt_curry_duck.name" = "Curry duck";
"recipe.tt_curry_duck.step1.body" = "Rinse %i1, rub with %i2 and %i3, then rinse again and pat dry. Trim excess surface fat but keep enough for flavor.";
"recipe.tt_curry_duck.step1.title" = "Wash and prep duck";
"recipe.tt_curry_duck.step10.body" = "Add the seasoned duck and stir to coat thoroughly in the curry base. Cook, turning pieces, until the duck releases some juices and begins to brown lightly.";
"recipe.tt_curry_duck.step10.title" = "Coat and seal the duck";
"recipe.tt_curry_duck.step11.body" = "Add %i17, %i11, %i12, %i10, and %i13. Bring to a steady simmer, cover, and cook until the duck is tender and the gravy starts to thicken.";
"recipe.tt_curry_duck.step11.title" = "Simmer until tender";
"recipe.tt_curry_duck.step12.body" = "Add %i18 and continue simmering until the potatoes are cooked through and the sauce is glossy and well reduced.";
"recipe.tt_curry_duck.step12.title" = "Cook potatoes in the curry";
"recipe.tt_curry_duck.step13.body" = "Stir in %i6 and simmer briefly so it blends into the gravy. Taste and adjust seasoning if needed.";
"recipe.tt_curry_duck.step13.title" = "Finish with amchar";
"recipe.tt_curry_duck.step14.body" = "Heat the tawa. Roll each rested coil into a round and cook on the hot surface, flipping until set and lightly browned. Brush with a little oil as needed for pliability.";
"recipe.tt_curry_duck.step14.title" = "Roll and cook roti";
"recipe.tt_curry_duck.step15.body" = "Stack the hot roti and clap to separate the layers. Serve curry duck with potatoes alongside the roti, spooning plenty of gravy over the plate.";
"recipe.tt_curry_duck.step15.title" = "Clap roti and serve";
"recipe.tt_curry_duck.step2.body" = "Toss the duck with %i7, part of %i4, %i5, %i14, and %i15. Let it sit while you prepare the curry base ingredients.";
"recipe.tt_curry_duck.step2.title" = "Season the duck";
"recipe.tt_curry_duck.step3.body" = "Combine %i19, %i20, %i21, and %i22 in a bowl and mix evenly.";
"recipe.tt_curry_duck.step3.title" = "Mix roti dry ingredients";
"recipe.tt_curry_duck.step4.body" = "Add %i23 gradually and knead to a smooth, soft dough that is not sticky. Cover the dough to prevent drying.";
"recipe.tt_curry_duck.step4.title" = "Knead roti dough";
"recipe.tt_curry_duck.step5.body" = "Let the dough rest so it relaxes and becomes easier to roll.";
"recipe.tt_curry_duck.step5.title" = "Rest the roti dough";
"recipe.tt_curry_duck.step6.body" = "Divide the dough into equal balls. Lightly coat each with a little %i25 so they stay supple.";
"recipe.tt_curry_duck.step6.title" = "Prepare roti portions";
"recipe.tt_curry_duck.step7.body" = "Roll one dough ball into a thin round, spread with %i24, fold and roll into a tight coil, then tuck the end underneath. Repeat for all portions and keep covered.";
"recipe.tt_curry_duck.step7.title" = "Layer the roti with ghee";
"recipe.tt_curry_duck.step8.body" = "Let the coiled portions rest so they roll without shrinking.";
"recipe.tt_curry_duck.step8.title" = "Rest layered roti";
"recipe.tt_curry_duck.step9.body" = "Heat %i16 in a heavy pot over medium heat. Add %i8 and cook until softened, then add %i9 and cook briefly. Stir in the remaining curry powder and cook until fragrant and slightly darkened.";
"recipe.tt_curry_duck.step9.title" = "Heat oil and bloom curry";
