"recipe.ge_pelamushi.drink.body" = "A small glass of Georgian semi-sweet red wine can accompany pelamushi at festive tables. For a non-alcoholic option, serve chilled sparkling water or unsweetened black tea.";
"recipe.ge_pelamushi.drink.summary" = "Semi-sweet red wine";
"recipe.ge_pelamushi.info" = "Pelamushi is a traditional Georgian dessert made by cooking grape juice with flour into a smooth, glossy pudding. It is especially associated with the grape harvest season and is commonly served chilled in bowls, often garnished with walnuts.";
"recipe.ge_pelamushi.info.summary" = "Grape harvest pudding";
"recipe.ge_pelamushi.name" = "Pelamushi";
"recipe.ge_pelamushi.step1.body" = "Pour most of the %i1 into a saucepan. In a bowl, whisk the %i2 with the remaining grape juice until completely smooth and free of lumps.";
"recipe.ge_pelamushi.step1.title" = "Prepare the base mixture";
"recipe.ge_pelamushi.step2.body" = "Set the saucepan over medium heat and stir in the flour mixture gradually, whisking continuously so the mixture stays smooth.";
"recipe.ge_pelamushi.step2.title" = "Combine in the pan";
"recipe.ge_pelamushi.step3.body" = "Cook the mixture, stirring constantly with a whisk and then a spoon, until it thickens into a smooth pudding and the raw flour taste is gone.";
"recipe.ge_pelamushi.step3.title" = "Cook until thick and glossy";
"recipe.ge_pelamushi.step4.body" = "Pour the hot pelamushi into serving bowls and smooth the tops.";
"recipe.ge_pelamushi.step4.title" = "Portion the dessert";
"recipe.ge_pelamushi.step5.body" = "Let the bowls cool, then refrigerate until the pelamushi is fully set and chilled.";
"recipe.ge_pelamushi.step5.title" = "Chill and set";
"recipe.ge_pelamushi.step6.body" = "Top with %i3 and serve chilled.";
"recipe.ge_pelamushi.step6.title" = "Garnish and serve";
