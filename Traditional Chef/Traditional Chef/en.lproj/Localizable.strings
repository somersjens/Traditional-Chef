"recipe.ru_vinegret.drink.body" = "A crisp dry white or light sparkling wine pairs well with the tangy pickles and earthy beets, though tea is also common at the table. Non-alcoholic pairing: sparkling water with lemon or hot black tea.";
"recipe.ru_vinegret.drink.summary" = "White wine";
"recipe.ru_vinegret.info" = "Vinegret is a traditional Russian beet salad made from diced boiled beets, potatoes, and carrots mixed with pickles, sauerkraut, and onions, then dressed simply with sunflower oil. It is served cold as a classic zakuska, often prepared ahead so the flavors meld and the vegetables take on a deep rosy color.";
"recipe.ru_vinegret.info.summary" = "Rosy beet salad";
"recipe.ru_vinegret.name" = "Vinegret salad";
"recipe.ru_vinegret.step1.body" = "Cook %i1, %i2, and %i3 in %i10 until tender. Drain and let them cool completely.";
"recipe.ru_vinegret.step1.title" = "Boil the vegetables";
"recipe.ru_vinegret.step2.body" = "Dice %i4 and finely chop %i6. Squeeze excess liquid from %i5.";
"recipe.ru_vinegret.step2.title" = "Prep pickles and onion";
"recipe.ru_vinegret.step3.body" = "Peel the cooled vegetables and dice them into small even cubes.";
"recipe.ru_vinegret.step3.title" = "Peel and dice";
"recipe.ru_vinegret.step4.body" = "Combine vegetables, pickles, sauerkraut, and onion in a bowl. Season with %i8 and %i9 and toss with %i7 until evenly coated.";
"recipe.ru_vinegret.step4.title" = "Dress the salad";
"recipe.ru_vinegret.step5.body" = "Refrigerate until well chilled and the flavors are melded, then serve cold.";
"recipe.ru_vinegret.step5.title" = "Chill";
