"recipe.dz_tamina.drink.body" = "A floral dessert wine like Muscat complements the honeyed sweetness and toasted semolina aromas. If you prefer something less sweet, a light sparkling wine can brighten the rich butter and honey. Non-alcoholic pairing: hot mint tea or black coffee.";
"recipe.dz_tamina.drink.summary" = "Dessert wine (Muscat)";
"recipe.dz_tamina.info" = "Tamina is a traditional Algerian sweet made by toasting semolina until nutty, then stirring in butter and honey to form a smooth, rich paste often finished with cinnamon. It is commonly prepared for celebrations and family occasions, served in small portions at room temperature with mint tea.";
"recipe.dz_tamina.info.summary" = "Semolina honey paste";
"recipe.dz_tamina.name" = "Tamina";
"recipe.dz_tamina.step1.body" = "Toast the %i1 in a heavy skillet over medium-low heat, stirring constantly, until it turns evenly golden and smells nutty.";
"recipe.dz_tamina.step1.title" = "Toast the semolina";
"recipe.dz_tamina.step2.body" = "Gently warm the %i2 with %i3 until the butter melts and the mixture is fluid.";
"recipe.dz_tamina.step2.title" = "Warm honey and butter";
"recipe.dz_tamina.step3.body" = "Pour the warm honey-butter mixture into the toasted semolina and stir continuously until smooth, glossy, and thick.";
"recipe.dz_tamina.step3.title" = "Combine into a paste";
"recipe.dz_tamina.step4.body" = "Stir in %i4, spread the tamina into a shallow dish, smooth the surface, and let it cool before serving.";
"recipe.dz_tamina.step4.title" = "Finish and plate";
"recipe.dz_tamina.tool.t1" = "Heavy skillet";
