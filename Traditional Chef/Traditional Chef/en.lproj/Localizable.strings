"recipe.tr_haydari.drink.body" = "A crisp Sauvignon Blanc or a dry Riesling cuts through the rich yogurt and herbs and refreshes the palate. For a non-alcoholic option, serve chilled ayran or sparkling water with lemon.";
"recipe.tr_haydari.drink.summary" = "White wine (Sauvignon)";
"recipe.tr_haydari.info" = "Haydari is a traditional Turkish meze of very thick strained yogurt mixed with garlic, dill, mint, and olive oil, often enriched with crumbly white cheese for body and saltiness. It is served chilled as part of a rakı table or mezze spread, meant to be scooped with bread alongside other small plates.";
"recipe.tr_haydari.info.summary" = "Thick herb yogurt";
"recipe.tr_haydari.name" = "Haydari";
