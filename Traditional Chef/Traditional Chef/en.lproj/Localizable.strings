"recipe.hu_libamaj.drink.body" = "Pair with Tokaji Aszú or a late-harvest Tokaji whose sweetness and acidity match the richness of the liver and the apples. A crisp dry white can also work if you prefer less sweetness. For a non-alcoholic option, serve sparkling water or a chilled apple spritz.";
"recipe.hu_libamaj.drink.summary" = "Tokaji Aszú";
"recipe.hu_libamaj.info" = "Libamáj is a classic Hungarian delicacy: fresh goose liver is gently soaked, dried, then quickly pan-seared in hot goose fat so it stays creamy inside with a browned crust. It is traditionally served immediately with sautéed apples and onions and toasted bread, balancing rich liver with sweetness and crunch.";
"recipe.hu_libamaj.info.summary" = "Seared goose liver";
"recipe.hu_libamaj.name" = "Pan-seared foie gras";
"recipe.hu_libamaj.step1.body" = "Cover %i1 with %i2 and let it soak so it mellows, then drain it.";
