"recipe.us_tx_pecan_pie.drink.body" = "A tawny port or a strong stout pairs with the caramelized pecans and buttery crust. For a non-alcoholic option, serve black coffee or unsweetened tea to cut the sweetness and highlight the toasted nuts.";
"recipe.us_tx_pecan_pie.drink.summary" = "Tawny Port";
"recipe.us_tx_pecan_pie.info" = "Texas pecan pie is a Southern pie classic strongly associated with Texas pecans: a flaky pastry crust filled with toasted pecans suspended in a rich, gooey custard-syrup filling made from eggs, sugar, butter, and corn syrup. Baked until set at the edges with a slight wobble in the center, it cools into clean slices with a caramel-nut flavor and a glossy top. Traditionally served at room temperature with vanilla ice cream alongside.";
"recipe.us_tx_pecan_pie.info.summary" = "Texas pecan pie";
"recipe.us_tx_pecan_pie.name" = "Pecan pie";
"recipe.us_tx_pecan_pie.step1.body" = "Cut %i2 into %i1 and %i4 until crumbly, then add %i3 and bring together into a cohesive dough without overworking.";
"recipe.us_tx_pecan_pie.step1.title" = "Make the pie dough";
"recipe.us_tx_pecan_pie.step2.body" = "Wrap and refrigerate the dough until firm so it rolls cleanly and bakes flaky.";
"recipe.us_tx_pecan_pie.step2.title" = "Chill the dough";
"recipe.us_tx_pecan_pie.step3.body" = "Roll the chilled dough into a round, fit it into the pie dish, and crimp the edge, then chill briefly so the shape holds.";
"recipe.us_tx_pecan_pie.step3.title" = "Roll and line the pie dish";
"recipe.us_tx_pecan_pie.step4.body" = "Heat the oven and toast %i5 until fragrant, then cool them so they stay crisp in the filling.";
"recipe.us_tx_pecan_pie.step4.title" = "Heat the oven and toast pecans";
"recipe.us_tx_pecan_pie.step5.body" = "Whisk %i6, %i7, %i9, %i8, %i10, and %i11 until smooth and glossy.";
"recipe.us_tx_pecan_pie.step5.title" = "Mix the filling";
"recipe.us_tx_pecan_pie.step6.body" = "Spread pecans evenly in the crust, then pour the filling over so the nuts are coated and mostly submerged.";
"recipe.us_tx_pecan_pie.step6.title" = "Fill the pie";
"recipe.us_tx_pecan_pie.step7.body" = "Bake on a baking sheet until the edges are set and the center still has a slight wobble, with the top deeply browned.";
"recipe.us_tx_pecan_pie.step7.title" = "Bake until set";
"recipe.us_tx_pecan_pie.step8.body" = "Cool the pie fully on a rack so the filling sets into clean slices.";
"recipe.us_tx_pecan_pie.step8.title" = "Cool completely";
"recipe.us_tx_pecan_pie.step9.body" = "Slice the pie and serve at room temperature with %i12.";
"recipe.us_tx_pecan_pie.step9.title" = "Serve";
