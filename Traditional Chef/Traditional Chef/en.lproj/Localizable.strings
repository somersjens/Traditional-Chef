"recipe.ca_tourtiere.step6.body" = "Spoon the cooled filling into the crust. Roll out the second disc, place it over the filling, trim the excess, and seal the edges. Cut vents in the top.";
"recipe.ca_tourtiere.step6.title" = "Fill and close the pie";
"recipe.ca_tourtiere.step7.body" = "Beat the %i15 with %i16 and brush the top crust evenly.";
"recipe.ca_tourtiere.step7.title" = "Brush the crust";
"recipe.ca_tourtiere.step8.body" = "Bake until the crust is deeply golden and the filling is hot throughout.";
"recipe.ca_tourtiere.step8.title" = "Bake the tourtière";
