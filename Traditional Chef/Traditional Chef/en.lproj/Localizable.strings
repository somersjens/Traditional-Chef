"recipe.hk_typhoon_shelter_crab.drink.body" = "A light lager or crisp dry white pairs well with the rich fried garlic and sweet crab meat without overpowering it. For a non-alcoholic option, serve hot pu-erh tea or warm barley water.";
"recipe.hk_typhoon_shelter_crab.drink.summary" = "Beer (Lager)";
"recipe.hk_typhoon_shelter_crab.info" = "A traditional Hong Kong seafood dish of chopped crab that is lightly coated, deep-fried, and stir-fried with a fragrant blanket of golden garlic, dried chilies, and fermented black beans. It is commonly served hot as a shared centerpiece dish in Cantonese seafood restaurants, especially with plain rice.";
"recipe.hk_typhoon_shelter_crab.info.summary" = "Garlic chili crab";
"recipe.hk_typhoon_shelter_crab.name" = "Typhoon shelter crab";
"recipe.hk_typhoon_shelter_crab.step1.body" = "Clean the %i1, remove the top shells and inedible parts, then chop into large pieces with the claws cracked for easier eating.";
"recipe.hk_typhoon_shelter_crab.step1.title" = "Prepare and chop the crab";
"recipe.hk_typhoon_shelter_crab.step10.body" = "Pile the crab onto a large platter with all the crispy garlic on top and serve immediately with %i14.";
"recipe.hk_typhoon_shelter_crab.step10.title" = "Plate and serve";
"recipe.hk_typhoon_shelter_crab.step2.body" = "Toss the crab pieces with %i2, %i3, and %i4, then let them stand briefly to remove raw smell and season lightly.";
"recipe.hk_typhoon_shelter_crab.step2.title" = "Season the crab";
"recipe.hk_typhoon_shelter_crab.step3.body" = "Finely chop the %i6, cut the %i7 into short pieces, rinse and roughly chop the %i8, and slice the %i9.";
"recipe.hk_typhoon_shelter_crab.step3.title" = "Prepare the aromatics";
"recipe.hk_typhoon_shelter_crab.step4.body" = "Drain off excess liquid from the crab and coat the pieces evenly with %i5 for a light crust.";
"recipe.hk_typhoon_shelter_crab.step4.title" = "Coat the crab";
"recipe.hk_typhoon_shelter_crab.step5.body" = "Heat most of the %i13 in a wok and deep-fry the crab pieces in batches until the shells turn bright and the coating is set, then lift out to drain.";
"recipe.hk_typhoon_shelter_crab.step5.title" = "Deep-fry the crab";
"recipe.hk_typhoon_shelter_crab.step6.body" = "Pour off some oil, leaving enough in the wok, then fry the garlic over medium-low heat until pale golden, add dried chilies and fermented black beans, and cook until fragrant.";
"recipe.hk_typhoon_shelter_crab.step6.title" = "Fry the garlic and chilies";
"recipe.hk_typhoon_shelter_crab.step7.body" = "Stir in %i10 and %i11 and keep tossing until the garlic becomes evenly golden and crisp but not bitter.";
"recipe.hk_typhoon_shelter_crab.step7.title" = "Season the aromatic mix";
"recipe.hk_typhoon_shelter_crab.step8.body" = "Add the fried crab back to the wok and toss thoroughly so the garlic-chili mixture coats every piece.";
"recipe.hk_typhoon_shelter_crab.step8.title" = "Return crab to the wok";
"recipe.hk_typhoon_shelter_crab.step9.body" = "Add the spring onion and %i12 and toss briefly just until aromatic.";
"recipe.hk_typhoon_shelter_crab.step9.title" = "Finish with spring onion and sesame oil";
"recipe.hk_typhoon_shelter_crab.tool.t1" = "Cleaver";
