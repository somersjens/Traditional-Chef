"recipe.kh_pleah_sach_ko.drink.body" = "A dry rosé or a light aromatic white such as Riesling pairs well with the bright lime dressing and herbs. A crisp lager also matches the salad. For a non-alcoholic option, serve iced jasmine tea or chilled soda water with lime.";
"recipe.kh_pleah_sach_ko.drink.summary" = "Rosé wine";
"recipe.kh_pleah_sach_ko.info" = "Pleah sach ko is a traditional Cambodian beef salad made with thinly sliced beef dressed with lime, fish sauce, palm sugar, lemongrass, herbs, and aromatics. It is commonly served as a starter or shared dish with fresh vegetables, balancing sour, salty, savory, and fragrant flavors.";
"recipe.kh_pleah_sach_ko.info.summary" = "Lime beef salad";
"recipe.kh_pleah_sach_ko.name" = "Pleah sach ko";
"recipe.kh_pleah_sach_ko.step1.body" = "Trim and finely slice the tender part of the %i5, thinly slice the %i6 and %i8, mince the %i7, and finely shred the %i9. Pick the %i11 and %i12, slice the %i13, and arrange the %i15 and %i14 for serving.";
"recipe.kh_pleah_sach_ko.step1.title" = "Prepare aromatics and herbs";
"recipe.kh_pleah_sach_ko.step2.body" = "Slice the %i1 very thinly across the grain and keep it ready for blanching.";
