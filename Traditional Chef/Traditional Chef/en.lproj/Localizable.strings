"recipe.ru_golubtsy.drink.body" = "A light, juicy red such as Gamay or Pinot Noir pairs well with the tangy tomato-sour cream sauce and savory meat filling. A crisp dry white also works if you prefer. Non-alcoholic pairing: black tea with lemon or sparkling water.";
"recipe.ru_golubtsy.drink.summary" = "Red wine (Gamay)";
"recipe.ru_golubtsy.info" = "Golubtsy are traditional Russian cabbage rolls made with tender cabbage leaves wrapped around a savory filling of minced meat and rice, then gently braised until succulent in a tomato and sour-cream sauce. They are served hot with extra sour cream, making a comforting home-style main course often prepared for family meals.";
"recipe.ru_golubtsy.info.summary" = "Russian cabbage rolls";
"recipe.ru_golubtsy.name" = "Stuffed cabbage rolls";
"recipe.ru_golubtsy.step1.body" = "Trim the %i7 core so leaves can loosen. Bring %i14 to a gentle boil in a large pot.";
"recipe.ru_golubtsy.step1.title" = "Prepare the cabbage";
"recipe.ru_golubtsy.step2.body" = "Lower the cabbage into the pot and simmer until outer leaves soften. Use tongs to peel off softened leaves as they loosen, then drain and cool the leaves.";
"recipe.ru_golubtsy.step2.title" = "Soften cabbage leaves";
"recipe.ru_golubtsy.step3.body" = "Rinse the %i3 and simmer it in %i14 until tender. Drain if needed and let it cool so it does not overcook the filling.";
"recipe.ru_golubtsy.step3.title" = "Cook the rice";
"recipe.ru_golubtsy.step4.body" = "Finely chop %i4, grate %i5, and mince %i6. Heat %i11 in a skillet and cook onion and carrot until softened, then stir in garlic briefly and cool.";
"recipe.ru_golubtsy.step4.title" = "Cook the aromatics";
"recipe.ru_golubtsy.step5.body" = "In a bowl, combine %i1 and %i2 with the cooked rice and the cooled vegetables. Season with %i12 and %i13 and mix until cohesive.";
"recipe.ru_golubtsy.step5.title" = "Make the filling";
"recipe.ru_golubtsy.step6.body" = "Trim thick ribs from cabbage leaves as needed so they fold easily. Place filling on each leaf, roll tightly, and tuck in the sides to seal.";
"recipe.ru_golubtsy.step6.title" = "Form the rolls";
"recipe.ru_golubtsy.step7.body" = "Combine %i8 and %i9 with %i10, then loosen with water until it becomes a pourable sauce. Season lightly.";
"recipe.ru_golubtsy.step7.title" = "Mix the sauce";
"recipe.ru_golubtsy.step8.body" = "Arrange the rolls seam-side down in a deep pan. Pour the sauce over, cover, and simmer gently until the cabbage is tender and the filling is cooked through.";
"recipe.ru_golubtsy.step8.title" = "Simmer the golubtsy";
"recipe.ru_golubtsy.step9.body" = "Let the rolls rest briefly in the sauce, then serve hot with sauce spooned over each portion.";
"recipe.ru_golubtsy.step9.title" = "Serve";
