"recipe.tn_kammounia.tool.t5" = "Measuring spoons";
"recipe.tn_kammounia.tool.t6" = "Ladle";
"recipe.tn_kammounia.tool.t7" = "Serving plates";
"recipe.tn_kosksi_bil_osban.drink.body" = "A medium-bodied red such as Grenache pairs well with the warm spices and rich offal, while a non-alcoholic option is hot Tunisian mint tea or sparkling water with lemon.";
"recipe.tn_kosksi_bil_osban.drink.summary" = "Red wine (Grenache)";
"recipe.tn_kosksi_bil_osban.info" = "Kosksi bil Osban is a traditional Tunisian couscous served with osban, sheep intestines stuffed with a rice-and-offal mixture, simmered in a spiced tomato broth with chickpeas and vegetables, then presented on a large platter with steamed couscous topped by osban, meat, vegetables, and ladled sauce.";
"recipe.tn_kosksi_bil_osban.info.summary" = "Stuffed couscous platter";
"recipe.tn_kosksi_bil_osban.name" = "Osban couscous";
"recipe.tn_kosksi_bil_osban.step1.body" = "Rinse the %i3, cover with %i33, and soak until plumped, then drain.";
"recipe.tn_kosksi_bil_osban.step1.title" = "Soak the chickpeas";
"recipe.tn_kosksi_bil_osban.step10.body" = "Steam until the couscous is hot and swells, then return it to the bowl and fluff thoroughly to break up clumps.";
"recipe.tn_kosksi_bil_osban.step10.title" = "First steam";
"recipe.tn_kosksi_bil_osban.step11.body" = "Moisten the couscous lightly with water, rub to separate the grains, and return it to the steamer basket.";
"recipe.tn_kosksi_bil_osban.step11.title" = "Moisten and fluff again";
"recipe.tn_kosksi_bil_osban.step12.body" = "Steam until the couscous is tender and fluffy, then fluff well and season the stew if needed.";
"recipe.tn_kosksi_bil_osban.step12.title" = "Second steam and finish";
"recipe.tn_kosksi_bil_osban.step13.body" = "Mound the couscous on a platter, arrange the lamb, osban, and vegetables on top, then ladle over the sauce and serve hot.";
"recipe.tn_kosksi_bil_osban.step13.title" = "Serve";
"recipe.tn_kosksi_bil_osban.step2.body" = "Rinse the %i10 thoroughly and keep them ready for stuffing.";
"recipe.tn_kosksi_bil_osban.step2.title" = "Prepare the casing";
"recipe.tn_kosksi_bil_osban.step3.body" = "Rinse the %i11, finely chop the %i13 and %i14, then mix the rice, %i12, chopped offal, %i15, %i16, %i17, %i18, %i19, and the %i20, %i21, %i22, %i23, %i24, %i25, and %i26 until evenly combined.";
"recipe.tn_kosksi_bil_osban.step3.title" = "Make the stuffing";
"recipe.tn_kosksi_bil_osban.step4.body" = "Using a funnel, fill the intestines with the stuffing, leaving room for expansion, then tie into secure lengths with twine.";
"recipe.tn_kosksi_bil_osban.step4.title" = "Stuff and tie osban";
"recipe.tn_kosksi_bil_osban.step5.body" = "In the bottom of the couscoussier, warm %i6, soften the %i4, add %i5, then whisk in %i7, %i8, %i9, and the spice mixture until glossy.";
"recipe.tn_kosksi_bil_osban.step5.title" = "Start the stew base";
"recipe.tn_kosksi_bil_osban.step6.body" = "Add %i2 and the soaked chickpeas, pour in water, add %i27, bring to a steady simmer, then add the osban and cook gently until the meat is tender and osban is cooked through.";
"recipe.tn_kosksi_bil_osban.step6.title" = "Simmer meat, chickpeas, and osban";
"recipe.tn_kosksi_bil_osban.step7.body" = "Peel and cut the %i28, %i29, %i30, %i31, and %i32 into large pieces so they hold their shape during simmering.";
"recipe.tn_kosksi_bil_osban.step7.title" = "Prepare the vegetables";
"recipe.tn_kosksi_bil_osban.step8.body" = "Add the carrots, turnips, potatoes, and pumpkin to the stew, simmer until nearly tender, then add the zucchini and simmer until all vegetables are cooked through.";
"recipe.tn_kosksi_bil_osban.step8.title" = "Cook the vegetables";
"recipe.tn_kosksi_bil_osban.step9.body" = "Place the %i1 in a bowl, moisten with water, rub to separate the grains, then transfer to the steamer basket over the simmering stew.";
"recipe.tn_kosksi_bil_osban.step9.title" = "Start steaming the couscous";
