"recipe.bg_tarator.drink.body" = "A crisp white wine such as Sauvignon Blanc or Pinot Grigio pairs well with the cool yogurt, cucumber, and dill. For a non-alcoholic pairing, serve chilled mineral water or ayran.";
"recipe.bg_tarator.drink.summary" = "White wine (Sauvignon)";
"recipe.bg_tarator.info" = "Tarator is a traditional Bulgarian cold soup made with yogurt, cucumber, garlic, dill, walnuts, sunflower oil, and water. It is a classic summer starter and refresher, commonly served well chilled at family meals and casual tables during hot weather.";
"recipe.bg_tarator.info.summary" = "Chilled yogurt soup";
"recipe.bg_tarator.name" = "Tarator";
"recipe.bg_tarator.step1.body" = "Peel %i2 if needed, dice them finely, crush %i3, chop %i4, and chop %i5.";
"recipe.bg_tarator.step1.title" = "Prepare the vegetables";
"recipe.bg_tarator.step2.body" = "Put %i1 in a large bowl and whisk in %i8 until the mixture is smooth and lightly loosened.";
"recipe.bg_tarator.step2.title" = "Thin the yogurt";
"recipe.bg_tarator.step3.body" = "Add the garlic, dill, %i6, and %i7 to the yogurt mixture and stir until evenly combined.";
"recipe.bg_tarator.step3.title" = "Season the soup";
"recipe.bg_tarator.step4.body" = "Stir in the cucumbers and most of the walnuts so they are distributed evenly through the soup.";
"recipe.bg_tarator.step4.title" = "Add the cucumber and walnuts";
"recipe.bg_tarator.step5.body" = "Refrigerate the soup until very cold and the flavors have blended fully.";
"recipe.bg_tarator.step5.title" = "Chill the tarator";
"recipe.bg_tarator.step6.body" = "Stir the tarator, pour it into a serving bowl, scatter the remaining walnuts on top, and serve well chilled.";
"recipe.bg_tarator.step6.title" = "Finish and serve";
