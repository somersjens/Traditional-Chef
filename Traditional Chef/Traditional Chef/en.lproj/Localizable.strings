"recipe.pk_seekh_kebab.drink.body" = "A light to medium red such as Pinot Noir or Grenache pairs well with smoky spiced meat without overpowering it. A crisp lager also works well. Non-alcoholic pairing: salted lassi or hot black tea are both excellent choices.";
"recipe.pk_seekh_kebab.drink.summary" = "Red wine (Pinot Noir)";
"recipe.pk_seekh_kebab.info" = "Seekh Kebab is a traditional Pakistani kebab made from minced meat mixed with onions, herbs, ginger, garlic, and spices, shaped around skewers and cooked over charcoal until smoky and juicy. It is commonly served hot with naan and mint chutney as a shared meal or street-style platter.";
"recipe.pk_seekh_kebab.info.summary" = "Grilled seekh kebabs";
"recipe.pk_seekh_kebab.name" = "Seekh kebab";
"recipe.pk_seekh_kebab.step1.body" = "Finely chop the %i2, %i3, %i4, %i7, %i5, and %i6 for the kebab mixture. Slice the %i25 for serving. Keep the chutney herbs and aromatics separate.";
"recipe.pk_seekh_kebab.step1.title" = "Prepare ingredients";
"recipe.pk_seekh_kebab.step10.body" = "Move the seekh kebabs off the heat and let them rest briefly so the juices settle.";
"recipe.pk_seekh_kebab.step10.title" = "Rest kebabs";
"recipe.pk_seekh_kebab.step11.body" = "Warm the %i24 briefly until soft and fragrant for serving.";
"recipe.pk_seekh_kebab.step11.title" = "Warm naan";
"recipe.pk_seekh_kebab.step12.body" = "Slide the seekh kebabs from the skewers onto a platter and serve hot with sliced red onion, naan bread, and mint chutney.";
"recipe.pk_seekh_kebab.step12.title" = "Serve";
"recipe.pk_seekh_kebab.step2.body" = "Dry-toast the %i8 briefly in a pan until aromatic, then cool it slightly before mixing.";
"recipe.pk_seekh_kebab.step2.title" = "Toast gram flour";
"recipe.pk_seekh_kebab.step3.body" = "Combine the %i1 with onion, cilantro, mint, garlic, ginger, green chili, toasted gram flour, %i9, %i10, %i11, %i12, %i13, %i14, and %i15. Mix thoroughly until the mixture becomes sticky and holds together well.";
"recipe.pk_seekh_kebab.step3.title" = "Mix kebab mince";
"recipe.pk_seekh_kebab.step4.body" = "Cover and rest the kebab mixture so the spices hydrate and the mince firms for shaping.";
"recipe.pk_seekh_kebab.step4.title" = "Rest kebab mixture";
"recipe.pk_seekh_kebab.step5.body" = "Blend the %i17, %i18, %i19, %i20, %i21, %i22, and %i23 until smooth and spoonable.";
"recipe.pk_seekh_kebab.step5.title" = "Make mint chutney";
"recipe.pk_seekh_kebab.step6.body" = "Wet your hands lightly and press the mince firmly around the skewers into long even kebabs so they grip the metal and cook evenly.";
"recipe.pk_seekh_kebab.step6.title" = "Shape on skewers";
"recipe.pk_seekh_kebab.step7.body" = "Heat the charcoal until very hot and covered with ash, then spread it into an even bed for direct grilling.";
"recipe.pk_seekh_kebab.step7.title" = "Prepare coals";
"recipe.pk_seekh_kebab.step8.body" = "Place the seekh kebabs over the coals and grill until browned and lightly charred on the first side, turning carefully once they firm up.";
"recipe.pk_seekh_kebab.step8.title" = "Grill first side";
"recipe.pk_seekh_kebab.step9.body" = "Turn regularly and baste lightly with %i16 until the kebabs are evenly browned, smoky, and cooked through while still juicy.";
"recipe.pk_seekh_kebab.step9.title" = "Finish grilling and baste";
