"recipe.no_kjottkaker.drink.body" = "A light, fresh red wine such as Pinot Noir works well with the browned meat and savory gravy. Light lager is also traditional, and a good non-alcoholic pairing is sparkling water or a tart apple drink.";
"recipe.no_kjottkaker.drink.summary" = "Red wine (Pinot Noir)";
"recipe.no_kjottkaker.info" = "Kjottkaker are traditional Norwegian meat cakes, larger and flatter than Swedish meatballs, and classically served as a hearty family dinner. The traditional plate includes brown gravy, boiled potatoes, carrots, stewed peas, and lingonberry jam.";
"recipe.no_kjottkaker.info.summary" = "Norwegian meat cakes";
"recipe.no_kjottkaker.name" = "Kjøttkaker";
"recipe.no_kjottkaker.step1.body" = "Rinse %i17, cover them with water, and leave them to soak until fully swollen.";
"recipe.no_kjottkaker.step1.title" = "Soak the peas";
"recipe.no_kjottkaker.step2.body" = "Grate %i3 finely and mix it with %i1, %i2, %i4, %i5, %i6, %i7, %i8, %i9, and %i10 until the mixture is smooth and well bound.";
"recipe.no_kjottkaker.step2.title" = "Prepare the meat mixture";
"recipe.no_kjottkaker.step3.body" = "Wet your hands and shape the mixture into thick, slightly flattened meat cakes.";
"recipe.no_kjottkaker.step3.title" = "Shape the meat cakes";
"recipe.no_kjottkaker.step4.body" = "Melt part of %i11 in the frying pan and brown the meat cakes on both sides in batches until they have a deep color. Lift them out as they are done.";
"recipe.no_kjottkaker.step4.title" = "Brown the meat cakes";
"recipe.no_kjottkaker.step5.body" = "Melt %i12 in the saucepan, stir in %i13, and cook until the roux turns brown. Whisk in %i14 gradually until the gravy is smooth, then season with %i15 and %i16.";
"recipe.no_kjottkaker.step5.title" = "Start the gravy";
"recipe.no_kjottkaker.step6.body" = "Add the browned meat cakes to the gravy and simmer gently until they are fully cooked and tender.";
"recipe.no_kjottkaker.step6.title" = "Finish the meat cakes in gravy";
"recipe.no_kjottkaker.step7.body" = "Drain the soaked peas, add fresh water, and simmer until very soft. Mash them with %i19 and %i20 into a thick stewed pea side.";
"recipe.no_kjottkaker.step7.title" = "Cook the peas";
"recipe.no_kjottkaker.step8.body" = "Peel %i21 and %i22, then cook them in salted %i23 until tender. Drain well and keep warm.";
"recipe.no_kjottkaker.step8.title" = "Boil the potatoes and carrots";
"recipe.no_kjottkaker.step9.body" = "Place the meat cakes on warm plates with the brown gravy, boiled potatoes, carrots, stewed peas, and %i25.";
"recipe.no_kjottkaker.step9.title" = "Serve";
