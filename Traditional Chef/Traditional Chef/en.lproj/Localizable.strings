"recipe.be_asperges_op_vlaamse_wijze.drink.body" = "Pair with a crisp, dry white wine such as Sauvignon Blanc or unoaked Chardonnay to match the buttery egg garnish without overpowering the asparagus. A light Belgian witbier also works well. For a non-alcoholic option, serve sparkling water with a squeeze of citrus or a chilled homemade lemonade.";
"recipe.be_asperges_op_vlaamse_wijze.drink.summary" = "White wine (Sauvignon)";
"recipe.be_asperges_op_vlaamse_wijze.info" = "Asperges op Vlaamse wijze is a traditional Belgian preparation of tender white asparagus served warm with clarified butter mixed with finely crushed hard-boiled eggs and fresh parsley. It is typically enjoyed in asparagus season and commonly served with boiled potatoes, letting the delicate asparagus flavor stay front and center.";
"recipe.be_asperges_op_vlaamse_wijze.info.summary" = "Flemish spring asparagus";
"recipe.be_asperges_op_vlaamse_wijze.name" = "Flemish white asparagus";
"recipe.be_asperges_op_vlaamse_wijze.step1.body" = "Peel %i1 from just below the tip down to the base and trim off the woody ends. Rinse %i2 and keep them whole if small, otherwise cut them into even pieces.";
"recipe.be_asperges_op_vlaamse_wijze.step1.title" = "Prep the vegetables";
"recipe.be_asperges_op_vlaamse_wijze.step2.body" = "Bring water to a boil, add %i3, and cook until hard-boiled. Drain and cool the eggs in cold water so they peel cleanly.";
"recipe.be_asperges_op_vlaamse_wijze.step2.title" = "Boil the eggs";
"recipe.be_asperges_op_vlaamse_wijze.step3.body" = "Cook the potatoes in salted water until tender. Drain well and keep them warm.";
"recipe.be_asperges_op_vlaamse_wijze.step3.title" = "Cook the potatoes";
"recipe.be_asperges_op_vlaamse_wijze.step4.body" = "Bring water to a gentle boil, season it with %i6, and add the asparagus. Cook until tender, keeping the spears intact.";
"recipe.be_asperges_op_vlaamse_wijze.step4.title" = "Cook the asparagus";
"recipe.be_asperges_op_vlaamse_wijze.step5.body" = "Turn off the heat and let the asparagus rest in the hot cooking water to finish gently, then lift it out carefully with a slotted spoon and drain.";
"recipe.be_asperges_op_vlaamse_wijze.step5.title" = "Rest the asparagus";
"recipe.be_asperges_op_vlaamse_wijze.step6.body" = "Melt %i4 slowly in a saucepan. Skim off any foam and pour off the clear butter, leaving the milky solids behind.";
"recipe.be_asperges_op_vlaamse_wijze.step6.title" = "Clarify the butter";
"recipe.be_asperges_op_vlaamse_wijze.step7.body" = "Peel the eggs and crush them finely with a fork. Chop %i5 and mix it into the crushed egg with a little salt, %i7, and %i8.";
"recipe.be_asperges_op_vlaamse_wijze.step7.title" = "Make the egg-parsley garnish";
"recipe.be_asperges_op_vlaamse_wijze.step8.body" = "Warm the clarified butter gently and fold it through the egg and parsley mixture so it stays spoonable and warm without frying.";
"recipe.be_asperges_op_vlaamse_wijze.step8.title" = "Warm the garnish";
"recipe.be_asperges_op_vlaamse_wijze.step9.body" = "Arrange the asparagus on warm plates with the potatoes alongside. Spoon the warm egg, parsley, and butter mixture over the asparagus and finish with a final touch of pepper.";
"recipe.be_asperges_op_vlaamse_wijze.step9.title" = "Serve the asparagus";
