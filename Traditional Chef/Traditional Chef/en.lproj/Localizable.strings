"recipe.kr_galbi.drink.body" = "A light fruity red such as Pinot Noir or Gamay pairs well with the caramelized sweet-savory ribs. A crisp lager is also a classic match. Non-alcoholic pairing: cold barley tea.";
"recipe.kr_galbi.drink.summary" = "Red wine (Pinot Noir)";
"recipe.kr_galbi.info" = "Galbi is a traditional Korean grilled beef short rib dish, typically marinated in a sweet-savory soy sauce mixture with garlic, onion, and Korean pear, then grilled over high heat. It is commonly served with rice and ssam vegetables with ssamjang for wrapping at the table.";
"recipe.kr_galbi.info.summary" = "Grilled beef ribs";
"recipe.kr_galbi.name" = "Galbi";
