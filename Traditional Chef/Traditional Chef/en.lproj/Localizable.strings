"recipe.kr_dasik.drink.body" = "Dasik is traditionally paired with Korean teas rather than wine, especially omija tea or green tea for a balanced sweet finish. Non-alcoholic pairing: roasted barley tea.";
"recipe.kr_dasik.drink.summary" = "Tea (Omija tea)";
"recipe.kr_dasik.info" = "Dasik is a traditional Korean hangwa confection served with tea, made by kneading fine seed or grain powder with honey and pressing it into patterned molds called dasikpan. It is commonly prepared for tea service, holidays, and ceremonial tables, and is valued for its delicate texture and decorative shapes.";
"recipe.kr_dasik.info.summary" = "Pressed tea sweets";
"recipe.kr_dasik.name" = "Dasik";
"recipe.kr_dasik.step1.body" = "Pass the %i1 through a fine sieve into a mixing bowl so the dough will press smoothly.";
"recipe.kr_dasik.step1.title" = "Sieve the sesame powder";
"recipe.kr_dasik.step2.body" = "Add the %i2 gradually to the sesame powder and mix until it forms a smooth pliable dough that holds together when pressed.";
"recipe.kr_dasik.step2.title" = "Mix the dasik dough";
"recipe.kr_dasik.step3.body" = "Lightly brush the dasik mold with %i3 and wipe away excess so the shapes release cleanly.";
"recipe.kr_dasik.step3.title" = "Prepare the mold";
"recipe.kr_dasik.step4.body" = "Press small portions of dough firmly into the mold cavities, level the surface, then tap out the patterned sweets onto a plate.";
"recipe.kr_dasik.step4.title" = "Press and unmold the dasik";
"recipe.kr_dasik.step5.body" = "Let the dasik rest briefly at room temperature so the surface firms and the pattern holds.";
"recipe.kr_dasik.step5.title" = "Set the sweets";
"recipe.kr_dasik.step6.body" = "Rinse the %i4 briefly, then combine with %i5 in a small pot and heat gently.";
"recipe.kr_dasik.step6.title" = "Start the omija tea";
"recipe.kr_dasik.step7.body" = "Keep the tea at a gentle steep until the color and flavor develop, then remove from the heat.";
"recipe.kr_dasik.step7.title" = "Steep the tea";
"recipe.kr_dasik.step8.body" = "Strain the tea into a serving vessel and stir in %i6 until dissolved.";
"recipe.kr_dasik.step8.title" = "Strain and sweeten the tea";
"recipe.kr_dasik.step9.body" = "Arrange the dasik on a serving plate and serve with warm omija tea.";
"recipe.kr_dasik.step9.title" = "Serve";
