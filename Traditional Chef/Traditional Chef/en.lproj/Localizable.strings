"recipe.ro_bulz.drink.body" = "A fresh dry white wine such as Fetească Albă pairs well with the salty sheep cheese and roasted cornmeal. For a non-alcoholic pairing, serve sparkling water or still water.";
"recipe.ro_bulz.drink.summary" = "White wine (Fetească Albă)";
"recipe.ro_bulz.info" = "Bulz is a traditional Romanian shepherd-style dish made from firm mămăligă filled with brânză de burduf, shaped, and roasted until hot and lightly crusted. It is a rustic main course from mountain and pastoral cooking, traditionally served hot with sour cream.";
"recipe.ro_bulz.info.summary" = "Shepherd’s cheese polenta";
"recipe.ro_bulz.name" = "Bulz";
"recipe.ro_bulz.step1.body" = "Bring %i2 to a boil in the saucepan and add %i3.";
"recipe.ro_bulz.step1.title" = "Start the mămăligă";
"recipe.ro_bulz.step2.body" = "Pour in %i1 gradually while stirring constantly, then cook over low heat until the mămăligă is thick, firm, and pulls away from the sides of the pan.";
"recipe.ro_bulz.step2.title" = "Cook the mămăligă";
"recipe.ro_bulz.step3.body" = "Let the mămăligă cool just enough to handle, divide it into portions, flatten each one, place some of %i4 and a little %i5 in the center, then enclose the filling completely and shape into round bulz.";
"recipe.ro_bulz.step3.title" = "Shape and fill the bulz";
"recipe.ro_bulz.step4.body" = "Place the bulz on the baking tray and roast until the outside is lightly crisp and the cheese inside is hot and softened.";
"recipe.ro_bulz.step4.title" = "Roast until lightly crusted";
"recipe.ro_bulz.step5.body" = "Serve the bulz hot with %i6 alongside or over the top.";
"recipe.ro_bulz.step5.title" = "Serve";
