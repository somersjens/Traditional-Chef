"recipe.bg_kavarma.step1.title" = "Prepare the ingredients";
"recipe.bg_kavarma.step2.body" = "Heat %i7 in the skillet and brown the pork well on all sides so it develops a deep savory base.";
"recipe.bg_kavarma.step2.title" = "Brown the pork";
"recipe.bg_kavarma.step3.body" = "Add the onions and peppers and cook until softened, then add the mushrooms and garlic and continue until the mixture is fragrant.";
"recipe.bg_kavarma.step3.title" = "Cook the vegetables";
"recipe.bg_kavarma.step4.body" = "Add %i9, %i10, %i11, and %i12 and stir well so the meat and vegetables are evenly coated.";
"recipe.bg_kavarma.step4.title" = "Season the stew";
"recipe.bg_kavarma.step5.body" = "Stir in the tomatoes, pour in %i8 and %i13, and bring the mixture to a gentle simmer.";
"recipe.bg_kavarma.step5.title" = "Add tomato and wine";
"recipe.bg_kavarma.step6.body" = "Spoon the stew into the clay pot and cover it well so it can bake slowly in the traditional way.";
"recipe.bg_kavarma.step6.title" = "Transfer to the pot";
"recipe.bg_kavarma.step7.body" = "Bake the kavarma until the pork is tender, the onions are sweet, and the sauce is rich and concentrated.";
"recipe.bg_kavarma.step7.title" = "Bake until tender";
"recipe.bg_kavarma.step8.body" = "Take the pot from the oven and let the kavarma stand briefly so the sauce settles and the flavors deepen.";
"recipe.bg_kavarma.step8.title" = "Rest before serving";
"recipe.bg_kavarma.step9.body" = "Ladle the kavarma hot into bowls and serve it with %i14 alongside for dipping into the sauce.";
"recipe.bg_kavarma.step9.title" = "Serve with bread";
