"recipe.lb_maamoul.drink.body" = "Pair with a lightly sweet Muscat or late-harvest Riesling that complements the buttery semolina and dates. For a non-alcoholic option, serve strong Arabic coffee or unsweetened black tea.";
"recipe.lb_maamoul.drink.summary" = "Dessert wine (Muscat)";
"recipe.lb_maamoul.info" = "Lebanese maamoul are festive molded cookies traditionally made for Eid and other celebrations. A buttery semolina dough is rested until tender, then filled with sweet date paste, shaped in carved wooden molds, and baked until pale-golden and fragrant. They are served once cooled, often alongside Arabic coffee when guests visit.";
"recipe.lb_maamoul.info.summary" = "Eid molded cookies";
"recipe.lb_maamoul.name" = "Date maamoul";
"recipe.lb_maamoul.step1.body" = "Combine %i1, %i2, %i3, %i4, %i5, and %i6 in a bowl. Warm the %i7 until liquid and pour it in, mixing until the grains are evenly coated.";
"recipe.lb_maamoul.step1.title" = "Prepare the dough base";
"recipe.lb_maamoul.step2.body" = "Cover the bowl and let the mixture rest so the semolina absorbs the fat and becomes tender.";
"recipe.lb_maamoul.step2.title" = "Rest the dough";
"recipe.lb_maamoul.step3.body" = "Mix %i8 with %i9 and %i10, then work it into the rested mixture until a soft, cohesive dough forms. Cover briefly so it relaxes.";
"recipe.lb_maamoul.step3.title" = "Finish the dough";
"recipe.lb_maamoul.step4.body" = "Knead the %i11 with %i12 until smooth and pliable, then portion into small balls.";
"recipe.lb_maamoul.step4.title" = "Make the date filling";
"recipe.lb_maamoul.step5.body" = "Divide the dough into portions, flatten each piece, enclose a date ball, and seal well. Press into the maamoul mold, then tap to release onto a lined baking sheet.";
"recipe.lb_maamoul.step5.title" = "Shape in the mold";
"recipe.lb_maamoul.step6.body" = "Bake until the cookies are set and lightly golden on the bottom while remaining pale on top.";
"recipe.lb_maamoul.step6.title" = "Bake";
"recipe.lb_maamoul.step7.body" = "Cool on a rack until fully set and tender, then serve with Arabic coffee or tea.";
"recipe.lb_maamoul.step7.title" = "Cool and serve";
