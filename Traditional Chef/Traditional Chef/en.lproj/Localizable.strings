"recipe.gr_fava.drink.body" = "Pair with a crisp Greek white such as Assyrtiko that matches lemon and olive oil and stays fresh with the capers. A light lager also works well. For a non-alcoholic option, serve sparkling water with lemon or a chilled lemon soda.";
"recipe.gr_fava.drink.summary" = "White wine (Assyrtiko)";
"recipe.gr_fava.info" = "Greek fava is a traditional Santorini-style purée made by simmering yellow split peas with onion until soft, then blending to a smooth, thick dip and finishing with good olive oil and lemon. It is classically served as a meze topped with raw onion and capers, with warm bread alongside for scooping.";
"recipe.gr_fava.info.summary" = "Santorini fava mezze";
"recipe.gr_fava.name" = "Fava purée";
"recipe.gr_fava.step1.body" = "Rinse %i1 well. Chop %i2 and slice %i6 thinly for the topping.";
"recipe.gr_fava.step1.title" = "Rinse and prep";
"recipe.gr_fava.step2.body" = "Simmer the split peas with the onion and %i3 gently until very soft, skimming any foam and stirring occasionally so they do not catch.";
"recipe.gr_fava.step2.title" = "Simmer the fava";
"recipe.gr_fava.step3.body" = "Blend the peas until very smooth, adjusting the texture with a little cooking liquid if needed, then season with %i5.";
"recipe.gr_fava.step3.title" = "Blend until smooth";
"recipe.gr_fava.step4.body" = "Spoon into a bowl, drizzle with %i4 and %i8, and top with the sliced red onion and %i7.";
"recipe.gr_fava.step4.title" = "Finish and top";
"recipe.gr_fava.step5.body" = "Warm %i9 and serve it alongside for scooping.";
"recipe.gr_fava.step5.title" = "Serve the fava";
