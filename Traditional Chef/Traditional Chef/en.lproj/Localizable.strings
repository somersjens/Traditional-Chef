"recipe.gr_spanakopita.drink.body" = "Pair with a crisp Greek white such as Assyrtiko or a dry rosé to match the salty feta and fresh herbs while cutting through buttery filo. A light lager also works well. For a non-alcoholic option, serve sparkling water with lemon or a chilled lemon soda.";
"recipe.gr_spanakopita.drink.summary" = "White wine (Assyrtiko)";
"recipe.gr_spanakopita.info" = "Spanakopita is a classic Greek pie of spinach, feta, herbs, and spring onions wrapped in crisp buttered filo. The filling is cooked just enough to remove excess moisture, then mixed with feta and egg so it bakes into a savory, tangy layer beneath shatteringly crisp pastry. It is served hot or warm, cut into pieces, as a staple meze or light course across Greece.";
"recipe.gr_spanakopita.info.summary" = "Crisp spinach filo pie";
"recipe.gr_spanakopita.name" = "Spanakopita";
