"recipe.ro_ciorba_de_burta.drink.body" = "A fresh dry white wine such as Fetească Albă or Sauvignon Blanc pairs well with the rich creamy broth and vinegar brightness. For a non-alcoholic pairing, serve sparkling water or still water.";
"recipe.ro_ciorba_de_burta.drink.summary" = "White wine (Fetească Albă)";
"recipe.ro_ciorba_de_burta.info" = "Ciorbă de burtă is a classic Romanian soup made from beef tripe and beef bones simmered with root vegetables, then finished with garlic, sour cream, egg yolks, vinegar, and the characteristic carrot color from the stock. It is traditionally served hot as a first course, especially in restaurants and at festive family meals, with hot peppers on the side.";
"recipe.ro_ciorba_de_burta.info.summary" = "Creamy tripe soup";
"recipe.ro_ciorba_de_burta.name" = "Tripe soup";
"recipe.ro_ciorba_de_burta.step1.body" = "Rinse %i1 well. Put %i2 in the stockpot with %i3, %i4, %i5, %i6, %i8, %i9, part of %i10, and %i7.";
"recipe.ro_ciorba_de_burta.step1.title" = "Prepare the stock ingredients";
"recipe.ro_ciorba_de_burta.step2.body" = "Bring the pot to a gentle simmer and cook slowly until the broth is rich and the bones have given full flavor. Skim when needed during cooking.";
"recipe.ro_ciorba_de_burta.step2.title" = "Simmer the stock";
"recipe.ro_ciorba_de_burta.step3.body" = "Strain the broth and keep the carrots. Discard the other vegetables, bay leaf, and peppercorns. Cut the tripe into thin strips if needed and return it to the clear broth.";
"recipe.ro_ciorba_de_burta.step3.title" = "Strain and prepare the soup base";
"recipe.ro_ciorba_de_burta.step4.body" = "Simmer the tripe in the strained broth until fully tender and the soup becomes aromatic and well combined.";
"recipe.ro_ciorba_de_burta.step4.title" = "Cook the tripe in the broth";
"recipe.ro_ciorba_de_burta.step5.body" = "Crush %i11 to a paste. Finely mash the cooked carrots into a smooth puree and stir them into the soup so the broth takes on its traditional color.";
"recipe.ro_ciorba_de_burta.step5.title" = "Prepare the garlic and carrot base";
"recipe.ro_ciorba_de_burta.step6.body" = "In the mixing bowl, whisk %i12 with %i13 until smooth.";
"recipe.ro_ciorba_de_burta.step6.title" = "Mix the creamy finish";
"recipe.ro_ciorba_de_burta.step7.body" = "Add a few ladles of hot soup gradually into the sour cream mixture while whisking so it warms gently without curdling.";
"recipe.ro_ciorba_de_burta.step7.title" = "Temper the mixture";
"recipe.ro_ciorba_de_burta.step8.body" = "Lower the heat, stir the tempered mixture back into the pot, then add %i14, the remaining salt, and %i15. Heat gently without boiling.";
"recipe.ro_ciorba_de_burta.step8.title" = "Finish the soup";
"recipe.ro_ciorba_de_burta.step9.body" = "Ladle the ciorbă de burtă into bowls and serve hot with %i16 alongside.";
"recipe.ro_ciorba_de_burta.step9.title" = "Serve";
