"recipe.eg_kofta.step6.title" = "Prep vegetables for grilling";
"recipe.eg_kofta.step7.body" = "Grill the kofta over high heat, turning regularly, until browned and cooked through while staying juicy.";
"recipe.eg_kofta.step7.title" = "Grill the kofta";
"recipe.eg_kofta.step8.body" = "Grill the tomatoes and onion until softened and charred in spots.";
"recipe.eg_kofta.step8.title" = "Grill the vegetables";
"recipe.eg_kofta.step9.body" = "Serve the kofta hot with grilled vegetables, tahini sauce, and %i18.";
"recipe.eg_kofta.step9.title" = "Serve";
