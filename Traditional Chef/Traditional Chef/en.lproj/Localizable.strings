"recipe.ch_alplermagronen.step1.title" = "Prepare the ingredients";
"recipe.ch_alplermagronen.step2.body" = "Bring %i3 to a boil in a large pot, add some of %i8, and cook the potatoes until nearly tender.";
"recipe.ch_alplermagronen.step2.title" = "Cook the potatoes";
"recipe.ch_alplermagronen.step3.body" = "Add %i1 to the same pot and cook until the pasta and potatoes are both tender, then drain them well.";
"recipe.ch_alplermagronen.step3.title" = "Cook the macaroni";
"recipe.ch_alplermagronen.step4.body" = "Melt %i7 in a large frying pan and cook the onions slowly until deep golden and sweet.";
"recipe.ch_alplermagronen.step4.title" = "Fry the onions";
"recipe.ch_alplermagronen.step5.body" = "Return the drained macaroni and potatoes to the pot, add %i5, most of the cheese, the remaining salt, and %i9, and stir until evenly mixed.";
"recipe.ch_alplermagronen.step5.title" = "Combine the base";
"recipe.ch_alplermagronen.step6.body" = "Transfer the mixture to an ovenproof dish, cover with the remaining cheese, and bake until hot and lightly golden on top.";
"recipe.ch_alplermagronen.step6.title" = "Bake the dish";
"recipe.ch_alplermagronen.step7.body" = "Top the Älplermagronen with the fried onions and serve immediately with %i10 on the side.";
"recipe.ch_alplermagronen.step7.title" = "Finish and serve";
