"recipe.uz_kazan_kebab.drink.body" = "A medium-bodied red such as Syrah or Tempranillo pairs well with the rich lamb and browned potatoes. A dry amber ale also works nicely. Non-alcoholic pairing: hot black tea is the traditional choice.";
"recipe.uz_kazan_kebab.drink.summary" = "Red wine (Syrah)";
"recipe.uz_kazan_kebab.info" = "Kazan Kebab is a traditional Uzbek cauldron dish of lamb and potatoes cooked in a heavy kazan until deeply browned, then finished covered so the meat becomes tender and the potatoes absorb the savory juices. It is typically served hot for sharing with flatbread and fresh onions or herbs.";
"recipe.uz_kazan_kebab.info.summary" = "Lamb and potato kazan";
"recipe.uz_kazan_kebab.name" = "Kazan kebab";
"recipe.uz_kazan_kebab.step1.body" = "Cut the %i1 into medium pieces. Peel the %i2 and keep small ones whole or halve larger ones. Slice the %i3 into rings and chop the %i8.";
"recipe.uz_kazan_kebab.step1.title" = "Prepare lamb and potatoes";
"recipe.uz_kazan_kebab.step2.body" = "Season the lamb with most of the %i5, the %i6, and %i7, keeping a little salt back for the potatoes.";
"recipe.uz_kazan_kebab.step2.title" = "Season lamb";
"recipe.uz_kazan_kebab.step3.body" = "Heat the kazan with the %i4 over medium-high heat. Add the potatoes and fry until golden on several sides. Season with the remaining salt, then remove and set aside.";
"recipe.uz_kazan_kebab.step3.title" = "Brown potatoes";
"recipe.uz_kazan_kebab.step4.body" = "Add the lamb to the same hot fat and brown well on all sides until a rich crust forms.";
"recipe.uz_kazan_kebab.step4.title" = "Brown lamb";
"recipe.uz_kazan_kebab.step5.body" = "Lower the heat. Arrange the browned potatoes over and around the lamb, then spread the onion rings on top. Cover tightly without stirring.";
"recipe.uz_kazan_kebab.step5.title" = "Layer for finishing";
"recipe.uz_kazan_kebab.step6.body" = "Cook on low heat until the lamb is tender and the potatoes are fully cooked, letting the dish finish in its own juices under the lid.";
"recipe.uz_kazan_kebab.step6.title" = "Cook covered";
"recipe.uz_kazan_kebab.step7.body" = "Turn off the heat and let the kazan kebab rest covered. Warm the %i9 briefly for serving.";
"recipe.uz_kazan_kebab.step7.title" = "Rest and warm bread";
"recipe.uz_kazan_kebab.step8.body" = "Transfer the lamb and potatoes to a serving platter, top with the softened onions and chopped cilantro, and serve immediately with the bread.";
"recipe.uz_kazan_kebab.step8.title" = "Serve";
