"recipe.no_multekrem.drink.body" = "A light dessert wine such as late harvest Riesling pairs well with the tart-sweet berries and cream. A good non-alcoholic pairing is black coffee or chilled sparkling water.";
"recipe.no_multekrem.drink.summary" = "Dessert wine (Riesling)";
"recipe.no_multekrem.info" = "Multekrem is a classic Norwegian dessert of sweetened cloudberries folded into lightly whipped cream, especially associated with Christmas and festive family meals. It is traditionally served chilled and often accompanied by crisp krumkaker for contrast in texture.";
"recipe.no_multekrem.info.summary" = "Cloudberry cream dessert";
"recipe.no_multekrem.name" = "Cloudberry cream";
"recipe.no_multekrem.step1.body" = "Place %i1 in a bowl and mix them gently with %i2 until the berries are lightly sweetened but still mostly whole.";
"recipe.no_multekrem.step1.title" = "Prepare the berries";
"recipe.no_multekrem.step2.body" = "Whip %i3 in a separate bowl until soft and airy, keeping it smooth rather than stiff.";
"recipe.no_multekrem.step2.title" = "Whip the cream";
"recipe.no_multekrem.step3.body" = "Fold the sweetened cloudberries gently into the whipped cream so the mixture stays light and the berries remain visible.";
"recipe.no_multekrem.step3.title" = "Fold the multekrem";
"recipe.no_multekrem.step4.body" = "Cover and chill the multekrem so it becomes cold and settles before serving.";
"recipe.no_multekrem.step4.title" = "Chill the dessert";
"recipe.no_multekrem.step5.body" = "Spoon the multekrem into dessert bowls and serve it cold with %i4 alongside.";
"recipe.no_multekrem.step5.title" = "Serve";
