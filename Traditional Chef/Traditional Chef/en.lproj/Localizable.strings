"recipe.be_mattentaart.drink.body" = "Pair with a lightly sweet wine such as late-harvest Riesling or a glass of Belgian gueuze if you like a tart contrast to the sweet curd filling. For a non-alcoholic option, serve coffee, black tea, or sparkling water.";
"recipe.be_mattentaart.drink.summary" = "Sweet wine (Riesling)";
"recipe.be_mattentaart.info" = "Geraardsbergse mattentaart is a traditional Belgian puff pastry tartlet from the Geraardsbergen area, filled with finely drained milk curd (matten) mixed with eggs, sugar, vanilla, and ground almonds. The tartlets are baked until the pastry is crisp and golden and the filling stays tender and creamy, and they are typically served slightly warm or at room temperature.";
"recipe.be_mattentaart.info.summary" = "Geraardsbergen curd tart";
"recipe.be_mattentaart.name" = "Mattentaart";
"recipe.be_mattentaart.step1.body" = "Bring %i1 to a boil with %i5. Once boiling, remove it from the heat, add %i2 all at once, and stir briefly to curdle.";
"recipe.be_mattentaart.step1.title" = "Start the matten";
"recipe.be_mattentaart.step2.body" = "Pour the curds and whey into a sieve lined with cheesecloth set over a bowl. Let the curd drain in a cool place until very dry, then discard the whey.";
"recipe.be_mattentaart.step2.title" = "Drain the curd";
"recipe.be_mattentaart.step3.body" = "Remove the vanilla pod. Break up the drained curd finely in a bowl, then mix in the egg yolks, %i4, %i6, and %i7 until smooth.";
"recipe.be_mattentaart.step3.title" = "Prepare the filling base";
"recipe.be_mattentaart.step4.body" = "Whisk the egg whites to stiff peaks and fold them gently into the curd mixture to keep it airy.";
"recipe.be_mattentaart.step4.title" = "Lighten the filling";
"recipe.be_mattentaart.step5.body" = "Butter the tartlet molds with %i10 and dust with %i11. Roll out %i8 and line the molds, leaving enough pastry to seal with a lid.";
"recipe.be_mattentaart.step5.title" = "Prepare the molds and pastry";
"recipe.be_mattentaart.step6.body" = "Fill the lined molds with the curd mixture, keeping the rim clean. Cover with pastry lids, seal the edges well, and trim neatly.";
"recipe.be_mattentaart.step6.title" = "Fill and close";
"recipe.be_mattentaart.step7.body" = "Beat %i9 for the wash and brush a thin layer over the tops of the tartlets.";
"recipe.be_mattentaart.step7.title" = "Brush with egg wash";
"recipe.be_mattentaart.step8.body" = "Bake in a hot oven until the pastry is puffed and deeply golden and the filling is set.";
"recipe.be_mattentaart.step8.title" = "Bake the tartlets";
"recipe.be_mattentaart.step9.body" = "Let the tartlets cool briefly in the molds, then unmold and serve slightly warm or at room temperature.";
"recipe.be_mattentaart.step9.title" = "Cool and serve";
