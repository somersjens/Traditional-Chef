"recipe.eg_basbousa.drink.body" = "Pair with a lightly sweet Moscato or an aromatic late-harvest Riesling that complements the lemony syrup and coconut. A small glass of sweet sherry also works with the toasted semolina notes. Non-alcoholic option: mint tea or black tea.";
"recipe.eg_basbousa.drink.summary" = "Sweet wine (Moscato)";
"recipe.eg_basbousa.info" = "Basbousa is a classic Egyptian semolina cake enriched with yogurt and ghee, lightly scented by coconut, baked until golden, then soaked with lemon sugar syrup for a moist, tender crumb. Traditionally cut into diamonds and topped with almonds, it is served at room temperature with tea or coffee as a beloved everyday and festive sweet.";
"recipe.eg_basbousa.info.summary" = "Syrup-soaked semolina cake";
"recipe.eg_basbousa.name" = "Basbousa";
"recipe.eg_basbousa.step1.body" = "Combine %i9 and %i10 in a saucepan and bring to a gentle boil, stirring to dissolve. Simmer briefly, then stir in %i11 and let the syrup cool.";
"recipe.eg_basbousa.step1.title" = "Make the sugar syrup";
"recipe.eg_basbousa.step2.body" = "Mix %i1, %i2, %i3, and %i6 in a bowl. Add %i4 and %i5 and mix until evenly moistened and thick.";
"recipe.eg_basbousa.step2.title" = "Mix the basbousa batter";
"recipe.eg_basbousa.step3.body" = "Let the batter rest so the semolina hydrates and the mixture firms slightly.";
"recipe.eg_basbousa.step3.title" = "Rest the batter";
"recipe.eg_basbousa.step4.body" = "Heat the oven. Grease the pan thoroughly with %i7, spread the batter evenly, and smooth the top. Score into diamond shapes and press %i8 into the center of each piece.";
"recipe.eg_basbousa.step4.title" = "Prepare the pan and top";
"recipe.eg_basbousa.step5.body" = "Bake until set and deeply golden on top and the edges pull slightly from the pan.";
"recipe.eg_basbousa.step5.title" = "Bake until golden";
"recipe.eg_basbousa.step6.body" = "Pour the cooled syrup evenly over the hot basbousa so it absorbs into the scored pieces.";
"recipe.eg_basbousa.step6.title" = "Soak with syrup";
"recipe.eg_basbousa.step7.body" = "Let the basbousa cool completely so the syrup fully absorbs and the pieces set for clean serving.";
"recipe.eg_basbousa.step7.title" = "Cool and set";
"recipe.eg_basbousa.step8.body" = "Cut along the scored lines and serve at room temperature.";
"recipe.eg_basbousa.step8.title" = "Serve";
