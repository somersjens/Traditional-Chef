"recipe.cn_lanzhou_niurou_lamian.step11.body" = "Place noodles in serving bowls, add a little soy sauce, ladle over the hot clear beef broth, and top with sliced beef and cooked radish.";
"recipe.cn_lanzhou_niurou_lamian.step11.title" = "Assemble the bowls";
"recipe.cn_lanzhou_niurou_lamian.step12.body" = "Add chili oil, cilantro, and garlic chives to each bowl and serve immediately while piping hot.";
"recipe.cn_lanzhou_niurou_lamian.step12.title" = "Finish and serve";
