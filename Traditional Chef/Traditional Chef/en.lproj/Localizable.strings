"recipe.sr_moksi_meti.drink.body" = "Serve with a light fruity red or a dry white wine that can handle the sweet-salty glaze without overpowering the meats. A light lager also works well. For a non-alcoholic option, serve chilled ginger drink or hot black tea.";
"recipe.sr_moksi_meti.drink.summary" = "Red wine";
"recipe.sr_moksi_meti.info" = "Moksi meti is a traditional Chinese-Surinamese dish of mixed meats, usually combining pork, chicken, and Chinese sausage in a savory soy-based glaze. It is commonly served hot alongside rice or noodles and is a well-known component of festive and takeaway-style Surinamese meals.";
"recipe.sr_moksi_meti.info.summary" = "Mixed roast meats";
"recipe.sr_moksi_meti.name" = "Moksi meti";
"recipe.sr_moksi_meti.step1.body" = "Cut %i1 and %i2 into serving pieces, slice %i3 and %i4, and finely chop %i5 and %i6.";
"recipe.sr_moksi_meti.step1.title" = "Prepare the meats";
"recipe.sr_moksi_meti.step2.body" = "Combine the pork and chicken with the garlic, ginger, %i7, %i8, %i9, %i10, %i11, and %i12, then leave them to absorb the seasoning.";
"recipe.sr_moksi_meti.step2.title" = "Marinate the meats";
"recipe.sr_moksi_meti.step3.body" = "Heat %i13 in a large pot or frying pan and brown the pork well on all sides.";
"recipe.sr_moksi_meti.step3.title" = "Brown the pork";
"recipe.sr_moksi_meti.step4.body" = "Add the chicken and Chinese sausage and cook until the meat is colored and the sausage begins to release its flavor.";
"recipe.sr_moksi_meti.step4.title" = "Brown the chicken and sausage";
"recipe.sr_moksi_meti.step5.body" = "Add the onion and cook until softened, then stir in the remaining dark soy sauce and let the mixture glaze lightly.";
"recipe.sr_moksi_meti.step5.title" = "Build the base";
"recipe.sr_moksi_meti.step6.body" = "Add %i14, cover, and let the meats simmer gently until tender and the sauce becomes rich and glossy.";
"recipe.sr_moksi_meti.step6.title" = "Braise the meats";
"recipe.sr_moksi_meti.step7.body" = "Remove the lid and cook briefly so the sauce thickens and coats the meats evenly.";
"recipe.sr_moksi_meti.step7.title" = "Reduce the sauce";
"recipe.sr_moksi_meti.step8.body" = "Arrange the moksi meti hot with %i15 and spoon the sauce over the meat.";
"recipe.sr_moksi_meti.step8.title" = "Serve";
