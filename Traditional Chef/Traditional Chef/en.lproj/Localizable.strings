"recipe.sy_muhammara.drink.summary" = "Red wine (Grenache)";
"recipe.sy_muhammara.info" = "Muhammara is a traditional Aleppine Syrian dip made from roasted red peppers blended with walnuts, breadcrumbs, garlic, spices, olive oil, and pomegranate molasses for a sweet-tangy heat. It is typically served as part of a mezze spread and eaten by scooping with pieces of warm bread.";
"recipe.sy_muhammara.info.summary" = "Aleppo walnut pepper dip";
"recipe.sy_muhammara.name" = "Muhammara";
"recipe.sy_muhammara.step1.body" = "Heat the oven and line a tray. Place %i1 on the tray and pierce them so steam can escape.";
"recipe.sy_muhammara.step1.title" = "Prepare for roasting";
"recipe.sy_muhammara.step2.body" = "Roast the peppers, turning once, until the skins blister and blacken in spots and the flesh is very soft.";
"recipe.sy_muhammara.step2.title" = "Roast the peppers";
"recipe.sy_muhammara.step3.body" = "Transfer the hot peppers to a bowl and cover to trap steam, then peel off the skins, remove seeds, and drain any excess liquid.";
"recipe.sy_muhammara.step3.title" = "Steam and peel";
"recipe.sy_muhammara.step4.body" = "Toast %i2 in a dry skillet, stirring often, until fragrant and lightly browned, then let them cool.";
"recipe.sy_muhammara.step4.title" = "Toast the walnuts";
"recipe.sy_muhammara.step5.body" = "Toast %i3 in the dry skillet, stirring until lightly golden and dry, then cool briefly.";
"recipe.sy_muhammara.step5.title" = "Toast the breadcrumbs";
"recipe.sy_muhammara.step6.body" = "In a food processor, blend the roasted peppers with %i4, walnuts, breadcrumbs, %i7, %i8, %i9, %i6, and %i5 until thick and spreadable.";
"recipe.sy_muhammara.step6.title" = "Blend the dip";
"recipe.sy_muhammara.step7.body" = "Let the muhammara rest so the flavors meld and the texture settles.";
"recipe.sy_muhammara.step7.title" = "Rest for flavor";
"recipe.sy_muhammara.step8.body" = "Spoon into a bowl and serve with %i10 for scooping.";
"recipe.sy_muhammara.step8.title" = "Serve";
