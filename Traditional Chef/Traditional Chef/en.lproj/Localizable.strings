"recipe.ar_bife_de_chorizo.drink.body" = "Malbec is the classic Argentine pairing, with enough fruit and structure for grilled beef and chimichurri. A dry Bonarda also works well. For a non-alcoholic option, serve sparkling water with lemon or unsweetened iced yerba mate.";
"recipe.ar_bife_de_chorizo.drink.summary" = "Red wine (Malbec)";
"recipe.ar_bife_de_chorizo.info" = "Bife de chorizo is Argentina’s classic thick-cut strip steak cooked over a hot parrilla with nothing more than salt, letting the beef and fire do the work. It’s a cornerstone of asado culture and is traditionally served sliced with chimichurri, the bright herb-and-vinegar sauce that cuts through the richness of the meat.";
"recipe.ar_bife_de_chorizo.info.summary" = "Thick-cut strip steak";
"recipe.ar_bife_de_chorizo.name" = "Bife de chorizo";
"recipe.ar_bife_de_chorizo.step1.body" = "Finely chop the %i3 and mince the %i4. Combine with %i5, %i6, %i7, %i8, %i9, and %i10, stirring until evenly mixed.";
"recipe.ar_bife_de_chorizo.step1.title" = "Make the chimichurri";
"recipe.ar_bife_de_chorizo.step2.body" = "Let the chimichurri stand so the flavors meld while you prepare the grill and steak.";
"recipe.ar_bife_de_chorizo.step2.title" = "Rest the chimichurri";
"recipe.ar_bife_de_chorizo.step3.body" = "Set the %i1 out so they lose their chill and cook more evenly.";
"recipe.ar_bife_de_chorizo.step3.title" = "Temper the steak";
"recipe.ar_bife_de_chorizo.step4.body" = "Preheat the grill to high heat, clean the grates, and set up a hotter zone and a slightly cooler zone for control.";
"recipe.ar_bife_de_chorizo.step4.title" = "Heat the parrilla";
"recipe.ar_bife_de_chorizo.step5.body" = "Season the steaks generously with %i2 on both sides right before grilling.";
"recipe.ar_bife_de_chorizo.step5.title" = "Salt the steaks";
"recipe.ar_bife_de_chorizo.step6.body" = "Place the steaks on the hot zone and sear without moving them until a deep crust forms.";
"recipe.ar_bife_de_chorizo.step6.title" = "Grill first side";
"recipe.ar_bife_de_chorizo.step7.body" = "Flip and grill the other side to build crust and bring the interior to your preferred doneness, moving briefly to the cooler zone if needed.";
"recipe.ar_bife_de_chorizo.step7.title" = "Grill second side";
"recipe.ar_bife_de_chorizo.step8.body" = "Rest the steaks so the juices redistribute before slicing.";
"recipe.ar_bife_de_chorizo.step8.title" = "Rest the steak";
"recipe.ar_bife_de_chorizo.step9.body" = "Slice the steak against the grain and serve with chimichurri spooned over the top and on the side.";
"recipe.ar_bife_de_chorizo.step9.title" = "Slice and serve";
