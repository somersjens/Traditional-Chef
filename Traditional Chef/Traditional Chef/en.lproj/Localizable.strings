"recipe.hu_halaszle.drink.body" = "Pair with a crisp dry white such as Furmint or Olaszrizling to stay fresh against paprika and fish. A pale lager also works well. For a non-alcoholic option, serve sparkling water with lemon or a chilled apple spritz.";
"recipe.hu_halaszle.drink.summary" = "White wine (Furmint)";
"recipe.hu_halaszle.info" = "Halászlé is a traditional Hungarian fisherman’s soup built from freshwater fish cooked in a vivid, paprika-rich broth made by simmering fish heads and bones with onions, then straining for a smooth base. Fish steaks are then poached in the spicy broth and served immediately with bread, creating a bright red, fragrant soup that is hot, clean, and deeply fishy in the best way.";
"recipe.hu_halaszle.info.summary" = "Paprika fisherman’s soup";
"recipe.hu_halaszle.name" = "Fisherman's soup";
"recipe.hu_halaszle.step1.body" = "Fillet and cut %i1 into serving-size pieces, keeping the heads, bones, and trimmings for the broth. Season the fish pieces with %i5 and keep them chilled.";
"recipe.hu_halaszle.step1.title" = "Prep the fish";
"recipe.hu_halaszle.step2.body" = "Slice %i2 and put it in a pot with the fish heads and bones and %i7.";
"recipe.hu_halaszle.step2.title" = "Start the base";
"recipe.hu_halaszle.step3.body" = "Simmer gently until the fish breaks down and the broth is strong and opaque, stirring and pressing so the flesh releases into the liquid.";
"recipe.hu_halaszle.step3.title" = "Simmer and extract";
"recipe.hu_halaszle.step4.body" = "Strain through a fine sieve, pressing firmly to extract the fish essence, and return the smooth broth to the pot.";
"recipe.hu_halaszle.step4.title" = "Strain the broth";
"recipe.hu_halaszle.step5.body" = "Off the heat, stir in %i3 and %i4 so they bloom without scorching, then return to gentle heat.";
"recipe.hu_halaszle.step5.title" = "Add the paprika";
"recipe.hu_halaszle.step6.body" = "Bring to a gentle simmer, add the fish pieces, and poach until just cooked through without boiling hard.";
"recipe.hu_halaszle.step6.title" = "Poach the fish";
"recipe.hu_halaszle.step7.body" = "Serve immediately, making sure each bowl gets fish and plenty of hot red broth, with %i8 alongside.";
"recipe.hu_halaszle.step7.title" = "Serve the halászlé";
