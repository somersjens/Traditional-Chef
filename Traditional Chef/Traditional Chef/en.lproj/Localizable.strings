"recipe.pk_sajji.drink.body" = "A dry aromatic white such as Riesling or Chenin Blanc works well with smoky roasted chicken and gentle seasoning. A crisp lager also pairs nicely. Non-alcoholic pairing: salted lassi or hot black tea are traditional choices.";
"recipe.pk_sajji.drink.summary" = "White wine (Riesling)";
"recipe.pk_sajji.info" = "Sajji is a traditional Balochi and Pakistani roasted meat dish, classically prepared by salting a whole chicken and roasting it over charcoal until the skin is browned and the meat stays juicy. It is commonly served hot for sharing with naan and simple fresh accompaniments.";
"recipe.pk_sajji.info.summary" = "Charcoal-roasted chicken";
"recipe.pk_sajji.name" = "Sajji";
"recipe.pk_sajji.step1.body" = "Clean and pat dry the %i1. Make deep slashes in the thick parts so it cooks evenly. Finely crush the %i6. Slice the %i9 and cut some %i10 into wedges for serving.";
"recipe.pk_sajji.step1.title" = "Prepare chicken and garnish";
"recipe.pk_sajji.step2.body" = "Mix %i2, %i3, %i4, %i5, and garlic in a bowl. Rub the mixture thoroughly over and inside the chicken, working it into the slashes.";
"recipe.pk_sajji.step2.title" = "Season the chicken";
"recipe.pk_sajji.step3.body" = "Leave the chicken to marinate so the seasoning penetrates and the surface dries slightly for better roasting.";
"recipe.pk_sajji.step3.title" = "Marinate";
"recipe.pk_sajji.step4.body" = "Heat charcoal until hot and evenly ashed over. Secure the chicken firmly on a long skewer or spit so it holds its shape during roasting.";
"recipe.pk_sajji.step4.title" = "Prepare fire and skewer";
"recipe.pk_sajji.step5.body" = "Roast the chicken over medium charcoal heat, turning regularly so it browns evenly and cooks through without burning. Baste lightly with %i7 during roasting to help color and keep the surface moist.";
"recipe.pk_sajji.step5.title" = "Roast slowly";
"recipe.pk_sajji.step6.body" = "Remove the chicken from the fire and let it rest so the juices settle before carving.";
"recipe.pk_sajji.step6.title" = "Rest the sajji";
"recipe.pk_sajji.step7.body" = "Warm the %i8 briefly until soft and fragrant for serving.";
"recipe.pk_sajji.step7.title" = "Warm naan";
"recipe.pk_sajji.step8.body" = "Carve the sajji into serving pieces and place on a platter. Serve hot with naan, sliced red onion, and lemon wedges.";
"recipe.pk_sajji.step8.title" = "Carve and serve";
