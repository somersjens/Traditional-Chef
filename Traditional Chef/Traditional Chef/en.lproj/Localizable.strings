"recipe.pe_chupe_de_camarones.drink.body" = "Pair with a ripe Viognier or an unoaked Chardonnay to match the creamy texture and sweet shrimp. A crisp lager also works well with the gentle chili warmth. For a non-alcoholic option, serve chicha morada or sparkling water with lime.";
"recipe.pe_chupe_de_camarones.drink.summary" = "White wine (Viognier)";
"recipe.pe_chupe_de_camarones.info" = "Chupe de Camarones is the traditional Arequipeño shrimp chowder, built on a deeply flavored shrimp stock and a sautéed base of onion, garlic, ají amarillo, and tomato, then simmered with potatoes, rice, corn, peas, and fava beans. The soup is finished with milk, fresh cheese, and eggs gently set in the broth, creating a hearty, creamy bowl that is served piping hot, often with bread on the side.";
"recipe.pe_chupe_de_camarones.info.summary" = "Arequipa shrimp chowder";
"recipe.pe_chupe_de_camarones.name" = "Shrimp chupe";
"recipe.pe_chupe_de_camarones.step1.body" = "Remove the heads and shells from the %i1, keeping the shells and heads for stock. Devein the shrimp and refrigerate the peeled shrimp.";
"recipe.pe_chupe_de_camarones.step1.title" = "Prep the shrimp";
"recipe.pe_chupe_de_camarones.step10.body" = "Ladle into bowls with an egg in each portion and serve immediately with %i19 on the side.";
"recipe.pe_chupe_de_camarones.step10.title" = "Serve";
"recipe.pe_chupe_de_camarones.step2.body" = "Simmer the shrimp heads and shells in %i2 with a pinch of %i3 until the stock is fragrant and colored, then strain and keep the hot stock.";
"recipe.pe_chupe_de_camarones.step2.title" = "Make shrimp stock";
"recipe.pe_chupe_de_camarones.step3.body" = "In the pot, heat %i8 and sauté the chopped %i4 until soft. Add minced %i5, %i6, and %i9 and cook until aromatic.";
"recipe.pe_chupe_de_camarones.step3.title" = "Build the soup base";
"recipe.pe_chupe_de_camarones.step4.body" = "Add finely chopped %i7 and cook, stirring, until they break down into a thick, cooked sauce.";
"recipe.pe_chupe_de_camarones.step4.title" = "Cook the tomatoes";
"recipe.pe_chupe_de_camarones.step5.body" = "Pour in the reserved shrimp stock, bring to a steady simmer, and season with %i10 and more salt as needed.";
"recipe.pe_chupe_de_camarones.step5.title" = "Start the soup";
"recipe.pe_chupe_de_camarones.step6.body" = "Add the %i11 and %i12 and simmer until the potatoes are nearly tender and the rice is mostly cooked.";
"recipe.pe_chupe_de_camarones.step6.title" = "Cook potatoes and rice";
"recipe.pe_chupe_de_camarones.step7.body" = "Add the %i14, %i15, and %i13 and simmer until the vegetables are tender and the soup looks hearty and thick.";
"recipe.pe_chupe_de_camarones.step7.title" = "Add vegetables and corn";
"recipe.pe_chupe_de_camarones.step8.body" = "Stir in the %i16 and add the peeled shrimp. Simmer gently until the shrimp are just cooked through.";
"recipe.pe_chupe_de_camarones.step8.title" = "Add milk and shrimp";
"recipe.pe_chupe_de_camarones.step9.body" = "Crack the %i18 into the simmering soup so they set in the broth, then crumble in the %i17 and let it warm through.";
"recipe.pe_chupe_de_camarones.step9.title" = "Set eggs and add cheese";
