"recipe.pl_ryba_po_grecku.step3.title" = "Prep the vegetables";
"recipe.pl_ryba_po_grecku.step4.body" = "Heat %i10 in a saucepan, add onion, and cook until softened. Add the grated vegetables and cook while stirring until they begin to soften.";
"recipe.pl_ryba_po_grecku.step4.title" = "Start the vegetable base";
"recipe.pl_ryba_po_grecku.step5.body" = "Stir in %i11, then add %i12 and %i13. Add %i14, %i15, %i16, %i17, and %i18, and simmer gently until the vegetables are tender and the sauce is thick and cohesive.";
"recipe.pl_ryba_po_grecku.step5.title" = "Simmer the tomato sauce";
"recipe.pl_ryba_po_grecku.step6.body" = "Arrange the fried fish in a serving dish and cover evenly with the hot vegetable-tomato sauce so the fish is well coated.";
"recipe.pl_ryba_po_grecku.step6.title" = "Layer fish and sauce";
"recipe.pl_ryba_po_grecku.step7.body" = "Cool completely, cover, and refrigerate so the flavors develop and the fish absorbs the sauce.";
"recipe.pl_ryba_po_grecku.step7.title" = "Chill to meld flavors";
"recipe.pl_ryba_po_grecku.step8.body" = "Serve the dish cold or at cool room temperature, spooning plenty of vegetable sauce over each portion.";
"recipe.pl_ryba_po_grecku.step8.title" = "Serve";
