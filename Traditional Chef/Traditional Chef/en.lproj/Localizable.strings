"recipe.it_calamari_fritti.drink.summary" = "White wine (Vermentino)";
"recipe.it_calamari_fritti.info" = "A classic Italian antipasto of squid cut into rings, lightly floured, and fried quickly in hot oil until pale golden and crisp. Traditionally served immediately with lemon and a pinch of salt, it is common along coastal regions and enjoyed as a shared starter with a bright, clean finish.";
"recipe.it_calamari_fritti.info.summary" = "Coastal fried squid";
"recipe.it_calamari_fritti.name" = "Fried calamari";
"recipe.it_calamari_fritti.step1.body" = "Pat the %i1 very dry, then cut the bodies into rings and keep the tentacles whole.";
"recipe.it_calamari_fritti.step1.title" = "Prep the squid";
"recipe.it_calamari_fritti.step2.body" = "Pour %i3 into a deep pot and heat it until frying temperature is reached.";
"recipe.it_calamari_fritti.step2.title" = "Heat the oil";
"recipe.it_calamari_fritti.step3.body" = "Toss the squid in %i2 to coat lightly, then shake off the excess flour.";
"recipe.it_calamari_fritti.step3.title" = "Flour the squid";
"recipe.it_calamari_fritti.step4.body" = "Fry the squid in small batches until just pale golden and crisp, then lift it out with a slotted spoon.";
"recipe.it_calamari_fritti.step4.title" = "Fry the squid";
"recipe.it_calamari_fritti.step5.body" = "Drain on paper towels and season immediately with %i5.";
"recipe.it_calamari_fritti.step5.title" = "Drain and season";
"recipe.it_calamari_fritti.step6.body" = "Transfer to a platter and serve right away with %i4 for squeezing.";
