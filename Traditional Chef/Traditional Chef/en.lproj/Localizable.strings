"recipe.gb_trifle.drink.body" = "A small glass of sherry or tawny port matches the traditional flavours of the trifle. For a non-alcoholic option, serve strong tea, sparkling water, or elderflower cordial.";
"recipe.gb_trifle.drink.summary" = "Sherry";
"recipe.gb_trifle.info" = "A traditional British trifle of sponge soaked with sherry and raspberry jam, layered with fruit and jelly, topped with custard and whipped cream, then chilled before serving. It is a classic celebration dessert for family gatherings and holidays, served cold from a glass bowl.";
"recipe.gb_trifle.info.summary" = "Layered trifle bowl";
"recipe.gb_trifle.name" = "Trifle";
"recipe.gb_trifle.step1.body" = "Dissolve the %i6 in hot %i7, stir until clear, then leave to cool until no longer warm but still fluid.";
"recipe.gb_trifle.step1.title" = "Prepare jelly";
"recipe.gb_trifle.step10.body" = "Chill the trifle again until the custard is cold and set enough to hold the cream.";
"recipe.gb_trifle.step10.title" = "Chill custard layer";
"recipe.gb_trifle.step11.body" = "Whip the %i13 with %i14 and %i15 until softly billowing and spreadable.";
"recipe.gb_trifle.step11.title" = "Whip cream";
"recipe.gb_trifle.step12.body" = "Spoon and spread the whipped cream over the custard, then scatter over the %i16.";
"recipe.gb_trifle.step12.title" = "Top trifle";
"recipe.gb_trifle.step13.body" = "Chill briefly so the top is firm and the layers are thoroughly cold.";
"recipe.gb_trifle.step13.title" = "Final chill";
"recipe.gb_trifle.step14.body" = "Serve the trifle cold, spooning down through all layers in each portion.";
"recipe.gb_trifle.step14.title" = "Serve";
"recipe.gb_trifle.step2.body" = "Cut the %i1 into slices or chunks, spread with %i2, place in the trifle bowl, and sprinkle over %i3.";
"recipe.gb_trifle.step2.title" = "Prepare sponge layer";
"recipe.gb_trifle.step3.body" = "Hull and slice the %i4, then layer them with %i5 over the sponge.";
"recipe.gb_trifle.step3.title" = "Prepare fruit";
"recipe.gb_trifle.step4.body" = "Pour the cooled jelly over the fruit and sponge layers.";
"recipe.gb_trifle.step4.title" = "Add jelly";
"recipe.gb_trifle.step5.body" = "Chill the bowl until the jelly layer is fully set.";
"recipe.gb_trifle.step5.title" = "Chill to set jelly";
"recipe.gb_trifle.step6.body" = "For the custard, heat the %i8 and %i9 with %i12 until hot but not boiling.";
"recipe.gb_trifle.step6.title" = "Heat custard dairy";
"recipe.gb_trifle.step7.body" = "Whisk the %i10 with %i11, pour in the hot dairy gradually, then return to gentle heat and stir until the custard thickens enough to coat a spoon.";
"recipe.gb_trifle.step7.title" = "Finish custard";
"recipe.gb_trifle.step8.body" = "Pass the custard through a fine sieve and cool until just warm, stirring occasionally to prevent a skin.";
"recipe.gb_trifle.step8.title" = "Strain custard";
"recipe.gb_trifle.step9.body" = "Pour the cooled custard over the set jelly layer and smooth the top.";
"recipe.gb_trifle.step9.title" = "Add custard layer";
