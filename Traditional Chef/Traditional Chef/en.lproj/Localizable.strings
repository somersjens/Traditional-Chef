"recipe.ch_papet_vaudois.drink.body" = "Serve with a dry Vaud white wine such as Chasselas, which matches the gentle sweetness of leek and the richness of the sausage. A light lager also works well. For a non-alcoholic option, serve hot black tea or sparkling apple juice.";
"recipe.ch_papet_vaudois.drink.summary" = "White wine (Chasselas)";
"recipe.ch_papet_vaudois.info" = "Papet Vaudois is the emblematic dish of the canton of Vaud, made from slowly cooked leeks and potatoes with Vaud cabbage sausage. The vegetables are cooked down to a soft, spoonable texture rather than mashed, and the dish is traditionally served hot as a hearty regional meal in French-speaking Switzerland.";
"recipe.ch_papet_vaudois.info.summary" = "Vaud sausage and leeks";
"recipe.ch_papet_vaudois.name" = "Papet Vaudois";
"recipe.ch_papet_vaudois.step1.body" = "Trim and wash %i3, peel %i4 and %i5, slice the leek, dice the potatoes, and finely chop the onion.";
"recipe.ch_papet_vaudois.step1.title" = "Prepare the vegetables";
"recipe.ch_papet_vaudois.step2.body" = "Place %i1 in a saucepan, cover with %i2, bring just to a simmer, and cook gently without boiling hard.";
"recipe.ch_papet_vaudois.step2.title" = "Poach the sausage";
"recipe.ch_papet_vaudois.step3.body" = "Melt %i6 in a large pot, add the onion and leek, and cook gently until softened.";
"recipe.ch_papet_vaudois.step3.title" = "Start the papet";
"recipe.ch_papet_vaudois.step4.body" = "Pour in %i7 and %i8, season lightly with some of %i9 and %i10, and let the leek cook until it begins to collapse.";
"recipe.ch_papet_vaudois.step4.title" = "Add wine and stock";
"recipe.ch_papet_vaudois.step5.body" = "Add the potatoes to the pot and simmer gently until the vegetables are very soft and the mixture becomes thick and spoonable while the pieces still remain visible.";
"recipe.ch_papet_vaudois.step5.title" = "Cook the potatoes";
"recipe.ch_papet_vaudois.step6.body" = "Adjust the texture with a little cooking liquid from the sausage if needed, then season with the remaining salt and black pepper.";
"recipe.ch_papet_vaudois.step6.title" = "Finish the papet";
"recipe.ch_papet_vaudois.step7.body" = "Lift the sausage from the cooking liquid, let it rest briefly, and cut it into thick slices.";
"recipe.ch_papet_vaudois.step7.title" = "Slice the sausage";
"recipe.ch_papet_vaudois.step8.body" = "Spoon the papet onto warm plates, place the sausage on top, and serve immediately with %i11.";
"recipe.ch_papet_vaudois.step8.title" = "Serve";
