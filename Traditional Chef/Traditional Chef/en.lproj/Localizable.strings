"recipe.my_satay.step2.title" = "Blend satay marinade";
"recipe.my_satay.step3.body" = "Mix the chicken with the marinade until evenly coated. Leave it to absorb the seasoning while preparing the peanut sauce and rice cakes.";
"recipe.my_satay.step3.title" = "Marinate the chicken";
"recipe.my_satay.step4.body" = "Soak the %i16 until soft, then drain. Blend the peanut sauce %i14, %i15, soaked chilies, and %i17 with a little %i21 into a smooth paste, and crush the %i13.";
