"recipe.ec_encebollado.drink.body" = "A cold light lager is a classic match for encebollado because it refreshes the palate between spoonfuls of the rich fish and yuca broth. A crisp young white wine also works. For a non-alcoholic option, serve sparkling lime water.";
"recipe.ec_encebollado.drink.summary" = "Beer (Lager)";
"recipe.ec_encebollado.info" = "Encebollado is a traditional Ecuadorian coastal fish soup made with albacore tuna, yuca, tomato, red onion, cilantro, and cumin, then finished with lime-pickled onion and tomato on top. It is commonly served hot for breakfast or lunch with chifles and ají on the side.";
"recipe.ec_encebollado.info.summary" = "Coastal fish yuca soup";
"recipe.ec_encebollado.name" = "Encebollado";
"recipe.ec_encebollado.step1.body" = "Peel and cut %i2. Dice %i4, thinly slice %i5, mince %i6, chop %i10, and cut %i1 into large pieces.";
"recipe.ec_encebollado.step1.title" = "Prepare the ingredients";
"recipe.ec_encebollado.step2.body" = "Place half of the red onion with part of the tomato in a bowl, add %i12 and %i11, and mix well. Let the curtido rest while you prepare the soup.";
"recipe.ec_encebollado.step2.title" = "Make the curtido";
"recipe.ec_encebollado.step3.body" = "Blend %i14 with %i15, %i16, and %i17 until smooth. Set the ají aside for serving.";
"recipe.ec_encebollado.step3.title" = "Make the ají";
"recipe.ec_encebollado.step4.body" = "Heat %i3 in the pot and cook the remaining red onion with the garlic until softened. Add the rest of the tomato, %i7, and %i8, and cook until the mixture becomes fragrant and lightly thickened.";
"recipe.ec_encebollado.step4.title" = "Start the base";
"recipe.ec_encebollado.step5.body" = "Add the yuca and %i9 to the pot, season with salt, and bring to a boil. Lower the heat and simmer until the yuca is tender.";
"recipe.ec_encebollado.step5.title" = "Cook the yuca";
"recipe.ec_encebollado.step6.body" = "Add the tuna pieces and cilantro sprigs to the pot and simmer gently until the fish is just cooked through and the broth has taken on its flavor.";
"recipe.ec_encebollado.step6.title" = "Poach the tuna";
"recipe.ec_encebollado.step7.body" = "Remove the cilantro sprigs. Break the tuna into large flakes and return it to the soup. Taste and adjust the salt, then stir in part of the chopped cilantro.";
"recipe.ec_encebollado.step7.title" = "Finish the broth";
"recipe.ec_encebollado.step8.body" = "Ladle the encebollado into bowls, top with the curtido, and finish with the remaining cilantro. Serve hot with %i13 and ají on the side.";
"recipe.ec_encebollado.step8.title" = "Serve traditionally";
