"recipe.sg_black_pepper_crab.drink.body" = "An off-dry Riesling helps balance the pepper heat and rich butter-oyster glaze. A crisp lager also works well. For a non-alcoholic option, serve hot Chinese tea or iced barley water.";
"recipe.sg_black_pepper_crab.drink.summary" = "White wine (Riesling)";
"recipe.sg_black_pepper_crab.info" = "Black pepper crab is a classic Singapore seafood dish of chopped mud crab wok-fried with a fragrant black pepper sauce built from butter, aromatics, soy and oyster sauce. It is typically served hot at zi char or seafood restaurants and eaten communally with steamed rice.";
"recipe.sg_black_pepper_crab.info.summary" = "Peppery crab stir-fry";
"recipe.sg_black_pepper_crab.name" = "Black pepper crab";
"recipe.sg_black_pepper_crab.step1.body" = "Clean the %i1, remove the inedible parts, chop into serving pieces, and crack the claws so the seasoning can penetrate.";
"recipe.sg_black_pepper_crab.step1.title" = "Prepare the crab";
"recipe.sg_black_pepper_crab.step2.body" = "Toss the crab pieces with %i2, %i3, and a little %i4 until lightly coated.";
"recipe.sg_black_pepper_crab.step2.title" = "Season the crab";
"recipe.sg_black_pepper_crab.step3.body" = "Finely chop the %i7, %i8, %i9, %i10, and %i19. In a small bowl, combine the %i14, %i15, %i16, %i17, %i20, and water.";
"recipe.sg_black_pepper_crab.step3.title" = "Prepare aromatics and sauce";
