"recipe.it_pasta_alla_norma.step4.body" = "Add %i5, break them up, and simmer until thick and glossy. Season the sauce with salt.";
"recipe.it_pasta_alla_norma.step4.title" = "Simmer the sauce";
"recipe.it_pasta_alla_norma.step5.body" = "Bring a large pot of water to a rolling boil and season it with salt.";
"recipe.it_pasta_alla_norma.step5.title" = "Boil the water";
"recipe.it_pasta_alla_norma.step6.body" = "Add %i1 and cook until al dente. Reserve some starchy pasta water, then drain.";
"recipe.it_pasta_alla_norma.step6.title" = "Cook the pasta";
"recipe.it_pasta_alla_norma.step7.body" = "Toss the pasta with the tomato sauce, loosening with a splash of reserved pasta water if needed.";
"recipe.it_pasta_alla_norma.step7.title" = "Combine pasta and sauce";
"recipe.it_pasta_alla_norma.step8.body" = "Fold in most of the fried eggplant and tear in %i3, keeping a little eggplant for the top.";
"recipe.it_pasta_alla_norma.step8.title" = "Add eggplant and basil";
"recipe.it_pasta_alla_norma.step9.body" = "Plate the pasta, top with the remaining eggplant, and grate %i7 over each portion.";
"recipe.it_pasta_alla_norma.step9.title" = "Finish and serve";
