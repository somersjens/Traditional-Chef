"recipe.tw_lu_rou_fan.step3.title" = "Boil eggs";
"recipe.tw_lu_rou_fan.step4.body" = "Heat %i11 in a wok or deep skillet and cook the shallots until fragrant and lightly golden, then add the garlic briefly.";
"recipe.tw_lu_rou_fan.step4.title" = "Fry aromatics";
"recipe.tw_lu_rou_fan.step5.body" = "Add the pork belly and cook until the fat renders and the meat loses its raw color.";
"recipe.tw_lu_rou_fan.step5.title" = "Render pork";
"recipe.tw_lu_rou_fan.step6.body" = "Add the %i4, %i5, %i6, %i7, and %i8, then stir until the pork is evenly coated.";
"recipe.tw_lu_rou_fan.step6.title" = "Season the braise";
"recipe.tw_lu_rou_fan.step7.body" = "Add %i9 and the peeled eggs, bring to a gentle simmer, then cover partially and braise until the pork is tender and the sauce is rich.";
"recipe.tw_lu_rou_fan.step7.title" = "Braise pork and eggs";
"recipe.tw_lu_rou_fan.step8.body" = "Bring %i15 to a boil and blanch the %i14 until tender-crisp, then drain.";
"recipe.tw_lu_rou_fan.step8.title" = "Blanch bok choy";
"recipe.tw_lu_rou_fan.step9.body" = "Let the cooked rice rest covered briefly, then fluff.";
