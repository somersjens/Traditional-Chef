"recipe.ro_tochitura.drink.body" = "A light to medium-bodied Romanian red such as Fetească Neagră pairs well with the pork, garlic, and sausages. For a non-alcoholic pairing, serve sparkling water or still water.";
"recipe.ro_tochitura.drink.summary" = "Red wine (Fetească Neagră)";
"recipe.ro_tochitura.info" = "Tochitură is a traditional Romanian pork dish, especially associated with Moldavia, made by slowly frying and stewing pork and sausages with garlic, wine, and thyme until rich and glossy. It is classically served hot with mămăligă, fried eggs, and salty sheep cheese, making it a festive and substantial main course.";
"recipe.ro_tochitura.info.summary" = "Festive pork skillet";
"recipe.ro_tochitura.name" = "Tochitură";
"recipe.ro_tochitura.step1.body" = "Cut %i1 into medium cubes, slice %i2, crush %i4, and crumble or grate %i13 for serving.";
"recipe.ro_tochitura.step1.title" = "Prepare the ingredients";
"recipe.ro_tochitura.step2.body" = "Melt %i3 in the heavy skillet, add the pork, and cook over medium heat until the meat loses its raw color and begins to render.";
"recipe.ro_tochitura.step2.title" = "Start the pork";
"recipe.ro_tochitura.step3.body" = "Lower the heat and cook the pork slowly in its own fat until tender and well browned, stirring from time to time.";
"recipe.ro_tochitura.step3.title" = "Cook the pork gently";
"recipe.ro_tochitura.step4.body" = "Add the sausage, garlic, %i6, %i7, and %i8, then cook until the sausage is lightly browned and fragrant.";
"recipe.ro_tochitura.step4.title" = "Add the sausage and seasonings";
"recipe.ro_tochitura.step5.body" = "Pour in %i5 and cook until it reduces and the meat is coated in a glossy, savory sauce.";
"recipe.ro_tochitura.step5.title" = "Deglaze with wine";
"recipe.ro_tochitura.step6.body" = "Bring %i10 to a boil in the saucepan, add %i11, then pour in %i9 gradually while whisking.";
"recipe.ro_tochitura.step6.title" = "Start the mămăligă";
"recipe.ro_tochitura.step7.body" = "Cook over low heat, stirring often, until the mămăligă is thick, smooth, and pulls slightly from the sides of the pan.";
"recipe.ro_tochitura.step7.title" = "Cook the mămăligă";
"recipe.ro_tochitura.step8.body" = "Cook %i12 in the frying pan until the whites are set and the yolks remain soft.";
"recipe.ro_tochitura.step8.title" = "Fry the eggs";
"recipe.ro_tochitura.step9.body" = "Spoon the mămăligă onto plates, top with the tochitură, add a fried egg to each serving, and finish with the telemea.";
"recipe.ro_tochitura.step9.title" = "Serve";
