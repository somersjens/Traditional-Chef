"recipe.mt_bragioli.drink.body" = "A medium-bodied red wine such as Merlot or a soft Cabernet blend pairs well with the slow-cooked beef and tomato sauce. A good non-alcoholic option is sparkling water or a dark grape juice spritzer.";
"recipe.mt_bragioli.drink.summary" = "Red wine (Merlot)";
"recipe.mt_bragioli.info" = "Bragioli are a traditional Maltese family dish of thin beef slices wrapped around a savory filling, then slowly braised in a rich tomato and red wine sauce. They are classically served hot with the sauce, peas, and mashed potatoes, and are also associated with Sunday cooking and festive home meals.";
"recipe.mt_bragioli.info.summary" = "Stuffed beef rolls";
"recipe.mt_bragioli.name" = "Bragioli";
"recipe.mt_bragioli.step1.body" = "Chop %i3, %i5, %i6, %i7, and the first %i8 very finely. Mix them with %i2, %i4, %i9, and %i10 until the filling is evenly combined.";
"recipe.mt_bragioli.step1.title" = "Prepare the filling";
"recipe.mt_bragioli.step2.body" = "Lay out %i1, divide the filling among them, roll them up tightly, fold in the sides, and tie each bragiola securely with kitchen string.";
"recipe.mt_bragioli.step2.title" = "Fill and tie the beef";
"recipe.mt_bragioli.step3.body" = "Heat %i11 in the heavy pot and brown the bragioli well on all sides. Lift them out and set them aside.";
"recipe.mt_bragioli.step3.title" = "Brown the bragioli";
"recipe.mt_bragioli.step4.body" = "Chop the second %i12, slice %i14, and chop %i15. Cook the onion, %i13, and carrot in the same pot until softened, then stir in the tomatoes and %i16.";
"recipe.mt_bragioli.step4.title" = "Build the sauce";
"recipe.mt_bragioli.step5.body" = "Pour in %i17 and %i18, add %i19, %i21, and %i22, and bring the sauce to a gentle simmer.";
"recipe.mt_bragioli.step5.title" = "Add the braising liquid";
"recipe.mt_bragioli.step6.body" = "Return the bragioli to the pot, cover, and simmer gently until the beef is tender and the sauce has thickened. Add %i20 for the last part of the cooking so they stay bright and tender.";
"recipe.mt_bragioli.step6.title" = "Braise the bragioli";
"recipe.mt_bragioli.step7.body" = "Peel %i23 and boil them in salted water until tender, then drain them well.";
"recipe.mt_bragioli.step7.title" = "Cook the potatoes";
"recipe.mt_bragioli.step8.body" = "Mash the potatoes with %i24, %i25, and %i26 until smooth and soft.";
"recipe.mt_bragioli.step8.title" = "Mash the potatoes";
"recipe.mt_bragioli.step9.body" = "Remove the strings from the bragioli and serve them hot with the sauce, peas, and mashed potatoes.";
"recipe.mt_bragioli.step9.title" = "Serve";
