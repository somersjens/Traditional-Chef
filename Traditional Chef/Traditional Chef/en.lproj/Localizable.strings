"recipe.de_kaesekuchen.drink.body" = "Pair with a lightly sweet Riesling that complements the tangy quark and vanilla without tasting heavy. A wheat beer can also work if you prefer beer. For a non-alcoholic option, serve coffee, black tea, or sparkling water.";
"recipe.de_kaesekuchen.drink.summary" = "White wine (Riesling)";
"recipe.de_kaesekuchen.info" = "Käsekuchen is a classic German baked cheesecake made with quark for a light, tangy filling set with eggs and a little starch. It is traditionally baked on a simple shortcrust base and served cooled so the filling slices cleanly while staying creamy. It is a staple of German home baking and cafés, often enjoyed with coffee.";
"recipe.de_kaesekuchen.info.summary" = "Café quark cheesecake";
"recipe.de_kaesekuchen.name" = "German cheesecake";
"recipe.de_kaesekuchen.step1.body" = "Combine %i1, %i2, and %i3, then rub in %i4 and mix in %i5 until a smooth dough forms. Chill it briefly so it rolls cleanly.";
"recipe.de_kaesekuchen.step1.title" = "Make the crust";
"recipe.de_kaesekuchen.step2.body" = "Grease the springform with %i15, dust with %i16, and line the base with parchment. Roll out the dough and press it into the base and slightly up the sides.";
"recipe.de_kaesekuchen.step2.title" = "Line the pan";
"recipe.de_kaesekuchen.step3.body" = "Split %i12. Zest %i13. Mix %i6 with %i7, %i14, the vanilla, and the lemon zest until smooth, then mix in %i9.";
"recipe.de_kaesekuchen.step3.title" = "Prepare the filling";
"recipe.de_kaesekuchen.step4.body" = "Mix %i8 until smooth with %i10, then add it to the filling along with %i11 and mix until fully combined.";
"recipe.de_kaesekuchen.step4.title" = "Add starch and liquids";
"recipe.de_kaesekuchen.step5.body" = "Pour the quark filling into the prepared crust and smooth the top.";
"recipe.de_kaesekuchen.step5.title" = "Fill the cake";
"recipe.de_kaesekuchen.step6.body" = "Bake until the centre is just set and the top is lightly coloured without cracking excessively.";
"recipe.de_kaesekuchen.step6.title" = "Bake the cheesecake";
"recipe.de_kaesekuchen.step7.body" = "Turn off the oven, crack the door, and let the cake cool gradually to prevent collapsing, then cool it fully on a rack before slicing.";
"recipe.de_kaesekuchen.step7.title" = "Cool the cheesecake slowly";
