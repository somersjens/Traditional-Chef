"recipe.bo_sajta_de_pollo.drink.body" = "A fresh medium-bodied white wine such as unoaked Chardonnay works well with the savory chicken and yellow chili sauce. A light lager also pairs well. For a non-alcoholic option, serve sparkling water with lime.";
"recipe.bo_sajta_de_pollo.drink.summary" = "White wine (Chardonnay)";
"recipe.bo_sajta_de_pollo.info" = "Sajta de Pollo is a traditional Bolivian chicken stew, especially associated with La Paz, made with yellow chili, onion, garlic, cumin, and broth, then served with potatoes, chuño, and rice. It is a hearty festive dish commonly prepared for family meals and special occasions.";
"recipe.bo_sajta_de_pollo.info.summary" = "Yellow chicken stew";
"recipe.bo_sajta_de_pollo.name" = "Sajta de pollo";
"recipe.bo_sajta_de_pollo.step1.body" = "Rinse %i15 well and soak it in water until softened enough to peel and cook.";
"recipe.bo_sajta_de_pollo.step1.title" = "Soak the chuño";
