"recipe.gb_fish_and_chips.drink.body" = "A classic pairing is a British pale ale or a crisp dry cider. For wine, a dry Sauvignon Blanc works well. For a non-alcoholic option, serve sparkling water with lemon or strong iced tea.";
"recipe.gb_fish_and_chips.drink.summary" = "Beer (Pale ale)";
"recipe.gb_fish_and_chips.info" = "A traditional British main of white fish in a crisp batter with thick-cut chips, deep-fried and served immediately with tartare sauce and lemon. It is a classic pub and seaside dish, best eaten hot with vinegar and salt at the table.";
"recipe.gb_fish_and_chips.info.summary" = "Crispy fish and chips";
"recipe.gb_fish_and_chips.name" = "Fish and chips";
"recipe.gb_fish_and_chips.step1.body" = "Peel the %i10 and cut them into thick chips, then rinse and drain them well.";
"recipe.gb_fish_and_chips.step1.title" = "Prepare potatoes";
"recipe.gb_fish_and_chips.step10.body" = "Serve the fish and chips immediately with tartare sauce, %i20, and %i21 at the table.";
"recipe.gb_fish_and_chips.step10.title" = "Serve";
"recipe.gb_fish_and_chips.step2.body" = "Finely chop the %i14, %i15, and %i16, then mix with the %i13, %i17, %i18, and %i19 and chill until serving.";
"recipe.gb_fish_and_chips.step2.title" = "Make tartare sauce";
"recipe.gb_fish_and_chips.step3.body" = "Pat the %i1 dry, season with %i2 and %i3, and dust lightly with the %i4.";
"recipe.gb_fish_and_chips.step3.title" = "Prepare fish";
"recipe.gb_fish_and_chips.step4.body" = "Whisk the %i5, %i6, and %i7, then whisk in the %i8 and ice-cold %i9 to make a smooth thick batter.";
"recipe.gb_fish_and_chips.step4.title" = "Make batter";
"recipe.gb_fish_and_chips.step5.body" = "Heat the %i12 and fry the chips gently in batches until softened and pale, then lift out to drain.";
"recipe.gb_fish_and_chips.step5.title" = "Blanch chips";
"recipe.gb_fish_and_chips.step6.body" = "Raise the heat of the frying fat so it is ready for crisping the chips and frying the fish.";
"recipe.gb_fish_and_chips.step6.title" = "Heat oil hotter";
"recipe.gb_fish_and_chips.step7.body" = "Dip each piece of fish in the batter, let excess drip off, then fry until the batter is deep golden and crisp and the fish is cooked through.";
"recipe.gb_fish_and_chips.step7.title" = "Fry fish";
"recipe.gb_fish_and_chips.step8.body" = "Lift the fish out and drain on a tray while the chips finish frying.";
"recipe.gb_fish_and_chips.step8.title" = "Drain fish";
