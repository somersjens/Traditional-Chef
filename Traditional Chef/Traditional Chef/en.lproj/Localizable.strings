"recipe.lb_kafta.drink.summary" = "Red wine (Lebanese blend)";
"recipe.lb_kafta.info" = "Lebanese kafta are seasoned ground-meat kebabs mixed with onion and parsley, shaped onto flat skewers and grilled until lightly charred and juicy. They are typically served hot as part of a mezze-and-grill table, with grilled tomatoes and onions, warm pita bread, and tarator, a lemony tahini-garlic sauce.";
"recipe.lb_kafta.info.summary" = "Charcoal kafta skewers";
"recipe.lb_kafta.name" = "Grilled kafta";
"recipe.lb_kafta.step1.body" = "Grate the %i2 and squeeze out excess liquid. Finely chop the %i3. In a bowl, combine the %i1 with the onion, parsley, %i6, %i5, and %i4, mixing until evenly seasoned and slightly sticky.";
"recipe.lb_kafta.step1.title" = "Prepare the kafta mixture";
"recipe.lb_kafta.step2.body" = "Divide the mixture into equal portions and press each portion firmly along a flat skewer into an even kebab shape, smoothing the surface so it holds together on the grill.";
"recipe.lb_kafta.step2.title" = "Shape onto skewers";
"recipe.lb_kafta.step3.body" = "Place the skewers on a tray and refrigerate to help the kebabs firm up before grilling.";
"recipe.lb_kafta.step3.title" = "Chill to set";
"recipe.lb_kafta.step4.body" = "Preheat the grill to medium-high and clean the grates. Lightly brush the grates and the grill vegetables with %i9.";
"recipe.lb_kafta.step4.title" = "Preheat and prep the grill";
"recipe.lb_kafta.step5.body" = "Grill the kafta, turning carefully, until browned and cooked through. Grill the %i7 and %i8 alongside until charred and tender.";
"recipe.lb_kafta.step5.title" = "Grill the kafta and vegetables";
"recipe.lb_kafta.step6.body" = "In a bowl, whisk %i10 with %i11 and %i14 until thickened, then whisk in crushed %i12. Add %i13 gradually while whisking until the sauce becomes smooth, creamy, and pourable.";
"recipe.lb_kafta.step6.title" = "Make the tarator sauce";
"recipe.lb_kafta.step7.body" = "Slide the kafta off the skewers onto a platter, add the grilled tomatoes and onion, and serve hot with warm %i15 and tarator on the side.";
"recipe.lb_kafta.step7.title" = "Serve";
