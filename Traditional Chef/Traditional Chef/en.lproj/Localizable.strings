"recipe.co_postre_de_natas.drink.body" = "Pair with a lightly sweet Moscato or a late-harvest white that complements the dairy richness and gentle cinnamon. Coffee also pairs naturally with the sweetness. Non-alcoholic option: black coffee or cinnamon tea.";
"recipe.co_postre_de_natas.drink.summary" = "Sweet wine (Moscato)";
"recipe.co_postre_de_natas.info" = "Postre de natas is a traditional Colombian dessert made by slowly heating milk so it forms delicate skins, which are lifted off and layered with sweetened condensed milk and a touch of cinnamon. The result is a rich, creamy, lightly spiced chilled dessert, commonly served in squares or spooned from a dish after resting in the refrigerator.";
"recipe.co_postre_de_natas.info.summary" = "Milk-skin dessert";
"recipe.co_postre_de_natas.name" = "Postre de natas";
"recipe.co_postre_de_natas.step1.body" = "Set out a shallow dish for layering and have %i2 and %i3 ready so skins can be layered immediately.";
"recipe.co_postre_de_natas.step1.title" = "Prepare the dish";
"recipe.co_postre_de_natas.step2.body" = "Pour %i1 into a wide pot and heat very gently until it steams and a skin forms on the surface. Keep the heat low so the milk does not boil hard.";
"recipe.co_postre_de_natas.step2.title" = "Heat the milk to form skins";
"recipe.co_postre_de_natas.step3.body" = "As each milk skin forms, lift it carefully with a slotted spoon and lay it flat in the dish. Continue heating and collecting until you have enough skins for multiple layers.";
"recipe.co_postre_de_natas.step3.title" = "Lift and collect the skins";
"recipe.co_postre_de_natas.step4.body" = "Spread a thin layer of condensed milk over the skins and dust with cinnamon, then repeat with more skins and condensed milk until all are used, finishing with a cinnamon dusting.";
"recipe.co_postre_de_natas.step4.title" = "Layer with condensed milk and cinnamon";
"recipe.co_postre_de_natas.step5.body" = "Refrigerate until fully chilled and the layers are set for clean serving.";
"recipe.co_postre_de_natas.step5.title" = "Chill to set";
"recipe.co_postre_de_natas.step6.body" = "Slice into portions or scoop servings, keeping the layers intact.";
"recipe.co_postre_de_natas.step6.title" = "Serve";
