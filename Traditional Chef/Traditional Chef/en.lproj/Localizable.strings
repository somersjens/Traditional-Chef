"recipe.ru_solyanka.drink.body" = "A medium-bodied dry red with moderate tannins pairs well with the smoky meats and tomato-pickle tang, while a crisp dry white can also work if you prefer something lighter. Non-alcoholic pairing: hot black tea or sparkling water with lemon.";
"recipe.ru_solyanka.drink.summary" = "Red wine";
"recipe.ru_solyanka.info" = "Solyanka is a traditional Russian soup with a bold sour-salty character, made by simmering a mix of meats with onions, pickles, tomato, and briny additions like olives and capers, then finishing each bowl with lemon and sour cream. It is served hot as a robust starter, often as part of a zakuski-style meal or a warming winter table.";
"recipe.ru_solyanka.info.summary" = "Tangy winter meat soup";
"recipe.ru_solyanka.name" = "Solyanka";
"recipe.ru_solyanka.step1.body" = "Slice the %i4 thinly. Cut the %i1 into bite-size strips. Dice the %i5 and slice the %i9. Cut the %i15 into wedges.";
"recipe.ru_solyanka.step1.title" = "Prep the ingredients";
"recipe.ru_solyanka.step2.body" = "Heat %i11 in a skillet over medium heat and cook the onion until soft and lightly golden.";
"recipe.ru_solyanka.step2.title" = "Sauté the onion";
"recipe.ru_solyanka.step3.body" = "Stir in %i7 and cook briefly until it darkens slightly and smells toasted.";
"recipe.ru_solyanka.step3.title" = "Cook the tomato base";
"recipe.ru_solyanka.step4.body" = "Transfer the onion-tomato mixture to a pot, add the %i8, %i12, and %i13, and bring to a gentle simmer.";
"recipe.ru_solyanka.step4.title" = "Start the soup";
"recipe.ru_solyanka.step5.body" = "Add the beef and simmer until it begins to turn tender, skimming if needed.";
"recipe.ru_solyanka.step5.title" = "Simmer the meats";
"recipe.ru_solyanka.step6.body" = "Add the %i2, %i3, diced pickles, and %i6, and simmer so the flavors meld.";
"recipe.ru_solyanka.step6.title" = "Add smoked meats and pickles";
"recipe.ru_solyanka.step7.body" = "Add the olives and %i10 and simmer briefly so they warm through without losing their bite.";
"recipe.ru_solyanka.step7.title" = "Finish with briny additions";
"recipe.ru_solyanka.step8.body" = "Taste and adjust %i14 so the soup is balanced between salty and sour.";
"recipe.ru_solyanka.step8.title" = "Season";
"recipe.ru_solyanka.step9.body" = "Ladle into bowls and serve hot with a spoon of %i16 and lemon wedges for squeezing in at the table.";
"recipe.ru_solyanka.step9.title" = "Serve";
