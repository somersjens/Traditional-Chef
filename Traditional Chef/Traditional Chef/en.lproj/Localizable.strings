"recipe.cl_brazo_de_reina.drink.body" = "A Chilean Brut sparkling wine pairs well with the sweet manjar and light sponge by refreshing the palate. If you prefer still wine, choose a lightly sweet Moscato. Non-alcoholic option: strong black tea or coffee, or a cold glass of milk.";
"recipe.cl_brazo_de_reina.drink.summary" = "Sparkling wine (Brut)";
"recipe.cl_brazo_de_reina.info" = "Brazo de Reina is a classic Chilean rolled sponge cake, baked as a thin sheet, then spread with manjar and rolled into a tight spiral. It is typically served in neat slices with a dusting of powdered sugar, enjoyed for afternoon tea or as a simple celebratory dessert.";
"recipe.cl_brazo_de_reina.info.summary" = "Manjar sponge roll";
"recipe.cl_brazo_de_reina.name" = "Brazo de reina";
"recipe.cl_brazo_de_reina.step1.body" = "Heat the oven and line a rimmed baking sheet with parchment paper so the sponge releases cleanly.";
"recipe.cl_brazo_de_reina.step1.title" = "Prepare the pan and oven";
"recipe.cl_brazo_de_reina.step10.body" = "Dust the top with powdered sugar, trim the ends, and slice to serve.";
"recipe.cl_brazo_de_reina.step10.title" = "Finish and serve";
"recipe.cl_brazo_de_reina.step2.body" = "Beat %i1 with %i2 until very pale, thick, and airy, so the batter holds a ribbon when lifted.";
"recipe.cl_brazo_de_reina.step2.title" = "Whip eggs and sugar";
"recipe.cl_brazo_de_reina.step3.body" = "Sift %i3, %i4, and %i5 over the foam and fold gently with a spatula until just combined, then fold in %i6 without deflating.";
"recipe.cl_brazo_de_reina.step3.title" = "Fold in dry ingredients";
"recipe.cl_brazo_de_reina.step4.body" = "Pour onto the prepared sheet and spread evenly to the corners in a thin, uniform layer.";
"recipe.cl_brazo_de_reina.step4.title" = "Spread the batter";
"recipe.cl_brazo_de_reina.step5.body" = "Bake until the surface springs back lightly and the sponge is set but still flexible for rolling.";
"recipe.cl_brazo_de_reina.step5.title" = "Bake the sponge";
"recipe.cl_brazo_de_reina.step6.body" = "Dust a clean towel with %i8. Turn the hot sponge out onto the towel, peel off the parchment, then roll up the sponge with the towel from the short end to set the shape.";
"recipe.cl_brazo_de_reina.step6.title" = "Roll while warm";
"recipe.cl_brazo_de_reina.step7.body" = "Let the rolled sponge cool completely so it won’t crack when filled.";
"recipe.cl_brazo_de_reina.step7.title" = "Cool the rolled sponge";
