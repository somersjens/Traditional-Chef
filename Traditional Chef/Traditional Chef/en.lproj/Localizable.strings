"recipe.pe_tiradito.drink.body" = "Pair with a crisp Albariño or Sauvignon Blanc to complement the citrusy ají amarillo sauce and delicate fish. A dry sparkling wine also works well. For a non-alcoholic option, serve chicha morada or sparkling water with lime.";
"recipe.pe_tiradito.drink.summary" = "White wine (Albariño)";
"recipe.pe_tiradito.info" = "Tiradito is a Peruvian cold starter of ultra-thin slices of very fresh white fish, arranged like sashimi and dressed with a bright, creamy ají amarillo leche de tigre. Unlike ceviche, the fish is served sliced and sauced to order, keeping a delicate texture while carrying the punch of lime, chili, and aromatics. It is traditionally served immediately, often with sweet potato and crunchy cancha on the side.";
"recipe.pe_tiradito.info.summary" = "Thin fish in ají sauce";
"recipe.pe_tiradito.name" = "Tiradito";
