"recipe.hk_wonton_noodles.drink.body" = "A crisp dry white such as Riesling can work with the delicate shrimp wontons and clear broth without overpowering them. For a non-alcoholic option, serve hot jasmine tea or warm barley water.";
"recipe.hk_wonton_noodles.drink.summary" = "White wine (Riesling)";
"recipe.hk_wonton_noodles.info" = "A traditional Hong Kong noodle soup of springy egg noodles served in a clear savory broth with shrimp-pork wontons. It is a classic cha chaan teng and noodle-shop dish, typically served hot in individual bowls with the noodles blanched separately for their signature texture.";
"recipe.hk_wonton_noodles.info.summary" = "Shrimp wonton noodles";
"recipe.hk_wonton_noodles.name" = "Wonton noodles";
"recipe.hk_wonton_noodles.step1.body" = "Put the %i13, %i14, %i15, %i16, %i17, and %i18 into a stockpot, bring to a boil, then reduce to a gentle simmer.";
"recipe.hk_wonton_noodles.step1.title" = "Start the broth base";
"recipe.hk_wonton_noodles.step10.body" = "Cook the %i22 in the boiling water until springy, then lift and dip briefly in fresh hot water to remove excess starch and alkaline taste before draining well.";
"recipe.hk_wonton_noodles.step10.title" = "Cook and rinse the noodles";
"recipe.hk_wonton_noodles.step11.body" = "Divide the noodles into bowls, add the wontons, and ladle over the hot broth.";
"recipe.hk_wonton_noodles.step11.title" = "Assemble the bowls";
"recipe.hk_wonton_noodles.step12.body" = "Serve the wonton noodles immediately while the noodles are springy and the broth is clear and hot.";
"recipe.hk_wonton_noodles.step12.title" = "Serve immediately";
"recipe.hk_wonton_noodles.step2.body" = "Simmer the broth until deeply savory, skimming as needed, then strain and season with %i19, %i20, and %i21. Keep the broth hot.";
"recipe.hk_wonton_noodles.step2.title" = "Simmer the broth";
"recipe.hk_wonton_noodles.step3.body" = "Peel and devein the %i1, chop most into pieces and mince a small portion into a paste. Finely chop the %i3 and %i4.";
"recipe.hk_wonton_noodles.step3.title" = "Prepare the filling ingredients";
"recipe.hk_wonton_noodles.step4.body" = "Combine shrimp, %i2, spring onion, ginger, %i5, %i6, %i7, %i8, %i9, %i10, and %i11, then stir in one direction until sticky and cohesive.";
"recipe.hk_wonton_noodles.step4.title" = "Mix the wonton filling";
"recipe.hk_wonton_noodles.step5.body" = "Cover and chill the filling briefly so it firms and is easier to wrap.";
"recipe.hk_wonton_noodles.step5.title" = "Chill the filling";
"recipe.hk_wonton_noodles.step6.body" = "Place filling on each %i12, moisten the edges with water, fold and seal into traditional wonton shapes, and keep them covered.";
"recipe.hk_wonton_noodles.step6.title" = "Wrap the wontons";
"recipe.hk_wonton_noodles.step7.body" = "Bring %i23 to a rolling boil in a large pot.";
"recipe.hk_wonton_noodles.step7.title" = "Prepare the boiling pot";
"recipe.hk_wonton_noodles.step8.body" = "Boil the wontons until they float and the filling is cooked through, then lift them out and keep warm.";
"recipe.hk_wonton_noodles.step8.title" = "Cook the wontons";
"recipe.hk_wonton_noodles.step9.body" = "Briefly blanch the %i24 in the boiling water, then remove and divide among serving bowls.";
"recipe.hk_wonton_noodles.step9.title" = "Blanch the chives";
