"recipe.gb_sussex_pond_pudding.drink.body" = "A small glass of sweet sherry or a light dessert wine suits the rich buttery lemon pudding. For a non-alcoholic option, serve hot black tea or coffee, or hot custard alongside.";
"recipe.gb_sussex_pond_pudding.drink.summary" = "Sweet sherry";
"recipe.gb_sussex_pond_pudding.info" = "A traditional Sussex dessert of suet pastry wrapped around a whole lemon with butter and brown sugar, then steamed for hours until a rich buttery lemon syrup forms a pond when cut. It is classically served hot in slices with pouring cream or custard.";
"recipe.gb_sussex_pond_pudding.info.summary" = "Suet lemon pudding";
