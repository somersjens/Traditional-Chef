"recipe.th_gaeng_phet_ped_yang.step3.title" = "Cook the rice";
"recipe.th_gaeng_phet_ped_yang.step4.body" = "Heat the wok and add the %i3. Cook while stirring until fragrant and slightly thickened, then add the %i2 and fry until aromatic.";
"recipe.th_gaeng_phet_ped_yang.step4.title" = "Crack the coconut cream";
"recipe.th_gaeng_phet_ped_yang.step5.body" = "Add the %i4 and %i5, then season with %i6 and %i7. Stir until the sugar dissolves and the curry is smooth.";
"recipe.th_gaeng_phet_ped_yang.step5.title" = "Build the curry sauce";
