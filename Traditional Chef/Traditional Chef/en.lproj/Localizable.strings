"recipe.se_kalops.step2.body" = "Melt %i3 in a heavy pot and brown the beef in batches so it takes on good color without steaming.";
"recipe.se_kalops.step2.title" = "Brown the beef";
"recipe.se_kalops.step3.body" = "Return all the beef to the pot, add the onion, carrot, remaining salt, %i8, %i9, and %i10, and stir briefly.";
"recipe.se_kalops.step3.title" = "Add the vegetables and spices";
"recipe.se_kalops.step4.body" = "Pour in %i6, bring to a gentle boil, lower the heat, cover, and simmer until the beef is very tender and the broth has thickened lightly.";
"recipe.se_kalops.step4.title" = "Simmer the kalops";
"recipe.se_kalops.step5.body" = "Cook %i11 in water until tender, then drain well.";
"recipe.se_kalops.step5.title" = "Boil the potatoes";
"recipe.se_kalops.step6.body" = "Check the seasoning and stir the kalops gently so the meat stays in pieces and the gravy is smooth.";
"recipe.se_kalops.step6.title" = "Finish the stew";
"recipe.se_kalops.step7.body" = "Serve the kalops hot with boiled potatoes and %i14 on the side.";
"recipe.se_kalops.step7.title" = "Serve traditionally";
