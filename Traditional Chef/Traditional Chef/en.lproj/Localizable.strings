"recipe.eg_mahashi.drink.body" = "Pair with a medium-bodied red such as Grenache or a fruity Syrah that can handle the tomato broth and warm spices. A crisp lager also works well with the herby rice filling. Non-alcoholic option: mint tea or sparkling water with lemon.";
"recipe.eg_mahashi.drink.summary" = "Red wine (Grenache)";
"recipe.eg_mahashi.info" = "Mahashi is a classic Egyptian family dish of vegetables and grape leaves stuffed with seasoned rice and fresh herbs, then gently simmered in a rich tomato broth until the rice is tender and the flavors meld. Served hot as a centerpiece meal, it’s a staple at gatherings and home lunches, prized for its aromatic filling, tender vegetables, and savory tomato base.";
"recipe.eg_mahashi.info.summary" = "Rice-stuffed vegetables";
"recipe.eg_mahashi.name" = "Mahashi";
"recipe.eg_mahashi.step1.body" = "Bring %i20 to a boil. Blanch %i16 briefly to soften, then drain well and set aside.";
"recipe.eg_mahashi.step1.title" = "Prep grape leaves";
"recipe.eg_mahashi.step2.body" = "Hollow %i13 and %i14, keeping the shells intact. Remove seeds from %i15 and keep them whole for stuffing.";
"recipe.eg_mahashi.step2.title" = "Prepare the vegetables";
"recipe.eg_mahashi.step3.body" = "Finely chop %i2, %i3, %i4, %i5, %i6, and %i7. Mix with %i1, %i8, %i9, %i10, %i11, and %i12 until evenly combined.";
"recipe.eg_mahashi.step3.title" = "Make the rice stuffing";
