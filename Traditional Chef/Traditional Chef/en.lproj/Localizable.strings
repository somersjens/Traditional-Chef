"recipe.ru_okroshka.drink.body" = "A crisp, high-acid dry white such as Riesling or Sauvignon Blanc can work alongside the tangy, refreshing flavors, though many prefer no wine with kvass. Non-alcoholic pairing: extra-chilled kvass or sparkling water with lemon.";
"recipe.ru_okroshka.drink.summary" = "White wine (Riesling)";
"recipe.ru_okroshka.info" = "Okroshka is a traditional Russian cold soup built on chilled kvass and a finely chopped mix of boiled potatoes, crisp cucumbers and radishes, scallions and dill, plus eggs and cooked meat, finished with sour cream and mustard for tang and body. It is served very cold, especially in warm weather, with the kvass poured over the chopped ingredients right before eating.";
"recipe.ru_okroshka.info.summary" = "Cold kvass soup";
"recipe.ru_okroshka.name" = "Okroshka";
"recipe.ru_okroshka.step1.body" = "Wash the %i2 and place them in a pot. Place the %i7 in the pot as well so everything can be cooked and cooled.";
"recipe.ru_okroshka.step1.title" = "Prep for boiling";
"recipe.ru_okroshka.step2.body" = "Cover with %i1 and bring to a simmer. Cook until the potatoes are tender and the eggs are hard-set.";
"recipe.ru_okroshka.step2.title" = "Boil potatoes and eggs";
"recipe.ru_okroshka.step3.body" = "Drain and cool the potatoes and eggs until easy to handle. Peel the potatoes and peel the eggs.";
"recipe.ru_okroshka.step3.title" = "Cool and peel";
"recipe.ru_okroshka.step4.body" = "Dice the potatoes, %i3, %i4, eggs, and %i8 into small even pieces. Finely slice %i5 and chop %i6.";
"recipe.ru_okroshka.step4.title" = "Chop the okroshka mix";
"recipe.ru_okroshka.step5.body" = "In a bowl, whisk %i9 with %i10, then season with %i11 and %i12 until well combined.";
"recipe.ru_okroshka.step5.title" = "Make the dressing";
"recipe.ru_okroshka.step6.body" = "Mix the chopped ingredients with the dressing so everything is evenly coated, then add kvass and stir to combine.";
"recipe.ru_okroshka.step6.title" = "Combine and add kvass";
"recipe.ru_okroshka.step7.body" = "Refrigerate until the soup is very cold and the flavors are melded.";
"recipe.ru_okroshka.step7.title" = "Chill thoroughly";
