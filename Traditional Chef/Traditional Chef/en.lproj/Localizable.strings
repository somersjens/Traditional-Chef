"recipe.ge_adjaruli_khachapuri.drink.body" = "A Georgian amber wine such as Rkatsiteli works well with the rich cheese and buttery finish. A crisp lager is also suitable. For a non-alcoholic option, serve chilled tarragon lemonade or sparkling water with lemon.";
"recipe.ge_adjaruli_khachapuri.drink.summary" = "Amber wine (Rkatsiteli)";
"recipe.ge_adjaruli_khachapuri.info" = "Adjaruli khachapuri is a traditional boat-shaped bread from Adjara in western Georgia, baked with a rich cheese filling and finished with egg and butter. It is typically served hot as a main dish, with the egg and butter stirred into the molten cheese before eating by tearing off pieces of crust and dipping them into the center.";
"recipe.ge_adjaruli_khachapuri.info.summary" = "Georgian cheese bread";
"recipe.ge_adjaruli_khachapuri.name" = "Adjaruli khachapuri";
"recipe.ge_adjaruli_khachapuri.step1.body" = "Combine warm %i2 and warm %i3 in a bowl, add %i4 and %i5, and stir until dissolved. Add %i1 and %i6, then mix to a shaggy dough. Add %i7 and knead until smooth and elastic.";
"recipe.ge_adjaruli_khachapuri.step1.title" = "Make the dough base";
"recipe.ge_adjaruli_khachapuri.step2.body" = "Cover the dough and let it rise in a warm place until doubled in size.";
"recipe.ge_adjaruli_khachapuri.step2.title" = "First rise";
"recipe.ge_adjaruli_khachapuri.step3.body" = "Grate the %i8 and %i9 and mix them together. Add the %i10 and a little %i11 to make a thick, spreadable cheese mixture.";
"recipe.ge_adjaruli_khachapuri.step3.title" = "Prepare the cheese filling";
"recipe.ge_adjaruli_khachapuri.step4.body" = "Heat the oven and place the baking tray inside to preheat. Divide the dough into four equal portions and shape them into balls.";
"recipe.ge_adjaruli_khachapuri.step4.title" = "Divide and preheat";
"recipe.ge_adjaruli_khachapuri.step5.body" = "Roll each dough ball into an oval. Roll the long sides inward toward the center and pinch the ends tightly to form boat shapes with an open middle.";
"recipe.ge_adjaruli_khachapuri.step5.title" = "Shape the boats";
"recipe.ge_adjaruli_khachapuri.step6.body" = "Place the shaped dough on the hot tray and fill the center of each boat with the cheese mixture, keeping the raised edges clear.";
"recipe.ge_adjaruli_khachapuri.step6.title" = "Fill the boats";
"recipe.ge_adjaruli_khachapuri.step7.body" = "Bake until the dough is golden and the cheese is melted and bubbling.";
"recipe.ge_adjaruli_khachapuri.step7.title" = "Bake until set";
"recipe.ge_adjaruli_khachapuri.step8.body" = "Remove the breads, make a small well in each center, crack one %i12 into each, and return to the oven just until the whites begin to set and the yolks stay soft.";
"recipe.ge_adjaruli_khachapuri.step8.title" = "Add eggs and finish baking";
"recipe.ge_adjaruli_khachapuri.step9.body" = "Top each khachapuri with %i13 and serve immediately. Stir the egg and butter into the hot cheese at the table, then tear the crust and dip it into the center.";
"recipe.ge_adjaruli_khachapuri.step9.title" = "Finish with butter and serve";
