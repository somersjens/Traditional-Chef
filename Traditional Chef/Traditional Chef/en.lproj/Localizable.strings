"recipe.es_tarta_de_santiago.drink.body" = "Pair with a glass of sweet Moscatel or a lightly sweet sherry to complement the almond richness. A dry Cava also works well to refresh the palate. Non-alcoholic option: espresso or black tea.";
"recipe.es_tarta_de_santiago.drink.summary" = "Sweet wine (Moscatel)";
"recipe.es_tarta_de_santiago.info" = "Tarta de Santiago is the traditional Galician almond cake made simply from ground almonds, sugar, eggs, and a hint of lemon and cinnamon, baked until golden and moist. Once cooled, it is dusted with powdered sugar through the iconic Cross of Saint James stencil and served in slices with coffee after meals, especially around festivals and pilgrim celebrations in Galicia.";
"recipe.es_tarta_de_santiago.info.summary" = "Galician almond cake";
"recipe.es_tarta_de_santiago.name" = "Tarta de Santiago";
"recipe.es_tarta_de_santiago.step1.body" = "Combine %i2 in a saucepan and bring to a gentle boil, stirring to dissolve. Simmer briefly, then stir in lemon juice and let the syrup cool.";
"recipe.es_tarta_de_santiago.step1.title" = "Make the sugar syrup";
"recipe.es_tarta_de_santiago.step2.body" = "Mix semolina, coconut, sugar, and baking powder in a bowl. Add yogurt and melted ghee and mix until evenly moistened and thick.";
"recipe.es_tarta_de_santiago.step2.title" = "Mix the basbousa batter";
"recipe.es_tarta_de_santiago.step3.body" = "Let the batter rest so the semolina hydrates and the mixture firms slightly.";
"recipe.es_tarta_de_santiago.step3.title" = "Rest the batter";
"recipe.es_tarta_de_santiago.step4.body" = "Heat the oven. Grease the pan thoroughly with tahini, spread the batter evenly, and smooth the top. Score into diamond shapes and press an almond into the center of each piece.";
"recipe.es_tarta_de_santiago.step4.title" = "Prepare the pan and top";
"recipe.es_tarta_de_santiago.step5.body" = "Bake until set and deeply golden on top and the edges pull slightly from the pan.";
"recipe.es_tarta_de_santiago.step5.title" = "Bake until golden";
"recipe.es_tarta_de_santiago.step6.body" = "Pour the cooled syrup evenly over the hot basbousa so it absorbs into the scored pieces.";
"recipe.es_tarta_de_santiago.step6.title" = "Soak with syrup";
"recipe.es_tarta_de_santiago.step7.body" = "Let the basbousa cool completely so the syrup fully absorbs and the pieces set for clean serving.";
"recipe.es_tarta_de_santiago.step7.title" = "Cool and set";
"recipe.es_tarta_de_santiago.step8.body" = "Cut along the scored lines and serve at room temperature.";
"recipe.es_tarta_de_santiago.step8.title" = "Serve";
