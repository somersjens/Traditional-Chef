"recipe.tr_manti.drink.summary" = "White wine (Viognier)";
"recipe.tr_manti.info" = "Turkish mantı are tiny meat-filled dumplings boiled and served with garlicky yogurt, then finished with a sizzling butter sauce flavored with pul biber and a sprinkle of dried mint. Traditionally associated with Anatolian home cooking, they are served hot immediately after assembly so the yogurt stays creamy and the butter sauce perfumes each bite.";
"recipe.tr_manti.info.summary" = "Tiny yogurt dumplings";
"recipe.tr_manti.name" = "Turkish mantı";
