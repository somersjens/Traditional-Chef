"recipe.cn_chun_juan.info" = "Chun juan are traditional Chinese spring rolls, especially associated with Spring Festival celebrations and banquet tables. Thin wheat wrappers are filled with a savory stir-fried mixture of pork, napa cabbage, vermicelli, and shiitake mushrooms, then rolled and deep-fried until golden and crisp.";
"recipe.cn_chun_juan.info.summary" = "Festival spring rolls";
