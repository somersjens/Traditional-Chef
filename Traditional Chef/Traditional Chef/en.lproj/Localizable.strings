"recipe.ir_dizi.drink.body" = "A savory, medium-bodied red such as Syrah or Grenache pairs well with the lamb and warm spices without overpowering the stew. If you prefer white, choose a fuller-bodied Chardonnay. Non-alcoholic: doogh (yogurt-mint drink) or hot black tea.";
"recipe.ir_dizi.drink.summary" = "Red wine (Syrah)";
"recipe.ir_dizi.info" = "Dizi, also known as abgoosht, is a traditional Iranian lamb-and-legume stew slowly simmered until deeply savory, often cooked and served in a stoneware pot. The broth is served first, then the solids are mashed into a rich paste (goosht kubideh) and eaten with Persian flatbread, herbs, onions, and pickles.";
"recipe.ir_dizi.info.summary" = "Stone-pot lamb stew";
"recipe.ir_dizi.name" = "Dizi";
"recipe.ir_dizi.step1.body" = "Rinse %i3 and %i4, then soak them in plenty of %i12 until fully hydrated.";
"recipe.ir_dizi.step1.title" = "Soak the legumes";
"recipe.ir_dizi.step2.body" = "Rinse and cut %i8, %i5, and %i2. Pierce %i7 so they release flavor during cooking.";
"recipe.ir_dizi.step2.title" = "Prepare the stew ingredients";
"recipe.ir_dizi.step3.body" = "Add %i1, soaked legumes, onion, tomatoes, %i6, %i9, %i10, and %i11 to a heavy pot. Add enough water to cover well and bring to a gentle boil.";
"recipe.ir_dizi.step3.title" = "Start the stew";
"recipe.ir_dizi.step4.body" = "Reduce to a steady simmer, skim any foam, then cook covered until the lamb and legumes are nearly tender, checking occasionally to keep the level of liquid steady with water if needed.";
"recipe.ir_dizi.step4.title" = "Slow simmer until tender";
"recipe.ir_dizi.step5.body" = "Add the potatoes and dried limes and continue simmering until the potatoes are soft, the legumes are fully cooked, and the lamb is falling tender.";
"recipe.ir_dizi.step5.title" = "Add potatoes and dried limes";
"recipe.ir_dizi.step6.body" = "Ladle the hot broth into bowls and serve immediately with %i13, the fresh herb platter, %i14, and %i19.";
"recipe.ir_dizi.step6.title" = "Serve the broth first";
"recipe.ir_dizi.step7.body" = "Remove the lamb bones, then mash the lamb, legumes, and potatoes until cohesive, mixing in a little broth as needed for a smooth, rich texture.";
"recipe.ir_dizi.step7.title" = "Make goosht kubideh";
"recipe.ir_dizi.step8.body" = "Serve the mashed mixture alongside the remaining broth, with bread, %i15, %i16, %i17, %i18, pickles, and onions for eating the traditional way.";
"recipe.ir_dizi.step8.title" = "Serve the mashed stew";
