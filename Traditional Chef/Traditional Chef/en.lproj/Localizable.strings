"recipe.pl_golabki.drink.body" = "Pair with a medium-bodied red such as Pinot Noir or a fresh Zweigelt that complements tomato and savory meat without overpowering. A classic pale lager also matches the dish’s comforting richness. Non-alcoholic option: black tea with lemon or still water.";
"recipe.pl_golabki.drink.summary" = "Red wine (Pinot Noir)";
"recipe.pl_golabki.info" = "Gołąbki are tender blanched cabbage leaves wrapped around a filling of minced meat, rice, and onion, then slowly baked or braised until succulent. In Poland they are most commonly served hot with a smooth tomato sauce that seeps into the rolls, making them a comforting, homestyle main course found at family dinners and celebrations alike.";
"recipe.pl_golabki.info.summary" = "Tomato-braised cabbage rolls";
"recipe.pl_golabki.name" = "Cabbage rolls";
"recipe.pl_golabki.step1.body" = "Rinse the %i4 and cook it in %i9 until tender. Spread it out to cool so it does not steam in the bowl.";
"recipe.pl_golabki.step1.title" = "Cook the rice";
"recipe.pl_golabki.step2.body" = "Bring %i10 to a boil in a large pot. Core the %i1 and blanch it, peeling off softened leaves as they loosen. Trim the thick rib on each leaf so it rolls easily.";
"recipe.pl_golabki.step2.title" = "Blanch the cabbage";
"recipe.pl_golabki.step3.body" = "Combine %i2 and %i3 in a bowl. Add cooled rice, finely chopped %i5, %i6, %i7, and %i8, then mix until evenly combined.";
"recipe.pl_golabki.step3.title" = "Mix the filling";
"recipe.pl_golabki.step4.body" = "Place a portion of filling on each cabbage leaf, fold in the sides, and roll tightly into neat parcels. Arrange the rolls seam-side down in a baking dish and tuck %i19 and %i20 around them.";
"recipe.pl_golabki.step4.title" = "Form the cabbage rolls";
"recipe.pl_golabki.step5.body" = "Warm %i13 with %i11 and %i12, stirring until smooth. Season with %i17, %i18, and %i16, then keep hot.";
"recipe.pl_golabki.step5.title" = "Start the tomato sauce";
"recipe.pl_golabki.step6.body" = "Melt %i14 in a skillet, whisk in %i15, and cook until smooth. Whisk in a ladle of hot tomato liquid to loosen, then whisk the thickener back into the sauce and simmer until lightly thickened.";
"recipe.pl_golabki.step6.title" = "Thicken the sauce";
"recipe.pl_golabki.step7.body" = "Pour the hot tomato sauce over the cabbage rolls so they are mostly covered, then cover the dish tightly.";
"recipe.pl_golabki.step7.title" = "Cover rolls with sauce";
"recipe.pl_golabki.step8.body" = "Bake until the cabbage is very tender and the filling is fully cooked through, basting the rolls with sauce occasionally.";
"recipe.pl_golabki.step8.title" = "Bake until tender";
"recipe.pl_golabki.step9.body" = "Let the dish rest briefly so the rolls set. Serve the cabbage rolls hot with plenty of tomato sauce.";
"recipe.pl_golabki.step9.title" = "Rest and serve";
