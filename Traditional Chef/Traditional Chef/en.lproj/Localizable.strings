"recipe.ch_meringues_avec_double_creme.drink.body" = "Serve with a light sweet wine such as a late-harvest white or a demi-sec sparkling wine. A mild dessert cider also works well. For a non-alcoholic option, serve black coffee or hot black tea.";
"recipe.ch_meringues_avec_double_creme.drink.summary" = "Sweet wine";
"recipe.ch_meringues_avec_double_creme.info" = "Meringues with double cream is a traditional dessert from the canton of Fribourg, especially associated with Gruyères and the Bénichon meal. Crisp baked meringues are served with rich double cream from La Gruyère, making a simple but iconic Swiss dessert served cold after a hearty meal.";
"recipe.ch_meringues_avec_double_creme.info.summary" = "Fribourg cream dessert";
"recipe.ch_meringues_avec_double_creme.name" = "Meringues with cream";
"recipe.ch_meringues_avec_double_creme.step1.body" = "Beat %i1 until very stiff, then gradually add %i2 while continuing to beat until the mixture is thick, glossy, and holds its shape firmly.";
"recipe.ch_meringues_avec_double_creme.step1.title" = "Whip the egg whites";
"recipe.ch_meringues_avec_double_creme.step2.body" = "Line a baking tray with baking paper and form the mixture into traditional oblong or shell-shaped meringues.";
"recipe.ch_meringues_avec_double_creme.step2.title" = "Shape the meringues";
"recipe.ch_meringues_avec_double_creme.step3.body" = "Bake the meringues at very low heat with the oven door slightly open until they are dry, crisp, and pale rather than browned.";
"recipe.ch_meringues_avec_double_creme.step3.title" = "Dry the meringues";
"recipe.ch_meringues_avec_double_creme.step4.body" = "Remove the tray from the oven and let the meringues cool completely so they become fully crisp.";
"recipe.ch_meringues_avec_double_creme.step4.title" = "Cool the meringues";
"recipe.ch_meringues_avec_double_creme.step5.body" = "Arrange the meringues on dessert plates and serve them with generous spoonfuls of %i3 alongside or over the top.";
"recipe.ch_meringues_avec_double_creme.step5.title" = "Serve";
"recipe.ch_meringues_avec_double_creme.tool.t1" = "Mixing bowl";
