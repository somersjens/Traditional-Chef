"recipe.ar_empanadas.drink.body" = "Malbec is a natural match with the savory beef filling and gentle spices, and a dry Torrontes also pairs well with the baked pastry. For a non-alcoholic option, serve sparkling water with lemon or cold yerba mate.";
"recipe.ar_empanadas.drink.summary" = "Red wine (Malbec)";
"recipe.ar_empanadas.info" = "Argentine empanadas are flaky pastry turnovers filled with a savory beef mixture seasoned with classic criollo spices, then baked until golden and served hot for lunch, dinner, or gatherings. The traditional beef filling is cooked, cooled, and finished with chopped hard-boiled egg and olives, while salsa criolla is commonly served alongside to add freshness and acidity.";
"recipe.ar_empanadas.info.summary" = "Baked beef empanadas";
"recipe.ar_empanadas.name" = "Beef empanadas";
"recipe.ar_empanadas.step1.body" = "Combine %i1 and %i2, rub in %i3 until crumbly, then add %i4 and knead until smooth and elastic.";
"recipe.ar_empanadas.step1.title" = "Make the dough";
"recipe.ar_empanadas.step10.body" = "Place filling on each disc, fold into a half-moon, press to seal, and crimp the edge firmly with a fork to prevent leaks.";
"recipe.ar_empanadas.step10.title" = "Fill and seal empanadas";
"recipe.ar_empanadas.step11.body" = "Beat the %i19 and brush the tops of the empanadas lightly to encourage browning.";
"recipe.ar_empanadas.step11.title" = "Brush with egg wash";
"recipe.ar_empanadas.step12.body" = "Bake until the empanadas are puffed and deeply golden, rotating the tray if needed for even color.";
"recipe.ar_empanadas.step12.title" = "Bake until golden";
"recipe.ar_empanadas.step13.body" = "Serve the empanadas hot with salsa criolla alongside.";
"recipe.ar_empanadas.step13.title" = "Serve";
"recipe.ar_empanadas.step2.body" = "Cover the dough and let it rest so it relaxes and rolls without shrinking.";
"recipe.ar_empanadas.step2.title" = "Rest the dough";
"recipe.ar_empanadas.step3.body" = "Boil %i17 until hard, cool, peel, and chop finely for the filling.";
"recipe.ar_empanadas.step3.title" = "Boil the eggs";
"recipe.ar_empanadas.step4.body" = "Melt %i9 in a skillet, cook %i6 until soft, then add %i7 and %i8 and cook until fragrant.";
"recipe.ar_empanadas.step4.title" = "Cook the filling base";
"recipe.ar_empanadas.step5.body" = "Add %i5 and cook until browned, then stir in %i10, %i11, %i12, %i13, %i14, and %i15 to coat evenly.";
"recipe.ar_empanadas.step5.title" = "Brown and season the beef";
