"recipe.th_khanom_mo_kaeng.drink.body" = "A lightly sweet late-harvest white wine can match the caramel and coconut notes, but this dessert is most traditionally paired with hot unsweetened tea. For a non-alcoholic option, serve jasmine tea or plain warm tea.";
"recipe.th_khanom_mo_kaeng.drink.summary" = "Tea";
"recipe.th_khanom_mo_kaeng.info" = "Khanom Mo Kaeng is a traditional Thai baked custard dessert made with eggs, coconut milk, palm sugar, mung beans, and a topping of fried shallots. It is baked until set and fragrant, then cut into small pieces and served at room temperature, often for celebrations and temple fairs.";
"recipe.th_khanom_mo_kaeng.info.summary" = "Thai baked custard";
"recipe.th_khanom_mo_kaeng.name" = "Khanom mo kaeng";
"recipe.th_khanom_mo_kaeng.step1.body" = "Rinse the %i1 several times until the water runs clearer, then drain well.";
"recipe.th_khanom_mo_kaeng.step1.title" = "Wash the mung beans";
"recipe.th_khanom_mo_kaeng.step10.body" = "Remove from the oven and let the khanom mo kaeng cool completely so it firms up for clean slicing.";
"recipe.th_khanom_mo_kaeng.step10.title" = "Cool completely";
"recipe.th_khanom_mo_kaeng.step11.body" = "Cut into small pieces and serve at room temperature.";
"recipe.th_khanom_mo_kaeng.step11.title" = "Cut and serve";
"recipe.th_khanom_mo_kaeng.step2.body" = "Place the mung beans in a saucepan with %i2 and cook gently until very soft and mashable. Drain any excess liquid.";
"recipe.th_khanom_mo_kaeng.step2.title" = "Cook the mung beans";
"recipe.th_khanom_mo_kaeng.step3.body" = "Slice the %i8 thinly. Heat the %i9 in a frying pan and fry the shallots gently until golden and crisp, then lift them out and reserve the shallot oil.";
"recipe.th_khanom_mo_kaeng.step3.title" = "Fry the shallots";
"recipe.th_khanom_mo_kaeng.step4.body" = "Lightly grease the baking tray with %i10 and preheat the oven.";
"recipe.th_khanom_mo_kaeng.step4.title" = "Prepare the baking tray";
"recipe.th_khanom_mo_kaeng.step5.body" = "Blend the cooked mung beans until smooth with part of the %i4 to help the mixture move evenly.";
"recipe.th_khanom_mo_kaeng.step5.title" = "Blend the mung beans";
"recipe.th_khanom_mo_kaeng.step6.body" = "In a mixing bowl combine the %i3, %i5, %i6, %i7, and the remaining coconut milk. Mix until the sugars dissolve and the mixture is smooth.";
"recipe.th_khanom_mo_kaeng.step6.title" = "Make the custard base";
"recipe.th_khanom_mo_kaeng.step7.body" = "Mix the blended mung beans into the custard base until fully smooth, then strain the batter through a sieve into a clean bowl.";
"recipe.th_khanom_mo_kaeng.step7.title" = "Combine and strain";
