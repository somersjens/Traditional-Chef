"recipe.sn_thieboudienne.drink.body" = "A crisp white wine such as Sauvignon Blanc or Picpoul complements the tomato broth and fish. For a non-alcoholic option, serve chilled bissap (hibiscus drink) or a fresh ginger drink.";
"recipe.sn_thieboudienne.drink.summary" = "White wine (Sauvignon)";
"recipe.sn_thieboudienne.info" = "Thieboudienne, also known as Ceebu Jën, is Senegal’s iconic one-pot dish of broken rice cooked in a deep tomato broth with stuffed fish and large-cut vegetables, traditionally served on a big communal platter with the fish and vegetables arranged on top and the cooking sauce spooned over.";
"recipe.sn_thieboudienne.info.summary" = "Fish rice platter";
"recipe.sn_thieboudienne.name" = "Thieboudienne";
"recipe.sn_thieboudienne.step1.body" = "Blend %i3, %i4, %i5, and %i6 into a smooth paste.";
"recipe.sn_thieboudienne.step1.title" = "Make the fish stuffing";
"recipe.sn_thieboudienne.step10.body" = "Taste the broth and adjust seasoning, then stir in the drained rice, cover, and cook until the rice absorbs the broth and becomes tender.";
"recipe.sn_thieboudienne.step10.title" = "Cook the rice in the broth";
"recipe.sn_thieboudienne.step11.body" = "Turn off the heat and let the rice rest covered so it finishes steaming and firms up.";
"recipe.sn_thieboudienne.step11.title" = "Rest the rice";
"recipe.sn_thieboudienne.step12.body" = "Mound the rice onto a large platter, arrange fish and vegetables on top, spoon the sauce over the center, and serve with %i18 for squeezing at the table.";
"recipe.sn_thieboudienne.step12.title" = "Plate and serve";
"recipe.sn_thieboudienne.step2.body" = "Cut shallow slits in the %i2 and press stuffing into the slits and over the surface, then season with %i16 and %i17.";
"recipe.sn_thieboudienne.step2.title" = "Stuff and season the fish";
"recipe.sn_thieboudienne.step3.body" = "Peel and cut the %i19, %i21, %i22, and %i23 into large chunks, cut the %i20 into wedges, trim the %i24, and keep pieces large so they hold together.";
"recipe.sn_thieboudienne.step3.title" = "Prep vegetables";
"recipe.sn_thieboudienne.step4.body" = "Rinse the %i1 repeatedly in a bowl with water, then drain well in a colander.";
"recipe.sn_thieboudienne.step4.title" = "Wash the rice";
"recipe.sn_thieboudienne.step5.body" = "Heat %i7 in the pot and brown the fish pieces briefly to firm them up, then lift them out and set aside.";
"recipe.sn_thieboudienne.step5.title" = "Brown the fish";
"recipe.sn_thieboudienne.step6.body" = "In the same pot, cook %i8 until softened, stir in %i9 and cook until it darkens slightly, then add %i10 and cook into a thick sauce.";
"recipe.sn_thieboudienne.step6.title" = "Build the tomato base";
"recipe.sn_thieboudienne.step7.body" = "Add %i25, %i14, %i15, %i11, %i12, and %i13, then bring to a steady simmer.";
"recipe.sn_thieboudienne.step7.title" = "Start the broth";
"recipe.sn_thieboudienne.step8.body" = "Add the firm vegetables first and simmer until they begin to soften, then return the fish to the pot and continue simmering gently so the broth becomes richly flavored.";
"recipe.sn_thieboudienne.step8.title" = "Simmer vegetables and fish";
"recipe.sn_thieboudienne.step9.body" = "Add cabbage and okra and simmer until all vegetables are tender and the sauce turns glossy, then lift out the fish and vegetables and keep warm.";
"recipe.sn_thieboudienne.step9.title" = "Finish vegetables";
