"recipe.pe_lomo_saltado.drink.body" = "Pair with a juicy Malbec or a medium-bodied Tempranillo to match the seared beef and savory soy notes. A crisp lager also works well. For a non-alcoholic option, serve Inca Kola or sparkling water with lime.";
"recipe.pe_lomo_saltado.drink.summary" = "Red wine (Malbec)";
"recipe.pe_lomo_saltado.info" = "Lomo Saltado is the iconic Peruvian-Chifa stir-fry of tender beef seared over very high heat with red onion, tomato, ají amarillo, and a savory soy-vinegar sauce, finished with cilantro. It is traditionally served immediately with white rice and French fries, with the fries mixed into the saucy stir-fry right before serving.";
"recipe.pe_lomo_saltado.info.summary" = "Wok-seared beef classic";
"recipe.pe_lomo_saltado.name" = "Lomo saltado";
"recipe.pe_lomo_saltado.step1.body" = "Rinse the %i15, then cook it with %i16 until tender and fluffy. Keep covered and warm.";
"recipe.pe_lomo_saltado.step1.title" = "Cook the rice";
"recipe.pe_lomo_saltado.step10.body" = "Serve right away with white rice on the side.";
"recipe.pe_lomo_saltado.step10.title" = "Serve immediately";
"recipe.pe_lomo_saltado.step2.body" = "Cut the %i1 into thick strips. Slice the %i2 into wedges, cut the %i3 into wedges, slice the %i4, mince the %i5, and chop the %i6.";
"recipe.pe_lomo_saltado.step2.title" = "Prep the ingredients";
"recipe.pe_lomo_saltado.step3.body" = "Cut the %i13 into fries, rinse briefly to remove surface starch, then dry thoroughly so they fry crisp.";
"recipe.pe_lomo_saltado.step3.title" = "Cut and rinse potatoes";
"recipe.pe_lomo_saltado.step4.body" = "Heat %i14 in a deep skillet and fry the potatoes until golden and crisp, turning as needed. Drain on paper towels and season with %i10 while hot.";
"recipe.pe_lomo_saltado.step4.title" = "Fry the potatoes";
"recipe.pe_lomo_saltado.step5.body" = "Heat the wok until smoking hot, add %i12, then sear the beef quickly so it browns well without overcooking. Remove the beef to a bowl.";
"recipe.pe_lomo_saltado.step5.title" = "Sear the beef";
"recipe.pe_lomo_saltado.step6.body" = "Add a little more oil if needed, then stir-fry the garlic and ají amarillo briefly. Add the onion and toss over high heat until lightly charred but still crisp.";
"recipe.pe_lomo_saltado.step6.title" = "Stir-fry aromatics and onion";
"recipe.pe_lomo_saltado.step7.body" = "Add the tomatoes and toss just until warmed and slightly softened while keeping their shape.";
"recipe.pe_lomo_saltado.step7.title" = "Add tomatoes";
