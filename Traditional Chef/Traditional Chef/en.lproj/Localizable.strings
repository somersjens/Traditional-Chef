"recipe.kh_chek_ktis.drink.body" = "A lightly sweet white wine such as Moscato or late-harvest Riesling complements the banana and coconut flavors. A light lager can also work with the sesame garnish. For a non-alcoholic option, serve hot jasmine tea or unsweetened green tea.";
"recipe.kh_chek_ktis.drink.summary" = "Sweet wine (Moscato)";
"recipe.kh_chek_ktis.info" = "Chek ktis is a traditional Cambodian dessert of ripe bananas and tapioca pearls simmered in sweet coconut milk, typically finished with toasted sesame. It is served warm as a comforting sweet dish at home and in Cambodian restaurants.";
"recipe.kh_chek_ktis.info.summary" = "Banana coconut sweet";
"recipe.kh_chek_ktis.name" = "Chek ktis";
