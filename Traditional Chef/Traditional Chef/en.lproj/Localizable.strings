"recipe.tr_hunkar_begendi.drink.body" = "A medium-bodied Syrah or an elegant Pinot Noir pairs with the lamb and the smoky eggplant without overpowering the creamy purée. For a non-alcoholic option, serve ayran or sparkling water with lemon.";
"recipe.tr_hunkar_begendi.drink.summary" = "Red wine (Syrah)";
"recipe.tr_hunkar_begendi.info" = "Hünkar Beğendi is a classic Ottoman Turkish dish of tender lamb stew served over smoky eggplant purée enriched with béchamel and cheese. Traditionally associated with palace cuisine, it is plated with the rich meat ragout on top of the silky, fire-roasted eggplant base, and served as a centerpiece main course.";
"recipe.tr_hunkar_begendi.info.summary" = "Ottoman lamb on eggplant";
