"recipe.lb_ataif.drink.body" = "Serve with a chilled Muscat or late-harvest Riesling to match the floral syrup and creamy filling. For a non-alcoholic pairing, choose strong Arabic coffee or fresh mint tea.";
"recipe.lb_ataif.drink.summary" = "Sweet wine (Muscat)";
"recipe.lb_ataif.info" = "Atayef bil Ashta are small one-sided Lebanese pancakes made from a lightly fermented batter, folded into little cones and filled with fragrant ashta cream. They are finished with attar syrup scented with flower waters and a sprinkle of pistachios, traditionally served during Ramadan and family gatherings.";
"recipe.lb_ataif.info.summary" = "Ramadan cream pancakes";
"recipe.lb_ataif.name" = "Atayef with cream";
"recipe.lb_ataif.step1.body" = "Combine %i14 with %i15 in a saucepan and bring to a boil, stirring to dissolve. Reduce to a gentle simmer, add %i16, and simmer until slightly thickened. Turn off the heat and stir in %i17 and %i18. Pour into a bowl and let cool completely.";
"recipe.lb_ataif.step1.title" = "Make the attar syrup";
"recipe.lb_ataif.step2.body" = "In a saucepan, whisk %i8, %i9, %i11, and %i10 until smooth. Cook over medium heat, stirring constantly, until thick and glossy. Remove from heat and stir in %i12 and %i13.";
"recipe.lb_ataif.step2.title" = "Cook the ashta cream";
"recipe.lb_ataif.step3.body" = "Transfer the ashta to a shallow dish, cover the surface directly, and refrigerate until fully cooled and set.";
"recipe.lb_ataif.step3.title" = "Chill the ashta";
"recipe.lb_ataif.step4.body" = "Sift %i1 with %i2, %i3, %i4, %i5, and %i6 into a bowl. Whisk in %i7 gradually until you have a smooth, pourable batter with no lumps.";
"recipe.lb_ataif.step4.title" = "Mix the atayef batter";
"recipe.lb_ataif.step5.body" = "Cover the batter and let it rest until slightly bubbly and lightly fermented.";
"recipe.lb_ataif.step5.title" = "Rest the batter";
"recipe.lb_ataif.step6.body" = "Heat a nonstick skillet or griddle over medium heat. Ladle small rounds of batter onto the surface and cook on one side only. When the top is covered with bubbles and no wet spots remain, remove and place on a towel. Keep covered so they stay pliable.";
"recipe.lb_ataif.step6.title" = "Cook the atayef pancakes";
"recipe.lb_ataif.step7.body" = "Place each pancake cooked-side down, add ashta in the center, and pinch the edges together to form a cone with a small opening at the top.";
"recipe.lb_ataif.step7.title" = "Fill and shape";
"recipe.lb_ataif.step8.body" = "Dip the exposed ashta at the opening into %i19 and arrange the atayef on a serving platter.";
"recipe.lb_ataif.step8.title" = "Garnish";
"recipe.lb_ataif.step9.body" = "Drizzle with cooled attar syrup and serve immediately.";
"recipe.lb_ataif.step9.title" = "Serve";
