"recipe.th_massaman_nuea.step3.title" = "Start the rice";
"recipe.th_massaman_nuea.step4.body" = "Cover and cook on low heat until the liquid is absorbed and the rice is tender. Rest covered off the heat.";
"recipe.th_massaman_nuea.step4.title" = "Cook the rice";
"recipe.th_massaman_nuea.step5.body" = "Heat the curry pot and add the %i3. Cook while stirring until fragrant and slightly thickened, then add the %i2 and fry until aromatic.";
"recipe.th_massaman_nuea.step5.title" = "Crack the coconut cream";
"recipe.th_massaman_nuea.step6.body" = "Add the beef and stir until the pieces are well coated in the curry paste and the outside is no longer raw.";
"recipe.th_massaman_nuea.step6.title" = "Coat the beef";
"recipe.th_massaman_nuea.step7.body" = "Add the %i4 and %i5, then season with %i6, %i7, and the tamarind extract. Stir until the sugar dissolves.";
"recipe.th_massaman_nuea.step7.title" = "Build the curry liquid";
"recipe.th_massaman_nuea.step8.body" = "Simmer gently until the beef becomes tender and the curry develops a rich aroma. Stir occasionally to prevent sticking.";
"recipe.th_massaman_nuea.step8.title" = "Braise the beef";
"recipe.th_massaman_nuea.step9.body" = "Add the potatoes and onion and continue simmering until the potatoes are tender and the onion is soft but still holds shape.";
"recipe.th_massaman_nuea.step9.title" = "Cook potatoes and onion";
