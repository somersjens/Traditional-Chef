"recipe.jp_yokan.drink.body" = "Sencha or matcha pairs well with the dense sweetness of yokan. For a non-alcoholic pairing, serve hot hojicha or cold barley tea.";
"recipe.jp_yokan.drink.summary" = "Green tea (Sencha)";
"recipe.jp_yokan.info" = "Yokan is a traditional Japanese wagashi made by simmering sweet bean paste with sugar and agar into a firm sliceable jelly. It is commonly served in small pieces with tea at home, tea gatherings, and confectionery shops, especially as a refined sweet with a long shelf life.";
"recipe.jp_yokan.info.summary" = "Sweet bean jelly";
"recipe.jp_yokan.name" = "Yokan";
"recipe.jp_yokan.step1.body" = "Line the mold with parchment so the yokan can be removed cleanly after setting.";
"recipe.jp_yokan.step1.title" = "Prepare the mold";
"recipe.jp_yokan.step2.body" = "Whisk %i3 into %i4 in a saucepan and bring to a gentle boil, stirring until fully dissolved and smooth.";
"recipe.jp_yokan.step2.title" = "Dissolve the agar";
"recipe.jp_yokan.step3.body" = "Add %i2 and %i5 and simmer while stirring until the sugar is completely dissolved.";
"recipe.jp_yokan.step3.title" = "Add sugar and salt";
"recipe.jp_yokan.step4.body" = "Add the %i1 and cook over medium-low heat, stirring constantly until the mixture is thick, glossy, and moves as a cohesive mass.";
"recipe.jp_yokan.step4.title" = "Cook with bean paste";
"recipe.jp_yokan.step5.body" = "Press through a sieve if desired for a finer texture, then stir briefly to keep the mixture uniform.";
"recipe.jp_yokan.step5.title" = "Smooth the mixture";
"recipe.jp_yokan.step6.body" = "Transfer the hot yokan mixture into the prepared mold and level the surface neatly.";
"recipe.jp_yokan.step6.title" = "Pour into the mold";
"recipe.jp_yokan.step7.body" = "Let the yokan cool and set completely until firm enough to unmold and slice cleanly.";
"recipe.jp_yokan.step7.title" = "Set until firm";
"recipe.jp_yokan.step8.body" = "Remove the yokan from the mold and cut into small neat serving pieces.";
"recipe.jp_yokan.step8.title" = "Unmold and slice";
"recipe.jp_yokan.step9.body" = "Arrange the slices on a plate and serve with tea.";
"recipe.jp_yokan.step9.title" = "Serve";
