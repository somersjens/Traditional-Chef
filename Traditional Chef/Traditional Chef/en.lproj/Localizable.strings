"recipe.sr_roti_kip.info" = "Surinamese roti chicken is a traditional Hindoestani-Surinamese dish of curried chicken with potatoes, kouseband, boiled egg, and roti plates. It is served hot as a full meal, with the components kept distinct on the plate so pieces of roti can be torn off and used to eat the chicken, vegetables, and sauce.";
"recipe.sr_roti_kip.info.summary" = "Curried chicken with roti";
"recipe.sr_roti_kip.name" = "Roti chicken";
"recipe.sr_roti_kip.step1.body" = "Mix %i1 with %i4 and part of %i5, add %i2 and part of %i3, and knead into a smooth soft dough. Cover and let it rest.";
"recipe.sr_roti_kip.step1.title" = "Make the roti dough";
