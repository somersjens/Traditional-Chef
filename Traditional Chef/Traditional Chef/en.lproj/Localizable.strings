"recipe.gr_briam.drink.body" = "Pair with a crisp Greek white such as Assyrtiko or a dry rosé that stays fresh against olive oil and roasted vegetables. A light lager also works well. For a non-alcoholic option, serve sparkling water with lemon or a chilled herbal iced tea.";
"recipe.gr_briam.drink.summary" = "White wine (Assyrtiko)";
"recipe.gr_briam.info" = "Briam is a traditional Greek baked vegetable dish of summer produce layered in a pan with plenty of olive oil, garlic, and herbs, then roasted until tender and slightly caramelized. It is commonly served warm or at room temperature with crusty bread and feta, which are used to scoop up the olive-oil-rich juices.";
"recipe.gr_briam.info.summary" = "Greek summer bake";
"recipe.gr_briam.name" = "Briam";
"recipe.gr_briam.step1.body" = "Cut %i1, %i2, %i3, %i4, and %i5 into even chunks. Chop %i7 and mince %i6 and %i12.";
"recipe.gr_briam.step1.title" = "Prep the vegetables";
"recipe.gr_briam.step2.body" = "Combine the vegetables with the garlic, %i11, %i9, %i10, %i8, and %i13 and spread them in a baking dish in an even layer.";
"recipe.gr_briam.step2.title" = "Season and assemble";
"recipe.gr_briam.step3.body" = "Cover and bake until the vegetables are starting to soften and release their juices.";
"recipe.gr_briam.step3.title" = "Bake covered";
"recipe.gr_briam.step4.body" = "Uncover and continue baking until the vegetables are tender and lightly caramelized and the pan juices are rich.";
"recipe.gr_briam.step4.title" = "Roast uncovered";
"recipe.gr_briam.step5.body" = "Serve warm or at room temperature with %i14 and %i15.";
"recipe.gr_briam.step5.title" = "Serve the briam";
