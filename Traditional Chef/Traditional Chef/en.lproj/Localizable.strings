"recipe.az_piti.drink.body" = "A dry white wine such as Chardonnay pairs well with the rich lamb broth and saffron. A light amber lager also suits the dish. For a non-alcoholic pairing, serve strong black tea or hot mint tea.";
"recipe.az_piti.drink.summary" = "White wine (Chardonnay)";
"recipe.az_piti.info" = "Azerbaijani piti is a traditional slow-cooked lamb dish from Sheki, prepared in individual clay pots with chickpeas, chestnuts, dried plums, saffron, onion, and sheep tail fat. It is served in the classic two-stage manner, first with broth poured over torn bread, then with the tender solids eaten after.";
"recipe.az_piti.info.summary" = "Sheki clay pot lamb";
"recipe.az_piti.name" = "Piti";
"recipe.az_piti.step1.body" = "Rinse %i3 and soak them in plenty of normal water until fully swollen for cooking.";
"recipe.az_piti.step1.title" = "Soak the chickpeas";
"recipe.az_piti.step2.body" = "Steep %i7 in a little hot %i9 until the color and aroma are fully released.";
"recipe.az_piti.step2.title" = "Prepare the saffron";
"recipe.az_piti.step3.body" = "Cut %i1 into large serving pieces, cut %i2 into small pieces, and slice %i4.";
"recipe.az_piti.step3.title" = "Prepare the ingredients";
"recipe.az_piti.step4.body" = "Divide the lamb, sheep tail fat, drained chickpeas, onions, %i5, and %i6 evenly among the clay pots. Season with %i8 and add the saffron infusion.";
"recipe.az_piti.step4.title" = "Fill the clay pots";
"recipe.az_piti.step5.body" = "Pour water into each pot so the ingredients are covered and place the pots in a deep baking dish.";
"recipe.az_piti.step5.title" = "Add the cooking liquid";
"recipe.az_piti.step6.body" = "Cook the pots slowly until the lamb is very tender, the chickpeas are soft, and the broth is rich and fragrant.";
"recipe.az_piti.step6.title" = "Cook the piti";
"recipe.az_piti.step7.body" = "Tear %i10 into serving bowls and sprinkle a little %i11 over the bread.";
"recipe.az_piti.step7.title" = "Prepare the bread";
"recipe.az_piti.step8.body" = "Ladle the hot broth from the clay pots over the bread so it softens and absorbs the saffron-scented liquid.";
"recipe.az_piti.step8.title" = "Serve the first stage";
"recipe.az_piti.step9.body" = "Transfer the lamb, chickpeas, chestnuts, dried plums, and onion from the pots to plates or bowls and serve immediately after the broth course.";
"recipe.az_piti.step9.title" = "Serve the second stage";
