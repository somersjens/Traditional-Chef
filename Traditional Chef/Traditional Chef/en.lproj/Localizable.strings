"recipe.it_crostata_di_marmellata.step4.title" = "Line the tart pan";
"recipe.it_crostata_di_marmellata.step5.body" = "Spread %i7 evenly over the pastry base.";
"recipe.it_crostata_di_marmellata.step5.title" = "Fill with jam";
