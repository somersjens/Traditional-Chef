"recipe.pl_szarlotka.drink.body" = "Pair with a lightly sweet wine such as late-harvest Riesling that complements the apples and cinnamon without overpowering. A creamy porter can also match the buttery crust and warm spice. Non-alcoholic option: black tea with lemon or coffee with milk.";
"recipe.pl_szarlotka.drink.summary" = "Sweet wine (Riesling)";
"recipe.pl_szarlotka.info" = "Szarlotka is a classic Polish apple cake built from buttery shortcrust pastry layered with tangy, cinnamon-scented apples and finished with a rustic crumb topping made from the same dough. Baked until golden and cooled, it’s cut into squares and dusted with powdered sugar, a staple home dessert served with tea or coffee throughout Poland.";
"recipe.pl_szarlotka.info.summary" = "Shortcrust apple cake";
"recipe.pl_szarlotka.name" = "Apple cake";
"recipe.pl_szarlotka.step1.body" = "Heat the oven. Line the baking pan with parchment and lightly grease it with %i12.";
"recipe.pl_szarlotka.step1.title" = "Prepare the pan";
"recipe.pl_szarlotka.step10.body" = "Dust generously with %i13 and cut into squares to serve.";
"recipe.pl_szarlotka.step10.title" = "Finish and serve";
"recipe.pl_szarlotka.step2.body" = "Combine %i1, %i5, %i3, and %i6. Rub in cold %i2 until crumbly, add %i4, and quickly knead into a smooth dough.";
"recipe.pl_szarlotka.step2.title" = "Make shortcrust dough";
"recipe.pl_szarlotka.step3.body" = "Divide the dough so one portion is larger for the base and one smaller for the topping. Chill the larger portion in the fridge and freeze the smaller portion for grating.";
"recipe.pl_szarlotka.step3.title" = "Chill the dough";
"recipe.pl_szarlotka.step4.body" = "Peel and core the %i7 and grate them. Add %i8, %i9, and %i10 and mix well.";
"recipe.pl_szarlotka.step4.title" = "Prepare the apples";
"recipe.pl_szarlotka.step5.body" = "Cook the apples in a saucepan, stirring, until excess moisture evaporates and the mixture is soft but not watery. Cool until warm.";
"recipe.pl_szarlotka.step5.title" = "Cook down the apples";
"recipe.pl_szarlotka.step6.body" = "Press the chilled larger portion of dough evenly into the pan to form the base. Sprinkle %i11 over the dough to help absorb apple juices.";
"recipe.pl_szarlotka.step6.title" = "Form the base";
"recipe.pl_szarlotka.step7.body" = "Spread the cooked apples evenly over the base, smoothing the surface.";
"recipe.pl_szarlotka.step7.title" = "Add the apple layer";
"recipe.pl_szarlotka.step8.body" = "Grate the frozen dough over the apples to cover them evenly with a rough, mountain-like layer.";
"recipe.pl_szarlotka.step8.title" = "Add the crumb topping";
"recipe.pl_szarlotka.step9.body" = "Bake until the top is deeply golden and the cake is set. Remove and cool completely on a rack.";
"recipe.pl_szarlotka.step9.title" = "Bake until golden";
