"recipe.se_raggmunk_med_flask.step1.title" = "Make the batter";
"recipe.se_raggmunk_med_flask.step2.body" = "Peel and grate %i1 coarsely, squeeze out excess liquid in a clean kitchen towel, and fold them into the batter just before frying.";
"recipe.se_raggmunk_med_flask.step2.title" = "Prepare the potatoes";
"recipe.se_raggmunk_med_flask.step3.body" = "Cook %i7 in a frying pan until browned and crisp at the edges, then keep it warm.";
"recipe.se_raggmunk_med_flask.step3.title" = "Fry the pork";
"recipe.se_raggmunk_med_flask.step4.body" = "Melt a little %i6 in a frying pan, spoon in portions of the potato batter, spread them into thin pancakes, and fry until golden on the first side.";
"recipe.se_raggmunk_med_flask.step4.title" = "Fry the raggmunk";
"recipe.se_raggmunk_med_flask.step5.body" = "Turn the pancakes and fry until cooked through and crisp around the edges, adding more butter as needed between batches.";
"recipe.se_raggmunk_med_flask.step5.title" = "Turn and finish";
"recipe.se_raggmunk_med_flask.step6.body" = "Serve the raggmunk immediately with the fried pork and %i8.";
"recipe.se_raggmunk_med_flask.step6.title" = "Serve traditionally";
