"recipe.bo_fricase_paceno.step4.title" = "Blend the chili base";
"recipe.bo_fricase_paceno.step5.body" = "Place %i1 in the pot with water, %i10, %i7, and %i8. Bring to a boil, lower the heat, and simmer until the pork is very tender.";
"recipe.bo_fricase_paceno.step5.title" = "Cook the pork";
"recipe.bo_fricase_paceno.step6.body" = "Stir the blended chili base into the pot and simmer until the broth turns deep yellow and the flavors come together.";
"recipe.bo_fricase_paceno.step6.title" = "Build the broth";
"recipe.bo_fricase_paceno.step7.body" = "Add the soaked chuño to the broth and cook until tender and fully infused with the pork and chili flavors.";
"recipe.bo_fricase_paceno.step7.title" = "Cook the chuño";
"recipe.bo_fricase_paceno.step8.body" = "Sprinkle in %i9 and stir well so the broth thickens slightly without becoming heavy. Taste and adjust the salt.";
"recipe.bo_fricase_paceno.step8.title" = "Thicken the fricase";
"recipe.bo_fricase_paceno.step9.body" = "Heat the cooked mote with a little of the hot broth until fully warmed through.";
