"recipe.cn_ma_la_xiao_long_xia.drink.body" = "A cold lager pairs naturally with the spicy oily sauce and shellfish sweetness, while iced unsweetened barley tea is a classic non-alcoholic option that helps cool the palate.";
"recipe.cn_ma_la_xiao_long_xia.drink.summary" = "Beer (Lager)";
"recipe.cn_ma_la_xiao_long_xia.info" = "Ma la xiao long xia is a traditional Chinese summer night-market dish of crayfish stir-braised with dried chilies, Sichuan peppercorns, doubanjiang, aromatics, and beer until deeply fragrant and glossy. It is commonly served hot in a large shared platter, often with cucumber as a cooling side and bread for soaking up the rich mala sauce.";
"recipe.cn_ma_la_xiao_long_xia.info.summary" = "Mala crayfish platter";
"recipe.cn_ma_la_xiao_long_xia.name" = "Spicy crayfish";
"recipe.cn_ma_la_xiao_long_xia.step1.body" = "Rinse the %i1 several times in %i2, scrub the shells, trim long whiskers and sharp claws with scissors, and remove the intestinal vein from each crayfish, then drain well.";
"recipe.cn_ma_la_xiao_long_xia.step1.title" = "Clean and trim the crayfish";
"recipe.cn_ma_la_xiao_long_xia.step10.body" = "Slice the %i22 and chop the %i21, then arrange the cucumber on a serving platter as a cooling base.";
"recipe.cn_ma_la_xiao_long_xia.step10.title" = "Prepare garnish and side";
"recipe.cn_ma_la_xiao_long_xia.step11.body" = "Pile the crayfish over the cucumber, spoon over the remaining mala sauce, scatter with cilantro, and serve hot with %i23 for soaking up the sauce.";
"recipe.cn_ma_la_xiao_long_xia.step11.title" = "Plate and serve";
"recipe.cn_ma_la_xiao_long_xia.step2.body" = "Soak the cleaned crayfish in %i3 water briefly, then rinse again and drain thoroughly to reduce grit and surface impurities.";
"recipe.cn_ma_la_xiao_long_xia.step2.title" = "Purge briefly with salt water";
"recipe.cn_ma_la_xiao_long_xia.step3.body" = "Slice the %i8, crush the %i9, cut the %i10 into sections, break the %i6 into pieces, and measure the mala braising seasonings.";
"recipe.cn_ma_la_xiao_long_xia.step3.title" = "Prepare aromatics and spices";
"recipe.cn_ma_la_xiao_long_xia.step4.body" = "Heat a large wok until hot, add the %i4, and swirl to coat the wok well.";
"recipe.cn_ma_la_xiao_long_xia.step4.title" = "Heat the wok and oil";
"recipe.cn_ma_la_xiao_long_xia.step5.body" = "Add %i5, dried chilies, %i7, %i11, %i12, and %i13, and stir-fry until the oil turns red and fragrant.";
"recipe.cn_ma_la_xiao_long_xia.step5.title" = "Fry the mala base";
"recipe.cn_ma_la_xiao_long_xia.step6.body" = "Add ginger, garlic, and scallions, then stir-fry briefly before adding %i14, %i15, %i16, and %i17.";
"recipe.cn_ma_la_xiao_long_xia.step6.title" = "Add aromatics and seasonings";
"recipe.cn_ma_la_xiao_long_xia.step7.body" = "Add the crayfish to the wok and toss over high heat until the shells turn bright red and are evenly coated with the spicy paste.";
"recipe.cn_ma_la_xiao_long_xia.step7.title" = "Stir-fry the crayfish";
"recipe.cn_ma_la_xiao_long_xia.step8.body" = "Add %i18 and %i19, bring to a strong boil, cover, and braise until the crayfish are fully cooked and the flavors penetrate the shells.";
"recipe.cn_ma_la_xiao_long_xia.step8.title" = "Braise with beer";
"recipe.cn_ma_la_xiao_long_xia.step9.body" = "Uncover and cook over higher heat, tossing frequently, until the sauce thickens and clings to the crayfish, then finish with %i20.";
"recipe.cn_ma_la_xiao_long_xia.step9.title" = "Reduce the sauce";
