"recipe.pe_crema_volteada.drink.body" = "Pair with a lightly sweet Moscatel or late-harvest white that echoes the caramel and vanilla. A small pour of aged rum also pairs well. For a non-alcoholic option, serve strong Peruvian-style coffee or black tea.";
"recipe.pe_crema_volteada.drink.summary" = "Dessert wine (Moscatel)";
"recipe.pe_crema_volteada.info" = "Crema Volteada is Peru’s classic baked caramel custard, similar to a rich flan, made with eggs blended into a smooth mixture of evaporated milk and sweetened condensed milk, flavored with vanilla, then baked gently in a water bath. It is chilled until set, then unmolded so the amber caramel sauce coats the custard and pools on the plate, served cold as a traditional finishing dessert.";
"recipe.pe_crema_volteada.info.summary" = "Caramel milk flan";
"recipe.pe_crema_volteada.name" = "Crema volteada";
"recipe.pe_crema_volteada.step1.body" = "Preheat the oven and place the flan mold or ramekins nearby with the roasting pan ready for a water bath.";
"recipe.pe_crema_volteada.step1.title" = "Preheat and set up";
"recipe.pe_crema_volteada.step2.body" = "Cook the %i1 with a little %i2 in a saucepan until it melts and turns a deep amber. Immediately pour the caramel into the mold and swirl to coat the base evenly.";
"recipe.pe_crema_volteada.step2.title" = "Make the caramel";
"recipe.pe_crema_volteada.step3.body" = "Whisk the %i3, then whisk in the %i4, %i5, and %i6 until completely smooth.";
"recipe.pe_crema_volteada.step3.title" = "Mix the custard";
"recipe.pe_crema_volteada.step4.body" = "Strain the custard mixture into the caramel-lined mold to remove bubbles and any bits of egg.";
"recipe.pe_crema_volteada.step4.title" = "Strain into the mold";
"recipe.pe_crema_volteada.step5.body" = "Set the mold in the roasting pan. Pour hot %i7 into the pan to surround the mold, taking care not to splash into the custard.";
"recipe.pe_crema_volteada.step5.title" = "Prepare the water bath";
"recipe.pe_crema_volteada.step6.body" = "Bake until the custard is set around the edges and still slightly wobbly in the center.";
"recipe.pe_crema_volteada.step6.title" = "Bake gently";
"recipe.pe_crema_volteada.step7.body" = "Remove the mold from the water bath and let it cool to room temperature.";
"recipe.pe_crema_volteada.step7.title" = "Cool completely";
"recipe.pe_crema_volteada.step8.body" = "Refrigerate until fully chilled and firm.";
"recipe.pe_crema_volteada.step8.title" = "Chill to set";
"recipe.pe_crema_volteada.step9.body" = "Run a thin knife around the edge, invert onto a plate, and lift off the mold so the caramel sauce flows over the custard. Serve cold.";
"recipe.pe_crema_volteada.step9.title" = "Unmold and serve";
