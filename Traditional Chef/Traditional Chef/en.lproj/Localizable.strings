"recipe.lb_kibbeh_bil_sanieh.drink.body" = "Pair with a medium-bodied Lebanese red blend, Cinsault, or Syrah to match the warm spices and baked meat. For a non-alcoholic option, serve chilled laban or plain yogurt drink, or sparkling water with lemon.";
"recipe.lb_kibbeh_bil_sanieh.drink.summary" = "Red wine (Lebanese blend)";
"recipe.lb_kibbeh_bil_sanieh.info" = "Kibbeh bil sanieh is the classic Lebanese baked kibbeh tray made with a finely worked mixture of lean meat and bulgur, layered in a pan around a spiced meat filling with toasted pine nuts. It is cut into diamond shapes before baking and served warm or at room temperature as a centerpiece dish, commonly accompanied by plain yogurt and warm pita.";
"recipe.lb_kibbeh_bil_sanieh.info.summary" = "Baked kibbeh tray";
"recipe.lb_kibbeh_bil_sanieh.name" = "Baked kibbeh";
"recipe.lb_kibbeh_bil_sanieh.step1.body" = "Rinse the %i1, cover with %i2, and let it sit until the grains soften. Drain well and squeeze out excess moisture so the mixture stays firm.";
"recipe.lb_kibbeh_bil_sanieh.step1.title" = "Soak the bulgur";
"recipe.lb_kibbeh_bil_sanieh.step2.body" = "Process the %i4 until very fine. Add the drained bulgur and process, then add the %i3, %i5, and %i6. Process until the mixture becomes cohesive and smooth, stopping to scrape the bowl as needed.";
"recipe.lb_kibbeh_bil_sanieh.step2.title" = "Make the kibbeh dough";
