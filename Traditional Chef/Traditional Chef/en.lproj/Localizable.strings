"recipe.ca_tourtiere.info" = "Tourtière is a traditional Quebec meat pie with a flaky double crust and a gently spiced filling of pork, beef, onion, potato, and stock. It is especially associated with holiday tables and winter family meals, and it is classically served hot with fruit ketchup on the side.";
"recipe.ca_tourtiere.info.summary" = "Quebec meat pie";
"recipe.ca_tourtiere.name" = "Tourtière";
