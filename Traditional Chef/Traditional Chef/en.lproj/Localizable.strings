"recipe.cn_peking_duck.drink.body" = "A dry sparkling wine or crisp lager pairs well with the rich duck skin and sweet-savory sauce, while hot jasmine tea is a classic non-alcoholic pairing that refreshes the palate and cuts the fat.";
"recipe.cn_peking_duck.drink.summary" = "Sparkling wine";
"recipe.cn_peking_duck.info" = "Peking duck is a classic Beijing banquet dish featuring air-dried duck roasted until the skin is deeply lacquered and crisp, then carved and served with thin pancakes, scallions, cucumber, and sweet bean sauce. It is traditionally presented as a shared centerpiece for wrapping at the table.";
"recipe.cn_peking_duck.info.summary" = "Beijing roast duck";
"recipe.cn_peking_duck.name" = "Peking duck";
"recipe.cn_peking_duck.step1.body" = "Trim any excess fat from the %i1, rinse and pat dry thoroughly, then rub the cavity with %i8 and add the %i2, %i3, and %i4.";
"recipe.cn_peking_duck.step1.title" = "Prepare the duck";
"recipe.cn_peking_duck.step10.body" = "Cut the %i12 and %i13 into thin batons and place them with the %i14 in serving dishes.";
"recipe.cn_peking_duck.step10.title" = "Prepare table accompaniments";
"recipe.cn_peking_duck.step11.body" = "Remove the roasted duck from the oven and let it rest briefly so carving is cleaner and the juices settle.";
"recipe.cn_peking_duck.step11.title" = "Rest the duck";
"recipe.cn_peking_duck.step12.body" = "Carve the duck into thin slices with skin on, arrange on a platter, and serve immediately with warm pancakes, scallions, cucumber, and sweet bean sauce for wrapping.";
"recipe.cn_peking_duck.step12.title" = "Carve and serve";
"recipe.cn_peking_duck.step2.body" = "Bring %i5 to a boil in a large pot, then dissolve the %i6, %i7, and salt to make the traditional glazing liquid.";
"recipe.cn_peking_duck.step2.title" = "Make the scalding glaze";
"recipe.cn_peking_duck.step3.body" = "Hold or hang the duck and ladle the hot glaze over the skin repeatedly until the skin tightens and is evenly coated.";
"recipe.cn_peking_duck.step3.title" = "Scald and glaze the duck";
"recipe.cn_peking_duck.step4.body" = "Hang the duck in a cool ventilated place and dry until the skin is taut and no longer wet to the touch, using a fan to help if needed.";
"recipe.cn_peking_duck.step4.title" = "Air-dry the duck";
"recipe.cn_peking_duck.step5.body" = "Mix the %i9 with %i10 to form a soft dough, knead until smooth, and let it rest covered.";
"recipe.cn_peking_duck.step5.title" = "Prepare pancake dough";
"recipe.cn_peking_duck.step6.body" = "Let the dough rest so it relaxes and becomes easier to roll into thin pancakes.";
"recipe.cn_peking_duck.step6.title" = "Rest the dough";
"recipe.cn_peking_duck.step7.body" = "Divide the dough, form small pieces, brush paired pieces lightly with %i11 between them, press together, and roll each pair into thin rounds.";
"recipe.cn_peking_duck.step7.title" = "Shape and roll pancake pairs";
"recipe.cn_peking_duck.step8.body" = "Steam the rolled pancake pairs until cooked through and pliable, then separate each pair into individual thin pancakes and keep them warm.";
"recipe.cn_peking_duck.step8.title" = "Steam the pancakes";
"recipe.cn_peking_duck.step9.body" = "Place the dried duck on a rack in the oven and roast until the skin is mahogany-colored and crisp and the meat is cooked through, turning as needed for even color.";
"recipe.cn_peking_duck.step9.title" = "Roast the duck";
