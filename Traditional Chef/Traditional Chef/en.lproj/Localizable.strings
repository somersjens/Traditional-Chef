"recipe.za_malva_pudding.step4.title" = "Combine wet ingredients";
"recipe.za_malva_pudding.step5.body" = "Sift in the %i8, %i9, and %i10, then fold until the batter is smooth with no dry pockets.";
"recipe.za_malva_pudding.step5.title" = "Add dry ingredients";
"recipe.za_malva_pudding.step6.body" = "Pour the batter into the baking dish and bake until risen, deeply golden, and set in the center.";
"recipe.za_malva_pudding.step6.title" = "Bake the pudding";
"recipe.za_malva_pudding.step7.body" = "In a saucepan, combine the %i11, %i12, %i13, %i14, and %i15 and bring to a boil, stirring until the sugar dissolves.";
"recipe.za_malva_pudding.step7.title" = "Cook the hot cream sauce";
"recipe.za_malva_pudding.step8.body" = "Reduce the heat and simmer the sauce until glossy and slightly thickened.";
"recipe.za_malva_pudding.step8.title" = "Simmer the sauce";
"recipe.za_malva_pudding.step9.body" = "Remove the baked pudding from the oven and immediately pierce it all over with a skewer.";
"recipe.za_malva_pudding.step9.title" = "Pierce the hot pudding";
