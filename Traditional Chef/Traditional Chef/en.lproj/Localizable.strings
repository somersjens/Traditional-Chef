"recipe.it_cannoli_siciliani.step11.body" = "Serve immediately once filled.";
"recipe.it_cannoli_siciliani.step11.title" = "Serve the cannoli";
"recipe.it_cannoli_siciliani.step2.body" = "Cover the dough and let it rest so it relaxes for rolling.";
"recipe.it_cannoli_siciliani.step2.title" = "Rest the dough";
"recipe.it_cannoli_siciliani.step3.body" = "Press %i9 through a fine sieve into a bowl to make it smooth and remove excess moisture.";
"recipe.it_cannoli_siciliani.step3.title" = "Drain the ricotta";
"recipe.it_cannoli_siciliani.step4.body" = "Stir %i10 into the ricotta until dissolved, then fold in %i11 and %i12. Refrigerate until needed.";
"recipe.it_cannoli_siciliani.step4.title" = "Mix the filling";
"recipe.it_cannoli_siciliani.step5.body" = "Roll the dough very thin and cut it into rounds.";
"recipe.it_cannoli_siciliani.step5.title" = "Roll and cut";
"recipe.it_cannoli_siciliani.step6.body" = "Wrap each round around a cannoli tube, sealing the edge with a little beaten egg so it holds during frying.";
"recipe.it_cannoli_siciliani.step6.title" = "Form the shells";
"recipe.it_cannoli_siciliani.step7.body" = "Heat %i13 in a deep pot to frying temperature.";
"recipe.it_cannoli_siciliani.step7.title" = "Heat the oil";
"recipe.it_cannoli_siciliani.step8.body" = "Fry the shells in batches until blistered and golden, turning for even colour. Remove them and drain on paper towels.";
"recipe.it_cannoli_siciliani.step8.title" = "Fry the shells";
"recipe.it_cannoli_siciliani.step9.body" = "Let the shells cool until safe to handle, then slide them off the tubes.";
