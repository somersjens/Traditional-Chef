"recipe.pl_sernik.step1.title" = "Make shortcrust dough";
"recipe.pl_sernik.step10.body" = "Refrigerate until fully chilled and sliceable.";
"recipe.pl_sernik.step10.title" = "Chill to firm";
"recipe.pl_sernik.step11.body" = "Dust with %i16 and cut into portions to serve.";
"recipe.pl_sernik.step11.title" = "Finish and serve";
