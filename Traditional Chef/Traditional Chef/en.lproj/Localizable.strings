"recipe.ps_musakhan.drink.body" = "A medium-bodied red wine such as Syrah or Cinsault works well with the tangy sumac, rich olive oil, and roasted chicken. For a non-alcoholic pairing, serve hot mint tea or cold unsweetened black tea.";
"recipe.ps_musakhan.drink.summary" = "Red wine (Syrah)";
"recipe.ps_musakhan.info" = "Musakhan is a traditional Palestinian main dish of roast chicken set over taboon bread soaked with olive oil, sweet onions, and sumac. It is served communally, often during family gatherings and the olive harvest season, and is typically eaten by hand with the bread and onions beneath the chicken.";
"recipe.ps_musakhan.info.summary" = "Sumac roast chicken";
"recipe.ps_musakhan.name" = "Musakhan";
"recipe.ps_musakhan.step1.body" = "Rub %i1 all over with part of %i2, %i3, %i5, %i6, %i7, and half of the total %i4. Leave it to take on the seasoning while you prepare the onions.";
"recipe.ps_musakhan.step1.title" = "Season the chicken";
"recipe.ps_musakhan.step2.body" = "Arrange the chicken in a roasting pan and roast until deeply golden and cooked through, turning once during roasting so it browns evenly and releases its juices.";
"recipe.ps_musakhan.step2.title" = "Roast the chicken";
"recipe.ps_musakhan.step3.body" = "Peel and slice %i8 thinly while the chicken roasts so they are ready to cook down evenly.";
"recipe.ps_musakhan.step3.title" = "Slice the onions";
"recipe.ps_musakhan.step4.body" = "Heat most of the remaining olive oil in a large skillet, add the onions and cook gently until very soft and sweet. Stir in the remaining salt and %i9 and continue until the onions are fully coated, tender, and richly seasoned.";
"recipe.ps_musakhan.step4.title" = "Cook the sumac onions";
"recipe.ps_musakhan.step5.body" = "Toast %i12 briefly in a dry pan until lightly golden, then remove them at once so they do not darken further.";
"recipe.ps_musakhan.step5.title" = "Toast the pine nuts";
"recipe.ps_musakhan.step6.body" = "Brush %i11 with the rest of the olive oil and some of the juices from the roasted chicken, then warm it until supple and fragrant.";
"recipe.ps_musakhan.step6.title" = "Warm the bread";
"recipe.ps_musakhan.step7.body" = "Spread the sumac onions generously over the warm bread, place the chicken on top, and spoon over the remaining roasting juices so the bread absorbs the flavor.";
"recipe.ps_musakhan.step7.title" = "Assemble the musakhan";
"recipe.ps_musakhan.step8.body" = "Return the assembled dish to the oven until heated through, then scatter the toasted pine nuts over the top and serve immediately.";
"recipe.ps_musakhan.step8.title" = "Finish and serve";
