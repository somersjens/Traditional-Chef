"recipe.de_dampfnudeln.drink.body" = "Pair with a lightly sweet white such as Riesling Kabinett that complements vanilla and gentle caramel notes without tasting heavy. A wheat beer can also work if you prefer beer. For a non-alcoholic option, serve black tea, coffee, or warm milk.";
"recipe.de_dampfnudeln.drink.summary" = "White wine (Riesling)";
"recipe.de_dampfnudeln.info" = "Dampfnudeln are traditional German steamed yeast dumplings cooked in a covered pan with milk and butter so they stay fluffy on top while forming a lightly caramelized crust underneath. They are classically served warm with homemade vanilla sauce, making them a comforting dessert found especially in southern Germany and the Palatinate.";
"recipe.de_dampfnudeln.info.summary" = "Southern steamed dumplings";
"recipe.de_dampfnudeln.name" = "Vanilla Dampfnudeln";
"recipe.de_dampfnudeln.step1.body" = "Warm %i2 until lukewarm and dissolve %i3 in it. Combine %i1, %i4, and %i5, then add %i6, softened %i7, and the yeasted milk and knead until smooth and elastic.";
"recipe.de_dampfnudeln.step1.title" = "Make the yeast dough";
"recipe.de_dampfnudeln.step10.body" = "Remove the vanilla pod and whisk the warm milk into the yolk mixture, then return it to the saucepan and cook gently while whisking until thickened, without boiling.";
"recipe.de_dampfnudeln.step10.title" = "Cook the vanilla sauce";
"recipe.de_dampfnudeln.step11.body" = "Serve the warm Dampfnudeln with vanilla sauce spooned over or alongside.";
"recipe.de_dampfnudeln.step11.title" = "Serve the dampfnudeln";
"recipe.de_dampfnudeln.step2.body" = "Cover the dough and let it rise in a warm place until doubled in size.";
"recipe.de_dampfnudeln.step2.title" = "Let the dough rise";
"recipe.de_dampfnudeln.step3.body" = "Punch down the dough and divide it into even portions. Shape each portion into a smooth ball with a taut surface.";
"recipe.de_dampfnudeln.step3.title" = "Shape the dumplings";
"recipe.de_dampfnudeln.step4.body" = "Arrange the dough balls with space between them, cover, and let them rise until noticeably puffy.";
"recipe.de_dampfnudeln.step4.title" = "Proof the dumplings";
"recipe.de_dampfnudeln.step5.body" = "Melt %i9 in a wide skillet, add %i8, %i10, and %i11, and bring it to a gentle simmer.";
"recipe.de_dampfnudeln.step5.title" = "Prepare the steaming pan";
"recipe.de_dampfnudeln.step6.body" = "Place the risen dumplings into the simmering liquid, cover tightly, and steam gently until the dumplings are cooked through and fluffy.";
"recipe.de_dampfnudeln.step6.title" = "Steam the dumplings";
"recipe.de_dampfnudeln.step7.body" = "Remove the lid and continue cooking until the liquid has evaporated and a golden crust forms on the bottoms without burning.";
"recipe.de_dampfnudeln.step7.title" = "Create the crust";
"recipe.de_dampfnudeln.step8.body" = "Split %i15, add it to %i12, and warm until steaming, then remove from the heat to infuse briefly.";
"recipe.de_dampfnudeln.step8.title" = "Infuse the milk";
"recipe.de_dampfnudeln.step9.body" = "Whisk %i13 with %i14, %i16, and a pinch of %i17 until smooth.";
"recipe.de_dampfnudeln.step9.title" = "Mix the yolks and starch";
