"recipe.gb_sussex_pond_pudding.step4.body" = "Prick the %i5 all over, put it into the pastry-lined basin, then pack the %i6 and %i7 around it.";
"recipe.gb_sussex_pond_pudding.step4.title" = "Prepare filling";
"recipe.gb_sussex_pond_pudding.step5.body" = "Roll out the reserved pastry for a lid, place it on top, seal the edges well, and trim any excess.";
"recipe.gb_sussex_pond_pudding.step5.title" = "Seal pudding";
"recipe.gb_sussex_pond_pudding.step6.body" = "Cover the basin with pleated parchment and foil, tie securely with string, and make a handle for lifting.";
"recipe.gb_sussex_pond_pudding.step6.title" = "Cover basin";
"recipe.gb_sussex_pond_pudding.step7.body" = "Place the basin over simmering water and steam until the pastry is tender and the lemon filling has formed a rich syrup, topping up water as needed.";
"recipe.gb_sussex_pond_pudding.step7.title" = "Steam pudding";
"recipe.gb_sussex_pond_pudding.step8.body" = "For the custard, heat the %i8 and %i9 with %i12 until hot but not boiling.";
"recipe.gb_sussex_pond_pudding.step8.title" = "Heat custard dairy";
"recipe.gb_sussex_pond_pudding.step9.body" = "Whisk the %i10 with %i11, pour in the hot dairy gradually, then return to gentle heat and stir until the custard thickens enough to coat a spoon.";
"recipe.gb_sussex_pond_pudding.step9.title" = "Finish custard";
