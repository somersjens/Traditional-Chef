"recipe.eg_kofta.step2.title" = "Mix the kofta";
"recipe.eg_kofta.step3.body" = "Cover and refrigerate so the mixture firms up and holds on skewers.";
"recipe.eg_kofta.step3.title" = "Chill the mixture";
"recipe.eg_kofta.step4.body" = "Divide the mixture and press it firmly along metal skewers into long, even kebabs, smoothing the surface so it cooks evenly.";
"recipe.eg_kofta.step4.title" = "Shape onto skewers";
"recipe.eg_kofta.step5.body" = "Crush %i10 and whisk it into %i9 with %i11 and %i13. Whisk in %i12 gradually until the sauce turns smooth, pale, and pourable.";
"recipe.eg_kofta.step5.title" = "Prepare the tahini sauce";
