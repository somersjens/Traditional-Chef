"recipe.cu_lechon_asado.drink.body" = "Pair with a crisp, citrusy white such as Albariño or Sauvignon Blanc to match the mojo and cut the richness. For a non-alcoholic option, serve sparkling water with lime or a tart citrus juice.";
"recipe.cu_lechon_asado.drink.summary" = "White wine (Albariño)";
"recipe.cu_lechon_asado.info" = "Cuban lechon asado is slow-roasted pork, deeply marinated with garlicky citrus mojo and aromatic spices until tender and browned. It is traditionally served with extra mojo spooned over the sliced pork, and commonly accompanied by yuca with mojo so the bright citrus-garlic flavors carry through the meal.";
"recipe.cu_lechon_asado.info.summary" = "Mojo roast pork";
"recipe.cu_lechon_asado.name" = "Lechon asado";
"recipe.cu_lechon_asado.step1.body" = "Blend %i2 with %i3, %i4, %i5, %i6, and %i7 until the garlic is very fine and the mixture is evenly combined.";
"recipe.cu_lechon_asado.step1.title" = "Make the mojo marinade";
"recipe.cu_lechon_asado.step10.body" = "Serve the lechon asado with the cooked yuca and drizzle the remaining mojo over the yuca and pork at the table.";
"recipe.cu_lechon_asado.step10.title" = "Serve";
"recipe.cu_lechon_asado.step2.body" = "Score the fat side of the %i1 and rub the mojo marinade all over, working it into the cuts. Cover and refrigerate.";
"recipe.cu_lechon_asado.step2.title" = "Marinate the pork";
"recipe.cu_lechon_asado.step3.body" = "Leave the pork to marinate so the garlic-citrus flavor penetrates deeply.";
"recipe.cu_lechon_asado.step3.title" = "Rest overnight";
"recipe.cu_lechon_asado.step4.body" = "Bring the pork toward room temperature briefly, then heat the oven and place the pork in a roasting pan.";
"recipe.cu_lechon_asado.step4.title" = "Preheat and set up for roasting";
"recipe.cu_lechon_asado.step5.body" = "Roast until the pork is deeply browned and very tender, basting occasionally with pan juices, and cook until a thermometer shows it is done.";
