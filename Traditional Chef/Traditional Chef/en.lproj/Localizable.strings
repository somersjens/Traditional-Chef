"recipe.et_kitfo.step12.title" = "Season as kitfo";
"recipe.et_kitfo.step13.body" = "Arrange injera on a platter. Spoon kitfo onto the injera, add ayib and gomen alongside, and serve immediately with extra injera for scooping.";
"recipe.et_kitfo.step13.title" = "Serve with accompaniments";
