"recipe.th_pad_krapao_moo_sap.drink.body" = "A cold light lager works well with the salty spicy stir-fry and fried egg richness. For a non-alcoholic pairing, serve cold water, unsweetened iced tea, or chilled jasmine tea.";
"recipe.th_pad_krapao_moo_sap.drink.summary" = "Beer (Lager)";
"recipe.th_pad_krapao_moo_sap.info" = "Pad Krapao Moo Sap is a traditional Thai stir-fry of minced pork cooked over high heat with garlic, bird eye chili, fish sauce, oyster sauce, and holy basil. It is typically served immediately over jasmine rice and commonly topped with a crispy fried egg for a complete everyday meal.";
