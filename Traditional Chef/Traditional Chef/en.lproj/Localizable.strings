"recipe.eg_kebda_iskandarani.step1.title" = "Prep the ingredients";
"recipe.eg_kebda_iskandarani.step2.body" = "In a bowl, toss the liver with %i8, %i6, %i7, %i9, and %i10 until evenly coated.";
"recipe.eg_kebda_iskandarani.step2.title" = "Season the liver";
"recipe.eg_kebda_iskandarani.step3.body" = "Heat %i11 in a skillet and add garlic and hot chile. Cook gently until fragrant without browning the garlic too dark.";
"recipe.eg_kebda_iskandarani.step3.title" = "Start the garlic-chile base";
"recipe.eg_kebda_iskandarani.step4.body" = "Add green pepper and cook until it softens slightly while staying bright.";
"recipe.eg_kebda_iskandarani.step4.title" = "Cook the peppers";
"recipe.eg_kebda_iskandarani.step5.body" = "Add the seasoned liver to the hot skillet and cook, tossing, until the liver is just cooked through and still tender.";
"recipe.eg_kebda_iskandarani.step5.title" = "Sauté the liver quickly";
"recipe.eg_kebda_iskandarani.step6.body" = "Stir in parsley and cook briefly so it wilts and perfumes the pan.";
"recipe.eg_kebda_iskandarani.step6.title" = "Finish with parsley";
"recipe.eg_kebda_iskandarani.step7.body" = "Split %i12, spread with %i13, and fill with the hot liver. Serve immediately with %i14.";
"recipe.eg_kebda_iskandarani.step7.title" = "Serve as sandwiches";
