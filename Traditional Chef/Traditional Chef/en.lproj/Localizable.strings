"recipe.tn_tajine_tounsi.drink.body" = "A crisp white such as Vermentino pairs with the savory egg and chicken, while a non-alcoholic option is hot Tunisian mint tea or sparkling water with lemon.";
"recipe.tn_tajine_tounsi.drink.summary" = "White wine (Vermentino)";
"recipe.tn_tajine_tounsi.info" = "Tajine Tounsi is a traditional Tunisian baked egg-and-chicken casserole where shredded cooked chicken is mixed with sautéed onion, parsley, cheese, and spiced eggs, then baked until puffed and set, served cut into squares and commonly accompanied by Tunisian bread and harissa.";
"recipe.tn_tajine_tounsi.info.summary" = "Chicken egg bake";
"recipe.tn_tajine_tounsi.name" = "Tunisian tajine";
"recipe.tn_tajine_tounsi.step1.body" = "Simmer the %i1 in %i16 with %i8 until cooked through, then lift out, cool slightly, and shred into small pieces.";
"recipe.tn_tajine_tounsi.step1.title" = "Cook the chicken";
"recipe.tn_tajine_tounsi.step2.body" = "Chop the %i2, crush the %i3, and finely chop the %i5.";
"recipe.tn_tajine_tounsi.step2.title" = "Prep aromatics";
"recipe.tn_tajine_tounsi.step3.body" = "Heat %i4 in a skillet, cook the onion until softened, then add garlic briefly until fragrant and take off the heat.";
"recipe.tn_tajine_tounsi.step3.title" = "Sauté onion and garlic";
"recipe.tn_tajine_tounsi.step4.body" = "In a bowl, whisk the %i13 with salt, %i7, %i9, %i10, %i11, and %i12, then stir in shredded chicken, parsley, sautéed onion mixture, and %i6.";
"recipe.tn_tajine_tounsi.step4.title" = "Mix the base";
"recipe.tn_tajine_tounsi.step5.body" = "Heat the oven and lightly oil the baking dish so the tajine releases cleanly.";
"recipe.tn_tajine_tounsi.step5.title" = "Heat the oven and dish";
"recipe.tn_tajine_tounsi.step6.body" = "Pour the mixture into the dish and bake until puffed, golden on top, and fully set in the center.";
"recipe.tn_tajine_tounsi.step6.title" = "Bake until set";
"recipe.tn_tajine_tounsi.step7.body" = "Let the tajine rest so it firms up, then cut into squares.";
"recipe.tn_tajine_tounsi.step7.title" = "Rest and slice";
"recipe.tn_tajine_tounsi.step8.body" = "Serve warm with %i14 and %i15 on the side.";
"recipe.tn_tajine_tounsi.step8.title" = "Serve";
