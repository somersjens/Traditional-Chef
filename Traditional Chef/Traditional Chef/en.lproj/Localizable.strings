"recipe.gb_devilled_kidneys.drink.body" = "A small dry sherry or light red wine complements the mustardy, savoury sauce. For a non-alcoholic option, serve strong black tea or sparkling water with lemon.";
"recipe.gb_devilled_kidneys.drink.summary" = "Sherry";
"recipe.gb_devilled_kidneys.info" = "A traditional British dish of lamb kidneys quickly fried and coated in a hot, tangy devilled sauce with mustard and Worcestershire, then served immediately on hot buttered toast. It was classically eaten for breakfast or supper and also works as a rich starter.";
"recipe.gb_devilled_kidneys.info.summary" = "Devilled kidneys on toast";
"recipe.gb_devilled_kidneys.name" = "Devilled kidneys";
"recipe.gb_devilled_kidneys.step1.body" = "Split the %i1, trim away the cores, cut into bite-size pieces, then season with half the %i9 and half the %i8 and toss lightly with the %i4.";
"recipe.gb_devilled_kidneys.step1.title" = "Prepare kidneys";
"recipe.gb_devilled_kidneys.step2.body" = "In a small bowl combine the %i5, %i6, %i7, and %i11 so it is ready to add quickly during cooking.";
"recipe.gb_devilled_kidneys.step2.title" = "Make devilled mix";
"recipe.gb_devilled_kidneys.step3.body" = "Toast the %i13 until hot and crisp, butter it with %i14, and keep warm for serving.";
"recipe.gb_devilled_kidneys.step3.title" = "Toast bread";
"recipe.gb_devilled_kidneys.step4.body" = "Melt half the %i2 in a hot frying pan and cook the %i3 briefly until softened but not browned.";
"recipe.gb_devilled_kidneys.step4.title" = "Soften shallot";
"recipe.gb_devilled_kidneys.step5.body" = "Add the remaining butter, then add the kidneys and fry quickly over high heat until browned outside and still tender inside.";
"recipe.gb_devilled_kidneys.step5.title" = "Sear kidneys";
"recipe.gb_devilled_kidneys.step6.body" = "Stir in the devilled mix, then add the %i10 and the remaining salt and black pepper and cook briefly until the sauce bubbles and lightly thickens.";
"recipe.gb_devilled_kidneys.step6.title" = "Build sauce";
"recipe.gb_devilled_kidneys.step7.body" = "Stir in most of the %i12 and toss the kidneys in the sauce for a final moment.";
"recipe.gb_devilled_kidneys.step7.title" = "Finish with parsley";
"recipe.gb_devilled_kidneys.step8.body" = "Spoon the devilled kidneys and sauce over the hot buttered toast, scatter over the remaining parsley, and serve immediately.";
"recipe.gb_devilled_kidneys.step8.title" = "Serve on toast";
