"recipe.dk_tarteletter_med_hons_i_asparges.drink.body" = "A dry white wine such as Riesling or Pinot Blanc pairs well with the creamy sauce and delicate chicken. For a non-alcoholic option, serve sparkling water or cold water with lemon.";
"recipe.dk_tarteletter_med_hons_i_asparges.drink.summary" = "White wine (Riesling)";
"recipe.dk_tarteletter_med_hons_i_asparges.info" = "Tarteletter med høns i asparges is a classic Danish dish of crisp tartlet shells filled with a creamy white sauce of poached chicken and white asparagus. It is traditionally served at Easter lunches, Christmas lunches, family gatherings, and festive meals, warm and freshly filled.";
"recipe.dk_tarteletter_med_hons_i_asparges.info.summary" = "Danish tartlet lunch";
"recipe.dk_tarteletter_med_hons_i_asparges.name" = "Chicken tartlets";
