"recipe.pl_sernik.step2.title" = "Chill the dough";
"recipe.pl_sernik.step3.body" = "Line the springform with parchment. Roll out most of the dough and press it into the base of the pan, keeping a portion of dough aside for the lattice top.";
"recipe.pl_sernik.step3.title" = "Line pan and roll base";
"recipe.pl_sernik.step4.body" = "Bake the crust until lightly set and just beginning to color, then remove and let it cool slightly.";
