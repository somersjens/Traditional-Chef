"recipe.pe_pollo_a_la_brasa.drink.body" = "Pair with a juicy Malbec or a medium-bodied Tempranillo to match the smoky spices and roasted skin. A crisp lager is also a classic pairing. For a non-alcoholic option, serve Inca Kola or sparkling water with lime.";
"recipe.pe_pollo_a_la_brasa.drink.summary" = "Red wine (Malbec)";
"recipe.pe_pollo_a_la_brasa.info" = "Pollo a la Brasa is Peru’s famous rotisserie-style chicken, marinated with garlic, spices, soy and vinegar, then roasted until the skin is deeply browned and crisp and the meat stays juicy. It is traditionally served with French fries and a simple salad, with creamy ají sauce and huacatay sauce on the side for dipping.";
"recipe.pe_pollo_a_la_brasa.info.summary" = "Rotisserie chicken feast";
"recipe.pe_pollo_a_la_brasa.name" = "Pollo a la brasa";
"recipe.pe_pollo_a_la_brasa.step1.body" = "Crush the %i7 and mix it with %i2, %i3, %i4, %i5, %i6, %i8, %i9, and %i10 into a thick paste.";
"recipe.pe_pollo_a_la_brasa.step1.title" = "Make the marinade";
"recipe.pe_pollo_a_la_brasa.step10.body" = "Serve the chicken with fries and salad, offering the ají mayo and huacatay sauces on the side.";
"recipe.pe_pollo_a_la_brasa.step10.title" = "Serve";
"recipe.pe_pollo_a_la_brasa.step2.body" = "Pat the %i1 dry and rub the marinade all over, including under the skin where possible. Cover and refrigerate.";
"recipe.pe_pollo_a_la_brasa.step2.title" = "Marinate the chicken";
"recipe.pe_pollo_a_la_brasa.step3.body" = "Leave the chicken to marinate overnight for the traditional flavor and color.";
"recipe.pe_pollo_a_la_brasa.step3.title" = "Rest the marinade";
"recipe.pe_pollo_a_la_brasa.step4.body" = "Cut the %i21 into fries and rinse briefly, then dry well. Slice the %i25 and %i24 and wash the %i23, keeping the salad simple and crisp.";
"recipe.pe_pollo_a_la_brasa.step4.title" = "Prep fries and salad";
"recipe.pe_pollo_a_la_brasa.step5.body" = "Roast the chicken on a rack in a hot oven, turning once if needed, until the skin is deep golden and crisp and the meat is fully cooked.";
"recipe.pe_pollo_a_la_brasa.step5.title" = "Roast the chicken";
"recipe.pe_pollo_a_la_brasa.step6.body" = "Stir together the %i11, %i12, %i13, and %i14 until smooth. Chill until serving.";
"recipe.pe_pollo_a_la_brasa.step6.title" = "Make ají mayo";
"recipe.pe_pollo_a_la_brasa.step7.body" = "Blend the %i15, %i16, lime juice, garlic, %i19, and %i20 until smooth and creamy. Chill until serving.";
"recipe.pe_pollo_a_la_brasa.step7.title" = "Make huacatay sauce";
"recipe.pe_pollo_a_la_brasa.step8.body" = "Fry the potatoes in %i22 until golden and crisp, then drain on paper towels and season with salt while hot.";
"recipe.pe_pollo_a_la_brasa.step8.title" = "Fry the potatoes";
"recipe.pe_pollo_a_la_brasa.step9.body" = "Let the roasted chicken rest, then carve into serving pieces, keeping the juices with the meat.";
"recipe.pe_pollo_a_la_brasa.step9.title" = "Rest and carve";
