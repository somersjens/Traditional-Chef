"recipe.tw_niu_rou_mian.step4.body" = "Add the tomato and cook until softened, then add %i9 and stir until aromatic and the oil turns red.";
"recipe.tw_niu_rou_mian.step4.title" = "Build the braise base";
"recipe.tw_niu_rou_mian.step5.body" = "Return the beef to the pot, add the %i10, %i11, %i12, %i13, %i14, %i15, and %i16, and stir to coat evenly.";
"recipe.tw_niu_rou_mian.step5.title" = "Season and coat beef";
"recipe.tw_niu_rou_mian.step6.body" = "Add water, bring to a boil, lower to a gentle simmer, and cook until the beef is tender and the broth is rich.";
"recipe.tw_niu_rou_mian.step6.title" = "Simmer broth";
"recipe.tw_niu_rou_mian.step7.body" = "Finely chop the %i20 and warm them briefly in a small pan to mellow and concentrate the flavor.";
"recipe.tw_niu_rou_mian.step7.title" = "Prepare mustard greens";
"recipe.tw_niu_rou_mian.step8.body" = "Bring %i19 to a boil and blanch the %i18 until tender-crisp, then drain.";
"recipe.tw_niu_rou_mian.step8.title" = "Blanch bok choy";
