"recipe.se_kroppkakor.drink.body" = "A dry Pinot Gris or other soft white wine pairs well with the rich pork filling and buttery potatoes. A light lager also suits the dish. For a non-alcoholic option, serve sparkling water or lightly sweetened lingonberry drink.";
"recipe.se_kroppkakor.drink.summary" = "White wine (Pinot Gris)";
"recipe.se_kroppkakor.info" = "Kroppkakor are traditional Swedish potato dumplings from southern Sweden, especially associated with Öland, Gotland, Småland, and Blekinge. They are filled with salted pork and onion, boiled until tender, and classically served with melted butter, cream, and lingonberry jam as a hearty family meal.";
"recipe.se_kroppkakor.info.summary" = "Potato dumplings and pork";
"recipe.se_kroppkakor.name" = "Kroppkakor";
"recipe.se_kroppkakor.step1.body" = "Peel %i1, cut them into even pieces, and boil them in salted water until fully tender.";
"recipe.se_kroppkakor.step1.title" = "Boil the potatoes";
"recipe.se_kroppkakor.step2.body" = "Dice %i5 and finely chop %i6. Fry them in %i9 until the pork is lightly browned and the onion is soft, then season with %i7 and %i8.";
"recipe.se_kroppkakor.step2.title" = "Make the filling";
"recipe.se_kroppkakor.step3.body" = "Drain the potatoes well and mash them until smooth. Let the mash cool slightly, then mix in %i2, %i3, and %i4 to form a soft potato dough.";
"recipe.se_kroppkakor.step3.title" = "Prepare the dough";
"recipe.se_kroppkakor.step4.body" = "Divide the dough into even pieces. Flatten each piece in your hand, add some filling to the centre, then close and roll it into smooth dumplings.";
"recipe.se_kroppkakor.step4.title" = "Shape the kroppkakor";
"recipe.se_kroppkakor.step5.body" = "Bring %i10 to a gentle boil in a large pot and add %i11.";
"recipe.se_kroppkakor.step5.title" = "Prepare the boiling water";
"recipe.se_kroppkakor.step6.body" = "Lower the kroppkakor carefully into the water and simmer gently until they float and are cooked through.";
"recipe.se_kroppkakor.step6.title" = "Boil the dumplings";
"recipe.se_kroppkakor.step7.body" = "Melt %i12 gently so it is ready to spoon over the dumplings.";
"recipe.se_kroppkakor.step7.title" = "Melt the serving butter";
"recipe.se_kroppkakor.step8.body" = "Lift out the kroppkakor with a slotted spoon and serve them hot with melted butter, %i13, and %i14.";
"recipe.se_kroppkakor.step8.title" = "Serve traditionally";
