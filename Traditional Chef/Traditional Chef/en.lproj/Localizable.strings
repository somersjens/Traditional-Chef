"recipe.es_paella_valenciana.drink.body" = "Pair with a crisp Spanish white such as Verdejo or a fresh Valencian white to balance the saffron rice and browned meats. A dry rosé also works well with the smoky socarrat. Non-alcoholic option: sparkling water with lemon.";
"recipe.es_paella_valenciana.drink.summary" = "White wine (Verdejo)";
"recipe.es_paella_valenciana.info" = "Paella valenciana is the traditional rice dish from Valencia cooked in a wide, shallow pan over open flame, built from browned chicken and rabbit, green beans and garrofó beans, a tomato-and-paprika sofrito, and saffron-scented rice cooked in a single layer until tender with a prized toasted socarrat at the bottom. It is served straight from the pan for a shared meal, traditionally finished with lemon wedges.";
"recipe.es_paella_valenciana.info.summary" = "Valencian rice classic";
"recipe.es_paella_valenciana.name" = "Paella";
"recipe.es_paella_valenciana.step1.body" = "Grate %i5, trim %i3, and pat %i1 and %i2 dry. Measure %i7 and set aside %i8, %i6, and %i9.";
"recipe.es_paella_valenciana.step1.title" = "Prep ingredients";
"recipe.es_paella_valenciana.step10.body" = "Remove from heat and let the paella rest so the rice finishes steaming and the socarrat sets.";
"recipe.es_paella_valenciana.step10.title" = "Rest the paella";
"recipe.es_paella_valenciana.step11.body" = "Cut %i13 into wedges and serve the paella straight from the pan with lemon alongside.";
"recipe.es_paella_valenciana.step11.title" = "Serve";
"recipe.es_paella_valenciana.step2.body" = "Heat %i10 in the paella pan and brown the chicken and rabbit well, turning until deeply golden and the fond develops.";
"recipe.es_paella_valenciana.step2.title" = "Brown the meats";
"recipe.es_paella_valenciana.step3.body" = "Add the green beans and sauté until they soften slightly and pick up color in the pan.";
"recipe.es_paella_valenciana.step3.title" = "Cook the vegetables";
"recipe.es_paella_valenciana.step4.body" = "Add grated tomato and cook down until it darkens and concentrates. Stir in paprika briefly so it becomes fragrant without burning.";
"recipe.es_paella_valenciana.step4.title" = "Make the sofrito";
"recipe.es_paella_valenciana.step5.body" = "Pour in %i11 and scrape up the fond so it dissolves into the liquid. Bring to a steady simmer and cook so the broth becomes flavorful.";
"recipe.es_paella_valenciana.step5.title" = "Add water and simmer";
"recipe.es_paella_valenciana.step6.body" = "Add %i4, saffron, and salt. Keep the simmer steady so the broth tastes well seasoned.";
"recipe.es_paella_valenciana.step6.title" = "Season and add beans";
"recipe.es_paella_valenciana.step7.body" = "Scatter the rice evenly across the pan in a single layer and level it so it cooks uniformly. Do not stir once it is distributed.";
"recipe.es_paella_valenciana.step7.title" = "Add the rice evenly";
"recipe.es_paella_valenciana.step8.body" = "Maintain a lively simmer so the rice begins to absorb and the surface starts to appear through the liquid.";
"recipe.es_paella_valenciana.step8.title" = "Cook to set the rice";
"recipe.es_paella_valenciana.step9.body" = "Reduce to a gentler heat and cook until the rice is tender and the liquid is absorbed. Add %i12 on top near the end and remove it once the aroma is released.";
"recipe.es_paella_valenciana.step9.title" = "Finish and form socarrat";
