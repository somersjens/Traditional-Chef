"recipe.id_rawon.drink.body" = "A light-bodied Syrah or a crisp lager can stand up to the earthy keluak broth and spices. For a non-alcoholic pairing, serve hot jasmine tea or cold lime water.";
"recipe.id_rawon.drink.summary" = "Red wine (Syrah)";
"recipe.id_rawon.info" = "Rawon is a traditional East Javanese beef soup with a deep black broth made from keluak, aromatic spices, and slow-simmered beef. It is commonly served as a hearty main meal with rice, bean sprouts, salted eggs, sambal, and crackers, especially at family meals and local warung.";
"recipe.id_rawon.info.summary" = "Black keluak beef soup";
"recipe.id_rawon.name" = "Rawon";
"recipe.id_rawon.step1.body" = "Cut the %i1 into serving pieces. Clean the aromatics and bruise the %i8 and %i10 so they release flavor during cooking.";
"recipe.id_rawon.step1.title" = "Prepare the beef and aromatics";
"recipe.id_rawon.step2.body" = "Grind the %i3, %i4, %i5, %i6, %i7, %i9, %i13, and %i14 into a smooth dark paste.";
"recipe.id_rawon.step2.title" = "Make the rawon paste";
"recipe.id_rawon.step3.body" = "Heat %i17 in a pan and fry the paste until fragrant and glossy, stirring well so it cooks through without burning.";
"recipe.id_rawon.step3.title" = "Sauté the spice paste";
"recipe.id_rawon.step4.body" = "Place the beef in a pot with %i2, bring to a gentle simmer, skim if needed, then add the sautéed paste, galangal, lemongrass, %i11, and %i12.";
"recipe.id_rawon.step4.title" = "Simmer the beef";
"recipe.id_rawon.step5.body" = "Continue simmering gently until the beef is tender and the broth is deep, aromatic, and dark. Season with %i15 and %i16 and let the flavors meld.";
"recipe.id_rawon.step5.title" = "Cook until tender";
"recipe.id_rawon.step6.body" = "Slice the %i23, peel and halve the %i20, and ready the %i21, %i22, %i24, and %i18 for serving.";
"recipe.id_rawon.step6.title" = "Prepare the garnishes";
"recipe.id_rawon.step7.body" = "Briefly blanch the %i19 in hot water until just wilted, then drain so they stay crisp-tender.";
"recipe.id_rawon.step7.title" = "Blanch the sprouts";
"recipe.id_rawon.step8.body" = "Place rice and bean sprouts in bowls, ladle over the hot beef and black broth, then top with scallions and fried shallots. Serve with salted eggs, sambal, and prawn crackers on the side.";
"recipe.id_rawon.step8.title" = "Serve the rawon";
