"recipe.kh_chek_ktis.step1.title" = "Soak tapioca";
"recipe.kh_chek_ktis.step2.body" = "Peel the %i1 and slice them into thick diagonal pieces.";
"recipe.kh_chek_ktis.step2.title" = "Prepare bananas";
"recipe.kh_chek_ktis.step3.body" = "Toast the %i7 in a dry pan over medium heat, stirring until fragrant and lightly golden, then set aside.";
"recipe.kh_chek_ktis.step3.title" = "Toast sesame";
"recipe.kh_chek_ktis.step4.body" = "Drain the soaked tapioca pearls and set them aside.";
"recipe.kh_chek_ktis.step4.title" = "Drain tapioca";
"recipe.kh_chek_ktis.step5.body" = "Bring water to a gentle boil in a saucepan, add the tapioca pearls, and stir regularly until they turn mostly translucent.";
"recipe.kh_chek_ktis.step5.title" = "Cook tapioca";
"recipe.kh_chek_ktis.step6.body" = "Add the %i4, %i5, and %i6, and stir gently until the sugar dissolves and the liquid returns to a simmer.";
"recipe.kh_chek_ktis.step6.title" = "Add coconut and sugar";
"recipe.kh_chek_ktis.step7.body" = "Add the banana pieces and simmer gently until the bananas are tender but still hold their shape and the pudding is slightly thickened.";
"recipe.kh_chek_ktis.step7.title" = "Add bananas";
"recipe.kh_chek_ktis.step8.body" = "Ladle the warm chek ktis into bowls and sprinkle the toasted sesame seeds over the top before serving.";
"recipe.kh_chek_ktis.step8.title" = "Serve";
