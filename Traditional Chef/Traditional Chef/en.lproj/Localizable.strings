"recipe.tr_kuzu_tandir.step7.title" = "Cook the pilaf";
"recipe.tr_kuzu_tandir.step8.body" = "Rest the lamb briefly, then pull or slice and serve with its juices alongside the rice pilaf.";
"recipe.tr_kuzu_tandir.step8.title" = "Serve";
