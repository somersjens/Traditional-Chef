"recipe.gr_paidakia.drink.body" = "Pair with a medium-bodied Greek red such as Agiorgitiko that matches lamb and oregano. A dry rosé also works well. For a non-alcoholic option, serve sparkling water with lemon or a chilled lemon soda.";
"recipe.gr_paidakia.drink.summary" = "Red wine (Agiorgitiko)";
"recipe.gr_paidakia.info" = "Paidakia are traditional Greek grilled lamb chops seasoned simply with oregano, lemon, garlic, and olive oil, then grilled quickly so they stay juicy with charred edges. They are classically served with lemon wedges, roasted potatoes, and pita bread to mop up the juices, making a staple taverna main.";
"recipe.gr_paidakia.info.summary" = "Taverna lamb chops";
