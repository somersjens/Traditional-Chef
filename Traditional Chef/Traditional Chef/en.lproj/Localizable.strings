"recipe.tr_revani.step3.title" = "Add dry ingredients";
"recipe.tr_revani.step4.body" = "Pour into a greased pan and bake until golden and a tester comes out clean.";
"recipe.tr_revani.step4.title" = "Bake the cake";
"recipe.tr_revani.step5.body" = "Cut the cake into squares while still hot so it absorbs syrup evenly.";
"recipe.tr_revani.step5.title" = "Slice the hot cake";
"recipe.tr_revani.step6.body" = "Pour the cooled syrup evenly over the hot cake and let it absorb.";
"recipe.tr_revani.step6.title" = "Soak with syrup";
"recipe.tr_revani.step7.body" = "Let the revani rest until fully soaked and set before serving.";
"recipe.tr_revani.step7.title" = "Rest to set";
"recipe.tr_revani.step8.body" = "Serve at room temperature in neat squares.";
"recipe.tr_revani.step8.title" = "Serve";
