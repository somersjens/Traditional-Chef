"recipe.co_lechona.step4.title" = "Season pork and stuffing";
"recipe.co_lechona.step5.body" = "Lay the %i5 skin-side down and spread the pea-rice-pork mixture evenly over the meat side.";
"recipe.co_lechona.step5.title" = "Prepare the skin-on belly";
"recipe.co_lechona.step6.body" = "Roll the belly tightly into a large cylinder with the filling inside, keeping the skin on the outside. Place seam-side down in a roasting pan.";
"recipe.co_lechona.step6.title" = "Roll and secure";
"recipe.co_lechona.step7.body" = "Roast at low heat, covered for most of the time, until the filling is cooked through and the pork is tender.";
"recipe.co_lechona.step7.title" = "Slow roast";
"recipe.co_lechona.step8.body" = "Uncover and raise the heat to render and crisp the skin until deeply golden and crackling.";
"recipe.co_lechona.step8.title" = "Crisp the skin";
"recipe.co_lechona.step9.body" = "Rest so juices settle and the filling firms up for clean portions.";
"recipe.co_lechona.step9.title" = "Rest before slicing";
