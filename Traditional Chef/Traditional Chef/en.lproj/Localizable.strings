"recipe.tr_kazandibi.drink.summary" = "Dessert wine (Muscat)";
"recipe.tr_kazandibi.info" = "Kazandibi is a traditional Turkish milk pudding with a thin caramelized, lightly burnt base, made by cooking a starch-thickened milk pudding and then browning it in a pan until it develops its signature toasted layer. It is served chilled, rolled or sliced, and often paired with tea as a classic pastry-shop dessert.";
"recipe.tr_kazandibi.info.summary" = "Burnt milk pudding";
"recipe.tr_kazandibi.name" = "Kazandibi";
"recipe.tr_kazandibi.step1.body" = "In a bowl, whisk %i3 and %i4 with some of %i2 so the starches disperse evenly.";
"recipe.tr_kazandibi.step1.title" = "Mix the dry ingredients";
"recipe.tr_kazandibi.step2.body" = "Heat %i1 with the remaining sugar, whisk in the starch mixture, and cook while whisking until thick, smooth, and glossy. Stir in %i5.";
"recipe.tr_kazandibi.step2.title" = "Cook the pudding";
"recipe.tr_kazandibi.step3.body" = "Strain the hot pudding into a clean pot or bowl to remove any lumps.";
"recipe.tr_kazandibi.step3.title" = "Strain for smoothness";
"recipe.tr_kazandibi.step4.body" = "Butter the wide pan with %i7 and dust it evenly with %i6 to create the caramelizing layer.";
"recipe.tr_kazandibi.step4.title" = "Prepare the browning pan";
"recipe.tr_kazandibi.step5.body" = "Pour the pudding into the prepared pan and smooth it into an even layer.";
"recipe.tr_kazandibi.step5.title" = "Spread the pudding";
"recipe.tr_kazandibi.step6.body" = "Cook the pan over low heat, rotating frequently, until the underside develops a deep golden-brown, lightly burnt caramel layer.";
"recipe.tr_kazandibi.step6.title" = "Caramelize the base";
"recipe.tr_kazandibi.step7.body" = "Transfer to the refrigerator and chill until fully set and cold.";
"recipe.tr_kazandibi.step7.title" = "Chill to set";
"recipe.tr_kazandibi.step8.body" = "Loosen the pudding, cut into rectangles, and serve with the caramelized side facing up.";
"recipe.tr_kazandibi.step8.title" = "Slice and serve";
