"recipe.it_bistecca_alla_fiorentina.drink.body" = "Pair with Chianti Classico or another Sangiovese-based Tuscan red with firm acidity and tannin to match the steak. Non-alcoholic option: sparkling water or an unsweetened iced tea with lemon.";
"recipe.it_bistecca_alla_fiorentina.drink.summary" = "Red wine (Chianti Classico)";
"recipe.it_bistecca_alla_fiorentina.info" = "A traditional Tuscan porterhouse-style T-bone steak from Chianina or similar beef, cooked over very hot coals and seasoned simply with salt, pepper, and olive oil. Served rare to medium-rare with a deeply seared crust, it is a centerpiece dish for gatherings, typically paired with rustic sides and enjoyed immediately after resting.";
"recipe.it_bistecca_alla_fiorentina.info.summary" = "Tuscan charcoal steak";
"recipe.it_bistecca_alla_fiorentina.name" = "Florentine steak";
