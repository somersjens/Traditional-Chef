"recipe.bo_fricase_paceno.step1.title" = "Soak the chuño";
"recipe.bo_fricase_paceno.step10.body" = "Place mote and chuño in each bowl, add the pork and broth over the top, and serve hot with sliced locoto and %i14.";
"recipe.bo_fricase_paceno.step10.title" = "Serve traditionally";
