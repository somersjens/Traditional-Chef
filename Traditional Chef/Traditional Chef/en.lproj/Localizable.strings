"recipe.bd_tehari.drink.body" = "A light-bodied, low-tannin red such as Gamay suits the roasted spices and mustard oil without turning bitter. If you prefer white, an off-dry Riesling balances the warmth and richness. Non-alcoholic pairing: chilled lemon soda or unsweetened black tea.";
"recipe.bd_tehari.drink.summary" = "Red wine (Gamay)";
"recipe.bd_tehari.info" = "Dhaka-style tehari is a beloved Bangladeshi one-pot rice dish where beef is cooked down with browned onions, mustard oil, yogurt, and a signature mix of aromatic spices, then the rice is cooked in the same pot so it absorbs the deeply roasted masala. The texture is drier than khichuri and intensely fragrant, traditionally served hot with a simple cucumber salad to refresh the palate.";
"recipe.bd_tehari.info.summary" = "Dhaka beef rice";
"recipe.bd_tehari.name" = "Beef tehari";
"recipe.bd_tehari.step1.body" = "Slice the %i3, mince the %i5, grate the %i4, and slit the %i6. Rinse the %i2 until the water runs mostly clear and drain well.";
"recipe.bd_tehari.step1.title" = "Prep and rinse";
"recipe.bd_tehari.step10.body" = "Keep the pot covered off the heat so the rice steams and the flavours settle, then fluff gently.";
"recipe.bd_tehari.step10.title" = "Dum and rest";
"recipe.bd_tehari.step11.body" = "Slice the %i22 and dress with %i23 juice and %i24.";
"recipe.bd_tehari.step11.title" = "Make the salad";
"recipe.bd_tehari.step12.body" = "Serve the tehari hot with the cucumber salad.";
"recipe.bd_tehari.step12.title" = "Serve";
"recipe.bd_tehari.step2.body" = "Whisk the %i7 smooth and mix in %i10, %i11, %i12, %i13, %i14, and some of the %i15.";
"recipe.bd_tehari.step2.title" = "Season the yogurt";
"recipe.bd_tehari.step3.body" = "Heat %i8 with %i9 in the pot and fry the onions until deep golden and caramelised, stirring so they do not burn.";
"recipe.bd_tehari.step3.title" = "Brown the onions";
"recipe.bd_tehari.step4.body" = "Add %i16, %i17, %i18, and %i19 to the hot fat and fry briefly until aromatic.";
"recipe.bd_tehari.step4.title" = "Bloom whole spices";
"recipe.bd_tehari.step5.body" = "Add the %i1 and cook on medium-high heat, stirring, until it browns and the masala begins to cling.";
"recipe.bd_tehari.step5.title" = "Bhuna the beef";
"recipe.bd_tehari.step6.body" = "Add the spiced yogurt, ginger, garlic, and green chilies and cook, stirring, until the mixture darkens and oil begins to separate.";
"recipe.bd_tehari.step6.title" = "Cook with yogurt masala";
"recipe.bd_tehari.step7.body" = "Add %i25 gradually to maintain a steady simmer, cover, and cook until the beef is tender and there is a rich cooking liquid left in the pot.";
"recipe.bd_tehari.step7.title" = "Tenderise the beef";
"recipe.bd_tehari.step8.body" = "Stir in %i20 and %i21, then add the drained rice and fold gently so the grains are coated without breaking the beef.";
"recipe.bd_tehari.step8.title" = "Add rice and finish spices";
"recipe.bd_tehari.step9.body" = "Add enough water to cook the rice, bring to a simmer, cover tightly, and cook on low heat until the rice is tender and the liquid is absorbed.";
"recipe.bd_tehari.step9.title" = "Cook the rice";
