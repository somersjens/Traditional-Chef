"recipe.iq_tashreeb.drink.body" = "A light red wine such as Cinsault or a young Grenache pairs well with the lamb and tomato broth without overpowering the bread-softened stew. A smooth amber lager also works well. For a non-alcoholic pairing, serve hot black tea with lemon or chilled ayran.";
"recipe.iq_tashreeb.drink.summary" = "Red wine (Cinsault)";
"recipe.iq_tashreeb.info" = "Iraqi tashreeb is a traditional family dish of tender lamb and chickpeas in a richly spiced tomato broth poured over torn Iraqi flatbread. It is served hot in a deep platter so the bread absorbs the savory broth while still keeping some texture, often as a hearty lunch or dinner centerpiece.";
"recipe.iq_tashreeb.info.summary" = "Bread-soaked lamb stew";
"recipe.iq_tashreeb.name" = "Tashreeb";
"recipe.iq_tashreeb.step1.body" = "Rinse %i2 and soak them in plenty of normal water until fully swollen and softened for cooking the next day.";
"recipe.iq_tashreeb.step1.title" = "Soak the chickpeas";
"recipe.iq_tashreeb.step2.body" = "Cut %i1 into large serving pieces. Slice %i3 and crush %i4.";
"recipe.iq_tashreeb.step2.title" = "Prepare the stew base";
"recipe.iq_tashreeb.step3.body" = "Heat %i11 in a heavy pot, cook the onions until softened, then add the garlic. Add the lamb and turn it until the surface loses its raw color.";
"recipe.iq_tashreeb.step3.title" = "Brown the aromatics and lamb";
"recipe.iq_tashreeb.step4.body" = "Stir in %i5, %i6, %i7, %i8, and %i9 until the lamb is coated and the tomato paste darkens slightly.";
"recipe.iq_tashreeb.step4.title" = "Season the pot";
"recipe.iq_tashreeb.step5.body" = "Add the drained chickpeas, %i10, and %i12. Bring to a boil, skim if needed, then cover and simmer gently until the lamb is tender, the chickpeas are fully cooked, and the broth is rich.";
"recipe.iq_tashreeb.step5.title" = "Simmer the stew";
"recipe.iq_tashreeb.step6.body" = "Tear %i13 into medium pieces and spread them in a deep serving platter.";
"recipe.iq_tashreeb.step6.title" = "Prepare the serving platter";
"recipe.iq_tashreeb.step7.body" = "Remove the dried limes from the pot. Ladle some broth over the bread first so it softens evenly, then arrange the lamb and chickpeas on top.";
"recipe.iq_tashreeb.step7.title" = "Soak the bread";
"recipe.iq_tashreeb.step8.body" = "Spoon more broth over the platter until the bread is well soaked but not dissolved. Scatter with %i14 and serve immediately with %i15.";
"recipe.iq_tashreeb.step8.title" = "Finish and serve";
