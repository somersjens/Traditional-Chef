"recipe.sr_saoto_soep.step7.title" = "Make the ketjap sambal";
"recipe.sr_saoto_soep.step8.body" = "Bring the strained broth back to a gentle boil and warm the shredded chicken in it briefly.";
"recipe.sr_saoto_soep.step8.title" = "Reheat for serving";
"recipe.sr_saoto_soep.step9.body" = "Place some %i17, rice vermicelli, bean sprouts, shredded chicken, egg, potato sticks, and %i16 into each bowl.";
"recipe.sr_saoto_soep.step9.title" = "Assemble the bowls";
