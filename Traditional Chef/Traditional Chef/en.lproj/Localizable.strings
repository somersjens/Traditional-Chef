"recipe.fr_escargots_de_bourgogne.drink.body" = "Pair with a crisp Burgundy Chardonnay such as Chablis to match the garlic-parsley butter without overpowering the snails. A dry sparkling wine also works well. For a non-alcoholic option, serve sparkling water with lemon or a chilled citrus spritz.";
"recipe.fr_escargots_de_bourgogne.drink.summary" = "White wine (Chablis)";
"recipe.fr_escargots_de_bourgogne.info" = "Escargots de Bourgogne are the classic Burgundian starter: tender snails baked in their shells with a rich beurre d’escargot made from butter, garlic, parsley, and shallot, then served sizzling hot with crusty bread to soak up the fragrant green butter. They are traditionally eaten straight from the escargot dish using special tongs and a small fork.";
"recipe.fr_escargots_de_bourgogne.info.summary" = "Sizzling Burgundy snails";
"recipe.fr_escargots_de_bourgogne.name" = "Escargots";
"recipe.fr_escargots_de_bourgogne.step1.body" = "Finely chop %i5 and %i4 and mince %i3 so the butter will be evenly flavoured.";
"recipe.fr_escargots_de_bourgogne.step1.title" = "Prep the aromatics";
"recipe.fr_escargots_de_bourgogne.step2.body" = "Work the softened %i2 with the garlic, parsley, and shallot until uniform, then season with %i6 and %i7.";
"recipe.fr_escargots_de_bourgogne.step2.title" = "Make the escargot butter";
"recipe.fr_escargots_de_bourgogne.step3.body" = "Preheat the oven. Place a small amount of butter in each cavity, add %i1, then seal the top with more butter so the snail is fully enclosed.";
"recipe.fr_escargots_de_bourgogne.step3.title" = "Fill the shells";
"recipe.fr_escargots_de_bourgogne.step4.body" = "Bake the escargots until the butter is bubbling vigorously and fragrant.";
"recipe.fr_escargots_de_bourgogne.step4.title" = "Bake until sizzling";
"recipe.fr_escargots_de_bourgogne.step5.body" = "Slice %i8 and toast it in the oven until crisp and warm.";
"recipe.fr_escargots_de_bourgogne.step5.title" = "Toast the bread";
"recipe.fr_escargots_de_bourgogne.step6.body" = "Serve immediately while sizzling, with the toasted bread for dipping and escargot tongs and fork for eating.";
"recipe.fr_escargots_de_bourgogne.step6.title" = "Serve the escargots";
