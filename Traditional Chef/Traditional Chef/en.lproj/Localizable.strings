"recipe.ro_sarmale.drink.body" = "A light to medium-bodied Romanian red such as Fetească Neagră pairs well with the rich pork and sour cabbage. For a non-alcoholic pairing, serve sparkling water or still water.";
"recipe.ro_sarmale.drink.summary" = "Red wine (Fetească Neagră)";
"recipe.ro_sarmale.info" = "Sarmale are traditional Romanian cabbage rolls made with sour cabbage leaves filled with pork, rice, onion, and thyme, then slow-cooked with smoked pork and tomato for a rich festive dish. They are especially associated with Christmas, New Year, weddings, and family celebrations, and are classically served hot with mămăligă and sour cream.";
"recipe.ro_sarmale.info.summary" = "Romanian cabbage rolls";
"recipe.ro_sarmale.name" = "Sarmale";
"recipe.ro_sarmale.step1.body" = "Separate %i1 carefully, trim the thick ribs, and chop the small inner leaves and any trimmings for lining the pot. If the cabbage is very salty, rinse it briefly and drain well.";
"recipe.ro_sarmale.step1.title" = "Prepare the cabbage";
"recipe.ro_sarmale.step10.body" = "Take the cabbage rolls off the heat and let them stand briefly so the sauce settles and the rolls hold together well.";
"recipe.ro_sarmale.step10.title" = "Rest briefly";
"recipe.ro_sarmale.step11.body" = "Serve the sarmale hot with the smoked pork from the pot, spoon over some sauce, and accompany with mămăligă and %i17.";
"recipe.ro_sarmale.step11.title" = "Serve";
"recipe.ro_sarmale.step2.body" = "Finely chop %i3 and cook it gently in %i5 until soft. Add %i4 and cook briefly until coated and slightly translucent, then let it cool a little.";
"recipe.ro_sarmale.step2.title" = "Cook the onion base";
"recipe.ro_sarmale.step3.body" = "Mix %i2 with the onion and rice mixture, chopped %i8, %i9, some %i11, and %i12 until evenly combined.";
"recipe.ro_sarmale.step3.title" = "Make the filling";
"recipe.ro_sarmale.step4.body" = "Place filling on each cabbage leaf, fold in the sides, and roll tightly into small cabbage rolls until the filling and usable leaves are used up.";
"recipe.ro_sarmale.step4.title" = "Roll the sarmale";
"recipe.ro_sarmale.step5.body" = "Line the bottom of the pot with some chopped cabbage, add part of %i6, then arrange the cabbage rolls in tight layers. Scatter the remaining chopped cabbage and the rest of the smoked pork ribs between and over the layers, then add %i10.";
"recipe.ro_sarmale.step5.title" = "Layer the pot";
"recipe.ro_sarmale.step6.body" = "Mix %i7 with %i13 and pour it over the cabbage rolls so the liquid comes close to the top layer.";
"recipe.ro_sarmale.step6.title" = "Add the cooking liquid";
"recipe.ro_sarmale.step7.body" = "Cover and simmer very gently until the cabbage is tender, the rice is fully cooked, and the flavors are deeply combined. Shake the pot occasionally instead of stirring with a spoon.";
"recipe.ro_sarmale.step7.title" = "Cook slowly";
"recipe.ro_sarmale.step8.body" = "Bring water to a boil in the saucepan, add %i16, then pour in %i14 gradually while whisking.";
"recipe.ro_sarmale.step8.title" = "Start the mămăligă";
"recipe.ro_sarmale.step9.body" = "Cook over low heat, stirring often, until the mămăligă is thick, smooth, and pulls slightly from the sides of the pan.";
"recipe.ro_sarmale.step9.title" = "Cook the mămăligă";
