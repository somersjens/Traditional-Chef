"recipe.mx_barbacoa.step1.title" = "Soak the chickpeas";
"recipe.mx_barbacoa.step10.body" = "Lift the lamb out and shred into bite-size pieces. Ladle the broth through a strainer into a bowl and return the chickpeas to the broth.";
"recipe.mx_barbacoa.step10.title" = "Shred the lamb and strain the broth";
