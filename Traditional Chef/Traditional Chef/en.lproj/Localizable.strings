"recipe.gr_saganaki.drink.summary" = "White wine (Assyrtiko)";
"recipe.gr_saganaki.info" = "Saganaki is a classic Greek meze of firm cheese quickly pan-fried until crisp and golden on the outside and molten within, then finished with lemon. It is served immediately, often alongside bread, so the cheese stays hot and stretchy.";
"recipe.gr_saganaki.info.summary" = "Molten fried cheese";
