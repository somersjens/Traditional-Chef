"recipe.pe_ceviche.drink.body" = "Pair with a zesty Sauvignon Blanc or a dry Albariño to complement the citrus and chili heat. A crisp lager also matches well. For a non-alcoholic option, serve chicha morada or sparkling water with lime.";
"recipe.pe_ceviche.drink.summary" = "White wine (Sauvignon)";
"recipe.pe_ceviche.info" = "Peruvian ceviche is made by briefly curing very fresh white fish in fresh lime juice, then tossing it with red onion, ají limo, salt, and cilantro to create a bright, bracing dish with a punchy leche de tigre. It is traditionally served immediately with sweet potato, choclo (large-kernel corn), and crunchy cancha for balance and contrast.";
"recipe.pe_ceviche.info.summary" = "Fresh lime-cured fish";
"recipe.pe_ceviche.name" = "Ceviche";
"recipe.pe_ceviche.step1.body" = "Cook the %i7 in salted %i10 until tender, then drain, peel if needed, and slice for serving.";
"recipe.pe_ceviche.step1.title" = "Boil the sweet potato";
"recipe.pe_ceviche.step10.body" = "Serve right away with sweet potato, corn, and cancha on the side.";
"recipe.pe_ceviche.step10.title" = "Serve immediately";
"recipe.pe_ceviche.step2.body" = "Boil the %i8 in water until hot and tender, then drain and cut into serving pieces.";
"recipe.pe_ceviche.step2.title" = "Cook the corn";
"recipe.pe_ceviche.step3.body" = "Toast the %i9 in a dry skillet, stirring, until crunchy and aromatic, then set aside to cool.";
"recipe.pe_ceviche.step3.title" = "Toast the cancha";
"recipe.pe_ceviche.step4.body" = "Slice the %i3 very thinly and rinse it in cold water, then drain well so it stays crisp and mild.";
"recipe.pe_ceviche.step4.title" = "Prepare the onion";
"recipe.pe_ceviche.step5.body" = "Cut the %i1 into bite-size cubes. Thinly slice the %i4, keeping the seeds if you want more heat, and finely chop the %i5.";
"recipe.pe_ceviche.step5.title" = "Prep fish and chili";
"recipe.pe_ceviche.step6.body" = "Juice the %i2 and strain out any seeds so the juice is clean and bright.";
"recipe.pe_ceviche.step6.title" = "Juice the limes";
"recipe.pe_ceviche.step7.body" = "Add the fish to a non-reactive bowl, season with %i6, then pour over the lime juice and toss gently to coat.";
"recipe.pe_ceviche.step7.title" = "Cure the fish";
"recipe.pe_ceviche.step8.body" = "Let the fish cure until the outside turns opaque while the center stays tender.";
"recipe.pe_ceviche.step8.title" = "Rest briefly";
"recipe.pe_ceviche.step9.body" = "Add the sliced onion, chili, and cilantro and toss gently. Spoon the leche de tigre over each portion when plating.";
"recipe.pe_ceviche.step9.title" = "Finish the ceviche";
