"recipe.my_satay.step5.title" = "Cook peanut sauce base";
"recipe.my_satay.step6.body" = "Add crushed peanuts, %i18, %i19, %i20, and water to the saucepan and simmer until thick, smooth, and spoonable. Stir often so the sauce does not catch on the bottom.";
"recipe.my_satay.step6.title" = "Finish peanut sauce";
