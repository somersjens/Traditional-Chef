"recipe.ar_asado.drink.body" = "Pair with an Argentinian Malbec or a structured Cabernet Sauvignon to match the smoky, fatty cuts and grilled sausages. A crisp lager also works well between bites. For a non-alcoholic option, serve sparkling water with lemon or cold yerba mate.";
"recipe.ar_asado.drink.summary" = "Red wine (Malbec)";
"recipe.ar_asado.info" = "Argentinian Asado is a traditional wood-fired parrilla feast centered on beef short ribs cooked slowly over embers, alongside chorizo and morcilla, seasoned simply with coarse salt to highlight the meat. It is served sliced and shared family-style with crusty bread and classic condiments like chimichurri and salsa criolla.";
"recipe.ar_asado.info.summary" = "Argentine parrilla feast";
"recipe.ar_asado.name" = "Asado";
"recipe.ar_asado.step1.body" = "Light the firewood and let it burn down to a large bed of glowing embers. Keep a small side fire going so you can add fresh embers as needed.";
"recipe.ar_asado.step1.title" = "Build the fire and embers";
"recipe.ar_asado.step2.body" = "Pat %i1 dry and season generously with %i4. Keep %i2 and %i3 ready and dry so they brown well on the grill.";
"recipe.ar_asado.step2.title" = "Prep the meats";
"recipe.ar_asado.step3.body" = "Cook the ribs slowly over gentle embers, fat-side toward the heat at first, adjusting the ember bed so they roast evenly without flare-ups.";
"recipe.ar_asado.step3.title" = "Slow-grill the ribs";
"recipe.ar_asado.step4.body" = "Add chorizo and morcilla to the parrilla and grill, turning occasionally, until browned and cooked through while the ribs finish.";
"recipe.ar_asado.step4.title" = "Grill the sausages";
"recipe.ar_asado.step5.body" = "Finely chop %i5 and %i6, then mix with %i7, %i8, %i9, %i10, %i11, and %i12 until spoonable and well combined.";
"recipe.ar_asado.step5.title" = "Make chimichurri";
"recipe.ar_asado.step6.body" = "Dice %i13, %i14, and %i15 small, then mix with %i16, %i17, and %i18 until glossy and lightly dressed.";
"recipe.ar_asado.step6.title" = "Make salsa criolla";
"recipe.ar_asado.step7.body" = "Move the grilled meats off the heat and rest briefly so the juices settle.";
"recipe.ar_asado.step7.title" = "Rest before slicing";
"recipe.ar_asado.step8.body" = "Slice the ribs and portion the sausages, then serve on a platter with %i19, chimichurri, and salsa criolla.";
"recipe.ar_asado.step8.title" = "Slice and serve";
