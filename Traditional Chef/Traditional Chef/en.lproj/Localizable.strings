"recipe.co_sobrebarriga.step1.title" = "Prep aromatics";
"recipe.co_sobrebarriga.step2.body" = "Add beef, onion, scallions, garlic, cilantro stems, %i7, %i8, and %i2 to a pot. Bring to a gentle simmer, skim foam, and cook until the beef is very tender.";
"recipe.co_sobrebarriga.step2.title" = "Braise the beef until tender";
"recipe.co_sobrebarriga.step3.body" = "Heat %i9 in a skillet and cook onion until soft, then add garlic and cook briefly.";
"recipe.co_sobrebarriga.step3.title" = "Start the tomato sauce";
"recipe.co_sobrebarriga.step4.body" = "Add %i10, salt, and black pepper and simmer until the sauce is thick and cohesive.";
"recipe.co_sobrebarriga.step4.title" = "Cook down tomatoes";
"recipe.co_sobrebarriga.step5.body" = "Remove beef from the broth, slice or shred, and add to the tomato sauce, simmering briefly so it is well coated.";
"recipe.co_sobrebarriga.step5.title" = "Finish the beef in salsa";
"recipe.co_sobrebarriga.step6.body" = "Cook %i15 with %i16, %i17, and %i18 until tender and fluffy, then keep warm.";
"recipe.co_sobrebarriga.step6.title" = "Cook the rice";
"recipe.co_sobrebarriga.step7.body" = "Boil %i19 in salted water until tender, then drain.";
"recipe.co_sobrebarriga.step7.title" = "Boil the potatoes";
"recipe.co_sobrebarriga.step8.body" = "Serve the beef in salsa with rice and boiled potatoes, adding %i20 on the side.";
"recipe.co_sobrebarriga.step8.title" = "Serve";
