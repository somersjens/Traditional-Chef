"recipe.ca_soupe_aux_pois.drink.summary" = "Cider";
"recipe.ca_soupe_aux_pois.info" = "Soupe aux Pois is a traditional French-Canadian pea soup from Quebec made with yellow peas, salt pork, vegetables, and herbs. It is a hearty cold-weather meal, commonly served hot as a simple family supper with crusty bread at the table.";
"recipe.ca_soupe_aux_pois.info.summary" = "Quebec pea soup";
"recipe.ca_soupe_aux_pois.name" = "Pea soup";
"recipe.ca_soupe_aux_pois.step1.body" = "Rinse the %i1, place them in a large bowl, cover them with %i2, and leave them to soak overnight.";
"recipe.ca_soupe_aux_pois.step1.title" = "Soak the peas";
"recipe.ca_soupe_aux_pois.step2.body" = "Drain the soaked peas. Dice the %i4, %i5, and %i6, and cut the %i3 into large pieces.";
"recipe.ca_soupe_aux_pois.step2.title" = "Drain and prepare";
"recipe.ca_soupe_aux_pois.step3.body" = "Place the peas, salt pork, onion, carrots, celery, water, %i8, %i9, and %i10 in a large pot. Bring to a boil, skimming the surface as needed.";
"recipe.ca_soupe_aux_pois.step3.title" = "Start the soup";
"recipe.ca_soupe_aux_pois.step4.body" = "Cover partially, reduce to low heat, and let the soup simmer gently until the peas are very soft and the broth is thick.";
"recipe.ca_soupe_aux_pois.step4.title" = "Simmer gently";
"recipe.ca_soupe_aux_pois.step5.body" = "Lift out the salt pork and bay leaf. Discard the bay leaf, cut the pork into small pieces, and return the meat to the pot.";
"recipe.ca_soupe_aux_pois.step5.title" = "Finish the meat";
"recipe.ca_soupe_aux_pois.step6.body" = "Simmer a little longer so the flavors come together and the soup reaches a traditional thick texture.";
"recipe.ca_soupe_aux_pois.step6.title" = "Final thickening";
"recipe.ca_soupe_aux_pois.step7.body" = "Slice the %i11 and warm it briefly.";
"recipe.ca_soupe_aux_pois.step7.title" = "Prepare the bread";
"recipe.ca_soupe_aux_pois.step8.body" = "Ladle the hot soup into bowls and serve it with the warm bread.";
"recipe.ca_soupe_aux_pois.step8.title" = "Serve";
