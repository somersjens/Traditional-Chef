"recipe.it_bruschetta_al_pomodoro.step2.title" = "Season the topping";
"recipe.it_bruschetta_al_pomodoro.step3.body" = "Toast or grill the %i1 until crisp and well browned on the surface.";
"recipe.it_bruschetta_al_pomodoro.step3.title" = "Toast the bread";
"recipe.it_bruschetta_al_pomodoro.step4.body" = "While the bread is still warm, rub the cut side of %i3 over each slice.";
"recipe.it_bruschetta_al_pomodoro.step4.title" = "Rub with garlic";
"recipe.it_bruschetta_al_pomodoro.step5.body" = "Spoon the tomato mixture onto the warm toasted bread.";
"recipe.it_bruschetta_al_pomodoro.step5.title" = "Top the bruschetta";
"recipe.it_bruschetta_al_pomodoro.step6.body" = "Serve immediately while the bread stays crisp.";
