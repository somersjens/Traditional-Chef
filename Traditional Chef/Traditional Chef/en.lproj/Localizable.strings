"recipe.th_massaman_nuea.drink.body" = "An off-dry Riesling pairs well with the rich coconut sauce and gentle warm spices while refreshing the palate. For a non-alcoholic option, serve unsweetened black tea, jasmine tea, or cold water with lime.";
"recipe.th_massaman_nuea.drink.summary" = "White wine (Riesling)";
"recipe.th_massaman_nuea.info" = "Gaeng Massaman Nuea is a traditional Thai Muslim-influenced curry of beef slowly braised in coconut milk with massaman curry paste, potatoes, onions, roasted peanuts, tamarind, fish sauce, and palm sugar. It is typically served as part of a shared meal with jasmine rice, with a rich, mildly spiced, sweet-sour-savory balance.";
"recipe.th_massaman_nuea.info.summary" = "Massaman beef curry";
"recipe.th_massaman_nuea.name" = "Massaman curry";
