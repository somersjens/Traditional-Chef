"recipe.ir_joojeh_kabab.drink.body" = "Aromatic whites like Viognier or dry Riesling pair well with saffron, citrus, and charred chicken. If you prefer red, choose a light-bodied Pinot Noir served slightly cool. Non-alcoholic: doogh (yogurt-mint drink) or sparkling water with lemon.";
"recipe.ir_joojeh_kabab.drink.summary" = "White wine (Viognier)";
"recipe.ir_joojeh_kabab.info" = "Joojeh Kabab is a classic Iranian chicken kebab marinated with saffron, onion, and citrus, then grilled over hot coals until smoky and juicy. It is traditionally served with Persian rice, grilled tomatoes, butter, and sumac, often with fresh herbs and flatbread alongside.";
"recipe.ir_joojeh_kabab.info.summary" = "Saffron chicken kebab";
"recipe.ir_joojeh_kabab.name" = "Joojeh kabab";
"recipe.ir_joojeh_kabab.step1.body" = "Crush %i7 and steep it in a little warm water so it releases color and aroma.";
"recipe.ir_joojeh_kabab.step1.title" = "Bloom saffron";
