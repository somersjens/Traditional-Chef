"recipe.ir_ash_reshteh.drink.body" = "Aromatic, medium-bodied whites such as Viognier or a lightly oaked Chardonnay pair well with the herbaceous, savory soup and tangy kashk. If you prefer red, choose a soft, low-tannin option like Pinot Noir served slightly cool. Non-alcoholic: drink doogh (yogurt-mint beverage) or sparkling water with lemon.";
"recipe.ir_ash_reshteh.drink.summary" = "White wine (Viognier)";
"recipe.ir_ash_reshteh.info" = "Ash Reshteh is a traditional Iranian thick soup-pottage of mixed herbs, legumes, and reshteh noodles, finished with tangy kashk and aromatic mint-garlic oil. It is commonly served for gatherings and during cold seasons, and it’s typically topped generously with fried onions and kashk, then eaten with Persian flatbread.";
"recipe.ir_ash_reshteh.info.summary" = "Kashk-topped herb soup";
"recipe.ir_ash_reshteh.name" = "Ash reshteh";
"recipe.ir_ash_reshteh.step1.body" = "Rinse %i1, %i2, and %i3, then soak them in plenty of %i19 until fully hydrated.";
"recipe.ir_ash_reshteh.step1.title" = "Soak the legumes";
"recipe.ir_ash_reshteh.step10.body" = "Break %i15 into shorter lengths and stir them into the pot, keeping the soup gently bubbling and stirring to prevent sticking.";
"recipe.ir_ash_reshteh.step10.title" = "Add reshteh noodles";
"recipe.ir_ash_reshteh.step11.body" = "Turn off the heat and rest the soup so the noodles finish softening and the texture settles.";
"recipe.ir_ash_reshteh.step11.title" = "Let it set";
"recipe.ir_ash_reshteh.step12.body" = "Warm %i18 gently, then swirl it over the soup in bowls and spoon more on top. Finish with the reserved fried onions, then serve hot with %i20.";
"recipe.ir_ash_reshteh.step12.title" = "Finish with kashk and serve";
"recipe.ir_ash_reshteh.step2.body" = "Rinse and finely chop %i5 and %i6, %i7, %i8, and %i9. Slice %i10 thinly. Mince %i11.";
"recipe.ir_ash_reshteh.step2.title" = "Prepare greens and aromatics";
"recipe.ir_ash_reshteh.step3.body" = "Drain the soaked legumes. Add them to a large pot, cover well with water, bring to a gentle boil, then simmer until nearly tender.";
"recipe.ir_ash_reshteh.step3.title" = "Cook chickpeas and beans";
"recipe.ir_ash_reshteh.step4.body" = "Heat %i16 in a skillet and fry the onions slowly, stirring, until deeply golden and crisp. Remove about half of the fried onions for topping.";
"recipe.ir_ash_reshteh.step4.title" = "Start the fried onions";
"recipe.ir_ash_reshteh.step5.body" = "To the remaining onions in the skillet, add %i12 and garlic and cook briefly until fragrant, keeping the garlic from browning.";
"recipe.ir_ash_reshteh.step5.title" = "Build the base flavor";
"recipe.ir_ash_reshteh.step6.body" = "In a small cleared area of the skillet, add %i17 to hot oil for a few seconds until aromatic, then immediately mix through so it does not burn.";
"recipe.ir_ash_reshteh.step6.title" = "Bloom the mint oil";
"recipe.ir_ash_reshteh.step7.body" = "Add the chopped herbs and spinach to the pot with the simmering legumes. Stir well and keep at a steady simmer.";
"recipe.ir_ash_reshteh.step7.title" = "Add herbs to the pot";
"recipe.ir_ash_reshteh.step8.body" = "Add %i4 and continue simmering until the lentils soften and the soup begins to thicken, stirring occasionally.";
"recipe.ir_ash_reshteh.step8.title" = "Cook lentils and thicken";
"recipe.ir_ash_reshteh.step9.body" = "Stir in %i13 and %i14. Add the onion-garlic-mint mixture from the skillet into the pot and mix thoroughly.";
"recipe.ir_ash_reshteh.step9.title" = "Season and enrich";
