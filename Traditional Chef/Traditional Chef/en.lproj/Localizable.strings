"recipe.sa_margoog.step4.body" = "Add %i11, bring to a boil, skim the surface, then lower the heat and simmer until the lamb is becoming tender and the broth is well flavored.";
"recipe.sa_margoog.step4.title" = "Simmer the lamb";
"recipe.sa_margoog.step5.body" = "Mix %i16 with %i18 and %i17, knead until smooth, then leave the dough to rest.";
"recipe.sa_margoog.step5.title" = "Make the dough";
"recipe.sa_margoog.step6.body" = "Cut %i12, %i13, %i14, and %i15 into medium pieces so they cook evenly and hold their shape in the stew.";
"recipe.sa_margoog.step6.title" = "Prepare the vegetables";
"recipe.sa_margoog.step7.body" = "Add the vegetables to the pot with the remaining salt and simmer until they begin to soften in the broth with the lamb.";
"recipe.sa_margoog.step7.title" = "Cook the vegetables";
"recipe.sa_margoog.step8.body" = "Divide the rested dough into pieces and roll each piece thin so it can cook quickly once added to the stew.";
"recipe.sa_margoog.step8.title" = "Shape the dough";
"recipe.sa_margoog.step9.body" = "Lay the thin dough pieces one by one over the bubbling stew, letting each piece set before adding the next so they do not clump together.";
"recipe.sa_margoog.step9.title" = "Add the margoog sheets";
