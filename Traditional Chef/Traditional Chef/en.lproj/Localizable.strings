"recipe.mu_flan_coco.step1.title" = "Prepare the baking setup";
"recipe.mu_flan_coco.step2.body" = "Combine %i1 with %i2 in a saucepan and cook until it turns a deep amber caramel. Immediately pour into the baking dish and swirl to coat the base evenly.";
"recipe.mu_flan_coco.step2.title" = "Make the caramel";
"recipe.mu_flan_coco.step3.body" = "Whisk %i5 with %i4 until smooth, then whisk in %i3, %i6, %i7, and %i8 until evenly combined.";
"recipe.mu_flan_coco.step3.title" = "Mix the custard";
"recipe.mu_flan_coco.step4.body" = "Strain the custard mixture into the caramel-lined dish to remove lumps and ensure a smooth set.";
"recipe.mu_flan_coco.step4.title" = "Strain into the dish";
"recipe.mu_flan_coco.step5.body" = "Place the roasting pan in the oven and carefully pour hot %i9 into the roasting pan to surround the dish for gentle baking.";
"recipe.mu_flan_coco.step5.title" = "Add the bain-marie";
"recipe.mu_flan_coco.step6.body" = "Bake until the flan is set around the edges with a slight wobble in the center.";
"recipe.mu_flan_coco.step6.title" = "Bake until set";
"recipe.mu_flan_coco.step7.body" = "Remove the dish from the bain-marie and let it cool completely so the custard finishes setting.";
"recipe.mu_flan_coco.step7.title" = "Cool to room temperature";
"recipe.mu_flan_coco.step8.body" = "Refrigerate until fully cold and firm so it unmolds cleanly and the caramel loosens.";
"recipe.mu_flan_coco.step8.title" = "Chill thoroughly";
"recipe.mu_flan_coco.step9.body" = "Run a knife around the edge, invert onto a serving plate, let the caramel flow over the flan, then slice and serve chilled.";
"recipe.mu_flan_coco.step9.title" = "Unmold and serve";
