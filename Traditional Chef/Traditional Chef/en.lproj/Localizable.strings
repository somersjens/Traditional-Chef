"recipe.es_gazpacho.drink.body" = "Pair with a crisp Spanish white such as Albariño or Verdejo to match the soup’s acidity and freshness. A dry Cava also works well with the chilled, savory profile. Non-alcoholic option: sparkling water with lemon.";
"recipe.es_gazpacho.drink.summary" = "White wine (Albariño)";
"recipe.es_gazpacho.info" = "Gazpacho is the classic Andalusian chilled soup made by blending ripe tomatoes with cucumber, green pepper, garlic, stale bread, olive oil, sherry vinegar, and WATER into a smooth, refreshing bowl. Traditionally served very cold in summer, it’s finished simply with its bright balance of acidity and olive-oil richness and commonly enjoyed with bread alongside.";
"recipe.es_gazpacho.info.summary" = "Andalusian chilled soup";
"recipe.es_gazpacho.name" = "Gazpacho";
"recipe.es_gazpacho.step1.body" = "Wash %i1, %i2, and %i3. Roughly chop them and crush %i4.";
"recipe.es_gazpacho.step1.title" = "Prep the vegetables";
"recipe.es_gazpacho.step2.body" = "Tear %i5 into pieces and soak it in %i9 until fully softened, then squeeze out excess liquid.";
"recipe.es_gazpacho.step2.title" = "Soak the bread";
"recipe.es_gazpacho.step3.body" = "Blend tomatoes, cucumber, pepper, garlic, and softened bread until very smooth.";
"recipe.es_gazpacho.step3.title" = "Blend until smooth";
"recipe.es_gazpacho.step4.body" = "With the blender running, add %i6 in a steady stream to emulsify. Add %i7 and %i8 and blend again until glossy and well balanced.";
"recipe.es_gazpacho.step4.title" = "Emulsify and season";
"recipe.es_gazpacho.step5.body" = "Pass the gazpacho through a fine sieve, pressing with a spatula, to remove skins and seeds.";
"recipe.es_gazpacho.step5.title" = "Strain for a silky texture";
"recipe.es_gazpacho.step6.body" = "Refrigerate until very cold so the flavors meld and the soup is refreshing.";
"recipe.es_gazpacho.step6.title" = "Chill thoroughly";
"recipe.es_gazpacho.step7.body" = "Stir well, pour into bowls or glasses, and serve cold with %i10 alongside.";
"recipe.es_gazpacho.step7.title" = "Serve";
