"recipe.et_yebeg_wat.step7.title" = "Prep the stew ingredients";
"recipe.et_yebeg_wat.step8.body" = "In a heavy pot over medium heat, cook the onions dry, stirring often, until deeply softened and starting to turn golden.";
"recipe.et_yebeg_wat.step8.title" = "Cook the onion base";
"recipe.et_yebeg_wat.step9.body" = "Stir in the spiced butter and cook until glossy. Mix in garlic and ginger until fragrant, then add %i21 and cook until it darkens slightly. Stir in %i22 and cook, stirring continuously, until aromatic and the oil turns deep red.";
"recipe.et_yebeg_wat.step9.title" = "Build the sauce";
