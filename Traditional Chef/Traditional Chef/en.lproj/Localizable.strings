"recipe.cl_leche_asada.drink.body" = "Pair with a lightly sweet Moscato or late-harvest style white that echoes the custard’s vanilla and caramelized notes. A cup of coffee also pairs naturally. Non-alcoholic option: black coffee, cinnamon tea, or a cold glass of milk.";
"recipe.cl_leche_asada.drink.summary" = "Sweet wine (Moscato)";
"recipe.cl_leche_asada.info" = "Leche asada is a traditional Chilean baked custard made by gently mixing milk with eggs, sugar, and vanilla, then baking it until softly set with a characteristic browned top. Unlike flan, it is typically served without a caramel layer, sliced or spooned from the dish once chilled, and enjoyed as a simple, comforting home dessert.";
"recipe.cl_leche_asada.info.summary" = "Baked milk custard";
"recipe.cl_leche_asada.name" = "Leche asada";
"recipe.cl_leche_asada.step1.body" = "Heat the oven and set a baking dish into a roasting pan so it can bake in a water bath for gentle, even setting.";
"recipe.cl_leche_asada.step1.title" = "Prepare the oven and pan";
"recipe.cl_leche_asada.step2.body" = "Whisk %i2 with %i3 until the sugar is dissolved and the mixture is smooth, then whisk in %i1 and %i4 without creating excessive foam.";
"recipe.cl_leche_asada.step2.title" = "Mix the custard base";
