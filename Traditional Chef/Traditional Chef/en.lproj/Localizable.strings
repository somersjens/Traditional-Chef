"recipe.sr_pom.step5.title" = "Mix the pomtajer";
"recipe.sr_pom.step6.body" = "Spread half of the pomtajer mixture in an oven dish, cover it evenly with the chicken filling, and spread the remaining pomtajer mixture over the top.";
"recipe.sr_pom.step6.title" = "Layer the pom";
"recipe.sr_pom.step7.body" = "Bake until the top is golden brown and the edges are well colored and set.";
"recipe.sr_pom.step7.title" = "Bake the pom";
"recipe.sr_pom.step8.body" = "Let the pom rest briefly so it firms up and can be cut cleanly.";
"recipe.sr_pom.step8.title" = "Rest before serving";
"recipe.sr_pom.step9.body" = "Cut the pom into portions and serve it hot with %i20.";
"recipe.sr_pom.step9.title" = "Serve";
