"recipe.mt_timpana.drink.body" = "A medium-bodied red wine such as Merlot pairs well with the rich meat sauce and pastry. A good non-alcoholic option is sparkling water or a dark grape juice spritzer.";
"recipe.mt_timpana.drink.summary" = "Red wine (Merlot)";
"recipe.mt_timpana.info" = "Timpana is a traditional Maltese baked pasta pie of macaroni in a rich meat sauce enclosed in shortcrust pastry. It is a celebratory family dish, classically baked until golden and sliced to show the pasta, meat, cheese, and egg filling inside.";
"recipe.mt_timpana.info.summary" = "Baked pasta pie";
"recipe.mt_timpana.name" = "Timpana";
"recipe.mt_timpana.step1.body" = "Rub %i1 and %i2 together until sandy, then mix in one %i3, %i5, and enough %i4 to make a firm pastry. Wrap it and let it rest in a cool place.";
"recipe.mt_timpana.step1.title" = "Make the pastry";
"recipe.mt_timpana.step10.body" = "Let the timpana rest so it sets and slices neatly.";
"recipe.mt_timpana.step10.title" = "Rest before serving";
"recipe.mt_timpana.step11.body" = "Cut the timpana into thick slices and serve hot.";
"recipe.mt_timpana.step11.title" = "Serve";
"recipe.mt_timpana.step2.body" = "Chop %i9, %i10, %i13, %i21, %i8, %i16, and %i17.";
"recipe.mt_timpana.step2.title" = "Prepare the filling ingredients";
"recipe.mt_timpana.step3.body" = "Heat %i11 in the frying pan and cook the onion, garlic, and bacon until softened. Add %i7 and chicken livers and cook until browned.";
"recipe.mt_timpana.step3.title" = "Start the meat sauce";
"recipe.mt_timpana.step4.body" = "Add %i12, tomatoes, %i14, %i15, %i19, and %i20. Simmer until the sauce is thick and rich, then stir in the parsley.";
"recipe.mt_timpana.step4.title" = "Simmer the sauce";
"recipe.mt_timpana.step5.body" = "Cook %i6 in salted %i22 until just tender, then drain it well.";
"recipe.mt_timpana.step5.title" = "Boil the macaroni";
"recipe.mt_timpana.step6.body" = "Mix the macaroni with the meat sauce, then fold in %i18 and chopped hard-boiled eggs.";
"recipe.mt_timpana.step6.title" = "Combine the filling";
"recipe.mt_timpana.step7.body" = "Roll out most of the pastry and line the buttered pie dish, leaving enough pastry to cover the top.";
"recipe.mt_timpana.step7.title" = "Line the dish";
"recipe.mt_timpana.step8.body" = "Spoon the macaroni filling into the pastry case, cover with the remaining pastry, seal the edges, and brush the top with the remaining %i25.";
"recipe.mt_timpana.step8.title" = "Fill and seal the timpana";
"recipe.mt_timpana.step9.body" = "Bake until the pastry is deeply golden and firm and the filling is heated through.";
"recipe.mt_timpana.step9.title" = "Bake the pie";
