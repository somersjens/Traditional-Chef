"recipe.uy_postre_martin_fierro.drink.body" = "Pair with a lightly sweet Muscat or a late-harvest white that complements the quince without overpowering the cheese. A mild tawny-style fortified wine also works. For a non-alcoholic option, serve maté, black tea, or sparkling water with lemon.";
"recipe.uy_postre_martin_fierro.drink.summary" = "Dessert wine (Muscat)";
"recipe.uy_postre_martin_fierro.info" = "Postre Martín Fierro is a traditional Uruguayan dessert of firm fresh cheese served with sweet quince paste, a simple and beloved pairing often called queso y dulce. It is typically sliced into neat portions and served at room temperature as a quick, satisfying finish to a meal.";
"recipe.uy_postre_martin_fierro.info.summary" = "Cheese with quince";
"recipe.uy_postre_martin_fierro.name" = "Martín Fierro";
"recipe.uy_postre_martin_fierro.step1.body" = "Cut the %i1 into equal slices or blocks suitable for serving.";
"recipe.uy_postre_martin_fierro.step1.title" = "Portion the cheese";
"recipe.uy_postre_martin_fierro.step2.body" = "Cut the %i2 into slices matching the cheese portions so each serving is balanced.";
"recipe.uy_postre_martin_fierro.step2.title" = "Portion the quince paste";
"recipe.uy_postre_martin_fierro.step3.body" = "Arrange alternating slices of cheese and quince paste on a plate and serve at room temperature.";
"recipe.uy_postre_martin_fierro.step3.title" = "Plate and serve";
