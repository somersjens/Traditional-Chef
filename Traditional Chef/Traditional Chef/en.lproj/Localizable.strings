"recipe.kr_yakgwa.drink.body" = "Yakgwa is traditionally paired with Korean teas rather than wine, especially jujube tea or green tea to balance its sweetness. Non-alcoholic pairing: roasted barley tea.";
"recipe.kr_yakgwa.drink.summary" = "Tea (Jujube tea)";
"recipe.kr_yakgwa.info" = "Yakgwa is a traditional Korean honey pastry made from wheat flour dough enriched with sesame oil and rice wine, shaped and fried, then soaked in ginger-honey syrup. It is a classic hangwa served for holidays, ancestral rites, and tea tables, valued for its floral pattern and chewy syruped texture.";
"recipe.kr_yakgwa.info.summary" = "Honey ginger cookies";
"recipe.kr_yakgwa.name" = "Yakgwa";
"recipe.kr_yakgwa.step1.body" = "Peel and finely grate the %i6 for the dough and slice the %i11 for the syrup.";
"recipe.kr_yakgwa.step1.title" = "Prepare ginger for dough and syrup";
"recipe.kr_yakgwa.step10.body" = "Transfer the hot fried yakgwa into the warm syrup and soak until the pastries absorb syrup and become glossy.";
"recipe.kr_yakgwa.step10.title" = "Soak in syrup";
"recipe.kr_yakgwa.step11.body" = "Lift the yakgwa from the syrup, drain briefly on a rack, and garnish each piece with a little %i13.";
"recipe.kr_yakgwa.step11.title" = "Drain and garnish the yakgwa";
"recipe.kr_yakgwa.step12.body" = "Rinse the %i14 and combine with %i15 in a small pot.";
"recipe.kr_yakgwa.step12.title" = "Start the jujube tea";
"recipe.kr_yakgwa.step13.body" = "Simmer gently until the tea is fragrant and lightly colored.";
"recipe.kr_yakgwa.step13.title" = "Simmer the jujube tea";
"recipe.kr_yakgwa.step14.body" = "Strain the tea and stir in %i16 until dissolved.";
"recipe.kr_yakgwa.step14.title" = "Strain and sweeten the tea";
"recipe.kr_yakgwa.step15.body" = "Arrange the yakgwa on a serving plate and serve with warm jujube tea.";
"recipe.kr_yakgwa.step15.title" = "Serve";
"recipe.kr_yakgwa.step2.body" = "In a bowl, combine the %i3, %i4, %i5, and dough ginger until evenly mixed.";
"recipe.kr_yakgwa.step2.title" = "Mix the wet dough base";
"recipe.kr_yakgwa.step3.body" = "Sift the %i1 and %i2, then mix into the wet base just until a soft dough forms without overworking.";
"recipe.kr_yakgwa.step3.title" = "Make the dough";
"recipe.kr_yakgwa.step4.body" = "Cover the dough and let it rest so the flour hydrates and the dough relaxes.";
"recipe.kr_yakgwa.step4.title" = "Rest the dough";
"recipe.kr_yakgwa.step5.body" = "Roll the dough, fold and press it to create layers, then roll again and cut pieces. Press each piece in a yakgwa mold or score the surface with a pattern.";
"recipe.kr_yakgwa.step5.title" = "Shape the yakgwa";
"recipe.kr_yakgwa.step6.body" = "Combine the %i8, %i9, %i10, syrup ginger, and %i12 in a saucepan and simmer gently until aromatic, then keep warm.";
"recipe.kr_yakgwa.step6.title" = "Make the syrup";
"recipe.kr_yakgwa.step7.body" = "Heat the %i7 in a deep pot to a moderate frying temperature suitable for a gentle first fry.";
"recipe.kr_yakgwa.step7.title" = "Heat the frying oil";
"recipe.kr_yakgwa.step8.body" = "Fry the shaped dough pieces in batches over moderate heat until they expand and cook through without darkening too quickly.";
"recipe.kr_yakgwa.step8.title" = "First fry the pastries";
"recipe.kr_yakgwa.step9.body" = "Raise the heat slightly and fry the pastries again until evenly golden brown and crisp on the outside.";
"recipe.kr_yakgwa.step9.title" = "Second fry for color";
