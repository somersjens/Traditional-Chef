"recipe.ua_borshch.step1.title" = "Start the broth";
"recipe.ua_borshch.step10.body" = "Divide the risen dough into small balls, arrange them closely on the baking tray, and leave them to puff again.";
"recipe.ua_borshch.step10.title" = "Shape the pampushky";
"recipe.ua_borshch.step11.body" = "Bake the buns until golden and fully cooked through.";
