"recipe.gb_bread_and_butter_pudding.drink.body" = "A small glass of sweet sherry or a light dessert wine works well with the rich custard and nutmeg. For a non-alcoholic option, serve hot black tea or coffee with the pudding.";
"recipe.gb_bread_and_butter_pudding.drink.summary" = "Sweet sherry";
"recipe.gb_bread_and_butter_pudding.info" = "A traditional British dessert of buttered bread layered with raisins, covered in a vanilla-nutmeg egg custard and baked until golden on top and softly set underneath. It is a classic way to use stale bread and is traditionally served warm with hot custard.";
"recipe.gb_bread_and_butter_pudding.info.summary" = "Custard bread pudding";
"recipe.gb_bread_and_butter_pudding.name" = "Bread and butter pudding";
