"recipe.ma_pastilla.step3.title" = "Braise the chicken";
"recipe.ma_pastilla.step4.body" = "Remove chicken from the pot, let it cool enough to handle, then discard bones and skin and shred the meat finely. Return the meat to the pot.";
"recipe.ma_pastilla.step4.title" = "Shred the chicken";
"recipe.ma_pastilla.step5.body" = "Simmer the onion cooking liquid until thick and jammy, stirring often so it does not stick. Stir in the chopped cilantro and parsley.";
"recipe.ma_pastilla.step5.title" = "Reduce the onion sauce";
"recipe.ma_pastilla.step6.body" = "Beat the %i14. With the sauce at a gentle simmer, pour in the eggs while stirring continuously until they set into soft curds and the mixture becomes cohesive.";
"recipe.ma_pastilla.step6.title" = "Enrich with eggs";
