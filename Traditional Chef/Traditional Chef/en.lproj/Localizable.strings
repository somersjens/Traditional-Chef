"recipe.bd_payesh.drink.body" = "A lightly chilled Muscat or late-harvest dessert wine matches the milky sweetness and cardamom aroma. If you prefer something less sweet, an off-dry Riesling pairs nicely. Non-alcoholic pairing: masala chai or chilled milk with cardamom.";
"recipe.bd_payesh.drink.summary" = "Sweet wine (Muscat)";
"recipe.bd_payesh.info" = "Payesh is a traditional Bangladeshi rice pudding made by slowly simmering aromatic rice in milk until the grains soften and the milk reduces into a creamy, thick kheer. It is sweetened with sugar, scented with cardamom, and enriched with ghee-toasted nuts and raisins. Served chilled or at room temperature, it is a classic festive dessert for celebrations and family gatherings.";
"recipe.bd_payesh.info.summary" = "Cardamom rice pudding";
"recipe.bd_payesh.name" = "Payesh";
"recipe.bd_payesh.step1.body" = "Rinse the %i1, cover it with %i8, and soak until the grains hydrate.";
"recipe.bd_payesh.step1.title" = "Soak the rice";
"recipe.bd_payesh.step2.body" = "Heat %i4 and fry %i5 until lightly golden, then add %i6 and stir until they puff. Remove and reserve, leaving the ghee behind.";
"recipe.bd_payesh.step2.title" = "Toast nuts and raisins";
"recipe.bd_payesh.step3.body" = "Bring the %i2 to a gentle simmer in a heavy saucepan, stirring so it does not scorch.";
"recipe.bd_payesh.step3.title" = "Start the milk";
"recipe.bd_payesh.step4.body" = "Drain the soaked rice and add it to the simmering milk. Cook gently, stirring often, until the rice is tender and the mixture thickens.";
"recipe.bd_payesh.step4.title" = "Cook the rice in milk";
"recipe.bd_payesh.step5.body" = "Stir in %i3 and %i7 and cook until the sugar fully dissolves and the payesh turns glossy.";
"recipe.bd_payesh.step5.title" = "Sweeten and perfume";
"recipe.bd_payesh.step6.body" = "Stir in the toasted cashews and raisins, then remove from the heat.";
"recipe.bd_payesh.step6.title" = "Finish with nuts";
"recipe.bd_payesh.step7.body" = "Cool to room temperature, refrigerate until well chilled, then serve.";
"recipe.bd_payesh.step7.title" = "Chill and serve";
