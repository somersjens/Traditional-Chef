"recipe.ir_chelo_kabab_koobideh.drink.body" = "A medium-bodied red like Grenache or Syrah works well with smoky grilled meat and buttered saffron rice. If you prefer white, a fuller-bodied Viognier can handle the richness. Non-alcoholic: doogh (yogurt-mint drink) or sparkling water with lemon.";
"recipe.ir_chelo_kabab_koobideh.drink.summary" = "Red wine (Grenache)";
"recipe.ir_chelo_kabab_koobideh.info" = "Chelo Kabab Koobideh is a signature Iranian dish of juicy minced-meat kebabs grilled on wide skewers and served with fluffy steamed basmati rice, saffron, and crisp tahdig. It is traditionally plated with grilled tomatoes, raw onion, sumac, and a pat of butter, with fresh herb sides and flatbread commonly served alongside.";
"recipe.ir_chelo_kabab_koobideh.info.summary" = "Iconic koobideh plate";
"recipe.ir_chelo_kabab_koobideh.name" = "Koobideh kebab";
"recipe.ir_chelo_kabab_koobideh.step1.body" = "Rinse %i7 until the water runs mostly clear, then soak it in salted %i11 so the grains hydrate evenly.";
"recipe.ir_chelo_kabab_koobideh.step1.title" = "Soak the rice";
"recipe.ir_chelo_kabab_koobideh.step10.body" = "Grill the kebabs over hot coals, turning frequently to set the meat and cook through with light charring. Grill the tomatoes until blistered and softened.";
"recipe.ir_chelo_kabab_koobideh.step10.title" = "Grill koobideh and tomatoes";
"recipe.ir_chelo_kabab_koobideh.step11.body" = "Turn out the rice to reveal the tahdig and spoon a little bloomed saffron over some of the rice. Serve kebabs beside the rice with grilled tomatoes, %i13, %i14, %i15, %i16, %i17, %i18, and %i19.";
"recipe.ir_chelo_kabab_koobideh.step11.title" = "Finish chelo and plate";
"recipe.ir_chelo_kabab_koobideh.step2.body" = "Crush %i6 and steep it in a little warm water so it releases color and aroma.";
"recipe.ir_chelo_kabab_koobideh.step2.title" = "Bloom saffron";
"recipe.ir_chelo_kabab_koobideh.step3.body" = "Grate %i3, drain it well, then combine it with %i1, %i2, %i4, and %i5. Knead vigorously until the mixture becomes sticky and cohesive.";
"recipe.ir_chelo_kabab_koobideh.step3.title" = "Prepare onion and mix meat";
"recipe.ir_chelo_kabab_koobideh.step4.body" = "Cover the meat mixture and chill so it firms up and holds to the skewers.";
"recipe.ir_chelo_kabab_koobideh.step4.title" = "Chill the kebab mixture";
"recipe.ir_chelo_kabab_koobideh.step5.body" = "Bring a large pot of water to a boil. Drain the soaked rice and boil until the grains are softened on the outside but still firm in the center, then drain well.";
"recipe.ir_chelo_kabab_koobideh.step5.title" = "Parboil the rice";
"recipe.ir_chelo_kabab_koobideh.step6.body" = "Mix %i8 with some of the bloomed saffron and combine it with a portion of the parboiled rice to make the tahdig layer.";
"recipe.ir_chelo_kabab_koobideh.step6.title" = "Make tahdig base";
"recipe.ir_chelo_kabab_koobideh.step7.body" = "Heat %i10 in the rice pot, spread the yogurt-rice mixture over the bottom, then mound the remaining rice on top. Poke a few steam vents, dot with %i9, wrap the lid with a towel, and cover tightly.";
"recipe.ir_chelo_kabab_koobideh.step7.title" = "Layer and start steaming";
"recipe.ir_chelo_kabab_koobideh.step8.body" = "Steam on low heat until the rice is fully cooked and fragrant and the tahdig is crisp.";
"recipe.ir_chelo_kabab_koobideh.step8.title" = "Steam the rice";
"recipe.ir_chelo_kabab_koobideh.step9.body" = "Skewer the meat onto wide skewers, pressing it firmly along the length. Skewer %i12 separately and keep them ready for the grill.";
"recipe.ir_chelo_kabab_koobideh.step9.title" = "Skewer kebabs and tomatoes";
