"recipe.kr_bulgogi.drink.body" = "A light red such as Pinot Noir or Gamay pairs well with the sweet-savory marinade and grilled beef. A clean lager also works very well. Non-alcoholic pairing: cold barley tea.";
"recipe.kr_bulgogi.drink.summary" = "Red wine (Pinot Noir)";
"recipe.kr_bulgogi.info" = "Bulgogi is a traditional Korean dish of thinly sliced beef marinated with soy sauce, aromatics, and pear, then quickly grilled or pan-cooked. It is commonly served with rice and leafy wraps, with ssamjang and banchan at the table for a shared meal.";
"recipe.kr_bulgogi.info.summary" = "Marinated grilled beef";
"recipe.kr_bulgogi.name" = "Bulgogi";
