"recipe.gb_spotted_dick.step7.body" = "Whisk the %i12 with the %i13, pour in the hot dairy gradually, then return to gentle heat and stir until the custard thickens enough to coat a spoon.";
"recipe.gb_spotted_dick.step7.title" = "Finish custard";
"recipe.gb_spotted_dick.step8.body" = "Pass the custard through a fine sieve and keep warm.";
"recipe.gb_spotted_dick.step8.title" = "Strain custard";
"recipe.gb_spotted_dick.step9.body" = "Lift out the pudding basin, remove the cover, and turn the pudding onto a warm serving dish.";
