"recipe.bd_mishti_doi.drink.body" = "A lightly chilled Muscat or late-harvest Chenin Blanc complements the caramel sweetness and creamy tang. If you prefer something less sweet, an off-dry Riesling works well. Non-alcoholic pairing: masala chai or cold milk with a pinch of cardamom.";
"recipe.bd_mishti_doi.drink.summary" = "Sweet wine (Muscat)";
"recipe.bd_mishti_doi.info" = "Mishti doi is a traditional Bangladeshi sweetened set yogurt made by gently reducing milk, sweetening it with caramelised sugar or jaggery, then culturing it with a little yogurt starter and allowing it to set into a smooth, softly firm curd. It is commonly prepared in earthenware bowls that help wick moisture and deepen the flavor, then served chilled as a classic Bengali dessert.";
"recipe.bd_mishti_doi.info.summary" = "Caramel set yogurt";
"recipe.bd_mishti_doi.name" = "Mishti doi";
"recipe.bd_mishti_doi.step1.body" = "Warm the earthenware bowls so they are not cold when filled, then set them on a baking tray.";
"recipe.bd_mishti_doi.step1.title" = "Warm the bowls";
"recipe.bd_mishti_doi.step2.body" = "Simmer the %i1 gently, stirring often, until it reduces and becomes slightly thicker and more fragrant.";
"recipe.bd_mishti_doi.step2.title" = "Reduce the milk";
"recipe.bd_mishti_doi.step3.body" = "Add the %i2 and stir over gentle heat until fully melted and the milk turns a light caramel colour.";
"recipe.bd_mishti_doi.step3.title" = "Caramelise the sweetener";
"recipe.bd_mishti_doi.step4.body" = "Remove from the heat and let the sweetened milk cool until warm but not hot.";
"recipe.bd_mishti_doi.step4.title" = "Cool to culturing temperature";
