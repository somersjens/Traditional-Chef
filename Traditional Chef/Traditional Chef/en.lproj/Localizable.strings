"recipe.bd_shondesh.drink.body" = "A lightly chilled Muscat or late-harvest dessert wine complements the milky sweetness and cardamom aroma. If you prefer something less sweet, an off-dry Riesling pairs well. Non-alcoholic pairing: masala chai or chilled milk with a pinch of cardamom.";
"recipe.bd_shondesh.drink.summary" = "Sweet wine (Muscat)";
"recipe.bd_shondesh.info" = "Shondesh is a classic Bangladeshi Bengali sweet made from fresh chhana (curdled milk solids) cooked gently with sugar until it turns smooth, slightly grainy, and fudgy, then scented with cardamom and molded into delicate bite-size sweets. Served at room temperature or lightly chilled, it is a traditional dessert for festivals, guests, and tea-time.";
"recipe.bd_shondesh.info.summary" = "Chhana tea sweet";
"recipe.bd_shondesh.name" = "Shondesh";
"recipe.bd_shondesh.step1.body" = "Warm the %i1 in a saucepan over medium heat, stirring so it does not scorch, until it reaches a steady simmer.";
"recipe.bd_shondesh.step1.title" = "Heat the milk";
"recipe.bd_shondesh.step2.body" = "Add %i2 juice gradually while stirring until curds separate clearly from the whey.";
"recipe.bd_shondesh.step2.title" = "Curdle to make chhana";
"recipe.bd_shondesh.step3.body" = "Pour the curds into a cloth-lined sieve and let them drain until the chhana is moist but not dripping.";
"recipe.bd_shondesh.step3.title" = "Drain the chhana";
"recipe.bd_shondesh.step4.body" = "Transfer chhana to a plate and knead firmly until smooth, soft, and no longer grainy.";
"recipe.bd_shondesh.step4.title" = "Knead until smooth";
"recipe.bd_shondesh.step5.body" = "Cook the kneaded chhana with %i3 in a heavy pan over low heat, stirring constantly, until it thickens and begins to leave the sides of the pan.";
"recipe.bd_shondesh.step5.title" = "Cook with sugar";
"recipe.bd_shondesh.step6.body" = "Stir in %i4, then remove from the heat and let the mixture cool until comfortable to handle.";
"recipe.bd_shondesh.step6.title" = "Perfume and cool slightly";
"recipe.bd_shondesh.step7.body" = "Portion the mixture and press into sandesh molds, then unmold onto a tray.";
"recipe.bd_shondesh.step7.title" = "Shape the shondesh";
"recipe.bd_shondesh.step8.body" = "Refrigerate until set, then serve slightly chilled or at room temperature.";
"recipe.bd_shondesh.step8.title" = "Set and serve";
