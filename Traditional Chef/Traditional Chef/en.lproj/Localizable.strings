"recipe.es_gambas_al_ajillo.drink.body" = "Pair with a crisp Spanish white such as Albariño or Verdejo to refresh the palate against the garlic and olive oil. A dry Cava also works well with the sizzling tapa. Non-alcoholic option: sparkling water with lemon.";
"recipe.es_gambas_al_ajillo.drink.summary" = "White wine (Albariño)";
"recipe.es_gambas_al_ajillo.info" = "Gambas al ajillo is a classic Spanish tapa of shrimp quickly sizzled in olive oil infused with plenty of sliced garlic and dried chile, finished with parsley and served bubbling hot in a small earthenware dish. It’s meant to be eaten immediately with crusty bread to soak up the garlicky oil, a staple in bars across Spain.";
"recipe.es_gambas_al_ajillo.info.summary" = "Sizzling garlic shrimp";
"recipe.es_gambas_al_ajillo.name" = "Garlic shrimp";
"recipe.es_gambas_al_ajillo.step1.body" = "Peel and devein %i1 and pat them dry. Slice %i3 thinly and chop %i6.";
"recipe.es_gambas_al_ajillo.step1.title" = "Prepare shrimp and aromatics";
"recipe.es_gambas_al_ajillo.step2.body" = "Warm %i2 in a skillet over low heat. Add garlic and %i4 and cook gently until the garlic turns pale golden.";
"recipe.es_gambas_al_ajillo.step2.title" = "Infuse the oil";
"recipe.es_gambas_al_ajillo.step3.body" = "Increase the heat and add the shrimp. Cook quickly, turning, until just opaque and coated in the garlic oil, then season with %i5.";
"recipe.es_gambas_al_ajillo.step3.title" = "Sizzle the shrimp";
"recipe.es_gambas_al_ajillo.step4.body" = "Stir in parsley, transfer to a warm cazuela with the hot oil, and serve immediately with %i7.";
"recipe.es_gambas_al_ajillo.step4.title" = "Finish and serve";
