"recipe.ec_seco_de_chivo.drink.body" = "A young fruity red wine such as Pinot Noir works well with the rich goat and aromatic sauce. A light lager is also a classic match. For a non-alcoholic option, serve sparkling water with lime.";
"recipe.ec_seco_de_chivo.drink.summary" = "Red wine (Pinot Noir)";
"recipe.ec_seco_de_chivo.info" = "Seco de Chivo is a traditional Ecuadorian goat stew, slowly braised with onion, garlic, cumin, achiote, herbs, beer, and naranjilla until the meat is tender and the sauce is rich. It is classically served as a hearty midday meal with yellow rice, fried ripe plantain, and avocado.";
"recipe.ec_seco_de_chivo.info.summary" = "Ecuadorian goat stew";
"recipe.ec_seco_de_chivo.name" = "Goat seco";
"recipe.ec_seco_de_chivo.step1.body" = "Cut %i1 into serving pieces if needed. Roughly chop %i2, %i3, %i4, and %i5, then chop %i12 and %i13. Peel and slice %i23 for serving later.";
"recipe.ec_seco_de_chivo.step1.title" = "Prepare the ingredients";
"recipe.ec_seco_de_chivo.step2.body" = "Blend the onion, garlic, tomatoes, bell pepper, %i6, %i7, %i8, %i9, %i10, %i14, and %i15 until smooth.";
"recipe.ec_seco_de_chivo.step2.title" = "Blend the sauce base";
"recipe.ec_seco_de_chivo.step3.body" = "Heat %i11 in the pot and brown the goat well on all sides so it develops deep flavor before braising.";
"recipe.ec_seco_de_chivo.step3.title" = "Brown the goat";
"recipe.ec_seco_de_chivo.step4.body" = "Pour in the blended sauce and add %i16. Bring to a boil, lower the heat, and cook slowly until the goat is very tender and the sauce has thickened.";
"recipe.ec_seco_de_chivo.step4.title" = "Braise the stew";
"recipe.ec_seco_de_chivo.step5.body" = "Stir in most of the cilantro and parsley, then simmer briefly so the fresh herb flavor blends into the stew.";
"recipe.ec_seco_de_chivo.step5.title" = "Finish with herbs";
"recipe.ec_seco_de_chivo.step6.body" = "Rinse %i17, then cook it in %i18 with %i19 and %i20 until tender and fluffy.";
"recipe.ec_seco_de_chivo.step6.title" = "Cook the yellow rice";
"recipe.ec_seco_de_chivo.step7.body" = "Cut %i21 and fry them in %i22 until golden and caramelized outside and soft inside. Drain well.";
"recipe.ec_seco_de_chivo.step7.title" = "Fry the plantains";
"recipe.ec_seco_de_chivo.step8.body" = "Let the seco settle briefly, then taste and adjust the salt. Spoon some sauce over the goat pieces.";
"recipe.ec_seco_de_chivo.step8.title" = "Rest and adjust the stew";
"recipe.ec_seco_de_chivo.step9.body" = "Serve the seco de chivo hot with yellow rice, fried ripe plantain, and avocado. Finish with the remaining herbs over the stew.";
