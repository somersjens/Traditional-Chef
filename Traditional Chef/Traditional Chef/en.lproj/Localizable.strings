"recipe.sa_kabsa.drink.body" = "A medium-bodied red wine such as Grenache or Syrah matches the warm spices, savory chicken, and tomato-rich rice. For a non-alcoholic pairing, serve mint tea or a cold yogurt drink.";
"recipe.sa_kabsa.drink.summary" = "Red wine (Grenache)";
"recipe.sa_kabsa.info" = "Kabsa is a traditional Saudi main dish of basmati rice cooked with chicken, tomatoes, onions, garlic, and fragrant whole spices including black lime, cardamom, cloves, cinnamon, and bay leaf. It is a centerpiece dish for family meals and hospitality, traditionally served hot on a large platter with daqoos, the fresh tomato chili sauce served alongside.";
"recipe.sa_kabsa.info.summary" = "Saudi spiced rice";
"recipe.sa_kabsa.name" = "Kabsa";
"recipe.sa_kabsa.step1.body" = "Heat %i2 in the heavy pot and brown %i1 well on both sides, then remove it so the pot keeps the flavor base.";
"recipe.sa_kabsa.step1.title" = "Brown the chicken";
"recipe.sa_kabsa.step10.body" = "Spoon the rice onto a large platter, arrange the chicken on top, and serve the daqoos alongside.";
"recipe.sa_kabsa.step10.title" = "Serve the dish";
"recipe.sa_kabsa.step2.body" = "Add %i3 and cook until softened, then add %i4, %i5, and %i6 and cook until the mixture thickens into a rich sauce.";
"recipe.sa_kabsa.step2.title" = "Cook the aromatics";
"recipe.sa_kabsa.step3.body" = "Add %i7, %i8, %i9, %i10, %i11, %i12, %i13, %i14, %i15, and %i16 and stir until fragrant.";
"recipe.sa_kabsa.step3.title" = "Add the spices";
"recipe.sa_kabsa.step4.body" = "Return the chicken to the pot, add %i17, bring to a boil, then cover and simmer until the chicken is tender and the broth is well seasoned.";
"recipe.sa_kabsa.step4.title" = "Simmer the chicken";
"recipe.sa_kabsa.step5.body" = "Rinse %i18 until the water runs mostly clear, then drain it well.";
"recipe.sa_kabsa.step5.title" = "Wash the rice";
"recipe.sa_kabsa.step6.body" = "Lift the chicken from the pot and keep it aside, then check the broth and leave enough in the pot to cook the rice properly.";
"recipe.sa_kabsa.step6.title" = "Prepare for the rice";
"recipe.sa_kabsa.step7.body" = "Add the rice to the pot, spread it evenly in the broth, set the chicken on top, then cover and cook gently until the rice is tender and the liquid is absorbed.";
"recipe.sa_kabsa.step7.title" = "Cook the rice";
"recipe.sa_kabsa.step8.body" = "Take the pot off the heat and let the kabsa rest covered so the rice finishes steaming and the grains settle.";
"recipe.sa_kabsa.step8.title" = "Rest the kabsa";
"recipe.sa_kabsa.step9.body" = "Blend the remaining %i19 with %i20, %i21, and the rest of %i22 until the sauce is smooth but still fresh tasting.";
"recipe.sa_kabsa.step9.title" = "Make the daqoos";
