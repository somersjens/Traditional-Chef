"recipe.pk_chapli_kebab.drink.body" = "A light to medium red such as Pinot Noir or Grenache can handle the spices without overpowering the kebabs. A crisp lager also pairs well. Non-alcoholic pairing: salted lassi or hot black tea are both excellent choices.";
"recipe.pk_chapli_kebab.drink.summary" = "Red wine (Pinot Noir)";
"recipe.pk_chapli_kebab.info" = "Chapli Kebab is a traditional Pakistani kebab, especially associated with Peshawar, made from minced meat mixed with herbs, spices, onion, and tomato, then shaped into flat patties and shallow-fried until crisp at the edges and juicy inside. It is commonly served hot with naan and chutney as a shared meal.";
"recipe.pk_chapli_kebab.info.summary" = "Peshawari meat patties";
"recipe.pk_chapli_kebab.name" = "Chapli kebab";
"recipe.pk_chapli_kebab.step1.body" = "Finely chop the %i2, %i3, %i4, %i5, %i8, %i6, and %i7 for the kebab mixture. Slice the %i26 for serving. Keep the chutney herbs and aromatics separate.";
"recipe.pk_chapli_kebab.step1.title" = "Prepare ingredients";
"recipe.pk_chapli_kebab.step10.body" = "Serve the hot chapli kebabs with sliced red onion, naan bread, and mint chutney.";
"recipe.pk_chapli_kebab.step10.title" = "Serve";
"recipe.pk_chapli_kebab.step2.body" = "Coarsely crush the %i12, %i13, and %i16 so they release aroma but still keep some texture.";
"recipe.pk_chapli_kebab.step2.title" = "Crush spices";
"recipe.pk_chapli_kebab.step3.body" = "Combine the %i1 with chopped onion, tomato, cilantro, mint, garlic, ginger, green chili, %i9, %i10, %i11, crushed spices, %i14, and %i15. Mix thoroughly until the mixture becomes sticky and holds together.";
"recipe.pk_chapli_kebab.step3.title" = "Mix kebab base";
"recipe.pk_chapli_kebab.step4.body" = "Let the kebab mixture rest so the spices hydrate and the mixture firms up for shaping.";
"recipe.pk_chapli_kebab.step4.title" = "Rest mixture";
"recipe.pk_chapli_kebab.step5.body" = "Blend the %i18, %i19, %i20, %i21, %i22, %i23, and %i24 until smooth and spoonable.";
"recipe.pk_chapli_kebab.step5.title" = "Make mint chutney";
"recipe.pk_chapli_kebab.step6.body" = "Divide the meat mixture and shape it into flat round patties on a plate, pressing gently so they are even and not too thick.";
"recipe.pk_chapli_kebab.step6.title" = "Shape patties";
"recipe.pk_chapli_kebab.step7.body" = "Heat the %i17 in a heavy pan over medium heat. Fry the patties in batches until the first side is well browned and crisp at the edges.";
"recipe.pk_chapli_kebab.step7.title" = "Fry first side";
"recipe.pk_chapli_kebab.step8.body" = "Turn the patties and continue frying until browned, cooked through, and still juicy inside. Remove and keep warm while finishing the remaining patties.";
"recipe.pk_chapli_kebab.step8.title" = "Fry second side";
"recipe.pk_chapli_kebab.step9.body" = "Warm the %i25 briefly until soft and fragrant.";
"recipe.pk_chapli_kebab.step9.title" = "Warm naan";
"recipe.pk_chapli_kebab.tool.t1" = "Mixing bowl";
