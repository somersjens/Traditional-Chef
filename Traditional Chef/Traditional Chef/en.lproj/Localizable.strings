"recipe.cz_svickova_na_smetane.drink.body" = "A light to medium-bodied red such as Pinot Noir or a softer Moravian red pairs well with the sweet root vegetables, cream, and beef. For a non-alcoholic pairing, serve sparkling water or still water with lemon.";
"recipe.cz_svickova_na_smetane.drink.summary" = "Red wine (Pinot Noir)";
"recipe.cz_svickova_na_smetane.info" = "Svíčková na smetaně is one of the best known dishes of Czech cuisine. Beef is larded, marinated with root vegetables and spices, then braised until tender and served in a smooth creamy vegetable sauce with bread dumplings, cranberries, lemon, and whipped cream.";
"recipe.cz_svickova_na_smetane.info.summary" = "Creamy beef classic";
"recipe.cz_svickova_na_smetane.name" = "Svíčková";
"recipe.cz_svickova_na_smetane.step1.body" = "Cut %i2 into thick strips and chill it until firm. Make deep holes in %i1 with the larding needle or a thin knife and insert the bacon strips throughout the meat.";
"recipe.cz_svickova_na_smetane.step1.title" = "Lard the beef";
