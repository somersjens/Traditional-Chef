"recipe.rs_muckalica.drink.body" = "A light to medium-bodied red wine such as Pinot Noir pairs well with the smoky pork and pepper-tomato sauce without overwhelming the dish. A pale lager also works well. For a non-alcoholic option, serve sparkling water or plain yogurt.";
"recipe.rs_muckalica.drink.summary" = "Red wine (Pinot Noir)";
"recipe.rs_muckalica.info" = "Muckalica is a traditional Serbian meat dish, especially associated with Leskovac, made by simmering grilled pork with onions, roasted peppers, tomatoes, garlic, and paprika into a rich, smoky stew. It is served hot as a hearty family meal and is traditionally accompanied by bread.";
"recipe.rs_muckalica.info.summary" = "Smoky pork stew";
"recipe.rs_muckalica.name" = "Mućkalica";
"recipe.rs_muckalica.step1.body" = "Cut %i1 into large bite-size pieces, slice %i2, chop %i3, mince %i4, peel and chop %i6, slice %i5, and finely slice %i8.";
"recipe.rs_muckalica.step1.title" = "Prepare the ingredients";
"recipe.rs_muckalica.step2.body" = "Heat the grill pan well and brown the pork in batches until it develops a grilled crust. Season it with part of %i11 and %i12, then set it aside.";
"recipe.rs_muckalica.step2.title" = "Brown the pork";
"recipe.rs_muckalica.step3.body" = "Heat %i9 in the skillet and cook the bacon until it starts releasing fat. Add the onions and cook until softened, then add the garlic and cook briefly.";
"recipe.rs_muckalica.step3.title" = "Cook the bacon and onions";
"recipe.rs_muckalica.step4.body" = "Add the tomatoes, roasted peppers, %i7, and hot chili peppers to the skillet. Cook until the vegetables soften and the base becomes thick and fragrant.";
"recipe.rs_muckalica.step4.title" = "Build the pepper base";
"recipe.rs_muckalica.step5.body" = "Return the pork to the skillet, add %i10, and simmer gently until the meat is tender and the sauce is rich and slightly reduced.";
"recipe.rs_muckalica.step5.title" = "Simmer the stew";
"recipe.rs_muckalica.step6.body" = "Taste and adjust with the remaining salt and black pepper, then stir the stew well so the pork is fully coated in the sauce.";
"recipe.rs_muckalica.step6.title" = "Finish the muckalica";
"recipe.rs_muckalica.step7.body" = "Serve the muckalica hot with %i13 alongside for dipping into the pepper and tomato sauce.";
"recipe.rs_muckalica.step7.title" = "Serve traditionally";
