"recipe.gr_youvarlakia.step2.title" = "Form the meatballs";
"recipe.gr_youvarlakia.step3.body" = "Bring %i7 and %i8 to a gentle simmer in a pot and season lightly with %i9.";
"recipe.gr_youvarlakia.step3.title" = "Heat the broth";
"recipe.gr_youvarlakia.step4.body" = "Add the meatballs and simmer gently until cooked through and the rice is tender, keeping the liquid below a boil.";
"recipe.gr_youvarlakia.step4.title" = "Simmer the meatballs";
