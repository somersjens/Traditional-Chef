"recipe.cn_xiaolongbao.drink.body" = "A dry sparkling wine or very light lager can pair with the rich pork broth and delicate wrapper, while hot jasmine tea is a classic non-alcoholic pairing that cleans the palate between dumplings.";
"recipe.cn_xiaolongbao.drink.summary" = "Sparkling wine";
"recipe.cn_xiaolongbao.info" = "Xiaolongbao are traditional Jiangnan soup dumplings, especially associated with Shanghai, made with a thin wheat wrapper enclosing seasoned pork filling and gelatin-rich aspic that melts into broth during steaming. They are served hot in bamboo steamers and eaten carefully with black vinegar and ginger as a classic dim sum or light meal.";
"recipe.cn_xiaolongbao.info.summary" = "Steamed soup dumplings";
"recipe.cn_xiaolongbao.name" = "Soup dumplings";
"recipe.cn_xiaolongbao.step1.body" = "Clean the %i1 and %i2, scrape off any remaining hair or impurities, then cut them into smaller pieces. Slice the %i4 and cut the %i5 into sections.";
"recipe.cn_xiaolongbao.step1.title" = "Prepare the aspic stock base";
"recipe.cn_xiaolongbao.step10.body" = "Line the bamboo steamers with %i20, bring %i21 to a boil in the steamer pot, and julienne the %i23 into %i22.";
"recipe.cn_xiaolongbao.step10.title" = "Prepare steamer and dipping sauce";
"recipe.cn_xiaolongbao.step11.body" = "Arrange the dumplings with space between them in the steamers and steam over boiling water until the wrappers turn translucent and the filling is cooked through.";
"recipe.cn_xiaolongbao.step11.title" = "Steam the xiaolongbao";
"recipe.cn_xiaolongbao.step12.body" = "Serve the hot soup dumplings in the steamers with the ginger vinegar dipping sauce.";
"recipe.cn_xiaolongbao.step12.title" = "Serve immediately";
"recipe.cn_xiaolongbao.step2.body" = "Place the pork skin, trotters, %i3, ginger, scallions, and %i6 in a large pot, bring to a boil, skim well, then simmer gently until the stock is rich and gelatinous.";
"recipe.cn_xiaolongbao.step2.title" = "Simmer the gelatin-rich stock";
"recipe.cn_xiaolongbao.step3.body" = "Strain the stock, discard the solids, and pour the reduced liquid into a shallow tray. Chill until fully set into a firm jelly.";
"recipe.cn_xiaolongbao.step3.title" = "Strain and set the aspic";
"recipe.cn_xiaolongbao.step4.body" = "Mix the %i7, %i8, and %i9 into a smooth dough, knead until elastic, then cover and let it rest.";
"recipe.cn_xiaolongbao.step4.title" = "Make and rest the dough";
"recipe.cn_xiaolongbao.step5.body" = "Mince the %i11 and %i12 very finely and gather the pork filling seasonings.";
"recipe.cn_xiaolongbao.step5.title" = "Prepare the filling aromatics";
"recipe.cn_xiaolongbao.step6.body" = "Combine the %i10 with ginger, scallions, %i13, %i14, %i15, %i16, %i17, and %i18, then stir in one direction until sticky and cohesive.";
"recipe.cn_xiaolongbao.step6.title" = "Mix the pork filling";
"recipe.cn_xiaolongbao.step7.body" = "Cut the chilled %i19 into small cubes, then gently fold it into the pork filling so the cubes stay distinct.";
"recipe.cn_xiaolongbao.step7.title" = "Dice and fold in aspic";
"recipe.cn_xiaolongbao.step8.body" = "Divide the rested dough into small pieces and roll each into a thin round wrapper with a slightly thicker center and thinner edge.";
"recipe.cn_xiaolongbao.step8.title" = "Prepare wrappers";
"recipe.cn_xiaolongbao.step9.body" = "Place filling in each wrapper, gather the edges, and pleat tightly to seal at the top, keeping the dumplings upright so the soup is enclosed.";
"recipe.cn_xiaolongbao.step9.title" = "Fill and pleat the dumplings";
