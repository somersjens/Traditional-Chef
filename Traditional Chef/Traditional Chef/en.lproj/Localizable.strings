"recipe.rs_karadjordjeva_snicla.drink.body" = "A fresh medium-bodied white wine such as unoaked Chardonnay pairs well with the rich kajmak filling and crisp fried coating. A pale lager also works well. For a non-alcoholic option, serve sparkling water with lemon.";
"recipe.rs_karadjordjeva_snicla.drink.summary" = "White wine (Chardonnay)";
"recipe.rs_karadjordjeva_snicla.info" = "Karadjordjeva Snicla is a traditional Serbian breaded rolled schnitzel, classically made with veal filled with kajmak, then coated and fried until crisp outside and tender inside. It is served hot as a restaurant-style main course, traditionally with tartar sauce, lemon, and pommes frites.";
"recipe.rs_karadjordjeva_snicla.info.summary" = "Stuffed fried schnitzel";
"recipe.rs_karadjordjeva_snicla.name" = "Karađorđeva šnicla";
"recipe.rs_karadjordjeva_snicla.step1.body" = "Peel and cut %i14 into fries, finely chop %i11, cut %i17 into wedges, and pound %i1 very thin into broad rectangles.";
"recipe.rs_karadjordjeva_snicla.step1.title" = "Prepare the components";
"recipe.rs_karadjordjeva_snicla.step2.body" = "Place %i9 for the tartar sauce in a saucepan, bring to a boil, and cook until hard-boiled. Cool them, peel them, and chop them finely.";
"recipe.rs_karadjordjeva_snicla.step2.title" = "Cook the eggs";
"recipe.rs_karadjordjeva_snicla.step3.body" = "Mix the chopped hard-boiled eggs with %i10, pickles, %i12, and %i13 until thick and well combined. Chill until serving.";
"recipe.rs_karadjordjeva_snicla.step3.title" = "Make the tartar sauce";
"recipe.rs_karadjordjeva_snicla.step4.body" = "Season the veal lightly with %i6 and %i7, place %i2 along the center of each cutlet, then roll tightly and tuck in the ends so the filling stays enclosed.";
"recipe.rs_karadjordjeva_snicla.step4.title" = "Fill and roll the schnitzels";
"recipe.rs_karadjordjeva_snicla.step5.body" = "Coat each roll in %i3, then beaten %i4, then %i5, pressing gently so the coating adheres evenly.";
"recipe.rs_karadjordjeva_snicla.step5.title" = "Bread the schnitzels";
"recipe.rs_karadjordjeva_snicla.step6.body" = "Heat %i15 in the deep pan and fry the potatoes until golden and crisp. Drain well and season with %i16.";
"recipe.rs_karadjordjeva_snicla.step6.title" = "Fry the potatoes";
"recipe.rs_karadjordjeva_snicla.step7.body" = "Heat %i8 in the skillet and fry the breaded rolls until deeply golden and cooked through on all sides. Drain them briefly on paper towels.";
"recipe.rs_karadjordjeva_snicla.step7.title" = "Fry the schnitzels";
"recipe.rs_karadjordjeva_snicla.step8.body" = "Serve each Karadjordjeva Snicla hot with pommes frites, tartar sauce, and lemon wedges on the side.";
"recipe.rs_karadjordjeva_snicla.step8.title" = "Serve traditionally";
