"recipe.no_fiskesuppe.drink.body" = "A dry, fresh white wine such as Sauvignon Blanc or unoaked Chardonnay works well with the delicate fish and creamy broth. A good non-alcoholic match is sparkling water with lemon or a chilled apple juice spritzer.";
"recipe.no_fiskesuppe.drink.summary" = "White wine (Sauvignon)";
"recipe.no_fiskesuppe.info" = "Fiskesuppe is a traditional Norwegian fish soup, especially associated with coastal cooking and the Bergen style. It is served hot as a substantial main course with tender fish, sweet root vegetables, shellfish, and a silky broth enriched with cream and egg yolk, traditionally accompanied by crisp flatbread.";
"recipe.no_fiskesuppe.info.summary" = "Creamy fish soup";
"recipe.no_fiskesuppe.name" = "Fish soup";
"recipe.no_fiskesuppe.step1.body" = "Trim and peel the vegetables. Cut half of %i11 and %i12 into very small dice and cut the remaining carrot and celeriac into thin slices. Slice %i13 thinly. Cut %i14 and %i15 into bite-size pieces. Pick and chop %i17.";
"recipe.no_fiskesuppe.step1.title" = "Prepare the ingredients";
"recipe.no_fiskesuppe.step2.body" = "Melt %i1 in the pot over medium heat. Whisk in %i2 and cook briefly until smooth without browning.";
"recipe.no_fiskesuppe.step2.title" = "Start the broth";
"recipe.no_fiskesuppe.step3.body" = "Pour in %i3 little by little while whisking so the base stays smooth. Bring the soup gently to a simmer.";
"recipe.no_fiskesuppe.step3.title" = "Add the stock";
"recipe.no_fiskesuppe.step4.body" = "Add the small diced carrot and celeriac to the soup and let them simmer until tender and the broth has taken on their flavor.";
"recipe.no_fiskesuppe.step4.title" = "Cook the diced vegetables";
"recipe.no_fiskesuppe.step5.body" = "Lift out the cooked diced vegetables with a slotted spoon and set them aside. Add the sliced carrot, sliced celeriac, and leek to the soup and simmer until just tender.";
"recipe.no_fiskesuppe.step5.title" = "Finish the vegetable garnish";
"recipe.no_fiskesuppe.step6.body" = "Whisk %i5 with %i4 in the bowl. Stir in %i8, %i6, %i7, %i9, and %i10. Temper with a little hot soup, then stir the mixture back into the pot and heat gently without boiling.";
"recipe.no_fiskesuppe.step6.title" = "Enrich the soup";
"recipe.no_fiskesuppe.step7.body" = "Add the cod and salmon to the hot soup and let them cook gently until just done. Return the reserved diced vegetables to the pot and add %i16 to warm through.";
"recipe.no_fiskesuppe.step7.title" = "Poach the fish";
"recipe.no_fiskesuppe.step8.body" = "Taste and adjust the seasoning. Ladle the fiskesuppe into warm bowls, scatter over the dill, and serve immediately with %i18 on the side.";
"recipe.no_fiskesuppe.step8.title" = "Serve";
