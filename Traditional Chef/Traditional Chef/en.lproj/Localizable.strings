"recipe.pk_zarda.drink.body" = "A lightly sweet dessert wine such as Moscato can complement the aromatic sweet rice in small servings. Non-alcoholic pairing: chai or plain black tea is a traditional and excellent companion.";
"recipe.pk_zarda.drink.summary" = "Dessert wine";
"recipe.pk_zarda.info" = "Zarda is a traditional Pakistani festive sweet rice dish made with basmati rice, sugar, ghee, saffron or food color, cardamom, and nuts, often enriched with khoya and dried fruits. It is commonly served at weddings, Eid, and celebratory meals, either warm or at room temperature.";
"recipe.pk_zarda.info.summary" = "Sweet saffron rice";
"recipe.pk_zarda.name" = "Zarda";
"recipe.pk_zarda.step1.body" = "Rinse the %i1 until the water runs mostly clear, then soak it in %i2 so the grains cook evenly and stay long.";
"recipe.pk_zarda.step1.title" = "Soak rice";
"recipe.pk_zarda.step2.body" = "Slice the %i11 and %i12, and keep the %i13 and %i14 ready. Soak the %i8 in a little warm water. Lightly crush the %i6.";
"recipe.pk_zarda.step2.title" = "Prepare nuts and aromatics";
"recipe.pk_zarda.step3.body" = "Bring water to a boil in a large pot with %i3, cardamom, and %i7. Drain the soaked rice, add it to the pot, and boil until the grains are mostly cooked but still firm, then drain well.";
"recipe.pk_zarda.step3.title" = "Parboil rice";
"recipe.pk_zarda.step4.body" = "Heat the %i5 in a heavy pot or degchi over medium heat. Add the drained rice, %i4, soaked saffron, %i10, and %i9, then toss gently so the grains are coated without breaking.";
"recipe.pk_zarda.step4.title" = "Start zarda base";
"recipe.pk_zarda.step5.body" = "Add the almonds, pistachios, raisins, and cashews, mixing gently so they distribute through the rice.";
"recipe.pk_zarda.step5.title" = "Add nuts and dried fruit";
"recipe.pk_zarda.step6.body" = "Crumble the %i15 over the rice and scatter the %i16 on top. Cover tightly and reduce the heat to very low.";
"recipe.pk_zarda.step6.title" = "Prepare dum";
"recipe.pk_zarda.step7.body" = "Cook on very low heat until the sugar melts fully, the rice becomes glossy and sweet, and the grains finish steaming without turning mushy.";
"recipe.pk_zarda.step7.title" = "Cook on dum";
"recipe.pk_zarda.step8.body" = "Turn off the heat and let the zarda rest covered so the grains firm up and the aromas settle.";
"recipe.pk_zarda.step8.title" = "Rest zarda";
"recipe.pk_zarda.step9.body" = "Open the pot, fluff the zarda gently with a slotted spoon, and transfer to a serving dish. Serve warm or at room temperature.";
"recipe.pk_zarda.step9.title" = "Fluff and serve";
