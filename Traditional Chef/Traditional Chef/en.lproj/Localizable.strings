"recipe.mx_sopa_de_tortilla.step6.title" = "Fry tortilla strips";
"recipe.mx_sopa_de_tortilla.step7.body" = "Ladle hot soup into bowls and top with tortilla strips, avocado, queso fresco, %i12, cilantro, and a squeeze of lime.";
