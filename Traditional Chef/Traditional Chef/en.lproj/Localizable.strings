"recipe.my_asam_laksa.step10.title" = "Serve traditionally";
"recipe.my_asam_laksa.step2.body" = "Soak the %i7 until softened, then drain. Blend the %i6, dried chilies, %i8, %i9, %i10, %i11, and %i12 into a smooth rempah with a little %i5 so it moves well in the blender.";
"recipe.my_asam_laksa.step2.title" = "Blend spice paste";
"recipe.my_asam_laksa.step3.body" = "Bring water to a gentle boil in a large pot with the %i2 and %i3. Add the %i1 and cook until just done, then lift out the fish and keep the broth in the pot.";
"recipe.my_asam_laksa.step3.title" = "Poach fish for stock";
"recipe.my_asam_laksa.step4.body" = "When cool enough to handle, remove skin and bones from the mackerel and flake the flesh. Strain the broth and return it to the pot, keeping the fish flakes aside.";
"recipe.my_asam_laksa.step4.title" = "Flake fish and strain broth";
"recipe.my_asam_laksa.step5.body" = "Add the blended spice paste to the broth and stir well so it disperses evenly. Bring it back to a steady simmer and cook until the raw aroma fades.";
"recipe.my_asam_laksa.step5.title" = "Cook the rempah";
"recipe.my_asam_laksa.step6.body" = "Add the %i13, %i4, torch ginger, daun kesum, %i16, and %i17 to the pot. Simmer gently so the broth becomes sour, aromatic, and full-bodied.";
"recipe.my_asam_laksa.step6.title" = "Simmer laksa broth";
"recipe.my_asam_laksa.step7.body" = "Return the flaked fish to the broth and stir gently to keep some texture. Taste and balance the broth so it is distinctly sour, savory, and lightly sweet.";
"recipe.my_asam_laksa.step7.title" = "Finish with fish";
"recipe.my_asam_laksa.step8.body" = "Bring %i19 to a boil in a separate saucepan and cook the %i18 until tender. Drain and rinse briefly, then portion the noodles into serving bowls.";
"recipe.my_asam_laksa.step8.title" = "Prepare noodles";
"recipe.my_asam_laksa.step9.body" = "Ladle the hot asam laksa broth over the noodles. Top each bowl with cucumber, pineapple, onion, lettuce, mint, and chili.";
