"recipe.dk_stegt_flaesk_med_persillesovs.drink.body" = "A classic Danish pale lager is the traditional match for the salty pork and creamy parsley sauce. A crisp dry white wine also works well. For a non-alcoholic pairing, serve sparkling water or cold water with lemon.";
"recipe.dk_stegt_flaesk_med_persillesovs.drink.summary" = "Beer (Lager)";
"recipe.dk_stegt_flaesk_med_persillesovs.info" = "Stegt flæsk med persillesovs is the classic Danish national dish of crisp fried pork belly served with boiled potatoes and warm parsley sauce. It is an old rural comfort food and is traditionally eaten as a hearty family main course, especially for Sunday meals and classic Danish lunch or dinner tables.";
"recipe.dk_stegt_flaesk_med_persillesovs.info.summary" = "Danish national pork dish";
"recipe.dk_stegt_flaesk_med_persillesovs.name" = "Crispy pork belly";
"recipe.dk_stegt_flaesk_med_persillesovs.step1.body" = "Lay %i1 out evenly and season them with %i2 so the meat is lightly but thoroughly seasoned.";
"recipe.dk_stegt_flaesk_med_persillesovs.step1.title" = "Salt the pork";
"recipe.dk_stegt_flaesk_med_persillesovs.step2.body" = "Arrange the pork slices on the rack over the tray and roast until deeply golden and crisp, turning once so both sides color evenly and excess fat renders out.";
"recipe.dk_stegt_flaesk_med_persillesovs.step2.title" = "Roast the pork until crisp";
"recipe.dk_stegt_flaesk_med_persillesovs.step3.body" = "Peel %i3 if needed, place them in the pot, cover with %i4, and add %i5.";
"recipe.dk_stegt_flaesk_med_persillesovs.step3.title" = "Prepare the potatoes";
"recipe.dk_stegt_flaesk_med_persillesovs.step4.body" = "Cook the potatoes gently until tender. Reserve some of the cooking water for the sauce, then keep the potatoes warm.";
"recipe.dk_stegt_flaesk_med_persillesovs.step4.title" = "Boil the potatoes";
"recipe.dk_stegt_flaesk_med_persillesovs.step5.body" = "Melt %i6 in the saucepan, stir in %i7, and cook briefly until smooth without letting it brown.";
"recipe.dk_stegt_flaesk_med_persillesovs.step5.title" = "Start the parsley sauce";
"recipe.dk_stegt_flaesk_med_persillesovs.step6.body" = "Whisk in %i8 little by little, then whisk in %i9 and simmer gently until the sauce is smooth and lightly thickened.";
"recipe.dk_stegt_flaesk_med_persillesovs.step6.title" = "Cook the white sauce";
"recipe.dk_stegt_flaesk_med_persillesovs.step7.body" = "Finely chop %i10 and stir it into the sauce with %i11 and %i12. Heat gently until the parsley sauce is hot and fragrant.";
"recipe.dk_stegt_flaesk_med_persillesovs.step7.title" = "Finish the sauce";
"recipe.dk_stegt_flaesk_med_persillesovs.step8.body" = "Arrange the potatoes on warm plates, add the crisp pork belly, and spoon over the parsley sauce or serve it alongside immediately.";
"recipe.dk_stegt_flaesk_med_persillesovs.step8.title" = "Serve";
