"recipe.pt_bacalhau_com_natas.drink.body" = "A bright Portuguese white such as Arinto or a crisp Vinho Verde balances the creamy sauce and highlights the cod. If you prefer red, choose a light, low-tannin Portuguese red served slightly cool. Non-alcoholic pairing: sparkling water with lemon or a chilled alcohol-free pilsner.";
"recipe.pt_bacalhau_com_natas.drink.summary" = "White wine (Arinto)";
"recipe.pt_bacalhau_com_natas.info" = "Bacalhau com Natas is a beloved Portuguese oven bake of desalted salt cod and potatoes bound in a rich, silky cream sauce, typically built on softly cooked onions and garlic and finished with a lightly browned top. It is served hot as a hearty main course, often as a family-style dish straight from the baking dish.";
"recipe.pt_bacalhau_com_natas.info.summary" = "Creamy cod casserole";
"recipe.pt_bacalhau_com_natas.name" = "Creamed cod";
"recipe.pt_bacalhau_com_natas.step1.body" = "Rinse the %i1, then soak it in plenty of cold %i16 in the refrigerator, changing the water several times, until properly desalinated.";
"recipe.pt_bacalhau_com_natas.step1.title" = "Desalt the cod";
"recipe.pt_bacalhau_com_natas.step10.body" = "Let the dish rest briefly so it settles, then serve hot straight from the baking dish.";
"recipe.pt_bacalhau_com_natas.step10.title" = "Rest and serve";
"recipe.pt_bacalhau_com_natas.step2.body" = "Place the cod in a pot, cover with water, and gently simmer until it flakes easily. Drain, cool slightly, remove skin and bones, and flake into bite-size pieces.";
"recipe.pt_bacalhau_com_natas.step2.title" = "Poach and flake the cod";
"recipe.pt_bacalhau_com_natas.step3.body" = "Peel the %i2 and cut into small cubes. Rinse, drain, and dry thoroughly so they fry evenly.";
"recipe.pt_bacalhau_com_natas.step3.title" = "Cut the potatoes";
"recipe.pt_bacalhau_com_natas.step4.body" = "Heat %i3 and fry the potatoes in batches until pale golden and cooked through. Drain on paper towels and season lightly with %i13.";
"recipe.pt_bacalhau_com_natas.step4.title" = "Fry the potatoes";
"recipe.pt_bacalhau_com_natas.step5.body" = "Warm %i11 in a skillet over medium-low heat. Add %i4 and cook until very soft, then add %i5 and %i6 and cook until fragrant.";
"recipe.pt_bacalhau_com_natas.step5.title" = "Soften onions and garlic";
"recipe.pt_bacalhau_com_natas.step6.body" = "Add the flaked cod to the skillet and gently fold to coat and warm through, then remove the bay leaf.";
"recipe.pt_bacalhau_com_natas.step6.title" = "Combine onion and cod";
"recipe.pt_bacalhau_com_natas.step7.body" = "In a saucepan, melt %i7, stir in %i8, and cook briefly. Gradually whisk in %i9 until smooth, then simmer while stirring until thickened. Stir in %i10, season with %i14 and %i15, and adjust salt.";
"recipe.pt_bacalhau_com_natas.step7.title" = "Make the cream sauce";
"recipe.pt_bacalhau_com_natas.step8.body" = "Mix the cod-onion mixture with the fried potatoes, spread in a baking dish, and cover evenly with the cream sauce. Sprinkle %i12 over the top.";
"recipe.pt_bacalhau_com_natas.step8.title" = "Assemble the bake";
"recipe.pt_bacalhau_com_natas.step9.body" = "Bake until bubbling hot and the top is well browned and lightly crisp.";
"recipe.pt_bacalhau_com_natas.step9.title" = "Bake until browned";
