"recipe.it_fiori_di_zucca_fritti.drink.body" = "Pair with a dry, lively sparkling wine such as Prosecco or a crisp white like Verdicchio to cut through the fried batter. A light Italian lager also suits. For a non-alcoholic option, serve sparkling water with a squeeze of lemon.";
"recipe.it_fiori_di_zucca_fritti.drink.summary" = "Sparkling wine (Prosecco)";
"recipe.it_fiori_di_zucca_fritti.info" = "Fiori di zucca fritti are classic Italian fritters made from delicate zucchini blossoms coated in a light batter and fried until crisp and airy. They are served hot as an antipasto or aperitivo snack, simply seasoned and eaten immediately while the batter is still crackly and the blossoms are tender.";
"recipe.it_fiori_di_zucca_fritti.info.summary" = "Crisp zucchini blossoms";
"recipe.it_fiori_di_zucca_fritti.name" = "Fried zucchini blossoms";
"recipe.it_fiori_di_zucca_fritti.step1.body" = "Gently open each %i1, remove the pistil, and check for dirt or insects. Wipe them clean with a damp cloth and let them dry.";
"recipe.it_fiori_di_zucca_fritti.step1.title" = "Prepare the blossoms";
"recipe.it_fiori_di_zucca_fritti.step2.body" = "Pour %i5 into a deep pot and heat it to a frying temperature suitable for a light batter.";
"recipe.it_fiori_di_zucca_fritti.step2.title" = "Heat the oil";
"recipe.it_fiori_di_zucca_fritti.step3.body" = "Whisk %i2 and %i3 together, then whisk in %i4 until you have a smooth, pourable batter.";
"recipe.it_fiori_di_zucca_fritti.step3.title" = "Make the batter";
"recipe.it_fiori_di_zucca_fritti.step4.body" = "Dip each blossom into the batter, letting the excess drip back into the bowl.";
"recipe.it_fiori_di_zucca_fritti.step4.title" = "Coat the blossoms";
"recipe.it_fiori_di_zucca_fritti.step5.body" = "Fry the coated blossoms in batches until pale golden and crisp, turning as needed so they cook evenly.";
"recipe.it_fiori_di_zucca_fritti.step5.title" = "Fry the blossoms";
"recipe.it_fiori_di_zucca_fritti.step6.body" = "Lift them out with a slotted spoon and drain on paper towels.";
