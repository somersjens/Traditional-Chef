"recipe.pl_kaczka_z_jablkami.drink.body" = "Pair with a dry, elegant red such as Pinot Noir to complement the duck’s richness without overwhelming the apples and marjoram. A malty amber lager is also a natural fit with roast poultry and cabbage. Non-alcoholic option: hot black tea with lemon or sparkling water.";
"recipe.pl_kaczka_z_jablkami.drink.summary" = "Red wine (Pinot Noir)";
"recipe.pl_kaczka_z_jablkami.info" = "Kaczka z jabłkami is a classic Polish roast: a whole duck seasoned with marjoram and garlic, stuffed with tart apples, then slowly roasted until the meat is tender and the juices turn into a rich pan gravy. It is traditionally served hot with braised red cabbage with apple (modra kapusta) and boiled potatoes, making a hearty Sunday or holiday main.";
"recipe.pl_kaczka_z_jablkami.info.summary" = "Apple-stuffed roast duck";
"recipe.pl_kaczka_z_jablkami.name" = "Roast duck with apples";
"recipe.pl_kaczka_z_jablkami.step1.body" = "Trim excess loose fat, pat the %i1 dry, and score the skin lightly without cutting into the meat. Rub inside and out with %i2, %i3, and %i4, then rub in crushed %i5.";
"recipe.pl_kaczka_z_jablkami.step1.title" = "Prepare and season the duck";
"recipe.pl_kaczka_z_jablkami.step10.body" = "Peel and cut the %i21, cover with %i22, add %i23, and bring to a gentle boil.";
"recipe.pl_kaczka_z_jablkami.step10.title" = "Boil the potatoes";
"recipe.pl_kaczka_z_jablkami.step11.body" = "Simmer until the potatoes are tender, then drain well and keep warm.";
"recipe.pl_kaczka_z_jablkami.step11.title" = "Cook potatoes until tender";
"recipe.pl_kaczka_z_jablkami.step12.body" = "Carve the duck and serve with apple stuffing, pan gravy, braised red cabbage, and boiled potatoes.";
"recipe.pl_kaczka_z_jablkami.step12.title" = "Carve and serve";
"recipe.pl_kaczka_z_jablkami.step2.body" = "Cover and refrigerate so the seasoning perfumes the meat and skin.";
"recipe.pl_kaczka_z_jablkami.step2.title" = "Chill to marinate";
"recipe.pl_kaczka_z_jablkami.step3.body" = "Core the %i6 and cut into wedges. Slice the %i7 and mix with the apples, then pack the cavity and tie the duck closed with kitchen twine.";
"recipe.pl_kaczka_z_jablkami.step3.title" = "Stuff with apples";
"recipe.pl_kaczka_z_jablkami.step4.body" = "Place the duck breast-side up in a roasting pan and roast hot to begin browning and rendering fat.";
"recipe.pl_kaczka_z_jablkami.step4.title" = "Start roasting for color";
"recipe.pl_kaczka_z_jablkami.step5.body" = "Lower the oven temperature and continue roasting, basting occasionally with rendered fat and pan juices until the meat is very tender.";
"recipe.pl_kaczka_z_jablkami.step5.title" = "Roast slowly until tender";
"recipe.pl_kaczka_z_jablkami.step6.body" = "Transfer the duck to a board, tent loosely, and let it rest so the juices redistribute. Keep the pan with drippings for gravy.";
"recipe.pl_kaczka_z_jablkami.step6.title" = "Rest the duck";
"recipe.pl_kaczka_z_jablkami.step7.body" = "Pour off excess fat, leaving the flavorful brown bits. Whisk %i8 into the remaining drippings, cook briefly, then whisk in %i9 and simmer until smooth and lightly thickened.";
"recipe.pl_kaczka_z_jablkami.step7.title" = "Make the pan gravy";
"recipe.pl_kaczka_z_jablkami.step8.body" = "Shred the %i10, slice the %i11, and cut the %i12. Melt %i13 in a saucepan, cook the onion until softened, then add cabbage and stir until it begins to wilt.";
"recipe.pl_kaczka_z_jablkami.step8.title" = "Start the braised red cabbage";
"recipe.pl_kaczka_z_jablkami.step9.body" = "Add %i14, %i19, and %i20, cover, and braise until tender. Stir in apples, then season with %i15, %i16, %i17, and %i18 and simmer until the flavors balance.";
"recipe.pl_kaczka_z_jablkami.step9.title" = "Braise and season the cabbage";
