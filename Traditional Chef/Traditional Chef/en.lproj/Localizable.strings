"recipe.it_bruschetta_al_pomodoro.drink.body" = "Pair with a crisp dry Italian white such as Vermentino or a light-bodied rosé to match the fresh tomato and olive oil. Non-alcoholic option: sparkling water with lemon or an unsweetened iced tea.";
"recipe.it_bruschetta_al_pomodoro.drink.summary" = "White wine (Vermentino)";
"recipe.it_bruschetta_al_pomodoro.info" = "A traditional Italian antipasto of grilled or toasted rustic bread rubbed with garlic and topped with chopped ripe tomatoes dressed with extra-virgin olive oil, basil, salt, and pepper. Served immediately while the bread is crisp and warm, it is a classic start to a meal, especially in summer when tomatoes are sweetest.";
"recipe.it_bruschetta_al_pomodoro.info.summary" = "Summer antipasto toast";
"recipe.it_bruschetta_al_pomodoro.name" = "Tomato bruschetta";
"recipe.it_bruschetta_al_pomodoro.step1.body" = "Dice the %i2 and place them in a bowl. Tear %i4 and add it to the tomatoes.";
"recipe.it_bruschetta_al_pomodoro.step1.title" = "Prepare the tomatoes";
