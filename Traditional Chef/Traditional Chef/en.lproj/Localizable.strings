"recipe.bg_gyuvech.drink.body" = "A medium-bodied red wine such as Mavrud or Merlot pairs well with the pork, sweet vegetables, and long-baked sauce. For a non-alcoholic pairing, serve ayran or sparkling water.";
"recipe.bg_gyuvech.drink.summary" = "Red wine (Mavrud)";
"recipe.bg_gyuvech.info" = "Gyuvech is a traditional Bulgarian baked stew of pork and seasonal vegetables such as potatoes, eggplant, peppers, tomatoes, zucchini, okra, green beans, peas, onion, and garlic, slowly cooked in an earthenware pot. It is a classic family main dish, especially in late summer and autumn, and is traditionally served hot with bread for the rich juices.";
"recipe.bg_gyuvech.info.summary" = "Earthenware vegetable stew";
"recipe.bg_gyuvech.name" = "Gyuvech";
