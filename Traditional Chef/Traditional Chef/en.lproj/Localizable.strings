"recipe.ru_medovik.drink.body" = "A lightly sweet dessert wine or late-harvest white complements the honey and caramel notes, while black tea is the traditional accompaniment. Non-alcoholic pairing: strong black tea with lemon or a lightly sweet herbal tea.";
"recipe.ru_medovik.drink.summary" = "Dessert wine";
"recipe.ru_medovik.info" = "Medovik is a classic Russian honey layer cake made from thin honey-butter cake layers baked quickly and stacked with a tangy sour-cream cream that softens the layers into a tender cake as it rests. Traditionally the cake is assembled with crumbs pressed onto the sides and top, then chilled overnight so the texture becomes sliceable and moist.";
"recipe.ru_medovik.info.summary" = "Honey layer cake";
"recipe.ru_medovik.name" = "Medovik";
"recipe.ru_medovik.step1.body" = "Preheat the oven and line baking sheets with parchment. Prepare a template for cutting even cake rounds.";
"recipe.ru_medovik.step1.title" = "Prep and preheat";
"recipe.ru_medovik.step10.body" = "Refrigerate the cake until the layers soften and the cake is fully set for clean slicing.";
"recipe.ru_medovik.step10.title" = "Chill and set";
"recipe.ru_medovik.step2.body" = "Warm %i1, %i2, and %i3 gently until melted and hot. Stir in %i5 and cook briefly until the mixture foams and turns a deeper caramel color.";
"recipe.ru_medovik.step2.title" = "Cook honey base";
"recipe.ru_medovik.step3.body" = "Cool the honey mixture slightly, then whisk in %i4 so they incorporate smoothly without scrambling.";
"recipe.ru_medovik.step3.title" = "Add eggs";
"recipe.ru_medovik.step4.body" = "Stir in %i6 and %i7 until a soft dough forms.";
"recipe.ru_medovik.step4.title" = "Make the dough";
"recipe.ru_medovik.step5.body" = "Divide the dough into equal portions. Roll each portion thinly on parchment into a round.";
"recipe.ru_medovik.step5.title" = "Portion and roll";
"recipe.ru_medovik.step6.body" = "Bake each layer until set and lightly golden, then cool on a rack.";
"recipe.ru_medovik.step6.title" = "Bake layers";
"recipe.ru_medovik.step7.body" = "Trim the baked layers to even rounds while still warm. Collect the trimmings and crumble finely.";
"recipe.ru_medovik.step7.title" = "Trim and crumb";
"recipe.ru_medovik.step8.body" = "Whisk %i8 with %i9 until smooth.";
"recipe.ru_medovik.step8.title" = "Make the cream";
"recipe.ru_medovik.step9.body" = "Stack the layers with cream spread between each one. Coat the top and sides with cream, then press crumbs over the cake.";
"recipe.ru_medovik.step9.title" = "Assemble";
