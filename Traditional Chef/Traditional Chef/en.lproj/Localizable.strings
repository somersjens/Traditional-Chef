"recipe.ru_napoleon_tort.drink.body" = "A lightly sweet dessert wine pairs well with the vanilla custard and buttery pastry, while sparkling wine also works for celebrations. Non-alcoholic pairing: strong black tea with lemon or a mild coffee.";
"recipe.ru_napoleon_tort.drink.summary" = "Dessert wine";
"recipe.ru_napoleon_tort.info" = "Russian Napoleon Cake is a classic layered dessert of many thin, flaky baked pastry sheets stacked with rich vanilla custard cream, then covered in fine pastry crumbs and rested so the layers soften into a tender, sliceable cake. It is traditionally served chilled, often with tea, with a delicate balance of crisp flakes and creamy filling.";
"recipe.ru_napoleon_tort.info.summary" = "Custard-layered pastry cake";
"recipe.ru_napoleon_tort.name" = "Napoleon cake";
"recipe.ru_napoleon_tort.step1.body" = "Combine %i1 and %i5, then cut in cold %i2 until crumbly. Mix in %i3 and %i4 and bring together into a soft dough without overworking.";
"recipe.ru_napoleon_tort.step1.title" = "Make the dough";
"recipe.ru_napoleon_tort.step10.body" = "Refrigerate until the layers soften and the cake slices cleanly.";
"recipe.ru_napoleon_tort.step10.title" = "Chill to set";
"recipe.ru_napoleon_tort.step2.body" = "Wrap the dough and refrigerate until firm enough to roll thinly.";
"recipe.ru_napoleon_tort.step2.title" = "Chill the dough";
"recipe.ru_napoleon_tort.step3.body" = "Preheat the oven and line baking sheets with parchment. Portion the dough into equal pieces for multiple thin layers.";
"recipe.ru_napoleon_tort.step3.title" = "Prepare for baking";
"recipe.ru_napoleon_tort.step4.body" = "Roll one portion very thin into a round or rectangle. Transfer to a baking sheet and dock all over with a fork so it bakes flat. Repeat with remaining portions.";
"recipe.ru_napoleon_tort.step4.title" = "Roll and dock layers";
"recipe.ru_napoleon_tort.step5.body" = "Bake the pastry sheets until evenly golden and crisp, rotating trays as needed. Cool completely on a rack.";
"recipe.ru_napoleon_tort.step5.title" = "Bake the layers";
"recipe.ru_napoleon_tort.step6.body" = "Heat %i6 until steaming. Whisk %i7, %i8, and %i9, then whisk in the hot milk gradually. Return to the saucepan and cook while whisking until thick and smooth.";
"recipe.ru_napoleon_tort.step6.title" = "Cook the custard base";
"recipe.ru_napoleon_tort.step7.body" = "Strain the custard for smoothness, then stir in %i10 until fully melted and glossy. Stir in %i11 and cool until warm but spreadable.";
"recipe.ru_napoleon_tort.step7.title" = "Finish the cream";
"recipe.ru_napoleon_tort.step8.body" = "Crumble one baked layer or trimmed edges into fine crumbs for coating the cake.";
"recipe.ru_napoleon_tort.step8.title" = "Make crumbs";
"recipe.ru_napoleon_tort.step9.body" = "Stack the pastry layers, spreading custard cream between each one. Coat the top and sides with a thin layer of cream and press crumbs over to cover.";
"recipe.ru_napoleon_tort.step9.title" = "Assemble the cake";
