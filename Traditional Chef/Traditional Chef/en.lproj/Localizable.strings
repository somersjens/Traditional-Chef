"recipe.bd_bhuna_khichuri.drink.body" = "An off-dry Riesling or aromatic white balances the warm spices and the richness from ghee. If you prefer red, choose a light-bodied, low-tannin red served slightly chilled. Non-alcoholic pairing: hot milk tea or chilled lemon soda.";
"recipe.bd_bhuna_khichuri.drink.summary" = "White wine (Riesling)";
"recipe.bd_bhuna_khichuri.info" = "Bhuna khichuri is a beloved Bangladeshi comfort dish where fragrant rice and moong dal are cooked together after the spices and onions are thoroughly fried (bhuna) so the grains take on a deeper colour and roasted aroma. Potatoes simmer in the pot and the texture is kept hearty rather than soupy. It is traditionally served hot with a simple egg omelette and a spoon of mango pickle on the side.";
"recipe.bd_bhuna_khichuri.info.summary" = "Bhuna rice and lentils";
"recipe.bd_bhuna_khichuri.name" = "Bhuna khichuri";
"recipe.bd_bhuna_khichuri.step1.body" = "Peel and cut the %i17 into chunks. Slice the %i3, mince the %i5, grate the %i4, and slit the %i6. Rinse the %i1 and %i2 until the water runs mostly clear.";
"recipe.bd_bhuna_khichuri.step1.title" = "Prep and rinse";
"recipe.bd_bhuna_khichuri.step2.body" = "Heat the pot and dry-toast the moong dal, stirring, until lightly fragrant and just turning pale golden, then tip it back into the bowl.";
"recipe.bd_bhuna_khichuri.step2.title" = "Toast the dal";
