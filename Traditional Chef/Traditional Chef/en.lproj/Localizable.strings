"recipe.az_dovga.drink.summary" = "White wine (Sauvignon)";
"recipe.az_dovga.info" = "Dovga is a classic Azerbaijani yogurt and herb soup made with rice, chickpeas, and a large amount of fresh green herbs. It is served warm in cooler weather or chilled after rich meals and festive gatherings, and is one of the most traditional soups in Azerbaijani home cooking.";
"recipe.az_dovga.info.summary" = "Yogurt herb soup";
"recipe.az_dovga.name" = "Dovga";
"recipe.az_dovga.step1.body" = "Wash %i8, %i9, %i10, %i11, and %i12 very well, then drain and chop them finely.";
"recipe.az_dovga.step1.title" = "Prepare the herbs";
"recipe.az_dovga.step2.body" = "Whisk %i1, %i2, and %i3 in a heavy saucepan until completely smooth.";
"recipe.az_dovga.step2.title" = "Make the yogurt base";
"recipe.az_dovga.step3.body" = "Gradually whisk in %i6, then add %i4 and %i7 and place the pan over low heat.";
"recipe.az_dovga.step3.title" = "Add the liquid and rice";
"recipe.az_dovga.step4.body" = "Cook the mixture slowly, stirring constantly so the yogurt does not split, until it reaches a gentle simmer and begins to thicken slightly.";
"recipe.az_dovga.step4.title" = "Stir until stable";
"recipe.az_dovga.step5.body" = "Keep the soup at a gentle simmer until the rice is nearly tender.";
"recipe.az_dovga.step5.title" = "Cook the rice";
"recipe.az_dovga.step6.body" = "Stir in %i5, cilantro, dill, mint, spinach, and spring onions and mix well.";
"recipe.az_dovga.step6.title" = "Add chickpeas and herbs";
"recipe.az_dovga.step7.body" = "Simmer gently until the herbs soften and the rice is fully cooked, stirring often to keep the soup smooth and even.";
"recipe.az_dovga.step7.title" = "Finish the dovga";
"recipe.az_dovga.step8.body" = "Remove the pan from the heat and let the dovga settle so the texture becomes calm and uniform.";
"recipe.az_dovga.step8.title" = "Cool slightly";
"recipe.az_dovga.step9.body" = "Serve the dovga warm or chilled in deep bowls with %i13 alongside.";
"recipe.az_dovga.step9.title" = "Serve the soup";
