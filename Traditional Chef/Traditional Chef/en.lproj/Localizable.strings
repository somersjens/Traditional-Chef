"recipe.az_kufta_bozbash.drink.body" = "A light red wine such as Pinot Noir or a dry rosé pairs well with the rich lamb and gentle saffron broth. A pale lager also works. For a non-alcoholic pairing, serve black tea or hot mint tea.";
"recipe.az_kufta_bozbash.drink.summary" = "Red wine (Pinot Noir)";
"recipe.az_kufta_bozbash.info" = "Kufta bozbash is a traditional Azerbaijani soup built around large lamb meatballs simmered with chickpeas and potatoes in a saffron-scented broth. Each meatball is classically filled with a sour dried plum, and the dish is served hot as a hearty family meal, especially in cooler weather.";
"recipe.az_kufta_bozbash.info.summary" = "Large meatball soup";
"recipe.az_kufta_bozbash.name" = "Kufta bozbash";
