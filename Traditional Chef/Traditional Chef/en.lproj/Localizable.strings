"recipe.kh_fish_amok.drink.body" = "An aromatic white wine such as Riesling or Gewurztraminer pairs well with the fragrant kroeung and rich coconut curry. A light lager also works well. For a non-alcoholic option, serve hot jasmine tea or chilled lime water.";
"recipe.kh_fish_amok.drink.summary" = "White wine (Riesling)";
"recipe.kh_fish_amok.info" = "Fish amok is a traditional Cambodian fish curry custard made with kroeung, coconut milk, egg, and white fish, steamed in banana-leaf cups until softly set. It is served hot with steamed rice and is a classic celebratory and restaurant dish across Cambodia.";
"recipe.kh_fish_amok.info.summary" = "Steamed fish curry";
"recipe.kh_fish_amok.name" = "Fish amok";
"recipe.kh_fish_amok.step1.body" = "Trim the %i1 and slice the tender parts. Peel and slice the %i2, %i3, %i4, and %i5. Remove the tough stems from the %i6 and slice part of them finely for the paste and the rest for garnish. Slice the %i7.";
"recipe.kh_fish_amok.step1.title" = "Prepare aromatics";
"recipe.kh_fish_amok.step10.body" = "Turn off the heat and let the covered rice rest, then fluff before serving.";
"recipe.kh_fish_amok.step10.title" = "Rest rice";
"recipe.kh_fish_amok.step11.body" = "Serve the hot fish amok in the banana leaf cups with steamed rice on the side.";
"recipe.kh_fish_amok.step11.title" = "Serve";
"recipe.kh_fish_amok.step2.body" = "Pound the lemongrass, galangal, turmeric, shallots, garlic, sliced makrut lime leaves, and chili into a fine yellow kroeung paste.";
"recipe.kh_fish_amok.step2.title" = "Pound yellow kroeung";
"recipe.kh_fish_amok.step3.body" = "Cut the %i8 into bite-size pieces. Wipe and soften the %i17 over gentle heat so they can be folded, then shape them into cups. Rinse and prepare the %i15.";
"recipe.kh_fish_amok.step3.title" = "Prepare fish and leaves";
"recipe.kh_fish_amok.step4.body" = "In a mixing bowl, combine the kroeung paste with %i9, %i10, %i11, %i12, %i13, and %i14 until smooth.";
"recipe.kh_fish_amok.step4.title" = "Mix amok custard base";
"recipe.kh_fish_amok.step5.body" = "Add the fish pieces to the custard base and mix gently so the fish is evenly coated.";
