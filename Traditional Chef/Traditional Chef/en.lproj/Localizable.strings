"recipe.mu_napolitaine.drink.summary" = "Sparkling wine (Moscato)";
"recipe.mu_napolitaine.info" = "Mauritian napolitaine are tender shortbread-style biscuits baked until pale and crisp, then sandwiched with jam and finished with a glossy pink icing and a coating of desiccated coconut. They are a staple of Mauritian pâtisserie and home baking, most often served at tea time and for celebrations, cut as neat rounds and eaten once the icing has set.";
"recipe.mu_napolitaine.info.summary" = "Pink iced biscuits";
"recipe.mu_napolitaine.name" = "Napolitaine";
