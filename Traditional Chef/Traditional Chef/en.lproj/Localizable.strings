"recipe.us_la_jambalaya.drink.body" = "A medium-bodied Côtes du Rhône or a crisp lager works with smoky andouille and savory rice without overpowering the spices. For a non-alcoholic option, serve iced tea or sparkling water with lemon to keep the meal refreshing.";
"recipe.us_la_jambalaya.drink.summary" = "Red wine (Côtes du Rhône)";
"recipe.us_la_jambalaya.info" = "Louisiana jambalaya is a classic one-pot rice dish with deep roots in Cajun and Creole cooking, built by browning meats, cooking the trinity of onion, celery, and bell pepper, and simmering everything together with rice until richly seasoned and cohesive. This traditional version uses chicken and andouille, with shrimp added near the end so it stays tender, creating a hearty, smoky, savory pot meant for gatherings. Served hot straight from the pot, it’s comfort food with big flavor.";
"recipe.us_la_jambalaya.info.summary" = "One-pot jambalaya";
"recipe.us_la_jambalaya.name" = "Jambalaya";
"recipe.us_la_jambalaya.step1.body" = "Heat %i4 in the pot and brown %i2, then brown %i1 well, building flavor on the bottom of the pot. Transfer browned meats within the pot as needed so nothing burns.";
"recipe.us_la_jambalaya.step1.title" = "Brown the meats";
"recipe.us_la_jambalaya.step2.body" = "Add %i5, %i6, and %i7 and cook until softened, scraping up browned bits so they dissolve into the base.";
"recipe.us_la_jambalaya.step2.title" = "Cook the trinity";
"recipe.us_la_jambalaya.step3.body" = "Stir in %i8, %i12, %i13, %i14, and %i15 until fragrant.";
"recipe.us_la_jambalaya.step3.title" = "Add garlic and spices";
"recipe.us_la_jambalaya.step4.body" = "Stir in %i9, then add %i10 and %i16 and bring to a strong simmer.";
"recipe.us_la_jambalaya.step4.title" = "Build the pot";
"recipe.us_la_jambalaya.step5.body" = "Stir in %i11 and andouille, return to a simmer, then cover and reduce heat to low so the rice cooks gently without scorching.";
"recipe.us_la_jambalaya.step5.title" = "Add rice and settle";
"recipe.us_la_jambalaya.step6.body" = "Keep covered and cook until the rice has absorbed liquid and is nearly tender, avoiding frequent stirring so the grains stay intact.";
"recipe.us_la_jambalaya.step6.title" = "Cook until rice is tender";
"recipe.us_la_jambalaya.step7.body" = "Scatter %i3 over the top, cover again, and cook until the shrimp are just cooked through and tender.";
"recipe.us_la_jambalaya.step7.title" = "Steam with shrimp";
"recipe.us_la_jambalaya.step8.body" = "Remove bay leaves, fold in %i17 and %i18, then rest briefly so the rice sets up, and serve hot straight from the pot.";
"recipe.us_la_jambalaya.step8.title" = "Finish and serve";
