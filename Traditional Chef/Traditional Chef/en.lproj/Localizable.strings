"recipe.tn_pasta_makrouna.drink.body" = "A fruit-forward red such as Grenache stands up to harissa heat and tomato richness. For a non-alcoholic option, serve hot Tunisian mint tea or sparkling water with lemon.";
"recipe.tn_pasta_makrouna.drink.summary" = "Red wine (Grenache)";
"recipe.tn_pasta_makrouna.info" = "Makrouna Tunisienne is a traditional Tunisian pasta dish where macaroni is coated in a rich tomato-harissa sauce simmered with spices and tender beef, then finished with a drizzle of olive oil and served hot as a comforting everyday meal.";
"recipe.tn_pasta_makrouna.info.summary" = "Tunisian spicy pasta";
"recipe.tn_pasta_makrouna.name" = "Makrouna";
"recipe.tn_pasta_makrouna.step1.body" = "Chop the %i4 and crush the %i5. Cut the %i2 into small, even pieces if needed.";
"recipe.tn_pasta_makrouna.step1.title" = "Prep the aromatics";
"recipe.tn_pasta_makrouna.step2.body" = "Heat %i3 in a large pot and brown the beef well, then add onion and cook until softened.";
"recipe.tn_pasta_makrouna.step2.title" = "Brown the beef";
"recipe.tn_pasta_makrouna.step3.body" = "Add garlic, stir briefly until fragrant, then stir in %i7, %i8, %i9, %i10, and %i11 to bloom in the hot oil.";
"recipe.tn_pasta_makrouna.step3.title" = "Bloom garlic and spices";
"recipe.tn_pasta_makrouna.step4.body" = "Stir in %i6 and cook until it darkens slightly and smells less raw.";
"recipe.tn_pasta_makrouna.step4.title" = "Cook the tomato paste";
"recipe.tn_pasta_makrouna.step5.body" = "Add %i14, bring to a steady simmer, season with %i12 and %i13, and stir so the sauce is smooth.";
"recipe.tn_pasta_makrouna.step5.title" = "Build the sauce";
"recipe.tn_pasta_makrouna.step6.body" = "Cover and simmer until the beef is tender and the sauce is rich, stirring occasionally so it does not stick.";
"recipe.tn_pasta_makrouna.step6.title" = "Simmer until tender";
"recipe.tn_pasta_makrouna.step7.body" = "Add the %i1 to the simmering pot and cook, stirring often and adding a little water if needed, until the pasta is tender and coated in thick sauce.";
"recipe.tn_pasta_makrouna.step7.title" = "Cook the pasta in the sauce";
"recipe.tn_pasta_makrouna.step8.body" = "Turn off the heat, cover briefly so the sauce settles, then stir and serve hot.";
"recipe.tn_pasta_makrouna.step8.title" = "Rest and serve";
