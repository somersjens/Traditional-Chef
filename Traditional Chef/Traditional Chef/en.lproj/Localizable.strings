"recipe.sk_sulance_s_makom.drink.body" = "A lightly sweet dessert wine pairs well with the nutty poppy seeds and buttery potato dumplings. A dry sparkling wine also works well. For a non-alcoholic option, serve black tea or warm milk.";
"recipe.sk_sulance_s_makom.drink.summary" = "Dessert wine";
"recipe.sk_sulance_s_makom.info" = "Sulance s Makom is a traditional Slovak sweet dish of soft potato dumplings rolled by hand, then coated with ground poppy seeds, sugar, and melted butter. It is served hot as a simple home dessert or sweet main meal, especially in colder months and during family cooking.";
"recipe.sk_sulance_s_makom.info.summary" = "Poppy potato dumplings";
"recipe.sk_sulance_s_makom.name" = "Poppy seed noodles";
"recipe.sk_sulance_s_makom.step1.body" = "Boil %i1 in %i4 until fully tender, then drain them well and let them cool enough to handle.";
"recipe.sk_sulance_s_makom.step1.title" = "Cook the potatoes";
"recipe.sk_sulance_s_makom.step2.body" = "Mash %i1 until smooth, then mix them with %i2 and part of %i3 to form a soft dough.";
"recipe.sk_sulance_s_makom.step2.title" = "Make the dough";
"recipe.sk_sulance_s_makom.step3.body" = "Divide the dough into pieces, roll each piece into ropes, and cut and roll them into short finger-shaped dumplings.";
"recipe.sk_sulance_s_makom.step3.title" = "Shape the sulance";
"recipe.sk_sulance_s_makom.step4.body" = "Bring %i4 to a boil, season it with the remaining salt, and cook the sulance until they float and are tender.";
"recipe.sk_sulance_s_makom.step4.title" = "Boil the dumplings";
"recipe.sk_sulance_s_makom.step5.body" = "Mix the ground %i5 with the powdered %i6 and melt %i7 until fully liquid.";
"recipe.sk_sulance_s_makom.step5.title" = "Prepare the topping";
"recipe.sk_sulance_s_makom.step6.body" = "Drain the hot sulance, coat them with melted %i7, then toss them with the poppy seed and sugar mixture until evenly covered.";
"recipe.sk_sulance_s_makom.step6.title" = "Finish the dish";
"recipe.sk_sulance_s_makom.step7.body" = "Serve the sulance s makom hot, with the buttery poppy seed coating evenly distributed over each portion.";
"recipe.sk_sulance_s_makom.step7.title" = "Serve traditionally";
