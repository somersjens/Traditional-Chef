"recipe.es_salmorejo.drink.body" = "Pair with a crisp Spanish white such as Verdejo or a mineral Albariño to balance the tomato richness and olive oil. A dry Cava also works well with the chilled, savory starter. Non-alcoholic option: sparkling water with lemon.";
"recipe.es_salmorejo.drink.summary" = "White wine (Verdejo)";
"recipe.es_salmorejo.info" = "Salmorejo is a traditional Córdoba cold tomato cream made by blending ripe tomatoes with stale bread, garlic, olive oil, sherry vinegar, and salt into a thick, silky emulsion. It is served very cold and traditionally topped with chopped hard-boiled egg and diced jamón serrano, a classic summer starter in Andalusia, eaten with a spoon rather than drunk.";
"recipe.es_salmorejo.info.summary" = "Córdoba cold tomato cream";
"recipe.es_salmorejo.name" = "Salmorejo";
"recipe.es_salmorejo.step1.body" = "Wash and roughly chop %i1. Tear %i2 into pieces so it hydrates quickly.";
"recipe.es_salmorejo.step1.title" = "Prep tomatoes and bread";
"recipe.es_salmorejo.step2.body" = "Blend tomatoes with %i3 and bread until very smooth and thick.";
"recipe.es_salmorejo.step2.title" = "Blend until smooth";
"recipe.es_salmorejo.step3.body" = "With the blender running, add %i4 in a steady stream until the mixture turns glossy and creamy. Season with %i5 and %i6 and blend again.";
"recipe.es_salmorejo.step3.title" = "Emulsify with olive oil";
"recipe.es_salmorejo.step4.body" = "Boil %i7 until hard, cool them, peel, and chop finely.";
"recipe.es_salmorejo.step4.title" = "Boil the eggs";
"recipe.es_salmorejo.step5.body" = "Refrigerate the salmorejo until very cold and the texture is fully set.";
"recipe.es_salmorejo.step5.title" = "Chill thoroughly";
"recipe.es_salmorejo.step6.body" = "Serve cold in bowls and top with chopped egg and %i8.";
"recipe.es_salmorejo.step6.title" = "Serve with toppings";
