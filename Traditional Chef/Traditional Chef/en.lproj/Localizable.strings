"recipe.tr_sekerpare.info" = "Şekerpare is a traditional Turkish syrup dessert of soft semolina-enriched cookies, typically topped with an almond, baked until lightly golden, then soaked in lemon-scented sugar syrup. It is served at room temperature with tea, known for its tender crumb and glossy syrup finish.";
"recipe.tr_sekerpare.info.summary" = "Almond syrup cookies";
"recipe.tr_sekerpare.name" = "Şekerpare";
"recipe.tr_sekerpare.step1.body" = "Combine %i1 and %i2, bring to a boil, then simmer until lightly thickened. Add %i3 and let the syrup cool.";
"recipe.tr_sekerpare.step1.title" = "Make the syrup";
"recipe.tr_sekerpare.step2.body" = "Cream %i4 with %i5, then mix in %i6 until smooth.";
"recipe.tr_sekerpare.step2.title" = "Make the dough";
"recipe.tr_sekerpare.step3.body" = "Mix in %i7, %i8, and %i9 until a soft, cohesive dough forms.";
"recipe.tr_sekerpare.step3.title" = "Add dry ingredients";
"recipe.tr_sekerpare.step4.body" = "Shape the dough into small oval cookies, arrange on a tray, score the tops, and press %i10 onto each.";
"recipe.tr_sekerpare.step4.title" = "Shape and top";
"recipe.tr_sekerpare.step5.body" = "Bake until the cookies are set and lightly golden.";
"recipe.tr_sekerpare.step5.title" = "Bake";
"recipe.tr_sekerpare.step6.body" = "Pour the cooled syrup over the hot cookies so they absorb evenly.";
"recipe.tr_sekerpare.step6.title" = "Soak with syrup";
"recipe.tr_sekerpare.step7.body" = "Let the şekerpare rest until fully soaked and glossy.";
"recipe.tr_sekerpare.step7.title" = "Rest to set";
"recipe.tr_sekerpare.step8.body" = "Serve at room temperature.";
"recipe.tr_sekerpare.step8.title" = "Serve";
