"recipe.az_dushbara.drink.body" = "A crisp dry white wine such as Sauvignon Blanc or an unoaked Chardonnay pairs well with the delicate broth and lamb filling. A light lager also works. For a non-alcoholic pairing, serve black tea or hot mint tea.";
"recipe.az_dushbara.drink.summary" = "White wine (Sauvignon)";
"recipe.az_dushbara.info" = "Dushbara is a classic Azerbaijani soup of very small lamb-filled dumplings cooked in a clear lamb broth and served hot with dried mint and garlic vinegar. It is a traditional home dish associated with skilled handwork, family meals, and cold-weather service, with the dumplings made notably tiny in the classic style.";
"recipe.az_dushbara.info.summary" = "Mini dumpling soup";
"recipe.az_dushbara.name" = "Dushbara";
"recipe.az_dushbara.step1.body" = "Place %i1 and %i2 in a pot with %i5, bring to a boil, skim carefully, then add %i3 and %i4 and simmer until the broth is fragrant and the meat is tender.";
"recipe.az_dushbara.step1.title" = "Make the broth";
"recipe.az_dushbara.step2.body" = "Mix %i6, %i7, %i8, and %i9 into a firm smooth dough, then knead until elastic and let it rest covered.";
"recipe.az_dushbara.step2.title" = "Prepare the dough";
"recipe.az_dushbara.step3.body" = "Mix %i10 with very finely grated %i11, %i12, and %i13 until evenly combined.";
"recipe.az_dushbara.step3.title" = "Make the filling";
"recipe.az_dushbara.step4.body" = "Roll the dough very thin, cut it into small squares, place a tiny bit of filling in each piece, and seal into very small dumplings in the traditional shape.";
"recipe.az_dushbara.step4.title" = "Roll and shape the dumplings";
"recipe.az_dushbara.step5.body" = "Remove the meat and onion from the broth and strain the liquid so it stays clear for the soup.";
"recipe.az_dushbara.step5.title" = "Strain the broth";
"recipe.az_dushbara.step6.body" = "Bring the clear broth back to a gentle boil and add the dumplings. Cook until they rise and the filling is fully done.";
"recipe.az_dushbara.step6.title" = "Cook the dushbara";
"recipe.az_dushbara.step7.body" = "Crush %i16 and stir it into %i15 so it becomes sharp and aromatic for serving.";
"recipe.az_dushbara.step7.title" = "Prepare the garlic vinegar";
"recipe.az_dushbara.step8.body" = "Ladle the hot broth and dumplings into bowls and scatter %i14 over the top.";
"recipe.az_dushbara.step8.title" = "Finish the soup";
"recipe.az_dushbara.step9.body" = "Serve immediately with the garlic vinegar alongside so it can be added at the table in the traditional way.";
"recipe.az_dushbara.step9.title" = "Serve the dushbara";
