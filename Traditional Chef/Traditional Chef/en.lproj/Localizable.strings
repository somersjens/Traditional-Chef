"recipe.tt_cassava_pone.drink.body" = "A lightly sweet Moscato or late-harvest white complements the warm spices and caramel notes without overpowering the cassava. If you prefer beer, a smooth stout works well. For a non-alcoholic option, serve ginger beer or iced black tea with lime.";
"recipe.tt_cassava_pone.drink.summary" = "Dessert wine (Moscato)";
"recipe.tt_cassava_pone.info" = "Cassava pone is a classic Trinidad and Tobago baked dessert made from finely grated cassava and coconut, enriched with milk, butter, eggs, and warm spices, then baked until a chewy, pudding-like interior forms with a browned crust. It’s commonly cut into squares for gatherings, bakeries, and family Sundays, enjoyed at room temperature with tea or a cool drink.";
"recipe.tt_cassava_pone.info.summary" = "Cassava coconut bake";
"recipe.tt_cassava_pone.name" = "Cassava pone";
"recipe.tt_cassava_pone.step1.body" = "Preheat the oven and lightly grease the baking pan with a little of the %i12 so the pone releases cleanly.";
"recipe.tt_cassava_pone.step1.title" = "Preheat and prepare pan";
"recipe.tt_cassava_pone.step10.body" = "Cut into squares and serve at room temperature.";
"recipe.tt_cassava_pone.step10.title" = "Slice and serve";
"recipe.tt_cassava_pone.step2.body" = "Peel and finely grate the %i1, %i3, and %i4. Keep the grated mixture together and break up any clumps so it mixes evenly.";
"recipe.tt_cassava_pone.step2.title" = "Grate the provisions";
"recipe.tt_cassava_pone.step3.body" = "Melt the butter gently in a saucepan, then remove from the heat so it cools slightly before mixing.";
"recipe.tt_cassava_pone.step3.title" = "Melt the butter";
"recipe.tt_cassava_pone.step4.body" = "In a large bowl, combine the %i5, %i6, %i7, %i8, %i9, %i10, and %i11 until evenly blended.";
"recipe.tt_cassava_pone.step4.title" = "Mix dry ingredients";
"recipe.tt_cassava_pone.step5.body" = "Stir in %i13 and %i14, then beat in %i15 and %i16 until the mixture looks smooth and well combined.";
"recipe.tt_cassava_pone.step5.title" = "Add wet ingredients";
"recipe.tt_cassava_pone.step6.body" = "Add the grated cassava, %i2, grated pumpkin, and grated sweet potato, mixing thoroughly. Pour in the melted butter and stir until the batter is uniform.";
"recipe.tt_cassava_pone.step6.title" = "Combine and enrich";
"recipe.tt_cassava_pone.step7.body" = "Scrape the batter into the prepared pan and level the top so it bakes evenly.";
"recipe.tt_cassava_pone.step7.title" = "Fill the pan";
"recipe.tt_cassava_pone.step8.body" = "Bake until set through the center with a deep golden top and browned edges, and the pone pulls slightly from the sides of the pan.";
"recipe.tt_cassava_pone.step8.title" = "Bake the pone";
"recipe.tt_cassava_pone.step9.body" = "Cool in the pan so the pone firms up and slices neatly.";
"recipe.tt_cassava_pone.step9.title" = "Cool to set";
