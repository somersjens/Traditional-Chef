"recipe.ua_varenyky.step11.title" = "Dress the dumplings";
"recipe.ua_varenyky.step12.body" = "Serve the varenyky immediately with %i12 alongside.";
"recipe.ua_varenyky.step12.title" = "Serve with sour cream";
