"recipe.tt_pelau.step4.title" = "Build the base";
"recipe.tt_pelau.step5.body" = "Stir in %i18, %i14, and %i15 so everything is coated in the seasoned base.";
"recipe.tt_pelau.step5.title" = "Add peas and vegetables";
"recipe.tt_pelau.step6.body" = "Stir in the %i17, then add %i16 and %i19 and mix well, scraping the bottom to loosen any flavorful browning.";
"recipe.tt_pelau.step6.title" = "Add rice and liquids";
"recipe.tt_pelau.step7.body" = "Bring to a steady simmer, cover tightly, and cook until the liquid is mostly absorbed and the rice is nearly tender.";
"recipe.tt_pelau.step7.title" = "Simmer covered";
"recipe.tt_pelau.step8.body" = "Reduce heat to low and continue cooking covered until the rice is fully tender and fluffy and the chicken is cooked through.";
"recipe.tt_pelau.step8.title" = "Steam to finish";
"recipe.tt_pelau.step9.body" = "Turn off the heat, rest covered, then fluff the pelau gently to distribute chicken and peas evenly.";
