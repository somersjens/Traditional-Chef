"recipe.lb_kibbeh_labanieh.step3.title" = "Make the kibbeh dough";
"recipe.lb_kibbeh_labanieh.step4.body" = "With damp hands, take a portion of dough and hollow it into a thin shell, add a little of the cooled stuffing, then pinch and smooth closed into an oval ball, keeping the seam sealed.";
"recipe.lb_kibbeh_labanieh.step4.title" = "Shape and stuff the kibbeh";
"recipe.lb_kibbeh_labanieh.step5.body" = "Whisk %i14 with %i15 in a pot until completely smooth, then set over medium-low heat and whisk steadily as it warms so it stays silky.";
"recipe.lb_kibbeh_labanieh.step5.title" = "Start the yogurt sauce";
"recipe.lb_kibbeh_labanieh.step6.body" = "Add crushed %i17, %i18, and %i19. Whisk in water gradually until the sauce is gently simmering and has a smooth, spoonable consistency.";
"recipe.lb_kibbeh_labanieh.step6.title" = "Season and thin the sauce";
"recipe.lb_kibbeh_labanieh.step7.body" = "Add the kibbeh gently to the simmering yogurt sauce and keep at a steady, gentle simmer, stirring carefully so nothing sticks, until the kibbeh is cooked through and the sauce is stable.";
"recipe.lb_kibbeh_labanieh.step7.title" = "Simmer the kibbeh in yogurt";
"recipe.lb_kibbeh_labanieh.step8.body" = "Rinse the %i21 until the water runs clearer. Melt %i23 in a pot and toast %i22 until deep golden, then add the rice and stir to coat. Add water and %i25, bring to a boil, cover, and cook until tender, then rest covered before fluffing.";
"recipe.lb_kibbeh_labanieh.step8.title" = "Cook the vermicelli rice";
"recipe.lb_kibbeh_labanieh.step9.body" = "Melt %i20 in a small pan, add crushed garlic and dried mint, and warm briefly until fragrant without browning.";
"recipe.lb_kibbeh_labanieh.step9.title" = "Finish with mint butter";
