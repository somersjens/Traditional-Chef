"recipe.bd_chomchom.drink.body" = "A lightly chilled Muscat or late-harvest dessert wine matches the syrupy sweetness and cardamom perfume. If you want less sweetness, an off-dry Riesling works well. Non-alcoholic pairing: masala chai or chilled milk with a pinch of cardamom.";
"recipe.bd_chomchom.drink.summary" = "Sweet wine (Muscat)";
"recipe.bd_chomchom.info" = "Chomchom is a traditional Bangladeshi chhana sweet: fresh curds are kneaded into a smooth dough, shaped, then gently simmered in fragrant sugar syrup until spongy and glossy. The sweets are soaked so they absorb the syrup, then drained and rolled in coconut for a soft, juicy bite with a delicate cardamom aroma. It is commonly served at celebrations and with tea as a classic Bengali dessert.";
"recipe.bd_chomchom.info.summary" = "Coconut-syrup sweet";
"recipe.bd_chomchom.name" = "Chomchom";
"recipe.bd_chomchom.step1.body" = "Warm the %i1 in a saucepan, stirring so it does not scorch, until it reaches a steady simmer.";
"recipe.bd_chomchom.step1.title" = "Heat the milk";
"recipe.bd_chomchom.step10.body" = "Lift the sweets out, drain briefly, then roll in %i8 until evenly coated.";
"recipe.bd_chomchom.step10.title" = "Drain and coat";
"recipe.bd_chomchom.step11.body" = "Rest briefly so the coating sets, then serve the chomchom at room temperature.";
"recipe.bd_chomchom.step11.title" = "Serve";
"recipe.bd_chomchom.step2.body" = "Add %i2 juice gradually while stirring until the curds separate clearly from the whey.";
"recipe.bd_chomchom.step2.title" = "Curdle the milk";
"recipe.bd_chomchom.step3.body" = "Pour the curds into a cloth-lined sieve and let them drain until the chhana is moist but not dripping.";
"recipe.bd_chomchom.step3.title" = "Drain the chhana";
"recipe.bd_chomchom.step4.body" = "Transfer the chhana to a plate, add %i7, and knead firmly until smooth, soft, and no longer grainy.";
"recipe.bd_chomchom.step4.title" = "Knead the chhana";
"recipe.bd_chomchom.step5.body" = "Divide the dough into even portions and shape into smooth oval logs with no cracks.";
"recipe.bd_chomchom.step5.title" = "Shape the chomchom";
"recipe.bd_chomchom.step6.body" = "Bring %i3 and %i4 to a boil in a large pot, add %i5, and keep the syrup at a steady boil.";
"recipe.bd_chomchom.step6.title" = "Prepare the syrup";
"recipe.bd_chomchom.step7.body" = "Gently slide the shaped pieces into the boiling syrup, cover, and cook while maintaining an active simmer so they puff and turn spongy.";
"recipe.bd_chomchom.step7.title" = "Cook in syrup";
"recipe.bd_chomchom.step8.body" = "Lower to a gentle simmer and cook a little longer so the syrup penetrates, then stir in %i6.";
"recipe.bd_chomchom.step8.title" = "Soak and perfume";
"recipe.bd_chomchom.step9.body" = "Turn off the heat and let the sweets cool in the syrup so they finish absorbing.";
"recipe.bd_chomchom.step9.title" = "Cool in syrup";
