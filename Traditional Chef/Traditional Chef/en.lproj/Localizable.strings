"recipe.kr_samgyetang.info" = "Samgyetang is a traditional Korean ginseng chicken soup made by simmering whole young chickens stuffed with glutinous rice, garlic, jujube, and ginseng until tender. It is served hot as a restorative meal, especially in summer, with a small dish of salt and pepper for seasoning at the table.";
"recipe.kr_samgyetang.info.summary" = "Ginseng chicken soup";
"recipe.kr_samgyetang.name" = "Samgyetang";
"recipe.kr_samgyetang.step1.body" = "Rinse the %i2 and soak it in cold water until it softens, then drain well.";
"recipe.kr_samgyetang.step1.title" = "Soak the glutinous rice";
"recipe.kr_samgyetang.step2.body" = "Clean the %i1, trim excess fat, and rinse briefly inside and out, then drain well.";
"recipe.kr_samgyetang.step2.title" = "Prepare the chickens";
"recipe.kr_samgyetang.step3.body" = "Trim the %i3, rinse the %i4, peel the %i5, and peel the %i6 if needed.";
"recipe.kr_samgyetang.step3.title" = "Prepare stuffing ingredients";
"recipe.kr_samgyetang.step4.body" = "Divide the soaked rice among the chickens and add garlic, jujube, chestnut, and ginseng to each cavity. Close the openings and tie the legs with kitchen twine.";
"recipe.kr_samgyetang.step4.title" = "Stuff the chickens";
"recipe.kr_samgyetang.step5.body" = "Place the stuffed chickens in a large pot and add %i7 so the chickens are well covered. Add the %i8.";
"recipe.kr_samgyetang.step5.title" = "Set up the pot";
"recipe.kr_samgyetang.step6.body" = "Bring the pot to a boil, skim foam, then reduce to a gentle simmer and cook until the chickens are tender and the stuffing is fully cooked.";
"recipe.kr_samgyetang.step6.title" = "Simmer the samgyetang";
"recipe.kr_samgyetang.step7.body" = "Mix the %i9 and %i10 in small bowls and thinly slice the %i11 for serving.";
"recipe.kr_samgyetang.step7.title" = "Prepare table seasoning";
"recipe.kr_samgyetang.step8.body" = "Remove the broth scallion and skim excess fat from the surface. Taste the broth and keep it hot.";
"recipe.kr_samgyetang.step8.title" = "Finish the broth";
"recipe.kr_samgyetang.step9.body" = "Place one chicken in each serving bowl, ladle over hot broth, top with garnish scallion, and serve immediately with the salt-pepper seasoning on the side.";
"recipe.kr_samgyetang.step9.title" = "Serve";
