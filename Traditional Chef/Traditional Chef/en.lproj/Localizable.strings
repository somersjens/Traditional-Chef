"recipe.mu_gateau_patate.drink.body" = "A lightly sweet Muscat or late-harvest Chenin pairs well with the caramelized sweet potato and coconut notes. If you prefer something simpler, a gentle spiced rum-based cocktail also works in small pours. Non-alcoholic pairing: strong black tea or chilled vanilla milk.";
"recipe.mu_gateau_patate.drink.summary" = "Dessert wine (Muscat)";
"recipe.mu_gateau_patate.info" = "Gâteau patate is a traditional Mauritian baked cake made from cooked sweet potatoes mixed with grated coconut, sugar, and warm spices, then baked until set with a golden crust. It is a classic home dessert and tea-time treat, usually cut into squares and served once cooled, when the texture becomes dense, moist, and fragrant.";
"recipe.mu_gateau_patate.info.summary" = "Baked sweet potato cake";
"recipe.mu_gateau_patate.name" = "Sweet potato cake";
