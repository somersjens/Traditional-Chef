"recipe.it_panna_cotta.drink.summary" = "Moscato d'Asti";
"recipe.it_panna_cotta.info" = "A traditional Italian set cream dessert made by gently heating cream with sugar and vanilla, then setting it with gelatin for a smooth, delicate wobble. Served chilled in small molds, it is a classic, understated finish to a meal, prized for its clean dairy flavor and soft texture.";
"recipe.it_panna_cotta.info.summary" = "Silky molded cream";
"recipe.it_panna_cotta.name" = "Panna cotta";
"recipe.it_panna_cotta.step1.body" = "Soak %i5 in cold %i6 until softened, then lift it out and gently squeeze out the excess water.";
"recipe.it_panna_cotta.step1.title" = "Bloom the gelatin";
"recipe.it_panna_cotta.step2.body" = "Split the %i4 and scrape the seeds. Add %i1, %i2, %i3, the vanilla seeds and pod, and a pinch of %i7 to a saucepan.";
"recipe.it_panna_cotta.step2.title" = "Infuse the cream";
