"recipe.ph_kinilaw.drink.body" = "A crisp white wine such as Sauvignon Blanc pairs well with the bright acidity and fresh fish. A pale lager is also a classic match for kinilaw. For a non-alcoholic option, serve chilled calamansi juice or cold soda water with lime.";
"recipe.ph_kinilaw.drink.summary" = "White wine (Sauvignon)";
"recipe.ph_kinilaw.info" = "Kinilaw is a traditional Filipino dish of very fresh raw fish cured in vinegar and calamansi with ginger, onion, and chili. It is commonly served chilled as a starter or pulutan, highlighting bright acidity, clean fish flavor, and sharp aromatics.";
"recipe.ph_kinilaw.info.summary" = "Vinegar-cured fish";
"recipe.ph_kinilaw.name" = "Kinilaw";
"recipe.ph_kinilaw.step1.body" = "Thinly slice the %i4, julienne the %i5, and slice the %i6. Place the onion in a small bowl with %i9 and some %i10 to crisp, then drain.";
"recipe.ph_kinilaw.step1.title" = "Prepare aromatics";
"recipe.ph_kinilaw.step2.body" = "Trim the %i1 and cut it into small bite-size cubes. Keep the fish cold while working.";
"recipe.ph_kinilaw.step2.title" = "Dice fish";
"recipe.ph_kinilaw.step3.body" = "Place the fish in a mixing bowl and season with %i7 and %i8, tossing gently to coat evenly.";
"recipe.ph_kinilaw.step3.title" = "Salt fish";
"recipe.ph_kinilaw.step4.body" = "Pour the %i2 over the fish and let it cure briefly until the surface turns opaque.";
"recipe.ph_kinilaw.step4.title" = "Cure with vinegar";
"recipe.ph_kinilaw.step5.body" = "Drain off most of the vinegar from the fish, leaving only a little to keep the mixture moist.";
"recipe.ph_kinilaw.step5.title" = "Drain fish";
"recipe.ph_kinilaw.step6.body" = "Add the %i3, drained onion, ginger, and chili, then toss gently until evenly mixed.";
"recipe.ph_kinilaw.step6.title" = "Finish kinilaw";
"recipe.ph_kinilaw.step7.body" = "Chill the kinilaw briefly so the flavors meld and the fish stays very cold.";
"recipe.ph_kinilaw.step7.title" = "Chill before serving";
"recipe.ph_kinilaw.step8.body" = "Transfer the kinilaw to a serving bowl and serve immediately while chilled.";
"recipe.ph_kinilaw.step8.title" = "Serve";
