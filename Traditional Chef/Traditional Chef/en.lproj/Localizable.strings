"recipe.bo_chairo.step1.body" = "Rinse %i3 well and soak it in water until softened enough to peel and break into smaller pieces.";
"recipe.bo_chairo.step1.title" = "Soak the chuño";
"recipe.bo_chairo.step2.body" = "Cut %i1 and %i2 into serving pieces if needed. Peel and chop %i7, mince %i8, dice %i9 and %i5, and chop %i19 and %i20.";
"recipe.bo_chairo.step2.title" = "Prepare the ingredients";
"recipe.bo_chairo.step3.body" = "Place the beef and lamb in the pot with water, %i16, and %i17. Bring to a boil, skim if needed, lower the heat, and simmer until the meats begin to soften.";
"recipe.bo_chairo.step3.title" = "Start the broth";
"recipe.bo_chairo.step4.body" = "Heat %i12 in the pot, add the onion and garlic, and cook until softened. Stir in %i13, %i14, and %i15 until fragrant.";
"recipe.bo_chairo.step4.title" = "Make the base";
"recipe.bo_chairo.step5.body" = "Add the carrots, potatoes, %i6, chuño, and %i4 to the pot. Simmer gently so the broth thickens and the chuño begins to soften fully.";
"recipe.bo_chairo.step5.title" = "Cook the main vegetables";
"recipe.bo_chairo.step6.body" = "Add %i10 and %i11 and continue simmering until the vegetables are tender and the meats are fully cooked.";
"recipe.bo_chairo.step6.title" = "Add the final vegetables";
"recipe.bo_chairo.step7.body" = "Taste and adjust the salt, then stir in most of the parsley. Add the mint at the end so its aroma stays fresh and traditional.";
"recipe.bo_chairo.step7.title" = "Finish the soup";
"recipe.bo_chairo.step8.body" = "Ladle the chairo into bowls and finish with the remaining parsley and mint over the top. Serve hot.";
"recipe.bo_chairo.step8.title" = "Serve traditionally";
