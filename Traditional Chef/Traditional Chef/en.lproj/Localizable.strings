"recipe.ca_tarte_au_sucre.drink.summary" = "Ice cider";
"recipe.ca_tarte_au_sucre.info" = "Sugar pie is a traditional Quebec dessert with a flaky pastry shell and a rich filling of brown sugar, cream, and egg baked until set. It is a classic holiday and family-table dessert in French Canada, usually served cooled so the filling slices cleanly.";
"recipe.ca_tarte_au_sucre.info.summary" = "Quebec sugar pie";
"recipe.ca_tarte_au_sucre.name" = "Sugar pie";
