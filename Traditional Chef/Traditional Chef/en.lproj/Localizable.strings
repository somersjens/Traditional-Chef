"recipe.bd_morog_polao.step5.title" = "Fry nuts and infuse saffron";
"recipe.bd_morog_polao.step6.body" = "Add the %i13, %i14, %i15, and %i16 to the pot and fry briefly, then add the marinated chicken and cook until the yogurt is absorbed and the chicken is lightly sealed.";
"recipe.bd_morog_polao.step6.title" = "Cook the chicken";
"recipe.bd_morog_polao.step7.body" = "Rinse the %i17 until the water runs mostly clear. Add the rice to the pot and stir so it is coated in the spiced fat.";
"recipe.bd_morog_polao.step7.title" = "Start the rice";
"recipe.bd_morog_polao.step8.body" = "Add %i26 and the remaining salt, bring to a simmer, cover, and cook gently until the rice is tender and the liquid is absorbed.";
"recipe.bd_morog_polao.step8.title" = "Cook the polao";
"recipe.bd_morog_polao.step9.body" = "Drizzle over the saffron milk and %i22, scatter the fried nuts and reserved onions, then cover and rest so the aromas settle and the rice fluffs up.";
"recipe.bd_morog_polao.step9.title" = "Finish and rest";
