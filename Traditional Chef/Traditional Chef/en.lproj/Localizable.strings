"recipe.lb_hummus.step3.title" = "Blend the hummus";
"recipe.lb_hummus.step4.body" = "Spoon into a serving bowl and spread with the back of a spoon to create a shallow well. Drizzle with %i8 and sprinkle with %i9.";
"recipe.lb_hummus.step4.title" = "Plate and garnish";
"recipe.lb_hummus.step5.body" = "Warm the %i10 briefly, then serve alongside the hummus for scooping.";
