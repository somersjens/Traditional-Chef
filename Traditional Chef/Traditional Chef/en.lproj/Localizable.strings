"recipe.ar_helado_artesanal.drink.body" = "A lightly sweet Moscato complements dulce de leche’s caramel richness, while a small pour of Tawny-style dessert wine echoes the toffee notes. For a non-alcoholic option, serve espresso or strong black coffee, or sparkling water with lemon.";
"recipe.ar_helado_artesanal.drink.summary" = "Dessert wine (Moscato)";
"recipe.ar_helado_artesanal.info" = "Argentine helado artesanal is a dense, silky ice cream in the Italian tradition, made with a cooked custard base and churned for a smooth texture. The most iconic Argentine flavor is dulce de leche, folded through the churned ice cream for rich caramel notes and a creamy, scoopable finish, typically enjoyed in a cup or cone from a heladería.";
"recipe.ar_helado_artesanal.info.summary" = "Dulce de leche gelato";
"recipe.ar_helado_artesanal.name" = "Dulce de leche ice cream";
"recipe.ar_helado_artesanal.step1.body" = "Prepare an ice bath and place a bowl in it so the custard can be cooled quickly after cooking.";
"recipe.ar_helado_artesanal.step1.title" = "Set up chilling";
"recipe.ar_helado_artesanal.step2.body" = "Warm %i1 and %i2 with %i3 and %i6 until steaming and fully dissolved, stirring so nothing scorches.";
"recipe.ar_helado_artesanal.step2.title" = "Heat dairy and dissolve sugar";
"recipe.ar_helado_artesanal.step3.body" = "Whisk %i4 in a bowl, then slowly whisk in some hot dairy to warm the yolks without scrambling.";
"recipe.ar_helado_artesanal.step3.title" = "Temper the yolks";
"recipe.ar_helado_artesanal.step4.body" = "Return the mixture to the saucepan and cook gently, stirring constantly, until the custard thickens and coats the spoon.";
"recipe.ar_helado_artesanal.step4.title" = "Cook the custard";
"recipe.ar_helado_artesanal.step5.body" = "Strain the custard into the chilled bowl to remove any bits, then stir in %i5 until uniform.";
"recipe.ar_helado_artesanal.step5.title" = "Strain and flavor";
"recipe.ar_helado_artesanal.step6.body" = "Cool the custard in the ice bath, then refrigerate until completely cold for proper churning.";
"recipe.ar_helado_artesanal.step6.title" = "Chill thoroughly";
"recipe.ar_helado_artesanal.step7.body" = "Churn the cold custard in an ice cream maker until thick, smooth, and softly frozen.";
"recipe.ar_helado_artesanal.step7.title" = "Churn the ice cream";
