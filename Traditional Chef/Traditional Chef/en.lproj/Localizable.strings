"recipe.ma_rfissa.step4.title" = "Simmer the chicken";
"recipe.ma_rfissa.step5.body" = "Rinse the %i14 and add them to the pot. Continue simmering until the lentils are tender and the broth has body, then stir in chopped cilantro.";
"recipe.ma_rfissa.step5.title" = "Cook the lentils";
"recipe.ma_rfissa.step6.body" = "In a bowl, mix %i15, %i16, and %i17. Add %i18 gradually and knead until a smooth, elastic dough forms. Cover and let it rest.";
"recipe.ma_rfissa.step6.title" = "Make msemen dough";
"recipe.ma_rfissa.step7.body" = "Let the dough rest covered so it relaxes for shaping.";
"recipe.ma_rfissa.step7.title" = "Rest the dough";
"recipe.ma_rfissa.step8.body" = "Melt the %i20 and mix it with %i19 so it stays spreadable for laminating and cooking.";
"recipe.ma_rfissa.step8.title" = "Prepare folding fat";
"recipe.ma_rfissa.step9.body" = "Divide the dough into balls. Oil the work surface and flatten each ball very thin, brush with the oil-butter mixture, fold into a layered square, then cook on a hot skillet, turning, until golden and cooked through. Repeat for all pieces.";
