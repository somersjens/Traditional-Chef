"recipe.gr_melitzanosalata.drink.body" = "Pair with a crisp Greek white such as Assyrtiko that stays fresh with smoke, lemon, and olive oil. A light lager also works well. For a non-alcoholic option, serve sparkling water with lemon or a chilled lemon soda.";
"recipe.gr_melitzanosalata.drink.summary" = "White wine (Assyrtiko)";
"recipe.gr_melitzanosalata.info" = "Melitzanosalata is a traditional Greek smoky eggplant dip made by charring whole eggplants until the flesh is soft and infused with smoke, then mashing and dressing with olive oil, lemon, and garlic. It is served as a meze with bread for scooping, highlighting the smoky flavor and silky texture.";
"recipe.gr_melitzanosalata.info.summary" = "Smoky village eggplant dip";
