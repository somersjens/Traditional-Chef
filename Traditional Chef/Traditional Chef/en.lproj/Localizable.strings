"recipe.pe_tiradito.step7.body" = "Pour the leche de tigre over the fish just before serving so the slices are dressed but not drowned.";
"recipe.pe_tiradito.step7.title" = "Sauce the tiradito";
"recipe.pe_tiradito.step8.body" = "Garnish with cilantro and ají limo, and serve immediately with sweet potato and %i14 on the side.";
"recipe.pe_tiradito.step8.title" = "Garnish and serve";
