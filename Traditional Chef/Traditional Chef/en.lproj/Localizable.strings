"recipe.uz_nisholda.drink.body" = "A lightly sweet dessert wine such as Moscato can match the sugar richness in small servings. Non-alcoholic pairing: hot green tea or black tea is the traditional and best companion.";
"recipe.uz_nisholda.drink.summary" = "Dessert wine";
"recipe.uz_nisholda.info" = "Nisholda is a traditional Uzbek festive sweet made by whipping egg whites with a concentrated sugar syrup and a decoction of etmak soapwort root until thick and glossy. It is commonly served cold during Ramadan and on festive tables, often with bread and hot tea.";
"recipe.uz_nisholda.info.summary" = "Foamy festive sweet";
"recipe.uz_nisholda.name" = "Nisholda";
"recipe.uz_nisholda.step1.body" = "Rinse the %i2 well, peel if needed, and cut it into smaller pieces for boiling.";
"recipe.uz_nisholda.step1.title" = "Prepare root";
"recipe.uz_nisholda.step10.body" = "Sprinkle %i7 over the top and serve cold with torn %i8.";
"recipe.uz_nisholda.step10.title" = "Serve";
"recipe.uz_nisholda.step2.body" = "Place the root in the small pot with %i3, bring to a boil, then simmer until the liquid takes on the foaming properties of the root.";
"recipe.uz_nisholda.step2.title" = "Make root decoction";
"recipe.uz_nisholda.step3.body" = "Strain the root liquid and let it cool until no longer hot.";
"recipe.uz_nisholda.step3.title" = "Strain and cool decoction";
"recipe.uz_nisholda.step4.body" = "In the saucepan, combine %i4, %i5, and %i6. Cook until a concentrated syrup forms and the sugar is fully dissolved.";
"recipe.uz_nisholda.step4.title" = "Cook sugar syrup";
"recipe.uz_nisholda.step5.body" = "Remove the syrup from the heat and let it cool slightly so it stays fluid but does not cook the egg whites on contact.";
"recipe.uz_nisholda.step5.title" = "Cool syrup slightly";
"recipe.uz_nisholda.step6.body" = "Whip the %i1 in the mixing bowl until a thick stable foam forms.";
"recipe.uz_nisholda.step6.title" = "Whip egg whites";
"recipe.uz_nisholda.step7.body" = "Gradually add the cooled root decoction to the whipped egg whites while whisking continuously until the foam becomes glossy and stronger.";
"recipe.uz_nisholda.step7.title" = "Add root decoction";
"recipe.uz_nisholda.step8.body" = "Slowly pour in the syrup while mixing constantly, then continue beating and folding until the mixture is smooth, thick, and uniform without separating.";
"recipe.uz_nisholda.step8.title" = "Finish nisholda";
"recipe.uz_nisholda.step9.body" = "Transfer the nisholda to a serving bowl and chill until cold and set to a spoonable texture.";
"recipe.uz_nisholda.step9.title" = "Chill";
