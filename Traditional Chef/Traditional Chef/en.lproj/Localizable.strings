"recipe.ph_ube_halaya.drink.body" = "A lightly sweet dessert wine such as Moscato complements the rich yam and buttery sweetness. Coffee also pairs very well. For a non-alcoholic option, serve hot barako coffee or unsweetened black tea.";
"recipe.ph_ube_halaya.drink.summary" = "Dessert wine (Moscato)";
"recipe.ph_ube_halaya.info" = "Ube halaya is a traditional Filipino dessert made by cooking mashed purple yam with milk, sugar, and butter until thick, glossy, and spreadable. It is commonly served chilled or at room temperature as a dessert, merienda sweet, or festive component, often topped with grated cheese.";
"recipe.ph_ube_halaya.info.summary" = "Purple yam jam";
"recipe.ph_ube_halaya.name" = "Ube halaya";
"recipe.ph_ube_halaya.step1.body" = "Peel the %i1 and cut it into large even pieces so it cooks evenly.";
"recipe.ph_ube_halaya.step1.title" = "Prepare ube";
"recipe.ph_ube_halaya.step10.body" = "Let the ube halaya cool until set enough to serve, then serve at room temperature or chilled.";
"recipe.ph_ube_halaya.step10.title" = "Cool and set";
"recipe.ph_ube_halaya.step2.body" = "Place the ube in a pot with %i2, bring to a boil, and simmer until very tender.";
"recipe.ph_ube_halaya.step2.title" = "Boil ube";
"recipe.ph_ube_halaya.step3.body" = "Drain the cooked ube well, then mash until smooth with as few lumps as possible.";
"recipe.ph_ube_halaya.step3.title" = "Drain and mash ube";
"recipe.ph_ube_halaya.step4.body" = "In a heavy saucepan, combine the mashed ube, %i3, %i4, %i5, and %i7, and stir over medium heat until evenly blended.";
"recipe.ph_ube_halaya.step4.title" = "Start halaya mixture";
"recipe.ph_ube_halaya.step5.body" = "Cook the mixture over medium-low heat, stirring continuously and scraping the bottom, until it thickens and becomes glossy.";
"recipe.ph_ube_halaya.step5.title" = "Cook halaya";
"recipe.ph_ube_halaya.step6.body" = "Add most of the %i6 and continue stirring until fully absorbed and the halaya pulls away from the sides of the pan.";
"recipe.ph_ube_halaya.step6.title" = "Finish with butter";
"recipe.ph_ube_halaya.step7.body" = "Lightly grease the serving dish or molds with %i9.";
"recipe.ph_ube_halaya.step7.title" = "Prepare serving dish";
"recipe.ph_ube_halaya.step8.body" = "Spoon the hot ube halaya into the greased dish and smooth the surface with a spatula.";
"recipe.ph_ube_halaya.step8.title" = "Transfer halaya";
"recipe.ph_ube_halaya.step9.body" = "Brush the surface with the remaining butter and sprinkle the %i8 evenly over the top.";
"recipe.ph_ube_halaya.step9.title" = "Top with cheese";
"recipe.ph_ube_halaya.tool.t1" = "Chef knife";
