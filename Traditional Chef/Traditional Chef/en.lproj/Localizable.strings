"recipe.id_sop_buntut.drink.body" = "A light lager or a soft light-bodied red can complement the rich beef broth without overpowering it. For a non-alcoholic pairing, serve hot jasmine tea or chilled lime water.";
"recipe.id_sop_buntut.drink.summary" = "Beer (Lager)";
"recipe.id_sop_buntut.info" = "Sop buntut is a traditional Indonesian oxtail soup with a clear aromatic broth, tender oxtail, carrots, potatoes, and warm spices. It is commonly served as a hearty family meal or special-occasion dish with steamed rice, sambal, lime, and crackers on the side.";
"recipe.id_sop_buntut.info.summary" = "Clear oxtail soup";
"recipe.id_sop_buntut.name" = "Oxtail soup";
"recipe.id_sop_buntut.step1.body" = "Rinse the %i1 pieces. Peel and cut the %i12 and %i13 into serving chunks, and slice the %i14 and %i15 for later.";
"recipe.id_sop_buntut.step1.title" = "Prepare the oxtail and vegetables";
"recipe.id_sop_buntut.step2.body" = "Place the oxtail in a pot with %i2, bring to a boil briefly, then drain and rinse the oxtail and clean the pot for a clearer broth.";
"recipe.id_sop_buntut.step2.title" = "Blanch the oxtail";
"recipe.id_sop_buntut.step3.body" = "Heat a little %i16 and sauté %i3, %i4, and %i5 until fragrant, then add %i6 and %i7 and stir briefly.";
"recipe.id_sop_buntut.step3.title" = "Cook the soup aromatics";
"recipe.id_sop_buntut.step4.body" = "Return the oxtail to the pot with fresh water, add the sautéed aromatics, %i9, %i10, %i11, and %i8, then simmer gently until the meat is becoming tender. Skim as needed.";
"recipe.id_sop_buntut.step4.title" = "Simmer the oxtail broth";
"recipe.id_sop_buntut.step5.body" = "Add the potatoes and carrots and continue simmering until the oxtail is very tender and the vegetables are cooked through. Add scallions and celery leaves near the end.";
"recipe.id_sop_buntut.step5.title" = "Add vegetables and finish soup";
"recipe.id_sop_buntut.step6.body" = "Thinly slice the %i17 and fry them until golden and crisp, then drain well for topping the soup.";
"recipe.id_sop_buntut.step6.title" = "Make fried shallot garnish";
"recipe.id_sop_buntut.step7.body" = "Cook the %i19, %i20, %i21, and %i22 briefly in a little %i25 until softened, then crush with %i23 and %i24 into a coarse sambal.";
"recipe.id_sop_buntut.step7.title" = "Make the sambal";
"recipe.id_sop_buntut.step8.body" = "Cut the %i27 and arrange the %i26 and %i28 for serving alongside the soup.";
"recipe.id_sop_buntut.step8.title" = "Prepare accompaniments";
"recipe.id_sop_buntut.step9.body" = "Ladle the hot sop buntut into bowls with oxtail and vegetables, top with fried shallots, and serve with sambal, lime, rice, and emping crackers.";
"recipe.id_sop_buntut.step9.title" = "Serve";
