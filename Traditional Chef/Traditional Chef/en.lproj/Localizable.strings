"recipe.id_soto_betawi.step1.title" = "Prepare the beef and tripe";
"recipe.id_soto_betawi.step10.body" = "Place beef and tripe in bowls, ladle over the hot creamy broth, add fried potatoes and tomato, then finish with scallions, celery leaves, and fried shallots. Serve with rice, sambal, lime, pickle, and emping on the side.";
"recipe.id_soto_betawi.step10.title" = "Serve the soto betawi";
"recipe.id_soto_betawi.step2.body" = "Place the beef and tripe in a pot with %i3, bring to a boil briefly, then drain and rinse the meats and clean the pot for a clearer broth.";
"recipe.id_soto_betawi.step2.title" = "Blanch the meats";
