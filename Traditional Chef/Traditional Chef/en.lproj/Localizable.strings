"recipe.za_waterblommetjie_bredie.drink.body" = "A dry South African Chenin Blanc complements the stew’s lemon-bright edge and savoury lamb richness. A lightly chilled Pinotage can also work if you prefer red. Non-alcoholic pairing: rooibos tea or sparkling water with lemon.";
"recipe.za_waterblommetjie_bredie.drink.summary" = "White wine (Chenin Blanc)";
"recipe.za_waterblommetjie_bredie.info" = "Waterblommetjie bredie is a traditional Cape winter stew of lamb slowly simmered with potatoes and the indigenous waterblommetjie (water flower), finished with lemon for its characteristic gentle tang. The stew is cooked until the lamb is tender and the gravy rich, then served simply with plain white rice to soak up the sauce.";
"recipe.za_waterblommetjie_bredie.info.summary" = "Cape lamb stew";
"recipe.za_waterblommetjie_bredie.name" = "Waterblommetjie bredie";
"recipe.za_waterblommetjie_bredie.step1.body" = "Chop the %i3 and %i4, peel and cut the %i11 into chunks, and rinse the %i12 well, discarding tough stems. Zest and juice the %i13.";
"recipe.za_waterblommetjie_bredie.step1.title" = "Prep ingredients";
"recipe.za_waterblommetjie_bredie.step10.body" = "Rest the rice covered so it fluffs up. Serve the waterblommetjie bredie hot with the rice.";
"recipe.za_waterblommetjie_bredie.step10.title" = "Rest and serve";
"recipe.za_waterblommetjie_bredie.step2.body" = "Heat %i2 in a heavy pot and brown the %i1 well in batches, seasoning with some of the %i7 and %i8 as it browns.";
"recipe.za_waterblommetjie_bredie.step2.title" = "Brown the lamb";
"recipe.za_waterblommetjie_bredie.step3.body" = "Add the onion to the pot and cook until softened, then add the garlic and cook until fragrant.";
"recipe.za_waterblommetjie_bredie.step3.title" = "Cook the aromatics";
"recipe.za_waterblommetjie_bredie.step4.body" = "Stir in %i5 and %i6, then pour in %i9 and scrape up any browned bits.";
"recipe.za_waterblommetjie_bredie.step4.title" = "Add spice and deglaze";
"recipe.za_waterblommetjie_bredie.step5.body" = "Add %i10 and the lemon zest, bring to a gentle simmer, cover, and cook until the lamb is starting to become tender.";
"recipe.za_waterblommetjie_bredie.step5.title" = "Simmer until tender";
"recipe.za_waterblommetjie_bredie.step6.body" = "Add the potatoes and continue simmering, covered, until the potatoes are soft. If the pot looks dry at any point, add %i15 to maintain a gentle simmer.";
"recipe.za_waterblommetjie_bredie.step6.title" = "Cook with potatoes";
"recipe.za_waterblommetjie_bredie.step7.body" = "Add the waterblommetjies and cook gently until tender but still holding their shape.";
"recipe.za_waterblommetjie_bredie.step7.title" = "Finish with waterblommetjies";
"recipe.za_waterblommetjie_bredie.step8.body" = "Stir in lemon juice to taste and adjust salt and pepper so the stew is savoury with a light tang.";
"recipe.za_waterblommetjie_bredie.step8.title" = "Season with lemon";
"recipe.za_waterblommetjie_bredie.step9.body" = "Rinse the %i14. Combine it with water and a pinch of salt, bring to a simmer, then cover and cook gently until tender.";
"recipe.za_waterblommetjie_bredie.step9.title" = "Cook the rice";
