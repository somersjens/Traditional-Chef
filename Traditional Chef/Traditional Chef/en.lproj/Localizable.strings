"recipe.it_pesto_alla_genovese.drink.body" = "Pair with a crisp Ligurian white such as Vermentino or Pigato to match the herbal basil and olive oil. A dry light lager also works. For a non-alcoholic option, serve sparkling water with lemon.";
"recipe.it_pesto_alla_genovese.drink.summary" = "White wine (Vermentino)";
"recipe.it_pesto_alla_genovese.info" = "Pesto alla Genovese is the classic Ligurian basil sauce made by crushing fresh basil with pine nuts, garlic, Parmesan and Pecorino cheeses, and extra virgin olive oil until fragrant and creamy. It is traditionally served with pasta, most famously trofie, often with potatoes and green beans cooked together, then dressed immediately so the aroma stays bright.";
"recipe.it_pesto_alla_genovese.info.summary" = "Genoa basil pasta";
"recipe.it_pesto_alla_genovese.name" = "Pesto pasta";
