"recipe.ma_taktouka.drink.body" = "A crisp dry white such as Sauvignon Blanc pairs well with roasted peppers, tomato sweetness, and warm spices. For a non-alcoholic option, serve Moroccan mint tea or sparkling water with lemon.";
"recipe.ma_taktouka.drink.summary" = "White wine (Sauvignon)";
"recipe.ma_taktouka.info" = "Taktouka is a classic Moroccan cooked salad of roasted peppers and tomatoes simmered with garlic, olive oil, cumin, and paprika until soft and jammy. It is traditionally served as a starter or side on shared tables, eaten warm or at room temperature, and paired with Moroccan khobz for scooping.";
"recipe.ma_taktouka.info.summary" = "Jammy pepper salad";
"recipe.ma_taktouka.name" = "Taktouka";
"recipe.ma_taktouka.step1.body" = "Combine %i9, %i10, and %i11 in a bowl. Add %i12 and knead until smooth and elastic, then cover with a towel.";
"recipe.ma_taktouka.step1.title" = "Start khobz dough";
"recipe.ma_taktouka.step2.body" = "Leave the dough covered in a warm spot until clearly risen and airy.";
"recipe.ma_taktouka.step2.title" = "Rise the dough";
"recipe.ma_taktouka.step3.body" = "Place the %i1 on a baking sheet and roast until blistered and blackened in spots. Transfer to a bowl, cover, and let them steam.";
"recipe.ma_taktouka.step3.title" = "Roast the peppers";
"recipe.ma_taktouka.step4.body" = "Peel the steamed peppers, remove seeds and stems, and chop the flesh finely.";
"recipe.ma_taktouka.step4.title" = "Peel and chop peppers";
"recipe.ma_taktouka.step5.body" = "Peel the %i2 by blanching if needed, then chop finely. Mince the %i3.";
"recipe.ma_taktouka.step5.title" = "Prep tomatoes and garlic";
"recipe.ma_taktouka.step6.body" = "Heat %i4 in a skillet over medium heat. Add garlic, then add tomatoes and peppers with %i5, %i6, %i7, and %i8. Simmer, stirring often, until thick, soft, and jammy and the oil separates slightly.";
"recipe.ma_taktouka.step6.title" = "Cook the taktouka";
"recipe.ma_taktouka.step7.body" = "Punch down the risen dough, shape into round loaves, cover briefly, and heat the oven with a baking stone or sheet inside.";
"recipe.ma_taktouka.step7.title" = "Shape khobz and heat oven";
"recipe.ma_taktouka.step8.body" = "Bake the loaves until well risen and browned. Remove and let cool slightly for serving.";
"recipe.ma_taktouka.step8.title" = "Bake the bread";
"recipe.ma_taktouka.step9.body" = "Serve taktouka warm or at room temperature with khobz for scooping.";
