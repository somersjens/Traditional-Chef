"recipe.bg_gyuvech.step2.title" = "Brown the pork";
"recipe.bg_gyuvech.step3.body" = "Add the onions and garlic to the skillet and cook until softened and fragrant around the pork.";
"recipe.bg_gyuvech.step3.title" = "Cook the onion base";
"recipe.bg_gyuvech.step4.body" = "Add %i6, %i7, most of %i8, and %i9, then pour in %i5 and %i10 and bring everything to a gentle simmer.";
"recipe.bg_gyuvech.step4.title" = "Season and moisten";
"recipe.bg_gyuvech.step5.body" = "Transfer the pork mixture to the clay pot and add the potatoes, eggplant, zucchini, peppers, tomatoes, green beans, okra, and %i18 in even layers, seasoning the vegetables with the remaining salt.";
"recipe.bg_gyuvech.step5.title" = "Layer the vegetables";
"recipe.bg_gyuvech.step6.body" = "Cover the pot and bake slowly until the pork is tender, the vegetables are fully cooked, and the juices have blended into a rich sauce.";
"recipe.bg_gyuvech.step6.title" = "Bake the gyuvech";
"recipe.bg_gyuvech.step7.body" = "Uncover the pot, sprinkle in %i19, and stir gently so the vegetables keep their shape.";
"recipe.bg_gyuvech.step7.title" = "Finish with parsley";
"recipe.bg_gyuvech.step8.body" = "Let the gyuvech stand briefly out of the oven so the juices settle and the flavors deepen.";
"recipe.bg_gyuvech.step8.title" = "Rest before serving";
"recipe.bg_gyuvech.step9.body" = "Ladle the gyuvech hot into bowls and serve it with %i20 alongside.";
"recipe.bg_gyuvech.step9.title" = "Serve with bread";
