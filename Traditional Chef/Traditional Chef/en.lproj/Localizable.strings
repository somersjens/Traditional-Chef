"recipe.lb_fattoush.drink.summary" = "White wine (Sauvignon)";
"recipe.lb_fattoush.info" = "Lebanese fattoush is a classic mezze salad of chopped seasonal vegetables and herbs tossed with a tangy sumac dressing and topped with crisp fried pita. It is served as part of a shared table alongside other dips and salads, best eaten soon after mixing so the bread stays crunchy.";
"recipe.lb_fattoush.info.summary" = "Crisp bread salad";
"recipe.lb_fattoush.name" = "Fattoush";
"recipe.lb_fattoush.step1.body" = "Wash and dry the vegetables and herbs thoroughly. Chop everything into bite-size pieces and place in a large bowl, keeping herbs ready to add just before tossing.";
"recipe.lb_fattoush.step1.title" = "Prep the vegetables and herbs";
"recipe.lb_fattoush.step2.body" = "Cut the %i17 into small pieces. Heat the %i18 in a pan and fry the pita until crisp and golden. Lift out with a slotted spoon and drain on paper towels, then let cool to stay crunchy.";
"recipe.lb_fattoush.step2.title" = "Fry the pita chips";
"recipe.lb_fattoush.step3.body" = "In a small bowl, whisk together %i10, %i11, %i12, crushed %i14, %i13, %i15, and %i16 until emulsified.";
"recipe.lb_fattoush.step3.title" = "Mix the fattoush dressing";
"recipe.lb_fattoush.step4.body" = "Add the herbs to the bowl of vegetables, drizzle over the dressing, and toss well so everything is evenly coated.";
"recipe.lb_fattoush.step4.title" = "Toss the salad";
"recipe.lb_fattoush.step5.body" = "Add the pita chips and toss briefly. Serve immediately so the bread stays crisp, with an extra sprinkle of sumac on top.";
"recipe.lb_fattoush.step5.title" = "Finish and serve";
