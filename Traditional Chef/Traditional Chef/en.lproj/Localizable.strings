"recipe.jp_warabi_mochi.drink.body" = "Hojicha or sencha pairs well with the roasted kinako and light sweetness. For a non-alcoholic pairing, serve cold barley tea or iced green tea.";
"recipe.jp_warabi_mochi.drink.summary" = "Green tea (Hojicha)";
"recipe.jp_warabi_mochi.info" = "Warabi mochi is a traditional Japanese wagashi made by cooking starch into a soft translucent gel, then chilling and cutting it into bite-size pieces and coating it with kinako and kuromitsu. It is commonly enjoyed as a refreshing summer sweet in tea houses and homes, served chilled with a soft chewy texture.";
"recipe.jp_warabi_mochi.info.summary" = "Kinako warabi mochi";
"recipe.jp_warabi_mochi.name" = "Warabi mochi";
"recipe.jp_warabi_mochi.step1.body" = "Lightly moisten a shallow tray and prepare a bowl of %i10 for cooling and handling the cooked warabi mochi.";
"recipe.jp_warabi_mochi.step1.title" = "Prepare the trays and bath";
"recipe.jp_warabi_mochi.step2.body" = "Whisk %i1, %i2, and %i3 in a saucepan until completely smooth with no lumps.";
"recipe.jp_warabi_mochi.step2.title" = "Mix the warabi base";
"recipe.jp_warabi_mochi.step3.body" = "Cook over medium-low heat, stirring constantly as the mixture thickens and turns glossy and translucent, until it becomes elastic and fully cooked.";
"recipe.jp_warabi_mochi.step3.title" = "Cook the warabi mochi";
"recipe.jp_warabi_mochi.step4.body" = "Transfer the hot mixture to the moistened tray and spread it into an even layer, then let it cool slightly.";
"recipe.jp_warabi_mochi.step4.title" = "Set the mochi";
"recipe.jp_warabi_mochi.step5.body" = "Chill the warabi mochi until cool and set enough to cut cleanly while staying soft and springy.";
"recipe.jp_warabi_mochi.step5.title" = "Chill until firm";
"recipe.jp_warabi_mochi.step6.body" = "Mix the %i4 with %i5 and %i6 in a bowl until evenly combined.";
"recipe.jp_warabi_mochi.step6.title" = "Make the kinako coating";
"recipe.jp_warabi_mochi.step7.body" = "Simmer %i7, %i8, and %i9 until dissolved and lightly thickened, then cool to a pourable syrup.";
"recipe.jp_warabi_mochi.step7.title" = "Make the kuromitsu syrup";
"recipe.jp_warabi_mochi.step8.body" = "Cut the chilled warabi mochi into bite-size pieces, briefly handle with wet hands or dip in ice water if sticking, then coat generously with the kinako mixture.";
"recipe.jp_warabi_mochi.step8.title" = "Cut and coat the mochi";
"recipe.jp_warabi_mochi.step9.body" = "Arrange the coated pieces on plates and serve with kuromitsu syrup drizzled over or alongside.";
"recipe.jp_warabi_mochi.step9.title" = "Serve chilled";
