"recipe.pt_arroz_de_pato.drink.body" = "A medium-bodied Portuguese red such as a Douro or Dão pairs well with the smoky chouriço and rich duck, while a structured white like Encruzado also works if you prefer white. Non-alcoholic pairing: sparkling water or a chilled citrus iced tea.";
"recipe.pt_arroz_de_pato.drink.summary" = "Red wine (Douro)";
"recipe.pt_arroz_de_pato.info" = "Arroz de Pato is a traditional Portuguese baked rice dish made by simmering duck with aromatics to create a rich broth, then cooking the rice in that broth and finishing it in the oven with shredded duck and slices of chouriço on top. It is served hot, family-style, with a crisp top and deeply savory, duck-scented rice.";
"recipe.pt_arroz_de_pato.info.summary" = "Oven-baked duck rice";
"recipe.pt_arroz_de_pato.name" = "Duck rice";
"recipe.pt_arroz_de_pato.step1.body" = "Place the %i1 in a large pot with %i2, %i3, %i4, %i5, %i7, %i6, %i10, %i13, %i14, and %i12. Bring to a gentle simmer, skimming any foam from the surface.";
"recipe.pt_arroz_de_pato.step1.title" = "Start the broth base";
"recipe.pt_arroz_de_pato.step2.body" = "Cover and cook at a low simmer until the duck is tender and pulls easily from the bone. Remove the duck, chouriço, and bacon with a slotted spoon.";
"recipe.pt_arroz_de_pato.step2.title" = "Simmer the duck";
"recipe.pt_arroz_de_pato.step3.body" = "Strain the cooking liquid into a bowl to remove aromatics and keep the hot broth. Shred the duck meat, discarding skin and bones. Slice part of the chouriço for topping and chop the bacon.";
"recipe.pt_arroz_de_pato.step3.title" = "Strain and prep meats";
"recipe.pt_arroz_de_pato.step4.body" = "In a saucepan, warm %i9 over medium heat and cook chopped onion until soft. Add garlic and cook briefly, then stir in %i8 to lightly toast.";
"recipe.pt_arroz_de_pato.step4.title" = "Build the rice base";
"recipe.pt_arroz_de_pato.step5.body" = "Add %i11 and bay leaf, then ladle in the hot broth until the rice is just covered. Simmer gently, adding more broth as needed, until the rice is mostly cooked and still slightly firm.";
"recipe.pt_arroz_de_pato.step5.title" = "Cook rice in broth";
"recipe.pt_arroz_de_pato.step6.body" = "Fold the shredded duck and the chopped chouriço and bacon through the rice so everything is evenly distributed. Taste and adjust seasoning.";
"recipe.pt_arroz_de_pato.step6.title" = "Combine duck and rice";
"recipe.pt_arroz_de_pato.step7.body" = "Spread the rice mixture in a baking dish and smooth the top. Arrange the reserved chouriço slices over the surface.";
"recipe.pt_arroz_de_pato.step7.title" = "Assemble for baking";
"recipe.pt_arroz_de_pato.step8.body" = "Bake until the top is set and lightly crisped and the chouriço edges are sizzling.";
"recipe.pt_arroz_de_pato.step8.title" = "Bake and crisp the top";
"recipe.pt_arroz_de_pato.step9.body" = "Let the dish rest briefly, then serve hot, scooping through the crisp top into the moist duck rice beneath.";
"recipe.pt_arroz_de_pato.step9.title" = "Rest and serve";
