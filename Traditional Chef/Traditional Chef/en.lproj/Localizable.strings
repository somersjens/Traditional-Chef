"recipe.hu_hideg_gyumolcsleves.drink.body" = "Pair with a lightly sweet white such as Tokaji late harvest that echoes fruit without overwhelming the tartness. A fruit cider can also work well. For a non-alcoholic option, serve sparkling water or chilled mint tea.";
"recipe.hu_hideg_gyumolcsleves.drink.summary" = "Sweet wine (Tokaji)";
"recipe.hu_hideg_gyumolcsleves.info" = "Hideg gyümölcsleves is a traditional Hungarian cold fruit soup, most commonly made with sour cherries simmered briefly with sugar, cinnamon, and lemon, then chilled and finished with sour cream for a lightly creamy, refreshing starter in summer. It is served very cold, often as a first course, balancing sweet-tart fruit with gentle spice.";
"recipe.hu_hideg_gyumolcsleves.info.summary" = "Summer chilled fruit soup";
"recipe.hu_hideg_gyumolcsleves.name" = "Cold fruit soup";
"recipe.hu_hideg_gyumolcsleves.step1.body" = "Combine %i1 with %i2, %i3, %i4, %i5 zest and juice, and a pinch of %i6 and bring to a gentle simmer.";
"recipe.hu_hideg_gyumolcsleves.step1.title" = "Start the soup";
"recipe.hu_hideg_gyumolcsleves.step2.body" = "Simmer just until the fruit releases its juices and is tender but not falling apart.";
"recipe.hu_hideg_gyumolcsleves.step2.title" = "Simmer briefly";
"recipe.hu_hideg_gyumolcsleves.step3.body" = "Mix %i7 with %i8 to a smooth slurry, stir it into the simmering soup, and cook briefly until lightly thickened.";
"recipe.hu_hideg_gyumolcsleves.step3.title" = "Thicken lightly";
"recipe.hu_hideg_gyumolcsleves.step4.body" = "Whisk a ladle of hot soup into %i9 until smooth, then stir it back into the pot off the heat.";
"recipe.hu_hideg_gyumolcsleves.step4.title" = "Temper the sour cream";
"recipe.hu_hideg_gyumolcsleves.step5.body" = "Cool, then chill until very cold so the soup is refreshing and the flavours meld.";
"recipe.hu_hideg_gyumolcsleves.step5.title" = "Chill thoroughly";
"recipe.hu_hideg_gyumolcsleves.step6.body" = "Serve cold and enjoy.";
"recipe.hu_hideg_gyumolcsleves.step6.title" = "Serve the soup";
