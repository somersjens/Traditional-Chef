"recipe.dz_tajine_zitoun.drink.body" = "A crisp, dry white like Vermentino complements the briny olives and gentle spices while keeping the dish bright. If you prefer red, choose a light-bodied red served slightly cool. Non-alcoholic pairing: mint tea or sparkling water with lemon.";
"recipe.dz_tajine_zitoun.drink.summary" = "White wine (Vermentino)";
"recipe.dz_tajine_zitoun.info" = "Tajine Zitoun is a traditional Algerian chicken stew in a delicate, aromatic white sauce scented with onion and spices, finished with green olives and often carrots, simmered until the chicken is tender and the broth is silky. It is commonly served as a family main dish, traditionally accompanied by crusty Algerian bread to soak up the flavorful sauce.";
"recipe.dz_tajine_zitoun.info.summary" = "Chicken with olives";
"recipe.dz_tajine_zitoun.name" = "Chicken olive tagine";
"recipe.dz_tajine_zitoun.step1.body" = "Mix %i13, %i14, %i15, and %i16. Add %i17, then add %i18 gradually and knead until smooth and elastic.";
"recipe.dz_tajine_zitoun.step1.title" = "Make the bread dough";
"recipe.dz_tajine_zitoun.step10.body" = "Serve tajine zitoun hot with bread for dipping.";
"recipe.dz_tajine_zitoun.step10.title" = "Serve";
"recipe.dz_tajine_zitoun.step2.body" = "Cover the dough and let it rise until doubled and airy.";
"recipe.dz_tajine_zitoun.step2.title" = "Proof the dough";
"recipe.dz_tajine_zitoun.step3.body" = "Chop the %i2, mince the %i3, and slice the %i4. Cut the %i6.";
"recipe.dz_tajine_zitoun.step3.title" = "Prep aromatics and carrots";
"recipe.dz_tajine_zitoun.step4.body" = "Boil the %i5 briefly, then drain and rinse to reduce bitterness and excess brine.";
"recipe.dz_tajine_zitoun.step4.title" = "Blanch the olives";
"recipe.dz_tajine_zitoun.step5.body" = "In a heavy pot, warm %i7 and %i8, cook onion until softened, add garlic briefly, then stir in %i9, %i10, and %i11.";
"recipe.dz_tajine_zitoun.step5.title" = "Start the stew base";
"recipe.dz_tajine_zitoun.step6.body" = "Add %i1, carrots, and %i12. Bring to a gentle simmer, cover partially, and cook until the chicken is tender.";
"recipe.dz_tajine_zitoun.step6.title" = "Simmer the chicken and carrots";
"recipe.dz_tajine_zitoun.step7.body" = "Turn the dough out, shape into a round loaf, place on a baking tray, and cover to rise again.";
"recipe.dz_tajine_zitoun.step7.title" = "Shape the bread";
"recipe.dz_tajine_zitoun.step8.body" = "Bake until well risen and browned, then cool slightly before slicing.";
"recipe.dz_tajine_zitoun.step8.title" = "Bake the bread";
"recipe.dz_tajine_zitoun.step9.body" = "Add the blanched olives and simmer until the sauce is silky and the olives are heated through. Finish with lemon juice and adjust salt if needed.";
"recipe.dz_tajine_zitoun.step9.title" = "Finish with olives and lemon";
