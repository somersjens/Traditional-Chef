"recipe.tw_oyster_omelet.step10.body" = "Serve the oyster omelets immediately while the texture is chewy and the sauce is warm.";
"recipe.tw_oyster_omelet.step10.title" = "Serve hot";
"recipe.tw_oyster_omelet.step2.body" = "Whisk the %i2 with %i3 until smooth, then season with %i7 and %i8.";
