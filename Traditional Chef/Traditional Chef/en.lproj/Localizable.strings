"recipe.gb_cottage_pie.drink.body" = "A light claret or a malty brown ale pairs well with the rich beef filling and potato topping. For a non-alcoholic option, serve sparkling water or strong black tea.";
"recipe.gb_cottage_pie.drink.summary" = "Claret";
"recipe.gb_cottage_pie.info" = "A traditional British cottage pie made with minced beef simmered with onion, carrot, herbs, stock, and Worcestershire sauce, topped with mashed potato and baked until golden. It is a classic family main course served hot, often with green peas or cabbage.";
"recipe.gb_cottage_pie.info.summary" = "Beef potato pie";
"recipe.gb_cottage_pie.name" = "Cottage pie";
"recipe.gb_cottage_pie.step1.body" = "Finely chop the %i2, %i3, and %i4, and set aside the %i15 and %i12 for later.";
"recipe.gb_cottage_pie.step1.title" = "Prepare vegetables";
"recipe.gb_cottage_pie.step10.body" = "Use a fork to roughen the potato surface so it browns and crisps in the oven.";
"recipe.gb_cottage_pie.step10.title" = "Rough the topping";
"recipe.gb_cottage_pie.step11.body" = "Bake until the filling is bubbling at the edges and the potato topping is golden brown.";
"recipe.gb_cottage_pie.step11.title" = "Bake pie";
"recipe.gb_cottage_pie.step12.body" = "Let the pie stand briefly before serving so the filling settles and portions hold their shape.";
"recipe.gb_cottage_pie.step12.title" = "Rest and serve";
"recipe.gb_cottage_pie.step2.body" = "Peel and cut the %i16, place in a saucepan with %i21, bring to the boil, and cook until tender.";
"recipe.gb_cottage_pie.step2.title" = "Boil potatoes";
"recipe.gb_cottage_pie.step3.body" = "Cook the %i1 in a large frying pan until well browned, breaking it up and allowing moisture to evaporate.";
"recipe.gb_cottage_pie.step3.title" = "Brown beef";
"recipe.gb_cottage_pie.step4.body" = "Add the %i5, onion, carrot, and celery to the beef and cook until softened and lightly coloured.";
"recipe.gb_cottage_pie.step4.title" = "Cook vegetables";
"recipe.gb_cottage_pie.step5.body" = "Stir in the %i6 and %i7 and cook briefly so the flour loses its raw taste.";
"recipe.gb_cottage_pie.step5.title" = "Add flour and paste";
"recipe.gb_cottage_pie.step6.body" = "Stir in the %i8 and %i9, then add %i10, %i11, %i12, half the %i13, and %i14.";
"recipe.gb_cottage_pie.step6.title" = "Add liquids and herbs";
"recipe.gb_cottage_pie.step7.body" = "Simmer until the beef filling is thick and rich, then stir in the peas and cook briefly.";
"recipe.gb_cottage_pie.step7.title" = "Simmer filling";
"recipe.gb_cottage_pie.step8.body" = "Drain the potatoes and mash with %i17, %i18, the remaining %i19, and %i20 until smooth.";
"recipe.gb_cottage_pie.step8.title" = "Mash potatoes";
"recipe.gb_cottage_pie.step9.body" = "Remove the bay and thyme from the filling, spoon the filling into the baking dish, and spread the mashed potato over the top.";
"recipe.gb_cottage_pie.step9.title" = "Assemble pie";
