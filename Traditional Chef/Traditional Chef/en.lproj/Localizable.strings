"recipe.hk_si_yau_gai.drink.body" = "A light red such as Pinot Noir or a mellow amber lager can match the sweet-savory soy glaze and tender chicken. For a non-alcoholic option, serve hot pu-erh tea or warm barley water.";
"recipe.hk_si_yau_gai.drink.summary" = "Red wine (Pinot Noir)";
"recipe.hk_si_yau_gai.info" = "A traditional Cantonese soy sauce chicken dish with a whole chicken gently poached in a fragrant soy-based master sauce until tender, then rested, chopped, and served with a glossy sauce spooned over. In Hong Kong it is commonly served with rice or noodles as a roast-meat shop favorite and family-style main dish.";
"recipe.hk_si_yau_gai.info.summary" = "Soy sauce chicken";
"recipe.hk_si_yau_gai.name" = "Soy sauce chicken";
"recipe.hk_si_yau_gai.step1.body" = "Trim excess fat from the %i1, rinse and pat dry. Slice the %i7 and tie or bundle the %i8 for easy removal.";
"recipe.hk_si_yau_gai.step1.title" = "Prepare the chicken and aromatics";
"recipe.hk_si_yau_gai.step10.body" = "Spoon the hot finishing sauce over the chicken and serve immediately with rice or noodles.";
"recipe.hk_si_yau_gai.step10.title" = "Sauce and serve";
"recipe.hk_si_yau_gai.step2.body" = "In a large pot, combine %i2, %i3, %i4, %i5, %i6, ginger, spring onion, %i9, and %i10, then bring to a gentle boil until the sugar dissolves.";
"recipe.hk_si_yau_gai.step2.title" = "Build the poaching sauce";
"recipe.hk_si_yau_gai.step3.body" = "Reduce to a gentle simmer and carefully lower the chicken into the sauce, breast side down, then ladle hot sauce over any exposed parts.";
"recipe.hk_si_yau_gai.step3.title" = "Lower in the chicken";
"recipe.hk_si_yau_gai.step4.body" = "Keep the liquid at a gentle simmer, cover, and poach while turning the chicken once or twice so it colors evenly and cooks through without toughening.";
"recipe.hk_si_yau_gai.step4.title" = "Poach gently and turn";
"recipe.hk_si_yau_gai.step5.body" = "Turn off the heat and leave the chicken in the hot sauce to finish gently and absorb flavor.";
"recipe.hk_si_yau_gai.step5.title" = "Rest in the sauce";
"recipe.hk_si_yau_gai.step6.body" = "Lift out the chicken, let excess sauce drip off, and rest it skin-side up so the surface sets and stays glossy.";
"recipe.hk_si_yau_gai.step6.title" = "Remove and hang dry briefly";
"recipe.hk_si_yau_gai.step7.body" = "Strain some of the poaching liquid into a small saucepan and simmer until slightly concentrated.";
"recipe.hk_si_yau_gai.step7.title" = "Strain and reduce the sauce";
"recipe.hk_si_yau_gai.step8.body" = "Mix %i11 with %i12 for slurry, stir it into the reduced sauce until lightly glossy, then finish with %i13.";
"recipe.hk_si_yau_gai.step8.title" = "Thicken the finishing sauce";
"recipe.hk_si_yau_gai.step9.body" = "Cut the chicken into serving pieces in the traditional chop style and arrange on a platter.";
"recipe.hk_si_yau_gai.step9.title" = "Chop the chicken";
