"recipe.mx_barbacoa.drink.body" = "A fruity, medium-bodied red like Garnacha (Grenache) or a chilled dry rosé stands up to the rich lamb and smoky salsa. A crisp Mexican lager also pairs well. For a non-alcoholic option, serve agua de jamaica or sparkling water with lime.";
"recipe.mx_barbacoa.drink.summary" = "Red wine (Garnacha)";
"recipe.mx_barbacoa.info" = "Barbacoa de borrego is a traditional specialty of central Mexico, especially Hidalgo, where lamb is slow-cooked until falling-apart tender, ideally wrapped in maguey leaves and cooked to yield both rich meat and a flavorful consomé. It is served hot in tacos with fresh corn tortillas and simple toppings like onion, cilantro, lime, and salsa borracha.";
"recipe.mx_barbacoa.info.summary" = "Pit-cooked lamb tacos";
"recipe.mx_barbacoa.name" = "Lamb barbacoa";
