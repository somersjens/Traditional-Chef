"recipe.hk_siu_ngo.drink.body" = "A light red such as Pinot Noir or a malty amber lager pairs well with the rich goose fat and caramelized skin. For a non-alcoholic option, serve hot pu-erh tea or warm barley water.";
"recipe.hk_siu_ngo.drink.summary" = "Red wine (Pinot Noir)";
"recipe.hk_siu_ngo.info" = "A traditional Cantonese siu mei roast goose with lacquered skin, rich meat, and aromatic five-spice seasoning. In Hong Kong it is roasted until deeply browned, chopped to order, and served hot with plum sauce, often with rice or noodles.";
"recipe.hk_siu_ngo.info.summary" = "Lacquered roast goose";
"recipe.hk_siu_ngo.name" = "Roast goose";
"recipe.hk_siu_ngo.step1.body" = "Remove any remaining pin feathers and excess fat, rinse the %i1 inside and out, and pat very dry.";
"recipe.hk_siu_ngo.step1.title" = "Clean and trim the goose";
"recipe.hk_siu_ngo.step10.body" = "Brush the hot goose lightly with remaining glaze for a traditional glossy finish.";
"recipe.hk_siu_ngo.step10.title" = "Brush for shine";
"recipe.hk_siu_ngo.step11.body" = "Let the goose rest so the juices settle and the skin remains crisp.";
"recipe.hk_siu_ngo.step11.title" = "Rest the roast goose";
"recipe.hk_siu_ngo.step12.body" = "Chop the goose into serving pieces and serve hot with %i15 on the side.";
"recipe.hk_siu_ngo.step12.title" = "Chop and serve";
"recipe.hk_siu_ngo.step2.body" = "Pound or mince the %i2, %i3, and %i4, then mix with %i5, %i6, %i7, %i8, and %i9 into a fragrant paste.";
"recipe.hk_siu_ngo.step2.title" = "Make the cavity seasoning";
"recipe.hk_siu_ngo.step3.body" = "Rub the seasoning paste thoroughly inside the cavity, avoiding the outside skin, then secure the cavity opening with kitchen twine.";
"recipe.hk_siu_ngo.step3.title" = "Season the goose";
"recipe.hk_siu_ngo.step4.body" = "Warm the %i10 with %i11, %i12, and %i13 until fully dissolved and smooth.";
"recipe.hk_siu_ngo.step4.title" = "Prepare the skin glaze";
"recipe.hk_siu_ngo.step5.body" = "Ladle the hot glaze all over the goose skin evenly so the surface tightens and is fully coated.";
"recipe.hk_siu_ngo.step5.title" = "Scald and glaze the skin";
"recipe.hk_siu_ngo.step6.body" = "Hang the goose in a cool airy place or uncovered in the refrigerator until the skin is dry and tacky.";
"recipe.hk_siu_ngo.step6.title" = "Air-dry the goose";
"recipe.hk_siu_ngo.step7.body" = "Set the goose on a roasting rack over a tray, add %i14 to the tray, and bring the goose closer to room temperature.";
"recipe.hk_siu_ngo.step7.title" = "Prepare for roasting";
"recipe.hk_siu_ngo.step8.body" = "Roast at high heat until the skin starts browning and the fat begins to render.";
"recipe.hk_siu_ngo.step8.title" = "Roast to color the skin";
"recipe.hk_siu_ngo.step9.body" = "Lower the heat and continue roasting until the goose is deeply browned, the skin is crisp, and the meat is cooked through, turning once if needed for even color.";
"recipe.hk_siu_ngo.step9.title" = "Roast until cooked through";
