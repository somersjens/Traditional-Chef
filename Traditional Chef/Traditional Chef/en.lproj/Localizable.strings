"recipe.hk_siu_yuk.drink.body" = "A light lager or dry cider pairs well with the rich pork belly and crisp crackling. For a non-alcoholic option, serve hot pu-erh tea or warm barley water.";
"recipe.hk_siu_yuk.drink.summary" = "Beer (Lager)";
"recipe.hk_siu_yuk.info" = "A traditional Cantonese siu mei roast pork belly with blistered crackling skin, layered fat, and juicy meat seasoned simply and roasted until crisp. In Hong Kong it is commonly chopped into bite-size pieces and served hot with rice, noodles, or as part of a shared roast-meat platter.";
"recipe.hk_siu_yuk.info.summary" = "Crispy roast pork belly";
"recipe.hk_siu_yuk.name" = "Siu yuk";
"recipe.hk_siu_yuk.step1.body" = "Bring %i11 to a boil in a large pot, add the %i1 skin-side down, then fully submerge, and blanch briefly until the skin tightens.";
"recipe.hk_siu_yuk.step1.title" = "Blanch the pork belly";
"recipe.hk_siu_yuk.step10.body" = "Return the pork to high heat and roast until the skin blisters and crackles evenly.";
"recipe.hk_siu_yuk.step10.title" = "Roast to blister the skin";
"recipe.hk_siu_yuk.step11.body" = "Let the roast pork rest so the juices settle and the crackling firms.";
"recipe.hk_siu_yuk.step11.title" = "Rest before chopping";
"recipe.hk_siu_yuk.step12.body" = "Chop the siu yuk into bite-size pieces and serve hot with rice or noodles.";
"recipe.hk_siu_yuk.step12.title" = "Chop and serve";
"recipe.hk_siu_yuk.step2.body" = "Remove the pork belly, pat it dry, score the meat side in shallow cuts without cutting through the skin, and pierce the skin all over with a skewer.";
"recipe.hk_siu_yuk.step2.title" = "Dry and prepare the pork";
"recipe.hk_siu_yuk.step3.body" = "Mix %i2, %i3, %i4, %i5, %i6, %i7, and crushed %i8 into a paste, then rub it evenly over the meat side only.";
"recipe.hk_siu_yuk.step3.title" = "Season the meat side";
"recipe.hk_siu_yuk.step4.body" = "Brush the skin with %i10 and keep the seasoning off the skin, then place the pork skin-side up on a tray.";
"recipe.hk_siu_yuk.step4.title" = "Treat the skin";
"recipe.hk_siu_yuk.step5.body" = "Leave the pork uncovered in the refrigerator until the skin is very dry for proper blistering.";
"recipe.hk_siu_yuk.step5.title" = "Dry the skin overnight";
"recipe.hk_siu_yuk.step6.body" = "Rub or pack %i9 over the skin in an even layer to protect it during the first roast.";
"recipe.hk_siu_yuk.step6.title" = "Salt the skin before roasting";
"recipe.hk_siu_yuk.step7.body" = "Place the pork on a rack over a roasting tray, add %i12 to the tray, and position the pork skin-side up.";
"recipe.hk_siu_yuk.step7.title" = "Prepare the roasting setup";
"recipe.hk_siu_yuk.step8.body" = "Roast until the meat cooks through and fat renders while the salt crust hardens on top.";
"recipe.hk_siu_yuk.step8.title" = "Roast the pork belly";
"recipe.hk_siu_yuk.step9.body" = "Take out the pork, scrape off the hardened salt crust, and brush the skin clean.";
"recipe.hk_siu_yuk.step9.title" = "Remove salt crust";
