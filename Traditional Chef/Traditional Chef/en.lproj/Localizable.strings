"recipe.no_tilslorte_bondepiker.drink.body" = "A light dessert wine such as late harvest Riesling pairs well with the sweet apples and cream. A good non-alcoholic option is black coffee or chilled sparkling apple drink.";
"recipe.no_tilslorte_bondepiker.drink.summary" = "Dessert wine (Riesling)";
"recipe.no_tilslorte_bondepiker.info" = "Tilslorte Bondepiker is a classic Norwegian layered dessert of stewed apples, sweetened whipped cream, and buttery toasted breadcrumbs. It is served chilled or at cool room temperature as a traditional family dessert, especially in autumn and during festive meals.";
"recipe.no_tilslorte_bondepiker.info.summary" = "Apple cream layers";
"recipe.no_tilslorte_bondepiker.name" = "Veiled peasant girls";
"recipe.no_tilslorte_bondepiker.step1.body" = "Peel, core, and slice %i1. Place them in the saucepan with %i2, %i3, and %i4.";
"recipe.no_tilslorte_bondepiker.step1.title" = "Prepare the apples";
"recipe.no_tilslorte_bondepiker.step2.body" = "Simmer the apples gently until soft and broken down into a thick compote, then let it cool.";
"recipe.no_tilslorte_bondepiker.step2.title" = "Cook the apple compote";
"recipe.no_tilslorte_bondepiker.step3.body" = "Melt %i6 in the frying pan, add %i5 and %i7, and cook while stirring until the mixture is golden and crisp. Let it cool completely.";
"recipe.no_tilslorte_bondepiker.step3.title" = "Toast the breadcrumbs";
"recipe.no_tilslorte_bondepiker.step4.body" = "Whip %i8 with %i9 until soft and airy.";
"recipe.no_tilslorte_bondepiker.step4.title" = "Whip the cream";
"recipe.no_tilslorte_bondepiker.step5.body" = "Spoon the apple compote, whipped cream, and toasted breadcrumbs into serving glasses or a bowl in repeating layers, finishing with breadcrumbs on top.";
"recipe.no_tilslorte_bondepiker.step5.title" = "Layer the dessert";
"recipe.no_tilslorte_bondepiker.step6.body" = "Chill the dessert so the layers settle and the dessert is served cold.";
"recipe.no_tilslorte_bondepiker.step6.title" = "Chill before serving";
