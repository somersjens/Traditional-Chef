"recipe.th_miang_kham.step1.title" = "Prepare the leaves and fillings";
"recipe.th_miang_kham.step2.body" = "Finely dice or grate the %i2, then dry-toast it in a frying pan while stirring until fragrant and golden brown. Set aside to cool.";
"recipe.th_miang_kham.step2.title" = "Toast the coconut";
"recipe.th_miang_kham.step3.body" = "Rinse and dry the %i4 if needed, then chop into small pieces suitable for wrapping.";
"recipe.th_miang_kham.step3.title" = "Prepare the dried shrimp for filling";
"recipe.th_miang_kham.step4.body" = "Slice the %i13, %i14, and %i15, then pound them with the sauce %i12 in a mortar and pestle until coarse and aromatic.";
"recipe.th_miang_kham.step4.title" = "Pound sauce aromatics";
