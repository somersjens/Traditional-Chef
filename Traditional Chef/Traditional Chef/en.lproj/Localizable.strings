"recipe.gb_toad_in_the_hole.drink.body" = "A malty British ale or dry cider pairs well with the sausages and onion gravy. For a non-alcoholic option, serve sparkling water or strong black tea.";
"recipe.gb_toad_in_the_hole.drink.summary" = "Beer (Ale)";
"recipe.gb_toad_in_the_hole.info" = "A traditional British dish of pork sausages baked in a Yorkshire pudding batter until deeply risen and golden, then served immediately with onion gravy. It is a classic family supper and pub-style comfort meal, especially in cooler weather.";
"recipe.gb_toad_in_the_hole.info.summary" = "Sausages in batter";
"recipe.gb_toad_in_the_hole.name" = "Toad in the hole";
"recipe.gb_toad_in_the_hole.step1.body" = "Whisk the %i2, %i3, %i4, %i5, and half the %i6 into a smooth batter, then set aside to rest while the oven heats.";
"recipe.gb_toad_in_the_hole.step1.title" = "Make batter";
"recipe.gb_toad_in_the_hole.step2.body" = "Put the %i1 and %i7 in a roasting tin and cook in the hot oven until the sausages are browned and the fat is hot.";
"recipe.gb_toad_in_the_hole.step2.title" = "Brown sausages";
"recipe.gb_toad_in_the_hole.step3.body" = "Pour the rested batter around the hot sausages in the tin and return immediately to the oven.";
"recipe.gb_toad_in_the_hole.step3.title" = "Pour batter";
"recipe.gb_toad_in_the_hole.step4.body" = "Bake without opening the oven until the batter is well risen, crisp, and deep golden.";
"recipe.gb_toad_in_the_hole.step4.title" = "Bake until risen";
"recipe.gb_toad_in_the_hole.step5.body" = "While the dish bakes, slice the %i8 and cook them gently in %i9 until soft and well coloured.";
"recipe.gb_toad_in_the_hole.step5.title" = "Cook onions";
"recipe.gb_toad_in_the_hole.step6.body" = "Stir the %i10 into the onions and cook briefly, then gradually stir in the %i11 and %i12.";
"recipe.gb_toad_in_the_hole.step6.title" = "Start gravy";
"recipe.gb_toad_in_the_hole.step7.body" = "Add %i13, the remaining %i14, and %i15, then simmer until the onion gravy is smooth and rich.";
"recipe.gb_toad_in_the_hole.step7.title" = "Simmer gravy";
"recipe.gb_toad_in_the_hole.step8.body" = "Bring the toad in the hole straight to the table and serve immediately with hot onion gravy.";
"recipe.gb_toad_in_the_hole.step8.title" = "Serve";
