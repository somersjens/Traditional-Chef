"recipe.pt_bacalhau_a_bras.drink.body" = "A fresh Portuguese white such as Vinho Verde (Loureiro) or a dry Arinto matches the briny cod and rich eggs and keeps the dish feeling light. If you prefer red, choose a very light, low-tannin red served slightly cool. Non-alcoholic pairing: sparkling water with lemon or a crisp alcohol-free lager.";
"recipe.pt_bacalhau_a_bras.drink.summary" = "White wine (Vinho Verde)";
"recipe.pt_bacalhau_a_bras.info" = "Bacalhau a Bras is a Lisbon classic of shredded salt cod folded with softly sautéed onions and garlic, crisp matchstick fried potatoes, and creamy eggs, finished with parsley and black olives. It is served hot as a comforting main dish, ideally with a soft, just-set texture and a little crunch from the potatoes and olives.";
"recipe.pt_bacalhau_a_bras.info.summary" = "Creamy cod scramble";
"recipe.pt_bacalhau_a_bras.name" = "Bacalhau à Brás";
"recipe.pt_bacalhau_a_bras.step1.body" = "Rinse the %i1, then soak it in plenty of water, changing the water a few times, until the fish is properly desalinated.";
"recipe.pt_bacalhau_a_bras.step1.title" = "Soak the cod";
"recipe.pt_bacalhau_a_bras.step2.body" = "Poach the soaked cod gently in water with %i6 until it flakes. Drain, remove the skin and bones, and shred it into fine flakes.";
"recipe.pt_bacalhau_a_bras.step2.title" = "Poach and shred";
"recipe.pt_bacalhau_a_bras.step3.body" = "Peel the %i2 and cut them into fine matchsticks. Rinse quickly, drain well, and dry thoroughly so they fry crisp.";
"recipe.pt_bacalhau_a_bras.step3.title" = "Prepare the potatoes";
"recipe.pt_bacalhau_a_bras.step4.body" = "Heat %i3 and fry the potatoes in batches until golden and crisp. Drain on paper towels and lightly season.";
"recipe.pt_bacalhau_a_bras.step4.title" = "Fry the potatoes";
"recipe.pt_bacalhau_a_bras.step5.body" = "Warm %i8 in a large frying pan over medium heat. Add %i4 and cook until soft, then add %i5 and cook until fragrant.";
"recipe.pt_bacalhau_a_bras.step5.title" = "Soften onion and garlic";
"recipe.pt_bacalhau_a_bras.step6.body" = "Add the shredded cod to the pan and toss until heated through and well coated with the onion and garlic.";
"recipe.pt_bacalhau_a_bras.step6.title" = "Warm the cod";
"recipe.pt_bacalhau_a_bras.step7.body" = "Add the fried potatoes and gently fold so they soften slightly while keeping some texture.";
"recipe.pt_bacalhau_a_bras.step7.title" = "Fold in potatoes";
"recipe.pt_bacalhau_a_bras.step8.body" = "Beat %i7 and season with %i11 and %i12. Remove the pan from direct heat, pour in the eggs, and stir continuously until creamy and just set.";
"recipe.pt_bacalhau_a_bras.step8.title" = "Set the eggs";
"recipe.pt_bacalhau_a_bras.step9.body" = "Transfer to a serving platter, sprinkle with chopped %i9, scatter %i10 over the top, and serve immediately.";
"recipe.pt_bacalhau_a_bras.step9.title" = "Garnish and serve";
