"recipe.ve_quesillo.drink.body" = "Serve with a light sweet dessert wine or demi-sec sparkling wine that complements the caramel notes without overwhelming the custard. For a non-alcoholic option, serve black coffee or hot black tea.";
"recipe.ve_quesillo.drink.summary" = "Sweet dessert wine";
"recipe.ve_quesillo.info" = "Quesillo is the traditional Venezuelan caramel custard made with whole eggs, condensed milk, milk, vanilla, and a layer of caramel. It is baked gently in a water bath until just set, then chilled and unmolded so the caramel runs over the custard, and it is commonly served cold for family meals and celebrations.";
"recipe.ve_quesillo.info.summary" = "Caramel custard classic";
"recipe.ve_quesillo.name" = "Quesillo";
