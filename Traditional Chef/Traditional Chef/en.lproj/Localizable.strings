"recipe.sr_roti_kip.step2.title" = "Prepare the ingredients";
"recipe.sr_roti_kip.step3.body" = "Heat part of %i15 in a large pot, add the onion, garlic, tomato, chili, %i13, %i14, %i19, and part of %i20, and cook until the mixture is fragrant and darkened slightly.";
"recipe.sr_roti_kip.step3.title" = "Start the curry base";
"recipe.sr_roti_kip.step4.body" = "Add the chicken and turn it well in the masala base until it is coated and lightly colored.";
"recipe.sr_roti_kip.step4.title" = "Cook the chicken";
"recipe.sr_roti_kip.step5.body" = "Add the potatoes, %i16, and %i17, bring to a boil, then lower the heat and simmer until the potatoes are nearly tender and the sauce is well flavored.";
"recipe.sr_roti_kip.step5.title" = "Simmer the potatoes";
"recipe.sr_roti_kip.step6.body" = "Add the kouseband and cook until it is tender but still holds its shape. Adjust the seasoning with the remaining salt.";
"recipe.sr_roti_kip.step6.title" = "Cook the kouseband";
"recipe.sr_roti_kip.step7.body" = "Divide the dough into equal pieces, roll them into thin rounds, and cook them one by one in a lightly oiled hot frying pan until speckled and cooked through on both sides.";
"recipe.sr_roti_kip.step7.title" = "Cook the roti plates";
"recipe.sr_roti_kip.step8.body" = "Peel the eggs and halve them for serving.";
"recipe.sr_roti_kip.step8.title" = "Finish the eggs";
"recipe.sr_roti_kip.step9.body" = "Place a roti plate on each plate and serve it with the chicken, potatoes, kouseband, sauce, and egg.";
"recipe.sr_roti_kip.step9.title" = "Serve";
