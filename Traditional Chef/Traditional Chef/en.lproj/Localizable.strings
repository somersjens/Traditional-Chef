"recipe.cl_empanadas_de_pino.drink.body" = "Pair with a medium-bodied Chilean Carménère or Merlot that complements the beef and sweet-savory filling. A dry rosé also works well. Non-alcoholic option: sparkling water with lemon or a chilled black tea with citrus.";
"recipe.cl_empanadas_de_pino.drink.summary" = "Red wine (Carménère)";
"recipe.cl_empanadas_de_pino.info" = "Empanadas de pino are Chile’s classic baked empanadas, filled with savory pino: onions slowly cooked down, seasoned beef, and a traditional set of additions—black olives, hard-boiled egg, and raisins—then enclosed in a wheat dough enriched with lard. They are baked until deeply golden and are especially traditional for celebrations, served hot or warm as a hearty hand pie.";
"recipe.cl_empanadas_de_pino.info.summary" = "Baked pino empanadas";
"recipe.cl_empanadas_de_pino.name" = "Empanadas de pino";
"recipe.cl_empanadas_de_pino.step1.body" = "Boil %i12 until fully set, cool in cold water, peel, and quarter. Set aside for filling.";
"recipe.cl_empanadas_de_pino.step1.title" = "Cook the hard-boiled eggs";
"recipe.cl_empanadas_de_pino.step10.body" = "Bake until deeply golden and crisp on the outside and hot through.";
"recipe.cl_empanadas_de_pino.step10.title" = "Bake";
"recipe.cl_empanadas_de_pino.step11.body" = "Let rest briefly so the filling settles, then serve warm.";
"recipe.cl_empanadas_de_pino.step11.title" = "Serve";
"recipe.cl_empanadas_de_pino.step2.body" = "Heat %i5 in a skillet and cook %i6 with %i7 over medium-low heat until very soft and translucent, stirring often so they sweeten without browning.";
"recipe.cl_empanadas_de_pino.step2.title" = "Start the onion base";
"recipe.cl_empanadas_de_pino.step3.body" = "Stir in %i9, %i11, %i8, and a little more salt as needed so the onion base is well seasoned.";
"recipe.cl_empanadas_de_pino.step3.title" = "Season the pino";
"recipe.cl_empanadas_de_pino.step4.body" = "Add %i10 and cook while breaking it up until no longer pink and the mixture is cohesive and savory.";
"recipe.cl_empanadas_de_pino.step4.title" = "Cook the beef";
"recipe.cl_empanadas_de_pino.step5.body" = "Cool the filling completely, then refrigerate so it firms up for clean, traditional empanada assembly.";
"recipe.cl_empanadas_de_pino.step5.title" = "Chill the pino";
"recipe.cl_empanadas_de_pino.step6.body" = "Mix %i1 and %i2, rub in %i3 until crumbly, then add %i4 gradually and knead until smooth and elastic. Rest the dough covered.";
"recipe.cl_empanadas_de_pino.step6.title" = "Make the dough";
"recipe.cl_empanadas_de_pino.step7.body" = "Roll the dough to an even thickness and cut into large rounds suitable for stuffing and folding.";
"recipe.cl_empanadas_de_pino.step7.title" = "Roll and cut discs";
"recipe.cl_empanadas_de_pino.step8.body" = "Place a portion of pino on each disc, then add a few %i14, %i13, and a piece of hard-boiled egg. Fold into the traditional rectangular shape and seal firmly, pressing edges with a fork.";
"recipe.cl_empanadas_de_pino.step8.title" = "Fill and shape";
"recipe.cl_empanadas_de_pino.step9.body" = "Place on a lined baking sheet. Brush with %i15 and make a small steam vent on top of each empanada.";
"recipe.cl_empanadas_de_pino.step9.title" = "Brush and vent";
