"recipe.co_sancocho.step2.title" = "Start the broth";
"recipe.co_sancocho.step3.body" = "Add %i1 and corn and return to a gentle simmer.";
"recipe.co_sancocho.step3.title" = "Add chicken and corn";
"recipe.co_sancocho.step4.body" = "Add cassava and plantain and simmer until they begin to soften and the broth gains body.";
"recipe.co_sancocho.step4.title" = "Cook cassava and plantain";
"recipe.co_sancocho.step5.body" = "Add potatoes and carrots and simmer until all roots are tender and the meats are fully cooked through.";
"recipe.co_sancocho.step5.title" = "Add potatoes and carrots";
"recipe.co_sancocho.step6.body" = "Cook %i16 with %i17, %i18, and %i19 until tender and fluffy, then keep warm.";
"recipe.co_sancocho.step6.title" = "Cook the rice";
"recipe.co_sancocho.step7.body" = "Stir in %i15 and cook briefly just until fragrant. Taste and adjust salt.";
"recipe.co_sancocho.step7.title" = "Finish with cilantro";
"recipe.co_sancocho.step8.body" = "Ladle sancocho into bowls, ensuring each serving gets meat, corn, and roots. Serve with rice and %i20 on the side.";
"recipe.co_sancocho.step8.title" = "Serve";
