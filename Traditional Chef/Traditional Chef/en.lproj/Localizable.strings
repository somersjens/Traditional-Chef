"recipe.us_nm_green_chile_stew.step2.title" = "Cook the aromatics";
"recipe.us_nm_green_chile_stew.step3.body" = "Stir in %i11, %i9, and %i10, then sprinkle in %i12 and cook while stirring so it coats the pork and loses its raw taste.";
"recipe.us_nm_green_chile_stew.step3.title" = "Season and toast flour";
