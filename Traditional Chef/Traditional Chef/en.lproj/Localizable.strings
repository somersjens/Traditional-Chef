"recipe.sr_saoto_soep.step5.title" = "Fry the potato sticks";
"recipe.sr_saoto_soep.step6.body" = "Soak %i13 until softened and blanch %i11 briefly so they stay fresh and crisp.";
"recipe.sr_saoto_soep.step6.title" = "Prepare the vermicelli and sprouts";
