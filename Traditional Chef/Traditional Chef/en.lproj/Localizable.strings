"recipe.lb_samak_harra.step1.title" = "Prepare the fish";
"recipe.lb_samak_harra.step2.body" = "Blend %i5 with %i6, then add %i4, %i7, %i8, %i9, %i10, and %i11. Blend until smooth, adding %i12 gradually until the sauce is creamy and spreadable.";
"recipe.lb_samak_harra.step2.title" = "Make the harra sauce";
"recipe.lb_samak_harra.step3.body" = "Spread the harra sauce evenly over the fish so it is fully covered.";
"recipe.lb_samak_harra.step3.title" = "Coat the fish";
"recipe.lb_samak_harra.step4.body" = "Bake until the fish is cooked through and the top is set and lightly browned in spots.";
