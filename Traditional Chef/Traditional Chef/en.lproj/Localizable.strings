"recipe.sr_heri_heri.drink.body" = "Serve with a light lager or a fresh dry white wine that does not overpower the salted fish and starchy roots. For a non-alcoholic option, serve chilled ginger drink or hot black tea.";
"recipe.sr_heri_heri.drink.summary" = "Beer (Lager)";
"recipe.sr_heri_heri.info" = "Heri heri is a traditional Surinamese dish with roots in the Afro-Surinamese community, built from boiled cassava, sweet potato, and plantain served with salted cod and egg. It is a hearty platter associated with remembrance and communal eating, and it is traditionally served hot as a complete meal.";
"recipe.sr_heri_heri.info.summary" = "Root vegetable platter";
"recipe.sr_heri_heri.name" = "Heri heri";
"recipe.sr_heri_heri.step1.body" = "Place %i6 in a bowl with cold water and leave it to soak so excess salt is drawn out.";
"recipe.sr_heri_heri.step1.title" = "Soak the salted cod";
"recipe.sr_heri_heri.step2.body" = "Peel %i1 and %i2 and cut them into large serving pieces. Peel %i3 and %i4 and cut them into thick pieces.";
"recipe.sr_heri_heri.step2.title" = "Prepare the roots";
"recipe.sr_heri_heri.step3.body" = "Place the cassava, sweet potato, green plantain, and ripe plantain in a large pot with %i5, bring to a boil, and cook until all are tender.";
"recipe.sr_heri_heri.step3.title" = "Boil the roots";
"recipe.sr_heri_heri.step4.body" = "Boil %i15 until firm, cool them, peel them, and halve them.";
"recipe.sr_heri_heri.step4.title" = "Cook the eggs";
"recipe.sr_heri_heri.step5.body" = "Drain the salted cod, cook it briefly in fresh water, drain again, and flake it into pieces.";
