"recipe.se_ostkaka.drink.body" = "A light dessert wine such as late harvest Riesling pairs well with the mild almond flavor and creamy texture. Coffee is also a classic match. For a non-alcoholic option, serve black coffee or hot tea.";
"recipe.se_ostkaka.drink.summary" = "Dessert wine";
"recipe.se_ostkaka.info" = "Ostkaka is a traditional Swedish baked curd dessert, especially associated with Småland. The classic version is made by curdling milk with rennet, then baking the curds with eggs, cream, sugar, almonds, and bitter almond until softly set. It is traditionally served lukewarm with whipped cream and jam at festive meals and coffee gatherings.";
"recipe.se_ostkaka.info.summary" = "Baked curd dessert";
"recipe.se_ostkaka.name" = "Ostkaka";
"recipe.se_ostkaka.step1.body" = "Whisk %i2 smooth with a little of %i1 in a bowl. Heat the remaining milk gently in a saucepan until lukewarm, then whisk in the flour mixture.";
"recipe.se_ostkaka.step1.title" = "Prepare the milk base";
"recipe.se_ostkaka.step2.body" = "Stir %i3 into %i4, add it to the warm milk, stir briefly, then leave the mixture undisturbed until it sets into soft curds.";
"recipe.se_ostkaka.step2.title" = "Curdle the milk";
"recipe.se_ostkaka.step3.body" = "Break the curds gently and pour them into a sieve lined with cheesecloth. Let the whey drain away until the curds are moist but no longer loose.";
"recipe.se_ostkaka.step3.title" = "Drain the curds";
"recipe.se_ostkaka.step4.body" = "Beat %i5 lightly, then mix them with %i6, %i7, %i8, and finely grated %i9. Fold in the drained curds until evenly combined.";
"recipe.se_ostkaka.step4.title" = "Make the batter";
"recipe.se_ostkaka.step5.body" = "Pour the mixture into an ovenproof baking dish and bake until lightly golden at the edges and softly set in the centre.";
"recipe.se_ostkaka.step5.title" = "Bake the ostkaka";
"recipe.se_ostkaka.step6.body" = "Let the ostkaka rest so it settles and becomes easier to portion while still staying traditionally lukewarm.";
"recipe.se_ostkaka.step6.title" = "Cool slightly";
"recipe.se_ostkaka.step7.body" = "Whip %i10 until softly thickened.";
"recipe.se_ostkaka.step7.title" = "Whip the cream";
"recipe.se_ostkaka.step8.body" = "Spoon or slice the ostkaka and serve it lukewarm with whipped cream and %i11.";
"recipe.se_ostkaka.step8.title" = "Serve traditionally";
