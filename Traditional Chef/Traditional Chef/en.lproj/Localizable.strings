"recipe.au_lamington.step2.title" = "Bake the sponge";
"recipe.au_lamington.step3.body" = "Turn the cake out onto a wire rack and let it cool completely so it is firm enough to cut and coat.";
"recipe.au_lamington.step3.title" = "Cool the cake";
"recipe.au_lamington.step4.body" = "Trim the edges if needed and cut the sponge into even squares.";
