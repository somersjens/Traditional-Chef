"recipe.ge_shkmeruli.drink.body" = "A crisp dry white wine such as Georgian Rkatsiteli pairs well with the rich garlic-milk sauce and roasted chicken flavors. A light lager also works. For a non-alcoholic option, serve sparkling water or chilled unsweetened tarragon tea.";
"recipe.ge_shkmeruli.drink.summary" = "White wine (Rkatsiteli)";
"recipe.ge_shkmeruli.info" = "Shkmeruli is a traditional Georgian chicken dish from the Racha region, made with browned chicken finished in a rich garlic and milk sauce. It is served hot as a main dish, often in a clay or cast-iron pan, with bread for dipping into the sauce.";
"recipe.ge_shkmeruli.info.summary" = "Garlic milk chicken";
"recipe.ge_shkmeruli.name" = "Shkmeruli";
"recipe.ge_shkmeruli.step1.body" = "Cut the %i1 into serving pieces and pat dry. Season with %i2 and %i3.";
"recipe.ge_shkmeruli.step1.title" = "Prepare the chicken";
"recipe.ge_shkmeruli.step2.body" = "Heat %i4 and %i5 in a large skillet and brown the chicken pieces on both sides until well colored.";
"recipe.ge_shkmeruli.step2.title" = "Brown the chicken";
"recipe.ge_shkmeruli.step3.body" = "Cover and cook the chicken gently so it becomes nearly cooked through and releases juices into the pan.";
"recipe.ge_shkmeruli.step3.title" = "Cook until nearly done";
"recipe.ge_shkmeruli.step4.body" = "Crush the %i6 to a paste while the chicken cooks.";
"recipe.ge_shkmeruli.step4.title" = "Prepare the garlic base";
"recipe.ge_shkmeruli.step5.body" = "Remove the chicken pieces to a warm dish, leaving the pan juices behind. Add the garlic to the pan, then pour in %i7 and %i8 and stir.";
"recipe.ge_shkmeruli.step5.title" = "Make the sauce liquid";
"recipe.ge_shkmeruli.step6.body" = "Add %i9 and %i10 and heat gently, stirring, until the garlic-milk sauce is hot and aromatic without hard boiling.";
"recipe.ge_shkmeruli.step6.title" = "Season and heat sauce";
"recipe.ge_shkmeruli.step7.body" = "Return the chicken to the skillet and simmer gently in the sauce until fully cooked and the flavors meld.";
"recipe.ge_shkmeruli.step7.title" = "Finish chicken in sauce";
"recipe.ge_shkmeruli.step8.body" = "Transfer the chicken with all of the garlic sauce to a serving pan and serve immediately with %i11 for dipping.";
"recipe.ge_shkmeruli.step8.title" = "Serve hot";
