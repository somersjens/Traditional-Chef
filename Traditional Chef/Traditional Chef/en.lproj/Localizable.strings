"recipe.it_pizza_margherita.drink.summary" = "Red wine (Sangiovese)";
"recipe.it_pizza_margherita.info" = "A traditional Neapolitan-style pizza with a soft, airy cornicione and a thin center, topped simply with crushed tomatoes, mozzarella, fresh basil, and extra-virgin olive oil. Baked at very high heat and served immediately, it is a staple of pizzerias and home ovens aiming for a fast bake and fresh, balanced flavors.";
"recipe.it_pizza_margherita.info.summary" = "Naples pizzeria icon";
"recipe.it_pizza_margherita.name" = "Margherita pizza";
