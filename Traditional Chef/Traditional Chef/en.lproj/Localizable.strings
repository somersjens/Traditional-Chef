"recipe.gb_brown_windsor_soup.drink.body" = "A small glass of Madeira matches the classic finish in the soup, while a light claret also works well. For a non-alcoholic option, serve hot black tea or sparkling water with lemon.";
"recipe.gb_brown_windsor_soup.drink.summary" = "Madeira";
"recipe.gb_brown_windsor_soup.info" = "A traditional British brown soup made from stewing beef and lamb simmered with root vegetables, herbs, and stock, then thickened lightly and finished with Madeira. It is served hot, often with bread, as a substantial first course in cold weather.";
"recipe.gb_brown_windsor_soup.info.summary" = "Hearty brown soup";
"recipe.gb_brown_windsor_soup.name" = "Brown Windsor soup";
"recipe.gb_brown_windsor_soup.step1.body" = "Cut the %i1 and %i2 into small pieces, slice the %i4, %i5, and %i6, and tie the %i10, %i11, and %i12 into a simple herb bundle.";
"recipe.gb_brown_windsor_soup.step1.title" = "Prepare ingredients";
"recipe.gb_brown_windsor_soup.step2.body" = "Melt the %i3 in a heavy pot and brown the beef and lamb well in batches, then return all the meat to the pot.";
"recipe.gb_brown_windsor_soup.step2.title" = "Brown the meat";
"recipe.gb_brown_windsor_soup.step3.body" = "Add the onion, carrot, and parsnip and cook gently until softened and lightly coloured.";
"recipe.gb_brown_windsor_soup.step3.title" = "Soften vegetables";
"recipe.gb_brown_windsor_soup.step4.body" = "Sprinkle in the %i7 and stir well over the heat so it coats the meat and vegetables and loses its raw taste.";
"recipe.gb_brown_windsor_soup.step4.title" = "Add flour";
"recipe.gb_brown_windsor_soup.step5.body" = "Gradually add the %i8 and %i9 while stirring, then add the herb bundle, %i13, %i14, and %i15 and bring to a gentle simmer.";
"recipe.gb_brown_windsor_soup.step5.title" = "Add liquids and herbs";
"recipe.gb_brown_windsor_soup.step6.body" = "Cover loosely and simmer gently until the meat is tender and the soup is rich, stirring from time to time.";
"recipe.gb_brown_windsor_soup.step6.title" = "Simmer slowly";
"recipe.gb_brown_windsor_soup.step7.body" = "Remove the herb bundle, stir in the %i16 and %i17, and simmer briefly to blend the flavours.";
"recipe.gb_brown_windsor_soup.step7.title" = "Finish soup";
"recipe.gb_brown_windsor_soup.step8.body" = "Toast the %i18 until crisp and hot for serving with the soup.";
"recipe.gb_brown_windsor_soup.step8.title" = "Toast bread";
"recipe.gb_brown_windsor_soup.step9.body" = "Ladle the soup into warmed bowls and serve immediately with the toast.";
"recipe.gb_brown_windsor_soup.step9.title" = "Serve";
