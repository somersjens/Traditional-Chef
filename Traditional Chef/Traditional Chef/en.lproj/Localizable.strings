"recipe.tn_mloukhia.drink.body" = "A medium-bodied red such as Grenache pairs well with the earthy, olive-oil richness and warm spices. For a non-alcoholic option, serve hot Tunisian mint tea or sparkling water with lemon.";
"recipe.tn_mloukhia.drink.summary" = "Red wine (Grenache)";
"recipe.tn_mloukhia.info" = "Tunisian Mloukhia is a slow-simmered, deep green-brown stew made from powdered jute leaves cooked in olive oil until fragrant and dark, then gently thinned with water and simmered for hours with tender meat and warm spices, traditionally served hot with Tunisian bread for dipping and scooping.";
"recipe.tn_mloukhia.info.summary" = "Slow-cooked mloukhia";
"recipe.tn_mloukhia.name" = "Mloukhia";
"recipe.tn_mloukhia.step1.body" = "Crush the %i4 and cut the %i3 into even chunks if needed.";
"recipe.tn_mloukhia.step1.title" = "Prep aromatics and meat";
"recipe.tn_mloukhia.step2.body" = "In the pot, whisk the %i1 into %i2 until completely smooth with no dry pockets.";
"recipe.tn_mloukhia.step2.title" = "Make mloukhia paste";
"recipe.tn_mloukhia.step3.body" = "Cook over low heat, stirring often, until the mixture darkens slightly and smells deeply aromatic without scorching.";
"recipe.tn_mloukhia.step3.title" = "Cook the mloukhia base";
"recipe.tn_mloukhia.step4.body" = "Whisk in %i11 gradually until the stew becomes smooth and fluid, then add %i8 and %i7.";
"recipe.tn_mloukhia.step4.title" = "Thin with liquid";
"recipe.tn_mloukhia.step5.body" = "Stir in %i5, %i6, %i9, and %i10, then add the meat and bring to a gentle simmer.";
"recipe.tn_mloukhia.step5.title" = "Season and add meat";
"recipe.tn_mloukhia.step6.body" = "Cover and simmer very gently, stirring occasionally, until the meat is very tender and the stew becomes glossy and thick.";
"recipe.tn_mloukhia.step6.title" = "Slow simmer until tender";
"recipe.tn_mloukhia.step7.body" = "Taste and adjust seasoning, remove bay leaves and chili, then serve hot with %i12 for dipping.";
"recipe.tn_mloukhia.step7.title" = "Finish and serve";
