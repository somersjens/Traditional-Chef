"recipe.lb_kibbeh_bil_sanieh.step3.title" = "Cook the meat filling";
"recipe.lb_kibbeh_bil_sanieh.step4.body" = "Spread the filling out to cool so it does not melt the kibbeh layers during assembly.";
"recipe.lb_kibbeh_bil_sanieh.step4.title" = "Cool the filling";
"recipe.lb_kibbeh_bil_sanieh.step5.body" = "Oil the baking dish. Press half the kibbeh dough evenly into the dish. Spread the cooled filling evenly over the base, leaving a small border. Add the remaining dough on top and press gently to seal and smooth the surface.";
"recipe.lb_kibbeh_bil_sanieh.step5.title" = "Assemble the tray";
"recipe.lb_kibbeh_bil_sanieh.step6.body" = "Cut the top into diamond shapes with a knife, pressing down through the top layer. Brush the surface lightly with olive oil so it bakes evenly and browns.";
"recipe.lb_kibbeh_bil_sanieh.step6.title" = "Score and oil the top";
"recipe.lb_kibbeh_bil_sanieh.step7.body" = "Bake until the tray is cooked through and the top is browned and set.";
"recipe.lb_kibbeh_bil_sanieh.step7.title" = "Bake";
"recipe.lb_kibbeh_bil_sanieh.step8.body" = "Let the kibbeh rest so it firms up, then cut along the scored lines and lift portions onto a platter.";
"recipe.lb_kibbeh_bil_sanieh.step8.title" = "Rest and portion";
"recipe.lb_kibbeh_bil_sanieh.step9.body" = "Serve warm or at room temperature with %i14 and warm %i15.";
