"recipe.th_gaeng_keow_wan_gai.step3.title" = "Cook the rice";
"recipe.th_gaeng_keow_wan_gai.step4.body" = "Heat the wok and add the %i3. Cook until fragrant and slightly thickened, then add the %i2 and fry while stirring until aromatic.";
"recipe.th_gaeng_keow_wan_gai.step4.title" = "Fry the curry paste";
"recipe.th_gaeng_keow_wan_gai.step5.body" = "Add the chicken to the curry base and stir until the pieces are coated and the outside is no longer raw.";
"recipe.th_gaeng_keow_wan_gai.step5.title" = "Cook the chicken";
"recipe.th_gaeng_keow_wan_gai.step6.body" = "Add the %i4 and %i5, then stir in the %i6 and %i7 until dissolved.";
"recipe.th_gaeng_keow_wan_gai.step6.title" = "Build the curry";
"recipe.th_gaeng_keow_wan_gai.step7.body" = "Add the thai eggplant and %i9 and simmer until the vegetables soften and the chicken is cooked through.";
"recipe.th_gaeng_keow_wan_gai.step7.title" = "Simmer with eggplants";
"recipe.th_gaeng_keow_wan_gai.step8.body" = "Add the kaffir lime leaves, thai basil, and sliced red spur chilies. Stir briefly just until fragrant and the basil wilts.";
"recipe.th_gaeng_keow_wan_gai.step8.title" = "Finish with herbs";
"recipe.th_gaeng_keow_wan_gai.step9.body" = "Transfer the curry to a serving bowl and serve hot with the jasmine rice.";
"recipe.th_gaeng_keow_wan_gai.step9.title" = "Serve";
