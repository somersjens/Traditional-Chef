"recipe.ch_engadiner_nusstorte.drink.body" = "Serve with a light sweet white wine or a demi-sec sparkling wine, which complements the caramelized walnut filling without overwhelming it. Coffee is the most traditional non-alcoholic pairing, and black tea also works well.";
"recipe.ch_engadiner_nusstorte.drink.summary" = "Sweet wine";
"recipe.ch_engadiner_nusstorte.info" = "Engadiner Nusstorte is a traditional dessert from Graubünden, especially the Engadine, made from a sweet shortcrust pastry filled with caramelized walnuts, cream, and honey under a pastry lid. It is a classic Swiss confection with a long shelf life and is typically served in slices with coffee after a meal or in the afternoon.";
"recipe.ch_engadiner_nusstorte.info.summary" = "Engadine walnut tart";
"recipe.ch_engadiner_nusstorte.name" = "Engadine walnut tart";
"recipe.ch_engadiner_nusstorte.step1.body" = "Combine %i1, %i2, %i3, %i4, and %i5 and work them into a smooth pastry dough. Shape it into a flat round and chill it.";
"recipe.ch_engadiner_nusstorte.step1.title" = "Make the pastry";
"recipe.ch_engadiner_nusstorte.step2.body" = "Roughly chop %i6 so the filling keeps a traditional coarse texture.";
"recipe.ch_engadiner_nusstorte.step2.title" = "Prepare the walnuts";
"recipe.ch_engadiner_nusstorte.step3.body" = "Caramelize the sugar in a saucepan, then add %i8 carefully and stir until smooth. Add %i9 and walnuts and cook briefly until the filling is thick and glossy.";
"recipe.ch_engadiner_nusstorte.step3.title" = "Cook the filling";
"recipe.ch_engadiner_nusstorte.step4.body" = "Leave the walnut filling to cool until it is warm rather than hot so it can be enclosed in the pastry.";
"recipe.ch_engadiner_nusstorte.step4.title" = "Cool the filling";
"recipe.ch_engadiner_nusstorte.step5.body" = "Roll out most of the pastry and line the tart pan, pressing it up the sides evenly.";
"recipe.ch_engadiner_nusstorte.step5.title" = "Line the tart pan";
"recipe.ch_engadiner_nusstorte.step6.body" = "Spread the walnut filling into the pastry shell. Roll out the remaining pastry, place it on top, seal the edges well, and prick the lid with a fork.";
"recipe.ch_engadiner_nusstorte.step6.title" = "Fill and cover the tart";
"recipe.ch_engadiner_nusstorte.step7.body" = "Bake until the pastry is deep golden and firm and the filling has set.";
"recipe.ch_engadiner_nusstorte.step7.title" = "Bake the tart";
"recipe.ch_engadiner_nusstorte.step8.body" = "Let the tart cool completely in the pan so the filling firms up and the slices cut cleanly.";
"recipe.ch_engadiner_nusstorte.step8.title" = "Cool before serving";
