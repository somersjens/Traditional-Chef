"recipe.ma_sellou.drink.body" = "A lightly sweet white such as Muscat pairs well with the nutty toasted flavors and honeyed sweetness. For a non-alcoholic option, serve Moroccan mint tea or sparkling water with lemon.";
"recipe.ma_sellou.drink.summary" = "Sweet wine (Muscat)";
"recipe.ma_sellou.info" = "Sellou, also known as sfouf, is a traditional Moroccan no-bake sweet made from toasted flour blended with ground almonds and sesame, perfumed with warm spices, then bound with butter and honey into a sandy, crumbly mixture. It is especially associated with Ramadan and celebrations, typically served in small mounds or bowls alongside Moroccan mint tea.";
"recipe.ma_sellou.info.summary" = "Sesame almond sweet";
"recipe.ma_sellou.name" = "Sellou";
"recipe.ma_sellou.step1.body" = "Heat a large skillet over medium-low heat and add the %i1. Stir constantly until evenly toasted and fragrant, then spread on a tray to cool completely.";
"recipe.ma_sellou.step1.title" = "Toast the flour";
"recipe.ma_sellou.step2.body" = "Toast the %i2 until lightly golden and fragrant, then cool. Ensure the %i3 is well toasted and fragrant, then cool.";
"recipe.ma_sellou.step2.title" = "Toast almonds and sesame";
"recipe.ma_sellou.step3.body" = "Grind the almonds to a fine meal, then grind the toasted sesame to a fine powder. Combine them in a mixing bowl.";
"recipe.ma_sellou.step3.title" = "Grind the nuts and sesame";
"recipe.ma_sellou.step4.body" = "Sift the cooled toasted flour into the bowl, then add %i4, %i5, %i6, and %i7. Mix thoroughly until evenly blended.";
"recipe.ma_sellou.step4.title" = "Combine dry ingredients";
"recipe.ma_sellou.step5.body" = "Melt the %i8 gently until fully liquid and warm, not browned.";
"recipe.ma_sellou.step5.title" = "Melt the butter";
"recipe.ma_sellou.step6.body" = "Pour the melted butter into the dry mixture and rub with your hands until evenly moistened and sandy. Add %i9 and continue rubbing and mixing until the mixture holds together when pressed but remains crumbly.";
"recipe.ma_sellou.step6.title" = "Bind into sellou";
"recipe.ma_sellou.step7.body" = "Spoon sellou into small bowls or shape into mounds and serve at room temperature.";
"recipe.ma_sellou.step7.title" = "Serve";
