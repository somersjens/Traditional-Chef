"recipe.cn_zui_ji.drink.body" = "A small pour of Shaoxing wine or a dry fino-style sherry complements the aromatic marinade, while chilled jasmine tea is a classic non-alcoholic pairing that keeps the palate fresh.";
"recipe.cn_zui_ji.drink.summary" = "Shaoxing wine";
"recipe.cn_zui_ji.info" = "Zui ji is a traditional Chinese cold appetizer of poached chicken chilled and marinated in Shaoxing wine with ginger, scallions, and seasonings until fragrant and tender. It is commonly served sliced at banquets and family meals, especially in Jiangnan and Shanghai-style cold dish assortments.";
"recipe.cn_zui_ji.info.summary" = "Drunken chicken slices";
"recipe.cn_zui_ji.name" = "Drunken chicken";
"recipe.cn_zui_ji.step1.body" = "Clean the %i1 and trim excess fat. Slice part of the %i3 and cut part of the %i4 into sections for poaching, reserving the rest for the marinade.";
"recipe.cn_zui_ji.step1.title" = "Prepare chicken and aromatics";
"recipe.cn_zui_ji.step2.body" = "Place the chicken in a pot with %i2, poaching ginger, poaching scallions, and part of the %i5. Bring just to a gentle boil, skim, then keep at a bare simmer until the chicken is cooked through and tender.";
"recipe.cn_zui_ji.step2.title" = "Poach the chicken";
"recipe.cn_zui_ji.step3.body" = "Lift out the chicken and transfer it immediately to an ice bath made with %i13 and %i14 to tighten the skin and stop the cooking, then drain well.";
"recipe.cn_zui_ji.step3.title" = "Chill the chicken";
"recipe.cn_zui_ji.step4.body" = "In a saucepan, combine the %i7, %i6, remaining salt, %i9, marinade ginger, marinade scallions, and %i12, bring to a brief simmer until the sugar dissolves, then cool completely.";
"recipe.cn_zui_ji.step4.title" = "Make the drunken marinade";
"recipe.cn_zui_ji.step5.body" = "Strain the cooled marinade into a clean container so the liquid is clear and aromatic.";
"recipe.cn_zui_ji.step5.title" = "Strain the marinade";
"recipe.cn_zui_ji.step6.body" = "Chop the chilled chicken into serving pieces or slice it neatly with bone attached, arranging the pieces compactly for marinating.";
"recipe.cn_zui_ji.step6.title" = "Cut the chicken";
"recipe.cn_zui_ji.step7.body" = "Submerge the chicken pieces in the cooled drunken marinade, cover, and refrigerate until well chilled and infused with the wine aroma.";
"recipe.cn_zui_ji.step7.title" = "Marinate the chicken";
"recipe.cn_zui_ji.step8.body" = "Remove the chicken from the marinade, arrange on a chilled platter, and serve cold as a starter.";
"recipe.cn_zui_ji.step8.title" = "Plate and serve";
