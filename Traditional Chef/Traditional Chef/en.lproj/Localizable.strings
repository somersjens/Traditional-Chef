"recipe.jp_sashimi_moriawase.step3.title" = "Prepare remaining garnishes";
"recipe.jp_sashimi_moriawase.step4.body" = "Pat the %i1, %i2, %i3, %i4, and %i5 dry, trim any uneven edges, and portion the seafood into clean slicing blocks for neat cuts.";
