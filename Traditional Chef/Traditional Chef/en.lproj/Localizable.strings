"recipe.us_sc_shrimp_and_grits.step1.title" = "Start the grits";
"recipe.us_sc_shrimp_and_grits.step2.body" = "Cook the grits at a low simmer, stirring often, until thick, tender, and creamy.";
"recipe.us_sc_shrimp_and_grits.step2.title" = "Cook until creamy";
"recipe.us_sc_shrimp_and_grits.step3.body" = "Stir in %i4, %i5, %i6, and %i7 until melted and smooth, then keep warm on very low heat.";
"recipe.us_sc_shrimp_and_grits.step3.title" = "Enrich the grits";
"recipe.us_sc_shrimp_and_grits.step4.body" = "Cook %i9 until crisp and the fat renders. Add %i10 and %i11 and cook until softened, then stir in %i12 until fragrant.";
"recipe.us_sc_shrimp_and_grits.step4.title" = "Render bacon and cook aromatics";
"recipe.us_sc_shrimp_and_grits.step5.body" = "Add %i13 and %i14 and simmer briefly while scraping the pan so the sauce becomes savory and cohesive.";
"recipe.us_sc_shrimp_and_grits.step5.title" = "Build the sauce";
"recipe.us_sc_shrimp_and_grits.step6.body" = "Season %i8 with %i16 and %i17, add to the skillet, and cook just until opaque and tender, turning once.";
"recipe.us_sc_shrimp_and_grits.step6.title" = "Cook the shrimp";
"recipe.us_sc_shrimp_and_grits.step7.body" = "Stir in %i15 and %i18, then taste and adjust seasoning so it is bright and savory.";
"recipe.us_sc_shrimp_and_grits.step7.title" = "Finish the skillet";
"recipe.us_sc_shrimp_and_grits.step8.body" = "Spoon creamy grits into bowls and top with the shrimp and bacon sauce, making sure each serving gets plenty of pan juices.";
"recipe.us_sc_shrimp_and_grits.step8.title" = "Serve";
