"recipe.tw_douhua.drink.body" = "A light off-dry Riesling pairs well with the ginger aroma and delicate soy flavor without overpowering the pudding. For a non-alcoholic option, serve hot roasted barley tea or lightly sweetened soy milk.";
"recipe.tw_douhua.drink.summary" = "White wine (Riesling)";
"recipe.tw_douhua.info" = "Douhua is a traditional Taiwanese tofu pudding dessert made from fresh soy milk set very softly, then served warm or chilled with ginger syrup. It is a common street-shop and home dessert, especially enjoyed as a light finish after a meal or as an afternoon sweet.";
"recipe.tw_douhua.info.summary" = "Silky soy pudding";
"recipe.tw_douhua.name" = "Douhua";
"recipe.tw_douhua.step1.body" = "Rinse the %i1 and soak them in plenty of %i2 until fully plumped and softened.";
"recipe.tw_douhua.step1.title" = "Soak soybeans";
"recipe.tw_douhua.step2.body" = "Drain the beans, then blend them with most of the water until very smooth and milky.";
"recipe.tw_douhua.step2.title" = "Blend soy milk base";
"recipe.tw_douhua.step3.body" = "Pour the blended mixture through a cloth-lined fine sieve into a pot and squeeze well to extract the soy milk.";
"recipe.tw_douhua.step3.title" = "Strain soy milk";
"recipe.tw_douhua.step4.body" = "Bring the soy milk to a gentle boil, then reduce and simmer briefly while stirring to prevent scorching and raw bean flavor.";
"recipe.tw_douhua.step4.title" = "Cook soy milk";
"recipe.tw_douhua.step5.body" = "In the heatproof setting bowl, whisk the %i3 and %i4 with the remaining water until smooth with no lumps.";
"recipe.tw_douhua.step5.title" = "Prepare coagulant slurry";
"recipe.tw_douhua.step6.body" = "Pour the hot soy milk into the bowl from a height to help mix naturally, cover immediately, and leave completely undisturbed until softly set.";
"recipe.tw_douhua.step6.title" = "Set the douhua";
"recipe.tw_douhua.step7.body" = "Slice the %i6 and simmer it with %i7 and %i8 until the sugar dissolves and the syrup is fragrant.";
"recipe.tw_douhua.step7.title" = "Make ginger syrup";
"recipe.tw_douhua.step8.body" = "Gently scoop the douhua into serving bowls and spoon the warm ginger syrup over the top before serving.";
"recipe.tw_douhua.step8.title" = "Scoop and serve";
