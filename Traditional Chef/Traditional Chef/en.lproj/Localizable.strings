"recipe.be_rijsttaart.drink.body" = "Pair with a lightly sweet wine such as late-harvest Riesling or a glass of demi-sec sparkling wine that complements vanilla and milk custard. For a non-alcoholic option, serve coffee, black tea, or a glass of cold milk.";
"recipe.be_rijsttaart.drink.summary" = "Sweet wine (Riesling)";
"recipe.be_rijsttaart.info" = "Belgian rijsttaart is a classic bakery-style tart made with a lightly sweet yeast dough base filled with creamy rice custard cooked in milk and vanilla, enriched with eggs and butter. After baking, the filling sets into a tender, sliceable layer and the crust stays soft and lightly golden. It is typically served at room temperature with coffee as a traditional Belgian pastry.";
"recipe.be_rijsttaart.info.summary" = "Bakery rice tart";
"recipe.be_rijsttaart.name" = "Rice tart";
"recipe.be_rijsttaart.step1.body" = "Warm %i5 until lukewarm, dissolve %i6 in it, then mix with %i1, %i2, %i3, %i4, and one %i10 to form a smooth, elastic dough.";
"recipe.be_rijsttaart.step1.title" = "Make the dough";
"recipe.be_rijsttaart.step10.body" = "Bake until the crust is golden and the filling is set with a light golden surface.";
"recipe.be_rijsttaart.step10.title" = "Bake the rijsttaart";
"recipe.be_rijsttaart.step11.body" = "Cool on a rack until fully set, then slice and serve at room temperature.";
"recipe.be_rijsttaart.step11.title" = "Cool and serve";
"recipe.be_rijsttaart.step2.body" = "Cover the dough and let it rise in a warm place until doubled in size.";
"recipe.be_rijsttaart.step2.title" = "Let the dough rise";
"recipe.be_rijsttaart.step3.body" = "Split %i12 and add it to %i8 in a saucepan. Bring it to a gentle simmer, add %i7, and cook slowly while stirring regularly until the rice is very tender and the mixture is thick.";
"recipe.be_rijsttaart.step3.title" = "Cook the rice custard";
"recipe.be_rijsttaart.step4.body" = "Remove the vanilla pod and let the rice mixture cool until warm so the eggs will not scramble when added.";
"recipe.be_rijsttaart.step4.title" = "Cool the custard";
"recipe.be_rijsttaart.step5.body" = "Zest %i13 and mix the zest into the rice custard. Beat in most of the remaining eggs until the filling becomes glossy and evenly combined, keeping a little beaten egg aside for brushing.";
"recipe.be_rijsttaart.step5.title" = "Enrich the filling";
"recipe.be_rijsttaart.step6.body" = "Roll out the risen dough and line the tart pan, pressing it into the base and sides and trimming neatly.";
"recipe.be_rijsttaart.step6.title" = "Line the tart pan";
"recipe.be_rijsttaart.step7.body" = "Spread the rice filling evenly into the dough-lined pan and smooth the top.";
"recipe.be_rijsttaart.step7.title" = "Fill and smooth";
"recipe.be_rijsttaart.step8.body" = "Let the filled tart rest until the dough looks slightly puffed at the edges.";
"recipe.be_rijsttaart.step8.title" = "Give the tart a final proof";
"recipe.be_rijsttaart.step9.body" = "Brush the surface of the filling lightly with the reserved beaten egg for a gentle sheen.";
