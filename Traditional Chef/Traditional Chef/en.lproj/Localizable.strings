"recipe.rs_svadbarski_kupus.drink.body" = "A light to medium-bodied red wine such as Pinot Noir pairs well with the rich meat and sour cabbage without overpowering the long-cooked flavors. A pale lager also works well. For a non-alcoholic option, serve sparkling water or plain yogurt.";
"recipe.rs_svadbarski_kupus.drink.summary" = "Red wine (Pinot Noir)";
"recipe.rs_svadbarski_kupus.info" = "Svadbarski Kupus is a traditional Serbian wedding dish of sour cabbage layered with pork, beef, smoked ribs, bacon, onion, garlic, paprika, and bay leaves, then baked slowly for many hours until deeply savory and tender. It is served hot for weddings, large family gatherings, and cold-weather feasts, usually with bread.";
"recipe.rs_svadbarski_kupus.info.summary" = "Wedding cabbage stew";
"recipe.rs_svadbarski_kupus.name" = "Wedding cabbage";
"recipe.rs_svadbarski_kupus.step1.body" = "Cut %i2, %i3, %i4, and %i5 into large pieces. Slice %i6, mince %i7, and chop %i1 if the strands are very long.";
"recipe.rs_svadbarski_kupus.step1.title" = "Prepare the ingredients";
"recipe.rs_svadbarski_kupus.step2.body" = "Rub the inside of the clay pot with %i8 so the cabbage can bake slowly without sticking.";
"recipe.rs_svadbarski_kupus.step2.title" = "Prepare the pot";
"recipe.rs_svadbarski_kupus.step3.body" = "Place a layer of sauerkraut in the pot, then add some onion, garlic, pork, beef, smoked ribs, and smoked bacon. Season with part of %i9, %i10, and %i11, then repeat the layers until all ingredients are used, finishing with sauerkraut on top.";
"recipe.rs_svadbarski_kupus.step3.title" = "Layer the cabbage and meat";
"recipe.rs_svadbarski_kupus.step4.body" = "Pour %i12 into the pot so the cabbage can soften and the meats can slowly braise without drying out.";
"recipe.rs_svadbarski_kupus.step4.title" = "Add water";
"recipe.rs_svadbarski_kupus.step5.body" = "Cover the pot and bake slowly until the cabbage is completely tender, the meats are very soft, and the flavors have fully merged into the traditional rich wedding-style stew.";
"recipe.rs_svadbarski_kupus.step5.title" = "Bake slowly";
"recipe.rs_svadbarski_kupus.step6.body" = "Remove the pot from the oven and let the svadbarski kupus rest briefly so the layers settle and the juices redistribute.";
"recipe.rs_svadbarski_kupus.step6.title" = "Rest the dish";
"recipe.rs_svadbarski_kupus.step7.body" = "Serve the svadbarski kupus hot with pieces of the different meats and plenty of cabbage in each portion, with %i13 alongside.";
"recipe.rs_svadbarski_kupus.step7.title" = "Serve traditionally";
