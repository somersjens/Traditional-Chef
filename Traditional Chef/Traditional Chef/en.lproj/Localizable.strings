"recipe.ec_guatita.drink.body" = "A cold light lager pairs well with the rich peanut sauce and tender tripe without overwhelming the dish. A fresh young white wine also works. For a non-alcoholic option, serve sparkling lime water.";
"recipe.ec_guatita.drink.summary" = "Beer (Lager)";
"recipe.ec_guatita.info" = "Guatita is a traditional Ecuadorian tripe stew made with beef tripe, potatoes, peanuts, onion, garlic, cumin, and achiote, cooked until thick and creamy. It is traditionally served hot as a hearty midday meal with white rice, avocado, curtido, and ají.";
"recipe.ec_guatita.info.summary" = "Peanut tripe stew";
"recipe.ec_guatita.name" = "Guatita";
"recipe.ec_guatita.step1.body" = "Clean %i1 well and cut it into small pieces. Chop %i3, %i4, %i5, %i6, and %i13, and slice %i21 for serving. Peel and cut %i2.";
"recipe.ec_guatita.step1.title" = "Prepare the ingredients";
"recipe.ec_guatita.step2.body" = "Place the tripe in the large pot with %i10 and part of %i11. Bring to a boil, lower the heat, and simmer until the tripe is tender.";
"recipe.ec_guatita.step2.title" = "Cook the tripe";
"recipe.ec_guatita.step3.body" = "Thinly slice %i17 and mix it with %i18, %i19, and part of %i20. Let it rest so the onion softens and brightens.";
"recipe.ec_guatita.step3.title" = "Make the curtido";
"recipe.ec_guatita.step4.body" = "Blend %i22 with %i23, %i24, %i25, %i26, and %i27 until smooth. Set the ají aside for serving.";
"recipe.ec_guatita.step4.title" = "Make the ají";
"recipe.ec_guatita.step5.body" = "Heat %i7 in the pot and cook the white onion, garlic, and bell pepper until softened. Add the tomatoes and %i8, then cook until the base becomes fragrant and lightly thickened.";
"recipe.ec_guatita.step5.title" = "Start the refrito";
"recipe.ec_guatita.step6.body" = "Add the potatoes and part of the tripe cooking liquid to the refrito. Simmer until the potatoes are tender enough to begin breaking down.";
"recipe.ec_guatita.step6.title" = "Cook the potatoes";
"recipe.ec_guatita.step7.body" = "Add the cooked tripe and %i9, then stir well and simmer gently until the stew thickens. Lightly mash some of the potatoes to give the sauce its traditional creamy texture, then adjust with salt and %i12.";
"recipe.ec_guatita.step7.title" = "Finish the guatita";
"recipe.ec_guatita.step8.body" = "Cook %i14 in %i15 with %i16 until tender and fluffy.";
"recipe.ec_guatita.step8.title" = "Cook the rice";
"recipe.ec_guatita.step9.body" = "Serve the guatita hot with white rice, avocado, curtido, and ají. Finish with the remaining cilantro over the stew.";
"recipe.ec_guatita.step9.title" = "Serve traditionally";
