"recipe.pl_zrazy.drink.body" = "Pair with a medium-bodied dry red such as Pinot Noir that won’t overpower the beef and mustardy gravy. A malty amber lager also works well with the braised sauce. Non-alcoholic option: sparkling water with lemon or unsweetened black tea.";
"recipe.pl_zrazy.drink.summary" = "Red wine (Pinot Noir)";
"recipe.pl_zrazy.info" = "Zrazy are traditional Polish beef roulades made by pounding beef thin, spreading with mustard, and rolling around a savory filling of bacon, onion, and pickled cucumber. The rolls are browned, then slowly braised with bay leaf and allspice until tender, creating a rich, savory gravy. They are served hot as a classic home-style main course, traditionally alongside buckwheat groats.";
"recipe.pl_zrazy.info.summary" = "Mustard beef roulades";
"recipe.pl_zrazy.name" = "Beef roulades";
"recipe.pl_zrazy.step1.body" = "Cut %i5 into small sticks, slice %i6 into thin strips, and cut %i7 into sticks suitable for rolling inside the beef.";
"recipe.pl_zrazy.step1.title" = "Prepare the filling";
"recipe.pl_zrazy.step10.body" = "Cover and cook on low heat until the water is absorbed and the groats are tender, then rest covered briefly to fluff.";
"recipe.pl_zrazy.step10.title" = "Steam the buckwheat";
"recipe.pl_zrazy.step11.body" = "Serve the zrazy hot with buckwheat and plenty of gravy.";
"recipe.pl_zrazy.step11.title" = "Serve";
"recipe.pl_zrazy.step2.body" = "Cut %i1 into thin slices and pound each between plastic wrap until evenly thin. Season both sides with %i2 and %i3, then spread %i4 over one side.";
"recipe.pl_zrazy.step2.title" = "Pound and season the beef";
"recipe.pl_zrazy.step3.body" = "Place bacon, onion, and pickled cucumber on the mustard side, then roll tightly into neat roulades and secure with kitchen twine or toothpicks.";
"recipe.pl_zrazy.step3.title" = "Roll and secure the zrazy";
"recipe.pl_zrazy.step4.body" = "Lightly coat the roulades in %i9. Heat %i8 in a skillet and prepare to brown the rolls well on all sides.";
"recipe.pl_zrazy.step4.title" = "Dredge and start browning";
"recipe.pl_zrazy.step5.body" = "Brown the roulades until well colored, turning carefully so they keep their shape. Transfer them to a heavy pot.";
"recipe.pl_zrazy.step5.title" = "Brown the roulades";
"recipe.pl_zrazy.step6.body" = "Add %i10, %i11, %i12, and %i13. Bring to a gentle simmer, cover, and braise slowly until the beef is very tender, turning the roulades occasionally.";
"recipe.pl_zrazy.step6.title" = "Braise until tender";
"recipe.pl_zrazy.step7.body" = "Remove the roulades to rest briefly. Whisk %i14 with cold %i15 into a smooth slurry, whisk it into the simmering braising liquid, and cook until the gravy thickens and becomes glossy.";
"recipe.pl_zrazy.step7.title" = "Thicken the gravy";
"recipe.pl_zrazy.step8.body" = "Return the roulades to the pot and simmer gently so they are coated and hot throughout. Remove twine or toothpicks before serving.";
"recipe.pl_zrazy.step8.title" = "Finish the roulades in sauce";
"recipe.pl_zrazy.step9.body" = "Rinse %i16, add to a saucepan with %i17 and %i18, and bring to a boil.";
"recipe.pl_zrazy.step9.title" = "Cook the buckwheat";
