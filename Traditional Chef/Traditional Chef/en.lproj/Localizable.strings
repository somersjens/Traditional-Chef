"recipe.hu_toltott_kaposzta.drink.body" = "Pair with a medium-bodied Hungarian red such as Kékfrankos that stands up to smoked meat and paprika. A dark lager also works well. For a non-alcoholic option, serve sparkling water or a chilled apple spritz.";
"recipe.hu_toltott_kaposzta.drink.summary" = "Red wine (Kékfrankos)";
"recipe.hu_toltott_kaposzta.info" = "Töltött káposzta is a traditional Hungarian dish of cabbage leaves stuffed with a pork-and-rice filling seasoned with paprika and garlic, then slowly simmered with sauerkraut and smoked meats until tender and richly flavored. It is served hot with a dollop of sour cream, which balances the tangy sauerkraut and smoky, paprika-scented sauce.";
"recipe.hu_toltott_kaposzta.info.summary" = "Stuffed cabbage classic";
