"recipe.cl_humitas.drink.body" = "Pair with a crisp Chilean Sauvignon Blanc or a dry rosé to complement the sweet corn and cut through the richness. A light lager also fits well. Non-alcoholic option: sparkling water with lime or a chilled herbal tea such as mint.";
"recipe.cl_humitas.drink.summary" = "White wine (Sauvignon)";
"recipe.cl_humitas.info" = "Humitas are traditional Chilean fresh-corn tamales made by grinding tender corn with sautéed onion and ají de color, enriching the mixture with a little lard, then wrapping it in corn husks and tying the parcels before steaming. They are commonly served hot with a simple tomato salad and a sprinkle of sugar, balancing savory corn with a touch of sweetness.";
"recipe.cl_humitas.info.summary" = "Steamed corn husk parcels";
"recipe.cl_humitas.name" = "Humitas";
"recipe.cl_humitas.step1.body" = "Soak the %i7 in warm %i8 until flexible. Separate and reserve the larger husks for wrapping. Remove the %i1 and keep them ready for grinding.";
"recipe.cl_humitas.step1.title" = "Prep husks and corn";
"recipe.cl_humitas.step2.body" = "Heat %i3 in a skillet and cook %i2 with %i6 until soft and translucent, without browning. Stir in %i5 until fragrant.";
"recipe.cl_humitas.step2.title" = "Make the onion base";
"recipe.cl_humitas.step3.body" = "Grind the corn kernels to a coarse paste, then mix into a bowl with the onion base and %i4 until evenly combined and thick.";
"recipe.cl_humitas.step3.title" = "Grind the corn";
"recipe.cl_humitas.step4.body" = "Place two overlapped husks on the board, spoon corn mixture into the center, fold the sides over and tuck ends to form a tight package, then tie securely with twine. Repeat for all parcels.";
"recipe.cl_humitas.step4.title" = "Fill and tie parcels";
"recipe.cl_humitas.step5.body" = "Set up a steamer in a pot with water, bring to a steady steam, arrange humitas upright, cover, and steam until the mixture is set and cooked through.";
"recipe.cl_humitas.step5.title" = "Steam the humitas";
"recipe.cl_humitas.step6.body" = "Dice the %i9 and thinly slice the %i10. Toss with %i11, %i12, and %i14 until juicy.";
"recipe.cl_humitas.step6.title" = "Make the tomato salad";
"recipe.cl_humitas.step7.body" = "Serve humitas hot with tomato salad and sprinkle %i13 over the humitas in the traditional way.";
"recipe.cl_humitas.step7.title" = "Serve";
