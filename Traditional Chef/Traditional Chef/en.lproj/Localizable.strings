"recipe.ma_chebakia.drink.body" = "A lightly sweet white wine such as Muscat pairs with the honeyed, aromatic spices and sesame richness without tasting sharp. For a non-alcoholic option, serve Moroccan mint tea or sparkling water with lemon.";
"recipe.ma_chebakia.drink.summary" = "Sweet wine (Muscat)";
"recipe.ma_chebakia.info" = "Chebakia are traditional Moroccan flower-shaped pastries made from spiced, sesame-rich dough that is intricately folded, deep-fried until crisp, then soaked in warm honey scented with orange blossom water and finished with toasted sesame. They are especially associated with Ramadan and are commonly served with mint tea, often alongside harira as part of iftar.";
"recipe.ma_chebakia.info.summary" = "Honey sesame pastries";
"recipe.ma_chebakia.name" = "Chebakia";
"recipe.ma_chebakia.step1.body" = "Grind most of the %i2 to a fine meal, keeping some whole for finishing. Crush the %i7 to a fine powder and prepare the spices so they are ready to add.";
"recipe.ma_chebakia.step1.title" = "Grind sesame and prep spices";
"recipe.ma_chebakia.step10.body" = "Lift chebakia from honey to drain, sprinkle with the reserved toasted sesame seeds, and arrange on a platter to cool before serving.";
"recipe.ma_chebakia.step10.title" = "Finish and serve";
"recipe.ma_chebakia.step2.body" = "Combine %i1, ground sesame, %i3, %i4, %i5, %i6, %i8, %i9, and %i10. Add %i11, %i12, %i13, melted %i14, %i15, %i16, and %i17, then knead until a smooth, firm dough forms.";
"recipe.ma_chebakia.step2.title" = "Mix and knead the dough";
"recipe.ma_chebakia.step3.body" = "Cover the dough and let it rest so it relaxes and becomes easier to roll and shape.";
"recipe.ma_chebakia.step3.title" = "Rest the dough";
"recipe.ma_chebakia.step4.body" = "Roll the dough thin. Cut into rectangles and make evenly spaced slits inside each piece to prepare for the traditional folded flower shape.";
"recipe.ma_chebakia.step4.title" = "Roll and cut for shaping";
"recipe.ma_chebakia.step5.body" = "Fold each cut piece into the classic flower form by weaving and pulling alternating strips through the center, then pinch firmly so it holds its shape during frying. Keep shaped pieces covered while you work.";
"recipe.ma_chebakia.step5.title" = "Shape the chebakia";
"recipe.ma_chebakia.step6.body" = "Gently warm %i19 until fluid and stir in %i20. Keep it warm so it coats and soaks evenly.";
"recipe.ma_chebakia.step6.title" = "Warm the honey bath";
"recipe.ma_chebakia.step7.body" = "Heat %i18 in a deep pot to a steady frying temperature so the pastries cook through and crisp without soaking up excess oil.";
"recipe.ma_chebakia.step7.title" = "Heat frying oil";
"recipe.ma_chebakia.step8.body" = "Fry chebakia in batches, turning carefully, until evenly deep golden and crisp. Drain briefly on paper towels.";
"recipe.ma_chebakia.step8.title" = "Fry until deep golden";
"recipe.ma_chebakia.step9.body" = "While still hot, transfer fried chebakia into the warm honey, turn to coat thoroughly, and let them soak so the interior becomes glossy and sweet.";
"recipe.ma_chebakia.step9.title" = "Soak in honey";
