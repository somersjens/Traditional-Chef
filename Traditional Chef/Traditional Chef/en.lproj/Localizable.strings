"recipe.lk_bibikkan.step7.title" = "Make the batter";
"recipe.lk_bibikkan.step8.body" = "Spread the batter evenly in the prepared baking tin and level the surface.";
"recipe.lk_bibikkan.step8.title" = "Fill the tin";
