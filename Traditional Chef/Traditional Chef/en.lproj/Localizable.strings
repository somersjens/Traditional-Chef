"recipe.za_sosaties.drink.body" = "A dry South African rosé (often Pinotage rosé) or a fruity, medium-bodied red like Pinotage complements the sweet-sour curry marinade and smoky braai notes. A ripe Chenin Blanc also works if you prefer white. Non-alcoholic pairing: chilled ginger beer or rooibos iced tea.";
"recipe.za_sosaties.drink.summary" = "Rosé wine (Pinotage)";
"recipe.za_sosaties.info" = "Sosaties are traditional South African kebabs with Cape Malay roots: cubes of lamb threaded with onion and dried apricot, marinated in a sweet-sour curry-spiced mixture, then grilled over a braai until lightly charred and juicy. They are commonly served with fragrant yellow rice to balance the spiced, tangy glaze and soak up any resting juices.";
"recipe.za_sosaties.info.summary" = "Braaied curry skewers";
"recipe.za_sosaties.name" = "Sosaties";
"recipe.za_sosaties.step1.body" = "Combine %i5, %i4, %i7, %i8, %i9, %i10, %i11, %i12, %i13, %i14, %i15, and %i16, then stir until the sugar dissolves.";
"recipe.za_sosaties.step1.title" = "Make the marinade";
"recipe.za_sosaties.step2.body" = "Cut the %i2 into chunks and separate into layers. If needed, cut %i1 into even cubes and check %i3 for pits.";
"recipe.za_sosaties.step2.title" = "Prepare kebab ingredients";
"recipe.za_sosaties.step3.body" = "Add %i1 and %i3 to the marinade, coat thoroughly, cover, and refrigerate so the flavours penetrate.";
"recipe.za_sosaties.step3.title" = "Marinate the lamb";
"recipe.za_sosaties.step4.body" = "Thread %i1, %i2, and %i3 onto skewers in alternating pieces, finishing with %i2 to help secure the skewer.";
"recipe.za_sosaties.step4.title" = "Assemble the sosaties";
"recipe.za_sosaties.step5.body" = "Grill over medium heat, turning regularly and basting with the remaining marinade, until browned, lightly caramelised, and cooked through.";
"recipe.za_sosaties.step5.title" = "Braai the sosaties";
"recipe.za_sosaties.step6.body" = "Rinse the %i17. Combine it with %i18, %i19, %i20, %i21, and %i23, then bring to a gentle simmer.";
"recipe.za_sosaties.step6.title" = "Start the yellow rice";
"recipe.za_sosaties.step7.body" = "Cover and cook gently until the rice is tender and the liquid is absorbed.";
"recipe.za_sosaties.step7.title" = "Cook the yellow rice";
"recipe.za_sosaties.step8.body" = "Stir in %i22, cover again, and let the rice rest so it fluffs up.";
"recipe.za_sosaties.step8.title" = "Finish the rice";
"recipe.za_sosaties.step9.body" = "Rest the sosaties briefly, then serve with the yellow rice.";
"recipe.za_sosaties.step9.title" = "Serve";
