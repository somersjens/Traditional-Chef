"recipe.sy_kebab_halabi.step3.title" = "Shape the kebabs";
"recipe.sy_kebab_halabi.step4.body" = "Rinse the %i18 in several changes of %i21 until the water runs mostly clear, then drain well.";
"recipe.sy_kebab_halabi.step4.title" = "Rinse and drain the rice";
"recipe.sy_kebab_halabi.step5.body" = "Melt the %i20 in a pot, toast the %i19 until golden, then add the drained rice and stir to coat the grains.";
"recipe.sy_kebab_halabi.step5.title" = "Toast vermicelli and coat rice";
"recipe.sy_kebab_halabi.step6.body" = "Add water and %i22, bring to a boil, then cover and cook on low heat until the liquid is absorbed and the rice is tender. Turn off the heat and let it rest covered, then fluff with a fork.";
"recipe.sy_kebab_halabi.step6.title" = "Cook the rice";
