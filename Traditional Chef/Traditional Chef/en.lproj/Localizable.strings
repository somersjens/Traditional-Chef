"recipe.mu_gateau_patate.step3.title" = "Drain and steam-dry";
"recipe.mu_gateau_patate.step4.body" = "Mash the sweet potatoes until smooth and lump-free while still warm.";
"recipe.mu_gateau_patate.step4.title" = "Mash smooth";
