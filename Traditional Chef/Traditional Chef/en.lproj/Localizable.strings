"recipe.eg_fatta.step7.title" = "Start the garlic-vinegar base";
"recipe.eg_fatta.step8.body" = "Stir in %i16, then add %i15, %i17, and %i18. Simmer until the sauce thickens slightly and tastes well balanced.";
"recipe.eg_fatta.step8.title" = "Simmer the tomato sauce";
"recipe.eg_fatta.step9.body" = "Spread the toasted pita in a serving dish and moisten it with hot broth. Add a layer of rice, then arrange the beef on top.";
"recipe.eg_fatta.step9.title" = "Assemble the fatta";
