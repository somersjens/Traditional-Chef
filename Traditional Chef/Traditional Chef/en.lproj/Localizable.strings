"recipe.cn_tangyuan.drink.body" = "Light floral tea pairs better than wine with this delicate dessert, and hot jasmine tea or warm plain water are classic non-alcoholic options that balance the sweetness and rich sesame filling.";
"recipe.cn_tangyuan.drink.summary" = "Jasmine tea";
"recipe.cn_tangyuan.info" = "Tangyuan is a traditional Chinese dessert of glutinous rice balls served in a lightly sweet syrup, especially eaten during Lantern Festival and family reunions for its symbolism of togetherness. A classic version uses a black sesame filling and is served hot in ginger-infused syrup.";
"recipe.cn_tangyuan.info.summary" = "Sesame-filled tangyuan";
"recipe.cn_tangyuan.name" = "Tangyuan";
"recipe.cn_tangyuan.step1.body" = "Toast the %i1 in a dry pan over medium heat until fragrant, then let them cool slightly.";
"recipe.cn_tangyuan.step1.title" = "Toast the sesame seeds";
"recipe.cn_tangyuan.step2.body" = "Grind the toasted sesame seeds with %i2, then mix in %i3 until a thick paste forms. Chill briefly until firm enough to portion.";
"recipe.cn_tangyuan.step2.title" = "Make the sesame filling";
"recipe.cn_tangyuan.step3.body" = "Divide the sesame filling into small portions and chill them so they are easier to wrap inside the dough.";
"recipe.cn_tangyuan.step3.title" = "Portion and chill filling";
"recipe.cn_tangyuan.step4.body" = "Mix the %i4 with %i5 gradually to form a smooth soft dough that holds together without cracking.";
"recipe.cn_tangyuan.step4.title" = "Make the rice dough";
"recipe.cn_tangyuan.step5.body" = "Divide the dough, flatten each piece, enclose a sesame filling portion, seal carefully, and roll smooth into round balls, dusting lightly with %i6 as needed.";
"recipe.cn_tangyuan.step5.title" = "Shape and fill the tangyuan";
"recipe.cn_tangyuan.step6.body" = "Slice the %i8 and simmer it in %i7, then add the %i9 and cook until dissolved and lightly infused.";
"recipe.cn_tangyuan.step6.title" = "Simmer the ginger syrup";
"recipe.cn_tangyuan.step7.body" = "Bring a pot of water to a gentle boil, add the tangyuan, and cook until they float and become glossy and tender.";
"recipe.cn_tangyuan.step7.title" = "Boil the tangyuan";
"recipe.cn_tangyuan.step8.body" = "Lift the cooked tangyuan into serving bowls and ladle over the hot ginger syrup before serving immediately.";
"recipe.cn_tangyuan.step8.title" = "Serve in syrup";
