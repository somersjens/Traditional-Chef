"recipe.fr_quiche_lorraine.drink.body" = "Pair with a dry Alsace white such as Pinot Blanc or Riesling to cut through the rich custard and bacon. A light lager also works well. For a non-alcoholic option, serve sparkling water or a crisp apple spritz.";
"recipe.fr_quiche_lorraine.drink.summary" = "White wine (Pinot Blanc)";
"recipe.fr_quiche_lorraine.info" = "Quiche Lorraine is the classic savory tart from Lorraine: a crisp shortcrust pastry filled with lardons and a rich egg-and-cream custard, baked until just set and lightly golden. In the traditional version, it contains no cheese. It is served warm or at room temperature, often with a simple green salad.";
"recipe.fr_quiche_lorraine.info.summary" = "Lorraine bacon tart";
"recipe.fr_quiche_lorraine.name" = "Quiche Lorraine";
"recipe.fr_quiche_lorraine.step1.body" = "Rub %i2 into %i1 and %i3 until sandy, add %i4, and bring it together into a smooth dough. Chill it briefly so it rolls cleanly.";
"recipe.fr_quiche_lorraine.step1.title" = "Make the pastry";
"recipe.fr_quiche_lorraine.step2.body" = "Roll out the dough on a floured surface and line the tart pan, pressing it into the corners and trimming neatly.";
"recipe.fr_quiche_lorraine.step2.title" = "Line the tart pan";
"recipe.fr_quiche_lorraine.step3.body" = "Dock the base, line it with parchment, fill with weights, and blind bake until set and lightly coloured, then remove the weights and bake briefly to dry the base.";
"recipe.fr_quiche_lorraine.step3.title" = "Blind-bake the crust";
"recipe.fr_quiche_lorraine.step4.body" = "Cook %i5 until rendered and lightly browned, then drain.";
"recipe.fr_quiche_lorraine.step4.title" = "Cook the lardons";
"recipe.fr_quiche_lorraine.step5.body" = "Whisk %i6 with %i7 and %i8, then season with %i9 and %i10.";
"recipe.fr_quiche_lorraine.step5.title" = "Mix the custard";
"recipe.fr_quiche_lorraine.step6.body" = "Scatter the lardons in the crust and pour in the custard.";
"recipe.fr_quiche_lorraine.step6.title" = "Fill the tart";
"recipe.fr_quiche_lorraine.step7.body" = "Bake until the custard is just set with a slight wobble in the centre and the top is lightly golden.";
"recipe.fr_quiche_lorraine.step7.title" = "Bake the quiche";
"recipe.fr_quiche_lorraine.step8.body" = "Let the quiche rest so it sets for clean slices, then serve it warm or at room temperature.";
"recipe.fr_quiche_lorraine.step8.title" = "Rest and serve";
