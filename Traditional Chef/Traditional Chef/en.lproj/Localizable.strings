"recipe.th_larb.step1.title" = "Soak the sticky rice";
"recipe.th_larb.step2.body" = "Thinly slice the %i7 and %i8, pick the %i9 and %i10, and cut the %i14, %i15, and %i16 for serving.";
"recipe.th_larb.step2.title" = "Prepare herbs and vegetables";
"recipe.th_larb.step3.body" = "Drain the soaked rice and spread it in a cloth-lined steamer. Add steaming %i13 to the steamer base and bring it to a boil.";
"recipe.th_larb.step3.title" = "Prepare the steamer";
"recipe.th_larb.step4.body" = "Steam the rice until tender and fully cooked, turning once for even cooking. Keep warm for serving.";
"recipe.th_larb.step4.title" = "Steam the sticky rice";
"recipe.th_larb.step5.body" = "Place the %i1 and %i2 in a wok or skillet and cook over medium heat, stirring to break up the meat until just cooked through.";
"recipe.th_larb.step5.title" = "Cook the pork";
"recipe.th_larb.step6.body" = "Turn off the heat and season the hot pork with %i3, %i4, %i5, and %i6, mixing well so the seasoning is absorbed.";
"recipe.th_larb.step6.title" = "Season the pork mixture";
"recipe.th_larb.step7.body" = "Add the shallots, spring onion, mint leaves, and coriander leaves, then toss gently until evenly combined.";
"recipe.th_larb.step7.title" = "Add aromatics and herbs";
"recipe.th_larb.step8.body" = "Let the larb sit briefly so the flavors meld and the herbs soften slightly while the dish remains warm.";
"recipe.th_larb.step8.title" = "Adjust and rest briefly";
"recipe.th_larb.step9.body" = "Transfer the larb to a serving plate and serve with sticky rice and the fresh vegetables.";
"recipe.th_larb.step9.title" = "Serve";
