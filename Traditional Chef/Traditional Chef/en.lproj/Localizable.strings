"recipe.kr_bulgogi.step10.title" = "Fluff the rice";
"recipe.kr_bulgogi.step11.body" = "Transfer the bulgogi to a platter and serve immediately with rice, lettuce, perilla leaves, and ssamjang for wrapping at the table.";
"recipe.kr_bulgogi.step11.title" = "Serve";
