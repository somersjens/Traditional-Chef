"recipe.th_som_tam.drink.body" = "A dry to off-dry Riesling can handle the lime, chili, and salty-sweet balance while staying refreshing. For a non-alcoholic option, serve cold water, unsweetened iced tea, or chilled jasmine tea.";
"recipe.th_som_tam.drink.summary" = "White wine (Riesling)";
"recipe.th_som_tam.info" = "Som Tam Thai is a traditional Thai green papaya salad made by pounding garlic, chili, palm sugar, fish sauce, and lime juice, then mixing with shredded green papaya, tomatoes, long beans, dried shrimp, and peanuts. It is served fresh as a shared salad, often alongside sticky rice and grilled foods in everyday meals.";
"recipe.th_som_tam.info.summary" = "Green papaya salad";
"recipe.th_som_tam.name" = "Som tam";
"recipe.th_som_tam.step1.body" = "Peel the %i1, remove the seeds, and shred it into thin strands. Cut the %i4 into short pieces and halve the %i5.";
"recipe.th_som_tam.step1.title" = "Prepare the papaya and vegetables";
"recipe.th_som_tam.step2.body" = "Pound the %i2 and %i3 in a mortar until crushed and fragrant.";
"recipe.th_som_tam.step2.title" = "Pound the aromatics";
"recipe.th_som_tam.step3.body" = "Add the %i8 to the mortar and pound and mix until it starts to dissolve, then add the %i9 and %i10 and stir to combine.";
"recipe.th_som_tam.step3.title" = "Make the dressing base";
"recipe.th_som_tam.step4.body" = "Add the long beans and cherry tomatoes and bruise them lightly with the pestle while mixing so they release juice but keep their shape.";
"recipe.th_som_tam.step4.title" = "Add long beans and tomatoes";
"recipe.th_som_tam.step5.body" = "Add the shredded papaya and %i6, then pound gently and toss repeatedly so the strands absorb the dressing evenly.";
"recipe.th_som_tam.step5.title" = "Add papaya and dried shrimp";
"recipe.th_som_tam.step6.body" = "Add most of the %i7 and mix briefly, keeping some texture in the salad.";
"recipe.th_som_tam.step6.title" = "Finish with peanuts";
"recipe.th_som_tam.step7.body" = "Transfer the som tam to a serving plate, scatter the remaining peanuts on top, and serve immediately.";
"recipe.th_som_tam.step7.title" = "Plate and serve";
"recipe.th_som_tam.tool.t1" = "Chef knife";
"recipe.th_som_tam.tool.t2" = "Cutting board";
"recipe.th_som_tam.tool.t3" = "Peeler";
