"recipe.ec_dulce_de_higos_con_queso.drink.body" = "A lightly sweet dessert wine can match the panela syrup, while a mild sparkling wine also works well. For a non-alcoholic option, serve black coffee or cinnamon tea.";
"recipe.ec_dulce_de_higos_con_queso.drink.summary" = "Dessert wine";
"recipe.ec_dulce_de_higos_con_queso.info" = "Dulce de Higos con Queso is a traditional Ecuadorian dessert of whole figs slowly cooked in panela syrup scented with cinnamon and cloves, then served with fresh cheese. It is especially associated with home cooking in the Andes and is commonly offered as a simple, classic dessert after lunch.";
"recipe.ec_dulce_de_higos_con_queso.info.summary" = "Figs with fresh cheese";
"recipe.ec_dulce_de_higos_con_queso.name" = "Figs with cheese";
"recipe.ec_dulce_de_higos_con_queso.step1.body" = "Wash %i1 and make a small cross cut at the blossom end of each one so they can release bitterness and absorb the syrup evenly.";
"recipe.ec_dulce_de_higos_con_queso.step1.title" = "Prepare the figs";
"recipe.ec_dulce_de_higos_con_queso.step2.body" = "Place the figs in the bowl, cover with water, and leave them to soak until the skins soften slightly.";
"recipe.ec_dulce_de_higos_con_queso.step2.title" = "Soak the figs";
"recipe.ec_dulce_de_higos_con_queso.step3.body" = "Drain the figs and place them in the pot with fresh %i3 and %i2. Bring to a boil and cook until the figs begin to soften.";
"recipe.ec_dulce_de_higos_con_queso.step3.title" = "Boil with baking soda";
"recipe.ec_dulce_de_higos_con_queso.step4.body" = "Drain the figs and leave them covered with fresh water again so they continue losing bitterness and develop their traditional texture.";
"recipe.ec_dulce_de_higos_con_queso.step4.title" = "Rest the figs again";
"recipe.ec_dulce_de_higos_con_queso.step5.body" = "Drain the figs and return them to the pot. Add water, %i4, %i5, and %i6, then bring everything to a gentle boil.";
"recipe.ec_dulce_de_higos_con_queso.step5.title" = "Start the syrup";
"recipe.ec_dulce_de_higos_con_queso.step6.body" = "Lower the heat and simmer until the figs are fully tender and the syrup has darkened and thickened around them.";
"recipe.ec_dulce_de_higos_con_queso.step6.title" = "Cook slowly";
"recipe.ec_dulce_de_higos_con_queso.step7.body" = "Turn off the heat and let the figs cool in the syrup so they absorb more flavor and the syrup settles.";
"recipe.ec_dulce_de_higos_con_queso.step7.title" = "Let the figs rest";
"recipe.ec_dulce_de_higos_con_queso.step8.body" = "Serve the figs with some of their syrup and %i7 on the side.";
"recipe.ec_dulce_de_higos_con_queso.step8.title" = "Serve traditionally";
