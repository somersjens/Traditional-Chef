"recipe.lb_znoud_el_sit.drink.summary" = "Dessert wine (Muscat)";
"recipe.lb_znoud_el_sit.info" = "Znoud el sit are classic Lebanese crisp phyllo rolls filled with silky ashta cream, fried until golden, then dipped in fragrant attar syrup and finished with pistachios. They are served as a celebratory sweet, especially during gatherings and festive seasons, best enjoyed the same day while the pastry stays crunchy.";
"recipe.lb_znoud_el_sit.info.summary" = "Crisp cream rolls";
"recipe.lb_znoud_el_sit.name" = "Znoud el sit";
"recipe.lb_znoud_el_sit.step1.body" = "Combine %i7 with %i8 in a saucepan and bring to a boil, stirring to dissolve. Add %i9 and simmer until slightly thickened. Turn off the heat and stir in %i10 and %i11, then pour into a bowl to cool.";
"recipe.lb_znoud_el_sit.step1.title" = "Make the attar syrup";
"recipe.lb_znoud_el_sit.step2.body" = "In a saucepan, whisk %i1, %i2, %i4, and %i3 until smooth. Cook over medium heat, whisking constantly, until thick and glossy. Remove from heat and stir in %i5 and %i6.";
"recipe.lb_znoud_el_sit.step2.title" = "Cook the ashta";
"recipe.lb_znoud_el_sit.step3.body" = "Transfer the ashta to a shallow dish, cover the surface directly, and refrigerate until fully cooled and firm enough to pipe.";
"recipe.lb_znoud_el_sit.step3.title" = "Chill the ashta";
"recipe.lb_znoud_el_sit.step4.body" = "Melt the %i13. Cut the %i12 into long rectangles, brush lightly with butter, then roll into tight tubes and seal the edge with butter so they hold their shape.";
"recipe.lb_znoud_el_sit.step4.title" = "Form the phyllo rolls";
"recipe.lb_znoud_el_sit.step5.body" = "Pipe the chilled ashta into the phyllo tubes from both ends so the filling runs through the center without splitting the pastry.";
"recipe.lb_znoud_el_sit.step5.title" = "Fill with ashta";
"recipe.lb_znoud_el_sit.step6.body" = "Heat the %i14 and fry the filled rolls, turning gently, until crisp and evenly golden. Drain on paper towels.";
"recipe.lb_znoud_el_sit.step6.title" = "Fry until golden";
"recipe.lb_znoud_el_sit.step7.body" = "While still hot, dip the fried rolls briefly in the cooled attar syrup, then lift out to drain so they stay crisp.";
"recipe.lb_znoud_el_sit.step7.title" = "Dip in syrup";
"recipe.lb_znoud_el_sit.step8.body" = "Arrange on a platter, sprinkle with %i15, and serve.";
