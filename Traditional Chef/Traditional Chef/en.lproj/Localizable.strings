"recipe.ua_banosh.step3.title" = "Heat the sour cream base";
"recipe.ua_banosh.step4.body" = "Pour in %i1 slowly while whisking constantly so the porridge thickens without lumps.";
"recipe.ua_banosh.step4.title" = "Add the cornmeal";
"recipe.ua_banosh.step5.body" = "Cook over low heat, stirring steadily, until the banosh is thick, glossy, and pulls slightly from the sides of the pot.";
"recipe.ua_banosh.step5.title" = "Cook the banosh";
"recipe.ua_banosh.step6.body" = "Crumble %i5 so it can be scattered evenly over the hot banosh.";
"recipe.ua_banosh.step6.title" = "Prepare the bryndza";
"recipe.ua_banosh.step7.body" = "Spoon the banosh onto a serving platter and top it with the bryndza, the cracklings, and the onions.";
"recipe.ua_banosh.step7.title" = "Assemble the dish";
"recipe.ua_banosh.step8.body" = "Bring the banosh to the table immediately while the porridge is soft and the toppings are still hot.";
"recipe.ua_banosh.step8.title" = "Serve hot";
