"recipe.jp_unagi_kabayaki.drink.summary" = "Sake";
"recipe.jp_unagi_kabayaki.info" = "Unagi kabayaki is a traditional Japanese preparation of eel fillets skewered, grilled, steamed, then repeatedly brushed with a sweet-savory tare and grilled until lacquered and fragrant. It is commonly served as a special main dish over rice, especially in summer and on celebratory meals, with sansho pepper and pickles on the side.";
"recipe.jp_unagi_kabayaki.info.summary" = "Lacquered grilled eel";
"recipe.jp_unagi_kabayaki.name" = "Grilled eel";
"recipe.jp_unagi_kabayaki.step1.body" = "Trim the %i1 if needed and insert %i2 to hold each fillet flat and steady for grilling and steaming.";
"recipe.jp_unagi_kabayaki.step1.title" = "Prepare and skewer the eel";
"recipe.jp_unagi_kabayaki.step2.body" = "Combine the %i4, %i5, %i6, and %i7 in a saucepan and simmer gently until slightly thickened and glossy, then keep warm.";
"recipe.jp_unagi_kabayaki.step2.title" = "Make the kabayaki tare";
"recipe.jp_unagi_kabayaki.step3.body" = "Grill the skewered eel over medium heat until the surface firms and begins to color, turning carefully so it cooks evenly without tearing.";
"recipe.jp_unagi_kabayaki.step3.title" = "Grill the eel first time";
"recipe.jp_unagi_kabayaki.step4.body" = "Transfer the grilled eel to a steamer and steam until tender so the flesh softens and excess fat renders.";
"recipe.jp_unagi_kabayaki.step4.title" = "Steam the eel";
"recipe.jp_unagi_kabayaki.step5.body" = "Remove the eel from the steamer, pat the surface lightly if needed, and return it to the grill while keeping the tare ready for brushing.";
"recipe.jp_unagi_kabayaki.step5.title" = "Prepare for glazing";
"recipe.jp_unagi_kabayaki.step6.body" = "Brush the eel with tare and grill, turning and brushing several times until the surface is lacquered, caramelized, and fragrant.";
"recipe.jp_unagi_kabayaki.step6.title" = "Glaze and grill repeatedly";
"recipe.jp_unagi_kabayaki.step7.body" = "Let the eel rest briefly so the glaze sets and the flesh stays moist when cut.";
"recipe.jp_unagi_kabayaki.step7.title" = "Rest briefly";
"recipe.jp_unagi_kabayaki.step8.body" = "Remove the skewers, cut the eel into serving pieces, and place over bowls of %i8.";
"recipe.jp_unagi_kabayaki.step8.title" = "Cut and arrange";
"recipe.jp_unagi_kabayaki.step9.body" = "Brush with a final little tare, sprinkle with %i9, and serve immediately with %i10 on the side.";
"recipe.jp_unagi_kabayaki.step9.title" = "Finish and serve";
