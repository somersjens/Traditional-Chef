"recipe.us_la_crawfish_etouffee.drink.body" = "A bright Chenin Blanc or a crisp lager pairs with the buttery roux and sweet crawfish without clashing with the spices. For a non-alcoholic option, serve iced tea or sparkling water with lemon to cut the richness and refresh the palate.";
"recipe.us_la_crawfish_etouffee.drink.summary" = "White wine (Chenin Blanc)";
"recipe.us_la_crawfish_etouffee.info" = "Louisiana crawfish etouffee is a Creole-Cajun classic of crawfish tails gently smothered in a rich, buttery roux-based sauce built on the trinity of onion, celery, and bell pepper. The sauce is simmered until silky and savory with stock and tomatoes, then finished with green onion, parsley, and a squeeze of lemon before being spooned over steamed white rice. It’s traditionally comforting, aromatic, and meant to be eaten hot and saucy.";
"recipe.us_la_crawfish_etouffee.info.summary" = "Smothered crawfish stew";
"recipe.us_la_crawfish_etouffee.name" = "Crawfish étouffée";
"recipe.us_la_crawfish_etouffee.step1.body" = "Rinse %i17 until the water runs mostly clear. Combine rice with %i18 and %i19, bring to a boil, cover, and cook on low heat until tender. Remove from heat and keep covered.";
"recipe.us_la_crawfish_etouffee.step1.title" = "Cook the rice";
"recipe.us_la_crawfish_etouffee.step2.body" = "Melt %i1 in a heavy saucepan over medium heat. Whisk in %i2 and cook, stirring constantly, until the roux turns a light brown and smells nutty.";
"recipe.us_la_crawfish_etouffee.step2.title" = "Start the roux";
"recipe.us_la_crawfish_etouffee.step3.body" = "Stir in %i3, %i4, and %i5 and cook until softened, scraping the bottom so the roux does not scorch.";
"recipe.us_la_crawfish_etouffee.step3.title" = "Cook the trinity";
"recipe.us_la_crawfish_etouffee.step4.body" = "Stir in %i6, %i7, %i8, %i9, and %i10 until fragrant and evenly distributed.";
"recipe.us_la_crawfish_etouffee.step4.title" = "Add garlic and spices";
"recipe.us_la_crawfish_etouffee.step5.body" = "Stir in %i11, then gradually add %i12 while stirring until smooth and saucy. Bring to a gentle simmer.";
"recipe.us_la_crawfish_etouffee.step5.title" = "Build the sauce";
"recipe.us_la_crawfish_etouffee.step6.body" = "Keep the sauce at a low simmer, stirring occasionally, until it thickens slightly and the flavors meld.";
"recipe.us_la_crawfish_etouffee.step6.title" = "Simmer until silky";
"recipe.us_la_crawfish_etouffee.step7.body" = "Stir in %i13 and cook gently until heated through, keeping the simmer mild so the crawfish stay tender.";
"recipe.us_la_crawfish_etouffee.step7.title" = "Warm the crawfish";
"recipe.us_la_crawfish_etouffee.step8.body" = "Stir in %i14 and %i15, then squeeze in %i16 and taste for salt and heat.";
"recipe.us_la_crawfish_etouffee.step8.title" = "Finish with herbs and lemon";
"recipe.us_la_crawfish_etouffee.step9.body" = "Fluff the rice, spoon rice into bowls, and ladle the etouffee over the top so each serving is saucy and packed with crawfish.";
"recipe.us_la_crawfish_etouffee.step9.title" = "Serve";
