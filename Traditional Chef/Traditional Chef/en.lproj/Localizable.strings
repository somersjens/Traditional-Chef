"recipe.il_chopped_liver.drink.body" = "Pair with an off-dry to dry Riesling or a crisp, high-acid white that cuts through the richness. A light-bodied red like Pinot Noir also works if you prefer red. For a non-alcoholic option, serve sparkling water with lemon or unsweetened iced tea to refresh the palate.";
"recipe.il_chopped_liver.drink.summary" = "White wine (Riesling)";
"recipe.il_chopped_liver.info" = "A classic Ashkenazi Jewish deli-style spread made by cooking chicken livers with slow-cooked onions in rendered chicken fat, then chopping with hard-boiled eggs until rich and savory. Traditionally served chilled as a Shabbat or holiday appetizer, spread generously on rye bread.";
"recipe.il_chopped_liver.info.summary" = "Ashkenazi chopped liver";
"recipe.il_chopped_liver.name" = "Chopped liver";
"recipe.il_chopped_liver.step1.body" = "Place %i2 in a skillet over medium heat and cook until the fat renders and the pieces turn deeply golden and crisp. Stir and monitor so they brown evenly without burning. Lift out the crisp bits with a slotted spoon, leave the rendered fat in the pan, and set the crisp bits aside.";
"recipe.il_chopped_liver.step1.title" = "Render schmaltz and gribenes";
"recipe.il_chopped_liver.step2.body" = "Put %i4 in a saucepan, cover with %i8, and bring to a boil. Lower to a steady simmer and cook until firm. Drain, cool under cold water, then peel.";
"recipe.il_chopped_liver.step2.title" = "Hard-boil the eggs";
"recipe.il_chopped_liver.step3.body" = "Dice %i3 and add them to the skillet with the rendered chicken fat. Cook over medium-low heat, stirring often, until soft, sweet, and golden.";
"recipe.il_chopped_liver.step3.title" = "Cook the onions in schmaltz";
"recipe.il_chopped_liver.step4.body" = "Increase the heat slightly and add %i1 to the onions. Cook, turning occasionally, until browned on the outside and just cooked through with no raw centers.";
"recipe.il_chopped_liver.step4.title" = "Cook the chicken livers";
"recipe.il_chopped_liver.step5.body" = "Roughly chop the peeled eggs. Add the cooked livers and onions to a food processor along with the eggs and the reserved crisp bits. Pulse until chopped to a rustic spread, scraping down the bowl as needed.";
"recipe.il_chopped_liver.step5.title" = "Chop with eggs and crisp bits";
"recipe.il_chopped_liver.step6.body" = "Transfer the mixture to a bowl and stir. Season with %i5 and %i6, then pulse briefly again if you want a finer texture.";
"recipe.il_chopped_liver.step6.title" = "Season to taste";
"recipe.il_chopped_liver.step7.body" = "Spoon the chopped liver into a serving dish, smooth the top, cover, and refrigerate until cold and set.";
"recipe.il_chopped_liver.step7.title" = "Chill to set";
"recipe.il_chopped_liver.step8.body" = "Bring the chopped liver to the table chilled and spread it on %i7.";
"recipe.il_chopped_liver.step8.title" = "Serve traditionally";
