"recipe.lb_kibbeh_nayyeh.step2.title" = "Prepare the onion";
"recipe.lb_kibbeh_nayyeh.step3.body" = "Add the drained bulgur, %i5, and %i6 to the onion and mix well. Add the %i1 and knead vigorously until the mixture becomes smooth, cohesive, and paste-like.";
"recipe.lb_kibbeh_nayyeh.step3.title" = "Knead the kibbeh";
"recipe.lb_kibbeh_nayyeh.step4.body" = "Spread the kibbeh onto a serving plate, smoothing the surface and shaping shallow grooves with the back of a spoon.";
"recipe.lb_kibbeh_nayyeh.step4.title" = "Plate the kibbeh";
"recipe.lb_kibbeh_nayyeh.step5.body" = "Drizzle %i7 over the kibbeh and serve immediately with %i8, %i9, %i10, and %i11.";
"recipe.lb_kibbeh_nayyeh.step5.title" = "Finish and serve";
