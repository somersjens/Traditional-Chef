"recipe.cn_mapo_tofu.drink.body" = "A crisp light lager or dry rosé pairs well with the spicy oily sauce and numbing pepper, while hot jasmine tea is a classic non-alcoholic pairing that refreshes the palate and balances the richness.";
"recipe.cn_mapo_tofu.drink.summary" = "Beer (Lager)";
"recipe.cn_mapo_tofu.info" = "Mapo tofu is a traditional Sichuan dish of soft tofu simmered in a fragrant sauce of beef, Pixian doubanjiang, fermented black beans, chili, and Sichuan pepper, then thickened lightly and finished with scallions. It is a classic home-style shared main, served piping hot with steamed rice.";
"recipe.cn_mapo_tofu.info.summary" = "Sichuan spicy tofu";
"recipe.cn_mapo_tofu.name" = "Mapo tofu";
