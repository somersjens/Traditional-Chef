"recipe.pt_sardinhas_assadas.drink.body" = "A crisp Vinho Verde is the classic match for smoky grilled sardines, keeping the meal bright and refreshing. A dry rosé also works well served cold. Non-alcoholic pairing: sparkling water with lemon or a chilled alcohol-free lager.";
"recipe.pt_sardinhas_assadas.drink.summary" = "White wine (Vinho Verde)";
"recipe.pt_sardinhas_assadas.info" = "Sardinhas Assadas are the iconic Portuguese grilled sardines, traditionally cooked over hot charcoal until the skin blisters and the flesh stays juicy, then served simply with coarse salt, lemon, and roasted peppers or a light salad. They are most famously enjoyed in summer, especially during the Santos Populares festivities, and are traditionally eaten with broa or crusty bread to catch the flavorful juices.";
"recipe.pt_sardinhas_assadas.info.summary" = "Summer charcoal sardines";
"recipe.pt_sardinhas_assadas.name" = "Grilled sardines";
"recipe.pt_sardinhas_assadas.step1.body" = "Light the charcoal and let it burn until the coals are covered with ash and very hot. Clean and heat the grill grate.";
"recipe.pt_sardinhas_assadas.step1.title" = "Prepare the fire";
"recipe.pt_sardinhas_assadas.step2.body" = "Rinse the %i1 quickly, drain, and pat dry. Sprinkle generously with %i2 and let them stand briefly while the grill reaches peak heat.";
"recipe.pt_sardinhas_assadas.step2.title" = "Salt the sardines";
"recipe.pt_sardinhas_assadas.step3.body" = "Place the %i4 on the hot grill and cook, turning, until the skins blister and char in spots. Transfer to a platter, season with salt, and drizzle with %i5.";
"recipe.pt_sardinhas_assadas.step3.title" = "Grill the peppers";
"recipe.pt_sardinhas_assadas.step4.body" = "Place the sardines on the hottest part of the grill and cook until the skins blister and release easily, then turn and cook until just done through and juicy.";
"recipe.pt_sardinhas_assadas.step4.title" = "Grill the sardines";
"recipe.pt_sardinhas_assadas.step5.body" = "Transfer sardines to a platter, add %i3 on the side, and serve immediately with the grilled peppers and %i6 for eating and soaking up the juices.";
"recipe.pt_sardinhas_assadas.step5.title" = "Serve";
