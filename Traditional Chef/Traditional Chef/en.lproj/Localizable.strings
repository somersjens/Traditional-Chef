"recipe.tr_acili_ezme.drink.body" = "A juicy Grenache or a soft Syrah pairs well with the sweet-tangy heat and roasted-pepper depth of the paste. For a non-alcoholic option, serve chilled ayran or sparkling water with lemon.";
"recipe.tr_acili_ezme.drink.summary" = "Red wine (Grenache)";
"recipe.tr_acili_ezme.info" = "Acılı Ezme is a traditional Turkish spicy chopped salad-meze from the kebab-house table, made by finely mincing tomatoes, onion, hot green peppers, herbs, and garlic, then binding it with pepper and tomato paste, pomegranate molasses, lemon, olive oil, and warm spices. It is served as part of mezze or alongside grilled meats, meant to be scooped with flatbread while still fresh and vibrant.";
"recipe.tr_acili_ezme.info.summary" = "Spicy kebab-house salad";
"recipe.tr_acili_ezme.name" = "Acılı ezme";
"recipe.tr_acili_ezme.step1.body" = "Finely chop the %i1, %i2, and %i3. Crush the %i4. Chop the %i5 and %i6 very finely.";
"recipe.tr_acili_ezme.step1.title" = "Prep the vegetables";
"recipe.tr_acili_ezme.step2.body" = "Toss the chopped tomatoes with %i15, let them release excess juice, then drain through a fine mesh strainer so the ezme stays thick.";
"recipe.tr_acili_ezme.step2.title" = "Drain the tomatoes";
"recipe.tr_acili_ezme.step3.body" = "In a bowl, mix the %i7 and %i8 until smooth, then stir in %i12, %i13, and %i14.";
"recipe.tr_acili_ezme.step3.title" = "Build the base";
"recipe.tr_acili_ezme.step4.body" = "Add the drained tomatoes, onion, green peppers, garlic, parsley, and mint to the bowl. Mix thoroughly until evenly combined.";
"recipe.tr_acili_ezme.step4.title" = "Combine and season";
"recipe.tr_acili_ezme.step5.body" = "Stir in %i11 and %i9, then drizzle in %i10 and mix until glossy and well bound.";
"recipe.tr_acili_ezme.step5.title" = "Finish with acids and oil";
"recipe.tr_acili_ezme.step6.body" = "Let the acılı ezme rest so the flavors meld and the texture tightens.";
"recipe.tr_acili_ezme.step6.title" = "Rest to meld";
"recipe.tr_acili_ezme.step7.body" = "Spoon into a serving bowl and serve with %i16 for scooping.";
"recipe.tr_acili_ezme.step7.title" = "Serve";
