"recipe.kh_num_akor.step2.title" = "Mix batter";
"recipe.kh_num_akor.step3.body" = "Cover the batter and leave it to ferment until airy and lightly bubbly.";
"recipe.kh_num_akor.step3.title" = "Ferment batter";
"recipe.kh_num_akor.step4.body" = "Bring water to a boil in the steamer and lightly heat the cake molds so the batter starts cooking quickly when poured.";
"recipe.kh_num_akor.step4.title" = "Prepare steamer and molds";
"recipe.kh_num_akor.step5.body" = "Stir the batter gently, ladle it into the molds, and steam until the cakes are set and springy.";
"recipe.kh_num_akor.step5.title" = "Steam rice cakes";
