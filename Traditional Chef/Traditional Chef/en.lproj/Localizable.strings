"recipe.dz_makroud.drink.body" = "A floral dessert wine like Muscat matches the honey and orange blossom while complementing the date filling. If you prefer something less sweet, a light sparkling wine can refresh the palate. Non-alcoholic pairing: hot mint tea or black coffee.";
"recipe.dz_makroud.drink.summary" = "Dessert wine (Muscat)";
"recipe.dz_makroud.info" = "Makroud is a traditional Algerian semolina pastry filled with a fragrant date paste, shaped into ridged diamonds, fried until golden, then dipped in warm honey perfumed with orange blossom. It is a classic sweet for Eid and celebrations, served in small pieces alongside mint tea.";
"recipe.dz_makroud.info.summary" = "Date-filled semolina pastry";
"recipe.dz_makroud.name" = "Makroud";
"recipe.dz_makroud.step1.body" = "Heat %i10 with %i11 and lemon juice until hot and fluid, then off the heat stir in %i13 and keep warm.";
"recipe.dz_makroud.step1.title" = "Warm the honey syrup";
"recipe.dz_makroud.step2.body" = "Knead the %i7 with %i8 and a little %i9 until smooth and pliable, then form into a long log.";
"recipe.dz_makroud.step2.title" = "Make the date filling";
"recipe.dz_makroud.step3.body" = "Rub the melted %i3 into %i1 and %i2 until evenly moistened, then add %i5 and %i4 and mix. Add %i6 gradually to form a cohesive, moldable dough without kneading heavily.";
"recipe.dz_makroud.step3.title" = "Prepare the semolina dough";
"recipe.dz_makroud.step4.body" = "Form the dough into a long trough, place the date log inside, enclose to seal, then press in the makroud mold to create ridges and flatten slightly.";
"recipe.dz_makroud.step4.title" = "Fill and shape";
"recipe.dz_makroud.step5.body" = "Cut the filled strip on the diagonal into diamond pieces, keeping shapes uniform for even frying.";
"recipe.dz_makroud.step5.title" = "Cut into diamonds";
"recipe.dz_makroud.step6.body" = "Heat %i14 for frying and fry the makroud in batches, turning until evenly deep golden. Drain briefly on paper towels.";
"recipe.dz_makroud.step6.title" = "Fry until golden";
"recipe.dz_makroud.step7.body" = "Dip the hot makroud into the warm honey syrup so it glazes and absorbs, then lift out and let excess drip off.";
"recipe.dz_makroud.step7.title" = "Dip in honey";
"recipe.dz_makroud.step8.body" = "Place on a rack and let the glaze set as the pastries cool.";
"recipe.dz_makroud.step8.title" = "Set and cool";
"recipe.dz_makroud.step9.body" = "Serve at room temperature with mint tea or coffee.";
"recipe.dz_makroud.step9.title" = "Serve";
