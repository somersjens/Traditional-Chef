"recipe.il_gefilte_fish.drink.body" = "Pair with a crisp, high-acid white such as Riesling or Chenin Blanc to balance the mild, savory fish and sweet notes from the broth. For a non-alcoholic option, serve sparkling water with lemon or a tart apple spritzer.";
"recipe.il_gefilte_fish.drink.summary" = "White wine (Riesling)";
"recipe.il_gefilte_fish.info" = "Gefilte fish is a traditional Ashkenazi Jewish appetizer of seasoned ground fish formed into oval quenelles and gently poached in a fragrant fish broth with vegetables. It is served cold, often with a slice of carrot on top and a sharp beet-horseradish chrein, commonly appearing on Shabbat and holiday tables in Israel and beyond.";
"recipe.il_gefilte_fish.info.summary" = "Holiday poached fish";
"recipe.il_gefilte_fish.name" = "Gefilte fish";
"recipe.il_gefilte_fish.step1.body" = "Place the %i1 in a large stockpot with %i2, %i3, %i4, %i5, and %i6. Cover with %i7 and bring to a boil, skimming any foam from the surface.";
"recipe.il_gefilte_fish.step1.title" = "Start the fish broth";
"recipe.il_gefilte_fish.step10.body" = "Place the %i16 in a saucepan, cover with water, and simmer until tender. Drain, cool, and peel.";
"recipe.il_gefilte_fish.step10.title" = "Cook the beets for chrein";
"recipe.il_gefilte_fish.step11.body" = "Grate the beets and %i17, then combine with %i18, sugar, and salt. Mix until evenly tinted and sharply aromatic.";
"recipe.il_gefilte_fish.step11.title" = "Prepare the chrein";
"recipe.il_gefilte_fish.step12.body" = "Cover and refrigerate the chrein so the flavors meld and the heat settles.";
"recipe.il_gefilte_fish.step12.title" = "Chill the chrein";
"recipe.il_gefilte_fish.step13.body" = "Serve the gefilte fish cold, topped with a slice of carrot from the broth, with chrein on the side and %i19 for spreading and eating.";
"recipe.il_gefilte_fish.step13.title" = "Serve traditionally";
"recipe.il_gefilte_fish.step2.body" = "Lower to a gentle simmer and cook until the broth is flavorful and the vegetables are tender. Keep the simmer steady so the broth stays clear.";
"recipe.il_gefilte_fish.step2.title" = "Simmer the broth";
"recipe.il_gefilte_fish.step3.body" = "Strain the broth into a clean pot and discard the solids. Keep the broth hot at a bare simmer for poaching.";
"recipe.il_gefilte_fish.step3.title" = "Strain and reserve the broth";
"recipe.il_gefilte_fish.step4.body" = "Process onions until very fine, then combine with the %i8 in a bowl. Add %i10, %i11, %i12, %i13, %i14, and %i15, and mix until smooth and cohesive.";
"recipe.il_gefilte_fish.step4.title" = "Make the fish mixture";
"recipe.il_gefilte_fish.step5.body" = "Cover the fish mixture and refrigerate until firm enough to shape neatly.";
"recipe.il_gefilte_fish.step5.title" = "Chill the mixture";
"recipe.il_gefilte_fish.step6.body" = "With wet hands, form the mixture into oval quenelles and smooth the surface so they hold together during poaching.";
"recipe.il_gefilte_fish.step6.title" = "Shape the quenelles";
"recipe.il_gefilte_fish.step7.body" = "Slip the quenelles into the barely simmering broth in a single layer. Keep the heat low so the liquid trembles gently, and poach until the quenelles are cooked through and tender.";
"recipe.il_gefilte_fish.step7.title" = "Poach in the broth";
"recipe.il_gefilte_fish.step8.body" = "Turn off the heat and let the quenelles cool in the broth so they stay moist and absorb flavor.";
"recipe.il_gefilte_fish.step8.title" = "Cool in broth";
"recipe.il_gefilte_fish.step9.body" = "Transfer the quenelles to a covered container with enough broth to keep them moist and refrigerate until fully cold and set.";
"recipe.il_gefilte_fish.step9.title" = "Chill for serving";
