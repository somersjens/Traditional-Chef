"recipe.sn_yassa_poulet.drink.body" = "A crisp white wine such as Sauvignon Blanc pairs well with the lemony onion sauce and chicken. For a non-alcoholic option, serve chilled ginger drink or bissap (hibiscus drink).";
"recipe.sn_yassa_poulet.drink.summary" = "White wine (Sauvignon)";
"recipe.sn_yassa_poulet.info" = "Yassa Poulet is a traditional Senegalese dish of chicken marinated in lemon, mustard, and aromatics, then grilled or browned and simmered with a generous mound of slowly cooked onions until tangy, savory, and deeply aromatic, traditionally served over plain white rice to catch the sauce.";
"recipe.sn_yassa_poulet.info.summary" = "Lemon onion chicken";
"recipe.sn_yassa_poulet.name" = "Yassa chicken";
"recipe.sn_yassa_poulet.step1.body" = "Slice the %i3 thinly. Juice the %i4 and mix the juice with %i5, crushed %i6, %i8, %i7, and the whole %i9.";
"recipe.sn_yassa_poulet.step1.title" = "Prep onions and marinade";
"recipe.sn_yassa_poulet.step2.body" = "Coat the %i2 and some of the onions with the lemon-mustard mixture, then cover and refrigerate so the flavor penetrates.";
"recipe.sn_yassa_poulet.step2.title" = "Marinate the chicken";
"recipe.sn_yassa_poulet.step3.body" = "Rinse the %i1 repeatedly in a bowl with water, then drain well.";
"recipe.sn_yassa_poulet.step3.title" = "Wash the rice";
"recipe.sn_yassa_poulet.step4.body" = "Cook the rinsed rice in a saucepan with %i11 until tender, then keep covered off the heat.";
"recipe.sn_yassa_poulet.step4.title" = "Cook the rice";
"recipe.sn_yassa_poulet.step5.body" = "Lift the chicken from the marinade and grill or broil until well browned, then set aside.";
"recipe.sn_yassa_poulet.step5.title" = "Brown the chicken";
"recipe.sn_yassa_poulet.step6.body" = "Heat %i10 in a large skillet and add all onions with a pinch of salt, stirring until they begin to soften and release their juices.";
"recipe.sn_yassa_poulet.step6.title" = "Start the onions";
"recipe.sn_yassa_poulet.step7.body" = "Cover and cook the onions gently, stirring occasionally, until very soft and lightly golden, adding a little water if they start to stick.";
"recipe.sn_yassa_poulet.step7.title" = "Cook onions down";
"recipe.sn_yassa_poulet.step8.body" = "Add the browned chicken and the remaining marinade to the onions, cover, and simmer until the chicken is cooked through and the sauce is tangy and savory.";
"recipe.sn_yassa_poulet.step8.title" = "Simmer chicken in the sauce";
"recipe.sn_yassa_poulet.step9.body" = "Remove the chili, taste and adjust seasoning, then serve the chicken and onion sauce over rice.";
"recipe.sn_yassa_poulet.step9.title" = "Serve";
