"recipe.lb_knafeh.drink.body" = "Pair with a lightly sweet Muscat or late-harvest Riesling to echo the floral attar and buttery semolina. For a non-alcoholic option, serve strong Arabic coffee or unsweetened mint tea.";
"recipe.lb_knafeh.drink.summary" = "Dessert wine (Muscat)";
"recipe.lb_knafeh.info" = "Lebanese knafeh bi jibneh is a warm semolina-and-butter pastry layered with stretchy desalted Akkawi cheese, baked until golden, then soaked with fragrant attar syrup scented with flower waters. It is commonly enjoyed as a special breakfast or dessert, often tucked into sesame kaak bread and served immediately while the cheese is melty.";
"recipe.lb_knafeh.info.summary" = "Cheese breakfast knafeh";
"recipe.lb_knafeh.name" = "Knafeh";
"recipe.lb_knafeh.step1.body" = "Cut the %i1 into pieces and soak in %i2, changing the water a few times, until the cheese tastes mildly salty. Drain well and pat dry.";
"recipe.lb_knafeh.step1.title" = "Desalt the cheese";
"recipe.lb_knafeh.step2.body" = "Combine %i8 with water in a saucepan and bring to a boil, stirring to dissolve. Add %i10, simmer until slightly thickened, then turn off the heat and stir in %i11 and %i12. Cool completely.";
"recipe.lb_knafeh.step2.title" = "Make the attar syrup";
"recipe.lb_knafeh.step3.body" = "In a saucepan, whisk %i4 with %i5 and %i3. Cook over medium heat, stirring constantly, until thick and smooth. Stir in %i6 until fully melted and absorbed, then mix in %i7 until evenly tinted.";
"recipe.lb_knafeh.step3.title" = "Cook the semolina base";
"recipe.lb_knafeh.step4.body" = "Butter the baking pan. Spread half the semolina base evenly in the pan, press gently to level, then distribute the drained cheese evenly over it. Cover with the remaining semolina base and smooth the top.";
"recipe.lb_knafeh.step4.title" = "Assemble the knafeh";
"recipe.lb_knafeh.step5.body" = "Bake until the knafeh is set and deeply golden at the edges and across the surface.";
"recipe.lb_knafeh.step5.title" = "Bake until golden";
"recipe.lb_knafeh.step6.body" = "Immediately after baking, pour cooled attar evenly over the hot knafeh so it absorbs and stays crisp on top while the cheese remains melty.";
"recipe.lb_knafeh.step6.title" = "Soak with syrup";
"recipe.lb_knafeh.step7.body" = "Sprinkle with %i13, cut into portions, and lift onto a platter.";
"recipe.lb_knafeh.step7.title" = "Garnish and portion";
"recipe.lb_knafeh.step8.body" = "Warm the %i14 briefly, split it, and serve the knafeh tucked inside or alongside, eaten immediately while warm.";
"recipe.lb_knafeh.step8.title" = "Serve with kaak";
