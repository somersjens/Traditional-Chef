"recipe.hk_cheung_fun.drink.body" = "Cheung fun is traditionally paired with Chinese tea rather than wine, especially jasmine or pu-erh at dim sum. If serving wine, a very light dry white can work, while hot jasmine tea is the classic non-alcoholic pairing.";
"recipe.hk_cheung_fun.drink.summary" = "Jasmine tea";
"recipe.hk_cheung_fun.info" = "A traditional Cantonese dim sum dish of soft steamed rice noodle sheets rolled and cut, then served hot with a lightly sweet soy sauce. In Hong Kong it is commonly eaten during yum cha and shared as part of a table of steamed and fried small dishes.";
"recipe.hk_cheung_fun.info.summary" = "Steamed rice rolls";
"recipe.hk_cheung_fun.name" = "Cheung fun";
"recipe.hk_cheung_fun.step1.body" = "Soak the %i8 briefly until softened, drain, and finely chop them. Finely slice the %i7 and set both aside.";
"recipe.hk_cheung_fun.step1.title" = "Prepare garnish";
"recipe.hk_cheung_fun.step2.body" = "Whisk together %i1, %i2, %i3, %i4, %i5, and %i6 until smooth, then let the batter stand briefly.";
"recipe.hk_cheung_fun.step2.title" = "Make the batter";
"recipe.hk_cheung_fun.step3.body" = "Combine %i9, %i10, %i11, %i12, and %i13 in a small saucepan and heat gently until the sugar dissolves.";
"recipe.hk_cheung_fun.step3.title" = "Make the soy sauce";
"recipe.hk_cheung_fun.step4.body" = "Add %i14 to the steamer and bring it to a steady boil while lightly oiling the flat steaming tray.";
"recipe.hk_cheung_fun.step4.title" = "Prepare the steamer";
"recipe.hk_cheung_fun.step5.body" = "Stir the batter well, pour a thin layer into the oiled tray, sprinkle a little dried shrimp and spring onion, and steam covered until the sheet is set.";
"recipe.hk_cheung_fun.step5.title" = "Steam the first sheet";
"recipe.hk_cheung_fun.step6.body" = "Remove the tray, brush the surface lightly with oil, then use a spatula to loosen and roll the noodle sheet into a log.";
"recipe.hk_cheung_fun.step6.title" = "Roll the noodle sheet";
"recipe.hk_cheung_fun.step7.body" = "Stir the batter before each batch and continue steaming and rolling sheets until all batter and garnish are used.";
"recipe.hk_cheung_fun.step7.title" = "Repeat with remaining batter";
"recipe.hk_cheung_fun.step8.body" = "Cut the rolled cheung fun into serving lengths and arrange on a warm plate.";
"recipe.hk_cheung_fun.step8.title" = "Cut the rolls";
"recipe.hk_cheung_fun.step9.body" = "Spoon the warm soy sauce over the cheung fun and serve immediately while soft and hot.";
"recipe.hk_cheung_fun.step9.title" = "Sauce and serve";
"recipe.hk_cheung_fun.tool.t1" = "Steamer";
