"recipe.ir_ghormeh_sabzi.step2.title" = "Prepare herbs and aromatics";
"recipe.ir_ghormeh_sabzi.step3.body" = "Heat %i4 in a skillet and fry the chopped herbs slowly, stirring often, until very dark green and fragrant. Stir in %i11 near the end and cook briefly.";
"recipe.ir_ghormeh_sabzi.step3.title" = "Fry the herbs";
"recipe.ir_ghormeh_sabzi.step4.body" = "In a heavy pot, cook the onion in a little oil until softened, then add %i3 and %i1 and brown well to build flavor.";
"recipe.ir_ghormeh_sabzi.step4.title" = "Brown meat and onion";
"recipe.ir_ghormeh_sabzi.step5.body" = "Add the soaked beans, dried limes, %i12, %i13, and enough water to cover well. Bring to a gentle boil, then simmer until the meat and beans are mostly tender.";
"recipe.ir_ghormeh_sabzi.step5.title" = "Simmer with beans and limes";
"recipe.ir_ghormeh_sabzi.step6.body" = "Stir the fried herb mixture into the pot and continue simmering until the stew is thick, deeply aromatic, and the meat is fully tender, adjusting with water if needed.";
"recipe.ir_ghormeh_sabzi.step6.title" = "Add herbs and finish the stew";
"recipe.ir_ghormeh_sabzi.step7.body" = "Rinse %i15 until the water runs mostly clear, then soak it in salted water so the grains hydrate evenly.";
"recipe.ir_ghormeh_sabzi.step7.title" = "Soak the rice";
"recipe.ir_ghormeh_sabzi.step8.body" = "Bring a large pot of water to a boil. Drain the soaked rice and boil until the grains are softened on the outside but still firm in the center, then drain well.";
"recipe.ir_ghormeh_sabzi.step8.title" = "Parboil the rice";
"recipe.ir_ghormeh_sabzi.step9.body" = "Return the drained rice to a nonstick pot, poke a few steam vents, dot with %i16, wrap the lid with a tea towel, and steam on low heat until fluffy and fully cooked.";
"recipe.ir_ghormeh_sabzi.step9.title" = "Steam the chelo";
