"recipe.cn_xingren_doufu.drink.body" = "Light floral tea pairs better than wine with this delicate dessert, and chilled jasmine tea or plain cold water are classic non-alcoholic options that keep the palate refreshed.";
"recipe.cn_xingren_doufu.drink.summary" = "Jasmine tea";
"recipe.cn_xingren_doufu.info" = "Xingren doufu is a traditional Chinese chilled dessert made from almond-flavored milk set into a smooth jelly, cut into cubes, and served in a light sweet syrup, often with fruit. It is commonly served at banquets and restaurants as a cooling finish to a rich meal, especially in summer.";
"recipe.cn_xingren_doufu.info.summary" = "Chilled almond jelly";
"recipe.cn_xingren_doufu.name" = "Almond jelly";
"recipe.cn_xingren_doufu.step1.body" = "Combine the %i1, %i2, %i3, and %i5 in a saucepan and whisk well so the agar is evenly dispersed before heating.";
"recipe.cn_xingren_doufu.step1.title" = "Mix the jelly base";
"recipe.cn_xingren_doufu.step2.body" = "Heat the mixture gently, stirring continuously, until it reaches a simmer and the sugar and agar are fully dissolved into a smooth base.";
"recipe.cn_xingren_doufu.step2.title" = "Cook and dissolve the agar";
"recipe.cn_xingren_doufu.step3.body" = "Remove from the heat, stir in %i4, and mix thoroughly so the fragrance is evenly distributed.";
"recipe.cn_xingren_doufu.step3.title" = "Add almond flavor";
"recipe.cn_xingren_doufu.step4.body" = "Pour the hot almond jelly mixture into a mold or shallow tray and let it cool briefly at room temperature.";
"recipe.cn_xingren_doufu.step4.title" = "Pour into mold";
"recipe.cn_xingren_doufu.step5.body" = "Refrigerate the jelly until fully set and firm enough to cut neatly.";
"recipe.cn_xingren_doufu.step5.title" = "Chill until set";
"recipe.cn_xingren_doufu.step6.body" = "Simmer %i6 with %i7 until dissolved and clear, then cool the syrup completely and chill it.";
"recipe.cn_xingren_doufu.step6.title" = "Make the sweet syrup";
"recipe.cn_xingren_doufu.step7.body" = "Unmold the almond jelly and cut it into cubes, then drain the %i8.";
"recipe.cn_xingren_doufu.step7.title" = "Cut the jelly and prepare fruit";
"recipe.cn_xingren_doufu.step8.body" = "Divide the jelly cubes and mandarin oranges into serving bowls, pour over the chilled sweet syrup, and serve cold.";
"recipe.cn_xingren_doufu.step8.title" = "Assemble and serve";
