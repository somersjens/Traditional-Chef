"recipe.it_pesto_alla_genovese.step2.title" = "Boil the water";
"recipe.it_pesto_alla_genovese.step3.body" = "Add the potato and cook until it is starting to soften.";
"recipe.it_pesto_alla_genovese.step3.title" = "Cook the potato";
"recipe.it_pesto_alla_genovese.step4.body" = "Add the green beans, then add %i1 and cook until al dente.";
