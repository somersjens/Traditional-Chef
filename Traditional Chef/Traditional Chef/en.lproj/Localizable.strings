"recipe.pe_carapulcra.drink.body" = "Pair with a medium-bodied Garnacha or Tempranillo to match the smoky chili and rich pork. A malty amber ale also works well. For a non-alcoholic option, serve chicha morada or sparkling water with lime.";
"recipe.pe_carapulcra.drink.summary" = "Red wine (Garnacha)";
"recipe.pe_carapulcra.info" = "Carapulcra is an ancient Andean-Peruvian stew made with papa seca (rehydrated dried potato) simmered with pork belly in a deep, smoky ají panca base, perfumed with cloves and cinnamon and enriched with roasted ground peanuts and a splash of port. It is traditionally served hot as a thick, hearty main course, commonly accompanied by white rice.";
"recipe.pe_carapulcra.info.summary" = "Ancient dried potato stew";
"recipe.pe_carapulcra.name" = "Carapulcra";
"recipe.pe_carapulcra.step1.body" = "Heat a dry skillet over medium heat and toast the %i1 briefly, stirring so it warms and lightly roasts without burning. Let it cool.";
"recipe.pe_carapulcra.step1.title" = "Roast the dried potato";
"recipe.pe_carapulcra.step10.body" = "Serve the carapulcra hot alongside white rice.";
"recipe.pe_carapulcra.step10.title" = "Serve";
"recipe.pe_carapulcra.step2.body" = "Rinse the toasted dried potato well, then place it in a bowl and cover with %i2 to about double its volume.";
"recipe.pe_carapulcra.step2.title" = "Wash and soak";
"recipe.pe_carapulcra.step3.body" = "Leave the dried potato to soak overnight until fully rehydrated, then drain well.";
"recipe.pe_carapulcra.step3.title" = "Rehydrate overnight";
"recipe.pe_carapulcra.step4.body" = "Rinse the %i16, then cook it with %i17 until tender and fluffy. Keep warm for serving.";
"recipe.pe_carapulcra.step4.title" = "Cook the rice";
"recipe.pe_carapulcra.step5.body" = "Cut the %i3 into chunks. Heat %i13 in a skillet over medium heat and brown the pork on all sides, then remove it to a plate.";
"recipe.pe_carapulcra.step5.title" = "Brown the pork";
"recipe.pe_carapulcra.step6.body" = "In the same skillet, sauté the diced %i4 until softened, then add minced %i5, %i6, %i7, and %i8 and cook until fragrant and the paste looks cooked.";
"recipe.pe_carapulcra.step6.title" = "Build the chili base";
"recipe.pe_carapulcra.step7.body" = "Blend the %i14 until finely ground, keeping some texture rather than a smooth butter.";
"recipe.pe_carapulcra.step7.title" = "Blend the peanuts";
"recipe.pe_carapulcra.step8.body" = "Add the drained rehydrated dried potato and the browned pork to a pot. Pour in %i10 to cover, add %i11 and %i12, and simmer uncovered, stirring occasionally, until the potato is tender and the stew thickens.";
"recipe.pe_carapulcra.step8.title" = "Simmer the stew";
"recipe.pe_carapulcra.step9.body" = "Stir in the ground peanuts and %i15, then simmer until the flavors meld. Season with %i9 until balanced, and remove the cloves and cinnamon stick before serving.";
"recipe.pe_carapulcra.step9.title" = "Finish and season";
