"recipe.pl_barszcz_czerwony.drink.body" = "Pair with a crisp, mineral dry white wine such as Riesling or Grüner Veltliner to match the beet’s sweetness and the broth’s gentle tang. A light, chilled Polish-style lager also works well with the mushroom dumplings. Non-alcoholic option: sparkling apple juice or a lightly sparkling water with lemon.";
"recipe.pl_barszcz_czerwony.drink.summary" = "White wine (Riesling)";
"recipe.pl_barszcz_czerwony.info" = "Barszcz czerwony is a clear, ruby beet broth central to Polish Wigilia traditions, gently sweet, earthy, and pleasantly sour from fermented beet kvass. It is served hot with small mushroom dumplings called uszka, whose savory filling perfumes the broth and turns it into a festive first course.";
"recipe.pl_barszcz_czerwony.info.summary" = "Wigilia beet broth";
"recipe.pl_barszcz_czerwony.name" = "Red borscht";
"recipe.pl_barszcz_czerwony.step1.body" = "Peel the %i1 for the kvass and cut them into thick slices. Place them in a clean jar with %i4, %i5, %i6, and %i7. Dissolve %i3 in %i2 and pour it over to fully cover the beets.";
"recipe.pl_barszcz_czerwony.step1.title" = "Prepare beet kvass jar";
"recipe.pl_barszcz_czerwony.step10.body" = "Let the dough rest covered so it relaxes and becomes easier to roll.";
"recipe.pl_barszcz_czerwony.step10.title" = "Rest the dough";
"recipe.pl_barszcz_czerwony.step11.body" = "Roll the dough thinly and cut into small squares. Place a little filling in the center of each, fold into triangles, seal well, then join the corners to form little ears. Keep formed dumplings covered.";
"recipe.pl_barszcz_czerwony.step11.title" = "Shape the uszka";
"recipe.pl_barszcz_czerwony.step12.body" = "Bring salted %i2 to a gentle boil. Cook dumplings in batches until they float and the dough is tender, then lift out with a slotted spoon and drain.";
"recipe.pl_barszcz_czerwony.step12.title" = "Boil the uszka";
"recipe.pl_barszcz_czerwony.step13.body" = "Ladle hot barszcz into bowls and add uszka. Finish with chopped %i25 and serve immediately.";
"recipe.pl_barszcz_czerwony.step13.title" = "Serve";
"recipe.pl_barszcz_czerwony.step2.body" = "Cover the jar with a breathable cover and keep at room temperature until the liquid turns pleasantly sour. Skim any harmless foam and keep the beets submerged.";
"recipe.pl_barszcz_czerwony.step2.title" = "Ferment the beet kvass";
"recipe.pl_barszcz_czerwony.step3.body" = "Strain the fermented liquid through cheesecloth or a fine sieve. Discard aromatics and reserve the sour beet kvass for finishing the soup.";
"recipe.pl_barszcz_czerwony.step3.title" = "Strain the beet kvass";
"recipe.pl_barszcz_czerwony.step4.body" = "Rinse %i10, cover with %i2, and let them soak. Then simmer them gently in the soaking liquid until fully tender. Reserve both the mushrooms and the mushroom liquid.";
"recipe.pl_barszcz_czerwony.step4.title" = "Soak and simmer mushrooms";
"recipe.pl_barszcz_czerwony.step5.body" = "Peel and slice the %i8. Add %i9 to a saucepan with the beets, %i12, %i13, and the reserved mushroom liquid. Bring to a gentle simmer.";
"recipe.pl_barszcz_czerwony.step5.title" = "Start the borscht base";
"recipe.pl_barszcz_czerwony.step6.body" = "Keep the broth at a bare simmer until deeply colored and aromatic. Do not boil hard. Strain the broth, pressing gently to extract flavor, and return the clear liquid to the pot.";
"recipe.pl_barszcz_czerwony.step6.title" = "Simmer to extract flavor";
"recipe.pl_barszcz_czerwony.step7.body" = "Season the broth with %i14, %i15, %i16, and %i19. Add beet kvass little by little until the soup is pleasantly sour and balanced. Keep hot without boiling.";
"recipe.pl_barszcz_czerwony.step7.title" = "Season the borscht";
"recipe.pl_barszcz_czerwony.step8.body" = "Finely chop the cooked mushrooms. Dice %i17 and cook it in %i18 until soft and golden, then mix with the mushrooms. Season with %i20 and pepper and let the filling cool.";
"recipe.pl_barszcz_czerwony.step8.title" = "Make mushroom filling";
"recipe.pl_barszcz_czerwony.step9.body" = "Combine %i21 and %i24 in a bowl. Add %i22 and %i23, then knead until smooth and elastic. Cover the dough so it does not dry out.";
"recipe.pl_barszcz_czerwony.step9.title" = "Mix and knead dough";
