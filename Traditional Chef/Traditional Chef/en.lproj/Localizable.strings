"recipe.ve_quesillo.step3.title" = "Fill the mold";
"recipe.ve_quesillo.step4.body" = "Place the mold in a deep baking dish and pour in %i7 around it to create a gentle bain-marie.";
"recipe.ve_quesillo.step4.title" = "Set up the water bath";
"recipe.ve_quesillo.step5.body" = "Bake until the custard is just set and still slightly trembling in the center.";
"recipe.ve_quesillo.step5.title" = "Bake the quesillo";
"recipe.ve_quesillo.step6.body" = "Remove the mold from the water bath and let the quesillo cool until it reaches room temperature.";
"recipe.ve_quesillo.step6.title" = "Cool the mold";
"recipe.ve_quesillo.step7.body" = "Refrigerate the quesillo until fully cold and firm so it unmolds cleanly.";
"recipe.ve_quesillo.step7.title" = "Chill thoroughly";
"recipe.ve_quesillo.step8.body" = "Run a knife around the edge, invert the mold onto a plate, and serve the quesillo cold with the caramel flowing over the top.";
"recipe.ve_quesillo.step8.title" = "Unmold and serve";
