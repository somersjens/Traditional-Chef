"recipe.az_plov.drink.body" = "A dry white wine such as Chardonnay or a light Pinot Noir pairs well with the fragrant saffron rice and sweet-savory lamb accompaniment. For a non-alcoholic pairing, serve black tea or chilled ayran.";
"recipe.az_plov.drink.summary" = "White wine (Chardonnay)";
"recipe.az_plov.info" = "Azerbaijani plov is a festive saffron rice dish traditionally served with a separate lamb accompaniment of onions chestnuts and dried fruits, along with fresh herbs. The rice is kept fluffy and distinct, often steamed over a lavash qazmaq crust, and served for family gatherings, holiday meals, and guests.";
"recipe.az_plov.info.summary" = "Saffron lamb plov";
"recipe.az_plov.name" = "Plov";
"recipe.az_plov.step1.body" = "Steep %i3 in a little hot %i5 until the color and aroma fully release.";
"recipe.az_plov.step1.title" = "Infuse the saffron";
"recipe.az_plov.step10.body" = "Turn the rice onto a serving platter so the qazmaq stays intact, place the lamb gara in a separate serving bowl, and serve with the fresh herbs on the side.";
"recipe.az_plov.step10.title" = "Serve the plov";
"recipe.az_plov.step2.body" = "Rinse %i1 until the water runs clearer, then soak it in salted normal water.";
"recipe.az_plov.step2.title" = "Soak the rice";
"recipe.az_plov.step3.body" = "Cut %i7 into bite-size pieces and slice %i8. Cut %i10 into halves.";
"recipe.az_plov.step3.title" = "Prepare the gara base";
"recipe.az_plov.step4.body" = "Melt part of %i12 in a frying pan, cook the onions until softened, then add the lamb and cook until it loses its raw color and begins to brown.";
"recipe.az_plov.step4.title" = "Cook the lamb and onions";
"recipe.az_plov.step5.body" = "Add %i9, dried apricots, %i11, %i13, and %i14 and cook gently until the lamb is tender and the fruits and chestnuts are glazed and fragrant.";
"recipe.az_plov.step5.title" = "Finish the gara";
"recipe.az_plov.step6.body" = "Bring water to a boil with %i4, add the soaked rice, and cook until the grains are partly cooked but still firm in the center. Drain well.";
"recipe.az_plov.step6.title" = "Parboil the rice";
"recipe.az_plov.step7.body" = "Melt some %i2 in a heavy saucepan and line the base and sides with %i6 to form the traditional qazmaq crust.";
"recipe.az_plov.step7.title" = "Line the pot";
"recipe.az_plov.step8.body" = "Pile the drained rice gently into the lined pot, drizzle with the remaining butter and the saffron infusion, cover tightly, and steam on low heat until the rice is fully tender and fluffy.";
"recipe.az_plov.step8.title" = "Steam the plov";
"recipe.az_plov.step9.body" = "Wash and trim %i15, %i16, and %i17 for serving alongside.";
"recipe.az_plov.step9.title" = "Prepare the herbs";
