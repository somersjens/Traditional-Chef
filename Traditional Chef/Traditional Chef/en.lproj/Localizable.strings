"recipe.fr_blanquette_de_veau.drink.body" = "Pair with a dry white such as Chardonnay or Chenin Blanc to match the creamy sauce and lemony finish without overpowering the veal. A light lager can also work. For a non-alcoholic option, serve sparkling water with lemon or a crisp apple spritz.";
"recipe.fr_blanquette_de_veau.drink.summary" = "White wine (Chardonnay)";
"recipe.fr_blanquette_de_veau.info" = "Blanquette de veau is a classic French white veal stew where veal is gently simmered with aromatics until tender, then coated in a velvety pale sauce thickened with a beurre manié or roux and finished with a liaison of egg yolk, cream, and lemon. It is traditionally garnished with mushrooms and pearl onions and served hot with plain white rice to soak up the sauce.";
"recipe.fr_blanquette_de_veau.info.summary" = "French veal in cream";
"recipe.fr_blanquette_de_veau.name" = "Veal blanquette";
"recipe.fr_blanquette_de_veau.step1.body" = "Put %i1 in a pot, cover it with %i9, and bring it up gently. Skim well so the broth stays clear, then drain the veal and rinse the pot.";
"recipe.fr_blanquette_de_veau.step1.title" = "Start the blanche";
"recipe.fr_blanquette_de_veau.step10.body" = "Off the heat, whisk a ladle of hot sauce into the liaison, then whisk it back into the pot. Add %i18 and warm gently without boiling.";
"recipe.fr_blanquette_de_veau.step10.title" = "Finish the blanquette";
"recipe.fr_blanquette_de_veau.step11.body" = "Return the veal to the sauce and add the mushrooms and pearl onions. Warm through gently and serve with rice.";
"recipe.fr_blanquette_de_veau.step11.title" = "Combine and serve";
"recipe.fr_blanquette_de_veau.step2.body" = "Return the veal to the pot with fresh water, add %i2, %i3, %i4 studded with %i6, %i5, %i7, and %i8, and bring to a gentle simmer.";
"recipe.fr_blanquette_de_veau.step2.title" = "Build the broth";
"recipe.fr_blanquette_de_veau.step3.body" = "Simmer very gently until the veal is tender, skimming as needed and keeping the liquid below a boil.";
"recipe.fr_blanquette_de_veau.step3.title" = "Simmer until tender";
"recipe.fr_blanquette_de_veau.step4.body" = "Cook %i19 in salted water until tender, then drain and keep it warm.";
"recipe.fr_blanquette_de_veau.step4.title" = "Cook the rice";
"recipe.fr_blanquette_de_veau.step5.body" = "Sauté %i10 in %i12 until their moisture evaporates and they are lightly coloured. In the same pan, cook %i11 gently in butter until tender and lightly glazed.";
"recipe.fr_blanquette_de_veau.step5.title" = "Prepare the garnish";
"recipe.fr_blanquette_de_veau.step6.body" = "Lift out the veal. Strain the cooking liquid and return it to the pot. Discard the aromatics and keep the veal warm.";
"recipe.fr_blanquette_de_veau.step6.title" = "Strain and portion";
"recipe.fr_blanquette_de_veau.step7.body" = "Melt %i13 in a saucepan, whisk in %i14, and cook while whisking so it stays pale and loses its raw taste.";
"recipe.fr_blanquette_de_veau.step7.title" = "Make the white roux";
"recipe.fr_blanquette_de_veau.step8.body" = "Whisk in the hot strained broth gradually and simmer until the sauce is smooth and lightly thickened.";
"recipe.fr_blanquette_de_veau.step8.title" = "Thicken the sauce";
"recipe.fr_blanquette_de_veau.step9.body" = "Whisk %i16 with %i15 and %i17 until smooth.";
"recipe.fr_blanquette_de_veau.step9.title" = "Make the liaison";
