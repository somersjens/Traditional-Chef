"recipe.th_gaeng_phet_ped_yang.step6.title" = "Add duck and fruit";
"recipe.th_gaeng_phet_ped_yang.step7.body" = "Simmer gently until the duck is heated through and the fruit and tomatoes soften slightly while the curry thickens.";
"recipe.th_gaeng_phet_ped_yang.step7.title" = "Simmer the curry";
"recipe.th_gaeng_phet_ped_yang.step8.body" = "Add the makrut lime leaves, thai basil, and sliced red spur chilies. Stir briefly just until fragrant and the basil wilts.";
"recipe.th_gaeng_phet_ped_yang.step8.title" = "Finish with herbs";
"recipe.th_gaeng_phet_ped_yang.step9.body" = "Transfer the curry to a serving bowl and serve hot with the jasmine rice.";
