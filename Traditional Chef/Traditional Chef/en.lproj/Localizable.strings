"recipe.tt_curry_crab_and_dumplings.drink.body" = "Off-dry Riesling or Gewurztraminer pairs well with the curry’s heat and coconut richness, while a crisp Caribbean lager also works. For a non-alcoholic option, serve chilled ginger beer or fresh limeade to cut through the spice.";
"recipe.tt_curry_crab_and_dumplings.drink.summary" = "White wine (Riesling)";
"recipe.tt_curry_crab_and_dumplings.info" = "Trinidad and Tobago’s iconic Tobago-style curry crab is simmered in a rich coconut curry gravy and served with soft boiled flour dumplings that soak up the sauce. It’s a festive coastal comfort dish, commonly eaten for weekend lunch and shared family meals, with the crab cooked just until tender and deeply seasoned.";
"recipe.tt_curry_crab_and_dumplings.info.summary" = "Tobago curry crab";
"recipe.tt_curry_crab_and_dumplings.name" = "Curry crab and dumplings";
"recipe.tt_curry_crab_and_dumplings.step1.body" = "Rinse %i1 thoroughly, scrub the shells, and split each crab into halves. Crack the claws slightly so the curry can penetrate, then set the crab aside.";
"recipe.tt_curry_crab_and_dumplings.step1.title" = "Clean and split crab";
"recipe.tt_curry_crab_and_dumplings.step10.body" = "Pour in %i12, bring to a steady simmer, and cook until the crab begins to turn bright red and the gravy starts to develop.";
"recipe.tt_curry_crab_and_dumplings.step10.title" = "Simmer in coconut milk";
"recipe.tt_curry_crab_and_dumplings.step11.body" = "Add %i4, %i7, %i6, %i8, %i9, and %i10. Continue simmering until the sauce thickens and the crab is fully cooked through.";
"recipe.tt_curry_crab_and_dumplings.step11.title" = "Finish the curry gravy";
"recipe.tt_curry_crab_and_dumplings.step12.body" = "Serve the curry crab hot with the boiled dumplings, spooning plenty of gravy over everything.";
"recipe.tt_curry_crab_and_dumplings.step12.title" = "Serve";
"recipe.tt_curry_crab_and_dumplings.step2.body" = "Rub the crab well with %i3 and part of %i2. Toss until evenly coated and let it sit to absorb the seasoning.";
"recipe.tt_curry_crab_and_dumplings.step2.title" = "Season the crab";
"recipe.tt_curry_crab_and_dumplings.step3.body" = "Bring %i15 to a rolling boil in a large pot. Stir in a little %i17 and %i14 so the dumplings won’t stick.";
"recipe.tt_curry_crab_and_dumplings.step3.title" = "Start boiling water";
"recipe.tt_curry_crab_and_dumplings.step4.body" = "Combine %i13 and salt in a bowl. Add %i16 gradually and knead to a smooth, firm dough that is not sticky.";
"recipe.tt_curry_crab_and_dumplings.step4.title" = "Make dumpling dough";
"recipe.tt_curry_crab_and_dumplings.step5.body" = "Cover the dough and let it rest so it relaxes before shaping.";
"recipe.tt_curry_crab_and_dumplings.step5.title" = "Rest the dough";
"recipe.tt_curry_crab_and_dumplings.step6.body" = "Divide the dough into equal pieces, roll into balls, then flatten each into a thick disc.";
"recipe.tt_curry_crab_and_dumplings.step6.title" = "Shape dumplings";
"recipe.tt_curry_crab_and_dumplings.step7.body" = "Slide the dumplings into the boiling water. Cook until they are set and floating, then remove with a slotted spoon and drain well.";
"recipe.tt_curry_crab_and_dumplings.step7.title" = "Boil dumplings";
"recipe.tt_curry_crab_and_dumplings.step8.body" = "Heat %i11 in a heavy pot over medium heat. Add %i5 and cook briefly, then add the remaining curry powder and cook until fragrant and slightly darkened.";
"recipe.tt_curry_crab_and_dumplings.step8.title" = "Heat oil and bloom curry";
"recipe.tt_curry_crab_and_dumplings.step9.body" = "Add the seasoned crab and stir to coat every piece in the curry base, letting the crab pick up color and aroma.";
"recipe.tt_curry_crab_and_dumplings.step9.title" = "Coat crab in curry";
"recipe.tt_curry_crab_and_dumplings.tool.t1" = "Large heavy-bottomed pot";
