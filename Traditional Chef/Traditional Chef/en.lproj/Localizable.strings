"recipe.pt_arroz_doce.drink.body" = "A lightly sweet Portuguese wine such as Moscatel complements the cinnamon and citrus without overpowering the creamy rice. If you prefer something fresher, a gentle sparkling wine works well too. Non-alcoholic pairing: iced black tea with lemon or sparkling water.";
"recipe.pt_arroz_doce.drink.summary" = "Moscatel";
"recipe.pt_arroz_doce.info" = "Arroz Doce is Portugal’s classic sweet rice pudding, cooked slowly until creamy with milk, sugar, lemon peel, and a cinnamon stick, then enriched with egg yolks for a silky texture and pale golden color. It is traditionally served in a shallow dish or small bowls and finished with a dusting of ground cinnamon, often patterned on top, and enjoyed chilled or at cool room temperature.";
"recipe.pt_arroz_doce.info.summary" = "Portuguese rice pudding";
"recipe.pt_arroz_doce.name" = "Sweet rice";
"recipe.pt_arroz_doce.step1.body" = "In a saucepan, bring %i2 to a boil with %i5, a strip of %i6 peel, %i7, and %i9.";
"recipe.pt_arroz_doce.step1.title" = "Start the infusion";
"recipe.pt_arroz_doce.step2.body" = "Add %i1, reduce to a gentle simmer, and cook until the rice is tender and the liquid is mostly absorbed, stirring occasionally.";
"recipe.pt_arroz_doce.step2.title" = "Cook the rice in water";
"recipe.pt_arroz_doce.step3.body" = "Add %i3 and cook gently, stirring often so it does not stick, until the mixture becomes thick and creamy and the rice is fully cooked.";
"recipe.pt_arroz_doce.step3.title" = "Cook with milk until creamy";
"recipe.pt_arroz_doce.step4.body" = "Stir in %i4 and continue cooking until fully dissolved and the texture is glossy and creamy.";
"recipe.pt_arroz_doce.step4.title" = "Sweeten the pudding";
"recipe.pt_arroz_doce.step5.body" = "Whisk %i8 in a bowl, then whisk in a ladle of the hot rice mixture to warm them gradually.";
"recipe.pt_arroz_doce.step5.title" = "Temper the egg yolks";
"recipe.pt_arroz_doce.step6.body" = "Remove the saucepan from direct heat and stir in the tempered yolks. Return to very low heat and stir until the pudding slightly thickens without boiling.";
"recipe.pt_arroz_doce.step6.title" = "Enrich and finish";
"recipe.pt_arroz_doce.step7.body" = "Remove the lemon peel and cinnamon stick. Spoon the pudding into a serving dish and smooth the top.";
"recipe.pt_arroz_doce.step7.title" = "Dish and cool";
"recipe.pt_arroz_doce.step8.body" = "Let the pudding cool, then refrigerate until set and chilled.";
"recipe.pt_arroz_doce.step8.title" = "Chill";
"recipe.pt_arroz_doce.step9.body" = "Dust the top with %i10 in an even layer and serve chilled or at cool room temperature.";
"recipe.pt_arroz_doce.step9.title" = "Cinnamon finish";
