"recipe.hk_bo_zai_fan.step11.title" = "Rest off heat";
"recipe.hk_bo_zai_fan.step12.body" = "Open the pot, scatter spring onion over the top, pour over the seasoned soy sauce, and mix at the table before serving.";
"recipe.hk_bo_zai_fan.step12.title" = "Finish and serve";
