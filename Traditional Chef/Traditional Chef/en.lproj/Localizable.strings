"recipe.sy_maqluba.step5.title" = "Simmer the chicken with spices";
"recipe.sy_maqluba.step6.body" = "Lay tomato slices in the bottom of the pot. Arrange the chicken over the tomatoes, then layer the fried vegetables evenly on top.";
"recipe.sy_maqluba.step6.title" = "Layer the pot";
"recipe.sy_maqluba.step7.body" = "Spread the drained rice over the layers, leveling the surface. Pour in the hot broth and add enough water so the liquid sits just above the rice. Bring to a gentle boil.";
"recipe.sy_maqluba.step7.title" = "Add rice and broth";
