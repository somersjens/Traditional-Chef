"recipe.it_crostata_di_marmellata.step6.title" = "Make the lattice";
"recipe.it_crostata_di_marmellata.step7.body" = "Bake until the crust is golden and the jam is set.";
"recipe.it_crostata_di_marmellata.step7.title" = "Bake the crostata";
"recipe.it_crostata_di_marmellata.step8.body" = "Cool completely so the filling firms up and slices cleanly.";
"recipe.it_crostata_di_marmellata.step8.title" = "Cool the crostata";
