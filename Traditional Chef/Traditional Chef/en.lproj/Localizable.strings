"recipe.hu_gulyasleves.drink.body" = "Pair with a medium-bodied Hungarian red such as Kékfrankos that handles paprika and beef without feeling heavy. A pale lager also works well with the soup’s warmth. For a non-alcoholic option, serve sparkling water or a chilled apple spritz.";
"recipe.hu_gulyasleves.drink.summary" = "Red wine (Kékfrankos)";
"recipe.hu_gulyasleves.info" = "Gulyásleves is the traditional Hungarian goulash soup: beef simmered in a paprika-scented broth built on slowly softened onions, then enriched with peppers, tomatoes, root vegetables, and potatoes. It is finished with csipetke, small pinched noodles cooked directly in the soup, and served hot with bread to mop up the rich, peppery broth.";
"recipe.hu_gulyasleves.info.summary" = "Hungarian goulash soup";
"recipe.hu_gulyasleves.name" = "Goulash soup";
"recipe.hu_gulyasleves.step1.body" = "Cut %i1 into even chunks. Chop %i2 and %i6, dice %i7 and %i8, slice %i9 and %i10, and cube %i11.";
"recipe.hu_gulyasleves.step1.title" = "Prep the ingredients";
"recipe.hu_gulyasleves.step10.body" = "Stir the csipetke into the gently simmering soup and cook until they float and are tender.";
"recipe.hu_gulyasleves.step10.title" = "Cook the csipetke";
"recipe.hu_gulyasleves.step11.body" = "Taste and adjust the seasoning, then serve hot with %i19.";
"recipe.hu_gulyasleves.step11.title" = "Finish and serve";
"recipe.hu_gulyasleves.step2.body" = "Melt %i3 in a heavy pot and cook the onions slowly until soft and translucent, stirring so they do not brown.";
"recipe.hu_gulyasleves.step2.title" = "Sweat the onions";
"recipe.hu_gulyasleves.step3.body" = "Take the pot off the heat, stir in %i4, %i5, and %i13, then add a splash of %i14 and stir quickly so the paprika does not scorch.";
"recipe.hu_gulyasleves.step3.title" = "Bloom the paprika and spices";
"recipe.hu_gulyasleves.step4.body" = "Return the pot to the heat, add the beef and garlic, and stir until the meat is well coated and the surface loses its raw look.";
"recipe.hu_gulyasleves.step4.title" = "Add the beef";
"recipe.hu_gulyasleves.step5.body" = "Add water and %i12, bring to a gentle simmer, and cook until the beef is starting to become tender, skimming if needed and keeping the soup below a boil.";
"recipe.hu_gulyasleves.step5.title" = "Simmer until nearly tender";
"recipe.hu_gulyasleves.step6.body" = "Add the carrots, parsley root, peppers, and tomatoes and simmer until the vegetables begin to soften and the broth turns rich and aromatic.";
"recipe.hu_gulyasleves.step6.title" = "Cook the vegetables";
"recipe.hu_gulyasleves.step7.body" = "Add the potatoes and simmer gently until they are nearly tender.";
"recipe.hu_gulyasleves.step7.title" = "Add the potatoes";
"recipe.hu_gulyasleves.step8.body" = "Mix %i15 with %i18, add %i16, and work it into a firm dough, adding a little %i17 only as needed so it stays stiff.";
"recipe.hu_gulyasleves.step8.title" = "Make the csipetke dough";
"recipe.hu_gulyasleves.step9.body" = "Pinch off small pieces of dough and roll them lightly between your fingers into small rough nuggets, keeping them small so they cook quickly.";
"recipe.hu_gulyasleves.step9.title" = "Shape the csipetke";
