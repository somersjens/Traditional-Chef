"recipe.it_cacio_e_pepe.drink.body" = "Pair with a crisp Roman white such as Frascati, or a light, low-tannin red to let the pepper and cheese shine. Non-alcoholic option: sparkling water or a bitter-sweet citrus soda.";
"recipe.it_cacio_e_pepe.drink.summary" = "White wine (Frascati)";
"recipe.it_cacio_e_pepe.info" = "A classic Roman pasta built from just pasta, Pecorino Romano, black pepper, and starchy cooking water, creating a glossy, tangy sauce that clings to each strand. Traditionally served hot as a simple yet satisfying main at trattorias and home tables, relying on technique and timing rather than extra ingredients.";
"recipe.it_cacio_e_pepe.info.summary" = "Roman pepper pasta";
"recipe.it_cacio_e_pepe.name" = "Cacio e pepe";
"recipe.it_cacio_e_pepe.step1.body" = "Finely grate the %i2 into a bowl so it melts quickly and smoothly.";
"recipe.it_cacio_e_pepe.step1.title" = "Grate the cheese";
"recipe.it_cacio_e_pepe.step10.body" = "Plate immediately and finish with an extra dusting of black pepper.";
"recipe.it_cacio_e_pepe.step10.title" = "Serve the pasta";
"recipe.it_cacio_e_pepe.step2.body" = "Bring a large pot of water to a rolling boil and season it with %i5.";
"recipe.it_cacio_e_pepe.step2.title" = "Boil the water";
"recipe.it_cacio_e_pepe.step3.body" = "Add %i1 and cook until just al dente, stirring occasionally. Reserve a good amount of starchy pasta water before draining.";
"recipe.it_cacio_e_pepe.step3.title" = "Cook the pasta";
"recipe.it_cacio_e_pepe.step4.body" = "Warm a skillet over medium heat, add %i3, and toast briefly until fragrant.";
"recipe.it_cacio_e_pepe.step4.title" = "Toast the pepper";
"recipe.it_cacio_e_pepe.step5.body" = "Add a ladle of pasta water to the skillet and swirl to form a peppery liquid base.";
"recipe.it_cacio_e_pepe.step5.title" = "Make the pepper base";
"recipe.it_cacio_e_pepe.step6.body" = "Take the skillet off the heat for a moment so the mixture is no longer aggressively bubbling before adding the cheese.";
"recipe.it_cacio_e_pepe.step6.title" = "Cool the pan slightly";
"recipe.it_cacio_e_pepe.step7.body" = "In the bowl, mix Pecorino with small splashes of pasta water, stirring until you get a smooth, thick cream.";
"recipe.it_cacio_e_pepe.step7.title" = "Build the cheese sauce";
"recipe.it_cacio_e_pepe.step8.body" = "Add the drained spaghetti to the skillet and toss to coat in the peppery liquid, adding a little pasta water if needed.";
"recipe.it_cacio_e_pepe.step8.title" = "Combine pasta and pepper";
"recipe.it_cacio_e_pepe.step9.body" = "Off the heat, add the cheese cream and toss vigorously until glossy and evenly coated, loosening with small splashes of pasta water as needed.";
"recipe.it_cacio_e_pepe.step9.title" = "Emulsify with the cheese";
