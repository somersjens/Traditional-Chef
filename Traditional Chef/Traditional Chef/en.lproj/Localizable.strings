"recipe.fr_bouillabaisse.drink.body" = "Pair with a Provençal white such as Cassis or a dry Rhône white to complement saffron, fennel, and garlic without overpowering the fish. A crisp pilsner can also work. For a non-alcoholic option, serve sparkling water with lemon or a chilled citrus spritz.";
"recipe.fr_bouillabaisse.drink.summary" = "White wine (Cassis)";
"recipe.fr_bouillabaisse.info" = "Bouillabaisse is the traditional Marseille fisherman’s soup: a fragrant saffron- and fennel-scented broth built from aromatic vegetables, tomatoes, white wine, and mixed Mediterranean fish, simmered gently so the broth turns rich and the fish stays tender. It is served in the classic way with the hot broth and fish accompanied by toasted bread and rouille, a garlicky saffron mayonnaise that is stirred in or spread on the croutons.";
"recipe.fr_bouillabaisse.info.summary" = "Marseille fisherman’s soup";
"recipe.fr_bouillabaisse.name" = "Bouillabaisse";
"recipe.fr_bouillabaisse.step1.body" = "Slice %i2, %i3, and %i4. Chop %i5 and %i6. Peel a strip of %i13 zest and keep it aside.";
"recipe.fr_bouillabaisse.step1.title" = "Prep the aromatics";
"recipe.fr_bouillabaisse.step10.body" = "Slice %i24, brush it with %i25, and toast it in the oven until crisp and golden.";
"recipe.fr_bouillabaisse.step10.title" = "Toast the croutons";
"recipe.fr_bouillabaisse.step11.body" = "Serve the hot broth and fish with the croutons and rouille so diners can spread rouille on bread and add it to the soup.";
"recipe.fr_bouillabaisse.step11.title" = "Serve the bouillabaisse";
"recipe.fr_bouillabaisse.step2.body" = "Heat %i7 in a large pot and sweat the onions, leek, and fennel until softened, stirring so they do not brown.";
"recipe.fr_bouillabaisse.step2.title" = "Sweat the base";
"recipe.fr_bouillabaisse.step3.body" = "Stir in the tomatoes and garlic and cook until the tomatoes begin to break down and turn saucy.";
"recipe.fr_bouillabaisse.step3.title" = "Add tomatoes and garlic";
"recipe.fr_bouillabaisse.step4.body" = "Add %i8 and let it simmer briefly, then add %i9, %i10, %i11, the orange zest, %i12, %i14, and %i15 and bring to a gentle simmer.";
"recipe.fr_bouillabaisse.step4.title" = "Build the broth";
"recipe.fr_bouillabaisse.step5.body" = "Simmer gently so the broth becomes aromatic and slightly concentrated, skimming if needed.";
"recipe.fr_bouillabaisse.step5.title" = "Simmer the broth";
"recipe.fr_bouillabaisse.step6.body" = "Add %i1 to the simmering broth and cook gently until the fish is just tender and holds together, keeping the liquid below a boil.";
"recipe.fr_bouillabaisse.step6.title" = "Cook the fish";
"recipe.fr_bouillabaisse.step7.body" = "Lift out the fish to a warm serving bowl. Strain the broth through a fine sieve and return it to the pot, adjusting the seasoning if needed.";
"recipe.fr_bouillabaisse.step7.title" = "Strain and arrange";
"recipe.fr_bouillabaisse.step8.body" = "Crush %i16 with %i23 to a smooth paste. Whisk in %i17, %i21, and %i22 until combined.";
"recipe.fr_bouillabaisse.step8.title" = "Make the rouille base";
"recipe.fr_bouillabaisse.step9.body" = "Whisk in %i18 slowly until thick, then whisk in %i20 and fold in %i19 until smooth and spoonable.";
"recipe.fr_bouillabaisse.step9.title" = "Emulsify the rouille";
