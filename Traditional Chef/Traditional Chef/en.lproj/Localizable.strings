"recipe.jp_okonomiyaki.drink.body" = "A crisp Japanese lager or a dry sake pairs well with the rich sauce and savory batter. For a non-alcoholic pairing, serve iced barley tea or hot green tea.";
"recipe.jp_okonomiyaki.drink.summary" = "Beer (Lager)";
"recipe.jp_okonomiyaki.info" = "Okonomiyaki is a traditional Japanese savory pancake from the Kansai region made with a dashi-based batter, plenty of cabbage, and pork belly, cooked on a griddle and finished with okonomiyaki sauce, mayonnaise, aonori, and bonito flakes. It is commonly served as a casual main dish at home and in specialty restaurants, eaten hot straight from the griddle.";
"recipe.jp_okonomiyaki.info.summary" = "Savory cabbage pancake";
"recipe.jp_okonomiyaki.name" = "Okonomiyaki";
"recipe.jp_okonomiyaki.step1.body" = "Finely shred the %i4, slice the %i5, chop the %i8, grate the %i6, and ready the %i9 and topping ingredients for quick cooking.";
"recipe.jp_okonomiyaki.step1.title" = "Prepare the vegetables and toppings";
"recipe.jp_okonomiyaki.step2.body" = "Whisk %i1, %i2, %i3, %i7, and %i15 until smooth, then mix in the grated nagaimo for a loose airy batter.";
"recipe.jp_okonomiyaki.step2.title" = "Make the batter base";
"recipe.jp_okonomiyaki.step3.body" = "Add the cabbage, scallions, and pickled red ginger to the batter and fold gently until everything is evenly coated without crushing the cabbage.";
"recipe.jp_okonomiyaki.step3.title" = "Fold in the filling";
"recipe.jp_okonomiyaki.step4.body" = "Heat the griddle and lightly oil the surface so the pancakes cook evenly and release cleanly.";
"recipe.jp_okonomiyaki.step4.title" = "Heat the griddle";
