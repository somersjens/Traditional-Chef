"recipe.eg_molokhia.drink.body" = "Pair with a crisp, high-acid dry white such as Sauvignon Blanc to refresh the palate against the garlicky coriander finish and rich broth. A light lager also works well with the savory chicken and rice. Non-alcoholic option: mint tea or sparkling water with lemon.";
"recipe.eg_molokhia.drink.summary" = "White wine (Sauvignon)";
"recipe.eg_molokhia.info" = "Molokhia is a classic Egyptian dish of jute mallow cooked into a silky green soup and finished with a sizzling garlic and coriander tempering poured over the top. It is traditionally made with a rich chicken broth and served hot over Egyptian rice with toasted vermicelli, with tender chicken alongside for a hearty family meal.";
"recipe.eg_molokhia.info.summary" = "Garlic-finished molokhia";
"recipe.eg_molokhia.name" = "Molokhia with chicken";
"recipe.eg_molokhia.step1.body" = "Put %i1 in a pot and cover with cold %i2. Bring up slowly to a gentle simmer and skim any foam so the broth stays clean.";
"recipe.eg_molokhia.step1.title" = "Start the chicken broth";
"recipe.eg_molokhia.step2.body" = "Add %i3, %i4, %i5, and %i6. Keep at a gentle simmer until the chicken is tender and the broth is richly flavored.";
"recipe.eg_molokhia.step2.title" = "Simmer until tender";
"recipe.eg_molokhia.step3.body" = "Lift out the chicken and strain the broth. Keep the chicken warm and reserve the hot broth for the molokhia.";
"recipe.eg_molokhia.step3.title" = "Strain and portion";
"recipe.eg_molokhia.step4.body" = "Melt %i15 in a saucepan, toast %i14 until golden, then stir in %i13 to coat. Add %i16 and %i17, bring to a boil, cover, and reduce to low heat.";
"recipe.eg_molokhia.step4.title" = "Cook rice with vermicelli";
"recipe.eg_molokhia.step5.body" = "Cook covered until the rice is tender and the liquid is absorbed, then rest covered so it finishes steaming.";
"recipe.eg_molokhia.step5.title" = "Steam the rice";
"recipe.eg_molokhia.step6.body" = "Bring the reserved chicken stock to a gentle simmer in a pot and season so it tastes well balanced.";
"recipe.eg_molokhia.step6.title" = "Heat the broth for molokhia";
"recipe.eg_molokhia.step7.body" = "Stir %i7 into the hot broth and keep it just below a boil, stirring until it turns silky and the raw taste is gone. Do not boil hard.";
"recipe.eg_molokhia.step7.title" = "Cook the molokhia";
"recipe.eg_molokhia.step8.body" = "Warm %i11 in a skillet, add minced %i9, and cook until fragrant. Stir in %i10 and let it sizzle briefly, then season with %i12.";
"recipe.eg_molokhia.step8.title" = "Make the ta leya";
"recipe.eg_molokhia.step9.body" = "Pour the sizzling ta leya over the molokhia and stir once. Serve hot over rice with the chicken alongside.";
"recipe.eg_molokhia.step9.title" = "Finish and serve";
