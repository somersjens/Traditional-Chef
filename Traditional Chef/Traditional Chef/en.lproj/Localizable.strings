"recipe.cz_svickova_na_smetane.step12.title" = "Finish the garnish";
"recipe.cz_svickova_na_smetane.step13.body" = "Slice the beef, spoon the creamy sauce onto plates, add the bread dumplings, and garnish each serving with %i24, a slice of lemon, and a spoonful of whipped cream.";
"recipe.cz_svickova_na_smetane.step13.title" = "Serve";
"recipe.cz_svickova_na_smetane.step2.body" = "Cut %i3, %i4, %i5, and %i6 into large pieces. Place them with the beef in a deep dish, add %i10, %i11, %i12, %i13, some %i14, %i8, and %i9, then cover.";
