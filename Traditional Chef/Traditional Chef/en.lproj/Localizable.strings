"recipe.ua_deruny.step3.body" = "Mix the drained potato mixture with %i3, %i4, %i5, and %i6 until the batter is thick and holds together well.";
"recipe.ua_deruny.step3.title" = "Make the batter";
"recipe.ua_deruny.step4.body" = "Pour %i7 into the skillet and heat it until ready for shallow frying.";
"recipe.ua_deruny.step4.title" = "Heat the oil";
"recipe.ua_deruny.step5.body" = "Spoon small portions of batter into the hot oil, flatten them slightly, and fry until golden and crisp on both sides.";
"recipe.ua_deruny.step5.title" = "Fry the first batches";
"recipe.ua_deruny.step6.body" = "Continue frying the rest of the batter in batches, adding more oil as needed and keeping the pancakes evenly browned.";
"recipe.ua_deruny.step6.title" = "Cook the remaining deruny";
