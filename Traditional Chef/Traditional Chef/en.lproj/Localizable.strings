"recipe.id_sate_ayam.drink.body" = "A light lager or an off-dry Riesling pairs well with the smoky grilled chicken and sweet-savory peanut sauce. For a non-alcoholic pairing, serve iced jasmine tea or cold lime water.";
"recipe.id_sate_ayam.drink.summary" = "Beer (Lager)";
"recipe.id_sate_ayam.info" = "Sate ayam is a traditional Indonesian dish of marinated chicken skewers grilled over charcoal and served with a thick peanut sauce. It is a classic street-food and family meal, commonly accompanied by rice cakes, sliced shallots, and fresh chilies or sambal.";
"recipe.id_sate_ayam.info.summary" = "Grilled chicken satay";
"recipe.id_sate_ayam.name" = "Chicken satay";
"recipe.id_sate_ayam.step1.body" = "Cut the %i1 into bite-size pieces and soak the %i13 in %i23 so they do not burn during grilling.";
"recipe.id_sate_ayam.step1.title" = "Prepare the chicken and skewers";
"recipe.id_sate_ayam.step10.body" = "Arrange the grilled sate ayam on a platter, spoon over some peanut sauce, and serve with extra sauce, rice cake, and fresh accompaniments.";
"recipe.id_sate_ayam.step10.title" = "Serve";
"recipe.id_sate_ayam.step2.body" = "Grind the %i2, %i3, %i4, %i5, %i6, %i7, and %i8 into a smooth paste, then mix with %i9, %i10, %i11, and %i12.";
"recipe.id_sate_ayam.step2.title" = "Make the satay marinade";
"recipe.id_sate_ayam.step3.body" = "Coat the chicken well with the marinade and let it rest so the flavors absorb while you prepare the sauce.";
"recipe.id_sate_ayam.step3.title" = "Marinate the chicken";
"recipe.id_sate_ayam.step4.body" = "Grind the %i14 with shallots, garlic, %i17, %i18, and shrimp paste into a coarse paste.";
"recipe.id_sate_ayam.step4.title" = "Make the peanut sauce paste";
"recipe.id_sate_ayam.step5.body" = "Heat oil in a saucepan, fry the peanut paste until fragrant, then add palm sugar, salt, %i22, and water. Simmer until thick and smooth, then stir in kecap manis.";
"recipe.id_sate_ayam.step5.title" = "Cook the peanut sauce";
"recipe.id_sate_ayam.step6.body" = "Thread the marinated chicken onto the soaked skewers, packing each skewer evenly for steady cooking.";
"recipe.id_sate_ayam.step6.title" = "Skewer the chicken";
"recipe.id_sate_ayam.step7.body" = "Mix kecap manis and oil for basting during grilling.";
"recipe.id_sate_ayam.step7.title" = "Prepare basting glaze";
"recipe.id_sate_ayam.step8.body" = "Grill the skewers over hot charcoal, turning frequently and basting until the chicken is cooked through, lightly charred, and glossy.";
"recipe.id_sate_ayam.step8.title" = "Grill the satay";
"recipe.id_sate_ayam.step9.body" = "Slice the %i28, shallots, chilies, and %i31 for serving alongside the satay and sauce.";
"recipe.id_sate_ayam.step9.title" = "Prepare accompaniments";
