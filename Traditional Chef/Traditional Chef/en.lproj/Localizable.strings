"recipe.us_ma_boston_cream_pie.drink.body" = "A nutty tawny port or a coffee stout pairs well with the vanilla custard and dark chocolate glaze without getting lost. For a non-alcoholic option, serve strong black coffee or unsweetened black tea to balance the sweetness and highlight the chocolate.";
"recipe.us_ma_boston_cream_pie.drink.summary" = "Tawny Port";
"recipe.us_ma_boston_cream_pie.info" = "Boston cream pie is a classic Massachusetts dessert: two tender vanilla cake layers filled with silky vanilla pastry cream and finished with a glossy chocolate glaze. Traditionally served chilled or cool so the custard sets cleanly, it’s a bakery-style celebration cake that eats like a rich, old-school American treat.";
"recipe.us_ma_boston_cream_pie.info.summary" = "Custard-filled cake";
"recipe.us_ma_boston_cream_pie.name" = "Boston cream pie";
"recipe.us_ma_boston_cream_pie.step1.body" = "Heat the %i9 until steaming. Whisk %i10, %i11, %i12, and %i13 until smooth. Temper with hot milk, return to the saucepan, and whisk over medium heat until thick and bubbling: keep cooking while whisking until the cream tastes cooked and holds its shape.";
"recipe.us_ma_boston_cream_pie.step1.title" = "Cook the pastry cream";
"recipe.us_ma_boston_cream_pie.step10.body" = "Pour the chocolate glaze over the top layer and gently nudge it to the edges so it flows into an even, smooth cap.";
"recipe.us_ma_boston_cream_pie.step10.title" = "Glaze the top";
"recipe.us_ma_boston_cream_pie.step11.body" = "Refrigerate until the glaze is set. Slice with a warm knife for clean cuts and serve cool.";
"recipe.us_ma_boston_cream_pie.step11.title" = "Set and serve";
"recipe.us_ma_boston_cream_pie.step2.body" = "Press the hot pastry cream through a fine sieve into a bowl. Stir in %i14 and %i15 until smooth. Press parchment directly onto the surface to prevent a skin.";
"recipe.us_ma_boston_cream_pie.step2.title" = "Strain and chill";
"recipe.us_ma_boston_cream_pie.step3.body" = "Refrigerate the pastry cream until fully cold and set so it will hold between the cake layers.";
"recipe.us_ma_boston_cream_pie.step3.title" = "Set the custard";
"recipe.us_ma_boston_cream_pie.step4.body" = "Heat the oven. Line the cake pans with parchment and lightly grease. Set out the ingredients so they come to a cool room temperature for even mixing.";
"recipe.us_ma_boston_cream_pie.step4.title" = "Prepare for baking";
"recipe.us_ma_boston_cream_pie.step5.body" = "Cream %i7 and %i4 until pale and fluffy. Beat in %i5 one at a time, then %i8. Mix %i1, %i2, and %i3, then add to the bowl alternating with %i6, mixing just until smooth.";
"recipe.us_ma_boston_cream_pie.step5.title" = "Mix the cake batter";
"recipe.us_ma_boston_cream_pie.step6.body" = "Divide the batter between the pans and bake until the cakes are golden, spring back in the center, and a tester comes out clean.";
"recipe.us_ma_boston_cream_pie.step6.title" = "Bake the layers";
"recipe.us_ma_boston_cream_pie.step7.body" = "Cool the cakes briefly in their pans, then turn out onto a rack, peel off parchment, and let the layers cool completely before filling.";
"recipe.us_ma_boston_cream_pie.step7.title" = "Cool completely";
"recipe.us_ma_boston_cream_pie.step8.body" = "Combine %i16, %i17, %i18, and %i19 in a heatproof bowl set over gently simmering water. Stir until melted and smooth, then remove from heat and let it cool until glossy and pourable.";
