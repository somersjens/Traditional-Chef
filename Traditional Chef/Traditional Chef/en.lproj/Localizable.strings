"recipe.hu_libamaj.step3.body" = "Heat %i9 in a skillet and cook the onions until soft and lightly golden, seasoning with a pinch of %i10 and %i11.";
"recipe.hu_libamaj.step3.title" = "Cook the onions";
"recipe.hu_libamaj.step4.body" = "Add the apples to the skillet and sauté until lightly browned and just tender, then keep them warm.";
"recipe.hu_libamaj.step4.title" = "Sauté the apples";
"recipe.hu_libamaj.step5.body" = "Pat the liver very dry, season it with %i4 and %i5, and coat it lightly with %i6, shaking off the excess.";
"recipe.hu_libamaj.step5.title" = "Dry and season the liver";
"recipe.hu_libamaj.step6.body" = "Heat %i3 in the skillet until hot and sear the liver quickly on both sides until browned outside while still creamy within.";
"recipe.hu_libamaj.step6.title" = "Sear the liver";
"recipe.hu_libamaj.step7.body" = "Toast %i12 until crisp and warm so it can carry the liver and pan juices.";
"recipe.hu_libamaj.step7.title" = "Toast the bread";
"recipe.hu_libamaj.step8.body" = "Serve the hot goose liver immediately with the sautéed apples and onions and the toasted bread.";
"recipe.hu_libamaj.step8.title" = "Serve the liver";
