"recipe.iq_pacha.drink.body" = "A dry white wine such as Chardonnay can match the rich broth and gelatinous meat, while a light lager also works well. For a non-alcoholic pairing, serve strong black tea with lemon or plain hot tea.";
"recipe.iq_pacha.drink.summary" = "White wine (Chardonnay)";
"recipe.iq_pacha.info" = "Iraqi pacha is a traditional slow-cooked dish of sheep head trotters and stuffed stomach simmered until tender in a rich broth, then served with Iraqi flatbread soaked in the cooking liquid. It is especially associated with cold mornings, festive gatherings, and Assyrian and Iraqi family meals.";
"recipe.iq_pacha.info.summary" = "Offal breakfast stew";
"recipe.iq_pacha.name" = "Pacha";
"recipe.iq_pacha.step1.body" = "Wash and thoroughly clean %i1, %i2, and %i3, scraping and rinsing them well so they are ready for cooking and stuffing.";
"recipe.iq_pacha.step1.title" = "Clean the offal";
"recipe.iq_pacha.step10.body" = "Serve immediately with extra broth spooned over so the bread stays soaked and the meat remains hot.";
"recipe.iq_pacha.step10.title" = "Serve the dish";
"recipe.iq_pacha.step2.body" = "Wash %i4, then mix it with %i5, finely chopped %i6, crushed %i7, %i8, and %i9.";
"recipe.iq_pacha.step2.title" = "Prepare the stuffing";
"recipe.iq_pacha.step3.body" = "Fill the stomach with the rice mixture, leaving room for expansion, then stitch it closed securely with kitchen thread.";
"recipe.iq_pacha.step3.title" = "Stuff the stomach";
"recipe.iq_pacha.step4.body" = "Place the sheep head, trotters, and stuffed stomach in a large heavy pot. Add %i10 and %i11 and bring slowly to a boil.";
"recipe.iq_pacha.step4.title" = "Start the pot";
"recipe.iq_pacha.step5.body" = "Skim the surface carefully as the broth rises, then reduce the heat so the pacha cooks at a gentle simmer.";
"recipe.iq_pacha.step5.title" = "Skim and steady the broth";
"recipe.iq_pacha.step6.body" = "Cover partially and simmer slowly until the meats are very tender, the broth is rich, and the stuffed stomach is fully cooked through.";
"recipe.iq_pacha.step6.title" = "Simmer until tender";
"recipe.iq_pacha.step7.body" = "Remove the stuffed stomach and slice it. Separate the tender meat from the head and trotters into serving pieces.";
"recipe.iq_pacha.step7.title" = "Prepare for serving";
"recipe.iq_pacha.step8.body" = "Tear %i12 into a deep serving platter and spread it evenly across the base.";
"recipe.iq_pacha.step8.title" = "Arrange the bread";
"recipe.iq_pacha.step9.body" = "Ladle broth over the bread until it softens, then arrange the sliced stuffed stomach and the meat pieces on top.";
"recipe.iq_pacha.step9.title" = "Assemble the pacha";
