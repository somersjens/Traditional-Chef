"recipe.cn_suanla_tang.drink.body" = "A dry Riesling or light lager can pair with the sour and peppery profile, while hot jasmine tea is a classic non-alcoholic pairing that keeps the palate refreshed without competing with the soup.";
"recipe.cn_suanla_tang.drink.summary" = "White wine (Riesling)";
"recipe.cn_suanla_tang.info" = "Suanla tang is a traditional Chinese soup known for its balanced sourness, peppery heat, and silky texture, made with pork, tofu, mushrooms, bamboo shoots, egg, and a seasoned stock thickened lightly with starch. It is commonly served hot as a starter in family meals and banquets, especially in northern Chinese and Sichuan-influenced cooking.";
"recipe.cn_suanla_tang.info.summary" = "Hot sour soup classic";
"recipe.cn_suanla_tang.name" = "Hot and sour soup";
"recipe.cn_suanla_tang.step1.body" = "Soak the %i3 and %i4 in %i7 until softened, then drain, rinse, and squeeze out excess moisture.";
"recipe.cn_suanla_tang.step1.title" = "Soak the mushrooms";
"recipe.cn_suanla_tang.step2.body" = "Slice the %i1 into thin shreds, cut the %i2 and %i5 into thin strips, slice the soaked mushrooms, mince the %i10, and cut the %i11.";
"recipe.cn_suanla_tang.step2.title" = "Prepare soup ingredients";
"recipe.cn_suanla_tang.step3.body" = "Combine %i8, %i9, ginger, and scallions in a soup pot and bring to a simmer.";
"recipe.cn_suanla_tang.step3.title" = "Build the broth base";
"recipe.cn_suanla_tang.step4.body" = "Add the pork, mushrooms, and bamboo shoots to the simmering broth and cook until the pork is just cooked and the vegetables are tender.";
"recipe.cn_suanla_tang.step4.title" = "Cook pork and vegetables";
"recipe.cn_suanla_tang.step5.body" = "Add the tofu, then season the soup with %i12, %i13, %i14, %i15, and %i16, and simmer gently to blend the flavors.";
"recipe.cn_suanla_tang.step5.title" = "Add tofu and seasonings";
"recipe.cn_suanla_tang.step6.body" = "Mix the %i17 with %i18, stir the soup, and pour in the slurry gradually until the soup becomes lightly thickened and silky.";
"recipe.cn_suanla_tang.step6.title" = "Thicken the soup";
"recipe.cn_suanla_tang.step7.body" = "Beat the %i6, drizzle it slowly into the gently simmering soup while stirring to form fine egg ribbons.";
"recipe.cn_suanla_tang.step7.title" = "Add egg ribbons";
"recipe.cn_suanla_tang.step8.body" = "Taste and balance the hot and sour seasoning, then ladle into bowls and garnish with %i19 and %i20 before serving hot.";
"recipe.cn_suanla_tang.step8.title" = "Finish and garnish";
