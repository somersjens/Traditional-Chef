"recipe.uy_chaja.drink.body" = "Pair with a fragrant Muscat or a late-harvest white to echo the peaches and dulce de leche without overpowering the cream. A tawny-style fortified wine also complements the caramel notes. For a non-alcoholic option, serve strong coffee, maté, or black tea.";
"recipe.uy_chaja.drink.summary" = "Dessert wine (Muscat)";
"recipe.uy_chaja.info" = "Chajá is a classic Uruguayan dessert from Paysandú, built with soft sponge cake layered with crisp meringue, whipped cream, peaches in syrup, and dulce de leche, then finished with crushed meringue and nuts for a light-but-decadent texture contrast. It is served well chilled in slices, commonly enjoyed with coffee after a family meal.";
"recipe.uy_chaja.info.summary" = "Peach cream meringue cake";
"recipe.uy_chaja.name" = "Chajá";
"recipe.uy_chaja.step1.body" = "Heat the oven and line the cake pan and baking sheets with parchment so the sponge and meringues release cleanly.";
"recipe.uy_chaja.step1.title" = "Prepare pans and oven";
"recipe.uy_chaja.step10.body" = "Layer sponge with %i12, whipped cream, peaches, and crisp meringue, repeating to build a tall, airy cake and finishing with cream on top.";
"recipe.uy_chaja.step10.title" = "Assemble the chajá";
"recipe.uy_chaja.step11.body" = "Cover the top and sides with crushed meringue and scatter walnuts so the cake is well coated and textured.";
"recipe.uy_chaja.step11.title" = "Finish with meringue and nuts";
"recipe.uy_chaja.step12.body" = "Refrigerate until fully chilled and stable for clean slicing, then serve cold.";
"recipe.uy_chaja.step12.title" = "Chill to set";
"recipe.uy_chaja.step2.body" = "Whip the %i1 with %i2 until very pale and thick, then fold in the %i3 with %i4 and %i5, finishing with %i6.";
"recipe.uy_chaja.step2.title" = "Make the sponge batter";
"recipe.uy_chaja.step3.body" = "Bake until the sponge is risen, golden, and springy in the center.";
"recipe.uy_chaja.step3.title" = "Bake the sponge";
"recipe.uy_chaja.step4.body" = "Cool the sponge completely on a rack so it slices neatly without tearing.";
"recipe.uy_chaja.step4.title" = "Cool the sponge";
"recipe.uy_chaja.step5.body" = "Whip the %i7 to stiff peaks, gradually adding %i8 until the meringue is thick and glossy.";
"recipe.uy_chaja.step5.title" = "Whip the meringue";
"recipe.uy_chaja.step6.body" = "Pipe or spread meringue into flat rounds on the baking sheets and bake low and slow until dry and crisp, then cool completely.";
"recipe.uy_chaja.step6.title" = "Bake the meringue";
"recipe.uy_chaja.step7.body" = "Drain the %i13, reserving the syrup, slice the peaches, and chop the %i14. Crush some meringue into irregular pieces for finishing.";
"recipe.uy_chaja.step7.title" = "Prep filling components";
"recipe.uy_chaja.step8.body" = "Whip the %i9 with %i10 and %i11 to firm peaks that hold their shape.";
"recipe.uy_chaja.step8.title" = "Whip the cream";
"recipe.uy_chaja.step9.body" = "Slice the sponge into even layers and lightly brush the cut sides with %i15 so the cake stays tender.";
"recipe.uy_chaja.step9.title" = "Slice and moisten the sponge";
