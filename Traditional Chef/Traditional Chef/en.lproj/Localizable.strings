"recipe.jp_kaisendon.drink.body" = "Dry sake or a crisp Japanese lager pairs well with the fresh seafood and soy seasoning. For a non-alcoholic pairing, serve hot green tea or chilled barley tea.";
"recipe.jp_kaisendon.drink.summary" = "Sake";
"recipe.jp_kaisendon.info" = "Kaisendon is a traditional Japanese rice bowl topped with assorted sashimi and garnishes, typically served over seasoned sushi rice and finished with soy sauce and wasabi. It is commonly eaten as a fresh seafood meal at markets, sushi shops, and home meals, especially when high-quality sashimi is available.";
"recipe.jp_kaisendon.info.summary" = "Sashimi rice bowl";
"recipe.jp_kaisendon.name" = "Seafood rice bowl";
"recipe.jp_kaisendon.step1.body" = "Rinse the %i1 repeatedly until the water runs mostly clear, then soak it briefly before cooking and drain well.";
"recipe.jp_kaisendon.step1.title" = "Rinse and soak the rice";
"recipe.jp_kaisendon.step2.body" = "Cook the rice with %i2 until tender, then let it rest covered so the grains finish steaming and become evenly cooked.";
"recipe.jp_kaisendon.step2.title" = "Cook the rice";
"recipe.jp_kaisendon.step3.body" = "Warm the %i3, %i4, and %i5 gently until dissolved, then let the seasoning cool slightly.";
"recipe.jp_kaisendon.step3.title" = "Make sushi seasoning";
"recipe.jp_kaisendon.step4.body" = "Transfer the hot rice to a wide bowl and fold in the sushi seasoning gently while fanning or spreading so the rice becomes glossy and cools to warm room temperature.";
"recipe.jp_kaisendon.step4.title" = "Season the rice";
"recipe.jp_kaisendon.step5.body" = "Warm the %i17 with %i18 and %i19 briefly to blend the flavors, then cool before serving.";
"recipe.jp_kaisendon.step5.title" = "Prepare the sauce";
"recipe.jp_kaisendon.step6.body" = "Slice the %i6, %i7, %i8, %i9, and %i10 into bite-size pieces and cut the %i11, %i12, %i13, and %i14 into fine garnish cuts. Keep the seafood chilled until assembly.";
"recipe.jp_kaisendon.step6.title" = "Prepare sashimi and garnishes";
"recipe.jp_kaisendon.step7.body" = "Divide the seasoned rice among serving bowls and level the surface lightly.";
"recipe.jp_kaisendon.step7.title" = "Portion the rice";
"recipe.jp_kaisendon.step8.body" = "Arrange the assorted sashimi neatly over each bowl, balancing colors and textures across the portions.";
"recipe.jp_kaisendon.step8.title" = "Arrange the seafood";
"recipe.jp_kaisendon.step9.body" = "Top with shiso, nori, cucumber, daikon, %i15, and a small amount of %i16. Serve immediately with the sauce for drizzling at the table.";
"recipe.jp_kaisendon.step9.title" = "Finish and serve";
