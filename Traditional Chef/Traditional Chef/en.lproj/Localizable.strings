"recipe.my_bubur_cha_cha.step1.title" = "Prepare the tubers and banana";
"recipe.my_bubur_cha_cha.step2.body" = "Steam the sweet potatoes and taro until just tender but not falling apart. Remove and set aside so they keep their shape.";
"recipe.my_bubur_cha_cha.step2.title" = "Steam the root vegetables";
"recipe.my_bubur_cha_cha.step3.body" = "Bring %i6 to a boil in a saucepan and cook the %i5 until mostly translucent. Drain, rinse under water to remove excess starch, and set aside.";
"recipe.my_bubur_cha_cha.step3.title" = "Cook the sago pearls";
"recipe.my_bubur_cha_cha.step4.body" = "Add water, %i9, %i8, and %i10 to a large pot and bring to a gentle simmer. Cook until the sugar dissolves and the pandan aroma infuses the liquid.";
"recipe.my_bubur_cha_cha.step4.title" = "Make pandan syrup base";
"recipe.my_bubur_cha_cha.step5.body" = "Add the steamed sweet potatoes, taro, and banana to the pot. Simmer gently so the banana softens and the root vegetables absorb the sweet pandan broth.";
"recipe.my_bubur_cha_cha.step5.title" = "Add roots and banana";
"recipe.my_bubur_cha_cha.step6.body" = "Stir in the cooked sago and %i7 and heat gently. Do not let the dessert boil hard after adding coconut milk.";
"recipe.my_bubur_cha_cha.step6.title" = "Add sago and coconut milk";
"recipe.my_bubur_cha_cha.step7.body" = "Taste and adjust the sweetness and salt balance so the coconut broth tastes rounded and fragrant. Remove the pandan leaves before serving.";
"recipe.my_bubur_cha_cha.step7.title" = "Finish and balance";
"recipe.my_bubur_cha_cha.step8.body" = "Ladle bubur cha cha into bowls and serve warm, or let it cool and serve chilled.";
"recipe.my_bubur_cha_cha.step8.title" = "Serve";
