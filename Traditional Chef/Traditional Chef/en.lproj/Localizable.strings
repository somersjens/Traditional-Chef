"recipe.gb_bread_and_butter_pudding.step1.title" = "Prepare bread and dish";
"recipe.gb_bread_and_butter_pudding.step10.body" = "Let the pudding stand briefly, then serve warm with the hot custard.";
"recipe.gb_bread_and_butter_pudding.step10.title" = "Rest and serve";
"recipe.gb_bread_and_butter_pudding.step2.body" = "Arrange half the bread in the dish, scatter over half the %i3 and some lemon zest, then repeat with the remaining bread, raisins, and lemon zest.";
"recipe.gb_bread_and_butter_pudding.step2.title" = "Layer pudding";
"recipe.gb_bread_and_butter_pudding.step3.body" = "Whisk the %i4 with the %i7, then whisk in the %i5, %i6, %i8, and most of the %i9.";
"recipe.gb_bread_and_butter_pudding.step3.title" = "Make custard mixture";
"recipe.gb_bread_and_butter_pudding.step4.body" = "Pour the custard mixture evenly over the bread layers and press the bread lightly so it soaks.";
"recipe.gb_bread_and_butter_pudding.step4.title" = "Pour over custard";
"recipe.gb_bread_and_butter_pudding.step5.body" = "Leave the pudding to stand so the bread absorbs the custard.";
"recipe.gb_bread_and_butter_pudding.step5.title" = "Soak before baking";
"recipe.gb_bread_and_butter_pudding.step6.body" = "Sprinkle the remaining nutmeg over the top and bake until golden brown on top and softly set in the centre.";
"recipe.gb_bread_and_butter_pudding.step6.title" = "Bake pudding";
"recipe.gb_bread_and_butter_pudding.step7.body" = "For the custard, heat the %i11 and %i12 with the %i15 until hot but not boiling.";
"recipe.gb_bread_and_butter_pudding.step7.title" = "Heat custard dairy";
"recipe.gb_bread_and_butter_pudding.step8.body" = "Whisk the %i13 with the %i14, pour in the hot dairy gradually, then return to gentle heat and stir until the custard thickens enough to coat a spoon.";
"recipe.gb_bread_and_butter_pudding.step8.title" = "Finish custard";
"recipe.gb_bread_and_butter_pudding.step9.body" = "Pass the custard through a fine sieve and keep warm.";
"recipe.gb_bread_and_butter_pudding.step9.title" = "Strain custard";
