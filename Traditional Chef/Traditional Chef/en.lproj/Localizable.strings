"recipe.ca_tarte_au_sucre.step1.title" = "Make the pastry";
"recipe.ca_tarte_au_sucre.step2.body" = "Shape the dough into a disc and chill it until firm enough to roll.";
"recipe.ca_tarte_au_sucre.step2.title" = "Chill the dough";
"recipe.ca_tarte_au_sucre.step3.body" = "Roll out the dough, fit it into the pie plate, trim the edge, and chill the shell briefly.";
"recipe.ca_tarte_au_sucre.step3.title" = "Line the pie plate";
"recipe.ca_tarte_au_sucre.step4.body" = "Whisk the %i6, %i7, and flour together in a saucepan, then whisk in the %i9, %i10, and %i11 and cook until the filling comes to a boil and thickens.";
"recipe.ca_tarte_au_sucre.step4.title" = "Cook the filling base";
"recipe.ca_tarte_au_sucre.step5.body" = "Pour the hot filling into the unbaked pastry shell and smooth the surface.";
"recipe.ca_tarte_au_sucre.step5.title" = "Fill the shell";
"recipe.ca_tarte_au_sucre.step6.body" = "Bake until the crust is golden and the filling is set.";
"recipe.ca_tarte_au_sucre.step6.title" = "Bake the pie";
"recipe.ca_tarte_au_sucre.step7.body" = "Let the pie cool fully on a wire rack so the filling firms up for clean slices.";
"recipe.ca_tarte_au_sucre.step7.title" = "Cool completely";
"recipe.ca_tarte_au_sucre.step8.body" = "Cut the sugar pie into portions and serve at room temperature.";
"recipe.ca_tarte_au_sucre.step8.title" = "Serve";
