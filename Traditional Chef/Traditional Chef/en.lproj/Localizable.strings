"recipe.us_ma_new_england_clam_chowder.step5.body" = "Simmer until the potatoes are tender and the broth is flavorful, stirring occasionally so nothing sticks.";
"recipe.us_ma_new_england_clam_chowder.step5.title" = "Simmer until tender";
"recipe.us_ma_new_england_clam_chowder.step6.body" = "Lower the heat and stir in %i8 and %i9, heating gently so the chowder stays smooth without boiling hard.";
"recipe.us_ma_new_england_clam_chowder.step6.title" = "Add milk and cream";
"recipe.us_ma_new_england_clam_chowder.step7.body" = "Add clams, cover, and cook until shells open. Discard any that do not open, then remove clams from shells, chop lightly if needed, and return meat to the pot.";
"recipe.us_ma_new_england_clam_chowder.step7.title" = "Cook the clams";
"recipe.us_ma_new_england_clam_chowder.step8.body" = "Stir in reserved bacon, taste and adjust salt and pepper, then ladle into bowls and serve hot with %i14.";
