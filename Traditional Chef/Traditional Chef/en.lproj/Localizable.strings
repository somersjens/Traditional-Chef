"recipe.sr_pepre_watra.step1.title" = "Prepare the ingredients";
"recipe.sr_pepre_watra.step2.body" = "Place %i2 in a large pot with the onion, tomato, garlic, celery leaves, %i7, %i8, %i9, and %i10, then bring it to a boil.";
"recipe.sr_pepre_watra.step2.title" = "Start the broth";
"recipe.sr_pepre_watra.step3.body" = "Lower the heat and let the broth simmer gently so the vegetables, pepper, and spices flavor the liquid well.";
"recipe.sr_pepre_watra.step3.title" = "Develop the broth";
"recipe.sr_pepre_watra.step4.body" = "Add the fish pieces to the broth and simmer gently until the fish is just cooked through and the soup is fragrant and clear.";
"recipe.sr_pepre_watra.step4.title" = "Cook the fish";
"recipe.sr_pepre_watra.step5.body" = "Taste the broth and adjust the salt, then remove the bay leaf before serving.";
"recipe.sr_pepre_watra.step5.title" = "Finish the soup";
"recipe.sr_pepre_watra.step6.body" = "Ladle the pepre watra into bowls and serve it hot with %i11 alongside.";
"recipe.sr_pepre_watra.step6.title" = "Serve";
