"recipe.gr_moussaka.step7.title" = "Make the béchamel";
"recipe.gr_moussaka.step8.body" = "Arrange a layer of potatoes in a baking dish, add a layer of eggplants, spread the meat sauce evenly, add another layer of eggplants, then pour béchamel over the top and smooth it.";
"recipe.gr_moussaka.step8.title" = "Assemble the layers";
