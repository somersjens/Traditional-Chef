"recipe.mt_soppa_tal_armla.drink.body" = "A dry, crisp white wine such as Vermentino or Sauvignon Blanc pairs well with the vegetable broth and fresh cheese. A good non-alcoholic option is chilled sparkling water with lemon.";
"recipe.mt_soppa_tal_armla.drink.summary" = "White wine (Vermentino)";
"recipe.mt_soppa_tal_armla.info" = "Soppa tal-Armla is a traditional Maltese vegetable soup, known as widow’s soup, made with a generous mixture of vegetables in a light tomato broth. It is traditionally finished with fresh gbejniet and eggs poached directly in the soup, making it a substantial family meal served hot.";
"recipe.mt_soppa_tal_armla.info.summary" = "Hearty widow’s soup";
"recipe.mt_soppa_tal_armla.name" = "Widow's soup";
"recipe.mt_soppa_tal_armla.step1.body" = "Peel and chop %i2, %i3, %i4, %i5, and %i6. Slice %i7 and %i11, break %i10 into small florets, chop %i12, and chop most of %i14.";
"recipe.mt_soppa_tal_armla.step1.title" = "Prepare the vegetables";
"recipe.mt_soppa_tal_armla.step2.body" = "Heat %i1 in the pot and cook the onion, garlic, and parsley gently until softened and fragrant.";
"recipe.mt_soppa_tal_armla.step2.title" = "Start the soup base";
"recipe.mt_soppa_tal_armla.step3.body" = "Add the carrot, potatoes, kohlrabi, celery, %i8, %i9, cauliflower, zucchini, tomatoes, and %i13. Stir well so everything is coated in the base.";
"recipe.mt_soppa_tal_armla.step3.title" = "Add the vegetables";
"recipe.mt_soppa_tal_armla.step4.body" = "Add %i15, %i16, and %i17. Bring to a boil, cover, and simmer gently until the vegetables are tender and the broth is rich.";
"recipe.mt_soppa_tal_armla.step4.title" = "Simmer the soup";
"recipe.mt_soppa_tal_armla.step5.body" = "Lower %i19 into the soup and let them heat through gently without breaking apart.";
"recipe.mt_soppa_tal_armla.step5.title" = "Add the gbejniet";
"recipe.mt_soppa_tal_armla.step6.body" = "Crack %i18 directly into the soup, cover the pot, and cook gently until the whites are set and the yolks remain soft.";
"recipe.mt_soppa_tal_armla.step6.title" = "Poach the eggs";
"recipe.mt_soppa_tal_armla.step7.body" = "Ladle the soup into bowls, making sure each serving gets vegetables, broth, one egg, and a gbejniet, then finish with the remaining parsley.";
"recipe.mt_soppa_tal_armla.step7.title" = "Serve";
