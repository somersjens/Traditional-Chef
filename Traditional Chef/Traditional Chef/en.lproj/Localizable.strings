"recipe.gr_dolmades.drink.body" = "Pair with a crisp Greek white such as Assyrtiko that matches lemon and herbs. A light lager also works well. For a non-alcoholic option, serve sparkling water with lemon or a chilled lemon soda.";
"recipe.gr_dolmades.drink.summary" = "White wine (Assyrtiko)";
"recipe.gr_dolmades.info" = "Dolmades are traditional Greek vine leaves stuffed with a fragrant rice-and-herb filling, tightly rolled and gently simmered until tender. They are served at room temperature with lemon, often as part of a meze spread, where the vine leaves turn silky and the filling stays bright with dill and herbs.";
"recipe.gr_dolmades.info.summary" = "Lemony vine leaf rolls";
"recipe.gr_dolmades.name" = "Dolmades";
"recipe.gr_dolmades.step1.body" = "Rinse %i11 and blanch them briefly in boiling water to soften, then drain well.";
"recipe.gr_dolmades.step1.title" = "Prep the leaves";
"recipe.gr_dolmades.step2.body" = "Finely chop %i2, %i3, %i4, %i5, and %i6. Mix them with %i1, %i7, %i8, %i9, and %i10.";
"recipe.gr_dolmades.step2.title" = "Make the filling";
"recipe.gr_dolmades.step3.body" = "Lay a leaf vein-side up, place a small amount of filling near the base, fold in the sides, and roll tightly. Repeat until all are rolled.";
"recipe.gr_dolmades.step3.title" = "Roll the dolmades";
"recipe.gr_dolmades.step4.body" = "Line the bottom of the pot with a few leaves, pack the dolmades snugly in layers, drizzle with %i13, and add water and lemon juice.";
"recipe.gr_dolmades.step4.title" = "Pack the pot";
"recipe.gr_dolmades.step5.body" = "Place a plate on top to keep the rolls submerged. Cover and simmer very gently until the rice is tender and the leaves are silky.";
"recipe.gr_dolmades.step5.title" = "Simmer gently";
"recipe.gr_dolmades.step6.body" = "Let them cool to room temperature so the flavours settle and the rolls firm up.";
"recipe.gr_dolmades.step6.title" = "Cool to serve";
"recipe.gr_dolmades.step7.body" = "Serve at room temperature with %i14 wedges.";
"recipe.gr_dolmades.step7.title" = "Serve the dolmades";
