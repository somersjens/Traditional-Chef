"recipe.bo_majadito.drink.body" = "A cold light lager is a classic match for the savory charque rice and fried accompaniments. A soft young red wine can also work. For a non-alcoholic option, serve mocochinchi or sparkling water with lime.";
"recipe.bo_majadito.drink.summary" = "Beer (Lager)";
"recipe.bo_majadito.info" = "Majadito is a traditional Bolivian dish from Santa Cruz, classically made with charque cooked with rice, onion, tomato, bell pepper, garlic, cumin, and achiote until the grains absorb the savory meat juices and turn richly colored. It is traditionally served as a full plate with fried ripe plantain, yuca, and fried egg.";
"recipe.bo_majadito.info.summary" = "Charque rice plate";
"recipe.bo_majadito.name" = "Majadito";
"recipe.bo_majadito.step1.body" = "Chop %i3, %i4, %i5, and %i6. Peel %i15, cut it into serving pieces, and slice %i13 lengthwise. Rinse %i2.";
"recipe.bo_majadito.step1.title" = "Prepare the ingredients";
"recipe.bo_majadito.step2.body" = "Place %i1 in the large pot with %i12 and simmer until tender enough to shred. Remove it, reserve the cooking liquid, and shred the meat finely.";
"recipe.bo_majadito.step2.title" = "Cook the charque";
"recipe.bo_majadito.step3.body" = "Heat %i9 in the pot and cook the onion, garlic, and bell pepper until softened. Add the tomatoes, %i7, %i8, %i10, and %i11, and cook until the mixture is fragrant and lightly thickened.";
"recipe.bo_majadito.step3.title" = "Make the base";
"recipe.bo_majadito.step4.body" = "Add the shredded charque and the rice to the pot and stir well so the grains are coated. Pour in the reserved cooking liquid and extra water as needed, then simmer until the rice is tender and the majadito is moist but not soupy.";
"recipe.bo_majadito.step4.title" = "Cook the rice with charque";
"recipe.bo_majadito.step5.body" = "Cook the yuca in water with %i16 until tender, then drain and keep warm.";
"recipe.bo_majadito.step5.title" = "Boil the yuca";
"recipe.bo_majadito.step6.body" = "Heat %i14 in the skillet and fry the plantain slices until golden and caramelized. Drain them well.";
"recipe.bo_majadito.step6.title" = "Fry the plantains";
"recipe.bo_majadito.step7.body" = "Cook %i17 in the skillet until the whites are set and the yolks remain soft.";
"recipe.bo_majadito.step7.title" = "Fry the eggs";
"recipe.bo_majadito.step8.body" = "Serve the majadito hot with yuca, fried ripe plantain, and a fried egg on each plate.";
"recipe.bo_majadito.step8.title" = "Serve traditionally";
