"recipe.tr_haydari.step3.title" = "Season and finish";
"recipe.tr_haydari.step4.body" = "Refrigerate the haydari so the flavors meld and the texture firms.";
"recipe.tr_haydari.step4.title" = "Chill to set";
"recipe.tr_haydari.step5.body" = "Spoon into a serving bowl and serve chilled with %i8.";
"recipe.tr_haydari.step5.title" = "Serve";
