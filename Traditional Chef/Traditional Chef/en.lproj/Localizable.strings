"recipe.no_lutefisk.drink.body" = "A light lager or a very dry white wine works well with the salty fish and bacon. A traditional non-alcoholic pairing is cold water, and sparkling apple drink also matches the meal well.";
"recipe.no_lutefisk.drink.summary" = "Beer (Lager)";
"recipe.no_lutefisk.info" = "Lutefisk is one of Norway’s oldest festive fish dishes, traditionally served in the Christmas season. The classic Norwegian table pairs the baked fish with boiled potatoes, stewed peas, fried bacon, and mustard for a rich, salty, sweet, and earthy meal.";
"recipe.no_lutefisk.info.summary" = "Christmas lutefisk dinner";
"recipe.no_lutefisk.name" = "Lutefisk";
"recipe.no_lutefisk.step1.body" = "Rinse %i4, cover them with water, and leave them to soak until fully swollen.";
"recipe.no_lutefisk.step1.title" = "Soak the peas";
"recipe.no_lutefisk.step2.body" = "Heat the oven. Place %i1 skin-side down in the baking dish, sprinkle with %i2 and %i3, and let it stand briefly so the salt starts to draw out moisture.";
"recipe.no_lutefisk.step2.title" = "Prepare the fish";
"recipe.no_lutefisk.step3.body" = "Cover the dish and bake the fish gently until it is hot through, opaque, and softly set but still delicate.";
"recipe.no_lutefisk.step3.title" = "Bake the lutefisk";
"recipe.no_lutefisk.step4.body" = "Drain the soaked peas and place them in the medium pot with fresh water. Simmer until very soft, then mash them with %i6 and %i7 into a thick stewed pea mixture.";
"recipe.no_lutefisk.step4.title" = "Cook the peas";
"recipe.no_lutefisk.step5.body" = "Cook %i9 in salted %i10 until tender, then drain them and keep them warm.";
"recipe.no_lutefisk.step5.title" = "Boil the potatoes";
"recipe.no_lutefisk.step6.body" = "Cut %i8 into pieces and fry it slowly until crisp and browned, keeping the rendered fat in the pan.";
"recipe.no_lutefisk.step6.title" = "Fry the bacon";
"recipe.no_lutefisk.step7.body" = "Lift the lutefisk carefully onto warm plates and serve it at once with the boiled potatoes, stewed peas, fried bacon with some of its fat, and %i12 on the side.";
"recipe.no_lutefisk.step7.title" = "Serve";
