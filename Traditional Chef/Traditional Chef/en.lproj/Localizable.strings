"recipe.mt_lampuki_pie.drink.body" = "A dry, crisp white wine such as Vermentino or Sauvignon Blanc pairs well with the fish, herbs, and briny filling. A good non-alcoholic option is chilled sparkling water with lemon or a light citrus drink.";
"recipe.mt_lampuki_pie.drink.summary" = "White wine (Vermentino)";
"recipe.mt_lampuki_pie.info" = "Lampuki Pie is one of Malta’s best-known seasonal dishes, made when lampuki is in season and baked as a substantial family meal. The traditional pie encloses lampuki with spinach, cauliflower, tomatoes, olives, capers, herbs, and sultanas in pastry, and is served hot or warm as a main course.";
"recipe.mt_lampuki_pie.info.summary" = "Lampuki fish pie";
"recipe.mt_lampuki_pie.name" = "Lampuki pie";
"recipe.mt_lampuki_pie.step1.body" = "Rub %i1 and %i2 together until sandy, then mix in one %i3, %i5, and enough %i4 to make a firm pastry. Bring it together, wrap it, and leave it to rest in a cool place.";
"recipe.mt_lampuki_pie.step1.title" = "Make the pastry";
"recipe.mt_lampuki_pie.step10.body" = "Bake the pie until the pastry is golden brown and the filling is fully cooked and hot through.";
"recipe.mt_lampuki_pie.step10.title" = "Bake the pie";
"recipe.mt_lampuki_pie.step11.body" = "Let the pie rest so the filling settles and slices cleanly.";
"recipe.mt_lampuki_pie.step11.title" = "Rest before serving";
"recipe.mt_lampuki_pie.step12.body" = "Cut the lampuki pie into slices and serve it hot or warm.";
"recipe.mt_lampuki_pie.step12.title" = "Serve";
"recipe.mt_lampuki_pie.step2.body" = "Chop %i7, %i8, %i14, %i19, %i20, and %i21. Break %i11 into small pieces, slice %i12, remove any remaining bones from %i6, and grate the zest from %i22.";
"recipe.mt_lampuki_pie.step2.title" = "Prepare the filling ingredients";
"recipe.mt_lampuki_pie.step3.body" = "Boil the cauliflower, carrot, and %i13 in salted %i26 until just tender, then drain them well. Cook %i10 until wilted, drain it thoroughly, and chop it.";
"recipe.mt_lampuki_pie.step3.title" = "Cook the vegetables";
"recipe.mt_lampuki_pie.step4.body" = "Heat %i9 in the frying pan and cook the onion and garlic gently until softened. Add the tomatoes and %i15 and cook until the mixture thickens slightly.";
"recipe.mt_lampuki_pie.step4.title" = "Start the filling base";
"recipe.mt_lampuki_pie.step5.body" = "Add the spinach, cauliflower, carrot, peas, %i16, %i17, %i18, parsley, mint, marjoram, lemon zest, %i24, and %i25. Fold in the lampuki and cook gently just until the fish starts to turn opaque, then let the mixture cool slightly.";
"recipe.mt_lampuki_pie.step5.title" = "Finish the filling";
"recipe.mt_lampuki_pie.step6.body" = "Beat one %i23 and mix it into the cooled filling so the pie sets properly during baking.";
"recipe.mt_lampuki_pie.step6.title" = "Bind the filling";
"recipe.mt_lampuki_pie.step7.body" = "Roll out a little more than half of the pastry and line the pie dish, leaving enough pastry to cover the rim.";
"recipe.mt_lampuki_pie.step7.title" = "Line the pie dish";
"recipe.mt_lampuki_pie.step8.body" = "Spoon the filling into the pastry case, roll out the remaining pastry, place it over the top, and seal the edges well.";
"recipe.mt_lampuki_pie.step8.title" = "Fill and close the pie";
"recipe.mt_lampuki_pie.step9.body" = "Beat the remaining %i28 and brush it over the top so the pastry bakes to a deep golden finish.";
"recipe.mt_lampuki_pie.step9.title" = "Brush the pie";
