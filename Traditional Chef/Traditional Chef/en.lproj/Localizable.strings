"recipe.bg_sarmi.drink.body" = "A light to medium-bodied red wine such as Mavrud or Pinot Noir pairs well with the savory pork, tangy cabbage, and sweet onions. For a non-alcoholic pairing, serve ayran or sparkling water.";
"recipe.bg_sarmi.drink.summary" = "Red wine (Mavrud)";
"recipe.bg_sarmi.info" = "Sarmi are traditional Bulgarian stuffed rolls made with pickled cabbage leaves filled with pork, rice, onion, and herbs, then slowly baked or simmered until tender. They are a classic winter family dish in Bulgaria and are traditionally served hot with thick Bulgarian yogurt on the side.";
"recipe.bg_sarmi.info.summary" = "Bulgarian cabbage rolls";
"recipe.bg_sarmi.name" = "Sarmi";
"recipe.bg_sarmi.step1.body" = "Chop %i3 finely and cook them in %i4 until soft and lightly golden.";
"recipe.bg_sarmi.step1.title" = "Prepare the filling base";
"recipe.bg_sarmi.step10.body" = "Arrange the sarmi in a serving dish and serve hot with %i12 on the side.";
"recipe.bg_sarmi.step10.title" = "Serve with yogurt";
