"recipe.dz_kalb_el_louz.drink.body" = "A floral dessert wine like Muscat echoes the orange blossom and almond notes while matching the syrupy sweetness. If you prefer something lighter, a gently sweet sparkling wine can refresh the palate. Non-alcoholic pairing: hot mint tea or black coffee.";
"recipe.dz_kalb_el_louz.drink.summary" = "Dessert wine (Muscat)";
"recipe.dz_kalb_el_louz.info" = "Kalb el Louz is a traditional Algerian semolina cake soaked in orange-blossom syrup and layered or topped with almonds, baked until deep golden and then drenched so it becomes moist, dense, and perfumed. It is a beloved Ramadan sweet, cut into diamond shapes and served at room temperature with mint tea.";
"recipe.dz_kalb_el_louz.info.summary" = "Syrupy semolina cake";
"recipe.dz_kalb_el_louz.name" = "Kalb el louz";
"recipe.dz_kalb_el_louz.step1.body" = "Simmer %i7 with %i8 and %i9 juice until slightly thickened, then off the heat stir in %i10 and set aside to cool.";
"recipe.dz_kalb_el_louz.step1.title" = "Make the syrup";
"recipe.dz_kalb_el_louz.step2.body" = "Combine %i1, %i2, and %i6. Rub in melted %i3 until evenly moistened and sandy.";
"recipe.dz_kalb_el_louz.step2.title" = "Mix semolina base";
"recipe.dz_kalb_el_louz.step3.body" = "Add %i4 and mix until evenly hydrated. Let the mixture rest so the semolina swells.";
"recipe.dz_kalb_el_louz.step3.title" = "Add milk and rest";
"recipe.dz_kalb_el_louz.step4.body" = "Grease the baking pan with %i11. Split the %i5 so they are ready for layering and topping.";
"recipe.dz_kalb_el_louz.step4.title" = "Prepare the pan and almonds";
"recipe.dz_kalb_el_louz.step5.body" = "Press half the semolina mixture firmly into the pan, add a layer of almonds, cover with the remaining semolina, press firmly, then score into diamond portions and place an almond on each piece.";
"recipe.dz_kalb_el_louz.step5.title" = "Assemble and score";
"recipe.dz_kalb_el_louz.step6.body" = "Bake until the surface is well browned and the cake is set throughout.";
"recipe.dz_kalb_el_louz.step6.title" = "Bake until deep golden";
"recipe.dz_kalb_el_louz.step7.body" = "Pour cooled syrup over the hot cake gradually so it absorbs evenly, then return briefly to the oven so the syrup penetrates.";
"recipe.dz_kalb_el_louz.step7.title" = "Soak with syrup";
"recipe.dz_kalb_el_louz.step8.body" = "Let the cake rest until fully cooled and the syrup is completely absorbed and the texture sets.";
"recipe.dz_kalb_el_louz.step8.title" = "Rest to absorb";
"recipe.dz_kalb_el_louz.step9.body" = "Cut along the scored lines and serve at room temperature.";
"recipe.dz_kalb_el_louz.step9.title" = "Serve";
