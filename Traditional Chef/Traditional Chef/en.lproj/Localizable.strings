"recipe.ma_rfissa.drink.body" = "A medium-bodied white such as Viognier or Chardonnay complements the aromatic spices and savory broth. For a non-alcoholic option, serve Moroccan mint tea or sparkling water with lemon.";
"recipe.ma_rfissa.drink.summary" = "White wine (Viognier)";
"recipe.ma_rfissa.info" = "Rfissa is a traditional Moroccan dish of tender chicken cooked in a fragrant broth with ras el hanout, fenugreek, and saffron, served over torn, layered msemen that soaks up the sauce. Green lentils are simmered in the same broth for body, and the dish is presented on a large platter for sharing, especially associated with family gatherings and postpartum meals.";
"recipe.ma_rfissa.info.summary" = "Rfissa family platter";
"recipe.ma_rfissa.name" = "Rfissa";
