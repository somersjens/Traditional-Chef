"recipe.ph_kare_kare.drink.body" = "A fuller white wine such as oaked Chardonnay can match the rich peanut sauce and slow-cooked beef. A pale lager is also a classic pairing. For a non-alcoholic option, serve calamansi juice or iced tea.";
"recipe.ph_kare_kare.drink.summary" = "White wine (Chardonnay)";
"recipe.ph_kare_kare.info" = "Kare-kare is a traditional Filipino peanut-based stew usually made with oxtail and beef tripe, colored with annatto and simmered until tender with vegetables such as eggplant, long beans, and bok choy. It is a festive family dish commonly served hot with steamed rice and bagoong alamang on the side.";
"recipe.ph_kare_kare.info.summary" = "Peanut oxtail stew";
"recipe.ph_kare_kare.name" = "Kare-kare";
"recipe.ph_kare_kare.step1.body" = "Rinse the %i1 and %i2. Cut the tripe into serving pieces. Peel and quarter the %i4 and lightly crush the %i5 for the broth.";
"recipe.ph_kare_kare.step1.title" = "Prepare meat and aromatics";
"recipe.ph_kare_kare.step10.body" = "Add the %i12 to the annatto oil, then whisk in %i10 and %i11 until smooth and gently simmering.";
"recipe.ph_kare_kare.step10.title" = "Build peanut sauce";
"recipe.ph_kare_kare.step11.body" = "Add the oxtail and tripe to the peanut sauce, season with %i13, and simmer until the sauce thickens and coats the meat. Fold in the blanched vegetables and heat through.";
"recipe.ph_kare_kare.step11.title" = "Finish kare-kare stew";
"recipe.ph_kare_kare.step12.body" = "In a small pan, heat %i21 and cook the chopped %i19 and %i20 until softened, then add %i18 and %i22 and cook until glossy and fragrant.";
"recipe.ph_kare_kare.step12.title" = "Cook bagoong side";
"recipe.ph_kare_kare.step13.body" = "Transfer the kare-kare to a serving bowl and serve hot with steamed rice and bagoong alamang on the side.";
"recipe.ph_kare_kare.step13.title" = "Serve";
"recipe.ph_kare_kare.step2.body" = "Place the oxtail and tripe in a stockpot with %i3, onion, garlic, %i6, and %i7. Bring to a boil, skim, then simmer gently until very tender.";
"recipe.ph_kare_kare.step2.title" = "Simmer meat";
"recipe.ph_kare_kare.step3.body" = "Lift out the oxtail and tripe and strain the cooking liquid. Keep the meat warm and reserve broth for the sauce.";
"recipe.ph_kare_kare.step3.title" = "Strain broth and separate meat";
"recipe.ph_kare_kare.step4.body" = "Cut the %i14 and %i15 into serving lengths, trim the %i16, and prepare the %i17 in slices suitable for the stew.";
"recipe.ph_kare_kare.step4.title" = "Prepare vegetables";
"recipe.ph_kare_kare.step5.body" = "Blanch the eggplant, long beans, bok choy, and banana blossom in simmering water until just tender, then drain and set aside.";
"recipe.ph_kare_kare.step5.title" = "Cook vegetables briefly";
"recipe.ph_kare_kare.step6.body" = "Rinse the %i23 until the water runs mostly clear, then drain.";
"recipe.ph_kare_kare.step6.title" = "Wash rice";
"recipe.ph_kare_kare.step7.body" = "Place the rice in a saucepan with %i24, bring to a boil, cover, and cook gently until the rice is tender and the water is absorbed.";
"recipe.ph_kare_kare.step7.title" = "Cook rice";
"recipe.ph_kare_kare.step8.body" = "Turn off the heat and let the covered rice rest, then fluff before serving.";
"recipe.ph_kare_kare.step8.title" = "Rest rice";
"recipe.ph_kare_kare.step9.body" = "Heat %i8 gently in a pot, add the %i9, and cook until the oil is deeply colored, then strain out the seeds.";
