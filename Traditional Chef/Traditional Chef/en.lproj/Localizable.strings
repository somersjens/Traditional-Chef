"recipe.co_mondongo.step6.title" = "Cook the rice";
"recipe.co_mondongo.step7.body" = "Stir in chopped cilantro leaves and cook briefly just until fragrant. Taste and adjust salt.";
"recipe.co_mondongo.step7.title" = "Finish with cilantro";
"recipe.co_mondongo.step8.body" = "Ladle soup into bowls and serve with rice and %i20 on the side.";
"recipe.co_mondongo.step8.title" = "Serve";
