"recipe.sk_strapacky.drink.body" = "A fresh white wine such as Riesling pairs well with the tangy sauerkraut and smoky bacon without overwhelming the dumplings. A pale lager is also a classic match. For a non-alcoholic option, serve kefir or sparkling water.";
"recipe.sk_strapacky.drink.summary" = "White wine (Riesling)";
"recipe.sk_strapacky.info" = "Strapacky is a traditional Slovak dish of rustic potato halusky dumplings mixed with slowly cooked sauerkraut and finished with crisp smoked bacon and onion. It is served hot as a hearty home-style main course, especially in colder months, and is one of the classic non-bryndza halusky variations.";
"recipe.sk_strapacky.info.summary" = "Sauerkraut halusky";
"recipe.sk_strapacky.name" = "Strapačky";
