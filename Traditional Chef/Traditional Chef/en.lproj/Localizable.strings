"recipe.sa_jareesh.drink.body" = "A soft, low-oak white wine such as Viognier or Chardonnay pairs gently with the tangy laban and rich ghee. For a non-alcoholic pairing, serve hot black tea or cold salted laban.";
"recipe.sa_jareesh.drink.summary" = "White wine (Viognier)";
"recipe.sa_jareesh.info" = "Jareesh is a traditional Saudi main dish of crushed wheat slowly cooked with laban and water until soft and porridge-like, then finished with a fried onion and ghee topping known as kushnah. It is especially associated with Najd and is served hot as a comforting family dish and an important part of Saudi culinary heritage.";
"recipe.sa_jareesh.info.summary" = "Cracked wheat porridge";
"recipe.sa_jareesh.name" = "Jareesh";
"recipe.sa_jareesh.step1.body" = "Wash %i1 well and drain it so the grains cook evenly and lose any excess surface starch.";
"recipe.sa_jareesh.step1.title" = "Rinse the wheat";
"recipe.sa_jareesh.step2.body" = "Put the cracked wheat in the heavy pot with %i5 and part of %i6, bring it up to a boil, and stir well.";
"recipe.sa_jareesh.step2.title" = "Start the base";
"recipe.sa_jareesh.step3.body" = "Lower the heat and cook gently, stirring regularly, until the wheat swells and becomes very soft and thick.";
"recipe.sa_jareesh.step3.title" = "Cook until very soft";
"recipe.sa_jareesh.step4.body" = "Stir in %i4 gradually so the mixture stays smooth, then add %i7, %i8, %i9, and the rest of the salt.";
"recipe.sa_jareesh.step4.title" = "Add the laban";
"recipe.sa_jareesh.step5.body" = "Keep cooking over low heat and stir firmly until the grains break down further and the dish becomes creamy and porridge-like.";
"recipe.sa_jareesh.step5.title" = "Mash and thicken the jareesh";
"recipe.sa_jareesh.step6.body" = "Slice %i2 thinly and fry them in %i3 until deep golden and fragrant.";
"recipe.sa_jareesh.step6.title" = "Prepare the kushnah";
"recipe.sa_jareesh.step7.body" = "Take the jareesh off the heat and let it stand briefly so the texture settles and thickens fully.";
"recipe.sa_jareesh.step7.title" = "Rest the pot";
"recipe.sa_jareesh.step8.body" = "Spoon the jareesh into a serving dish and pour the hot onion and ghee kushnah over the top before serving immediately.";
"recipe.sa_jareesh.step8.title" = "Finish and serve";
