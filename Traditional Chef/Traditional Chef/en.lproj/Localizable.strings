"recipe.dz_mechoui.drink.body" = "A medium-bodied red like Syrah pairs well with roasted lamb and browned fat while handling cumin and char. If you prefer white, a structured white like Viognier can work with the richness. Non-alcoholic pairing: mint tea or sparkling water with lemon.";
"recipe.dz_mechoui.drink.summary" = "Red wine (Syrah)";
"recipe.dz_mechoui.info" = "Mechoui is a traditional Algerian celebration dish of lamb roasted until deeply browned and tender, seasoned simply with salt and often served pulled or carved with cumin on the side. It is commonly presented at gatherings and feasts, accompanied by fresh khobz bread and a simple tomato-onion salad to balance the rich meat.";
"recipe.dz_mechoui.info.summary" = "Celebration roast lamb";
"recipe.dz_mechoui.name" = "Mechoui";
"recipe.dz_mechoui.step1.body" = "Mix %i7, %i8, %i9, and %i10. Add %i11, then add %i12 gradually and knead until smooth and elastic.";
"recipe.dz_mechoui.step1.title" = "Make the bread dough";
"recipe.dz_mechoui.step2.body" = "Cover the dough and let it rise until doubled and airy.";
"recipe.dz_mechoui.step2.title" = "Proof the dough";
"recipe.dz_mechoui.step3.body" = "Pat the %i1 dry. Pound or mince the %i2 and rub it over the lamb with %i3 and %i5.";
"recipe.dz_mechoui.step3.title" = "Prepare the lamb";
"recipe.dz_mechoui.step4.body" = "Roast the lamb, adding a little %i6 to the pan to prevent scorching, until deeply browned and tender, basting occasionally.";
"recipe.dz_mechoui.step4.title" = "Roast until tender";
"recipe.dz_mechoui.step5.body" = "Rest the lamb loosely covered so the juices redistribute before carving or pulling.";
"recipe.dz_mechoui.step5.title" = "Rest the lamb";
"recipe.dz_mechoui.step6.body" = "Turn the dough out, shape into a round loaf, place on a baking tray, and cover to rise again.";
"recipe.dz_mechoui.step6.title" = "Shape the bread";
"recipe.dz_mechoui.step7.body" = "Bake until well risen and browned, then cool slightly before slicing.";
"recipe.dz_mechoui.step7.title" = "Bake the bread";
"recipe.dz_mechoui.step8.body" = "Slice the %i14 and chop the %i13, then dress with %i15, %i16, and %i17.";
"recipe.dz_mechoui.step8.title" = "Make the salad";
"recipe.dz_mechoui.step9.body" = "Carve or pull the lamb and serve hot with %i4 for sprinkling, alongside bread and the simple salad.";
"recipe.dz_mechoui.step9.title" = "Serve with cumin";
