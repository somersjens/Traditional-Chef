"recipe.it_pesto_alla_genovese.step6.title" = "Add the basil";
"recipe.it_pesto_alla_genovese.step7.body" = "Work in the grated %i7 and %i8 until evenly combined.";
"recipe.it_pesto_alla_genovese.step7.title" = "Add the cheeses";
"recipe.it_pesto_alla_genovese.step8.body" = "Drizzle in %i9 while grinding until the pesto is smooth and aromatic.";
"recipe.it_pesto_alla_genovese.step8.title" = "Emulsify with oil";
"recipe.it_pesto_alla_genovese.step9.body" = "Drain the pasta and vegetables, transfer them to a bowl, add the pesto, and toss thoroughly, loosening with a little pasta cooking water if needed.";
