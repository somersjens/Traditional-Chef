"recipe.gr_galaktoboureko.drink.body" = "Pair with a sweet Muscat from Greece that complements lemon syrup and custard without clashing with buttered filo. A lightly sweet sparkling wine can also work. For a non-alcoholic option, serve Greek coffee, black tea, or sparkling water with lemon.";
"recipe.gr_galaktoboureko.drink.summary" = "Sweet wine (Muscat)";
"recipe.gr_galaktoboureko.info" = "Galaktoboureko is a classic Greek dessert of creamy semolina custard baked in crisp layers of buttered filo, then soaked with hot lemon-scented syrup as soon as it comes out of the oven. The contrast of crackly pastry, rich custard, and fragrant syrup is central, and it is served in neat squares once the syrup has been absorbed.";
"recipe.gr_galaktoboureko.info.summary" = "Syrup-soaked filo custard";
"recipe.gr_galaktoboureko.name" = "Galaktoboureko";
"recipe.gr_galaktoboureko.step1.body" = "Simmer %i10 with %i11, lemon peel, and lemon juice until slightly thickened, then stir in %i13 and let the syrup cool.";
"recipe.gr_galaktoboureko.step1.title" = "Make the syrup";
"recipe.gr_galaktoboureko.step2.body" = "Warm %i1 with %i6 and a pinch of %i7. Whisk in %i2 and cook while stirring until thick and smooth, then stir in %i3 and %i5.";
"recipe.gr_galaktoboureko.step2.title" = "Cook the semolina custard";
"recipe.gr_galaktoboureko.step3.body" = "Remove the vanilla pod. Let the custard cool slightly, then whisk in the beaten %i4 gradually so the custard stays smooth.";
"recipe.gr_galaktoboureko.step3.title" = "Enrich with the eggs";
"recipe.gr_galaktoboureko.step4.body" = "Butter the baking dish and layer %i8, brushing each sheet with melted %i9, building a thick base with overhang for folding.";
"recipe.gr_galaktoboureko.step4.title" = "Layer the filo base";
"recipe.gr_galaktoboureko.step5.body" = "Pour in the custard, fold the overhanging filo over the top, and layer the remaining filo sheets on top, buttering each layer.";
"recipe.gr_galaktoboureko.step5.title" = "Fill and fold";
"recipe.gr_galaktoboureko.step6.body" = "Score the top layers into portions so the pastry can be cut cleanly after baking.";
"recipe.gr_galaktoboureko.step6.title" = "Score the top";
"recipe.gr_galaktoboureko.step7.body" = "Bake until the filo is deeply golden and crisp and the custard is set.";
"recipe.gr_galaktoboureko.step7.title" = "Bake the pie";
"recipe.gr_galaktoboureko.step8.body" = "As soon as it comes out of the oven, pour the cooled syrup evenly over the hot pastry so it crackles and absorbs.";
"recipe.gr_galaktoboureko.step8.title" = "Syrup the hot pie";
"recipe.gr_galaktoboureko.step9.body" = "Let it rest until the syrup is absorbed and the pie is cool enough to cut cleanly.";
"recipe.gr_galaktoboureko.step9.title" = "Rest to absorb";
