"recipe.us_ma_new_england_clam_chowder.step2.title" = "Render the bacon";
"recipe.us_ma_new_england_clam_chowder.step3.body" = "Cook %i2 in the bacon fat until softened, then stir in %i3 until fragrant.";
"recipe.us_ma_new_england_clam_chowder.step3.title" = "Cook the aromatics";
