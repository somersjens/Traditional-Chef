"recipe.pe_papa_a_la_huancaina.drink.body" = "Pair with a crisp Sauvignon Blanc or a dry Albariño to match the creamy cheese and ají amarillo. A light pilsner also works well. For a non-alcoholic option, serve chicha morada or sparkling water with lime.";
"recipe.pe_papa_a_la_huancaina.drink.summary" = "White wine (Sauvignon)";
"recipe.pe_papa_a_la_huancaina.info" = "Papa a la Huancaína is a classic Peruvian starter of sliced boiled yellow potatoes served cold or at room temperature under a smooth, creamy ají amarillo and fresh cheese sauce. It is traditionally plated on lettuce leaves and garnished with hard-boiled egg and black olives, offering a bright, mildly spicy, savory balance.";
"recipe.pe_papa_a_la_huancaina.info.summary" = "Potatoes in ají sauce";
"recipe.pe_papa_a_la_huancaina.name" = "Papa a la Huancaína";
"recipe.pe_papa_a_la_huancaina.step1.body" = "Cook the %i1 in salted %i11 until tender, then drain and let them cool until easy to handle.";
"recipe.pe_papa_a_la_huancaina.step1.title" = "Boil the potatoes";
"recipe.pe_papa_a_la_huancaina.step2.body" = "Boil the %i2 until hard-set, then cool, peel, and slice for garnish.";
"recipe.pe_papa_a_la_huancaina.step2.title" = "Hard-boil the eggs";
"recipe.pe_papa_a_la_huancaina.step3.body" = "Peel the cooled potatoes and slice them into thick rounds for serving.";
"recipe.pe_papa_a_la_huancaina.step3.title" = "Peel and slice potatoes";
"recipe.pe_papa_a_la_huancaina.step4.body" = "Blend %i5, %i6, %i7, %i8, %i9, and %i10 until completely smooth and creamy.";
"recipe.pe_papa_a_la_huancaina.step4.title" = "Blend the huancaína sauce";
"recipe.pe_papa_a_la_huancaina.step5.body" = "Refrigerate the sauce until slightly thickened so it coats the potatoes well.";
"recipe.pe_papa_a_la_huancaina.step5.title" = "Chill the sauce";
"recipe.pe_papa_a_la_huancaina.step6.body" = "Arrange %i4 on plates, add sliced potatoes, spoon the huancaína sauce generously over them, and garnish with egg slices and %i3.";
"recipe.pe_papa_a_la_huancaina.step6.title" = "Plate traditionally";
