"recipe.iq_dolma_iraqiya.drink.body" = "A dry rosé or a light-bodied red such as Pinot Noir works well with the rich lamb filling and sour-sweet cooking juices. For a non-alcoholic pairing, serve black tea with lemon or chilled ayran.";
"recipe.iq_dolma_iraqiya.drink.summary" = "Rosé wine";
"recipe.iq_dolma_iraqiya.info" = "Iraqi dolma is a festive family dish of vegetables and leaves stuffed with seasoned rice lamb and herbs, then packed tightly in a pot and cooked until tender in a tangy tomato and pomegranate broth. It is traditionally unmolded onto a large tray and served hot for sharing at lunch or dinner.";
"recipe.iq_dolma_iraqiya.info.summary" = "Stuffed vegetable pot";
"recipe.iq_dolma_iraqiya.name" = "Dolma";
"recipe.iq_dolma_iraqiya.step1.body" = "Wash all the vegetables and leaves. Hollow %i14, %i15, %i16, and the larger %i17, keeping the tomato flesh for the filling. Separate %i6 layers for stuffing and peel and slice %i20.";
"recipe.iq_dolma_iraqiya.step1.title" = "Prepare the vegetables";
"recipe.iq_dolma_iraqiya.step2.body" = "Blanch %i18 and %i19 briefly in hot %i22 until flexible, then drain well.";
"recipe.iq_dolma_iraqiya.step2.title" = "Soften the leaves";
"recipe.iq_dolma_iraqiya.step3.body" = "Mix %i1, %i2, %i3, %i4, %i5, finely chopped onions, chopped tomato flesh, %i8, %i9, %i10, %i11, %i12, and %i13 until evenly combined.";
"recipe.iq_dolma_iraqiya.step3.title" = "Make the filling";
"recipe.iq_dolma_iraqiya.step4.body" = "Fill the hollowed vegetables loosely with the rice mixture. Place filling in each grape leaf and Swiss chard leaf, fold in the sides, and roll them into firm parcels.";
"recipe.iq_dolma_iraqiya.step4.title" = "Stuff and roll";
"recipe.iq_dolma_iraqiya.step5.body" = "Arrange the potato slices in the bottom of the pot and place %i21 over them. Pack the stuffed vegetables tightly, then arrange the rolled leaves on top in snug layers.";
"recipe.iq_dolma_iraqiya.step5.title" = "Layer the pot";
"recipe.iq_dolma_iraqiya.step6.body" = "Stir together water, %i23, %i24, %i25, and %i26 until smooth.";
"recipe.iq_dolma_iraqiya.step6.title" = "Mix the cooking broth";
"recipe.iq_dolma_iraqiya.step7.body" = "Pour the broth into the pot, place a plate directly over the dolma to keep everything compact, cover, and bring to a gentle simmer. Cook until the rice is tender, the vegetables are soft, and most of the liquid has reduced into the pot.";
"recipe.iq_dolma_iraqiya.step7.title" = "Cook the dolma";
"recipe.iq_dolma_iraqiya.step8.body" = "Remove the pot from the heat and let the dolma rest covered so the layers settle and the juices are absorbed.";
"recipe.iq_dolma_iraqiya.step8.title" = "Rest the pot";
"recipe.iq_dolma_iraqiya.step9.body" = "Run a knife around the inside edge if needed, place a large tray over the pot, and carefully invert the dolma. Serve hot with the reduced cooking juices spooned over.";
"recipe.iq_dolma_iraqiya.step9.title" = "Unmold and serve";
