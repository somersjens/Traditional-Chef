"recipe.pt_ameijoas_a_bulhao_pato.drink.body" = "A crisp Portuguese white such as Vinho Verde or a dry Arinto cuts through the olive oil and highlights the briny clams and citrus. Serve well chilled. Non-alcoholic pairing: sparkling water with lemon or a chilled citrusy alcohol-free spritz.";
"recipe.pt_ameijoas_a_bulhao_pato.drink.summary" = "White wine (Vinho Verde)";
"recipe.pt_ameijoas_a_bulhao_pato.info" = "Ameijoas a Bulhao Pato is a classic Portuguese petisco of fresh clams quickly steamed with olive oil, sliced garlic, white wine, lemon, and plenty of fresh coriander, producing a fragrant broth meant to be soaked up at the table. Serve immediately while the clams are hot, with crusty bread for dipping and lemon on the side.";
"recipe.pt_ameijoas_a_bulhao_pato.info.summary" = "Garlicky clam petisco";
"recipe.pt_ameijoas_a_bulhao_pato.name" = "Clams Bulhão Pato";
"recipe.pt_ameijoas_a_bulhao_pato.step1.body" = "Place the %i1 in a bowl with %i9 and enough %i7 to make it pleasantly salty. Leave them to purge sand, then lift the clams out and rinse well in a colander under running water.";
"recipe.pt_ameijoas_a_bulhao_pato.step1.title" = "Purge the clams";
"recipe.pt_ameijoas_a_bulhao_pato.step2.body" = "Slice the %i2 thinly, chop the %i5, and cut the %i6 so you can add juice and serve extra on the side. Set out the %i10 for toasting.";
"recipe.pt_ameijoas_a_bulhao_pato.step2.title" = "Prep aromatics and garnish";
"recipe.pt_ameijoas_a_bulhao_pato.step3.body" = "Heat the %i3 in a large pot over medium heat. Add the garlic and cook gently until fragrant and just starting to soften, without letting it brown.";
"recipe.pt_ameijoas_a_bulhao_pato.step3.title" = "Warm the base";
"recipe.pt_ameijoas_a_bulhao_pato.step4.body" = "Add the clams and pour in %i4. Cover and cook, shaking the pot once or twice, until the clams open and release their juices.";
"recipe.pt_ameijoas_a_bulhao_pato.step4.title" = "Steam the clams";
"recipe.pt_ameijoas_a_bulhao_pato.step5.body" = "Discard any clams that did not open. Add lemon juice and most of the chopped coriander, season with salt and %i8, and toss briefly so the clams are coated in the garlicky broth.";
"recipe.pt_ameijoas_a_bulhao_pato.step5.title" = "Finish the sauce";
"recipe.pt_ameijoas_a_bulhao_pato.step6.body" = "Toast the bread until crisp on the outside and still a little tender inside, ready for dipping into the broth.";
"recipe.pt_ameijoas_a_bulhao_pato.step6.title" = "Toast the bread";
"recipe.pt_ameijoas_a_bulhao_pato.step7.body" = "Transfer the clams and all the broth to a serving bowl. Sprinkle with the remaining coriander and serve immediately with lemon on the side and the toasted bread.";
"recipe.pt_ameijoas_a_bulhao_pato.step7.title" = "Serve";
"recipe.pt_ameijoas_a_bulhao_pato.tool.t1" = "Large bowl";
"recipe.pt_ameijoas_a_bulhao_pato.tool.t2" = "Colander";
"recipe.pt_ameijoas_a_bulhao_pato.tool.t3" = "Large pot with lid";
