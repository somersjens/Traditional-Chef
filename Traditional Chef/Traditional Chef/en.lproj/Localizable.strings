"recipe.ma_zaalouk.drink.body" = "A light to medium red such as Grenache pairs well with smoky eggplant, tomato sweetness, and warm spices. For a non-alcoholic option, serve Moroccan mint tea or sparkling water with lemon.";
"recipe.ma_zaalouk.drink.summary" = "Red wine (Grenache)";
"recipe.ma_zaalouk.info" = "Zaalouk is a classic Moroccan cooked salad of eggplant and tomatoes simmered with garlic, olive oil, cumin, paprika, and herbs until soft and jammy, then mashed into a scoopable dip. It is traditionally served as a starter or side on shared tables, eaten warm or at room temperature, and paired with Moroccan khobz for scooping.";
"recipe.ma_zaalouk.info.summary" = "Eggplant tomato dip";
"recipe.ma_zaalouk.name" = "Zaalouk";
"recipe.ma_zaalouk.step1.body" = "Combine %i10, %i11, and %i12 in a bowl. Add %i13 and knead until smooth and elastic, then cover with a towel.";
"recipe.ma_zaalouk.step1.title" = "Start khobz dough";
"recipe.ma_zaalouk.step2.body" = "Leave the dough covered in a warm spot until clearly risen and airy.";
"recipe.ma_zaalouk.step2.title" = "Rise the dough";
"recipe.ma_zaalouk.step3.body" = "Roast the whole %i1 until the skins are blistered and the flesh is very soft. Transfer to a bowl, cover, and let them steam.";
"recipe.ma_zaalouk.step3.title" = "Roast the eggplant";
"recipe.ma_zaalouk.step4.body" = "Peel off the skin, discard it, and chop the soft eggplant flesh.";
"recipe.ma_zaalouk.step4.title" = "Peel and chop eggplant";
"recipe.ma_zaalouk.step5.body" = "Peel the %i2 by blanching if needed, then chop finely. Mince the %i3 and chop the %i9.";
"recipe.ma_zaalouk.step5.title" = "Prep tomatoes and garlic";
"recipe.ma_zaalouk.step6.body" = "Heat %i4 in a skillet over medium heat. Add garlic briefly, then add tomatoes with %i5, %i6, %i7, and %i8 and simmer until thick. Add eggplant and cook, stirring often, until the mixture is jammy and the oil separates slightly. Mash to a scoopable texture and stir in cilantro.";
"recipe.ma_zaalouk.step6.title" = "Cook the zaalouk";
"recipe.ma_zaalouk.step7.body" = "Punch down the risen dough, shape into round loaves, cover briefly, and heat the oven with a baking stone or sheet inside.";
"recipe.ma_zaalouk.step7.title" = "Shape khobz and heat oven";
"recipe.ma_zaalouk.step8.body" = "Bake the loaves until well risen and browned. Remove and let cool slightly for serving.";
"recipe.ma_zaalouk.step8.title" = "Bake the bread";
"recipe.ma_zaalouk.step9.body" = "Serve zaalouk warm or at room temperature with khobz for scooping.";
"recipe.ma_zaalouk.step9.title" = "Serve";
