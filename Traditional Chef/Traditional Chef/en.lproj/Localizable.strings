"recipe.hr_skradinski_rizot.drink.body" = "A full-bodied Dalmatian red such as Plavac Mali pairs well with the rich veal, long-cooked onion base, and cheese. For a non-alcoholic pairing, serve sparkling mineral water or still water with lemon.";
"recipe.hr_skradinski_rizot.drink.summary" = "Red wine (Plavac Mali)";
"recipe.hr_skradinski_rizot.info" = "Skradinski rižot is a celebrated traditional risotto from Skradin in Dalmatia, known for its unusually long preparation and deep savory flavor. It is made with veal, a strong homemade stock, plenty of onion, a little prosciutto, rice, butter, nutmeg, and hard sheep cheese, then cooked slowly until the meat almost dissolves and the risotto turns rich and creamy. It is a festive main course traditionally prepared for special gatherings and long family meals.";
"recipe.hr_skradinski_rizot.info.summary" = "Festive meat risotto";
"recipe.hr_skradinski_rizot.name" = "Skradin risotto";
"recipe.hr_skradinski_rizot.step1.body" = "Cut %i1 and %i2 into large pieces if needed. Peel and roughly chop %i3, %i4, %i5, and %i6.";
"recipe.hr_skradinski_rizot.step1.title" = "Prepare the stock ingredients";
"recipe.hr_skradinski_rizot.step10.body" = "Stir in most of the grated %i16, keeping a little back for serving.";
"recipe.hr_skradinski_rizot.step10.title" = "Add the cheese";
"recipe.hr_skradinski_rizot.step11.body" = "Spoon the risotto onto warm plates and finish with the remaining cheese. Serve immediately while hot and creamy.";
"recipe.hr_skradinski_rizot.step11.title" = "Serve";
"recipe.hr_skradinski_rizot.step2.body" = "Put the beef shank, hen, vegetables, %i7, %i9, and part of %i8 into the stockpot. Bring to a gentle simmer and cook slowly until the broth is strong and fragrant.";
"recipe.hr_skradinski_rizot.step2.title" = "Cook the stock";
"recipe.hr_skradinski_rizot.step3.body" = "Strain the stock and keep it hot. Discard the spent vegetables and reserve the cooked meats for another use.";
"recipe.hr_skradinski_rizot.step3.title" = "Strain and keep hot";
"recipe.hr_skradinski_rizot.step4.body" = "Finely chop %i11, dice %i10 very small, and cut %i13 into tiny pieces.";
"recipe.hr_skradinski_rizot.step4.title" = "Prepare the risotto base";
"recipe.hr_skradinski_rizot.step5.body" = "Heat %i12 in the heavy pot and cook the onions slowly, stirring often, until they become very soft and sweet without browning.";
"recipe.hr_skradinski_rizot.step5.title" = "Soften the onions";
"recipe.hr_skradinski_rizot.step6.body" = "Add the veal and prosciutto to the onions and cook over low heat for many hours, adding hot stock little by little and stirring regularly. Continue until the meat breaks down and the mixture becomes thick and almost spreadable.";
"recipe.hr_skradinski_rizot.step6.title" = "Cook the veal slowly";
"recipe.hr_skradinski_rizot.step7.body" = "Stir %i14 into the meat base so every grain is coated and heated through.";
"recipe.hr_skradinski_rizot.step7.title" = "Add the rice";
"recipe.hr_skradinski_rizot.step8.body" = "Add hot stock a ladle at a time, stirring constantly and letting each addition absorb before adding more, until the rice is tender and the risotto is creamy and flowing.";
"recipe.hr_skradinski_rizot.step8.title" = "Finish the risotto";
"recipe.hr_skradinski_rizot.step9.body" = "Stir in %i15, grate in %i17, add the remaining %i18 and %i19, and mix vigorously so the risotto turns glossy.";
"recipe.hr_skradinski_rizot.step9.title" = "Season and enrich";
