"recipe.fr_profiteroles.drink.body" = "Pair with a sweet red such as Banyuls or Maury that complements dark chocolate and cream. A strong espresso also fits well. For a non-alcoholic option, serve coffee, black tea, or sparkling water.";
"recipe.fr_profiteroles.drink.summary" = "Red wine (Banyuls)";
"recipe.fr_profiteroles.info" = "Profiteroles are classic French choux pastry puffs split and filled with vanilla ice cream, then topped with warm chocolate sauce. They are served immediately so the contrast of cold ice cream and hot sauce stays sharp, making them a brasserie-style dessert centerpiece.";
"recipe.fr_profiteroles.info.summary" = "Ice cream choux stack";
"recipe.fr_profiteroles.name" = "Profiteroles";
"recipe.fr_profiteroles.step1.body" = "Bring %i1, %i2, %i3, and %i4 to a boil. Add %i5 all at once and stir vigorously until the dough forms a ball and a film forms on the pan.";
"recipe.fr_profiteroles.step1.title" = "Make the panade";
"recipe.fr_profiteroles.step2.body" = "Let the dough cool slightly, then beat in %i6 gradually until the paste is smooth, glossy, and pipeable.";
"recipe.fr_profiteroles.step2.title" = "Cool and add the eggs";
"recipe.fr_profiteroles.step3.body" = "Pipe small mounds onto a lined tray and bake until well risen and deeply golden, then cool them fully on a rack.";
"recipe.fr_profiteroles.step3.title" = "Pipe and bake";
"recipe.fr_profiteroles.step4.body" = "Warm %i9 with %i10 until steaming, add the chopped %i8, and whisk until smooth and glossy. Keep it warm.";
"recipe.fr_profiteroles.step4.title" = "Make the chocolate sauce";
"recipe.fr_profiteroles.step5.body" = "Split the cooled profiteroles and fill each one with a scoop of %i7.";
"recipe.fr_profiteroles.step5.title" = "Fill with ice cream";
"recipe.fr_profiteroles.step6.body" = "Arrange the profiteroles on plates, spoon over the warm chocolate sauce, and serve immediately.";
"recipe.fr_profiteroles.step6.title" = "Sauce and serve";
