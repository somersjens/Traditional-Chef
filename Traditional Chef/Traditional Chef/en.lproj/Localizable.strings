"recipe.es_cordero_asado.drink.body" = "Pair with a medium-bodied Spanish red such as Rioja Crianza or Ribera del Duero to match the lamb’s richness without overwhelming the simple seasoning. A dry Cava also works well to cut through the fat. Non-alcoholic option: sparkling water with lemon.";
"recipe.es_cordero_asado.drink.summary" = "Red wine (Rioja Crianza)";
"recipe.es_cordero_asado.info" = "Cordero asado is a traditional Castilian roast of young lamb, seasoned simply with salt and roasted slowly over WATER so the meat turns meltingly tender while the exterior browns and bastes in its own juices. Served hot with its pan drippings, it’s a celebratory centerpiece in Castilla, commonly accompanied by a simple green salad and crusty bread to soak up the savory juices.";
"recipe.es_cordero_asado.info.summary" = "Castilian roast lamb";
"recipe.es_cordero_asado.name" = "Roast lamb";
"recipe.es_cordero_asado.step1.body" = "Heat the oven. Pat %i1 dry and season thoroughly with %i2 on all sides.";
"recipe.es_cordero_asado.step1.title" = "Prepare lamb and oven";
"recipe.es_cordero_asado.step2.body" = "Place a rack in a roasting tray and pour %i3 into the tray so drippings won’t burn. Set the lamb on the rack.";
"recipe.es_cordero_asado.step2.title" = "Set up roasting tray";
"recipe.es_cordero_asado.step3.body" = "Roast until the lamb begins to brown and the fat renders, keeping water in the tray so the pan stays moist.";
"recipe.es_cordero_asado.step3.title" = "Roast slowly for tenderness";
"recipe.es_cordero_asado.step4.body" = "Turn the lamb and baste with pan juices, keeping the skin side as dry as possible while refreshing water in the tray if needed.";
"recipe.es_cordero_asado.step4.title" = "Turn and baste";
"recipe.es_cordero_asado.step5.body" = "Continue roasting, basting occasionally, until the lamb is very tender and well browned, maintaining water in the tray throughout.";
"recipe.es_cordero_asado.step5.title" = "Finish roasting until deeply browned";
"recipe.es_cordero_asado.step6.body" = "Remove the lamb and rest so the juices settle while keeping it warm.";
"recipe.es_cordero_asado.step6.title" = "Rest the roast";
"recipe.es_cordero_asado.step7.body" = "Slice %i4 and %i5. Dress with %i6, %i7, and %i8 and toss well.";
"recipe.es_cordero_asado.step7.title" = "Make the salad";
"recipe.es_cordero_asado.step8.body" = "Carve the lamb and serve with pan juices, green salad, and %i9.";
"recipe.es_cordero_asado.step8.title" = "Carve and serve";
