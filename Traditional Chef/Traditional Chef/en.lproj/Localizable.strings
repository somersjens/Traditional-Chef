"recipe.kh_num_plae_ai.drink.body" = "A lightly sweet white wine such as Moscato complements the palm sugar and coconut. A light lager can also work with the toasted sesame notes. For a non-alcoholic option, serve hot jasmine tea or unsweetened green tea.";
"recipe.kh_num_plae_ai.drink.summary" = "Sweet wine (Moscato)";
"recipe.kh_num_plae_ai.info" = "Num plae ai is a traditional Cambodian dessert of glutinous rice dumplings filled with palm sugar, boiled until tender, then coated with fresh grated coconut and toasted sesame. It is commonly served as a snack or dessert, often presented in small banana-leaf bowls.";
"recipe.kh_num_plae_ai.info.summary" = "Palm sugar dumplings";
