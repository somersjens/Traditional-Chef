"recipe.gb_sussex_pond_pudding.step1.title" = "Prepare steamer and basin";
"recipe.gb_sussex_pond_pudding.step10.body" = "Pass the custard through a fine sieve and keep warm.";
"recipe.gb_sussex_pond_pudding.step10.title" = "Strain custard";
