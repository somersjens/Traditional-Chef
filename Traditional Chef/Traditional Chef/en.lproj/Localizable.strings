"recipe.ir_sholeh_zard.step3.body" = "Drain the rice, add it to a heavy pot with water, bring to a gentle boil, then simmer until the grains are very soft and the mixture turns thick, stirring often.";
"recipe.ir_sholeh_zard.step3.title" = "Cook the rice until broken down";
"recipe.ir_sholeh_zard.step4.body" = "Stir in %i3 and continue cooking, stirring regularly, until the pudding becomes glossy and spoon-thick.";
"recipe.ir_sholeh_zard.step4.title" = "Sweeten and thicken";
"recipe.ir_sholeh_zard.step5.body" = "Stir in the bloomed saffron and %i5 and cook briefly so the aroma settles into the pudding.";
