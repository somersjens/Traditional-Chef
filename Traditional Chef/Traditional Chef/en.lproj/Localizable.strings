"recipe.bd_morog_polao.drink.body" = "An off-dry Riesling or aromatic white balances the rich ghee and warm spices while staying bright alongside the chicken. If you prefer red, choose a light-bodied, low-tannin red served slightly chilled. Non-alcoholic pairing: chilled lemon soda or unsweetened black tea.";
"recipe.bd_morog_polao.drink.summary" = "White wine (Riesling)";
"recipe.bd_morog_polao.info" = "Morog polao is a celebratory Bangladeshi dish where basmati rice is cooked in a richly perfumed stock with chicken, ghee, fried onions, yogurt, and aromatic whole spices. The result is tender chicken and fluffy, fragrant rice with a mellow, creamy spice profile. It is traditionally served hot with a simple cucumber salad to refresh the palate.";
"recipe.bd_morog_polao.info.summary" = "Fragrant chicken polao";
"recipe.bd_morog_polao.name" = "Morog polao";
"recipe.bd_morog_polao.step1.body" = "Make a paste from the %i3 and %i4. Whisk the %i2 smooth and mix it with the paste, %i8, %i9, %i10, %i11, and some of the %i12.";
"recipe.bd_morog_polao.step1.title" = "Prepare the marinade";
"recipe.bd_morog_polao.step10.body" = "Slice the %i23 and dress with %i24 juice and %i25.";
"recipe.bd_morog_polao.step10.title" = "Make the salad";
"recipe.bd_morog_polao.step11.body" = "Serve the morog polao hot with the cucumber salad.";
"recipe.bd_morog_polao.step11.title" = "Serve";
"recipe.bd_morog_polao.step2.body" = "Coat the %i1 thoroughly in the yogurt-spice mixture and set aside.";
"recipe.bd_morog_polao.step2.title" = "Marinate the chicken";
"recipe.bd_morog_polao.step3.body" = "Cover and refrigerate so the chicken absorbs flavour.";
"recipe.bd_morog_polao.step3.title" = "Rest the marinade";
"recipe.bd_morog_polao.step4.body" = "Slice the %i5 thinly and fry in %i6 with %i7 until deep golden. Remove and reserve some for garnish, leaving the remaining fried onions and fat in the pot.";
"recipe.bd_morog_polao.step4.title" = "Make birista";
