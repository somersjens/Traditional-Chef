"recipe.kr_bibimbap.step10.title" = "Cook the beef";
"recipe.kr_bibimbap.step11.body" = "Fry the %i27 in a little neutral oil until the whites are set and the yolks remain soft.";
"recipe.kr_bibimbap.step11.title" = "Fry the eggs";
"recipe.kr_bibimbap.step12.body" = "Fluff the rested rice and divide it among serving bowls.";
"recipe.kr_bibimbap.step12.title" = "Warm and fluff the rice";
