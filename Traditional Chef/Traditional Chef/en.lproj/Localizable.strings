"recipe.se_kottbullar.drink.body" = "A light Pinot Noir pairs well with the savory meatballs and creamy sauce. A pale lager also works nicely. For a non-alcoholic option, serve sparkling water or tart lingonberry drink.";
"recipe.se_kottbullar.drink.summary" = "Red wine (Pinot Noir)";
"recipe.se_kottbullar.info" = "Köttbullar are traditional Swedish meatballs made from beef and pork, gently spiced and browned before being served with cream gravy. They are classically eaten with mashed potatoes, lingonberries, and pressed cucumber, especially as a comforting family meal and festive Sunday dinner.";
"recipe.se_kottbullar.info.summary" = "Swedish meatballs";
"recipe.se_kottbullar.name" = "Swedish meatballs";
