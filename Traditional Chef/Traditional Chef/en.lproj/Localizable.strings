"recipe.al_tave_kosi.drink.body" = "A dry, fresh white wine such as Sauvignon Blanc or an unoaked Chardonnay pairs well with the tangy yogurt topping and rich lamb. A good non-alcoholic pairing is sparkling water or a salted yogurt drink.";
"recipe.al_tave_kosi.drink.summary" = "White wine (Sauvignon)";
"recipe.al_tave_kosi.info" = "Tavë Kosi, also known as Tavë Elbasani, is a traditional Albanian baked lamb and yogurt dish associated with Elbasan and widely regarded as a national dish. Tender lamb and rice are baked under a set layer of yogurt, eggs, and roux, and it is served hot as a substantial family main course.";
"recipe.al_tave_kosi.info.summary" = "Albanian yogurt lamb bake";
"recipe.al_tave_kosi.name" = "Tavë kosi";
"recipe.al_tave_kosi.step1.body" = "Cut %i1 into large pieces and chop %i3. Season the lamb with %i4, %i5, %i6, and garlic.";
"recipe.al_tave_kosi.step1.title" = "Prepare the lamb";
"recipe.al_tave_kosi.step10.body" = "Spoon the tavë kosi onto plates and serve it hot.";
"recipe.al_tave_kosi.step10.title" = "Serve";
"recipe.al_tave_kosi.step2.body" = "Place the lamb in the pot with %i7, bring it to a gentle boil, then lower the heat and simmer until the meat is tender and the cooking liquid is flavorful.";
"recipe.al_tave_kosi.step2.title" = "Cook the lamb";
"recipe.al_tave_kosi.step3.body" = "Lift the lamb out and reserve the cooking liquid. Add %i2 to some of the hot cooking liquid and cook it until partly tender.";
"recipe.al_tave_kosi.step3.title" = "Cook the rice";
"recipe.al_tave_kosi.step4.body" = "Place the lamb in the baking dish and spread the partly cooked rice around it.";
"recipe.al_tave_kosi.step4.title" = "Arrange the base";
