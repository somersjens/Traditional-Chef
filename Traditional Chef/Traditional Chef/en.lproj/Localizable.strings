"recipe.th_pla_neung_manao.drink.body" = "A crisp Sauvignon Blanc pairs well with the bright lime, garlic, and chili flavors while staying fresh with delicate fish. For a non-alcoholic option, serve chilled jasmine tea or plain cold water.";
"recipe.th_pla_neung_manao.drink.summary" = "White wine (Sauvignon)";
"recipe.th_pla_neung_manao.info" = "Pla Neung Manao is a traditional Thai dish of whole steamed fish served with a hot, sharp sauce of lime juice, garlic, bird eye chili, fish sauce, and a touch of sugar, often with ginger and celery beneath the fish. It is commonly served as part of a shared meal with jasmine rice, especially in seafood restaurants and home-style family meals.";
"recipe.th_pla_neung_manao.info.summary" = "Steamed lime fish";
"recipe.th_pla_neung_manao.name" = "Steamed fish with lime";
"recipe.th_pla_neung_manao.step1.body" = "Clean and score the %i1. Slice the %i2 and cut the %i3 into lengths, then place them on a heatproof fish plate as a bed for the fish.";
"recipe.th_pla_neung_manao.step1.title" = "Prepare the fish and aromatics";
"recipe.th_pla_neung_manao.step10.body" = "Serve the pla neung manao immediately on the steaming plate with jasmine rice.";
"recipe.th_pla_neung_manao.step10.title" = "Serve";
"recipe.th_pla_neung_manao.step2.body" = "Rinse the %i12 until the water runs mostly clear. Put it in a saucepan with %i13 and bring it to a boil.";
"recipe.th_pla_neung_manao.step2.title" = "Start the rice";
"recipe.th_pla_neung_manao.step3.body" = "Cover and cook on low heat until the water is absorbed and the rice is tender. Rest covered off the heat.";
"recipe.th_pla_neung_manao.step3.title" = "Cook the rice";
"recipe.th_pla_neung_manao.step4.body" = "Finely chop the %i5 and %i6, chop the %i11, and combine them in a bowl with %i7, %i8, %i9, and %i10.";
"recipe.th_pla_neung_manao.step4.title" = "Prepare the sauce ingredients";
"recipe.th_pla_neung_manao.step5.body" = "Heat the sauce mixture gently in a small saucepan just until the sugar dissolves and the sauce is hot. Do not boil for long so the lime flavor stays bright.";
"recipe.th_pla_neung_manao.step5.title" = "Warm the sauce";
"recipe.th_pla_neung_manao.step6.body" = "Add steaming %i4 to the steamer base and bring it to a strong boil.";
"recipe.th_pla_neung_manao.step6.title" = "Boil steaming water";
"recipe.th_pla_neung_manao.step7.body" = "Place the fish on the aromatic bed in the steamer and steam until the flesh is just cooked through and flakes easily.";
"recipe.th_pla_neung_manao.step7.title" = "Steam the fish";
"recipe.th_pla_neung_manao.step8.body" = "Carefully remove the fish plate from the steamer and spoon the hot lime garlic chili sauce over the fish so it spreads into the steaming juices.";
"recipe.th_pla_neung_manao.step8.title" = "Top with sauce";
"recipe.th_pla_neung_manao.step9.body" = "Scatter the chopped coriander over the fish and let it sit briefly so the aroma releases into the sauce.";
"recipe.th_pla_neung_manao.step9.title" = "Finish with coriander";
"recipe.th_pla_neung_manao.tool.t1" = "Chef knife";
"recipe.th_pla_neung_manao.tool.t2" = "Cutting board";
