"recipe.gb_summer_pudding.step2.title" = "Cook berry filling";
"recipe.gb_summer_pudding.step3.body" = "Lift out the fruit with a spoon, keeping the cooking juices in the pan for dipping the bread and finishing the pudding.";
"recipe.gb_summer_pudding.step3.title" = "Strain juices briefly";
"recipe.gb_summer_pudding.step4.body" = "Line the basin with plastic wrap, trim crusts from the %i7, cut pieces to fit, then dip bread quickly in berry juice and line the basin fully without gaps.";
"recipe.gb_summer_pudding.step4.title" = "Line basin with bread";
"recipe.gb_summer_pudding.step5.body" = "Spoon the cooked berry mixture into the bread-lined basin and pour over a little more juice.";
"recipe.gb_summer_pudding.step5.title" = "Fill pudding";
"recipe.gb_summer_pudding.step6.body" = "Cover the fruit with more bread dipped in juice to seal the top, then fold over the plastic wrap.";
"recipe.gb_summer_pudding.step6.title" = "Seal top";
"recipe.gb_summer_pudding.step7.body" = "Place a plate on top and add a light weight so the pudding compresses.";
"recipe.gb_summer_pudding.step7.title" = "Weight pudding";
"recipe.gb_summer_pudding.step8.body" = "Chill the weighted pudding until fully set and the juices have soaked through the bread.";
"recipe.gb_summer_pudding.step8.title" = "Chill to set";
"recipe.gb_summer_pudding.step9.body" = "Remove the weight and wrap, turn the pudding onto a serving plate, and spoon over some reserved juice to colour any pale patches.";
