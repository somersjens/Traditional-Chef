"recipe.pk_sindhi_biryani.drink.body" = "A medium-bodied red such as Syrah or Grenache can handle the bold spices and rich mutton while staying balanced with the tangy masala. A crisp lager also pairs well. Non-alcoholic pairing: salted lassi or plain yogurt raita is the traditional companion, and black tea also works.";
"recipe.pk_sindhi_biryani.drink.summary" = "Red wine (Syrah)";
"recipe.pk_sindhi_biryani.info" = "Sindhi Biryani is a traditional Pakistani biryani from Sindh made with layered basmati rice and mutton in a spicy, tangy masala with potatoes, tomatoes, yogurt, herbs, green chilies, and dried plums. It is cooked on dum and served hot for family meals and gatherings, typically with raita.";
"recipe.pk_sindhi_biryani.info.summary" = "Tangy Sindhi biryani";
"recipe.pk_sindhi_biryani.name" = "Sindhi biryani";
"recipe.pk_sindhi_biryani.step1.body" = "Rinse the %i14 until the water runs mostly clear, then soak it in %i15 so the grains cook evenly.";
"recipe.pk_sindhi_biryani.step1.title" = "Soak rice";
"recipe.pk_sindhi_biryani.step10.body" = "Turn off the heat and let the biryani rest covered so the layers settle and the grains firm up.";
"recipe.pk_sindhi_biryani.step10.title" = "Rest biryani";
"recipe.pk_sindhi_biryani.step11.body" = "Whisk the %i31 until smooth. Finely chop the %i32, %i33, and %i34, then mix with the yogurt, %i35, and %i36.";
"recipe.pk_sindhi_biryani.step11.title" = "Make raita";
"recipe.pk_sindhi_biryani.step12.body" = "Loosen the biryani gently from the sides and lift it out without overmixing so the layers stay visible. Serve hot with the raita.";
"recipe.pk_sindhi_biryani.step12.title" = "Serve";
"recipe.pk_sindhi_biryani.step2.body" = "Slice the %i3. Chop the %i7. Peel and halve the %i8. Finely chop the %i4 and %i5. Slice the %i10. Chop the %i11 and %i12. Soak the %i30 in a little warm %i13.";
"recipe.pk_sindhi_biryani.step2.title" = "Prepare ingredients";
"recipe.pk_sindhi_biryani.step3.body" = "Heat the %i2 in a karahi or heavy pot and fry the onions until deep golden. Remove about half for layering and keep the rest in the pot.";
"recipe.pk_sindhi_biryani.step3.title" = "Fry onions";
"recipe.pk_sindhi_biryani.step4.body" = "Add the %i1 to the pot and cook until the surface changes color and starts to brown. Add garlic, ginger, %i24, and cook until fragrant.";
"recipe.pk_sindhi_biryani.step4.title" = "Brown mutton and aromatics";
"recipe.pk_sindhi_biryani.step5.body" = "Add %i6, tomatoes, potatoes, %i9, green chilies, %i21, %i22, %i23, %i25, %i27, and %i26. Cook while stirring until the tomatoes break down and the masala thickens.";
"recipe.pk_sindhi_biryani.step5.title" = "Build the masala";
"recipe.pk_sindhi_biryani.step6.body" = "Add water, cover, and simmer until the mutton is tender and the potatoes are cooked, leaving a thick masala with some gravy for layering.";
"recipe.pk_sindhi_biryani.step6.title" = "Simmer mutton";
"recipe.pk_sindhi_biryani.step7.body" = "Bring %i15 to a boil in a large pot with %i16, %i17, %i18, %i19, and %i20. Drain the soaked rice, add it to the boiling water, and cook until the grains are mostly cooked but still firm, then drain.";
"recipe.pk_sindhi_biryani.step7.title" = "Parboil rice";
"recipe.pk_sindhi_biryani.step8.body" = "In the dum pot, spread half of the mutton masala, then half of the rice. Add half of the reserved fried onions, half of the cilantro and mint, and a little %i29. Repeat with the remaining masala, rice, fried onions, cilantro, mint, lemon juice, saffron water, and %i28.";
"recipe.pk_sindhi_biryani.step8.title" = "Layer biryani";
"recipe.pk_sindhi_biryani.step9.body" = "Cover tightly and cook on low heat so the rice finishes steaming and absorbs the mutton masala aromas and juices.";
"recipe.pk_sindhi_biryani.step9.title" = "Cook on dum";
