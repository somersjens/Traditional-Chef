"recipe.fr_salade_nicoise.drink.body" = "Pair with a dry Provençal rosé that matches the briny anchovies and tuna while staying fresh with the vegetables. A crisp pilsner also works well. For a non-alcoholic option, serve sparkling water with lemon or a chilled citrus spritz.";
"recipe.fr_salade_nicoise.drink.summary" = "Rosé wine";
"recipe.fr_salade_nicoise.info" = "Salade Niçoise is a traditional dish from Nice built from raw vegetables and classic Provençal elements: tomatoes, green beans, hard-boiled eggs, anchovies, and tuna, finished with olives and a sharp vinaigrette. In the traditional version, the vegetables are served mostly raw or simply blanched, and potatoes are not included. It is served as a composed salad, eaten fresh and cool.";
"recipe.fr_salade_nicoise.info.summary" = "Niçoise composed salad";
"recipe.fr_salade_nicoise.name" = "Niçoise salad";
"recipe.fr_salade_nicoise.step1.body" = "Bring water to a boil, add %i10, and cook until hard-boiled. Cool them in cold water, then peel and quarter them.";
"recipe.fr_salade_nicoise.step1.title" = "Boil the eggs";
"recipe.fr_salade_nicoise.step2.body" = "Salt the water with %i18, bring it to a boil, and blanch %i2 until crisp-tender. Drain and cool them quickly so they stay bright.";
"recipe.fr_salade_nicoise.step2.title" = "Blanch the beans";
"recipe.fr_salade_nicoise.step3.body" = "Slice %i1, %i3, %i4, %i5, and %i6 and tear %i7.";
"recipe.fr_salade_nicoise.step3.title" = "Prep the vegetables";
"recipe.fr_salade_nicoise.step4.body" = "Whisk %i14 with %i13, then whisk in %i12 until emulsified. Season with %i15 and %i16.";
"recipe.fr_salade_nicoise.step4.title" = "Make the vinaigrette";
"recipe.fr_salade_nicoise.step5.body" = "Arrange the tomatoes and other vegetables on a platter, add the beans, then place %i8, %i9, the eggs, and %i11 neatly over the top.";
"recipe.fr_salade_nicoise.step5.title" = "Compose the salad";
"recipe.fr_salade_nicoise.step6.body" = "Spoon the vinaigrette over the salad and serve immediately.";
