"recipe.it_carpaccio.step4.title" = "Emulsify the sauce";
"recipe.it_carpaccio.step5.body" = "Season the sauce with %i8 and %i9, then taste and balance with a little more lemon juice if needed.";
"recipe.it_carpaccio.step5.title" = "Season the sauce";
"recipe.it_carpaccio.step6.body" = "Refrigerate the sauce while you prepare the beef.";
"recipe.it_carpaccio.step6.title" = "Keep the sauce cold";
"recipe.it_carpaccio.step7.body" = "Slice the firm beef as thinly as possible across the grain.";
"recipe.it_carpaccio.step7.title" = "Slice the beef";
"recipe.it_carpaccio.step8.body" = "Place the slices between plastic wrap and gently pound them to an even, paper-thin layer without tearing.";
"recipe.it_carpaccio.step8.title" = "Flatten the slices";
"recipe.it_carpaccio.step9.body" = "Lay the beef in a single layer on the chilled plates, slightly overlapping to cover the surface.";
