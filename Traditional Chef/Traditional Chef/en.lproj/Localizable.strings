"recipe.sk_strapacky.step2.body" = "Cut the smoked %i6 into small pieces and cook it slowly in the skillet until it releases fat. Add %i7 and cook until softened, then add %i5 and %i8.";
"recipe.sk_strapacky.step2.title" = "Start the sauerkraut base";
"recipe.sk_strapacky.step3.body" = "Add %i4 to the skillet, cover, and cook %i5 gently until tender and mellow, stirring from time to time so it softens without drying out.";
"recipe.sk_strapacky.step3.title" = "Cook the sauerkraut";
"recipe.sk_strapacky.step4.body" = "Bring %i4 to a steady boil in the large pot and season it with the remaining salt.";
"recipe.sk_strapacky.step4.title" = "Boil the water";
"recipe.sk_strapacky.step5.body" = "Push the dough through the halusky board into the boiling water and cook the dumplings until they rise and are tender. Drain them well.";
"recipe.sk_strapacky.step5.title" = "Cook the halusky";
"recipe.sk_strapacky.step6.body" = "Add the drained halusky to the skillet and mix them thoroughly with %i5, %i6, and %i7 so everything is evenly coated.";
"recipe.sk_strapacky.step6.title" = "Combine the dish";
"recipe.sk_strapacky.step7.body" = "Serve the strapacky hot with %i5 and crisp %i6 distributed evenly over each portion.";
"recipe.sk_strapacky.step7.title" = "Serve traditionally";
