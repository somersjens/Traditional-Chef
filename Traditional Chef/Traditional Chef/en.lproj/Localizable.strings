"recipe.cl_arrollado_huaso.drink.body" = "Pair with a Chilean Carménère or other medium-bodied red with good acidity to match the rich pork and bold seasoning. If you prefer white, choose a dry Sauvignon Blanc to cut through the fat. Non-alcoholic option: sparkling water with lemon or a chilled citrusy herbal iced tea to refresh the palate.";
"recipe.cl_arrollado_huaso.drink.summary" = "Red wine (Carménère)";
"recipe.cl_arrollado_huaso.info" = "Arrollado huaso is a traditional Chilean countryside-style pork roll made by seasoning strips of pork, rolling them tightly inside pork skin, tying the roll, and gently simmering it until tender. After cooking, it is pressed and chilled, then sliced and served cold as a hearty charcuterie-style centerpiece, commonly enjoyed in sandwiches with crusty Chilean bread and a fresh pebre salsa.";
"recipe.cl_arrollado_huaso.info.summary" = "Chilean pork roll";
"recipe.cl_arrollado_huaso.name" = "Arrollado huaso";
"recipe.cl_arrollado_huaso.step1.body" = "Lay the %i1 flat, skin-side down. Trim to a neat rectangle and scrape off any remaining fat so it rolls tightly. Pat dry.";
"recipe.cl_arrollado_huaso.step1.title" = "Prepare the pork skin";
"recipe.cl_arrollado_huaso.step10.body" = "Remove the twine and slice the arrollado thinly. Serve on %i22 with pebre spooned over, or plate slices alongside pebre for topping each bite.";
"recipe.cl_arrollado_huaso.step10.title" = "Slice and serve";
"recipe.cl_arrollado_huaso.step2.body" = "In a bowl, combine %i2 with %i3, %i4, %i5, %i6, %i7, %i8, and about half of %i9. Mix thoroughly so every piece is evenly seasoned.";
"recipe.cl_arrollado_huaso.step2.title" = "Season the pork";
"recipe.cl_arrollado_huaso.step3.body" = "Cover and refrigerate so the seasoning penetrates the meat before rolling.";
"recipe.cl_arrollado_huaso.step3.title" = "Chill to marinate";
"recipe.cl_arrollado_huaso.step4.body" = "Spread the seasoned pork in an even layer over the pork skin. Roll up very tightly into a firm cylinder. Tie securely with kitchen twine at regular intervals so it holds its shape during cooking.";
"recipe.cl_arrollado_huaso.step4.title" = "Roll and tie";
"recipe.cl_arrollado_huaso.step5.body" = "Place %i10, %i11, %i12, %i13, and %i14 in a large pot. Add the tied pork roll, bring to a gentle boil, then lower to a steady simmer with the lid slightly ajar.";
"recipe.cl_arrollado_huaso.step5.title" = "Start the simmer";
"recipe.cl_arrollado_huaso.step6.body" = "Keep the roll at a gentle simmer, turning it occasionally, until the pork is fully tender and the roll feels firm and set.";
"recipe.cl_arrollado_huaso.step6.title" = "Simmer until tender";
"recipe.cl_arrollado_huaso.step7.body" = "Lift the roll out and let it cool until safe to handle. Place it on a rimmed tray, cover with another tray or board, and set a pressing weight on top to compact it into a neat shape.";
"recipe.cl_arrollado_huaso.step7.title" = "Cool and press";
"recipe.cl_arrollado_huaso.step8.body" = "Refrigerate under pressure until fully cold and sliceable.";
"recipe.cl_arrollado_huaso.step8.title" = "Chill to set";
"recipe.cl_arrollado_huaso.step9.body" = "Finely chop %i15, %i16, %i17, %i18, and %i19. Stir in %i20, %i21, and the remaining %i9 until juicy and well combined. Chill briefly so the flavors meld.";
"recipe.cl_arrollado_huaso.step9.title" = "Make the pebre";
