"recipe.my_pengat_pisang.drink.body" = "A lightly sweet Moscato dAsti or a light wheat beer pairs gently with the coconut and palm sugar notes. For a non-alcoholic pairing, serve hot ginger tea or unsweetened jasmine tea.";
"recipe.my_pengat_pisang.drink.summary" = "Moscato dAsti";
"recipe.my_pengat_pisang.info" = "Pengat pisang is a traditional Malaysian banana dessert in which ripe bananas are simmered in a sweet coconut milk and palm sugar broth scented with pandan. It is commonly served warm as a dessert or tea-time sweet, with a soft texture and rich caramel-like coconut flavor.";
"recipe.my_pengat_pisang.info.summary" = "Banana coconut dessert";
"recipe.my_pengat_pisang.name" = "Pengat pisang";
"recipe.my_pengat_pisang.step1.body" = "Peel the %i1 and cut them into thick pieces. Tie the %i5 into knots so they are easy to remove later.";
"recipe.my_pengat_pisang.step1.title" = "Prepare bananas and pandan";
"recipe.my_pengat_pisang.step2.body" = "Add %i3, %i4, and pandan leaves to a medium pot and heat gently until the sugar dissolves completely. Stir until the liquid becomes a smooth fragrant syrup.";
"recipe.my_pengat_pisang.step2.title" = "Make palm sugar syrup base";
"recipe.my_pengat_pisang.step3.body" = "Pour in the %i2 and add %i6, then stir gently over low heat. Keep the heat moderate so the coconut mixture stays smooth and does not split.";
"recipe.my_pengat_pisang.step3.title" = "Add coconut milk and salt";
"recipe.my_pengat_pisang.step4.body" = "Add the banana pieces and simmer gently until they soften and the broth thickens slightly. Stir carefully to avoid breaking the bananas.";
"recipe.my_pengat_pisang.step4.title" = "Simmer the bananas";
"recipe.my_pengat_pisang.step5.body" = "Taste and balance the sweetness and salt, then remove the pandan leaves. Let the pengat rest briefly so the flavors settle.";
"recipe.my_pengat_pisang.step5.title" = "Finish and rest briefly";
"recipe.my_pengat_pisang.step6.body" = "Ladle the pengat pisang into bowls and serve warm in the traditional style.";
"recipe.my_pengat_pisang.step6.title" = "Serve";
