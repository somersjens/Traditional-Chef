"recipe.sy_kebab_halabi.drink.body" = "A juicy Grenache or a medium-bodied Syrah stands up to the tomato and Aleppo pepper while matching the lamby richness. For a non-alcoholic option, serve chilled ayran or a pomegranate-lemon spritzer.";
"recipe.sy_kebab_halabi.drink.summary" = "Red wine (Grenache)";
"recipe.sy_kebab_halabi.info" = "Kebab Halabi is an Aleppine-style dish of spiced minced-meat kebabs cooked and then gently simmered in a bold tomato sauce sharpened with pomegranate molasses and Aleppo pepper. It is served hot with vermicelli rice and bread to scoop up the tangy, peppery sauce, making it a classic family meal associated with Aleppo (Halab).";
"recipe.sy_kebab_halabi.info.summary" = "Aleppo kebab stew";
"recipe.sy_kebab_halabi.name" = "Aleppo kebab";
"recipe.sy_kebab_halabi.step1.body" = "Grate the %i2 and mince the %i4. Chop the %i3 very finely. Keep the garlic for the sauce separate from the garlic for the kebabs.";
"recipe.sy_kebab_halabi.step1.title" = "Prep the aromatics";
"recipe.sy_kebab_halabi.step10.body" = "Nestle the cooked kebabs into the simmering sauce and cook gently so they absorb flavor without breaking.";
"recipe.sy_kebab_halabi.step10.title" = "Finish kebabs in the sauce";
"recipe.sy_kebab_halabi.step11.body" = "Spoon the kebabs and sauce over vermicelli rice and serve with %i23 on the side.";
"recipe.sy_kebab_halabi.step11.title" = "Serve";
"recipe.sy_kebab_halabi.step2.body" = "In a bowl, combine the %i1 with grated onion, parsley, minced garlic, %i5, %i6, %i7, and %i8. Mix until cohesive and slightly sticky.";
"recipe.sy_kebab_halabi.step2.title" = "Mix the kebab meat";
