"recipe.tn_lablabi.drink.body" = "A crisp white wine such as Vermentino pairs with the cumin and garlic, while a non-alcoholic option is hot Tunisian mint tea or sparkling water with lemon.";
"recipe.tn_lablabi.drink.summary" = "White wine (Vermentino)";
"recipe.tn_lablabi.info" = "Lablabi is a traditional Tunisian chickpea soup thickened with garlicky cumin broth and soaked bread, finished with olive oil, harissa, and a softly poached egg, and commonly served hot as a hearty breakfast or simple meal with lemon for brightness.";
"recipe.tn_lablabi.info.summary" = "Garlicky chickpea soup";
"recipe.tn_lablabi.name" = "Lablabi";
"recipe.tn_lablabi.step1.body" = "Rinse the %i1, cover with water, and soak until plumped, then drain.";
"recipe.tn_lablabi.step1.title" = "Soak the chickpeas";
"recipe.tn_lablabi.step2.body" = "Chop the %i2 and crush the %i3. Add the chickpeas, onion, garlic, and %i7 to a pot and bring to a gentle simmer.";
"recipe.tn_lablabi.step2.title" = "Start the pot";
"recipe.tn_lablabi.step3.body" = "Cover and simmer until the chickpeas are very tender and the broth is flavorful, skimming any foam as needed.";
"recipe.tn_lablabi.step3.title" = "Cook chickpeas until tender";
"recipe.tn_lablabi.step4.body" = "Stir in %i4, %i5, and %i6 and simmer briefly so the cumin blooms in the hot broth.";
"recipe.tn_lablabi.step4.title" = "Season the broth";
"recipe.tn_lablabi.step5.body" = "Tear or cut the %i8 into small pieces and place into serving bowls, then spoon chickpeas and hot broth over to soak the bread.";
"recipe.tn_lablabi.step5.title" = "Prepare serving bowls";
"recipe.tn_lablabi.step6.body" = "Add %i11 and a drizzle of %i10, then crack in an %i9 and stir so it sets in the hot soup.";
"recipe.tn_lablabi.step6.title" = "Finish each bowl";
"recipe.tn_lablabi.step7.body" = "Serve immediately with %i12 for squeezing over each bowl.";
"recipe.tn_lablabi.step7.title" = "Serve with lemon";
