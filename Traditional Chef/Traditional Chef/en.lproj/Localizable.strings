"recipe.ru_kulebyaka.drink.body" = "A crisp, high-acid white such as dry Riesling or a mineral Sauvignon Blanc pairs well with the rich pastry and delicate fish filling. Sparkling wine also works for celebrations. Non-alcoholic pairing: hot black tea with lemon or sparkling water.";
"recipe.ru_kulebyaka.drink.summary" = "White wine (Riesling)";
"recipe.ru_kulebyaka.info" = "Kulebyaka is a traditional Russian festive pie made with a rich yeasted dough wrapped around layered fillings, most classically fish with rice, mushrooms, onions, dill, and hard-boiled eggs. The pie is baked until golden, then sliced to reveal distinct layers, and is often served with warm clear fish stock alongside to sip or spoon over each slice.";
"recipe.ru_kulebyaka.info.summary" = "Layered festive fish pie";
"recipe.ru_kulebyaka.name" = "Kulebyaka";
"recipe.ru_kulebyaka.step1.body" = "Warm %i2 until just lukewarm. Stir in %i4 and %i5 and let it stand until foamy.";
"recipe.ru_kulebyaka.step1.title" = "Activate yeast";
"recipe.ru_kulebyaka.step10.body" = "Cover and let the pie rise until slightly puffy.";
"recipe.ru_kulebyaka.step10.title" = "Final proof";
"recipe.ru_kulebyaka.step11.body" = "Brush the top with beaten %i19 and bake until deeply golden and the pie feels firm and baked through.";
"recipe.ru_kulebyaka.step11.title" = "Bake";
"recipe.ru_kulebyaka.step12.body" = "Rest the baked pie on a rack so the layers set and slices hold cleanly.";
"recipe.ru_kulebyaka.step12.title" = "Rest";
"recipe.ru_kulebyaka.step13.body" = "Warm %i17 and serve slices of kulebyaka with the hot stock alongside.";
"recipe.ru_kulebyaka.step13.title" = "Serve with stock";
"recipe.ru_kulebyaka.step2.body" = "Combine %i1 and %i6 in a bowl. Add the yeast mixture, %i7, and softened %i3, then knead until smooth and elastic.";
"recipe.ru_kulebyaka.step2.title" = "Mix and knead dough";
"recipe.ru_kulebyaka.step3.body" = "Cover the dough and let it rise until doubled in size.";
"recipe.ru_kulebyaka.step3.title" = "First rise";
"recipe.ru_kulebyaka.step4.body" = "Rinse %i9 and simmer it in %i18 until tender and fairly dry, then cool.";
"recipe.ru_kulebyaka.step4.title" = "Cook the rice";
"recipe.ru_kulebyaka.step5.body" = "Chop %i11 and slice %i10. Melt %i12 in a skillet and cook onion until soft, add mushrooms, and cook until their moisture evaporates and the mixture is deeply savory. Season with %i16 and %i15 and cool.";
"recipe.ru_kulebyaka.step5.title" = "Cook mushrooms and onions";
"recipe.ru_kulebyaka.step6.body" = "Boil %i14 until hard-set, cool, peel, and chop.";
"recipe.ru_kulebyaka.step6.title" = "Hard-boil the eggs";
"recipe.ru_kulebyaka.step7.body" = "Cut %i8 into pieces suitable for layering. Chop %i13 and season the fish lightly.";
"recipe.ru_kulebyaka.step7.title" = "Prepare fish and herbs";
"recipe.ru_kulebyaka.step8.body" = "Punch down the dough and roll it into a rectangle on parchment. Lay down a bed of rice, then the mushroom-onion mixture, then salmon, then chopped eggs, sprinkling dill between layers.";
"recipe.ru_kulebyaka.step8.title" = "Roll and layer";
"recipe.ru_kulebyaka.step9.body" = "Fold the dough over the filling to enclose it fully, pinch seams well, and turn seam-side down on the baking sheet. Make a few small vents on top.";
"recipe.ru_kulebyaka.step9.title" = "Seal the kulebyaka";
