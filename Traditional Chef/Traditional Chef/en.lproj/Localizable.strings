"recipe.az_lavangi.drink.body" = "A dry white wine such as Chardonnay or a light Pinot Noir pairs well with the sweet-sour walnut stuffing and roasted chicken. A light amber lager also works. For a non-alcoholic pairing, serve strong black tea or tart pomegranate sherbet.";
"recipe.az_lavangi.drink.summary" = "White wine (Chardonnay)";
"recipe.az_lavangi.info" = "Azerbaijani lavangi is a traditional Talysh and southern Azerbaijani dish of whole chicken stuffed with a rich mixture of onions walnuts and sour pomegranate seasoning, then roasted until deeply browned and fragrant. It is a festive main course associated with family gatherings and holiday tables, especially in the Lankaran region.";
"recipe.az_lavangi.info.summary" = "Walnut-stuffed chicken";
"recipe.az_lavangi.name" = "Lavangi";
"recipe.az_lavangi.step1.body" = "Clean and dry %i1 well. Season it inside and out with part of %i5 and set it aside.";
"recipe.az_lavangi.step1.title" = "Prepare the chicken";
"recipe.az_lavangi.step2.body" = "Finely grate %i2 and squeeze out the excess juice. Grind %i3, then mix them with %i2, %i4, the remaining %i5, %i6, %i7, and part of %i8 until thick and aromatic.";
"recipe.az_lavangi.step2.title" = "Make the stuffing";
"recipe.az_lavangi.step3.body" = "Fill the chicken cavity firmly with the walnut mixture and secure the opening with kitchen twine so the stuffing stays inside during roasting.";
"recipe.az_lavangi.step3.title" = "Stuff the chicken";
"recipe.az_lavangi.step4.body" = "Rub the outside of the chicken with the remaining %i9 and place it in a roasting pan breast side up.";
"recipe.az_lavangi.step4.title" = "Prepare for roasting";
"recipe.az_lavangi.step5.body" = "Roast the chicken until the skin is deeply browned and the meat is fully cooked through, basting once or twice with the pan juices as it cooks.";
"recipe.az_lavangi.step5.title" = "Roast the lavangi";
"recipe.az_lavangi.step6.body" = "Remove the lavangi from the oven and let it rest so the juices settle and the stuffing firms slightly for carving.";
"recipe.az_lavangi.step6.title" = "Rest the chicken";
"recipe.az_lavangi.step7.body" = "Warm %i10 until soft and ready for serving.";
"recipe.az_lavangi.step7.title" = "Warm the bread";
"recipe.az_lavangi.step8.body" = "Transfer the chicken to a large platter, carve it into serving pieces, and spoon some of the stuffing alongside. Serve hot with the warm flatbread.";
"recipe.az_lavangi.step8.title" = "Serve the lavangi";
