"recipe.pt_pudim_abade_de_priscos.drink.body" = "A small glass of tawny Port echoes the pudding’s own aroma of caramel and spice, while a lightly sweet Moscatel also pairs well. Non-alcoholic pairing: espresso or strong black coffee, or sparkling water to cut the richness.";
"recipe.pt_pudim_abade_de_priscos.drink.summary" = "Tawny Port";
"recipe.pt_pudim_abade_de_priscos.info" = "Pudim Abade de Priscos is a famed Portuguese caramel flan from the Braga region, enriched with many egg yolks and scented with lemon peel and cinnamon, with an unmistakable touch of pork fat that perfumes the syrup. The custard is baked gently in a bain-marie in a caramel-lined mold, then chilled and unmolded so the caramel coats each slice.";
"recipe.pt_pudim_abade_de_priscos.info.summary" = "Braga caramel flan";
"recipe.pt_pudim_abade_de_priscos.name" = "Abbot of Priscos pudding";
"recipe.pt_pudim_abade_de_priscos.step1.body" = "Set the mold nearby and have a roasting pan ready for a bain-marie. Preheat the oven.";
"recipe.pt_pudim_abade_de_priscos.step1.title" = "Prepare the mold";
"recipe.pt_pudim_abade_de_priscos.step10.body" = "Run a thin knife around the edge, invert onto a plate, let the caramel flow over the pudding, and slice to serve.";
"recipe.pt_pudim_abade_de_priscos.step10.title" = "Unmold and serve";
"recipe.pt_pudim_abade_de_priscos.step2.body" = "Cook %i1 with a little %i2 until it turns amber. Carefully loosen with a small splash of water, then pour into the mold and swirl to coat the base and sides.";
"recipe.pt_pudim_abade_de_priscos.step2.title" = "Make the caramel";
"recipe.pt_pudim_abade_de_priscos.step3.body" = "Boil %i3 with %i4, %i5, %i6 peel, and %i7, cooking until the syrup reaches a thin-thread stage.";
"recipe.pt_pudim_abade_de_priscos.step3.title" = "Cook the flavored syrup";
"recipe.pt_pudim_abade_de_priscos.step4.body" = "Strain the syrup to remove the solids and let it cool slightly so it is hot but not boiling.";
"recipe.pt_pudim_abade_de_priscos.step4.title" = "Cool and strain";
"recipe.pt_pudim_abade_de_priscos.step5.body" = "Whisk %i8 with %i9 until smooth without whipping in much air.";
"recipe.pt_pudim_abade_de_priscos.step5.title" = "Prepare yolks and port";
"recipe.pt_pudim_abade_de_priscos.step6.body" = "Whisk the warm syrup into the yolk mixture in a steady stream until fully combined, then strain again for a perfectly smooth custard.";
"recipe.pt_pudim_abade_de_priscos.step6.title" = "Combine custard";
"recipe.pt_pudim_abade_de_priscos.step7.body" = "Pour the custard into the caramel-lined mold, close the lid, and place the mold in the roasting pan.";
"recipe.pt_pudim_abade_de_priscos.step7.title" = "Fill and cover";
"recipe.pt_pudim_abade_de_priscos.step8.body" = "Add hot %i10 to the roasting pan to come partway up the mold, then bake until the custard is set with a slight wobble.";
"recipe.pt_pudim_abade_de_priscos.step8.title" = "Bake in bain marie";
"recipe.pt_pudim_abade_de_priscos.step9.body" = "Remove the mold from the bain-marie, cool to room temperature, then refrigerate until fully chilled and firm.";
"recipe.pt_pudim_abade_de_priscos.step9.title" = "Chill thoroughly";
