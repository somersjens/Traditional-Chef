"recipe.be_tarte_al_djote.drink.body" = "Pair with a dark Belgian monastery-style beer or a malty brown ale that stands up to the rich butter and tangy cheese. A full-bodied red such as Burgundy-style Pinot Noir is also a classic match. For a non-alcoholic option, serve sparkling water or a malty alcohol-free beer.";
"recipe.be_tarte_al_djote.drink.summary" = "Beer (Belgian)";
"recipe.be_tarte_al_djote.info" = "Tarte al djote is the famed savory tart from Nivelles in Wallonia, built on a soft, lightly yeasted pastry and filled with Swiss chard, onions, and the traditional local fermented boulette-style curd cheese, enriched generously with butter and egg. It is baked hot so the crust sets while the filling stays tender and creamy, then served immediately, often with extra salted butter melting on top.";
"recipe.be_tarte_al_djote.info.summary" = "Nivelles savory tart";
"recipe.be_tarte_al_djote.name" = "Tarte al djote";
