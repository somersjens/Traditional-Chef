"recipe.ph_sisig.step11.body" = "Heat the remaining oil in a pan, saute most of the diced onion briefly, then add the sisig mixture and cook while stirring until hot and well combined.";
"recipe.ph_sisig.step11.title" = "Saute and sizzle";
"recipe.ph_sisig.step12.body" = "Heat the sizzling plate, add the %i16, then transfer the sisig onto it and top with the remaining diced onion so it sizzles on contact.";
"recipe.ph_sisig.step12.title" = "Finish on hot plate";
"recipe.ph_sisig.step13.body" = "Serve the hot sisig immediately on the sizzling plate with steamed rice.";
"recipe.ph_sisig.step13.title" = "Serve";
"recipe.ph_sisig.step2.body" = "Place the pork jowl and ears in a pot with %i3, the quartered onion, garlic, bay leaves, peppercorns, and %i8. Bring to a boil, skim as needed, then simmer until tender.";
"recipe.ph_sisig.step2.title" = "Boil pork cuts";
"recipe.ph_sisig.step3.body" = "Lift out the pork cuts, drain well, and let them cool enough to handle while preparing the grill.";
"recipe.ph_sisig.step3.title" = "Drain and cool pork";
"recipe.ph_sisig.step4.body" = "Rinse the %i17 until the water runs mostly clear, then drain.";
"recipe.ph_sisig.step4.title" = "Wash rice";
"recipe.ph_sisig.step5.body" = "Place the rice in a saucepan with %i18, bring to a boil, cover, and cook gently until the rice is tender and the water is absorbed.";
"recipe.ph_sisig.step5.title" = "Cook rice";
"recipe.ph_sisig.step6.body" = "Turn off the heat and let the covered rice rest, then fluff before serving.";
"recipe.ph_sisig.step6.title" = "Rest rice";
"recipe.ph_sisig.step7.body" = "Grill the boiled pork jowl and ears until the surfaces are browned and lightly charred, turning to color evenly.";
"recipe.ph_sisig.step7.title" = "Grill pork cuts";
"recipe.ph_sisig.step8.body" = "Heat part of the %i10 in a pan and cook the %i9 until just cooked through, then remove and let it cool slightly.";
"recipe.ph_sisig.step8.title" = "Cook liver";
"recipe.ph_sisig.step9.body" = "Finely chop the grilled pork jowl, pork ears, and cooked liver. Finely dice the %i11 and slice the %i14.";
"recipe.ph_sisig.step9.title" = "Chop sisig components";
