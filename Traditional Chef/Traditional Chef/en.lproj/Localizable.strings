"recipe.dz_griwech.step2.title" = "Make the dough";
"recipe.dz_griwech.step3.body" = "Cover the dough and let it rest so it relaxes for shaping.";
"recipe.dz_griwech.step3.title" = "Rest the dough";
"recipe.dz_griwech.step4.body" = "Roll the dough thin, cut into rectangles, and slit each piece to braid into traditional knotted shapes, pressing ends to seal.";
"recipe.dz_griwech.step4.title" = "Shape the griwech";
"recipe.dz_griwech.step5.body" = "Heat %i10 with water and %i12 juice until hot and fluid, then keep warm for dipping.";
"recipe.dz_griwech.step5.title" = "Warm the honey syrup";
"recipe.dz_griwech.step6.body" = "Heat %i13 and fry the pastries in batches, turning until evenly golden and crisp. Drain briefly.";
"recipe.dz_griwech.step6.title" = "Fry until golden";
"recipe.dz_griwech.step7.body" = "Dip the hot pastries into the warm honey syrup so they absorb and glaze, then lift out and let excess drip off.";
"recipe.dz_griwech.step7.title" = "Dip in honey";
"recipe.dz_griwech.step8.body" = "Place on a rack to set until the glaze is no longer runny and the pastries cool.";
"recipe.dz_griwech.step8.title" = "Set and cool";
"recipe.dz_griwech.step9.body" = "Arrange on a plate and serve with mint tea or coffee.";
"recipe.dz_griwech.step9.title" = "Serve";
