"recipe.tr_icli_kofte.step6.title" = "Heat the frying oil";
"recipe.tr_icli_kofte.step7.body" = "Fry the filled köfte in batches until deep golden and crisp, turning gently, then drain on paper towels.";
"recipe.tr_icli_kofte.step7.title" = "Fry the köfte";
"recipe.tr_icli_kofte.step8.body" = "Serve hot with %i16 wedges for squeezing over each piece.";
