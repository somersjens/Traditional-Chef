"recipe.ma_harira.drink.body" = "A medium-bodied red such as Grenache pairs with the tomato base and warm spices without overpowering the soup. For a non-alcoholic option, serve Moroccan mint tea or sparkling water with lemon.";
"recipe.ma_harira.drink.summary" = "Red wine (Grenache)";
"recipe.ma_harira.info" = "Harira is Morocco’s traditional tomato-based soup simmered with lamb, chickpeas, lentils, and warm spices, finished with a flour thickener and a delicate ribbon of egg and lemon for body and fragrance. It is famously served during Ramadan to break the fast, and is also enjoyed year-round as a nourishing starter, typically accompanied by Moroccan khobz for dipping and scooping.";
"recipe.ma_harira.info.summary" = "Ramadan harira bowl";
"recipe.ma_harira.name" = "Harira";
"recipe.ma_harira.step1.body" = "Rinse the %i1 and cover with %i2. Leave to soak until fully hydrated, then drain.";
"recipe.ma_harira.step1.title" = "Soak chickpeas";
"recipe.ma_harira.step10.body" = "Bake the loaves until well risen and browned. Remove and let cool slightly before serving.";
"recipe.ma_harira.step10.title" = "Bake the bread";
"recipe.ma_harira.step11.body" = "Whisk %i18 with %i19 until completely smooth, then pass through a fine-mesh sieve so there are no lumps.";
"recipe.ma_harira.step11.title" = "Make tadouira";
"recipe.ma_harira.step12.body" = "With the soup gently simmering, whisk in the tadouira in a steady stream, stirring continuously until the soup thickens and looks silky.";
"recipe.ma_harira.step12.title" = "Thicken the soup";
"recipe.ma_harira.step13.body" = "Add the %i11 and simmer until tender, stirring so it does not clump or stick.";
"recipe.ma_harira.step13.title" = "Cook vermicelli";
"recipe.ma_harira.step14.body" = "Whisk the %i20 with %i21. With the soup at a gentle simmer, pour in the egg mixture in a thin stream while stirring to form delicate threads, then stir in chopped cilantro.";
"recipe.ma_harira.step14.title" = "Finish with egg and lemon";
"recipe.ma_harira.step15.body" = "Ladle harira into bowls and serve with khobz and %i23 wedges for squeezing at the table.";
"recipe.ma_harira.step15.title" = "Serve with khobz and lemon";
"recipe.ma_harira.step2.body" = "Cut the %i4 into small pieces. Finely chop the %i5 and %i6, mince the %i7, chop the %i22, and crush the %i8 to a pulp.";
"recipe.ma_harira.step2.title" = "Prep soup ingredients";
"recipe.ma_harira.step3.body" = "Heat %i3 in a large pot over medium heat. Add onion and celery and cook until softened, then add garlic and stir until fragrant.";
"recipe.ma_harira.step3.title" = "Start the base";
"recipe.ma_harira.step4.body" = "Stir in %i12, %i13, %i14, and %i15. Add tomatoes and %i9 and cook until the mixture turns glossy and thick.";
"recipe.ma_harira.step4.title" = "Bloom spices and tomato";
"recipe.ma_harira.step5.body" = "Add lamb and soaked chickpeas, stir to coat, then add %i17 and %i16. Bring to a gentle simmer, cover, and cook until the lamb and chickpeas are becoming tender.";
"recipe.ma_harira.step5.title" = "Simmer lamb and chickpeas";
"recipe.ma_harira.step6.body" = "In a bowl, mix %i24, %i25, and %i26. Add %i27 and knead until smooth and elastic, then cover with a towel.";
"recipe.ma_harira.step6.title" = "Start khobz dough";
"recipe.ma_harira.step7.body" = "Leave the dough covered in a warm spot until clearly risen and airy.";
"recipe.ma_harira.step7.title" = "Rise the dough";
"recipe.ma_harira.step8.body" = "Rinse the %i10 and add them to the simmering soup. Continue cooking at a steady simmer until the lentils are tender.";
"recipe.ma_harira.step8.title" = "Add lentils";
"recipe.ma_harira.step9.body" = "Punch down the dough, shape into round loaves on a baking sheet, cover, and let them relax while the oven heats.";
"recipe.ma_harira.step9.title" = "Shape khobz and preheat oven";
