"recipe.sk_kapustnica.drink.body" = "A fresh white wine such as Riesling pairs well with the soup’s smoky, sour, and earthy flavors. A pale lager also works very well. For a non-alcoholic option, serve sparkling water or hot black tea.";
"recipe.sk_kapustnica.drink.summary" = "White wine (Riesling)";
"recipe.sk_kapustnica.info" = "Kapustnica is a traditional Slovak sauerkraut soup, especially associated with Christmas and other winter family gatherings. The classic rich version combines sauerkraut, smoked meat, smoked sausage, dried mushrooms, potatoes, paprika, and sour cream into a deeply savory and slightly tangy soup that is served hot with rye bread.";
"recipe.sk_kapustnica.info.summary" = "Sauerkraut mushroom soup";
"recipe.sk_kapustnica.name" = "Kapustnica";
