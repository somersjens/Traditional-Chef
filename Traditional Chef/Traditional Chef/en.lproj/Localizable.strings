"recipe.pl_kielbasa_z_kapusta.drink.body" = "Pair with a crisp dry white wine such as Riesling or Grüner Veltliner to balance the sauerkraut’s tang and the kielbasa’s smoke. A clean Polish-style lager also works well. Non-alcoholic option: hot black tea or sparkling water with lemon.";
"recipe.pl_kielbasa_z_kapusta.drink.summary" = "White wine (Riesling)";
"recipe.pl_kielbasa_z_kapusta.info" = "Kiełbasa z kapustą is a classic Polish one-pot dish of sauerkraut and fresh cabbage slowly braised with onion and smoky sausage until tender and deeply savory, with bay, allspice, and caraway tying the flavors together. It is served hot as a simple, comforting home meal, traditionally alongside boiled potatoes that soak up the tangy, sausage-scented juices.";
"recipe.pl_kielbasa_z_kapusta.info.summary" = "Smoky sausage cabbage pot";
"recipe.pl_kielbasa_z_kapusta.name" = "Kielbasa and cabbage";
"recipe.pl_kielbasa_z_kapusta.step1.body" = "Slice the %i3 into thick rounds. Shred the %i2. Peel and slice the %i4. If the %i1 strands are long, chop them shorter.";
"recipe.pl_kielbasa_z_kapusta.step1.title" = "Prepare ingredients";
"recipe.pl_kielbasa_z_kapusta.step2.body" = "Heat the pot with %i5, add kielbasa, and brown lightly. Add onion and cook until softened and starting to turn golden.";
"recipe.pl_kielbasa_z_kapusta.step2.title" = "Brown kielbasa and onion";
"recipe.pl_kielbasa_z_kapusta.step3.body" = "Stir in fresh cabbage and cook until it begins to wilt. Add sauerkraut and mix thoroughly so the sausage and cabbage are evenly combined.";
"recipe.pl_kielbasa_z_kapusta.step3.title" = "Add cabbage and sauerkraut";
"recipe.pl_kielbasa_z_kapusta.step4.body" = "Add %i6, %i7, %i8, %i9, and %i10. Pour in %i11 and bring to a gentle simmer.";
"recipe.pl_kielbasa_z_kapusta.step4.title" = "Season and moisten";
"recipe.pl_kielbasa_z_kapusta.step5.body" = "Cover partially and braise gently, stirring from time to time so it does not catch, until the cabbage is tender and the flavors are well merged.";
"recipe.pl_kielbasa_z_kapusta.step5.title" = "Braise until tender";
"recipe.pl_kielbasa_z_kapusta.step6.body" = "Peel the %i12, cut into even pieces, cover with %i13 in a pot, add %i14, and bring to a gentle boil.";
"recipe.pl_kielbasa_z_kapusta.step6.title" = "Start the potatoes";
"recipe.pl_kielbasa_z_kapusta.step7.body" = "Simmer until the potatoes are tender, then drain well and keep warm.";
"recipe.pl_kielbasa_z_kapusta.step7.title" = "Cook potatoes until tender";
"recipe.pl_kielbasa_z_kapusta.step8.body" = "Taste the cabbage and adjust seasoning. Serve hot with boiled potatoes alongside.";
"recipe.pl_kielbasa_z_kapusta.step8.title" = "Serve";
