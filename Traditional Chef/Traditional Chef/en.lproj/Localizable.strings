"recipe.sr_pepre_watra.drink.body" = "Serve with a light dry white wine or a very mild lager that will not overpower the spicy broth. For a non-alcoholic option, serve hot tea or chilled ginger drink.";
"recipe.sr_pepre_watra.drink.summary" = "White wine";
"recipe.sr_pepre_watra.info" = "Pepre watra is a traditional Surinamese fish soup, especially associated with Indigenous cooking, built from fish simmered in a light but fiery broth with pepper, tomato, onion, celery, and warm spices. It is served hot as a simple, restorative meal and is classically accompanied by cassava bread.";
"recipe.sr_pepre_watra.info.summary" = "Spicy fish soup";
"recipe.sr_pepre_watra.name" = "Pepre watra";
