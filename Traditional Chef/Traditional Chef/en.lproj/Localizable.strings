"recipe.mm_nangyi_thoke.drink.body" = "Nangyi thoke is traditionally served with Burmese tea rather than wine. If serving wine, a light aromatic white can work with the savory spicy dressing. Non-alcoholic pairing: hot Burmese green tea or lime soda.";
"recipe.mm_nangyi_thoke.drink.summary" = "Green tea";
"recipe.mm_nangyi_thoke.info" = "Nangyi thoke is a traditional Myanmar thick rice noodle salad mixed with a rich chicken curry gravy, chickpea flour, chili oil, and fresh garnishes. It is commonly served as a substantial breakfast or lunch, with boiled egg, lime, and herbs added just before eating.";
"recipe.mm_nangyi_thoke.info.summary" = "Thick noodle salad";
"recipe.mm_nangyi_thoke.name" = "Nangyi thoke";
