"recipe.jp_zenzai.drink.body" = "Sencha or hojicha pairs well with the sweet beans and toasted mochi. For a non-alcoholic pairing, serve hot roasted barley tea or unsweetened green tea.";
"recipe.jp_zenzai.drink.summary" = "Green tea (Sencha)";
"recipe.jp_zenzai.info" = "Zenzai is a traditional Japanese sweet dessert soup of simmered azuki beans and sugar, typically served warm with toasted mochi. It is commonly enjoyed in winter and at tea shops or home as a comforting wagashi-style dessert, often in small bowls with a lightly salted finish to balance the sweetness.";
"recipe.jp_zenzai.info.summary" = "Warm red bean soup";
"recipe.jp_zenzai.name" = "Zenzai";
"recipe.jp_zenzai.step1.body" = "Rinse the %i1 well and check for any debris before cooking.";
"recipe.jp_zenzai.step1.title" = "Rinse the azuki beans";
"recipe.jp_zenzai.step2.body" = "Place the beans in a pot with %i2, bring to a boil briefly, then drain to remove harshness and start a cleaner sweet soup.";
"recipe.jp_zenzai.step2.title" = "Parboil the beans";
"recipe.jp_zenzai.step3.body" = "Return the beans to the pot with fresh water and simmer gently until the beans are tender and beginning to split, adding a little water if needed to keep them covered.";
"recipe.jp_zenzai.step3.title" = "Simmer until tender";
"recipe.jp_zenzai.step4.body" = "Add the %i3 in portions and stir gently so the beans keep their shape, then add %i4 and simmer until the soup is glossy and slightly thickened.";
"recipe.jp_zenzai.step4.title" = "Sweeten the zenzai";
"recipe.jp_zenzai.step5.body" = "Toast the %i5 until puffed and lightly browned, turning as needed so it heats evenly.";
"recipe.jp_zenzai.step5.title" = "Toast the mochi";
"recipe.jp_zenzai.step6.body" = "Warm the zenzai gently and add a little water if needed so it is thick but spoonable.";
"recipe.jp_zenzai.step6.title" = "Warm and adjust consistency";
"recipe.jp_zenzai.step7.body" = "Place toasted mochi in serving bowls, ladle the hot sweet azuki soup over, and serve immediately.";
"recipe.jp_zenzai.step7.title" = "Serve hot";
