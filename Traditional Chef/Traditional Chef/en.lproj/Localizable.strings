"recipe.gr_gemista.drink.body" = "Pair with a dry Greek rosé or a light red such as Agiorgitiko served slightly cool to match baked vegetables and herbs. A light lager also works well. For a non-alcoholic option, serve sparkling water with lemon or a chilled herbal iced tea.";
"recipe.gr_gemista.drink.summary" = "Rosé wine";
"recipe.gr_gemista.info" = "Gemista are traditional Greek tomatoes and peppers stuffed with a fragrant rice-and-herb mixture, baked slowly with potatoes until the vegetables collapse tenderly and the rice is cooked through in the juices. The dish relies on ripe summer vegetables, plenty of olive oil, and fresh herbs, and it is served warm or at room temperature, often with feta and bread to capture the pan juices.";
"recipe.gr_gemista.info.summary" = "Summer stuffed vegetables";
"recipe.gr_gemista.name" = "Gemista";
