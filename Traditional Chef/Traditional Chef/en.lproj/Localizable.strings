"recipe.ar_empanadas.step7.title" = "Make salsa criolla";
"recipe.ar_empanadas.step8.body" = "Preheat the oven and set a baking sheet ready so empanadas can go straight in once formed.";
"recipe.ar_empanadas.step8.title" = "Preheat oven and prepare tray";
