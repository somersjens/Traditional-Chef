"recipe.vn_banh_da_lon.step8.body" = "Stir the mung bean batter, pour a thin layer over the set pandan layer, and steam until set.";
"recipe.vn_banh_da_lon.step8.title" = "Steam second layer";
"recipe.vn_banh_da_lon.step9.body" = "Continue alternating thin pandan and mung bean layers, steaming each layer until set before adding the next, and finish with a pandan layer on top.";
