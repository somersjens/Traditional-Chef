"recipe.ph_chicken_inasal.drink.body" = "An aromatic white wine such as Riesling or Gewurztraminer pairs well with the smoky grilled chicken and tangy marinade. A pale lager is also a classic match. For a non-alcoholic option, serve calamansi juice or iced tea.";
"recipe.ph_chicken_inasal.drink.summary" = "White wine (Riesling)";
"recipe.ph_chicken_inasal.info" = "Chicken inasal is a traditional Filipino grilled chicken dish from Bacolod, marinated with vinegar, calamansi, lemongrass, garlic, and ginger, then basted with annatto oil while grilling. It is commonly served hot with rice and a sharp soy-vinegar-calamansi dipping sauce at family meals and grill houses.";
"recipe.ph_chicken_inasal.info.summary" = "Bacolod grilled chicken";
"recipe.ph_chicken_inasal.name" = "Chicken inasal";
"recipe.ph_chicken_inasal.step1.body" = "Bruise and finely chop the %i4, mince the %i5, and grate the %i6. Score the %i1 so the marinade penetrates well.";
"recipe.ph_chicken_inasal.step1.title" = "Prepare aromatics and chicken";
"recipe.ph_chicken_inasal.step10.body" = "Place the chicken on the grill and cook while turning regularly, basting often with the annatto oil so the skin colors and the meat cooks evenly.";
"recipe.ph_chicken_inasal.step10.title" = "Grill and baste chicken";
"recipe.ph_chicken_inasal.step11.body" = "Transfer the chicken off the heat and let it rest briefly so the juices settle.";
"recipe.ph_chicken_inasal.step11.title" = "Rest grilled chicken";
"recipe.ph_chicken_inasal.step12.body" = "Serve the chicken inasal hot with steamed rice and the dipping sauce on the side.";
"recipe.ph_chicken_inasal.step12.title" = "Serve";
"recipe.ph_chicken_inasal.step2.body" = "In a mixing bowl, combine %i2, %i3, lemongrass, garlic, ginger, %i7, %i8, %i9, and a little salt.";
"recipe.ph_chicken_inasal.step2.title" = "Make marinade";
"recipe.ph_chicken_inasal.step3.body" = "Coat the chicken thoroughly in the marinade and leave it to marinate, turning once during the resting time.";
"recipe.ph_chicken_inasal.step3.title" = "Marinate chicken";
"recipe.ph_chicken_inasal.step4.body" = "Gently heat %i10 with %i11 until the oil turns orange-red, then strain and mix with %i12 and %i13.";
"recipe.ph_chicken_inasal.step4.title" = "Make annatto basting oil";
"recipe.ph_chicken_inasal.step5.body" = "Combine %i14, %i15, %i16, and sliced %i17 in a small bowl and set aside.";
"recipe.ph_chicken_inasal.step5.title" = "Prepare dipping sauce";
"recipe.ph_chicken_inasal.step6.body" = "Rinse the %i18 until the water runs mostly clear, then drain.";
"recipe.ph_chicken_inasal.step6.title" = "Wash rice";
"recipe.ph_chicken_inasal.step7.body" = "Place the rice in a saucepan with %i19, bring to a boil, cover, and cook gently until the rice is tender and the water is absorbed.";
"recipe.ph_chicken_inasal.step7.title" = "Cook rice";
"recipe.ph_chicken_inasal.step8.body" = "Turn off the heat and let the covered rice rest, then fluff before serving.";
"recipe.ph_chicken_inasal.step8.title" = "Rest rice";
"recipe.ph_chicken_inasal.step9.body" = "Prepare a medium charcoal fire or preheat the grill so it is hot enough to sear without burning the chicken.";
