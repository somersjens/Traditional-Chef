"recipe.ge_chakapuli.drink.body" = "A crisp dry white wine such as Georgian Tsolikouri or Rkatsiteli complements the herbs and sour plum notes in chakapuli. A light wheat beer can also work. For a non-alcoholic option, serve sparkling water with lemon or chilled unsweetened tarragon tea.";
"recipe.ge_chakapuli.drink.summary" = "White wine (Tsolikouri)";
"recipe.ge_chakapuli.info" = "Chakapuli is a traditional Georgian spring stew, most often made with lamb and abundant fresh herbs, especially tarragon, then soured with green plums or tkemali. It is served hot as a main dish, commonly at family meals and festive tables, with bread to soak up the aromatic broth.";
"recipe.ge_chakapuli.info.summary" = "Spring herb lamb stew";
"recipe.ge_chakapuli.name" = "Chakapuli";
"recipe.ge_chakapuli.step1.body" = "Cut the %i1 into serving pieces. Slice the %i2 and %i4, mince the %i3, and roughly chop the %i5, %i6, %i7, and %i8. Wash and halve the %i9.";
"recipe.ge_chakapuli.step1.title" = "Prepare the ingredients";
"recipe.ge_chakapuli.step2.body" = "Place the lamb and onion in the pot, season with %i12 and %i13, and add half of the spring onions and half of each chopped herb.";
"recipe.ge_chakapuli.step2.title" = "Layer the base";
"recipe.ge_chakapuli.step3.body" = "Add the green plums and garlic, then pour in %i10 and %i11.";
"recipe.ge_chakapuli.step3.title" = "Add souring and liquid";
"recipe.ge_chakapuli.step4.body" = "Cover and simmer gently until the lamb is tender and the plums soften into the broth.";
"recipe.ge_chakapuli.step4.title" = "Simmer the stew";
"recipe.ge_chakapuli.step5.body" = "Add the remaining spring onions and remaining herbs, stir gently, and taste for salt.";
"recipe.ge_chakapuli.step5.title" = "Add remaining herbs";
"recipe.ge_chakapuli.step6.body" = "Cover and simmer briefly so the fresh herbs perfume the stew without losing their color.";
"recipe.ge_chakapuli.step6.title" = "Finish the chakapuli";
"recipe.ge_chakapuli.step7.body" = "Ladle the chakapuli into bowls with broth and tender lamb pieces, and serve immediately with %i14.";
"recipe.ge_chakapuli.step7.title" = "Serve hot";
"recipe.ge_chakapuli.tool.t1" = "Large pot";
"recipe.ge_chakapuli.tool.t2" = "Knife";
"recipe.ge_chakapuli.tool.t3" = "Cutting board";
"recipe.ge_chakapuli.tool.t4" = "Wooden spoon";
"recipe.ge_chakapuli.tool.t5" = "Lid";
"recipe.ge_chakapuli.tool.t6" = "Ladle";
"recipe.ge_chakhokhbili.drink.body" = "A light to medium-bodied dry red wine such as Saperavi or a fresh red blend pairs well with the tomato and herbs. A pale lager also works. For a non-alcoholic option, serve sparkling water with lemon or chilled unsweetened black tea.";
"recipe.ge_chakhokhbili.drink.summary" = "Red wine (Saperavi)";
"recipe.ge_chakhokhbili.info" = "Chakhokhbili is a traditional Georgian chicken stew cooked with onions, tomatoes, garlic, and fresh herbs until rich and fragrant. It is served hot as a main dish at family meals and festive tables, often with bread to soak up the sauce.";
"recipe.ge_chakhokhbili.info.summary" = "Tomato chicken stew";
"recipe.ge_chakhokhbili.name" = "Chakhokhbili";
"recipe.ge_chakhokhbili.step1.body" = "Cut the %i2 into thin slices, mince the %i4, and chop the %i5, %i6, %i7, and %i8. Score the %i3, blanch briefly, peel, and chop them.";
"recipe.ge_chakhokhbili.step1.title" = "Prepare the ingredients";
"recipe.ge_chakhokhbili.step2.body" = "Heat the pot and add the %i1 skin-side down. Cook until the fat renders and the pieces lightly brown on both sides, then remove them to a plate.";
"recipe.ge_chakhokhbili.step2.title" = "Render and brown the chicken";
"recipe.ge_chakhokhbili.step3.body" = "Add %i12 to the pot and cook the onions in the chicken fat until soft and lightly golden, stirring regularly.";
"recipe.ge_chakhokhbili.step3.title" = "Soften the onions";
"recipe.ge_chakhokhbili.step4.body" = "Return the chicken to the pot, add the tomatoes, garlic, %i9, %i10, and %i11, and stir to combine.";
"recipe.ge_chakhokhbili.step4.title" = "Build the stew base";
"recipe.ge_chakhokhbili.step5.body" = "Add %i13, cover, and simmer gently until the chicken is tender and the tomato-onion mixture becomes a thick sauce.";
"recipe.ge_chakhokhbili.step5.title" = "Simmer until tender";
"recipe.ge_chakhokhbili.step6.body" = "Add the chopped herbs, stir gently, and taste to adjust seasoning.";
