"recipe.au_sticky_date_pudding.step3.title" = "Fill the tin";
"recipe.au_sticky_date_pudding.step4.body" = "Bake until the pudding is risen, deep golden, and cooked through in the centre.";
"recipe.au_sticky_date_pudding.step4.title" = "Bake the pudding";
