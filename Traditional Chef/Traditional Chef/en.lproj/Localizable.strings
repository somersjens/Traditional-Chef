"recipe.kh_beef_lok_lak.step1.title" = "Prep ingredients";
"recipe.kh_beef_lok_lak.step10.body" = "Return all the beef to the wok, add the stir-fry sauce, and toss over high heat until the beef is glazed and just cooked through.";
"recipe.kh_beef_lok_lak.step10.title" = "Finish lok lak";
"recipe.kh_beef_lok_lak.step11.body" = "Spoon the beef onto the prepared salad plates, serve with the steamed rice, and place the lime-pepper dipping sauce alongside.";
"recipe.kh_beef_lok_lak.step11.title" = "Plate and serve";
"recipe.kh_beef_lok_lak.step2.body" = "Combine the beef with %i2, %i3, %i4, %i5, and garlic in a mixing bowl. Mix well and leave to marinate.";
"recipe.kh_beef_lok_lak.step2.title" = "Marinate beef";
"recipe.kh_beef_lok_lak.step3.body" = "Rinse the %i19 until the water runs mostly clear, then drain.";
"recipe.kh_beef_lok_lak.step3.title" = "Wash rice";
"recipe.kh_beef_lok_lak.step4.body" = "Place the rice in a saucepan with %i20, bring to a boil, then cover and cook gently until the rice is tender and the water is absorbed.";
"recipe.kh_beef_lok_lak.step4.title" = "Cook rice";
"recipe.kh_beef_lok_lak.step5.body" = "Turn off the heat and let the covered rice rest, then fluff before serving.";
"recipe.kh_beef_lok_lak.step5.title" = "Rest rice";
"recipe.kh_beef_lok_lak.step6.body" = "In a small bowl, combine the %i11 with %i12, %i13, and %i14. Stir until the sugar dissolves.";
"recipe.kh_beef_lok_lak.step6.title" = "Mix dipping sauce";
"recipe.kh_beef_lok_lak.step7.body" = "Divide the lettuce, tomato, cucumber, and red onion among serving plates, leaving space for the beef and rice.";
"recipe.kh_beef_lok_lak.step7.title" = "Arrange salad plates";
