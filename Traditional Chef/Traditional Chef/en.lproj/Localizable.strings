"recipe.hk_feng_zhao.drink.body" = "Feng zhao is traditionally paired with tea during dim sum, especially pu-erh or chrysanthemum tea. If serving alcohol, a light lager works with the rich sauce, while hot pu-erh tea is the classic non-alcoholic pairing.";
"recipe.hk_feng_zhao.drink.summary" = "Pu-erh tea";
"recipe.hk_feng_zhao.info" = "A traditional Cantonese dim sum dish of chicken feet that are blanched, fried, soaked, then steamed and braised until tender in a savory sauce. In Hong Kong it is commonly served hot in small portions during yum cha as part of a shared table of dim sum dishes.";
"recipe.hk_feng_zhao.info.summary" = "Dim sum chicken feet";
"recipe.hk_feng_zhao.name" = "Chicken feet";
"recipe.hk_feng_zhao.step1.body" = "Trim the nails from the %i1, rinse well, and split each foot into two sections for traditional dim sum preparation.";
"recipe.hk_feng_zhao.step1.title" = "Trim and split the feet";
"recipe.hk_feng_zhao.step10.body" = "Transfer the chicken feet and sauce to a heatproof steaming dish, add %i17 to the steamer, and steam covered until the chicken feet are tender and the sauce is rich.";
"recipe.hk_feng_zhao.step10.title" = "Steam until tender";
"recipe.hk_feng_zhao.step11.body" = "Let the dish rest briefly after steaming so the sauce settles and clings to the chicken feet.";
"recipe.hk_feng_zhao.step11.title" = "Rest before serving";
"recipe.hk_feng_zhao.step12.body" = "Serve the feng zhao hot in the steaming dish as a dim sum plate.";
"recipe.hk_feng_zhao.step12.title" = "Serve hot";
"recipe.hk_feng_zhao.step2.body" = "Bring %i2 to a boil with %i3 and %i4, add the chicken feet, and blanch until impurities are released.";
"recipe.hk_feng_zhao.step2.title" = "Blanch with aromatics";
"recipe.hk_feng_zhao.step3.body" = "Drain the chicken feet thoroughly and let them dry well so they fry safely and blister properly.";
"recipe.hk_feng_zhao.step3.title" = "Drain and dry";
"recipe.hk_feng_zhao.step4.body" = "Heat the %i5 in a wok and fry the chicken feet in batches until puffed and lightly browned, then lift out and drain.";
"recipe.hk_feng_zhao.step4.title" = "Deep-fry the chicken feet";
"recipe.hk_feng_zhao.step5.body" = "Place the fried chicken feet in a bowl, cover with %i6, and soak until the skin expands and softens.";
"recipe.hk_feng_zhao.step5.title" = "Soak after frying";
"recipe.hk_feng_zhao.step6.body" = "Drain the soaked chicken feet, then mince the %i7 and roughly chop the %i8.";
"recipe.hk_feng_zhao.step6.title" = "Prepare the sauce base";
"recipe.hk_feng_zhao.step7.body" = "Heat the wok with a little oil from the frying, stir-fry the garlic and fermented black beans until fragrant, then add %i9, %i10, %i11, %i12, %i13, %i14, and %i15.";
"recipe.hk_feng_zhao.step7.title" = "Cook the braising sauce";
"recipe.hk_feng_zhao.step8.body" = "Stir the %i16 into a little cool braising water and add it to the sauce, cooking until lightly thickened and glossy.";
"recipe.hk_feng_zhao.step8.title" = "Thicken the sauce";
"recipe.hk_feng_zhao.step9.body" = "Add the chicken feet to the sauce and turn well so all pieces are evenly coated.";
"recipe.hk_feng_zhao.step9.title" = "Coat the chicken feet";
