"recipe.sr_pom.step1.title" = "Cook the chicken";
"recipe.sr_pom.step2.body" = "Lift the chicken from the cooking liquid, let it cool briefly, and shred the meat. Reserve some of the cooking liquid for the filling.";
"recipe.sr_pom.step2.title" = "Shred the chicken";
