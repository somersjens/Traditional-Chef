"recipe.it_pasta_alla_norma.drink.body" = "Pair with a Sicilian red such as Nero dAvola, or a dry rosé with good acidity to match the tomato and eggplant. Non-alcoholic option: sparkling water with lemon or a chilled herbal iced tea.";
"recipe.it_pasta_alla_norma.drink.summary" = "Red wine (Nero d'Avola)";
"recipe.it_pasta_alla_norma.info" = "A traditional Sicilian pasta of fried eggplant tossed with a simple tomato sauce, finished with fragrant basil and a shower of salty ricotta salata. Often made in late summer when eggplants and tomatoes are at their best, it is served hot as a comforting main that balances sweetness, acidity, and savory cheese.";
"recipe.it_pasta_alla_norma.info.summary" = "Sicilian summer pasta";
"recipe.it_pasta_alla_norma.name" = "Pasta alla Norma";
