"recipe.ps_maftoul.drink.body" = "A light to medium-bodied red wine such as Cinsault or Pinot Noir pairs well with the warm spices and savory broth. For a non-alcoholic pairing, serve hot mint tea or a glass of salted yogurt drink.";
"recipe.ps_maftoul.drink.summary" = "Red wine (Cinsault)";
"recipe.ps_maftoul.info" = "Maftoul is a traditional Palestinian main dish of hand-rolled wheat pearls served with a brothy chicken, chickpea, and onion stew. It is a comforting family meal, especially in cooler weather, with the grains served first and the fragrant stew spooned generously over the top.";
"recipe.ps_maftoul.info.summary" = "Hand-rolled wheat pearls";
"recipe.ps_maftoul.name" = "Maftoul";
"recipe.ps_maftoul.step1.body" = "Rub %i1 with half of %i5, half of %i6, half of %i7, part of %i8, and %i9. Heat some of %i4 in the large pot and brown the chicken on both sides.";
"recipe.ps_maftoul.step1.title" = "Season and brown the chicken";
"recipe.ps_maftoul.step2.body" = "Pour in %i10, bring to a boil, skim the surface, then lower the heat and simmer until the chicken is nearly tender and the broth is fragrant.";
"recipe.ps_maftoul.step2.title" = "Simmer the chicken";
"recipe.ps_maftoul.step3.body" = "Slice %i2 into strips. Heat the remaining olive oil for the stew in the skillet and cook the onions until softened and lightly golden.";
"recipe.ps_maftoul.step3.title" = "Cook the onions";
"recipe.ps_maftoul.step4.body" = "Add the onions and %i3 to the chicken pot with the remaining allspice, turmeric, caraway, and the rest of the salt. Simmer until the chicken is fully tender and the onions are sweet and soft.";
"recipe.ps_maftoul.step4.title" = "Finish the stew";
"recipe.ps_maftoul.step5.body" = "Heat %i12 in the second pot, add %i11, and stir briefly so the grains are coated and lightly warmed.";
"recipe.ps_maftoul.step5.title" = "Prepare the maftoul";
"recipe.ps_maftoul.step6.body" = "Pour in hot water, bring to a boil, then cover and cook gently until the grains are tender and the liquid is absorbed.";
"recipe.ps_maftoul.step6.title" = "Cook the maftoul";
"recipe.ps_maftoul.step7.body" = "Add %i14, %i15, and %i16 to the cooked maftoul and fluff well so the seasoning is evenly distributed.";
"recipe.ps_maftoul.step7.title" = "Season the grains";
"recipe.ps_maftoul.step8.body" = "Let the maftoul stand covered for a few minutes so the grains settle and finish steaming.";
"recipe.ps_maftoul.step8.title" = "Rest the dish";
"recipe.ps_maftoul.step9.body" = "Spread the maftoul onto a serving platter, arrange the chicken over it, then spoon the chickpeas, onions, and plenty of broth on top and serve immediately.";
"recipe.ps_maftoul.step9.title" = "Assemble and serve";
