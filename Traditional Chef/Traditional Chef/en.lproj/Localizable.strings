"recipe.tr_sutlac.drink.body" = "A lightly sweet Muscat or late-harvest Riesling complements the creamy milk and gentle sweetness. For a non-alcoholic option, serve Turkish tea or plain coffee alongside.";
"recipe.tr_sutlac.drink.summary" = "Dessert wine (Muscat)";
"recipe.tr_sutlac.info" = "Sütlaç is a traditional Turkish rice pudding made by gently cooking rice until tender, then simmering it with milk and sugar until creamy. It is served chilled in bowls and often finished with a dusting of cinnamon, a classic dessert found in homes and lokantas.";
"recipe.tr_sutlac.info.summary" = "Chilled rice pudding";
"recipe.tr_sutlac.name" = "Rice pudding";
"recipe.tr_sutlac.step1.body" = "Rinse the %i1, add %i2, bring to a simmer, and cook until the rice is very tender and most of the water is absorbed.";
"recipe.tr_sutlac.step1.title" = "Cook the rice";
"recipe.tr_sutlac.step2.body" = "Add the %i3 and simmer gently, stirring often, until the mixture thickens and becomes creamy.";
"recipe.tr_sutlac.step2.title" = "Simmer with milk";
"recipe.tr_sutlac.step3.body" = "Stir in %i4 and %i5 and simmer until fully dissolved and the pudding is smooth.";
"recipe.tr_sutlac.step3.title" = "Sweeten and finish";
"recipe.tr_sutlac.step4.body" = "Ladle the hot sütlaç into serving bowls.";
"recipe.tr_sutlac.step4.title" = "Portion into bowls";
"recipe.tr_sutlac.step5.body" = "Refrigerate until fully cold and set.";
"recipe.tr_sutlac.step5.title" = "Chill to set";
"recipe.tr_sutlac.step6.body" = "Dust with %i6 and serve chilled.";
"recipe.tr_sutlac.step6.title" = "Serve";
"recipe.tr_sutlac.tool.t1" = "Large pot";
