"recipe.my_otak_otak.step7.body" = "Place the parcels on a medium grill and cook until the leaf is charred in spots and the filling begins to set. Turn carefully with tongs.";
"recipe.my_otak_otak.step7.title" = "Grill first side";
"recipe.my_otak_otak.step8.body" = "Continue grilling until both sides are lightly charred and the fish custard is fully cooked and fragrant. Avoid high heat so the leaf does not burn before the filling sets.";
"recipe.my_otak_otak.step8.title" = "Finish grilling";
"recipe.my_otak_otak.step9.body" = "Serve the otak-otak hot in the leaf parcels or slightly opened so the smoky aroma is released at the table.";
"recipe.my_otak_otak.step9.title" = "Serve hot";
