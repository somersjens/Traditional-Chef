"recipe.tr_manti.step3.title" = "Prepare the filling";
"recipe.tr_manti.step4.body" = "Roll the dough very thin and cut into small squares for traditional tiny mantı.";
"recipe.tr_manti.step4.title" = "Roll and cut squares";
"recipe.tr_manti.step5.body" = "Place a small amount of filling on each square and pinch the corners together to seal, forming small dumplings. Arrange on a floured tray.";
"recipe.tr_manti.step5.title" = "Fill and pinch";
"recipe.tr_manti.step6.body" = "Whisk %i9 with %i10 and %i11 until smooth and ready for serving.";
"recipe.tr_manti.step6.title" = "Make the garlic yogurt";
"recipe.tr_manti.step7.body" = "Bring %i15 to a boil, season it with %i16, then cook the mantı until the dough is tender and the filling is cooked through. Drain well.";
"recipe.tr_manti.step7.title" = "Boil the mantı";
"recipe.tr_manti.step8.body" = "Melt %i12 in a small skillet and cook until foaming, then stir in %i13 and %i14 and remove from heat.";
"recipe.tr_manti.step8.title" = "Make the butter sauce";
"recipe.tr_manti.step9.body" = "Portion the hot mantı into bowls, spoon garlic yogurt over the top, and drizzle with the hot butter sauce.";
"recipe.tr_manti.step9.title" = "Assemble and serve";
