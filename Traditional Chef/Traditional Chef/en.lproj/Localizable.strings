"recipe.pl_makowiec.step7.body" = "Punch down the dough and roll it into a rectangle. Spread the poppy filling evenly, leaving a clear edge, then roll up tightly into a log and place seam-side down on a parchment-lined tray.";
"recipe.pl_makowiec.step7.title" = "Roll and fill";
"recipe.pl_makowiec.step8.body" = "Cover the roll and let it rise until noticeably puffy.";
"recipe.pl_makowiec.step8.title" = "Second proof";
