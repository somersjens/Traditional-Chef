"recipe.be_dame_blanche.drink.body" = "Pair with a lightly sweet wine such as late-harvest Riesling or a fruity dessert beer that complements dark chocolate without overwhelming the vanilla. For a non-alcoholic option, serve espresso, mint tea, or sparkling water to keep the finish refreshing.";
"recipe.be_dame_blanche.drink.summary" = "Sweet wine (Riesling)";
"recipe.be_dame_blanche.info" = "Dame Blanche is a classic Belgian dessert of vanilla ice cream topped with warm dark chocolate sauce and a generous crown of whipped cream. It is served immediately so the contrast between cold ice cream and hot sauce stays sharp, making it a staple on brasserie menus and a simple, elegant finish to a meal.";
"recipe.be_dame_blanche.info.summary" = "Brasserie ice cream sundae";
"recipe.be_dame_blanche.name" = "Dame Blanche";
"recipe.be_dame_blanche.step1.body" = "Chop %i2 into small pieces so it melts smoothly for the sauce.";
