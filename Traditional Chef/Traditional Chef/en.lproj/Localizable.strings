"recipe.mu_vindaye_poisson.step6.title" = "Add vinegar and season";
"recipe.mu_vindaye_poisson.step7.body" = "Add the fried fish to the vindaye mixture and turn gently so every piece is well coated.";
"recipe.mu_vindaye_poisson.step7.title" = "Coat the fish";
"recipe.mu_vindaye_poisson.step8.body" = "Transfer to a lidded container and rest so the flavors develop and the fish absorbs the tangy mustard sauce.";
"recipe.mu_vindaye_poisson.step8.title" = "Marinate and cure";
