"recipe.dk_flaeskesteg.drink.body" = "A light to medium-bodied red wine such as Pinot Noir works well with the roast pork and sweet-sour cabbage. For a non-alcoholic option, serve sparkling water or cold water with lemon.";
"recipe.dk_flaeskesteg.drink.summary" = "Red wine (Pinot Noir)";
"recipe.dk_flaeskesteg.info" = "Flæskesteg is a traditional Danish roast pork with crisp crackling, especially associated with Christmas and other festive family meals. It is served with pan gravy, boiled potatoes, caramelized potatoes, and braised red cabbage, making it one of the most classic Danish celebratory main courses.";
"recipe.dk_flaeskesteg.info.summary" = "Danish crackling roast";
"recipe.dk_flaeskesteg.name" = "Roast pork";
"recipe.dk_flaeskesteg.step1.body" = "Pat %i1 dry and check that the rind is cut into narrow strips without cutting into the meat. Rub %i2 thoroughly into every groove and insert %i3 in some of the cuts. Put %i4 and %i5 in the roasting pan, set the pork on top, and use foil under one side if needed so the rind sits level.";
"recipe.dk_flaeskesteg.step1.title" = "Prepare the roast";
"recipe.dk_flaeskesteg.step10.body" = "Slice the roast between the crackling cuts and serve with the gravy, boiled potatoes, caramelized potatoes, and braised red cabbage.";
"recipe.dk_flaeskesteg.step10.title" = "Serve";
"recipe.dk_flaeskesteg.step2.body" = "Pour %i6 into the roasting pan and roast until the meat is cooked through and the crackling is deeply crisp. Add a little more water if the pan dries out during roasting.";
"recipe.dk_flaeskesteg.step2.title" = "Roast the pork";
"recipe.dk_flaeskesteg.step3.body" = "Shred %i18 finely. Melt %i19 in the Dutch oven, add the cabbage, %i20, %i21, %i22, %i23, %i24, and %i25, then stir until the cabbage begins to soften.";
"recipe.dk_flaeskesteg.step3.title" = "Start the red cabbage";
"recipe.dk_flaeskesteg.step4.body" = "Cover and cook the red cabbage gently until tender, glossy, and sweet-sour, stirring from time to time.";
"recipe.dk_flaeskesteg.step4.title" = "Braise the red cabbage";
"recipe.dk_flaeskesteg.step5.body" = "Put %i12 in the large pot, cover with water, add %i14, and bring to a boil.";
"recipe.dk_flaeskesteg.step5.title" = "Boil the potatoes";
"recipe.dk_flaeskesteg.step6.body" = "Simmer the potatoes until tender, then drain them. Keep the larger potatoes for serving and let the small potatoes cool slightly for caramelizing.";
"recipe.dk_flaeskesteg.step6.title" = "Cook the potatoes until tender";
"recipe.dk_flaeskesteg.step7.body" = "Melt %i16 in the sauté pan until golden, add %i17, then roll %i15 in the caramel over gentle heat until evenly glazed and shiny.";
"recipe.dk_flaeskesteg.step7.title" = "Caramelize the small potatoes";
"recipe.dk_flaeskesteg.step8.body" = "Lift the roast out to rest. Strain the roasting juices into the saucepan, whisk %i7 and %i8 together separately, then whisk that into the hot juices. Add %i9 and simmer until the gravy is smooth, then season with %i10 and %i11.";
"recipe.dk_flaeskesteg.step8.title" = "Make the gravy";
"recipe.dk_flaeskesteg.step9.body" = "Let the pork rest briefly so the juices settle and the crackling stays crisp.";
"recipe.dk_flaeskesteg.step9.title" = "Rest the roast";
