"recipe.sn_soupe_kandja.drink.body" = "A crisp white wine such as Sauvignon Blanc pairs well with the seafood and okra, while a chilled non-alcoholic ginger drink or bissap (hibiscus) balances the richness of the palm oil.";
"recipe.sn_soupe_kandja.drink.summary" = "White wine (Sauvignon)";
"recipe.sn_soupe_kandja.info" = "Soupe Kandja is a traditional Senegalese okra stew built on red palm oil and a savory broth enriched with smoked seafood, then simmered with vegetables and fresh fish until the sauce turns glossy and lightly thick from the okra, and it is traditionally served spooned generously over plain white rice for a hearty shared meal.";
"recipe.sn_soupe_kandja.info.summary" = "Okra seafood stew";
"recipe.sn_soupe_kandja.name" = "Kandja soup";
"recipe.sn_soupe_kandja.step1.body" = "Wash and cut the %i11, %i12, %i13, %i14, and %i15 into large pieces, trim the %i10, and prepare the %i6, %i7, %i8, and %i9. Keep the %i19 whole.";
"recipe.sn_soupe_kandja.step1.title" = "Prep ingredients";
"recipe.sn_soupe_kandja.step10.body" = "Remove the chili and bay leaves, taste and adjust seasoning, then serve the soupe kandja ladled over rice with seafood and vegetables on top.";
"recipe.sn_soupe_kandja.step10.title" = "Serve";
"recipe.sn_soupe_kandja.step2.body" = "Rinse the %i1 repeatedly in a bowl with water, then drain well in a colander.";
"recipe.sn_soupe_kandja.step2.title" = "Wash the rice";
"recipe.sn_soupe_kandja.step3.body" = "Cook the rinsed rice in a saucepan with %i22 until tender, then keep covered off the heat.";
"recipe.sn_soupe_kandja.step3.title" = "Cook the rice";
"recipe.sn_soupe_kandja.step4.body" = "Heat %i2 in the pot, cook the %i3 until softened, add %i4, then stir in %i5 and cook until darkened and fragrant.";
"recipe.sn_soupe_kandja.step4.title" = "Start the stew base";
"recipe.sn_soupe_kandja.step5.body" = "Add water, %i16, %i17, %i18, %i20, %i21, and the whole chili, then bring to a steady simmer.";
"recipe.sn_soupe_kandja.step5.title" = "Build the broth";
"recipe.sn_soupe_kandja.step6.body" = "Add the smoked fish and dried shrimp and simmer so the broth becomes deeply flavored, skimming as needed.";
"recipe.sn_soupe_kandja.step6.title" = "Infuse with smoked seafood";
"recipe.sn_soupe_kandja.step7.body" = "Add the cassava, sweet potato, carrots, and eggplant and simmer until they begin to turn tender.";
"recipe.sn_soupe_kandja.step7.title" = "Cook firm vegetables";
"recipe.sn_soupe_kandja.step8.body" = "Add the okra and cabbage and simmer, stirring gently, until the sauce turns glossy and lightly thickened by the okra.";
"recipe.sn_soupe_kandja.step8.title" = "Cook okra and cabbage";
"recipe.sn_soupe_kandja.step9.body" = "Add the fresh fish and crab pieces and simmer gently until the fish is just cooked and the crab is heated through without breaking the fish apart.";
"recipe.sn_soupe_kandja.step9.title" = "Add fresh seafood";
