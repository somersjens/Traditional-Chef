"recipe.bd_bhuna_khichuri.step3.title" = "Bhuna the onion base";
"recipe.bd_bhuna_khichuri.step4.body" = "Add %i13, %i14, %i15, and %i16 and fry briefly, then stir in %i9, %i10, %i11, %i12, %i19, and %i18 until the spices darken slightly.";
"recipe.bd_bhuna_khichuri.step4.title" = "Bloom spices";
"recipe.bd_bhuna_khichuri.step5.body" = "Add the rice and toasted dal and stir so every grain is coated in the bhuna masala and fat.";
"recipe.bd_bhuna_khichuri.step5.title" = "Coat rice and dal";
"recipe.bd_bhuna_khichuri.step6.body" = "Add the potatoes and %i24, bring to a steady simmer, cover, and cook until the rice and dal are tender and the consistency is thick and spoonable, stirring occasionally near the end to prevent sticking.";
"recipe.bd_bhuna_khichuri.step6.title" = "Cook the khichuri";
"recipe.bd_bhuna_khichuri.step7.body" = "Beat the %i20 with %i22. Heat %i21 in a pan and cook the omelette until set and lightly browned, then cut into wedges.";
"recipe.bd_bhuna_khichuri.step7.title" = "Make the omelette";
"recipe.bd_bhuna_khichuri.step8.body" = "Let the khichuri stand covered briefly so it settles. Serve hot with omelette wedges and %i23.";
"recipe.bd_bhuna_khichuri.step8.title" = "Rest and serve";
