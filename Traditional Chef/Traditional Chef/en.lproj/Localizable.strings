"recipe.pl_karpatka.drink.body" = "Pair with off-dry sparkling wine or a lightly sweet late-harvest Riesling to match the vanilla custard without cloying. A creamy milk stout can also work alongside the toasted choux notes. Non-alcoholic option: black tea or a latte.";
"recipe.pl_karpatka.drink.summary" = "Sparkling wine";
"recipe.pl_karpatka.info" = "Karpatka is a traditional Polish cream cake made from two rugged, puffed sheets of choux pastry that resemble the snowy ridges of the Carpathian Mountains. The layers are filled with a thick vanilla custard buttercream (krem budyniowy), then chilled and finished with a dusting of powdered sugar. It is typically served in squares with coffee or tea as a classic home-baked dessert.";
"recipe.pl_karpatka.info.summary" = "Carpathian cream cake";
"recipe.pl_karpatka.name" = "Karpatka";
"recipe.pl_karpatka.step1.body" = "Heat the oven and line two baking trays with parchment paper. Set out a mixing bowl and mixer so the dough can be worked while warm.";
"recipe.pl_karpatka.step1.title" = "Prepare for baking";
"recipe.pl_karpatka.step10.body" = "Refrigerate until the cream is firmly set and the cake slices cleanly.";
"recipe.pl_karpatka.step10.title" = "Chill to set";
"recipe.pl_karpatka.step11.body" = "Dust the top generously with %i15 and cut into portions to serve.";
"recipe.pl_karpatka.step11.title" = "Finish and serve";
"recipe.pl_karpatka.step2.body" = "Bring %i1 and %i2 to a boil with %i4. Add %i3 all at once and stir vigorously until a smooth dough forms and a thin film develops on the pot.";
"recipe.pl_karpatka.step2.title" = "Cook the choux base";
"recipe.pl_karpatka.step3.body" = "Transfer the dough to a bowl and beat briefly to cool slightly. Add %i5 one at a time, mixing well each time, until the dough is glossy and thick.";
"recipe.pl_karpatka.step3.title" = "Beat in the eggs";
"recipe.pl_karpatka.step4.body" = "Divide the dough into two equal parts and spread each onto a prepared tray in an even layer, leaving the surface intentionally rough for a mountain-like finish.";
"recipe.pl_karpatka.step4.title" = "Spread the layers";
"recipe.pl_karpatka.step5.body" = "Bake until puffed, deeply golden, and dry. Cool the baked layers completely on racks.";
"recipe.pl_karpatka.step5.title" = "Bake the pastry layers";
"recipe.pl_karpatka.step6.body" = "Heat most of the %i6 with %i7 and %i8 until steaming. In a bowl, whisk the remaining milk with %i9, %i10, %i11, and %i12 until smooth.";
"recipe.pl_karpatka.step6.title" = "Start the custard";
"recipe.pl_karpatka.step7.body" = "Pour the slurry into the hot milk while whisking continuously. Cook, whisking, until very thick and bubbling. Press through a fine sieve, cover the surface to prevent a skin, and cool to room temperature.";
"recipe.pl_karpatka.step7.title" = "Cook the custard thick";
"recipe.pl_karpatka.step8.body" = "Beat %i13 with %i14 until pale and fluffy. Add the cooled custard gradually while beating, until smooth and thick.";
"recipe.pl_karpatka.step8.title" = "Make the buttercream";
"recipe.pl_karpatka.step9.body" = "Place one pastry layer on a serving plate, spread the cream evenly over it, and top with the second pastry layer, pressing very gently to set.";
"recipe.pl_karpatka.step9.title" = "Assemble the cake";
