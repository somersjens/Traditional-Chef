"recipe.ua_kyiv_cake.step1.title" = "Prepare the nuts";
"recipe.ua_kyiv_cake.step10.body" = "Place one meringue layer on the stand, spread it with some cocoa cream, set the second layer on top, and coat the top and sides with the remaining cocoa cream.";
"recipe.ua_kyiv_cake.step10.title" = "Assemble the cake";
"recipe.ua_kyiv_cake.step11.body" = "Pipe the reserved light buttercream over the top in classic rosettes and borders, then finish with %i13.";
"recipe.ua_kyiv_cake.step11.title" = "Decorate traditionally";
"recipe.ua_kyiv_cake.step12.body" = "Chill the cake until the buttercream is firm and the layers slice cleanly.";
"recipe.ua_kyiv_cake.step12.title" = "Chill before serving";
"recipe.ua_kyiv_cake.step2.body" = "Beat %i1 until foamy, then gradually add the remaining sugar and %i5 and continue beating until stiff and glossy.";
"recipe.ua_kyiv_cake.step2.title" = "Whip the meringue";
"recipe.ua_kyiv_cake.step3.body" = "Fold the hazelnut mixture gently into the meringue so the batter stays airy while the nuts are evenly distributed.";
"recipe.ua_kyiv_cake.step3.title" = "Fold in the nut mixture";
"recipe.ua_kyiv_cake.step4.body" = "Spread the mixture evenly into two round layers on lined trays and bake slowly until dry, pale golden, and crisp.";
"recipe.ua_kyiv_cake.step4.title" = "Bake the layers";
"recipe.ua_kyiv_cake.step5.body" = "Leave the baked layers to stand until fully dry and stable so they hold their texture during assembly.";
"recipe.ua_kyiv_cake.step5.title" = "Rest the layers";
"recipe.ua_kyiv_cake.step6.body" = "Whisk %i6 with %i7, add %i8, and cook gently while stirring until the mixture thickens lightly into a smooth custard.";
"recipe.ua_kyiv_cake.step6.title" = "Cook the charlotte base";
"recipe.ua_kyiv_cake.step7.body" = "Transfer the custard base to cool completely so it can be beaten into the butter without melting it.";
"recipe.ua_kyiv_cake.step7.title" = "Cool the custard";
"recipe.ua_kyiv_cake.step8.body" = "Beat %i9 until light, then add the cooled custard gradually with %i10 and %i12 until the cream is smooth and fluffy.";
"recipe.ua_kyiv_cake.step8.title" = "Make the buttercream";
"recipe.ua_kyiv_cake.step9.body" = "Set aside part of the buttercream for decoration, then beat %i11 into the larger portion so you have a chocolate cream for filling and coating.";
"recipe.ua_kyiv_cake.step9.title" = "Prepare the cocoa cream";
