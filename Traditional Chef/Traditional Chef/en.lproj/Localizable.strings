"recipe.hk_siu_mai.drink.body" = "Siu mai is traditionally paired with Chinese tea during dim sum, especially pu-erh or jasmine tea. If serving alcohol, a light lager works with the savory filling, while hot pu-erh tea is the classic non-alcoholic pairing.";
"recipe.hk_siu_mai.drink.summary" = "Pu-erh tea";
"recipe.hk_siu_mai.info" = "A traditional Cantonese dim sum dumpling with an open-topped wrapper filled with seasoned pork, shrimp, and mushroom, then steamed until juicy and springy. In Hong Kong it is a classic yum cha staple served hot in bamboo steamers as part of a shared table of dim sum dishes.";
"recipe.hk_siu_mai.info.summary" = "Open-topped dumplings";
"recipe.hk_siu_mai.name" = "Siu mai";
"recipe.hk_siu_mai.step1.body" = "Soak the %i3 until softened, then drain and squeeze dry. Finely dice the mushrooms, %i4, and %i5. Peel and devein the %i2, then chop most into small pieces and mince a small portion into a paste.";
"recipe.hk_siu_mai.step1.title" = "Prepare filling ingredients";
"recipe.hk_siu_mai.step2.body" = "Combine %i1, shrimp, mushrooms, bamboo shoots, spring onion, %i6, %i7, %i8, %i9, %i10, %i11, %i12, %i13, and %i14, then stir in one direction until the filling becomes sticky and cohesive.";
"recipe.hk_siu_mai.step2.title" = "Mix the filling";
"recipe.hk_siu_mai.step3.body" = "Cover and chill the filling so it firms slightly and is easier to shape.";
"recipe.hk_siu_mai.step3.title" = "Chill the filling";
"recipe.hk_siu_mai.step4.body" = "Add %i17 to the pot, set up the steamer, and lightly oil the steamer liner.";
"recipe.hk_siu_mai.step4.title" = "Prepare steamer setup";
"recipe.hk_siu_mai.step5.body" = "Place filling on each %i15, gather the sides around the filling, and press gently to form open-topped cylinders with flat bottoms.";
"recipe.hk_siu_mai.step5.title" = "Shape the siu mai";
"recipe.hk_siu_mai.step6.body" = "Finely grate the %i16 and place a small pinch on top of each dumpling.";
"recipe.hk_siu_mai.step6.title" = "Garnish the tops";
"recipe.hk_siu_mai.step7.body" = "Place the siu mai in the lined steamer with space between them so steam can circulate evenly.";
"recipe.hk_siu_mai.step7.title" = "Arrange in steamer";
"recipe.hk_siu_mai.step8.body" = "Steam over boiling water until the wrappers are tender and the filling is fully cooked and springy.";
"recipe.hk_siu_mai.step8.title" = "Steam until cooked";
"recipe.hk_siu_mai.step9.body" = "Serve the siu mai immediately while hot in the steamer basket or on a warmed plate.";
"recipe.hk_siu_mai.step9.title" = "Serve hot";
