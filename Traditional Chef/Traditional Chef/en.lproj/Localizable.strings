"recipe.mx_aguachile.drink.body" = "A dry rosé or a crisp, unoaked Sauvignon Blanc pairs well with the lime and chile heat. A light Mexican lager also works nicely. For a non-alcoholic option, serve sparkling water with lime and a pinch of salt.";
"recipe.mx_aguachile.drink.summary" = "Rosé wine";
"recipe.mx_aguachile.info" = "Aguachile verde is a traditional coastal Mexican seafood dish from northwestern Mexico, made with raw shrimp quickly cured in lime and dressed in a fiery green mixture of fresh chiles and cilantro, then served very cold with crisp cucumber and sliced onion for brightness and crunch. It is typically eaten immediately, spooned onto tostadas as a refreshing appetizer.";
"recipe.mx_aguachile.info.summary" = "Icy green shrimp";
"recipe.mx_aguachile.name" = "Aguachile";
"recipe.mx_aguachile.step1.body" = "Butterfly %i1 so they are thin and open. Lay them in a single layer in a shallow non-reactive dish.";
"recipe.mx_aguachile.step1.title" = "Prepare the shrimp";
"recipe.mx_aguachile.step2.body" = "Squeeze the limes to make %i2 and remove any seeds.";
"recipe.mx_aguachile.step2.title" = "Juice the limes";
"recipe.mx_aguachile.step3.body" = "Cover the shrimp with the lime juice and season with %i6. Turn the shrimp once during curing until opaque and firm.";
"recipe.mx_aguachile.step3.title" = "Cure the shrimp";
"recipe.mx_aguachile.step4.body" = "Thinly slice %i8. Slice %i7 into thin rounds or half-moons and keep chilled.";
"recipe.mx_aguachile.step4.title" = "Slice the vegetables";
"recipe.mx_aguachile.step5.body" = "In a molcajete or mortar, crush %i3 with salt into a coarse paste.";
"recipe.mx_aguachile.step5.title" = "Grind the chiles";
"recipe.mx_aguachile.step6.body" = "Work in %i4 until bright green, then add a little %i5 and grind to a pourable sauce.";
"recipe.mx_aguachile.step6.title" = "Make the green sauce";
"recipe.mx_aguachile.step7.body" = "Pour the green sauce over the cured shrimp along with the curing lime juice and fold gently to coat.";
"recipe.mx_aguachile.step7.title" = "Dress the shrimp";
"recipe.mx_aguachile.step8.body" = "Add the cucumber and onion, toss lightly, then refrigerate so it is served very cold.";
"recipe.mx_aguachile.step8.title" = "Chill with vegetables";
"recipe.mx_aguachile.step9.body" = "Arrange the aguachile with plenty of liquid and serve immediately with %i9 for scooping.";
"recipe.mx_aguachile.step9.title" = "Serve";
