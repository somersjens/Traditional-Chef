"recipe.sn_domoda.drink.body" = "A smooth, medium-bodied red wine such as Grenache or Cinsault complements the savory tomato sauce and gentle heat. For a non-alcoholic option, serve chilled hibiscus tea (bissap) or a fresh ginger drink.";
"recipe.sn_domoda.drink.summary" = "Red wine (Grenache)";
"recipe.sn_domoda.info" = "Domoda Farine is a traditional Senegalese tomato-based meat stew thickened with flour, simmered with hearty vegetables and finished with a bright citrus tang, then served hot over plain white rice for a comforting family meal.";
"recipe.sn_domoda.info.summary" = "Tomato-thickened stew";
"recipe.sn_domoda.name" = "Domoda farine";
"recipe.sn_domoda.step1.body" = "Peel and cut the %i9, %i10, %i11, %i12, and %i13 into large pieces, chop the %i4, and crush the %i5. Cut the %i2 into even chunks if needed.";
"recipe.sn_domoda.step1.title" = "Prep ingredients";
"recipe.sn_domoda.step2.body" = "Heat %i3 in the pot and brown the beef well. Add onion and cook until softened, then add garlic and stir briefly until fragrant.";
"recipe.sn_domoda.step2.title" = "Start the stew";
"recipe.sn_domoda.step3.body" = "Stir in %i7 and cook until it darkens slightly. Add the %i6 and cook until they break down into a thick, glossy sauce.";
"recipe.sn_domoda.step3.title" = "Build the tomato base";
"recipe.sn_domoda.step4.body" = "Add %i20, %i14, %i15, %i18, %i19, and %i16. Bring to a steady simmer, cover, and cook until the beef begins to tenderize.";
"recipe.sn_domoda.step4.title" = "Simmer the meat";
"recipe.sn_domoda.step5.body" = "Rinse the %i1 until the water runs clearer, drain, then cook it in a saucepan with water until tender. Keep covered off the heat.";
"recipe.sn_domoda.step5.title" = "Cook the rice";
"recipe.sn_domoda.step6.body" = "Add the firm vegetables to the stew first and simmer until they are nearly tender, then add cabbage and okra and continue simmering until all are cooked through.";
"recipe.sn_domoda.step6.title" = "Cook the vegetables";
"recipe.sn_domoda.step7.body" = "In a bowl, whisk %i8 with cool water to a smooth slurry. Stir it into the simmering stew and cook until the sauce thickens and the flour taste is gone.";
"recipe.sn_domoda.step7.title" = "Thicken with flour";
"recipe.sn_domoda.step8.body" = "Squeeze in %i17 juice, simmer briefly, then taste and adjust seasoning so the stew is savory with a gentle tang.";
"recipe.sn_domoda.step8.title" = "Finish with citrus";
"recipe.sn_domoda.step9.body" = "Spoon rice onto plates and ladle the domoda over the top, making sure each serving gets beef, vegetables, and plenty of sauce.";
"recipe.sn_domoda.step9.title" = "Serve";
