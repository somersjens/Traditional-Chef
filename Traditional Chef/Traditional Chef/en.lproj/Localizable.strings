"recipe.pe_aji_de_gallina.drink.body" = "Pair with a chilled, lightly oaked Chardonnay to match the creamy sauce, or a crisp Sauvignon Blanc if you prefer more freshness against the chili. For a non-alcoholic option, serve chicha morada or sparkling water with lime to keep the meal bright and refreshing.";
"recipe.pe_aji_de_gallina.drink.summary" = "White wine (Chardonnay)";
"recipe.pe_aji_de_gallina.info" = "Ají de Gallina is a classic Peruvian dish of shredded chicken folded into a smooth, creamy, lightly spicy ají amarillo sauce thickened with bread and nuts and finished with Parmesan. It is traditionally served plated with white rice and boiled yellow potatoes, and garnished with black olives and hard-boiled egg, often on a bed of lettuce.";
"recipe.pe_aji_de_gallina.info.summary" = "Creamy chicken ají";
"recipe.pe_aji_de_gallina.name" = "Ají de gallina";
"recipe.pe_aji_de_gallina.step1.body" = "Add the %i1 to a large pot with the %i3, %i4, and about half of the %i2. Cover with %i6, add %i5 and a pinch of %i7, and bring to a gentle simmer.";
"recipe.pe_aji_de_gallina.step1.title" = "Start the broth";
"recipe.pe_aji_de_gallina.step10.body" = "Stir in %i18 until melted and smooth, then fold in the shredded chicken. Warm through, adjusting seasoning with salt until balanced.";
"recipe.pe_aji_de_gallina.step10.title" = "Finish with cheese";
"recipe.pe_aji_de_gallina.step11.body" = "Place lettuce leaves on plates, add sliced potatoes and a mound of rice, then spoon the ají de gallina over or alongside. Garnish with olives and the egg quarters and serve hot.";
"recipe.pe_aji_de_gallina.step11.title" = "Plate traditionally";
"recipe.pe_aji_de_gallina.step2.body" = "Simmer until the chicken is cooked through and tender. Lift out the chicken to cool slightly, then strain the broth and keep the clear liquid for the sauce.";
"recipe.pe_aji_de_gallina.step2.title" = "Poach the chicken";
"recipe.pe_aji_de_gallina.step3.body" = "Shred the chicken into fine strands. Hard-boil the %i21, cool them, then peel and quarter them. Pit or slice the %i22 if needed and wash the %i23 for serving.";
"recipe.pe_aji_de_gallina.step3.title" = "Prepare chicken and garnishes";
"recipe.pe_aji_de_gallina.step4.body" = "Boil the %i20 in salted water until tender, then drain. Peel if desired and slice into thick rounds for plating.";
"recipe.pe_aji_de_gallina.step4.title" = "Boil the potatoes";
"recipe.pe_aji_de_gallina.step5.body" = "Rinse the %i19, then cook it until fluffy and tender. Keep warm for serving.";
"recipe.pe_aji_de_gallina.step5.title" = "Cook the rice";
"recipe.pe_aji_de_gallina.step6.body" = "Tear the %i14 into pieces and soak it with %i15 until fully softened.";
"recipe.pe_aji_de_gallina.step6.title" = "Soften the bread";
"recipe.pe_aji_de_gallina.step7.body" = "Finely chop the remaining onion and sauté it in %i9 over medium heat until soft and translucent. Add the %i8, %i12, %i11, %i13, and %i10 and cook briefly until fragrant.";
"recipe.pe_aji_de_gallina.step7.title" = "Cook the aromatics";
"recipe.pe_aji_de_gallina.step8.body" = "Add the soaked bread mixture and the %i17 to the blender. Pour in some reserved broth and blend until completely smooth.";
"recipe.pe_aji_de_gallina.step8.title" = "Blend the sauce base";
"recipe.pe_aji_de_gallina.step9.body" = "Return the blended mixture to the skillet. Add more reserved broth as needed to make a thick, spoonable sauce, then simmer gently while stirring until it tastes cooked and cohesive.";
"recipe.pe_aji_de_gallina.step9.title" = "Simmer the sauce";
