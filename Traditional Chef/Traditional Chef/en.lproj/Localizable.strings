"recipe.ru_kholodets.drink.body" = "Traditionally served with chilled vodka, kholodets also pairs well with a crisp dry white that can cut through the richness of the aspic. Non-alcoholic pairing: hot black tea or sparkling water with lemon.";
"recipe.ru_kholodets.drink.summary" = "Chilled vodka";
"recipe.ru_kholodets.info" = "Kholodets is a traditional Russian jellied meat dish made by slowly simmering collagen-rich pork and beef with aromatics to produce a naturally set savory aspic. The tender meat is picked from the bones, combined with garlic, and set in the clarified broth until firm, then served cold as a classic zakuska with horseradish, mustard, and rye bread.";
"recipe.ru_kholodets.info.summary" = "Jellied meat zakuska";
"recipe.ru_kholodets.name" = "Kholodets";
"recipe.ru_kholodets.step1.body" = "Rinse %i1 and %i2 well, scraping if needed. Place them in a pot, cover with cold %i9, bring briefly to a boil, drain, and rinse the meats and pot to keep the aspic clear.";
"recipe.ru_kholodets.step1.title" = "Clean the meats";
"recipe.ru_kholodets.step2.body" = "Return the cleaned meats to the pot with fresh %i9. Bring to a gentle simmer and skim diligently until the surface stays clear.";
"recipe.ru_kholodets.step2.title" = "Start the broth";
"recipe.ru_kholodets.step3.body" = "Add %i3, %i4, %i6, and %i7. Cover partially and simmer very gently until the meat is tender and the broth is rich and gelatinous.";
"recipe.ru_kholodets.step3.title" = "Slow simmer";
"recipe.ru_kholodets.step4.body" = "Remove the meats and vegetables. Strain the broth through a fine strainer lined with cheesecloth into a clean pot or bowl.";
"recipe.ru_kholodets.step4.title" = "Strain the broth";
"recipe.ru_kholodets.step5.body" = "When cool enough to handle, remove bones, cartilage you do not want to eat, and skin as needed, then shred or chop the meat into bite-size pieces and place in a bowl.";
"recipe.ru_kholodets.step5.title" = "Pick and shred meat";
"recipe.ru_kholodets.step6.body" = "Warm the strained broth gently and season with %i8. Mince %i5 and mix it into the meat so it is evenly distributed.";
"recipe.ru_kholodets.step6.title" = "Season and add garlic";
"recipe.ru_kholodets.step7.body" = "Spread the meat evenly in a loaf pan. Ladle the hot broth over so the meat is fully covered, tapping the pan gently to release bubbles.";
"recipe.ru_kholodets.step7.title" = "Assemble";
"recipe.ru_kholodets.step8.body" = "Cool, then refrigerate until fully firm and jelled.";
"recipe.ru_kholodets.step8.title" = "Chill until set";
"recipe.ru_kholodets.step9.body" = "Unmold or slice in the pan and serve cold with %i10, %i11, and %i12.";
"recipe.ru_kholodets.step9.title" = "Serve";
