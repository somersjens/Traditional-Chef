"recipe.se_toast_skagen.drink.body" = "A crisp Chablis or other dry unoaked Chardonnay pairs well with the sweet prawns and creamy topping. A light lager also works. For a non-alcoholic option, serve sparkling water with lemon.";
"recipe.se_toast_skagen.drink.summary" = "White wine (Chablis)";
"recipe.se_toast_skagen.info" = "Toast Skagen is a classic Swedish starter of butter-fried white bread topped with skagenröra, a chilled mixture of small prawns, mayonnaise, crème fraîche, dill, lemon, and a little onion. It is traditionally served as an elegant first course, finished with fish roe, lemon, and dill.";
"recipe.se_toast_skagen.info.summary" = "Shrimp toast Skagen";
"recipe.se_toast_skagen.name" = "Toast Skagen";
"recipe.se_toast_skagen.step1.body" = "Finely chop %i5 and %i4. Finely grate a little zest from %i6 and squeeze the lemon juice.";
"recipe.se_toast_skagen.step1.title" = "Prepare the aromatics";
"recipe.se_toast_skagen.step2.body" = "Combine %i1, %i2, %i3, chopped dill, shallot, lemon zest, lemon juice, %i7, and %i8 in a bowl. Mix gently so the prawns stay lightly textured.";
"recipe.se_toast_skagen.step2.title" = "Make the skagenrora";
"recipe.se_toast_skagen.step3.body" = "Cover the bowl and refrigerate the skagenrora so it becomes cold and the flavors meld.";
"recipe.se_toast_skagen.step3.title" = "Chill the filling";
"recipe.se_toast_skagen.step4.body" = "Melt %i10 in a frying pan and fry %i9 on both sides until golden and crisp.";
"recipe.se_toast_skagen.step4.title" = "Fry the bread";
"recipe.se_toast_skagen.step5.body" = "Place the warm bread on plates and spoon the chilled skagenrora generously on top.";
"recipe.se_toast_skagen.step5.title" = "Assemble the toasts";
"recipe.se_toast_skagen.step6.body" = "Top each toast with %i11 and the remaining %i12, then serve immediately with lemon wedges.";
