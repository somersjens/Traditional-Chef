"recipe.pl_rosol.drink.body" = "Pair with a crisp, mineral dry white such as Riesling or Grüner Veltliner to complement the delicate broth and herbs. A light pilsner-style lager can also work well alongside the noodles. Non-alcoholic option: hot black tea with lemon or sparkling water.";
"recipe.pl_rosol.drink.summary" = "White wine (Riesling)";
"recipe.pl_rosol.info" = "Rosół is Poland’s beloved clear chicken broth, slowly simmered with classic soup vegetables and warm spices until golden, fragrant, and deeply savory. It is traditionally served hot with fine noodles and chopped parsley, as a comforting first course at Sunday family dinners and holidays, prized for its clarity and clean, rich flavor.";
"recipe.pl_rosol.info.summary" = "Sunday chicken broth";
"recipe.pl_rosol.name" = "Chicken soup";
"recipe.pl_rosol.step1.body" = "Put %i1 in a stockpot and cover with cold %i2. Bring up slowly to a gentle simmer so the broth stays clear.";
"recipe.pl_rosol.step1.title" = "Start the broth";
"recipe.pl_rosol.step2.body" = "As foam rises, skim it off carefully and keep the simmer very gentle.";
"recipe.pl_rosol.step2.title" = "Skim for clarity";
"recipe.pl_rosol.step3.body" = "Add %i3, %i4, %i5, %i6, %i7, %i8, %i9, and %i10. Maintain a bare simmer so the broth stays clear and aromatic.";
"recipe.pl_rosol.step3.title" = "Add vegetables and spices";
"recipe.pl_rosol.step4.body" = "Simmer gently until the chicken is tender and the broth is rich and golden, without boiling hard.";
"recipe.pl_rosol.step4.title" = "Slow-simmer until golden";
"recipe.pl_rosol.step5.body" = "Remove chicken, then strain the broth through a fine sieve into a clean pot. Season with %i11 to taste and keep hot.";
"recipe.pl_rosol.step5.title" = "Strain the broth";
"recipe.pl_rosol.step6.body" = "Bring %i13 to a boil in a separate pot, season with %i14, and cook the %i12 until tender.";
"recipe.pl_rosol.step6.title" = "Boil noodles";
"recipe.pl_rosol.step7.body" = "Drain the noodles well and divide them among serving bowls.";
"recipe.pl_rosol.step7.title" = "Drain and portion noodles";
"recipe.pl_rosol.step8.body" = "Ladle hot broth over the noodles and finish with chopped %i15. Serve immediately.";
"recipe.pl_rosol.step8.title" = "Serve";
