"recipe.sr_bojo.drink.body" = "Serve with a light sweet dessert wine or demi-sec sparkling wine that complements the caramelized cassava and coconut. For a non-alcoholic option, serve black coffee or hot black tea.";
"recipe.sr_bojo.drink.summary" = "Sweet dessert wine";
"recipe.sr_bojo.info" = "Bojo is a traditional Surinamese baked cassava dessert made with grated cassava, coconut, sugar, butter, eggs, and warm aromatics. It is baked until firm and richly golden, then served in slices at room temperature or slightly chilled as a festive sweet.";
"recipe.sr_bojo.info.summary" = "Cassava coconut cake";
"recipe.sr_bojo.name" = "Bojo";
"recipe.sr_bojo.step1.body" = "Place %i1, %i2, %i3, %i7, %i8, %i9, %i10, and %i11 in a mixing bowl and combine well.";
"recipe.sr_bojo.step1.title" = "Prepare the batter";
"recipe.sr_bojo.step2.body" = "Melt %i5, then add it with %i4 and %i6 to the bowl and mix until the batter is evenly combined.";
"recipe.sr_bojo.step2.title" = "Add the wet ingredients";
"recipe.sr_bojo.step3.body" = "Grease the oven dish lightly, transfer the batter into it, and spread the top evenly.";
"recipe.sr_bojo.step3.title" = "Fill the dish";
"recipe.sr_bojo.step4.body" = "Bake until the bojo is firm, deeply golden on top, and colored around the edges.";
"recipe.sr_bojo.step4.title" = "Bake the bojo";
"recipe.sr_bojo.step5.body" = "Leave the bojo to cool completely in the dish so it sets fully and slices cleanly.";
"recipe.sr_bojo.step5.title" = "Cool the dessert";
"recipe.sr_bojo.step6.body" = "Cut the bojo into pieces and serve at room temperature or slightly chilled.";
"recipe.sr_bojo.step6.title" = "Serve";
