"recipe.es_cocido_madrileno.drink.body" = "Pair with a medium-bodied Spanish red such as Rioja Crianza to stand up to the cured meats and chickpeas without overwhelming the broth. A dry Cava also works well to cut richness. Non-alcoholic option: sparkling water with lemon.";
"recipe.es_cocido_madrileno.drink.summary" = "Red wine (Rioja Crianza)";
"recipe.es_cocido_madrileno.info" = "Cocido madrileño is Madrid’s iconic chickpea stew served in three vuelcos: first a clear, rich broth with fine noodles, then chickpeas and vegetables, and finally the assorted meats and sausages that perfume the pot. It is slowly simmered until everything is tender and deeply flavored, with the cabbage typically served reheated and lightly sautéed with garlic and paprika, and crusty bread on the side.";
"recipe.es_cocido_madrileno.info.summary" = "Madrid three-course stew";
"recipe.es_cocido_madrileno.name" = "Cocido";
"recipe.es_cocido_madrileno.step1.body" = "Rinse %i8 and cover with plenty of %i9 in a bowl. Soak until fully hydrated.";
"recipe.es_cocido_madrileno.step1.title" = "Soak the chickpeas";
"recipe.es_cocido_madrileno.step10.body" = "Lift out meats, sausages, and vegetables. Strain the broth through a fine sieve and season with %i19.";
"recipe.es_cocido_madrileno.step10.title" = "Separate broth, meats, and vegetables";
"recipe.es_cocido_madrileno.step11.body" = "Bring the strained broth to a gentle simmer in a saucepan and cook %i14 until tender.";
"recipe.es_cocido_madrileno.step11.title" = "Cook the noodle soup";
"recipe.es_cocido_madrileno.step12.body" = "Serve the noodle soup first. Then serve chickpeas with vegetables and sautéed cabbage. Finally, serve the meats and sausages, with %i20 alongside.";
"recipe.es_cocido_madrileno.step12.title" = "Serve in three courses";
