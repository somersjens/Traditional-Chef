"recipe.hk_har_gow.drink.body" = "Har gow is traditionally paired with Chinese tea at dim sum, especially jasmine or pu-erh tea. If serving wine, a very light dry white can work, while hot jasmine tea is the classic non-alcoholic pairing.";
"recipe.hk_har_gow.drink.summary" = "Jasmine tea";
"recipe.hk_har_gow.info" = "A traditional Cantonese dim sum shrimp dumpling with a translucent wheat-starch wrapper and a juicy filling of shrimp, pork fat, and bamboo shoots. It is served hot from the steamer during yum cha and prized for its delicate pleats and tender bite.";
"recipe.hk_har_gow.info.summary" = "Translucent shrimp dumplings";
"recipe.hk_har_gow.name" = "Har gow";
"recipe.hk_har_gow.step1.body" = "Peel and devein the %i1, then chop most of them into pieces and mince a smaller portion into a paste. Finely dice the %i2, %i3, and %i4.";
"recipe.hk_har_gow.step1.title" = "Prepare the filling ingredients";
"recipe.hk_har_gow.step10.body" = "Steam the dumplings over boiling water until the wrappers turn translucent and the shrimp filling is cooked through.";
"recipe.hk_har_gow.step10.title" = "Steam the first batch";
"recipe.hk_har_gow.step11.body" = "Continue steaming the remaining dumplings in batches, keeping the shaped dumplings covered while waiting.";
"recipe.hk_har_gow.step11.title" = "Steam remaining dumplings";
"recipe.hk_har_gow.step12.body" = "Serve the har gow immediately while the wrappers are tender and translucent.";
"recipe.hk_har_gow.step12.title" = "Serve hot";
"recipe.hk_har_gow.step2.body" = "Combine shrimp, pork fat, bamboo shoots, spring onion, %i5, %i6, %i7, %i8, and %i9, then stir in one direction until sticky and cohesive.";
"recipe.hk_har_gow.step2.title" = "Mix the filling";
"recipe.hk_har_gow.step3.body" = "Cover and chill the filling so it firms up and is easier to wrap.";
"recipe.hk_har_gow.step3.title" = "Chill the filling";
"recipe.hk_har_gow.step4.body" = "Mix %i10, %i11, and %i12 in a bowl, pour in %i13, and stir quickly until a shaggy hot dough forms.";
"recipe.hk_har_gow.step4.title" = "Start the wrapper dough";
"recipe.hk_har_gow.step5.body" = "When cool enough to handle, knead in %i14 until the dough is smooth, pliable, and slightly glossy.";
"recipe.hk_har_gow.step5.title" = "Knead with lard";
"recipe.hk_har_gow.step6.body" = "Cover the dough and let it rest to relax and hydrate evenly.";
"recipe.hk_har_gow.step6.title" = "Rest the dough";
"recipe.hk_har_gow.step7.body" = "Add %i15 to the pot, set up the steamer, and lightly oil the steamer liner.";
"recipe.hk_har_gow.step7.title" = "Prepare the steamer";
"recipe.hk_har_gow.step8.body" = "Divide the dough into small portions, keep them covered, and roll each portion into a thin round wrapper with the center slightly thicker than the edge.";
"recipe.hk_har_gow.step8.title" = "Divide and shape wrappers";
"recipe.hk_har_gow.step9.body" = "Place filling in each wrapper, fold and pleat into crescent dumplings, and set them on the prepared steamer liner with space between them.";
"recipe.hk_har_gow.step9.title" = "Fill and pleat dumplings";
