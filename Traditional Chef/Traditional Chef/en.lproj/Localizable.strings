"recipe.tn_kousksi_bil_hout.drink.body" = "A crisp Mediterranean white such as Vermentino pairs well with the tomato-harissa broth and fish. For a non-alcoholic option, serve hot Tunisian mint tea or sparkling water with lemon.";
"recipe.tn_kousksi_bil_hout.drink.summary" = "White wine (Vermentino)";
"recipe.tn_kousksi_bil_hout.info" = "Kousksi bil Hout is a traditional Tunisian fish couscous where a spicy tomato-harissa broth is simmered with chickpeas and vegetables, then finished with fish cooked gently in the sauce and served over fluffy steamed couscous, with extra broth ladled on top for a hearty communal meal.";
"recipe.tn_kousksi_bil_hout.info.summary" = "Fish couscous platter";
"recipe.tn_kousksi_bil_hout.name" = "Fish couscous";
"recipe.tn_kousksi_bil_hout.step1.body" = "Rinse the %i14, cover with water, and soak until plumped, then drain.";
"recipe.tn_kousksi_bil_hout.step1.title" = "Soak the chickpeas";
"recipe.tn_kousksi_bil_hout.step10.body" = "Mound couscous on a platter, arrange fish and vegetables on top, then ladle over the sauce and serve hot with extra broth at the table.";
"recipe.tn_kousksi_bil_hout.step10.title" = "Serve";
"recipe.tn_kousksi_bil_hout.step2.body" = "Peel and cut the %i9, %i10, %i11, %i12, and %i13 into large pieces. Pat the %i8 dry and keep it ready for gentle cooking later.";
"recipe.tn_kousksi_bil_hout.step2.title" = "Prep vegetables and fish";
"recipe.tn_kousksi_bil_hout.step3.body" = "In the bottom of the couscoussier, warm %i2, soften the %i3, add %i4, then whisk in %i5, %i6, %i7, %i15, %i16, %i17, %i18, and %i19 until glossy and fragrant.";
"recipe.tn_kousksi_bil_hout.step3.title" = "Start the sauce base";
"recipe.tn_kousksi_bil_hout.step4.body" = "Add soaked chickpeas, %i20, and %i21, bring to a steady simmer, then add the firm vegetables and cook until nearly tender.";
"recipe.tn_kousksi_bil_hout.step4.title" = "Simmer chickpeas and vegetables";
"recipe.tn_kousksi_bil_hout.step5.body" = "Place the %i1 in a bowl, moisten with water, rub to separate grains, then transfer to the steamer basket over the simmering stew.";
"recipe.tn_kousksi_bil_hout.step5.title" = "Prepare couscous for steaming";
"recipe.tn_kousksi_bil_hout.step6.body" = "Steam until the couscous is hot and swollen, then return it to the bowl and fluff thoroughly to break up clumps.";
"recipe.tn_kousksi_bil_hout.step6.title" = "First steam";
"recipe.tn_kousksi_bil_hout.step7.body" = "Moisten the couscous lightly with water, rub to separate grains, and return it to the steamer basket.";
"recipe.tn_kousksi_bil_hout.step7.title" = "Moisten and re-steam";
"recipe.tn_kousksi_bil_hout.step8.body" = "Steam again until the couscous is tender and fluffy, then fluff well and keep warm.";
"recipe.tn_kousksi_bil_hout.step8.title" = "Second steam and finish couscous";
"recipe.tn_kousksi_bil_hout.step9.body" = "Slide the fish into the simmering sauce and cook gently until just done, avoiding vigorous stirring so the fish stays intact.";
"recipe.tn_kousksi_bil_hout.step9.title" = "Cook the fish gently";
