"recipe.cz_vepro_knedlo_zelo.drink.body" = "A classic Czech pale lager or a light red wine pairs well with the roast pork and sauerkraut. For a non-alcoholic pairing, serve sparkling water or still water with lemon.";
"recipe.cz_vepro_knedlo_zelo.drink.summary" = "Beer (Lager)";
"recipe.cz_vepro_knedlo_zelo.info" = "Vepřo knedlo zelo is one of the most traditional dishes of Czech cuisine, made of roast pork with gravy, bread dumplings, and braised sauerkraut. It is a classic Sunday and holiday main course, valued for the balance of rich pork, soft dumplings, and sweet-sour cabbage.";
"recipe.cz_vepro_knedlo_zelo.info.summary" = "Czech roast pork plate";
"recipe.cz_vepro_knedlo_zelo.name" = "Vepřo knedlo zelo";
"recipe.cz_vepro_knedlo_zelo.step1.body" = "Pat %i1 dry, rub it all over with %i7, %i8, crushed %i2, and %i6, then place it in the roasting pan over sliced %i3 with %i4.";
"recipe.cz_vepro_knedlo_zelo.step1.title" = "Season the pork";
"recipe.cz_vepro_knedlo_zelo.step10.body" = "Lift the pork from the roasting pan and let it rest briefly. Skim excess fat from the roasting juices if needed and stir the juices so they become a simple gravy.";
"recipe.cz_vepro_knedlo_zelo.step10.title" = "Finish the gravy";
"recipe.cz_vepro_knedlo_zelo.step11.body" = "Remove the dumplings, prick them so steam can escape, and slice them.";
"recipe.cz_vepro_knedlo_zelo.step11.title" = "Slice the dumplings";
"recipe.cz_vepro_knedlo_zelo.step12.body" = "Slice the pork and serve it with the bread dumplings and braised sauerkraut, then spoon the roast gravy over the meat and dumplings.";
"recipe.cz_vepro_knedlo_zelo.step12.title" = "Serve";
"recipe.cz_vepro_knedlo_zelo.step2.body" = "Add %i5 to the pan and roast until the pork is tender and deeply browned, basting from time to time and adding a little more water if needed to keep the juices from burning.";
"recipe.cz_vepro_knedlo_zelo.step2.title" = "Roast the pork";
"recipe.cz_vepro_knedlo_zelo.step3.body" = "Rinse %i9 briefly only if very sharp, then squeeze it lightly and cut it shorter. Dice %i10 and %i11.";
"recipe.cz_vepro_knedlo_zelo.step3.title" = "Start the cabbage";
"recipe.cz_vepro_knedlo_zelo.step4.body" = "Melt %i12 in the Dutch oven, cook the bacon until it releases fat, then add the onion and cook until softened.";
"recipe.cz_vepro_knedlo_zelo.step4.title" = "Build the cabbage base";
"recipe.cz_vepro_knedlo_zelo.step5.body" = "Add the sauerkraut, %i16, %i17, %i13, and water, then cover and simmer until tender. Stir in %i14 near the end and sprinkle in %i15 so the cabbage becomes lightly thickened and glossy.";
"recipe.cz_vepro_knedlo_zelo.step5.title" = "Braise the cabbage";
"recipe.cz_vepro_knedlo_zelo.step6.body" = "Cut %i19 into small cubes. Warm %i21 slightly, crumble in %i22, and let it loosen. Mix %i18, %i20, the yeast mixture, bread cubes, and %i23 into a soft dough.";
"recipe.cz_vepro_knedlo_zelo.step6.title" = "Prepare the dumpling dough";
"recipe.cz_vepro_knedlo_zelo.step7.body" = "Cover the dough and leave it until clearly puffed and airy.";
"recipe.cz_vepro_knedlo_zelo.step7.title" = "Let the dough rise";
"recipe.cz_vepro_knedlo_zelo.step8.body" = "Divide the dough into two long loaves with floured hands and shape them evenly.";
"recipe.cz_vepro_knedlo_zelo.step8.title" = "Shape the dumplings";
"recipe.cz_vepro_knedlo_zelo.step9.body" = "Bring water to a gentle boil in the large pot and cook the dumplings until puffed and cooked through, turning them once during cooking.";
