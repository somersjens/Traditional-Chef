"recipe.se_raggmunk_med_flask.drink.body" = "A light lager or dry apple cider works well with the salty pork and crisp potato pancakes. A crisp white wine such as unoaked Chardonnay also fits. For a non-alcoholic option, serve sparkling water or tart lingonberry drink.";
"recipe.se_raggmunk_med_flask.drink.summary" = "Beer (Lager)";
"recipe.se_raggmunk_med_flask.info" = "Raggmunk med fläsk is a classic Swedish home-style dish of grated potato pancakes fried until golden and served with fried salted pork and lingonberries. It is a traditional everyday meal, especially associated with old-fashioned husmanskost, where the contrast of crisp pancake, savory pork, and tart-sweet berries is central.";
"recipe.se_raggmunk_med_flask.info.summary" = "Potato pancakes and pork";
