"recipe.ge_badrijani_nigvzit.drink.body" = "A dry Georgian amber wine such as Rkatsiteli pairs well with the walnut, garlic, and spices. A light lager also works. For a non-alcoholic option, serve sparkling mineral water or chilled unsweetened black tea with lemon.";
"recipe.ge_badrijani_nigvzit.drink.summary" = "Amber wine (Rkatsiteli)";
"recipe.ge_badrijani_nigvzit.info" = "Badrijani nigvzit is a traditional Georgian starter of thin fried eggplant slices rolled around a seasoned walnut and garlic paste, then garnished with pomegranate. It is commonly served as part of a supra table alongside other cold appetizers and salads.";
"recipe.ge_badrijani_nigvzit.info.summary" = "Walnut eggplant rolls";
"recipe.ge_badrijani_nigvzit.name" = "Badrijani nigvzit";
"recipe.ge_badrijani_nigvzit.step1.body" = "Trim the %i1 and slice them lengthwise into thin strips. Sprinkle with %i2 on both sides and place in a colander.";
"recipe.ge_badrijani_nigvzit.step1.title" = "Slice and salt eggplant";
"recipe.ge_badrijani_nigvzit.step2.body" = "Let the salted eggplant stand so bitterness and moisture release, then gently press and pat the slices dry.";
"recipe.ge_badrijani_nigvzit.step2.title" = "Drain the eggplant";
"recipe.ge_badrijani_nigvzit.step3.body" = "Grind the %i4 with %i5 and %i6 until fine, then transfer to a bowl and mix with %i7, %i8, %i9, %i10, %i12, and %i11.";
"recipe.ge_badrijani_nigvzit.step3.title" = "Make walnut filling base";
"recipe.ge_badrijani_nigvzit.step4.body" = "Mix until a smooth, thick spreadable paste forms that can hold inside the rolls.";
"recipe.ge_badrijani_nigvzit.step4.title" = "Adjust filling texture";
"recipe.ge_badrijani_nigvzit.step5.body" = "Heat %i3 in a frying pan and fry the eggplant slices in batches until soft and lightly golden on both sides. Drain on paper towels.";
"recipe.ge_badrijani_nigvzit.step5.title" = "Fry eggplant slices";
"recipe.ge_badrijani_nigvzit.step6.body" = "Let the fried eggplant cool until easy to handle and no longer steaming.";
"recipe.ge_badrijani_nigvzit.step6.title" = "Cool for rolling";
"recipe.ge_badrijani_nigvzit.step7.body" = "Spread a layer of walnut filling over each eggplant slice and roll each slice into a neat cylinder.";
"recipe.ge_badrijani_nigvzit.step7.title" = "Fill and roll";
"recipe.ge_badrijani_nigvzit.step8.body" = "Arrange the rolls on a platter, top with %i13, and serve at room temperature.";
"recipe.ge_badrijani_nigvzit.step8.title" = "Garnish and serve";
"recipe.ge_badrijani_nigvzit.tool.t1" = "Knife";
