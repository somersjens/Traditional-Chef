"recipe.bd_beef_kala_bhuna.drink.body" = "A fruit-forward Shiraz or an off-dry red with low tannins suits the roasted spices and caramelised onion depth without tasting harsh. If you prefer white, choose an aromatic, slightly off-dry Riesling. Non-alcoholic pairing: chilled lemon soda or strong black tea.";
"recipe.bd_beef_kala_bhuna.drink.summary" = "Red wine (Shiraz)";
"recipe.bd_beef_kala_bhuna.info" = "Beef kala bhuna is a traditional Bangladeshi Chittagong-style bhuna where beef is slow-cooked and repeatedly fried down with onions, mustard oil, and a robust mix of whole and ground spices until the meat turns deep brown-black and the masala clings thickly. It is served hot as a rich, intense main course alongside plain steamed rice to balance the concentrated, roasted spice flavours.";
"recipe.bd_beef_kala_bhuna.info.summary" = "Dark Chittagong beef";
"recipe.bd_beef_kala_bhuna.name" = "Beef kala bhuna";
"recipe.bd_beef_kala_bhuna.step1.body" = "Grate the %i3 and %i4, slice the %i5, and crush the %i20 lightly. Prepare the %i13, %i14, %i15, %i16, %i17, and %i18.";
"recipe.bd_beef_kala_bhuna.step1.title" = "Make the spice base";
"recipe.bd_beef_kala_bhuna.step10.body" = "Rinse the %i22. Combine it with water and a pinch of salt, bring to a simmer, then cover and cook gently until tender.";
"recipe.bd_beef_kala_bhuna.step10.title" = "Cook the rice";
"recipe.bd_beef_kala_bhuna.step11.body" = "Rest the rice covered so it fluffs up, then serve the kala bhuna hot with the steamed rice.";
"recipe.bd_beef_kala_bhuna.step11.title" = "Rest and serve";
"recipe.bd_beef_kala_bhuna.step2.body" = "In a bowl, coat the %i1 with ginger, garlic, green chilies, %i7, %i8, %i9, %i10, %i11, %i12, and some of the %i6 until evenly covered.";
"recipe.bd_beef_kala_bhuna.step2.title" = "Marinate the beef";
"recipe.bd_beef_kala_bhuna.step3.body" = "Cover and refrigerate so the spices penetrate the beef.";
"recipe.bd_beef_kala_bhuna.step3.title" = "Rest the marinade";
"recipe.bd_beef_kala_bhuna.step4.body" = "Heat the remaining mustard oil in a heavy pot and cook the %i2 slowly until very deep brown and caramelised, stirring so they do not burn.";
"recipe.bd_beef_kala_bhuna.step4.title" = "Brown the onions deeply";
"recipe.bd_beef_kala_bhuna.step5.body" = "Add the cinnamon, bay leaves, cardamom, cloves, and mace to the browned onions and fry briefly until aromatic.";
"recipe.bd_beef_kala_bhuna.step5.title" = "Bloom whole spices";
"recipe.bd_beef_kala_bhuna.step6.body" = "Add the marinated beef and cook on medium-high heat, stirring continuously, until the meat tightens and the masala darkens and begins to cling.";
"recipe.bd_beef_kala_bhuna.step6.title" = "Bhuna the beef";
"recipe.bd_beef_kala_bhuna.step7.body" = "Continue stirring and frying until moisture reduces and the oil separates from the masala and the colour becomes very dark.";
"recipe.bd_beef_kala_bhuna.step7.title" = "Fry down to oil separation";
"recipe.bd_beef_kala_bhuna.step8.body" = "Add %i23 gradually to maintain a gentle simmer, cover, and cook until the beef is tender, uncovering occasionally to stir and prevent sticking.";
"recipe.bd_beef_kala_bhuna.step8.title" = "Slow cook until tender";
"recipe.bd_beef_kala_bhuna.step9.body" = "Remove the lid and fry the beef and masala again, stirring until thick, glossy, and very dark, then stir in the %i21 and %i19.";
"recipe.bd_beef_kala_bhuna.step9.title" = "Final kala bhuna finish";
