"recipe.gb_treacle_tart.drink.body" = "A small glass of sweet sherry or a light dessert wine complements the syrupy citrus filling. For a non-alcoholic option, serve hot black tea or coffee with the tart.";
"recipe.gb_treacle_tart.drink.summary" = "Sweet sherry";
"recipe.gb_treacle_tart.info" = "A traditional British tart with a crisp shortcrust pastry case filled with golden syrup, fresh breadcrumbs, lemon, and butter, baked until just set and served warm. It is a classic teatime and pudding dessert, commonly served with clotted cream or custard.";
"recipe.gb_treacle_tart.info.summary" = "Golden syrup tart";
"recipe.gb_treacle_tart.name" = "Treacle tart";
"recipe.gb_treacle_tart.step1.body" = "Rub the %i2 into the %i1 and %i3, then add cold %i4 to bring the pastry together and form a smooth dough.";
"recipe.gb_treacle_tart.step1.title" = "Make pastry dough";
"recipe.gb_treacle_tart.step2.body" = "Wrap and chill the pastry until firm enough to roll.";
"recipe.gb_treacle_tart.step2.title" = "Chill pastry";
"recipe.gb_treacle_tart.step3.body" = "Roll out the pastry, line the tart tin, trim the edges, and chill the lined case briefly.";
"recipe.gb_treacle_tart.step3.title" = "Line tart tin";
"recipe.gb_treacle_tart.step4.body" = "Line the pastry with parchment and baking beans, bake until set, then remove the beans and parchment and bake briefly again to dry the base.";
"recipe.gb_treacle_tart.step4.title" = "Blind bake case";
"recipe.gb_treacle_tart.step5.body" = "Warm the %i5 and %i7 gently, then stir in the %i6, lemon zest, lemon juice, and %i9 until evenly combined.";
"recipe.gb_treacle_tart.step5.title" = "Prepare filling";
"recipe.gb_treacle_tart.step6.body" = "Spoon the filling into the baked pastry case and level the surface.";
"recipe.gb_treacle_tart.step6.title" = "Fill tart";
"recipe.gb_treacle_tart.step7.body" = "Bake until the filling is just set and lightly golden on top with a slight wobble in the centre.";
"recipe.gb_treacle_tart.step7.title" = "Bake tart";
"recipe.gb_treacle_tart.step8.body" = "Let the tart stand so the filling settles and slices neatly while still warm.";
"recipe.gb_treacle_tart.step8.title" = "Cool slightly";
"recipe.gb_treacle_tart.step9.body" = "Slice and serve warm with %i10.";
"recipe.gb_treacle_tart.step9.title" = "Serve";
