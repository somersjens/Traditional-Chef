"recipe.it_cannoli_siciliani.drink.body" = "Pair with a small glass of Marsala or a lightly sparkling sweet wine such as Moscato to echo the pastry and ricotta. Non-alcoholic option: espresso or sparkling water with a twist of orange.";
"recipe.it_cannoli_siciliani.drink.summary" = "Marsala";
"recipe.it_cannoli_siciliani.info" = "Traditional Sicilian cannoli are crisp fried pastry shells wrapped around a tube and filled at the last moment with sweetened ricotta, often scented with citrus and a touch of spice. Served as a celebratory pastry in bars and homes, they are best enjoyed soon after filling so the shell stays shatteringly crisp.";
"recipe.it_cannoli_siciliani.info.summary" = "Sicilian pastry classic";
"recipe.it_cannoli_siciliani.name" = "Cannoli";
