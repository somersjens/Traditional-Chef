"recipe.nz_boil_up.drink.body" = "A dry Pinot Gris works with the rich pork broth and earthy greens without overpowering the dish. A light pale ale also suits it well. For a non-alcoholic option, serve hot black tea or plain sparkling water.";
"recipe.nz_boil_up.drink.summary" = "White wine (Pinot Gris)";
"recipe.nz_boil_up.info" = "Boil-up is a traditional Māori one-pot meal from Aotearoa New Zealand, built around pork bones simmered into a rich broth with pūhā, root vegetables, and flour dumplings known as doughboys. It is hearty family food, commonly served straight from the pot as a sustaining shared meal.";
"recipe.nz_boil_up.info.summary" = "Māori pork boil-up";
"recipe.nz_boil_up.name" = "Boil-up";
"recipe.nz_boil_up.step1.body" = "Wash the %i4 thoroughly and remove tough stems. Peel and cut the %i5 and %i6 into large chunks.";
"recipe.nz_boil_up.step1.title" = "Prepare the ingredients";
"recipe.nz_boil_up.step2.body" = "Place the %i1 in a large stockpot with %i2 and %i3. Bring to a boil, lower to a gentle simmer, cover, and cook until the broth is rich and the meat is tender.";
"recipe.nz_boil_up.step2.title" = "Simmer the pork bones";
"recipe.nz_boil_up.step3.body" = "Add the potato and kūmara to the pot and continue cooking at a gentle simmer so the vegetables begin to soften in the broth.";
"recipe.nz_boil_up.step3.title" = "Add the root vegetables";
"recipe.nz_boil_up.step4.body" = "Mix the %i7 with the remaining salt in a bowl, add the %i9, and bring it together into a soft dough. Divide the dough into even balls.";
"recipe.nz_boil_up.step4.title" = "Make the doughboys";
"recipe.nz_boil_up.step5.body" = "Lay the pūhā over the meat and vegetables, then place the doughboys on top so they steam and absorb the broth.";
"recipe.nz_boil_up.step5.title" = "Add pūhā and doughboys";
"recipe.nz_boil_up.step6.body" = "Cover the pot and cook gently until the pūhā is tender, the doughboys are cooked through, and the vegetables are fully soft.";
"recipe.nz_boil_up.step6.title" = "Finish the boil-up";
"recipe.nz_boil_up.step7.body" = "Ladle the broth, pork bones, pūhā, vegetables, and doughboys into bowls and serve hot in the traditional style.";
"recipe.nz_boil_up.step7.title" = "Serve from the pot";
"recipe.nz_boil_up.tool.t1" = "Large stockpot";
"recipe.nz_boil_up.tool.t2" = "Chef knife";
"recipe.nz_boil_up.tool.t3" = "Cutting board";
"recipe.nz_boil_up.tool.t4" = "Mixing bowl";
"recipe.nz_boil_up.tool.t5" = "Wooden spoon";
