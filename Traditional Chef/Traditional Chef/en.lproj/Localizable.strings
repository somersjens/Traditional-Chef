"recipe.tn_salade_mechouia.drink.body" = "A dry rosé pairs well with the smoky grilled vegetables and briny toppings. For a non-alcoholic option, serve hot Tunisian mint tea or sparkling water with lemon.";
"recipe.tn_salade_mechouia.drink.summary" = "Rosé wine";
"recipe.tn_salade_mechouia.info" = "Salade Mechouia is a traditional Tunisian salad of char-grilled peppers and tomatoes that are peeled, finely chopped, and dressed with olive oil, lemon, and spices, then served with classic toppings like tuna, hard-boiled eggs, and olives, typically eaten with bread as a mezze or light starter.";
"recipe.tn_salade_mechouia.info.summary" = "Charred salad classic";
"recipe.tn_salade_mechouia.name" = "Mechouia salad";
"recipe.tn_salade_mechouia.step1.body" = "Char the %i1 and %i2 over a grill or under a broiler, turning until the skins blister and blacken and the vegetables soften.";
"recipe.tn_salade_mechouia.step1.title" = "Char the vegetables";
"recipe.tn_salade_mechouia.step2.body" = "Transfer the hot vegetables to a bowl, cover to steam, then peel off the skins and remove the pepper seeds and cores.";
"recipe.tn_salade_mechouia.step2.title" = "Steam and peel";
"recipe.tn_salade_mechouia.step3.body" = "Bring %i14 to a boil, add the %i10, and cook until hard-boiled, then cool and peel.";
"recipe.tn_salade_mechouia.step3.title" = "Boil the eggs";
"recipe.tn_salade_mechouia.step4.body" = "Finely chop the peeled grilled peppers and tomatoes, then chop the %i3 and crush the %i4 and combine everything into a coarse, spoonable mixture.";
"recipe.tn_salade_mechouia.step4.title" = "Chop the salad base";
"recipe.tn_salade_mechouia.step5.body" = "Add %i5, %i6, %i7, and %i8, then mix until glossy and well seasoned.";
"recipe.tn_salade_mechouia.step5.title" = "Dress and season";
"recipe.tn_salade_mechouia.step6.body" = "Spread the salad on a platter, top with %i9, quartered eggs, %i11, and %i12.";
"recipe.tn_salade_mechouia.step6.title" = "Add traditional toppings";
"recipe.tn_salade_mechouia.step7.body" = "Serve immediately with %i13 for scooping.";
"recipe.tn_salade_mechouia.step7.title" = "Serve";
