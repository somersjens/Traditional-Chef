"recipe.nz_pavlova.drink.body" = "A light dessert wine such as late harvest Riesling pairs well with the sweet meringue and tart fruit. For a non-alcoholic option, serve hot black tea or sparkling water with lemon.";
"recipe.nz_pavlova.drink.summary" = "Dessert wine";
"recipe.nz_pavlova.info" = "Pavlova is a classic New Zealand celebration dessert with a crisp shell and soft marshmallow-like centre. It is traditionally served with whipped cream and fresh fruit, especially kiwifruit and passionfruit, and is closely associated with summer gatherings and Christmas tables.";
"recipe.nz_pavlova.info.summary" = "Kiwi pavlova classic";
"recipe.nz_pavlova.name" = "Pavlova";
"recipe.nz_pavlova.step1.body" = "Heat the oven and line a baking tray with baking paper. Make sure the bowl and beaters are perfectly clean and dry.";
"recipe.nz_pavlova.step1.title" = "Prepare the oven and tray";
"recipe.nz_pavlova.step2.body" = "Beat %i1 with %i6 until soft peaks form, then gradually add %i2 and continue beating until the mixture is thick and glossy.";
"recipe.nz_pavlova.step2.title" = "Whisk the egg whites";
"recipe.nz_pavlova.step3.body" = "Fold in %i3, %i4, and %i5 gently so the mixture stays light and voluminous.";
"recipe.nz_pavlova.step3.title" = "Finish the meringue";
"recipe.nz_pavlova.step4.body" = "Spoon the mixture onto the lined tray and shape it into a round with slightly higher edges and a shallow hollow in the centre.";
"recipe.nz_pavlova.step4.title" = "Shape the pavlova";
"recipe.nz_pavlova.step5.body" = "Bake the pavlova at a low temperature until the outside is crisp and dry.";
"recipe.nz_pavlova.step5.title" = "Bake the shell";
"recipe.nz_pavlova.step6.body" = "Turn off the oven and leave the pavlova inside to cool fully so the shell sets and the centre stays soft.";
"recipe.nz_pavlova.step6.title" = "Cool completely";
"recipe.nz_pavlova.step7.body" = "Whip %i7 until thick, peel and slice %i8, and halve %i9.";
"recipe.nz_pavlova.step7.title" = "Prepare the topping";
"recipe.nz_pavlova.step8.body" = "Transfer the pavlova carefully to a serving plate, fill the centre with whipped cream, top with the kiwifruit and passionfruit, and serve immediately.";
"recipe.nz_pavlova.step8.title" = "Assemble and serve";
