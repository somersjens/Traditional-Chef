"recipe.ca_jiggs_dinner.drink.body" = "A dry cider suits the salty beef and sweet root vegetables without overpowering the meal. A light crisp white can also work, and sparkling apple cider is a good non-alcoholic pairing.";
"recipe.ca_jiggs_dinner.drink.summary" = "Cider";
"recipe.ca_jiggs_dinner.info" = "Jiggs Dinner is a traditional Newfoundland boiled meal of salt beef, potatoes, cabbage, turnip, carrots, parsnip, and pease pudding cooked together in one pot. It is a classic Sunday and holiday family dinner, served hot with pot liquor spooned over the plate.";
"recipe.ca_jiggs_dinner.info.summary" = "Newfoundland boiled dinner";
"recipe.ca_jiggs_dinner.name" = "Jiggs dinner";
"recipe.ca_jiggs_dinner.step1.body" = "Soak the %i1 in cold %i2 in a large bowl. Put the %i3 into a pudding bag, tie it securely, and soak it in cold water overnight.";
"recipe.ca_jiggs_dinner.step1.title" = "Soak the beef and peas";
"recipe.ca_jiggs_dinner.step2.body" = "Peel the %i11, %i10, %i12, and %i13. Cut the %i9 into wedges, slice the turnip, halve the carrots and parsnips, and leave the %i8 whole.";
"recipe.ca_jiggs_dinner.step2.title" = "Prepare the vegetables";
"recipe.ca_jiggs_dinner.step3.body" = "Drain the soaked beef and place it in a large pot with fresh water and the onion. Bring to a boil, then lower the heat.";
"recipe.ca_jiggs_dinner.step3.title" = "Start the boiler";
"recipe.ca_jiggs_dinner.step4.body" = "Add the bag of soaked peas to the pot and simmer gently until the beef begins to soften and the peas are tender.";
"recipe.ca_jiggs_dinner.step4.title" = "Cook the beef and peas";
"recipe.ca_jiggs_dinner.step5.body" = "Add the cabbage and turnip to the pot and continue cooking gently.";
"recipe.ca_jiggs_dinner.step5.title" = "Add the first vegetables";
"recipe.ca_jiggs_dinner.step6.body" = "Add the potatoes, carrots, and parsnips, then simmer until all the vegetables are tender and the beef is fully cooked.";
"recipe.ca_jiggs_dinner.step6.title" = "Add the remaining vegetables";
"recipe.ca_jiggs_dinner.step7.body" = "Lift out the pea bag, empty the cooked peas into a bowl, and mash them with the %i5 and %i6 until smooth and thick.";
"recipe.ca_jiggs_dinner.step7.title" = "Finish the pease pudding";
"recipe.ca_jiggs_dinner.step8.body" = "Remove the beef and vegetables from the pot and arrange them on a warm serving platter or in separate bowls.";
"recipe.ca_jiggs_dinner.step8.title" = "Arrange the dinner";
"recipe.ca_jiggs_dinner.step9.body" = "Serve the Jiggs Dinner hot with the pease pudding alongside and ladle some pot liquor from the boiler over each portion.";
"recipe.ca_jiggs_dinner.step9.title" = "Serve with pot liquor";
