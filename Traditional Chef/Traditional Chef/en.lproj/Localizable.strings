"recipe.pl_sernik.step5.title" = "Prepare the cheese filling";
"recipe.pl_sernik.step6.body" = "Mix the smooth twarog into the butter mixture, then add %i12, %i14, and %i13 and fold until evenly combined.";
"recipe.pl_sernik.step6.title" = "Finish the filling";
"recipe.pl_sernik.step7.body" = "Spread the filling over the prebaked crust. Roll the reserved dough and cut strips, lay them in a lattice on top, and brush the lattice with beaten %i15.";
"recipe.pl_sernik.step7.title" = "Assemble with lattice";
"recipe.pl_sernik.step8.body" = "Bake until the filling is set and the top is golden, with only a slight wobble in the center.";
"recipe.pl_sernik.step8.title" = "Bake until set";
"recipe.pl_sernik.step9.body" = "Let the cheesecake cool so it sets without cracking, then remove the ring once it is no longer warm.";
"recipe.pl_sernik.step9.title" = "Cool gradually";
