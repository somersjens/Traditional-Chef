"recipe.sy_mabroumeh.step4.title" = "Prepare the kataifi";
"recipe.sy_mabroumeh.step5.body" = "Melt the %i9, then drizzle and work it through the kataifi with your hands until evenly coated and glossy.";
"recipe.sy_mabroumeh.step5.title" = "Butter the kataifi";
"recipe.sy_mabroumeh.step6.body" = "Spread a layer of kataifi, place the drained cheese along one edge, and roll tightly into a long log, pressing gently so it holds together. Repeat to use all the mixture.";
"recipe.sy_mabroumeh.step6.title" = "Form the rolls";
"recipe.sy_mabroumeh.step7.body" = "Line a tray, place the rolls seam-side down, and brush any remaining butter over the surface.";
"recipe.sy_mabroumeh.step7.title" = "Arrange for baking";
"recipe.sy_mabroumeh.step8.body" = "Bake until the mabroumeh is crisp and richly golden all over, rotating the tray if needed for even color.";
"recipe.sy_mabroumeh.step8.title" = "Bake until deeply golden";
