"recipe.bd_mishti_doi.step6.title" = "Fill the bowls";
"recipe.bd_mishti_doi.step7.body" = "Place the tray in a warm oven (switched off but warm) and leave undisturbed until the yogurt is set.";
"recipe.bd_mishti_doi.step7.title" = "Incubate to set";
"recipe.bd_mishti_doi.step8.body" = "Refrigerate until thoroughly chilled, then serve the mishti doi cold.";
"recipe.bd_mishti_doi.step8.title" = "Chill and serve";
