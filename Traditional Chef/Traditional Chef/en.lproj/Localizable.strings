"recipe.az_kufta_bozbash.step1.title" = "Soak the chickpeas";
"recipe.az_kufta_bozbash.step10.body" = "Simmer gently until the meatballs are cooked through, the potatoes are tender, and the broth is rich and aromatic.";
"recipe.az_kufta_bozbash.step10.title" = "Finish the kufta bozbash";
"recipe.az_kufta_bozbash.step11.body" = "Ladle one large meatball into each bowl with chickpeas, potatoes, and broth, then scatter %i15 over the top and serve hot.";
"recipe.az_kufta_bozbash.step11.title" = "Serve the soup";
"recipe.az_kufta_bozbash.step2.body" = "Steep %i5 in a little hot %i7 until the color and aroma are fully released.";
