"recipe.tw_san_bei_ji.step8.title" = "Rest the rice";
"recipe.tw_san_bei_ji.step9.body" = "Spoon rice into bowls and serve the three cup chicken hot over or alongside the rice.";
"recipe.tw_san_bei_ji.step9.title" = "Serve";
