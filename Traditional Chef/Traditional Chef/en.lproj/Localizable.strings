"recipe.hk_double_skin_milk.drink.body" = "This dessert is traditionally paired with tea rather than wine, especially jasmine tea. If serving wine, a very light off-dry white can work, while hot jasmine tea or warm water is the classic non-alcoholic pairing.";
"recipe.hk_double_skin_milk.drink.summary" = "Jasmine tea";
"recipe.hk_double_skin_milk.info" = "A traditional Cantonese milk pudding with a delicate double skin, usually served warm or chilled in individual bowls. It is a classic dessert in Hong Kong-style dessert shops and is made simply from milk, egg white, and sugar using a gentle steaming method.";
"recipe.hk_double_skin_milk.info.summary" = "Double-skin milk pudding";
"recipe.hk_double_skin_milk.name" = "Double skin milk";
"recipe.hk_double_skin_milk.step1.body" = "Warm the %i1 with %i3 in a small saucepan over low heat until the sugar dissolves and the milk is hot but not boiling.";
"recipe.hk_double_skin_milk.step1.title" = "Heat the milk";
"recipe.hk_double_skin_milk.step10.body" = "Serve warm for a traditional dessert-shop style, or cool completely and chill before serving.";
"recipe.hk_double_skin_milk.step10.title" = "Serve";
"recipe.hk_double_skin_milk.step2.body" = "Pour the hot milk into individual heatproof bowls and let it stand until a milk skin forms on the surface.";
"recipe.hk_double_skin_milk.step2.title" = "Form the first skin";
"recipe.hk_double_skin_milk.step3.body" = "Beat the %i2 gently in a bowl just until loosened, without creating much foam.";
"recipe.hk_double_skin_milk.step3.title" = "Prepare the egg whites";
"recipe.hk_double_skin_milk.step4.body" = "Use a spoon to hold the milk skin in each bowl, pour most of the milk into the egg whites, and leave a little milk behind so the skin stays attached in the bowls.";
"recipe.hk_double_skin_milk.step4.title" = "Drain milk under the skin";
"recipe.hk_double_skin_milk.step5.body" = "Stir the warm milk into the egg whites gently until combined, then strain the mixture for a smooth texture.";
"recipe.hk_double_skin_milk.step5.title" = "Mix and strain the custard";
"recipe.hk_double_skin_milk.step6.body" = "Pour the strained mixture back into the bowls so the first milk skin floats back up to the surface.";
"recipe.hk_double_skin_milk.step6.title" = "Refill the bowls";
"recipe.hk_double_skin_milk.step7.body" = "Add %i4 to the steamer and bring it to a gentle boil.";
"recipe.hk_double_skin_milk.step7.title" = "Prepare the steamer";
"recipe.hk_double_skin_milk.step8.body" = "Place the bowls in the steamer and steam over low heat until the pudding is just set with a slight wobble.";
"recipe.hk_double_skin_milk.step8.title" = "Steam gently";
"recipe.hk_double_skin_milk.step9.body" = "Turn off the heat and let the bowls rest covered briefly so the custard finishes setting gently.";
"recipe.hk_double_skin_milk.step9.title" = "Rest after steaming";
