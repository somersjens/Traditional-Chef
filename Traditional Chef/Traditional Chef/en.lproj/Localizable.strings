"recipe.sn_ngalakh.drink.body" = "A lightly chilled sweet white wine such as Muscat pairs nicely with the nutty sweetness and baobab tang. For a non-alcoholic option, serve hot Senegalese mint tea or chilled bissap (hibiscus drink).";
"recipe.sn_ngalakh.drink.summary" = "Sweet wine (Muscat)";
"recipe.sn_ngalakh.info" = "Ngalakh is a traditional Senegalese dessert of steamed millet couscous folded into a sweet, tangy baobab-and-peanut cream, typically served chilled or at cool room temperature in bowls for celebrations and family gatherings.";
"recipe.sn_ngalakh.info.summary" = "Baobab peanut dessert";
"recipe.sn_ngalakh.name" = "Ngalakh";
"recipe.sn_ngalakh.step1.body" = "Place the %i1 in a bowl and moisten it with %i2, rubbing between your hands to separate grains.";
"recipe.sn_ngalakh.step1.title" = "Prepare the couscous";
"recipe.sn_ngalakh.step2.body" = "Transfer the couscous to a steamer and steam until the grains swell and become tender, then tip into a bowl.";
"recipe.sn_ngalakh.step2.title" = "Steam the couscous";
"recipe.sn_ngalakh.step3.body" = "Fluff the couscous thoroughly with a spoon to break up clumps and let it cool until just warm.";
"recipe.sn_ngalakh.step3.title" = "Fluff and cool";
"recipe.sn_ngalakh.step4.body" = "Sift the %i4 into a bowl, add %i6, and whisk until smooth with no lumps.";
"recipe.sn_ngalakh.step4.title" = "Make the baobab base";
"recipe.sn_ngalakh.step5.body" = "Whisk in %i3 until fully emulsified, then whisk in %i5 and %i7 until dissolved and creamy.";
"recipe.sn_ngalakh.step5.title" = "Whisk in peanut and sugar";
"recipe.sn_ngalakh.step6.body" = "Fold the cooled couscous into the peanut-baobab cream until evenly coated and thickly spoonable.";
"recipe.sn_ngalakh.step6.title" = "Combine";
"recipe.sn_ngalakh.step7.body" = "Cover and chill until the flavors meld and the mixture firms slightly, then portion into bowls and serve.";
"recipe.sn_ngalakh.step7.title" = "Chill to set";
