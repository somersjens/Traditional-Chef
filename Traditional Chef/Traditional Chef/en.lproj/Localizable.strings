"recipe.jp_agedashi_tofu.drink.body" = "Dry sake or a crisp Japanese lager pairs well with the delicate tofu and umami dashi broth. For a non-alcoholic pairing, serve hot green tea or chilled barley tea.";
"recipe.jp_agedashi_tofu.drink.summary" = "Sake";
"recipe.jp_agedashi_tofu.info" = "Agedashi tofu is a traditional Japanese dish of lightly fried silken or soft tofu served in a warm savory dashi-based broth and topped with classic condiments such as grated daikon, ginger, scallions, and bonito flakes. It is commonly served as an appetizer or small side in home meals and izakaya-style dining.";
"recipe.jp_agedashi_tofu.info.summary" = "Fried tofu in dashi";
"recipe.jp_agedashi_tofu.name" = "Agedashi tofu";
"recipe.jp_agedashi_tofu.step1.body" = "Remove the %i1 from its packaging, place it on a towel-lined tray, and let it drain so excess moisture releases before frying.";
"recipe.jp_agedashi_tofu.step1.title" = "Drain the tofu";
"recipe.jp_agedashi_tofu.step2.body" = "Grate the %i8 and %i9, slice the %i10, and lightly squeeze the grated daikon so it is moist but not watery.";
"recipe.jp_agedashi_tofu.step2.title" = "Prepare garnishes";
"recipe.jp_agedashi_tofu.step3.body" = "Combine %i4, %i5, %i6, and %i7 in a small saucepan, bring to a gentle simmer, and keep warm.";
"recipe.jp_agedashi_tofu.step3.title" = "Make the agedashi broth";
"recipe.jp_agedashi_tofu.step4.body" = "Cut the drained tofu into serving pieces, pat dry again, then coat each piece evenly with %i2 and shake off excess.";
"recipe.jp_agedashi_tofu.step4.title" = "Cut and coat the tofu";
"recipe.jp_agedashi_tofu.step5.body" = "Heat the %i3 in a deep pot until ready for frying, keeping the heat steady so the coating crisps without burning.";
"recipe.jp_agedashi_tofu.step5.title" = "Heat the frying oil";
"recipe.jp_agedashi_tofu.step6.body" = "Fry the coated tofu in batches until the surface is lightly golden and crisp, then lift out and drain briefly.";
"recipe.jp_agedashi_tofu.step6.title" = "Fry the tofu";
"recipe.jp_agedashi_tofu.step7.body" = "Place the hot fried tofu in shallow bowls and pour the warm broth around the tofu so the tops stay partly crisp.";
"recipe.jp_agedashi_tofu.step7.title" = "Assemble the bowls";
"recipe.jp_agedashi_tofu.step8.body" = "Top with grated daikon, grated ginger, scallions, and %i11, then serve immediately while the tofu is hot and crisp.";
"recipe.jp_agedashi_tofu.step8.title" = "Finish and serve";
