"recipe.us_nm_green_chile_stew.step6.title" = "Cook the potatoes";
"recipe.us_nm_green_chile_stew.step7.body" = "Remove the bay leaf, taste and adjust salt, then ladle into bowls and serve hot with %i13 for dipping and scooping.";
"recipe.us_nm_green_chile_stew.step7.title" = "Finish and serve";
