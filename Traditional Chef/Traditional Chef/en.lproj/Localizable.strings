"recipe.dk_skipperlabskovs.drink.body" = "A dark lager or a light amber beer matches the rich beef and soft potatoes well. For a non-alcoholic option, serve sparkling water or cold water with lemon.";
"recipe.dk_skipperlabskovs.drink.summary" = "Beer (Dark lager)";
"recipe.dk_skipperlabskovs.info" = "Skipperlabskovs is a traditional Danish sailor-style stew of beef, onions, and potatoes cooked slowly until the meat is tender and some of the potatoes break down to thicken the dish. It is a hearty cold-weather main course traditionally served hot with rye bread, pickled beetroot, chives, and a little butter.";
"recipe.dk_skipperlabskovs.info.summary" = "Sailor beef stew";
"recipe.dk_skipperlabskovs.name" = "Skipperlabskovs";
"recipe.dk_skipperlabskovs.step1.body" = "Cut %i1 into cubes, slice %i2, peel %i3, and cut the potatoes into large pieces. Keep %i10 ready for serving.";
"recipe.dk_skipperlabskovs.step1.title" = "Prepare the ingredients";
"recipe.dk_skipperlabskovs.step2.body" = "Melt the larger part of %i7 in the heavy pot, add the beef and onion, and cook until the meat loses its raw color and the onion begins to soften.";
"recipe.dk_skipperlabskovs.step2.title" = "Start the stew";
"recipe.dk_skipperlabskovs.step3.body" = "Add the potatoes, %i4, %i5, %i6, %i8, and %i9, then bring the pot to a gentle boil.";
"recipe.dk_skipperlabskovs.step3.title" = "Add the seasoning";
"recipe.dk_skipperlabskovs.step4.body" = "Cover and simmer gently until the beef is tender and the potatoes are very soft. Stir from time to time, and during the last part of cooking stir more firmly so some of the potatoes break down and thicken the stew.";
"recipe.dk_skipperlabskovs.step4.title" = "Simmer until tender";
"recipe.dk_skipperlabskovs.step5.body" = "Remove the bay leaf and peppercorns, then stir in the remaining butter so the stew turns glossy and rich. Taste and adjust the seasoning.";
"recipe.dk_skipperlabskovs.step5.title" = "Finish the texture";
"recipe.dk_skipperlabskovs.step6.body" = "Ladle the skipperlabskovs into deep plates, scatter over the chives, and serve immediately with %i12, %i13, and small pieces of %i11.";
"recipe.dk_skipperlabskovs.step6.title" = "Serve";
