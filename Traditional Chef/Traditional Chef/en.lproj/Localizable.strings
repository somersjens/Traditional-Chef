"recipe.fi_karjalanpaisti.drink.body" = "A light, fresh red wine such as Pinot Noir pairs well with the long-cooked meats and broth. A good non-alcoholic option is cold water or a tart lingonberry drink.";
"recipe.fi_karjalanpaisti.drink.summary" = "Red wine (Pinot Noir)";
"recipe.fi_karjalanpaisti.info" = "Karjalanpaisti is a traditional Karelian meat stew from eastern Finland, slowly cooked until the meats become tender and the broth turns deeply savoury. The classic version combines beef, pork, and lamb with onion, carrot, black pepper, and bay, and it is traditionally served hot with boiled potatoes and lingonberries.";
"recipe.fi_karjalanpaisti.info.summary" = "Karelian meat stew";
"recipe.fi_karjalanpaisti.name" = "Karelian stew";
"recipe.fi_karjalanpaisti.step1.body" = "Cut %i1, %i2, and %i3 into large stew pieces. Peel and quarter %i4 and peel and cut %i5 into thick pieces.";
"recipe.fi_karjalanpaisti.step1.title" = "Prepare the ingredients";
"recipe.fi_karjalanpaisti.step2.body" = "Place the meats in the ovenproof pot with the onion, carrot, %i6, %i7, and %i8, mixing the contents lightly as you fill the pot.";
"recipe.fi_karjalanpaisti.step2.title" = "Fill the pot";
"recipe.fi_karjalanpaisti.step3.body" = "Pour in %i9 so the ingredients are mostly covered, then cover the pot with the lid.";
"recipe.fi_karjalanpaisti.step3.title" = "Add water";
"recipe.fi_karjalanpaisti.step4.body" = "Cook the stew gently in the oven until the meats are fully tender and the broth is rich and deeply flavoured.";
"recipe.fi_karjalanpaisti.step4.title" = "Slow-cook the stew";
"recipe.fi_karjalanpaisti.step5.body" = "Near the end of cooking, boil %i10 in water with water until tender, then drain them well.";
"recipe.fi_karjalanpaisti.step5.title" = "Boil the potatoes";
"recipe.fi_karjalanpaisti.step6.body" = "Ladle the karjalanpaisti into deep plates with some broth, serve it hot with the boiled potatoes, and add %i13 alongside.";
"recipe.fi_karjalanpaisti.step6.title" = "Serve";
"recipe.fi_karjalanpaisti.tool.t1" = "Large ovenproof pot";
"recipe.fi_karjalanpaisti.tool.t2" = "Cutting board";
"recipe.fi_karjalanpaisti.tool.t3" = "Chef knife";
