"recipe.mu_biryani_mauricien.drink.body" = "Choose a medium-bodied red like Grenache or a spicy Syrah to match the fried onions and warm spices without overpowering the herbs. If you prefer white, an aromatic off-dry Riesling works well with the chili and fragrant rice. Non-alcoholic pairing: chilled sparkling water with lemon or a lightly sweet mint-lemonade.";
"recipe.mu_biryani_mauricien.drink.summary" = "Red wine (Grenache)";
"recipe.mu_biryani_mauricien.info" = "Mauritian biryani (briani) is a celebratory layered rice dish cooked in the Muslim Mauritian style, featuring marinated chicken, fried potatoes, lots of fried onions, aromatic spices, fresh herbs, and basmati rice finished gently on dum. It is traditionally served hot with a fresh tomato chutney on the side to cut through the richness.";
"recipe.mu_biryani_mauricien.info.summary" = "Mauritian festive briani";
"recipe.mu_biryani_mauricien.name" = "Chicken biryani";
"recipe.mu_biryani_mauricien.step1.body" = "Rinse the %i9 until the water runs mostly clear, then cover with %i10 and let it soak while you prepare everything else.";
"recipe.mu_biryani_mauricien.step1.title" = "Wash and soak rice";
"recipe.mu_biryani_mauricien.step10.body" = "Warm the %i22 and crumble in the %i21. Let it steep until strongly colored and aromatic.";
"recipe.mu_biryani_mauricien.step10.title" = "Saffron milk";
"recipe.mu_biryani_mauricien.step11.body" = "Spread half the drained parboiled rice over the chicken and potatoes. Scatter some remaining mint, coriander, and fried onions. Add the remaining rice on top and finish with the rest of the fried onions and the saffron milk drizzled over the surface.";
"recipe.mu_biryani_mauricien.step11.title" = "Layer the biryani";
"recipe.mu_biryani_mauricien.step12.body" = "Cover the pot tightly (seal with foil if needed), then cook on very low heat so the steam finishes the rice and melds the layers.";
"recipe.mu_biryani_mauricien.step12.title" = "Dum cook (steam finish)";
"recipe.mu_biryani_mauricien.step13.body" = "Turn off the heat and let the biryani rest covered so the steam settles and the rice firms up.";
"recipe.mu_biryani_mauricien.step13.title" = "Rest before serving";
"recipe.mu_biryani_mauricien.step14.body" = "Finely chop the %i23, %i24, %i25, and %i26. Mix with salt and %i27 and let it sit briefly so the juices combine.";
"recipe.mu_biryani_mauricien.step14.title" = "Make tomato chutney";
"recipe.mu_biryani_mauricien.step15.body" = "Gently lift and mix the biryani from the bottom to bring masala through the rice without crushing the grains. Serve hot with the fresh tomato chutney on the side.";
"recipe.mu_biryani_mauricien.step15.title" = "Serve";
"recipe.mu_biryani_mauricien.step2.body" = "Slice all the %i19. Blend about one third of the onions with a little water to make a smooth onion paste and set aside. Keep the remaining sliced onions for frying.";
"recipe.mu_biryani_mauricien.step2.title" = "Make onion paste-base";
"recipe.mu_biryani_mauricien.step3.body" = "Combine the %i1 with %i2, %i3, %i5, %i6, %i7, %i20, and some chopped %i15 and %i16. Mix thoroughly so everything is well coated.";
"recipe.mu_biryani_mauricien.step3.title" = "Marinate the chicken";
"recipe.mu_biryani_mauricien.step4.body" = "Cover and rest the marinated chicken so the flavors penetrate.";
"recipe.mu_biryani_mauricien.step4.title" = "Rest the marinade";
"recipe.mu_biryani_mauricien.step5.body" = "Heat %i18 in a skillet and fry the sliced onions in batches until deep golden and crisp. Drain well. Reserve a generous handful for topping and the rest for the masala.";
"recipe.mu_biryani_mauricien.step5.title" = "Fry onions";
"recipe.mu_biryani_mauricien.step6.body" = "Peel and cut the %i8 into large chunks. Fry until golden outside and just tender. Drain well and set aside.";
"recipe.mu_biryani_mauricien.step6.title" = "Fry potatoes";
