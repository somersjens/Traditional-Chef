"recipe.dk_rodgrod_med_flode.drink.body" = "A lightly sweet white dessert wine pairs gently with the tart berries and cream. For a non-alcoholic option, serve cold water or unsweetened black tea.";
"recipe.dk_rodgrod_med_flode.drink.summary" = "Dessert wine";
"recipe.dk_rodgrod_med_flode.info" = "Rødgrød med fløde is a classic Danish summer dessert made by cooking mixed red berries with sugar and thickening the fruit with potato starch until spoonable and glossy. It is chilled and served with cold cream poured over, making it one of the most traditional fruit desserts in Denmark.";
"recipe.dk_rodgrod_med_flode.info.summary" = "Summer berry dessert";
"recipe.dk_rodgrod_med_flode.name" = "Red berry pudding";
"recipe.dk_rodgrod_med_flode.step1.body" = "Rinse %i1, %i2, and %i3, hull the strawberries, and cut any large berries into smaller pieces so the pudding cooks evenly.";
"recipe.dk_rodgrod_med_flode.step1.title" = "Prepare the berries";
"recipe.dk_rodgrod_med_flode.step2.body" = "Put the berries, %i4, and %i5 into the saucepan and bring gently to a simmer. Cook until the fruit softens and releases its juices.";
"recipe.dk_rodgrod_med_flode.step2.title" = "Cook the fruit base";
"recipe.dk_rodgrod_med_flode.step3.body" = "Pass the cooked fruit through the fine sieve, pressing well so the juice and soft fruit go through while the seeds are left behind.";
"recipe.dk_rodgrod_med_flode.step3.title" = "Strain the base";
"recipe.dk_rodgrod_med_flode.step4.body" = "Stir %i6 with the remaining %i7 in the bowl until completely smooth.";
"recipe.dk_rodgrod_med_flode.step4.title" = "Mix the starch";
"recipe.dk_rodgrod_med_flode.step5.body" = "Return the strained fruit to gentle heat and stir in the starch mixture. Cook carefully until the pudding thickens and turns glossy, without boiling hard after the starch is added.";
"recipe.dk_rodgrod_med_flode.step5.title" = "Thicken the pudding";
"recipe.dk_rodgrod_med_flode.step6.body" = "Pour the pudding into the serving bowl and let it cool completely.";
"recipe.dk_rodgrod_med_flode.step6.title" = "Cool the pudding";
"recipe.dk_rodgrod_med_flode.step7.body" = "Refrigerate the pudding until fully cold and softly set.";
"recipe.dk_rodgrod_med_flode.step7.title" = "Chill thoroughly";
"recipe.dk_rodgrod_med_flode.step8.body" = "Spoon the chilled rødgrød into bowls and pour the cold %i8 over just before serving.";
"recipe.dk_rodgrod_med_flode.step8.title" = "Serve";
