"recipe.ma_tangia.drink.body" = "A medium-bodied red such as Grenache or Syrah pairs well with the lamb richness and warm cumin-saffron aromatics. For a non-alcoholic option, serve Moroccan mint tea or sparkling water with lemon.";
"recipe.ma_tangia.drink.summary" = "Red wine (Grenache)";
"recipe.ma_tangia.info" = "Tangia Marrakchia is a traditional Marrakech specialty where lamb is seasoned with lots of garlic, cumin, ginger, saffron, preserved lemon, and smen, then sealed and slow-cooked until meltingly tender in its own juices. It is typically served as a communal dish, brought to the table in its cooking vessel and eaten with Moroccan khobz to scoop up the rich sauce and tender meat.";
"recipe.ma_tangia.info.summary" = "Marrakech slow lamb";
"recipe.ma_tangia.name" = "Tangia";
"recipe.ma_tangia.step1.body" = "Combine %i12, %i13, and %i14 in a bowl. Add %i15 and knead until smooth and elastic, then cover with a towel.";
"recipe.ma_tangia.step1.title" = "Start khobz dough";
"recipe.ma_tangia.step2.body" = "Leave the dough covered in a warm spot until clearly risen and airy.";
"recipe.ma_tangia.step2.title" = "Rise the dough";
"recipe.ma_tangia.step3.body" = "Crush the %i2 into a paste. Rinse the %i6 and remove the pulp, keeping the peel for chopping.";
"recipe.ma_tangia.step3.title" = "Prepare seasoning";
"recipe.ma_tangia.step4.body" = "In a bowl, combine the garlic paste with %i3, %i4, %i5, %i7, %i8, %i9, %i10, and the chopped preserved lemon peel. Coat the %i1 thoroughly.";
"recipe.ma_tangia.step4.title" = "Season the lamb";
"recipe.ma_tangia.step5.body" = "Place the seasoned lamb into the tangia pot, add %i11, and ensure the lamb is nestled so it cooks in the sauce.";
"recipe.ma_tangia.step5.title" = "Load the cooking vessel";
"recipe.ma_tangia.step6.body" = "Cover the vessel and cook at low heat until the lamb is very tender and the sauce is reduced and fragrant.";
"recipe.ma_tangia.step6.title" = "Slow cook until tender";
"recipe.ma_tangia.step7.body" = "Punch down the risen dough, shape into round loaves on a baking sheet, cover briefly, and heat the oven.";
"recipe.ma_tangia.step7.title" = "Shape khobz and heat oven";
"recipe.ma_tangia.step8.body" = "Bake the loaves until well risen and browned, then remove and let cool slightly for serving.";
"recipe.ma_tangia.step8.title" = "Bake the bread";
"recipe.ma_tangia.step9.body" = "Open the tangia and spoon the sauce over the lamb. Serve hot with khobz for scooping up the meat and sauce.";
"recipe.ma_tangia.step9.title" = "Serve";
