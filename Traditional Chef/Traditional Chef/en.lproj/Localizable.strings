"recipe.my_asam_pedas_ikan.step2.title" = "Prepare paste and vegetables";
"recipe.my_asam_pedas_ikan.step3.body" = "Blend the shallots, garlic, ginger, fresh turmeric, %i8, soaked dried chilies, and %i10 into a smooth paste with a little %i16.";
"recipe.my_asam_pedas_ikan.step3.title" = "Blend the rempah";
"recipe.my_asam_pedas_ikan.step4.body" = "Heat %i19 in the pot and cook the blended paste over medium heat, stirring until fragrant and slightly thickened. Add the lemongrass and galangal and continue cooking until the raw smell is gone.";
"recipe.my_asam_pedas_ikan.step4.title" = "Cook the spice paste";
"recipe.my_asam_pedas_ikan.step5.body" = "Add water and %i15, then bring the pot to a simmer. Add %i17 and %i18 and let the gravy cook so the sour and spicy flavors meld.";
"recipe.my_asam_pedas_ikan.step5.title" = "Build the sour gravy";
"recipe.my_asam_pedas_ikan.step6.body" = "Slide the fish pieces into the simmering gravy in a single layer. Simmer gently without vigorous stirring so the fish keeps its shape.";
"recipe.my_asam_pedas_ikan.step6.title" = "Cook the fish gently";
"recipe.my_asam_pedas_ikan.step7.body" = "Add the okra and tomato and continue simmering until the vegetables are tender and the fish is fully cooked. Taste and adjust the balance to a sharp sour and spicy gravy.";
"recipe.my_asam_pedas_ikan.step7.title" = "Add vegetables and finish";
"recipe.my_asam_pedas_ikan.step8.body" = "Ladle the asam pedas ikan into serving bowls and serve hot with %i20.";
