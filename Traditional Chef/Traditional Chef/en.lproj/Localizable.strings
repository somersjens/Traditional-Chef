"recipe.us_la_red_beans_and_rice.drink.body" = "A medium-bodied Côtes du Rhône or a malty lager pairs with smoky sausage and the peppery, savory beans. For a non-alcoholic option, serve iced tea or sparkling water with lemon to keep the meal bright.";
"recipe.us_la_red_beans_and_rice.drink.summary" = "Red wine (Côtes du Rhône)";
"recipe.us_la_red_beans_and_rice.info" = "Louisiana red beans and rice is a New Orleans staple traditionally cooked low and slow with smoked pork and the trinity of onion, celery, and bell pepper until the beans turn creamy and richly seasoned. The pot is finished with andouille and served over steamed white rice, often with hot sauce at the table, making a hearty, deeply savory meal associated with Monday cooking and big-batch comfort food.";
"recipe.us_la_red_beans_and_rice.info.summary" = "Monday red beans";
"recipe.us_la_red_beans_and_rice.name" = "Red beans and rice";
"recipe.us_la_red_beans_and_rice.step1.body" = "Pick over %i1 to remove any debris, then rinse well and drain.";
"recipe.us_la_red_beans_and_rice.step1.title" = "Sort and rinse the beans";
"recipe.us_la_red_beans_and_rice.step2.body" = "Combine beans with %i2, %i3, %i4, %i5, %i6, %i8, %i9, %i10, %i11, %i12, %i13, and %i14, then bring to a simmer.";
"recipe.us_la_red_beans_and_rice.step2.title" = "Start the pot";
"recipe.us_la_red_beans_and_rice.step3.body" = "Keep the pot at a gentle simmer, stirring occasionally, until the beans are very tender and begin to break down into a creamy base.";
"recipe.us_la_red_beans_and_rice.step3.title" = "Slow cook until creamy";
"recipe.us_la_red_beans_and_rice.step4.body" = "Mash some of the beans against the side of the pot and stir back in to make the beans thick and creamy while keeping some whole.";
"recipe.us_la_red_beans_and_rice.step4.title" = "Mash for texture";
"recipe.us_la_red_beans_and_rice.step5.body" = "Slice %i7 and stir it into the beans, then simmer until the sausage is heated through and the flavors meld.";
"recipe.us_la_red_beans_and_rice.step5.title" = "Add andouille";
"recipe.us_la_red_beans_and_rice.step6.body" = "Rinse %i16 until the water runs mostly clear. Combine rice with %i17 and %i18, bring to a boil, cover, and cook on low heat until tender, then keep covered off heat.";
"recipe.us_la_red_beans_and_rice.step6.title" = "Cook the rice";
"recipe.us_la_red_beans_and_rice.step7.body" = "Remove bay leaves and the ham hock bone, shred any meat from the hock back into the pot, then stir in %i15. Spoon rice into bowls, ladle red beans over the top, and serve with %i19.";
"recipe.us_la_red_beans_and_rice.step7.title" = "Finish and serve";
