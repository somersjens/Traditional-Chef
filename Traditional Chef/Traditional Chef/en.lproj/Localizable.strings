"recipe.gb_eton_mess.drink.body" = "A chilled sparkling wine or light dessert wine pairs well with the strawberries and cream. For a non-alcoholic option, serve sparkling water, lemonade, or cold elderflower cordial.";
"recipe.gb_eton_mess.drink.summary" = "Sparkling wine";
"recipe.gb_eton_mess.info" = "A traditional English dessert of crushed meringue folded with lightly whipped cream and strawberries, served immediately so the textures stay crisp and soft at once. It is classically associated with summer and outdoor gatherings, especially during the British strawberry season.";
"recipe.gb_eton_mess.info.summary" = "Berries cream meringue";
"recipe.gb_eton_mess.name" = "Eton mess";
"recipe.gb_eton_mess.step1.body" = "Whisk the %i1 to stiff peaks, then whisk in the %i2 gradually until glossy, and fold in the %i3 and %i4.";
"recipe.gb_eton_mess.step1.title" = "Whisk meringue base";
"recipe.gb_eton_mess.step2.body" = "Spoon rough mounds of meringue onto a lined baking tray.";
"recipe.gb_eton_mess.step2.title" = "Shape meringues";
"recipe.gb_eton_mess.step3.body" = "Bake the meringues at low heat until crisp outside and dry, then leave them to cool completely.";
"recipe.gb_eton_mess.step3.title" = "Bake and dry meringues";
"recipe.gb_eton_mess.step4.body" = "Hull and cut the %i5, then toss part with the %i6 and lightly crush some of them to make a little syrup while keeping the rest in pieces.";
"recipe.gb_eton_mess.step4.title" = "Prepare strawberries";
"recipe.gb_eton_mess.step5.body" = "Whisk the %i7 with the %i8 and remaining sugar until softly whipped.";
"recipe.gb_eton_mess.step5.title" = "Whip cream";
"recipe.gb_eton_mess.step6.body" = "Break the cooled meringues into bite-size pieces, keeping a mix of small crumbs and larger chunks.";
"recipe.gb_eton_mess.step6.title" = "Crush meringues";
"recipe.gb_eton_mess.step7.body" = "Fold the strawberries and meringue pieces through the whipped cream gently so the mixture stays rippled and textured.";
"recipe.gb_eton_mess.step7.title" = "Fold eton mess";
"recipe.gb_eton_mess.step8.body" = "Spoon into serving bowls and serve at once while the meringue still has some crunch.";
"recipe.gb_eton_mess.step8.title" = "Serve immediately";
