"recipe.et_atkilt_wat.drink.body" = "A light, fruity red wine like Pinot Noir pairs well with the warm spices and gentle sweetness of cabbage and carrots, while a dry rosé also works nicely. For a non-alcoholic option, serve spiced Ethiopian-style tea or chilled ginger-infused sparkling water alongside.";
"recipe.et_atkilt_wat.drink.summary" = "Red wine (Pinot Noir)";
"recipe.et_atkilt_wat.info" = "Atkilt Wat is a classic Ethiopian vegetable wat of cabbage, potatoes, and carrots slowly softened with onions, garlic, ginger, turmeric, and cumin until fragrant and tender. It is traditionally eaten family-style on injera, the fermented teff flatbread that also serves as the utensil, with the stew spooned over the spongy surface for scooping.";
"recipe.et_atkilt_wat.info.summary" = "Ethiopian vegetable wat";
"recipe.et_atkilt_wat.name" = "Atkilt wat";
"recipe.et_atkilt_wat.step1.body" = "In a large bowl, combine %i1 with %i2 to make a smooth batter. Stir well, scrape down the sides, cover with a clean cloth, and leave at room temperature to begin fermenting.";
"recipe.et_atkilt_wat.step1.title" = "Start injera fermentation";
"recipe.et_atkilt_wat.step10.body" = "Add potatoes and carrots, stir to coat, then add water and %i10. Bring to a steady simmer and cook until the vegetables begin to soften.";
"recipe.et_atkilt_wat.step10.title" = "Simmer potatoes and carrots";
"recipe.et_atkilt_wat.step11.body" = "Add cabbage, cover, and cook, stirring occasionally, until the cabbage is tender and the stew is moist but not watery.";
"recipe.et_atkilt_wat.step11.title" = "Cook cabbage until tender";
"recipe.et_atkilt_wat.step12.body" = "Taste and adjust salt if needed, then spoon the stew over injera and serve immediately with extra injera for scooping.";
"recipe.et_atkilt_wat.step12.title" = "Serve with injera";
"recipe.et_atkilt_wat.step2.body" = "Let the covered batter ferment until it smells pleasantly sour and bubbles appear. Do not disturb it during this time.";
"recipe.et_atkilt_wat.step2.title" = "Ferment the batter";
"recipe.et_atkilt_wat.step3.body" = "Gently pour off any liquid on top if present, then stir the batter back together. Strain through a fine-mesh sieve to remove lumps and return to the bowl.";
"recipe.et_atkilt_wat.step3.title" = "Skim and strain";
"recipe.et_atkilt_wat.step4.body" = "In a small saucepan, whisk a portion of the batter with water and cook, stirring constantly, until it thickens into a glossy paste.";
"recipe.et_atkilt_wat.step4.title" = "Make absit";
"recipe.et_atkilt_wat.step5.body" = "Whisk the hot absit back into the main batter until smooth, then stir in %i3. Cover and let the batter rest until lightly bubbly again.";
"recipe.et_atkilt_wat.step5.title" = "Strengthen and rest";
"recipe.et_atkilt_wat.step6.body" = "Heat a nonstick skillet over medium heat. Ladle batter onto the pan and swirl to coat. Cover with a lid to steam until the top sets and the edges lift, then remove and cool on a flat surface. Repeat to use up the batter.";
"recipe.et_atkilt_wat.step6.title" = "Cook the injera";
"recipe.et_atkilt_wat.step7.body" = "Cut the %i12 into bite-size pieces. Cut the %i13 into chunks and slice the %i14. Finely chop the %i5, and crush %i6 and %i7 into a paste.";
"recipe.et_atkilt_wat.step7.title" = "Prepare vegetables";
"recipe.et_atkilt_wat.step8.body" = "Heat %i4 in a large pot over medium heat. Add onion and cook until soft and glossy, then stir in garlic and ginger until fragrant.";
"recipe.et_atkilt_wat.step8.title" = "Build the spice base";
"recipe.et_atkilt_wat.step9.body" = "Stir in %i8 and %i9 and cook briefly, stirring so the spices toast gently without burning.";
"recipe.et_atkilt_wat.step9.title" = "Bloom spices";
"recipe.et_atkilt_wat.tool.t1" = "Large mixing bowl";
