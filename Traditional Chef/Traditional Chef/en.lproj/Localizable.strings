"recipe.pk_yakhni_pulao.drink.body" = "A dry aromatic white such as Riesling or Chenin Blanc pairs well with the gently spiced stock and fragrant rice. A light lager also works well. Non-alcoholic pairing: salted lassi or plain yogurt raita is the traditional companion, and black tea can also be served.";
"recipe.pk_yakhni_pulao.drink.summary" = "White wine (Riesling)";
"recipe.pk_yakhni_pulao.info" = "Yakhni Pulao is a traditional Pakistani pulao made by cooking basmati rice in a strained meat stock called yakhni, prepared with bone-in meat and whole spices. It is a festive yet comforting dish, usually served hot with raita and sometimes salad at family meals and gatherings.";
"recipe.pk_yakhni_pulao.info.summary" = "Aromatic stock rice";
"recipe.pk_yakhni_pulao.name" = "Yakhni pulao";
"recipe.pk_yakhni_pulao.step1.body" = "Rinse the %i13 until the water runs mostly clear, then soak it in %i2 so the grains cook evenly and remain long.";
"recipe.pk_yakhni_pulao.step1.title" = "Soak rice";
"recipe.pk_yakhni_pulao.step10.body" = "Cook on very low heat until the rice is fully tender and the mutton is heated through and aromatic.";
"recipe.pk_yakhni_pulao.step10.title" = "Steam on dum";
"recipe.pk_yakhni_pulao.step11.body" = "Turn off the heat and let the yakhni pulao rest covered so the grains firm up and the flavors settle.";
"recipe.pk_yakhni_pulao.step11.title" = "Rest pulao";
"recipe.pk_yakhni_pulao.step12.body" = "Whisk the %i26 until smooth. Finely chop or grate the cucumber and chop the %i28, then mix with the yogurt and %i29 until creamy and balanced.";
"recipe.pk_yakhni_pulao.step12.title" = "Make raita";
"recipe.pk_yakhni_pulao.step13.body" = "Fluff the pulao gently with a slotted spoon and transfer to a serving platter, keeping the rice grains separate. Serve hot with the cucumber raita.";
"recipe.pk_yakhni_pulao.step13.title" = "Serve";
"recipe.pk_yakhni_pulao.step2.body" = "Slice the %i3. Roughly crush the %i4 and %i5. Tie or gather the broth whole spices for easier straining if desired. Slice the %i15 and finely chop the %i16 and %i17. Chop the %i23 and %i24, and prepare the %i27 for raita.";
"recipe.pk_yakhni_pulao.step2.title" = "Prepare broth ingredients";
"recipe.pk_yakhni_pulao.step3.body" = "Place the %i1 in a large pot with broth onion, broth garlic, broth ginger, %i6, %i7, %i8, %i9, %i10, %i11, %i12, part of the %i18, and %i2. Bring slowly to a boil and skim the surface well.";
"recipe.pk_yakhni_pulao.step3.title" = "Start yakhni";
"recipe.pk_yakhni_pulao.step4.body" = "Cover and simmer gently until the mutton is tender and a fragrant stock develops.";
"recipe.pk_yakhni_pulao.step4.title" = "Simmer broth and meat";
"recipe.pk_yakhni_pulao.step5.body" = "Remove the mutton pieces and set aside. Strain the broth and discard the spent aromatics and whole spices. Keep the hot yakhni ready for cooking the rice.";
"recipe.pk_yakhni_pulao.step5.title" = "Strain yakhni and separate meat";
"recipe.pk_yakhni_pulao.step6.body" = "Heat the %i14 in a heavy pot or degchi. Add the sliced pulao onion and cook until golden. Add the pulao garlic, pulao ginger, %i19, %i20, %i21, and %i22, and cook briefly until fragrant.";
"recipe.pk_yakhni_pulao.step6.title" = "Fry onions and aromatics";
"recipe.pk_yakhni_pulao.step7.body" = "Add the cooked mutton and stir to coat in the fried onion base. Drain the soaked rice and add it to the pot, mixing gently so the grains are coated without breaking.";
"recipe.pk_yakhni_pulao.step7.title" = "Add meat and rice";
"recipe.pk_yakhni_pulao.step8.body" = "Add hot yakhni and the remaining salt so the rice cooks in the stock. Bring to a simmer and cook uncovered until the liquid is mostly absorbed and the rice is nearly tender.";
"recipe.pk_yakhni_pulao.step8.title" = "Cook with yakhni";
"recipe.pk_yakhni_pulao.step9.body" = "Sprinkle cilantro, mint, and %i25 over the rice. Gather the rice gently toward the center, cover tightly, and reduce the heat.";
"recipe.pk_yakhni_pulao.step9.title" = "Prepare dum";
