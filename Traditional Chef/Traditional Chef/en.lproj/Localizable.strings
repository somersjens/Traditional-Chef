"recipe.tr_hunkar_begendi.step7.title" = "Finish the beğendi";
"recipe.tr_hunkar_begendi.step8.body" = "Spread the eggplant beğendi on a platter and spoon the hot lamb stew over the top to serve.";
"recipe.tr_hunkar_begendi.step8.title" = "Plate and serve";
