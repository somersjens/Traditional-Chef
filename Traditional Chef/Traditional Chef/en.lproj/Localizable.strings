"recipe.id_nasi_goreng.step6.body" = "Add the %i1 and break up any clumps over high heat. Toss continuously so the grains are coated and heated through.";
"recipe.id_nasi_goreng.step6.title" = "Stir-fry the rice";
"recipe.id_nasi_goreng.step7.body" = "Add %i7, %i8, %i9, and %i10, then stir-fry until the rice is evenly colored and slightly smoky. Fold in the scallions at the end.";
"recipe.id_nasi_goreng.step7.title" = "Season and finish";
"recipe.id_nasi_goreng.step8.body" = "Serve the nasi goreng hot with fried eggs on top, sambal on the side, and cucumber, tomato, %i24, and %i25 as accompaniments.";
"recipe.id_nasi_goreng.step8.title" = "Plate and garnish";
