"recipe.hr_rozata.drink.body" = "A small glass of prošek or another sweet Dalmatian dessert wine suits the caramel and floral notes well. For a non-alcoholic pairing, serve cold water with lemon or unsweetened black tea.";
"recipe.hr_rozata.drink.summary" = "Dessert wine (Prošek)";
"recipe.hr_rozata.info" = "Rozata is the traditional custard dessert of Dubrovnik, a Croatian relative of crème caramel distinguished by local rose liqueur and lemon zest. It is baked gently in a caramel-lined mold, chilled, and turned out so the amber syrup runs over the delicate custard. It is served cold, most often as a festive dessert after a Dalmatian meal.";
"recipe.hr_rozata.info.summary" = "Dubrovnik rose custard";
"recipe.hr_rozata.name" = "Rozata";
"recipe.hr_rozata.step1.body" = "Heat %i1 with a little %i2 in the saucepan until it turns into a deep amber caramel, then pour it immediately into the baking mold and swirl to coat the bottom evenly.";
"recipe.hr_rozata.step1.title" = "Make the caramel";
"recipe.hr_rozata.step2.body" = "Warm %i3 gently until hot but not boiling, then take it off the heat.";
"recipe.hr_rozata.step2.title" = "Heat the milk";
"recipe.hr_rozata.step3.body" = "Whisk %i4 with %i5 until smooth, then slowly whisk in the hot milk. Add %i6 and %i7.";
"recipe.hr_rozata.step3.title" = "Mix the custard";
"recipe.hr_rozata.step4.body" = "Strain the custard through the fine strainer into the caramel-lined mold so the mixture is smooth.";
"recipe.hr_rozata.step4.title" = "Strain into the mold";
"recipe.hr_rozata.step5.body" = "Place the mold in the deep roasting pan and pour hot water around it to create a gentle water bath.";
"recipe.hr_rozata.step5.title" = "Set up the water bath";
"recipe.hr_rozata.step6.body" = "Bake until the custard is just set with a slight wobble in the center.";
"recipe.hr_rozata.step6.title" = "Bake gently";
"recipe.hr_rozata.step7.body" = "Remove the mold from the water bath and let the rozata cool completely.";
"recipe.hr_rozata.step7.title" = "Cool the custard";
"recipe.hr_rozata.step8.body" = "Refrigerate the rozata until fully cold and firm enough to unmold cleanly.";
"recipe.hr_rozata.step8.title" = "Chill thoroughly";
"recipe.hr_rozata.step9.body" = "Run a knife around the edge, invert the rozata onto a serving plate, and serve cold with the caramel syrup flowing over the top.";
"recipe.hr_rozata.step9.title" = "Unmold and serve";
