"recipe.th_panang_gai.drink.body" = "An off-dry Riesling pairs well with the rich coconut sauce and aromatic spices while balancing the gentle chili heat. For a non-alcoholic option, serve chilled jasmine tea, unsweetened iced tea, or cold water with lime.";
"recipe.th_panang_gai.drink.summary" = "White wine (Riesling)";
"recipe.th_panang_gai.info" = "Panang Gai is a traditional Thai panang curry of chicken simmered in a thick rich coconut curry sauce with panang curry paste, makrut lime leaves, fish sauce, palm sugar, and Thai basil. It is commonly served as part of a shared meal with jasmine rice, with a creamy mildly sweet and savory flavor.";
"recipe.th_panang_gai.info.summary" = "Thick panang curry";
"recipe.th_panang_gai.name" = "Panang curry";
"recipe.th_panang_gai.step1.body" = "Slice the %i1 into bite-size pieces. Thinly slice the %i9, tear and thinly slice the %i7, and pick the %i8.";
"recipe.th_panang_gai.step1.title" = "Prepare ingredients";
"recipe.th_panang_gai.step2.body" = "Rinse the %i10 until the water runs mostly clear. Put it in a saucepan with %i11 and bring it to a boil.";
"recipe.th_panang_gai.step2.title" = "Start the rice";
"recipe.th_panang_gai.step3.body" = "Cover and cook on low heat until the liquid is absorbed and the rice is tender. Rest covered off the heat.";
"recipe.th_panang_gai.step3.title" = "Cook the rice";
"recipe.th_panang_gai.step4.body" = "Heat the wok and add most of the %i3. Cook while stirring until fragrant and slightly thickened, then add the %i2 and fry until aromatic.";
"recipe.th_panang_gai.step4.title" = "Crack the coconut cream";
"recipe.th_panang_gai.step5.body" = "Add the chicken and stir until coated in the curry paste and the outside is no longer raw.";
"recipe.th_panang_gai.step5.title" = "Cook the chicken";
"recipe.th_panang_gai.step6.body" = "Add the %i4 and the remaining coconut cream, then season with %i5 and %i6. Stir until the sugar dissolves and the curry becomes smooth and thick.";
"recipe.th_panang_gai.step6.title" = "Build the sauce";
"recipe.th_panang_gai.step7.body" = "Simmer gently until the chicken is cooked through and the sauce is rich and thick enough to coat the meat.";
"recipe.th_panang_gai.step7.title" = "Simmer the panang curry";
"recipe.th_panang_gai.step8.body" = "Add most of the makrut lime leaves and the thai basil, then stir briefly until fragrant and the basil wilts.";
"recipe.th_panang_gai.step8.title" = "Finish with herbs";
"recipe.th_panang_gai.step9.body" = "Transfer to a serving bowl, top with the remaining makrut lime leaves and sliced red spur chili, and serve hot with jasmine rice.";
"recipe.th_panang_gai.step9.title" = "Garnish and serve";
