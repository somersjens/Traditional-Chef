"recipe.th_pad_see_ew.drink.summary" = "Beer (Lager)";
"recipe.th_pad_see_ew.info" = "Pad See Ew is a traditional Thai stir-fried noodle dish made with fresh wide rice noodles, Chinese broccoli, egg, garlic, and pork in a savory sweet soy-based sauce. It is cooked quickly over high heat for slight caramelization and served immediately as a complete street-food style meal.";
"recipe.th_pad_see_ew.info.summary" = "Soy sauce noodles";
"recipe.th_pad_see_ew.name" = "Pad see ew";
"recipe.th_pad_see_ew.step1.body" = "Slice the %i2 thinly, cut the %i3 stems and leaves into bite-size pieces, and chop the %i5. Loosen the %i1 gently so they separate without breaking.";
"recipe.th_pad_see_ew.step1.title" = "Prepare ingredients";
"recipe.th_pad_see_ew.step2.body" = "Combine the %i7, %i8, %i9, %i10, and %i11 in a bowl and stir until the sugar dissolves.";
"recipe.th_pad_see_ew.step2.title" = "Mix the sauce";
"recipe.th_pad_see_ew.step3.body" = "Heat the wok over high heat until very hot, then add part of the %i6.";
"recipe.th_pad_see_ew.step3.title" = "Heat the wok";
"recipe.th_pad_see_ew.step4.body" = "Add the garlic and stir briefly until fragrant, then add the pork and stir-fry until just cooked and lightly browned in spots.";
"recipe.th_pad_see_ew.step4.title" = "Cook pork and garlic";
"recipe.th_pad_see_ew.step5.body" = "Push the pork to one side, add a little more oil, crack in the %i4, and scramble until softly set.";
"recipe.th_pad_see_ew.step5.title" = "Cook the egg";
"recipe.th_pad_see_ew.step6.body" = "Add the chinese broccoli stems first, then the leaves, and stir-fry until the stems begin to soften while the leaves wilt.";
"recipe.th_pad_see_ew.step6.title" = "Add chinese broccoli";
"recipe.th_pad_see_ew.step7.body" = "Add the rice noodles and pour in the sauce. Toss and press the noodles against the hot wok to coat evenly and develop slight caramelization.";
"recipe.th_pad_see_ew.step7.title" = "Add noodles and sauce";
"recipe.th_pad_see_ew.step8.body" = "Add the remaining oil if needed and continue tossing until the noodles are glossy, hot, and evenly seasoned.";
"recipe.th_pad_see_ew.step8.title" = "Finish the stir-fry";
"recipe.th_pad_see_ew.step9.body" = "Divide onto serving plates and serve immediately with %i12 for table seasoning.";
"recipe.th_pad_see_ew.step9.title" = "Serve";
