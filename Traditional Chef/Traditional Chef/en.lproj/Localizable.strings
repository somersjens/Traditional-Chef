"recipe.it_carpaccio.drink.summary" = "White wine (Soave)";
"recipe.it_carpaccio.info" = "Carpaccio is a Venetian classic of paper-thin raw beef served chilled with a creamy, tangy sauce. It is typically presented on a cold plate as an elegant antipasto, meant to be eaten immediately while the meat is tender and the sauce is fresh.";
"recipe.it_carpaccio.info.summary" = "Venetian raw beef starter";
"recipe.it_carpaccio.name" = "Beef carpaccio";
"recipe.it_carpaccio.step1.body" = "Place the serving plates in the refrigerator so the carpaccio stays cold when plated.";
"recipe.it_carpaccio.step1.title" = "Chill the plates";
"recipe.it_carpaccio.step10.body" = "Spoon the chilled sauce over the beef in a light, even coating. Serve with %i10 on the side.";
"recipe.it_carpaccio.step10.title" = "Dress with the sauce";
"recipe.it_carpaccio.step2.body" = "Wrap %i1 tightly and place it in the freezer until firm but not frozen solid, so it can be sliced very thinly.";
"recipe.it_carpaccio.step2.title" = "Firm the beef";
