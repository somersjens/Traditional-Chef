"recipe.pe_causa_limena.drink.body" = "Pair with a crisp Albariño or Sauvignon Blanc to match the lime and ají amarillo. A light sparkling wine also works well. For a non-alcoholic option, serve chicha morada or sparkling water with lime.";
"recipe.pe_causa_limena.drink.summary" = "White wine (Albariño)";
"recipe.pe_causa_limena.info" = "Causa Limeña is a classic cold Peruvian starter made from smooth mashed yellow potatoes seasoned with ají amarillo and lime, then layered with a creamy chicken filling. It is traditionally served chilled and neatly unmolded, garnished with avocado, hard-boiled egg, black olives, and lettuce for a bright, elegant presentation.";
"recipe.pe_causa_limena.info.summary" = "Chilled layered potatoes";
"recipe.pe_causa_limena.name" = "Causa";
"recipe.pe_causa_limena.step1.body" = "Cook the %i1 in salted %i16 until completely tender, then drain.";
"recipe.pe_causa_limena.step1.title" = "Boil the potatoes";
"recipe.pe_causa_limena.step10.body" = "Unmold the causa, then garnish with egg slices and %i14 and serve on %i15.";
"recipe.pe_causa_limena.step10.title" = "Garnish and serve";
"recipe.pe_causa_limena.step2.body" = "Let the potatoes cool until safe to handle, then peel them while still slightly warm.";
"recipe.pe_causa_limena.step2.title" = "Cool and peel";
"recipe.pe_causa_limena.step3.body" = "Poach the %i6 in gently simmering water until cooked through, then remove and let it cool.";
"recipe.pe_causa_limena.step3.title" = "Cook the chicken";
"recipe.pe_causa_limena.step4.body" = "Shred the cooled chicken into fine strands for a smooth filling.";
"recipe.pe_causa_limena.step4.title" = "Shred the chicken";
"recipe.pe_causa_limena.step5.body" = "Boil the %i13 until hard-set, then cool, peel, and slice for garnish.";
"recipe.pe_causa_limena.step5.title" = "Hard-boil the eggs";
"recipe.pe_causa_limena.step6.body" = "Mash the potatoes until very smooth, then mix in the %i2, %i3, %i4, and %i5 until a pliable, cohesive dough forms.";
"recipe.pe_causa_limena.step6.title" = "Make the potato base";
"recipe.pe_causa_limena.step7.body" = "Finely mince the %i8 and %i9, then combine with the shredded chicken and %i7. Season with %i11 and %i10 and add a little lime to brighten the filling.";
"recipe.pe_causa_limena.step7.title" = "Mix the chicken filling";
"recipe.pe_causa_limena.step8.body" = "Line or set a ring mold on a plate. Press in half of the potato base, add a layer of sliced %i12, spread the chicken filling evenly, then cover with the remaining potato base and smooth the top.";
"recipe.pe_causa_limena.step8.title" = "Assemble the causa";
"recipe.pe_causa_limena.step9.body" = "Refrigerate until firm enough to unmold cleanly and slice neatly.";
"recipe.pe_causa_limena.step9.title" = "Chill to set";
