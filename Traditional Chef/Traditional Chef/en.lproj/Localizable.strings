"recipe.dz_griwech.drink.body" = "A floral dessert wine such as Muscat complements the honey, sesame, and orange blossom flavors without clashing. If you prefer something less sweet, a light sparkling wine can balance the syrup. Non-alcoholic pairing: hot mint tea or black coffee.";
"recipe.dz_griwech.drink.summary" = "Dessert wine (Muscat)";
"recipe.dz_griwech.info" = "Griwech is a traditional Algerian fried pastry shaped into braided knots, flavored with orange blossom and sesame, then dipped into warm honey syrup so it turns glossy and sweet while staying crisp at the edges. It is a classic dessert for Eid and weddings, served in small pieces alongside mint tea.";
"recipe.dz_griwech.info.summary" = "Honeyed braided pastry";
"recipe.dz_griwech.name" = "Griwech";
"recipe.dz_griwech.step1.body" = "Toast the %i2 in a dry skillet until fragrant, then cool and lightly crush a portion to deepen flavor.";
