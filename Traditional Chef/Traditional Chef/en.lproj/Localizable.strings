"recipe.ma_tagine_chicken_preserved_lemon_olives.drink.body" = "An aromatic white such as Viognier or a dry Chenin Blanc pairs well with saffron, preserved lemon, and olives without clashing with the citrus and brine. For a non-alcoholic option, serve Moroccan mint tea or sparkling water with lemon.";
"recipe.ma_tagine_chicken_preserved_lemon_olives.drink.summary" = "White wine (Viognier)";
"recipe.ma_tagine_chicken_preserved_lemon_olives.info" = "This classic Moroccan tagine features chicken gently braised with onions, garlic, saffron, ginger, and turmeric until tender, then finished with preserved lemon and green olives for a bright, salty, fragrant sauce. It is traditionally served straight from the tagine for sharing, with Moroccan khobz used to scoop up the chicken and the rich cooking juices.";
"recipe.ma_tagine_chicken_preserved_lemon_olives.info.summary" = "Lemon olive chicken tagine";
"recipe.ma_tagine_chicken_preserved_lemon_olives.name" = "Chicken tagine";
