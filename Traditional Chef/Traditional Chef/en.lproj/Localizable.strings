"recipe.kh_samlor_kari.step6.title" = "Fry kroeung";
"recipe.kh_samlor_kari.step7.body" = "Add the chicken and stir to coat it well in the kroeung, cooking until the outside loses its raw color.";
"recipe.kh_samlor_kari.step7.title" = "Add chicken";
