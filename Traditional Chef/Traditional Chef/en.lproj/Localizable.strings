"recipe.pl_kotlet_schabowy.drink.body" = "Pair with a crisp dry white such as Riesling or Grüner Veltliner to cut through the fried crust and complement the creamy cucumber salad. A clean pilsner-style lager is also a traditional match. Non-alcoholic option: sparkling water with lemon or cold kefir.";
"recipe.pl_kotlet_schabowy.drink.summary" = "White wine (Riesling)";
"recipe.pl_kotlet_schabowy.info" = "Kotlet schabowy is Poland’s classic breaded pork cutlet: pork loin pounded thin, seasoned, coated in flour, egg, and breadcrumbs, then fried in hot fat until crisp and golden. It is traditionally served as a hearty dinner with mashed potatoes and mizeria, a cool cucumber-and-sour-cream salad that balances the rich, crunchy cutlet.";
"recipe.pl_kotlet_schabowy.info.summary" = "Crispy pork cutlet";
"recipe.pl_kotlet_schabowy.name" = "Pork cutlet";
"recipe.pl_kotlet_schabowy.step1.body" = "Peel and cut the %i8, cover with %i9, add %i10, and bring to a gentle boil.";
"recipe.pl_kotlet_schabowy.step1.title" = "Prepare potatoes";
"recipe.pl_kotlet_schabowy.step2.body" = "Simmer until the potatoes are very tender, then drain well and return to the pot.";
"recipe.pl_kotlet_schabowy.step2.title" = "Cook the potatoes";
"recipe.pl_kotlet_schabowy.step3.body" = "Mash the hot potatoes, then stir in %i12 and warm %i11 until smooth. Keep warm.";
"recipe.pl_kotlet_schabowy.step3.title" = "Make mashed potatoes";
"recipe.pl_kotlet_schabowy.step4.body" = "Slice the %i13 thinly, salt them with %i14, and let them sit briefly, then squeeze out excess liquid. Mix with %i15, %i16, %i17, %i18, and chopped %i19, then chill.";
"recipe.pl_kotlet_schabowy.step4.title" = "Make mizeria";
"recipe.pl_kotlet_schabowy.step5.body" = "Cut %i1 into cutlets, cover with plastic wrap, and pound thin. Season both sides with %i2 and %i3.";
"recipe.pl_kotlet_schabowy.step5.title" = "Pound and season pork";
"recipe.pl_kotlet_schabowy.step6.body" = "Set up %i4, beaten %i5, and %i6. Coat each cutlet in flour, then egg, then breadcrumbs, pressing so the coating adheres well.";
"recipe.pl_kotlet_schabowy.step6.title" = "Bread the cutlets";
"recipe.pl_kotlet_schabowy.step7.body" = "Heat %i7 in a skillet and fry the cutlets until deeply golden and crisp on both sides, turning once and controlling the heat so the crust does not burn.";
"recipe.pl_kotlet_schabowy.step7.title" = "Fry until golden";
"recipe.pl_kotlet_schabowy.step8.body" = "Let the cutlets rest briefly, then serve hot with mashed potatoes and chilled mizeria.";
"recipe.pl_kotlet_schabowy.step8.title" = "Rest and serve";
