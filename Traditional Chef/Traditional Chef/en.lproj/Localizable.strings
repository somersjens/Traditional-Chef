"recipe.tw_oyster_omelet.step3.title" = "Beat eggs";
"recipe.tw_oyster_omelet.step4.body" = "In a small saucepan combine %i10, %i11, %i12, %i13, %i14, and most of the %i16, then heat and whisk until smooth.";
"recipe.tw_oyster_omelet.step4.title" = "Cook sauce base";
"recipe.tw_oyster_omelet.step5.body" = "Mix %i15 with the remaining water, whisk into the saucepan, and cook until the sauce thickens and turns glossy.";
"recipe.tw_oyster_omelet.step5.title" = "Thicken sauce";
"recipe.tw_oyster_omelet.step6.body" = "Heat some %i9 in a skillet, add one quarter of the oysters and cook briefly, then add one quarter of the greens and scallions.";
"recipe.tw_oyster_omelet.step6.title" = "Start first omelet";
"recipe.tw_oyster_omelet.step7.body" = "Stir the starch slurry and pour in one quarter, let it turn translucent in patches, then pour in one quarter of the beaten egg over the top.";
"recipe.tw_oyster_omelet.step7.title" = "Add slurry and egg";
"recipe.tw_oyster_omelet.step8.body" = "Cook until the omelet is set but still tender, fold lightly or slide onto a plate, and spoon sauce over the top.";
