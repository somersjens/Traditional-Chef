"recipe.ar_carbonada_criolla.drink.body" = "Argentine Malbec is the classic match for the beefy, tomato-rich stew and the gentle sweetness from dried fruit. A medium-bodied Bonarda also works well. For a non-alcoholic option, serve sparkling water with lemon or hot yerba mate.";
"recipe.ar_carbonada_criolla.drink.summary" = "Red wine (Malbec)";
"recipe.ar_carbonada_criolla.info" = "Carbonada criolla is a hearty Argentine stew of beef simmered with tomatoes, potatoes, sweet potato, squash, carrots, and corn, subtly sweetened with dried peaches. Traditionally it is served inside a roasted pumpkin, making a rustic centerpiece where the tender pumpkin flesh mixes into the rich, gently spiced broth as you scoop and serve.";
"recipe.ar_carbonada_criolla.info.summary" = "Pumpkin beef pot";
"recipe.ar_carbonada_criolla.name" = "Carbonada criolla";
"recipe.ar_carbonada_criolla.step1.body" = "Cut a lid from the top of the %i1 and scoop out seeds and strings. Rub the inside lightly with %i3 and a pinch of %i19, then set it on a baking tray and cover loosely with foil.";
"recipe.ar_carbonada_criolla.step1.title" = "Prepare the pumpkin bowl";
"recipe.ar_carbonada_criolla.step10.body" = "Bake until the stew is bubbling and the pumpkin flesh softens further, so some of it can be scooped into the stew while serving.";
"recipe.ar_carbonada_criolla.step10.title" = "Bake to meld";
"recipe.ar_carbonada_criolla.step11.body" = "Bring the pumpkin to the table, ladle out stew, and scrape a little tender pumpkin flesh into each serving.";
"recipe.ar_carbonada_criolla.step11.title" = "Serve";
"recipe.ar_carbonada_criolla.step2.body" = "Roast until the flesh near the walls is tender but the pumpkin still holds its shape as a serving bowl.";
"recipe.ar_carbonada_criolla.step2.title" = "Roast the pumpkin";
"recipe.ar_carbonada_criolla.step3.body" = "Heat olive oil in a heavy pot and brown the %i2 well, turning to color all sides without crowding.";
"recipe.ar_carbonada_criolla.step3.title" = "Brown the beef";
"recipe.ar_carbonada_criolla.step4.body" = "Add %i4, %i6, and %i5 to the pot and cook until softened and fragrant, scraping up the browned bits.";
"recipe.ar_carbonada_criolla.step4.title" = "Build the sofrito";
"recipe.ar_carbonada_criolla.step5.body" = "Pour in %i13 and simmer to reduce slightly. Stir in %i18, %i17, %i16, %i19, and %i20.";
"recipe.ar_carbonada_criolla.step5.title" = "Deglaze and season";
"recipe.ar_carbonada_criolla.step6.body" = "Add %i14 and %i15, bring to a steady simmer, cover, and cook so the beef begins to tenderize.";
"recipe.ar_carbonada_criolla.step6.title" = "Add tomatoes and stock";
"recipe.ar_carbonada_criolla.step7.body" = "Continue simmering covered until the beef is approaching tender and the broth is well flavored.";
"recipe.ar_carbonada_criolla.step7.title" = "Simmer the beef";
"recipe.ar_carbonada_criolla.step8.body" = "Add %i7, %i8, %i9, %i10, %i11, and %i12. Keep at a gentle simmer until the vegetables are tender and the stew thickens slightly.";
"recipe.ar_carbonada_criolla.step8.title" = "Add vegetables and fruit";
"recipe.ar_carbonada_criolla.step9.body" = "Spoon the hot stew into the roasted pumpkin bowl, pushing some pieces down so it packs evenly, then set the lid on top.";
"recipe.ar_carbonada_criolla.step9.title" = "Fill the pumpkin";
