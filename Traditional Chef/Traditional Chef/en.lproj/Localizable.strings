"recipe.gr_pastitsio.step3.title" = "Boil the pasta";
"recipe.gr_pastitsio.step4.body" = "Melt %i4 and toss it through the hot pasta. Beat %i2 with %i3, then mix it through the pasta so it is evenly coated.";
"recipe.gr_pastitsio.step4.title" = "Bind the pasta";
