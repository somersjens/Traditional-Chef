"recipe.pe_papa_rellena.drink.body" = "Pair with a juicy Malbec or medium-bodied Tempranillo to match the fried potato and savory beef. A crisp lager also works well. For a non-alcoholic option, serve chicha morada or sparkling water with lime.";
"recipe.pe_papa_rellena.drink.summary" = "Red wine (Malbec)";
"recipe.pe_papa_rellena.info" = "Papa Rellena is a classic Peruvian comfort food of seasoned mashed potato formed around a savory beef filling with onion, garlic, ají, and spices, then coated in flour and fried until crisp and golden. It is traditionally served hot, often with a simple onion-lime salsa criolla on the side to brighten the rich filling.";
"recipe.pe_papa_rellena.info.summary" = "Stuffed potato fritter";
"recipe.pe_papa_rellena.name" = "Stuffed potato";
"recipe.pe_papa_rellena.step1.body" = "Cook the %i1 in salted %i23 until very tender, then drain well.";
"recipe.pe_papa_rellena.step1.title" = "Boil the potatoes";
"recipe.pe_papa_rellena.step10.body" = "Serve hot with salsa criolla on the side.";
"recipe.pe_papa_rellena.step10.title" = "Serve";
"recipe.pe_papa_rellena.step2.body" = "Mash the potatoes until smooth, season with %i2 and %i3, and let them cool until firm enough to shape without sticking.";
"recipe.pe_papa_rellena.step2.title" = "Mash and season";
"recipe.pe_papa_rellena.step3.body" = "Heat %i12 in a skillet and sauté the chopped %i5 until soft. Add minced %i6, %i7, %i8, and %i9 and cook until fragrant.";
"recipe.pe_papa_rellena.step3.title" = "Cook the filling base";
"recipe.pe_papa_rellena.step4.body" = "Add %i4 and cook until browned, breaking it up, then season with %i10 and %i11 and cook until the liquid reduces.";
"recipe.pe_papa_rellena.step4.title" = "Brown the beef";
"recipe.pe_papa_rellena.step5.body" = "Stir in %i15 and chopped %i13, then cool the filling so it firms up for stuffing. Cut the %i14 into pieces for placing inside each fritter.";
"recipe.pe_papa_rellena.step5.title" = "Finish the filling";
"recipe.pe_papa_rellena.step6.body" = "Thinly slice the %i18 and rinse briefly in cold water, then drain. Toss with %i20, %i21, chopped %i19, and finely sliced %i22.";
"recipe.pe_papa_rellena.step6.title" = "Make salsa criolla";
"recipe.pe_papa_rellena.step7.body" = "Divide the potato dough into portions. Flatten each portion in your hand, add a spoonful of filling and a piece of egg, then seal and shape into an oval, patching any cracks.";
"recipe.pe_papa_rellena.step7.title" = "Form the papas";
"recipe.pe_papa_rellena.step8.body" = "Roll each stuffed potato in %i16, dusting off excess so the crust fries evenly.";
"recipe.pe_papa_rellena.step8.title" = "Coat with flour";
"recipe.pe_papa_rellena.step9.body" = "Fry in hot %i17, turning carefully, until deeply golden and crisp all over, then drain on paper towels.";
"recipe.pe_papa_rellena.step9.title" = "Fry until golden";
