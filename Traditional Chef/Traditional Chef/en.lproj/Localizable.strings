"recipe.ir_joojeh_kabab.step2.title" = "Prepare the marinade";
"recipe.ir_joojeh_kabab.step3.body" = "Cut %i1 into kebab pieces, coat thoroughly in the marinade, cover, and refrigerate so the flavors penetrate.";
"recipe.ir_joojeh_kabab.step3.title" = "Marinate the chicken";
"recipe.ir_joojeh_kabab.step4.body" = "Rinse %i8 until the water runs mostly clear, then soak it in salted %i11 so the grains hydrate evenly.";
"recipe.ir_joojeh_kabab.step4.title" = "Soak the rice";
"recipe.ir_joojeh_kabab.step5.body" = "Bring a large pot of water to a boil. Drain the soaked rice and boil until the grains are softened on the outside but still firm in the center, then drain well.";
"recipe.ir_joojeh_kabab.step5.title" = "Parboil the rice";
"recipe.ir_joojeh_kabab.step6.body" = "Return the drained rice to a nonstick pot, poke a few steam vents, dot with %i9, wrap the lid with a tea towel, and steam on low heat until fluffy and fully cooked.";
"recipe.ir_joojeh_kabab.step6.title" = "Steam the chelo";
"recipe.ir_joojeh_kabab.step7.body" = "Thread the marinated chicken onto skewers, packing pieces snugly. Skewer %i12 separately and keep ready for the grill.";
"recipe.ir_joojeh_kabab.step7.title" = "Skewer chicken and tomatoes";
"recipe.ir_joojeh_kabab.step8.body" = "Grill the chicken over hot coals, turning regularly, until lightly charred and cooked through. Grill the tomatoes until blistered and softened.";
"recipe.ir_joojeh_kabab.step8.title" = "Grill the kebabs";
"recipe.ir_joojeh_kabab.step9.body" = "Plate the rice and kebabs with grilled tomatoes, %i13, %i14, %i15, %i16, %i17, %i18, and %i19.";
