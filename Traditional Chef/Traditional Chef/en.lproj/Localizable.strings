"recipe.gb_spotted_dick.drink.summary" = "Sweet sherry";
"recipe.gb_spotted_dick.info" = "A traditional British steamed suet pudding studded with currants and raisins, classically served in slices with hot custard. It is a longstanding nursery and pub dessert, served warm and comforting, especially in colder weather.";
