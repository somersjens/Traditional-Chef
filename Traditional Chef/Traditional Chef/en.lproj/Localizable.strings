"recipe.lb_samak_harra.drink.body" = "Pair with a crisp, saline white such as Sauvignon Blanc or Assyrtiko to cut through the tahini and spice and complement the fish. For a non-alcoholic option, serve sparkling water with lemon or unsweetened mint tea.";
"recipe.lb_samak_harra.drink.summary" = "White wine (Sauvignon)";
"recipe.lb_samak_harra.info" = "Samak harra is a traditional Lebanese fish dish, especially associated with the Tripoli region, where baked fish is coated in a bold spicy tahini sauce enriched with walnuts, garlic, lemon, and herbs. It is served hot or warm as a main course, typically with warm pita bread to scoop up the sauce and juices.";
"recipe.lb_samak_harra.info.summary" = "Tripoli spicy fish";
