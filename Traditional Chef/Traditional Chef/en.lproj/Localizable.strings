"recipe.th_miang_kham.step5.title" = "Cook the miang kham sauce";
"recipe.th_miang_kham.step6.body" = "Strain the sauce to remove fibrous solids, pressing well to extract flavor, then return the smooth sauce to the pan briefly if it needs to thicken more.";
"recipe.th_miang_kham.step6.title" = "Strain the sauce";
"recipe.th_miang_kham.step7.body" = "Let the sauce cool until thick enough to spoon easily without running.";
"recipe.th_miang_kham.step7.title" = "Cool the sauce";
"recipe.th_miang_kham.step8.body" = "Place the cha plu leaves, toasted coconut, %i3, dried shrimp, lime, shallots, ginger, and chili on a serving platter and spoon the sauce into a small bowl.";
"recipe.th_miang_kham.step8.title" = "Arrange the platter";
"recipe.th_miang_kham.step9.body" = "Serve so each person wraps a leaf with a little of each filling and a spoonful of sauce to make individual bites.";
"recipe.th_miang_kham.step9.title" = "Serve";
