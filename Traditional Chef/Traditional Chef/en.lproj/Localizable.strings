"recipe.il_kubbeh_selek.drink.body" = "Pair with a crisp, dry rosé or a bright, high-acid white like Riesling to balance the soup’s sweet-and-sour beet broth. For a non-alcoholic option, serve sparkling water with lemon or a tart pomegranate spritzer.";
"recipe.il_kubbeh_selek.drink.summary" = "Rosé wine";
"recipe.il_kubbeh_selek.info" = "Kubbeh selek is a classic Iraqi-Jewish and Kurdish-Jewish Jerusalemite soup of semolina dumplings stuffed with spiced beef, simmered in a sweet-and-sour beet broth with celery and lemon. It is traditionally served hot as a hearty meal, especially on cool days, with bread on the side to soak up the deep magenta broth.";
"recipe.il_kubbeh_selek.info.summary" = "Beet kubbeh soup";
"recipe.il_kubbeh_selek.name" = "Kubbeh selek";
"recipe.il_kubbeh_selek.step1.body" = "Heat %i1 in a large pot and cook chopped %i2 until softened. Add minced %i3 and cook until fragrant, then stir in the %i6 until it darkens slightly.";
"recipe.il_kubbeh_selek.step1.title" = "Start the soup base";
"recipe.il_kubbeh_selek.step10.body" = "Ladle soup and dumplings into bowls, ensuring each serving gets broth, beets, and celery. Serve hot with %i24 on the side.";
"recipe.il_kubbeh_selek.step10.title" = "Serve";
"recipe.il_kubbeh_selek.step2.body" = "Add the %i4 and %i5 and cook briefly to coat. Add %i7, %i8, and %i9, then add %i11 and the %i10 and bring to a boil.";
"recipe.il_kubbeh_selek.step2.title" = "Build the beet broth";
"recipe.il_kubbeh_selek.step3.body" = "Reduce to a gentle simmer, cover, and cook until the beets begin to soften and the broth turns deeply colored.";
"recipe.il_kubbeh_selek.step3.title" = "Simmer until the broth develops";
"recipe.il_kubbeh_selek.step4.body" = "Heat %i13 in a skillet, cook finely chopped %i15 until soft, then add %i14 and cook until browned and crumbly. Stir in %i17, %i18, %i19, and %i16, then remove from heat to cool.";
"recipe.il_kubbeh_selek.step4.title" = "Cook the beef filling";
"recipe.il_kubbeh_selek.step5.body" = "Combine %i20 and %i21 in a bowl. Add %i22 and %i23 and knead until a smooth, pliable dough forms that holds together when pressed.";
"recipe.il_kubbeh_selek.step5.title" = "Make the semolina dough";
"recipe.il_kubbeh_selek.step6.body" = "Cover the dough and let it rest so the semolina hydrates and the dough becomes easier to shape.";
"recipe.il_kubbeh_selek.step6.title" = "Rest the dough";
"recipe.il_kubbeh_selek.step7.body" = "With wet hands, pinch off pieces of dough, flatten into a thin round, add a small amount of filling, and seal into a smooth oval dumpling. Keep hands damp so the dough does not crack and seals tightly.";
"recipe.il_kubbeh_selek.step7.title" = "Shape and fill the dumplings";
"recipe.il_kubbeh_selek.step8.body" = "Stir %i12 into the simmering soup and taste for balance, adjusting with a little more salt if needed.";
"recipe.il_kubbeh_selek.step8.title" = "Season the soup";
"recipe.il_kubbeh_selek.step9.body" = "Gently lower the dumplings into the barely simmering soup. Cover and simmer gently, keeping the heat low so the dumplings cook through without breaking.";
"recipe.il_kubbeh_selek.step9.title" = "Poach the kubbeh";
