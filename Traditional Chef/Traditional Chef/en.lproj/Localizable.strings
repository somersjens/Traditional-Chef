"recipe.bo_silpancho.drink.body" = "Light lager or crisp pilsner suits silpancho well. Its carbonation and clean finish balance the fried beef, egg, rice, and potatoes. For a non-alcoholic option, serve sparkling water with lime.";
"recipe.bo_silpancho.drink.summary" = "Beer (Lager)";
"recipe.bo_silpancho.info" = "Silpancho is a traditional Bolivian dish from Cochabamba built as a full plate of white rice, potatoes, a very thin breaded beef cutlet, salad, and fried egg. It is served hot as a substantial midday meal and is traditionally accompanied with llajua for heat and brightness.";
"recipe.bo_silpancho.info.summary" = "Breaded beef plate";
"recipe.bo_silpancho.name" = "Silpancho";
"recipe.bo_silpancho.step1.body" = "Peel %i7, %i10, and %i11. Slice %i8, cut %i9, chop %i12 and %i19, and set aside %i17 and %i18 for the llajua.";
"recipe.bo_silpancho.step1.title" = "Prepare the ingredients";
"recipe.bo_silpancho.step10.body" = "Place rice on each plate, add the fried potatoes, cover with the beef cutlet, top with the salad, and finish with a fried egg. Serve the llajua on the side.";
"recipe.bo_silpancho.step10.title" = "Assemble traditionally";
"recipe.bo_silpancho.step2.body" = "Cook %i5 in %i6 with part of %i13 until tender and fluffy, then keep it warm.";
"recipe.bo_silpancho.step2.title" = "Cook the rice";
"recipe.bo_silpancho.step3.body" = "Boil the beetroot and carrots in water until tender, then grate them. Boil the potatoes until just tender, drain them, and let them cool slightly.";
"recipe.bo_silpancho.step3.title" = "Cook the vegetables";
"recipe.bo_silpancho.step4.body" = "Mix the red onion, tomatoes, grated beetroot, grated carrots, parsley, %i16, and part of the salt. Let the salad rest while you finish the plate components.";
"recipe.bo_silpancho.step4.title" = "Make the salad";
"recipe.bo_silpancho.step5.body" = "Blend the locoto peppers, tomato, cilantro, and %i20 until coarse and bright. Set aside for serving.";
"recipe.bo_silpancho.step5.title" = "Make the llajua";
"recipe.bo_silpancho.step6.body" = "Season %i1 with the remaining salt and %i14, divide it into portions, coat lightly with %i3 and %i2, and flatten each portion very thin with the mallet.";
"recipe.bo_silpancho.step6.title" = "Shape the cutlets";
"recipe.bo_silpancho.step7.body" = "Cut the boiled potatoes into slices, heat part of %i15, and fry the potatoes until golden. Drain well.";
"recipe.bo_silpancho.step7.title" = "Fry the potatoes";
"recipe.bo_silpancho.step8.body" = "Heat more oil in the skillet and fry the thin breaded beef cutlets until browned and cooked through.";
"recipe.bo_silpancho.step8.title" = "Cook the beef";
"recipe.bo_silpancho.step9.body" = "Cook %i4 in the skillet until the whites are set and the yolks remain soft.";
"recipe.bo_silpancho.step9.title" = "Fry the eggs";
