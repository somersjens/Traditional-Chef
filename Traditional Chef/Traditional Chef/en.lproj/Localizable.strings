"recipe.bd_kheer_kadam.drink.body" = "A lightly chilled Muscat or late-harvest dessert wine matches the rich milk flavour and gentle sweetness. If you want something less sweet, an off-dry Riesling pairs well. Non-alcoholic pairing: masala chai or chilled milk with cardamom.";
"recipe.bd_kheer_kadam.drink.summary" = "Sweet wine (Muscat)";
"recipe.bd_kheer_kadam.info" = "Kheer kadam is a traditional Bengali sweet popular in Bangladesh, made by reducing milk into kheer (khoya/mawa), shaping a firm inner ball, then coating it with a smooth chhana layer before cooking the balls in light sugar syrup. Once soaked and set, each sweet is rolled in fine coconut to create its characteristic soft outer shell around a dense, milky center. It is served at celebrations and with tea.";
"recipe.bd_kheer_kadam.info.summary" = "Layered milk sweet";
"recipe.bd_kheer_kadam.name" = "Kheer kadam";
"recipe.bd_kheer_kadam.step1.body" = "Simmer the %i1 in a wide pan, stirring often, until it reduces to a thick khoya-like mass. Stir in %i2 and %i3 and cook until it turns dense and holds together.";
"recipe.bd_kheer_kadam.step1.title" = "Make the kheer center";
"recipe.bd_kheer_kadam.step10.body" = "Lift the sweets out, drain briefly, then roll in %i12 and serve at room temperature.";
"recipe.bd_kheer_kadam.step10.title" = "Coat and serve";
"recipe.bd_kheer_kadam.step2.body" = "Cool the reduced milk mixture until workable, then divide and shape into firm, smooth small balls.";
"recipe.bd_kheer_kadam.step2.title" = "Cool and shape the centers";
"recipe.bd_kheer_kadam.step3.body" = "Bring the %i4 to a simmer, add %i5 juice gradually, and stir until the curds separate clearly from the whey.";
"recipe.bd_kheer_kadam.step3.title" = "Curdle milk for chhana";
"recipe.bd_kheer_kadam.step4.body" = "Pour into a cloth-lined sieve and drain until the chhana is moist but not dripping.";
"recipe.bd_kheer_kadam.step4.title" = "Drain the chhana";
"recipe.bd_kheer_kadam.step5.body" = "Transfer the chhana to a plate, add %i6 and %i7, and knead until smooth and no longer grainy.";
"recipe.bd_kheer_kadam.step5.title" = "Knead the chhana";
"recipe.bd_kheer_kadam.step6.body" = "Divide the chhana dough and flatten portions, place a kheer ball inside each, and seal completely so the outer layer is smooth with no cracks.";
"recipe.bd_kheer_kadam.step6.title" = "Wrap the centers";
"recipe.bd_kheer_kadam.step7.body" = "Boil %i8 and %i9 with lightly crushed %i10 to make a clear syrup, keeping it at a steady simmer.";
"recipe.bd_kheer_kadam.step7.title" = "Prepare the syrup";
"recipe.bd_kheer_kadam.step8.body" = "Gently add the wrapped balls to the simmering syrup, cover, and cook so they puff slightly and become spongy.";
"recipe.bd_kheer_kadam.step8.title" = "Cook in syrup";
"recipe.bd_kheer_kadam.step9.body" = "Turn off the heat, stir in %i11, and let the sweets cool in the syrup so they absorb it.";
"recipe.bd_kheer_kadam.step9.title" = "Perfume and cool";
