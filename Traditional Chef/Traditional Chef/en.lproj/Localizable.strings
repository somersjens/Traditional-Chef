"recipe.lb_moghrabieh.drink.body" = "Pair with a rounded, aromatic white such as Viognier or an oaked Chardonnay to match the warm spices and rich broth. For a non-alcoholic option, serve sparkling water with lemon or hot mint tea.";
"recipe.lb_moghrabieh.drink.summary" = "White wine (Viognier)";
"recipe.lb_moghrabieh.info" = "Lebanese moghrabieh is a hearty stew built around large pearl couscous simmered in fragrant chicken broth with chickpeas and tender chicken, finished with sweet caramelized onions and toasted nuts. It is served hot as a family-style dish, with the couscous pearls taking on the warm spice and broth flavor typical of Lebanese winter and gathering meals.";
"recipe.lb_moghrabieh.info.summary" = "Pearl couscous chicken";
"recipe.lb_moghrabieh.name" = "Moghrabieh";
"recipe.lb_moghrabieh.step1.body" = "Rinse %i8 and cover with %i2 in a bowl. Leave to soak until fully plumped, then drain and rinse well.";
"recipe.lb_moghrabieh.step1.title" = "Soak the chickpeas";
"recipe.lb_moghrabieh.step2.body" = "Place %i1 in a pot with water, %i3, %i4, %i5, %i6, and %i7. Bring to a boil, skim any foam, then simmer until the chicken is tender. Lift out the chicken and strain the broth.";
"recipe.lb_moghrabieh.step2.title" = "Make the chicken broth";
"recipe.lb_moghrabieh.step3.body" = "Put the soaked chickpeas in a pot, cover with water, and simmer until tender. Drain and set aside.";
"recipe.lb_moghrabieh.step3.title" = "Cook the chickpeas";
"recipe.lb_moghrabieh.step4.body" = "Thinly slice %i21 for topping. Peel %i11. Crush %i12.";
"recipe.lb_moghrabieh.step4.title" = "Prepare onions and garlic";
"recipe.lb_moghrabieh.step5.body" = "Heat %i22 and %i23 in a skillet and cook the sliced onions slowly, stirring often, until deeply golden and sweet. Set aside.";
"recipe.lb_moghrabieh.step5.title" = "Caramelize the onions";
"recipe.lb_moghrabieh.step6.body" = "In the same skillet, toast %i24 until golden and fragrant, then set aside.";
"recipe.lb_moghrabieh.step6.title" = "Toast the almonds";
"recipe.lb_moghrabieh.step7.body" = "In a large pot, warm %i13 and %i14 and sauté the pearl onions until they begin to soften. Add the garlic and cook briefly until fragrant.";
"recipe.lb_moghrabieh.step7.title" = "Start the moghrabieh base";
"recipe.lb_moghrabieh.step8.body" = "Add %i10 and stir to coat. Add hot chicken broth gradually and simmer, stirring regularly, until the pearls are tender and the mixture is saucy. Stir in the cooked chickpeas and the chicken and season with %i15, %i16, %i17, %i18, %i19, and %i20, simmering until everything is heated through.";
"recipe.lb_moghrabieh.step8.title" = "Simmer the moghrabieh";
"recipe.lb_moghrabieh.step9.body" = "Spoon into a serving platter, top with caramelized onions and toasted almonds, and serve hot.";
