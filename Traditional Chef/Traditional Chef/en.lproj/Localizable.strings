"recipe.ro_papanasi.drink.body" = "A lightly sweet Romanian dessert wine pairs well with the warm fried dough and tangy cheese. For a non-alcoholic pairing, serve black tea or cold water.";
"recipe.ro_papanasi.drink.summary" = "Dessert wine";
"recipe.ro_papanasi.info" = "Papanași are one of the best known Romanian desserts, made from a sweet fresh cheese dough shaped into rings with small tops, fried until golden, and served warm. They are traditionally finished with sour cream and fruit jam, most classically blueberry or sour cherry, and are commonly served in Romanian homes and traditional restaurants.";
"recipe.ro_papanasi.info.summary" = "Fried cheese doughnuts";
"recipe.ro_papanasi.name" = "Papanasi";
"recipe.ro_papanasi.step1.body" = "Mash %i1 in the bowl, then mix in %i2, %i3, %i4, %i5, %i6, %i7, and %i8 until a soft dough forms.";
"recipe.ro_papanasi.step1.title" = "Make the dough";
"recipe.ro_papanasi.step2.body" = "Divide the dough into equal portions, shape each main piece into a thick ring with a hole in the center, and form a small round top for each one from the remaining dough.";
"recipe.ro_papanasi.step2.title" = "Shape the papanasi";
"recipe.ro_papanasi.step3.body" = "Leave the shaped papanasi briefly so the dough relaxes and holds its shape better during frying.";
"recipe.ro_papanasi.step3.title" = "Rest the shaped dough";
"recipe.ro_papanasi.step4.body" = "Heat %i9 in the deep pot and fry the rings and small tops in batches until deeply golden and cooked through, turning them so they color evenly on all sides.";
"recipe.ro_papanasi.step4.title" = "Fry until golden";
"recipe.ro_papanasi.step5.body" = "Lift the fried papanasi out with the slotted spoon and drain them briefly on paper towels.";
"recipe.ro_papanasi.step5.title" = "Drain the papanasi";
"recipe.ro_papanasi.step6.body" = "Place the rings on plates, add %i10 and %i11 on top, then place the small fried tops over the cream and jam and serve warm.";
"recipe.ro_papanasi.step6.title" = "Serve";
