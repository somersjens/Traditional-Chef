"recipe.th_gaeng_keow_wan_gai.drink.body" = "An off-dry Riesling balances chili heat and fragrant herbs while refreshing the palate between bites. For a non-alcoholic option, serve chilled Thai jasmine tea or cold water with lime.";
"recipe.th_gaeng_keow_wan_gai.drink.summary" = "White wine (Riesling)";
"recipe.th_gaeng_keow_wan_gai.info" = "Gaeng Keow Wan Gai is a traditional Thai green curry made with chicken simmered in rich coconut cream and coconut milk with green curry paste, Thai eggplants, pea eggplant, kaffir lime leaves, and Thai basil. It is served hot with jasmine rice as a central shared meal dish.";
"recipe.th_gaeng_keow_wan_gai.info.summary" = "Green chicken curry";
"recipe.th_gaeng_keow_wan_gai.name" = "Green curry";
