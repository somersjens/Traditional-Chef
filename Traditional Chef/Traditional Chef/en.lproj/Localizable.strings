"recipe.uz_shashlik.drink.body" = "A light to medium red such as Pinot Noir or young Grenache pairs well with smoky lamb and grilled fat. A crisp lager also works well. Non-alcoholic pairing: hot black tea is a traditional and excellent choice.";
"recipe.uz_shashlik.drink.summary" = "Red wine (Pinot Noir)";
"recipe.uz_shashlik.info" = "Uzbek shashlik is a traditional charcoal-grilled kebab of marinated lamb, often threaded with pieces of lamb tail fat and served straight from the skewers with sliced onions and non bread. It is a classic street food and gathering dish across Uzbekistan, cooked over a mangal and eaten hot.";
"recipe.uz_shashlik.info.summary" = "Charcoal lamb skewers";
"recipe.uz_shashlik.name" = "Shashlik";
"recipe.uz_shashlik.step1.body" = "Cut the %i1 into kebab-sized pieces. Cut the %i2 into smaller pieces for alternating on skewers. Slice the %i3 thinly and slice the %i8 for serving. Chop the %i9.";
"recipe.uz_shashlik.step1.title" = "Prepare lamb and onions";
"recipe.uz_shashlik.step2.body" = "In a bowl, combine the lamb, tail fat, marinade onion, %i4, %i5, %i6, and %i7. Mix thoroughly so the meat is evenly coated and lightly compressed by the onions.";
"recipe.uz_shashlik.step2.title" = "Make marinade";
"recipe.uz_shashlik.step3.body" = "Cover and marinate the meat until it is seasoned through and the onions have softened.";
"recipe.uz_shashlik.step3.title" = "Marinate";
"recipe.uz_shashlik.step4.body" = "Thread the lamb onto skewers, alternating with pieces of tail fat so the skewers cook evenly and baste themselves over the fire.";
"recipe.uz_shashlik.step4.title" = "Skewer the meat";
"recipe.uz_shashlik.step5.body" = "Heat the charcoal until very hot and covered with ash, then spread it into an even bed for direct grilling.";
"recipe.uz_shashlik.step5.title" = "Prepare coals";
"recipe.uz_shashlik.step6.body" = "Place the skewers over the coals and grill, turning regularly, until the lamb is browned and lightly charred on the outside and cooked through while still juicy.";
"recipe.uz_shashlik.step6.title" = "Grill shashlik";
"recipe.uz_shashlik.step7.body" = "Move the skewers off the heat and let the shashlik rest briefly so the juices settle.";
"recipe.uz_shashlik.step7.title" = "Rest briefly";
"recipe.uz_shashlik.step8.body" = "Warm the %i10 briefly. Toss the sliced red onion with the cilantro so it is ready for serving.";
"recipe.uz_shashlik.step8.title" = "Warm bread and garnish onions";
"recipe.uz_shashlik.step9.body" = "Serve the hot shashlik on a platter or on the skewers with the onion-cilantro garnish and torn non bread.";
"recipe.uz_shashlik.step9.title" = "Serve";
"recipe.uz_shashlik.tool.t1" = "Mangal or charcoal grill";
"recipe.uz_shashlik.tool.t2" = "Metal skewers";
