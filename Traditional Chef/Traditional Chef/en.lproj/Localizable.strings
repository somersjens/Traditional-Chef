"recipe.id_soto_betawi.drink.body" = "A light lager or an aromatic white wine such as Viognier pairs well with the rich spiced broth. For a non-alcoholic pairing, serve hot jasmine tea or chilled lime water.";
"recipe.id_soto_betawi.drink.summary" = "Beer (Lager)";
"recipe.id_soto_betawi.info" = "Soto Betawi is a traditional Jakarta beef soup with a rich creamy broth made from coconut milk and milk, fragrant with Indonesian spices and served with beef, offal or both. It is commonly enjoyed as a hearty main meal with rice, emping crackers, pickles, sambal, and lime on the side.";
"recipe.id_soto_betawi.info.summary" = "Jakarta creamy beef soup";
"recipe.id_soto_betawi.name" = "Soto Betawi";
