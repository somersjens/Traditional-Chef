"recipe.es_torrijas.drink.body" = "Pair with a sweet wine such as Moscatel or a lightly sweet sherry to complement the cinnamon and fried bread. A glass of dry Cava also works well to refresh the palate. Non-alcoholic option: café con leche or black tea.";
"recipe.es_torrijas.drink.summary" = "Sweet wine (Moscatel)";
"recipe.es_torrijas.info" = "Torrijas are Spain’s traditional Holy Week sweet: thick slices of stale bread soaked in cinnamon-citrus infused milk, dipped in egg, fried until golden, then coated in cinnamon sugar. Served warm or at room temperature, they are rich, custardy, and aromatic, often enjoyed with coffee after meals during Semana Santa.";
"recipe.es_torrijas.info.summary" = "Holy Week bread pudding";
"recipe.es_torrijas.name" = "Torrijas";
"recipe.es_torrijas.step1.body" = "Warm %i1 with %i3 and strips of %i4 until steaming and fragrant, then remove from heat to infuse.";
"recipe.es_torrijas.step1.title" = "Infuse the milk";
"recipe.es_torrijas.step2.body" = "Stir %i2 into the warm milk until dissolved, then let it cool so it can soak the bread without scrambling the egg later.";
"recipe.es_torrijas.step2.title" = "Sweeten and cool slightly";
"recipe.es_torrijas.step3.body" = "Cut %i5 into thick slices and soak them in the infused milk until well saturated but still holding their shape.";
"recipe.es_torrijas.step3.title" = "Soak the bread";
"recipe.es_torrijas.step4.body" = "Beat %i6 in a bowl. Mix %i8 with %i9 on a plate for coating.";
"recipe.es_torrijas.step4.title" = "Prepare egg and cinnamon sugar";
"recipe.es_torrijas.step5.body" = "Heat %i7 in a skillet. Dip soaked bread in egg and fry until deeply golden on both sides, working in batches.";
"recipe.es_torrijas.step5.title" = "Fry until golden";
"recipe.es_torrijas.step6.body" = "Drain briefly on paper towels, then coat each torrija in cinnamon sugar while still warm.";
"recipe.es_torrijas.step6.title" = "Drain and coat";
"recipe.es_torrijas.step7.body" = "Serve warm or at room temperature.";
"recipe.es_torrijas.step7.title" = "Serve";
