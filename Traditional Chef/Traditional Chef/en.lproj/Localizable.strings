"recipe.de_schweinshaxe.step10.title" = "Start the sauerkraut";
"recipe.de_schweinshaxe.step11.body" = "Cover and simmer gently until tender and well flavoured, stirring occasionally.";
"recipe.de_schweinshaxe.step11.title" = "Simmer the sauerkraut";
"recipe.de_schweinshaxe.step12.body" = "Serve the pork knuckles hot with potato dumplings and sauerkraut.";
"recipe.de_schweinshaxe.step12.title" = "Serve the pork";
