"recipe.kr_galbi.step11.title" = "Finish the galbi";
"recipe.kr_galbi.step12.body" = "Fluff the rested rice and divide it into serving bowls.";
"recipe.kr_galbi.step12.title" = "Fluff the rice";
"recipe.kr_galbi.step13.body" = "Serve the galbi hot with rice, ssam vegetables, ssamjang, and kitchen scissors for cutting the ribs into bite-size pieces at the table.";
"recipe.kr_galbi.step13.title" = "Serve";
