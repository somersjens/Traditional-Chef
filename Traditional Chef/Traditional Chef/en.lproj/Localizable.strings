"recipe.kh_samlor_machu_yuon.drink.body" = "An aromatic white wine such as Riesling pairs well with the tamarind sourness, pineapple sweetness, and fragrant herbs. A crisp pale lager also works well. For a non-alcoholic option, serve iced jasmine tea or chilled water with lime.";
"recipe.kh_samlor_machu_yuon.drink.summary" = "White wine (Riesling)";
"recipe.kh_samlor_machu_yuon.info" = "Samlor machu yuon is a traditional Cambodian sweet-sour fish soup influenced by Vietnamese canh chua, made with tamarind, pineapple, tomato, aromatics, and fresh herbs. It is commonly served hot as a family meal with steamed rice, with a broth that balances sour, savory, and lightly sweet flavors.";
"recipe.kh_samlor_machu_yuon.info.summary" = "Sour fish soup";
"recipe.kh_samlor_machu_yuon.name" = "Samlor machu yuon";
"recipe.kh_samlor_machu_yuon.step1.body" = "Trim the %i1 and bruise the tender parts. Slice the %i2 and %i3, tear the %i4, and slice the %i5. Cut the %i15, %i16, and %i17 into bite-size pieces. Trim and cut the %i18, pick the %i19, and slice the %i20.";
"recipe.kh_samlor_machu_yuon.step1.title" = "Prepare aromatics and produce";
"recipe.kh_samlor_machu_yuon.step10.body" = "Add the fish pieces and simmer gently until the fish is just cooked through and the broth is balanced sweet-sour and savory.";
"recipe.kh_samlor_machu_yuon.step10.title" = "Cook fish";
"recipe.kh_samlor_machu_yuon.step11.body" = "Add the rice paddy herb, scallions, and chili, and simmer briefly to release their aroma.";
"recipe.kh_samlor_machu_yuon.step11.title" = "Finish with herbs";
"recipe.kh_samlor_machu_yuon.step12.body" = "Ladle the hot samlor machu yuon into bowls and serve with steamed rice.";
"recipe.kh_samlor_machu_yuon.step12.title" = "Serve";
"recipe.kh_samlor_machu_yuon.step2.body" = "Soak the %i6 in hot %i7, mash it well, then strain to obtain tamarind juice.";
"recipe.kh_samlor_machu_yuon.step2.title" = "Make tamarind extract";
"recipe.kh_samlor_machu_yuon.step3.body" = "Cut the %i8 into bite-size pieces and set aside.";
"recipe.kh_samlor_machu_yuon.step3.title" = "Prepare fish";
"recipe.kh_samlor_machu_yuon.step4.body" = "Rinse the %i21 until the water runs mostly clear, then drain.";
"recipe.kh_samlor_machu_yuon.step4.title" = "Wash rice";
"recipe.kh_samlor_machu_yuon.step5.body" = "Place the rice in a saucepan with %i22, bring to a boil, cover, and cook gently until the rice is tender and the water is absorbed.";
"recipe.kh_samlor_machu_yuon.step5.title" = "Cook rice";
"recipe.kh_samlor_machu_yuon.step6.body" = "Turn off the heat and let the covered rice rest, then fluff before serving.";
"recipe.kh_samlor_machu_yuon.step6.title" = "Rest rice";
"recipe.kh_samlor_machu_yuon.step7.body" = "Heat the %i14 in a large pot, add the lemongrass, galangal, and garlic, and cook gently until fragrant.";
"recipe.kh_samlor_machu_yuon.step7.title" = "Start soup base";
"recipe.kh_samlor_machu_yuon.step8.body" = "Add water, %i9, %i11, %i12, %i13, makrut lime leaves, and the tamarind juice, then stir and bring to a gentle simmer.";
"recipe.kh_samlor_machu_yuon.step8.title" = "Build broth";
"recipe.kh_samlor_machu_yuon.step9.body" = "Add the chayote and lotus stems first and simmer until they begin to soften, then add the pineapple and tomatoes.";
"recipe.kh_samlor_machu_yuon.step9.title" = "Cook vegetables";
