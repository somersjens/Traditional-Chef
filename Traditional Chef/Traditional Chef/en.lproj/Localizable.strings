"recipe.sk_kapustnica.step1.title" = "Prepare the ingredients";
"recipe.sk_kapustnica.step10.body" = "Serve the kapustnica hot with %i18 alongside.";
"recipe.sk_kapustnica.step10.title" = "Serve traditionally";
"recipe.sk_kapustnica.step2.body" = "Place the sauerkraut, %i2, smoked pork, soaked mushrooms with their soaking liquid, %i12, %i13, and water in the pot. Bring to a boil, then lower the heat.";
"recipe.sk_kapustnica.step2.title" = "Start the soup";
"recipe.sk_kapustnica.step3.body" = "Cook the soup gently until the smoked pork and mushrooms begin to soften and the broth takes on their flavor.";
"recipe.sk_kapustnica.step3.title" = "Simmer the smoky base";
"recipe.sk_kapustnica.step4.body" = "Heat %i9 in the skillet, cook the onion until softened, then add the garlic and sausage. Stir in %i10 and %i11 and cook briefly until fragrant.";
"recipe.sk_kapustnica.step4.title" = "Cook the onion and sausage";
"recipe.sk_kapustnica.step5.body" = "Scrape the onion and sausage mixture into the pot and stir well so the smoky and paprika flavors spread through the broth.";
"recipe.sk_kapustnica.step5.title" = "Add the base to the soup";
"recipe.sk_kapustnica.step6.body" = "Add the potatoes and simmer until they are tender and the soup becomes heartier.";
"recipe.sk_kapustnica.step6.title" = "Cook the potatoes";
"recipe.sk_kapustnica.step7.body" = "Whisk %i15 with %i16 until smooth, then loosen it with a little hot broth so it blends evenly into the soup.";
"recipe.sk_kapustnica.step7.title" = "Make the cream thickener";
"recipe.sk_kapustnica.step8.body" = "Stir the sour cream mixture into the soup and cook gently until slightly thickened. Taste and adjust with %i17.";
"recipe.sk_kapustnica.step8.title" = "Finish the kapustnica";
"recipe.sk_kapustnica.step9.body" = "Let the kapustnica stand briefly off the heat so the flavors settle and the broth smooths out.";
"recipe.sk_kapustnica.step9.title" = "Rest the soup";
