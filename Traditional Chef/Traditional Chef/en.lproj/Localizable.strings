"recipe.kh_num_plae_ai.step3.body" = "Divide the dough into small portions, flatten each one, place a piece of palm sugar in the center, seal well, and roll into smooth balls.";
"recipe.kh_num_plae_ai.step3.title" = "Shape filled dumplings";
"recipe.kh_num_plae_ai.step4.body" = "Toast the %i9 in a dry pan until fragrant and lightly golden, then let them cool slightly.";
"recipe.kh_num_plae_ai.step4.title" = "Toast sesame";
"recipe.kh_num_plae_ai.step5.body" = "Mix the %i8 with the toasted sesame seeds and a little %i10 on a plate or tray.";
"recipe.kh_num_plae_ai.step5.title" = "Prepare coconut coating";
"recipe.kh_num_plae_ai.step6.body" = "Bring %i5 to a gentle boil in a large pot and add a little %i6.";
"recipe.kh_num_plae_ai.step6.title" = "Boil water";
"recipe.kh_num_plae_ai.step7.body" = "Lower the filled dumplings into the simmering water and cook until they float and the dough is tender.";
"recipe.kh_num_plae_ai.step7.title" = "Cook dumplings";
"recipe.kh_num_plae_ai.step8.body" = "Lift the dumplings out with a slotted spoon and transfer them to %i7 briefly so they firm up slightly.";
"recipe.kh_num_plae_ai.step8.title" = "Cool briefly";
"recipe.kh_num_plae_ai.step9.body" = "Drain the dumplings and roll them in the coconut-sesame mixture until fully coated.";
"recipe.kh_num_plae_ai.step9.title" = "Coat dumplings";
