"recipe.no_pinnekjott.drink.body" = "A light lager or a fresh dry cider suits the salty, rich lamb and sweet rutabaga. A good non-alcoholic pairing is cold sparkling water or a crisp apple drink.";
"recipe.no_pinnekjott.drink.summary" = "Beer (Lager)";
"recipe.no_pinnekjott.info" = "Pinnekjott is a deeply traditional Norwegian Christmas dish of salt-cured, dried lamb ribs, especially associated with Western Norway. The ribs are soaked, then steamed until tender, and traditionally served with rutabaga mash, boiled potatoes, and some of the rich cooking liquor.";
"recipe.no_pinnekjott.info.summary" = "Christmas lamb ribs";
"recipe.no_pinnekjott.name" = "Pinnekjøtt";
"recipe.no_pinnekjott.step1.body" = "Rinse %i1 and soak it in cold water to reduce the saltiness, changing the water once during soaking.";
"recipe.no_pinnekjott.step1.title" = "Soak the pinnekjott";
"recipe.no_pinnekjott.step2.body" = "Place the birch sticks in the bottom of the large pot, add %i2 so it sits below the sticks, and bring it to a gentle simmer.";
"recipe.no_pinnekjott.step2.title" = "Prepare the steaming pot";
"recipe.no_pinnekjott.step3.body" = "Arrange the pinnekjott on top of the birch sticks, cover with the lid, and steam gently until the meat is very tender and loosens easily from the bones, adding more water if needed.";
"recipe.no_pinnekjott.step3.title" = "Steam the pinnekjott";
"recipe.no_pinnekjott.step4.body" = "Peel and cut %i3, %i4, and %i5 for the mash into even pieces.";
"recipe.no_pinnekjott.step4.title" = "Prepare the vegetables";
"recipe.no_pinnekjott.step5.body" = "Boil the rutabaga, carrot, and the potato until completely tender, then drain well.";
"recipe.no_pinnekjott.step5.title" = "Cook the rutabaga mash base";
"recipe.no_pinnekjott.step6.body" = "Mash the cooked vegetables with %i6, %i7, %i8, and %i9 until smooth but still rustic, then keep warm.";
"recipe.no_pinnekjott.step6.title" = "Mash the rutabaga";
"recipe.no_pinnekjott.step7.body" = "Cook %i10 in salted %i11 until tender, then drain them.";
"recipe.no_pinnekjott.step7.title" = "Boil the potatoes";
"recipe.no_pinnekjott.step8.body" = "Lift the pinnekjott from the pot and serve it immediately with the rutabaga mash, boiled potatoes, and a little of the cooking liquor spooned over the meat.";
"recipe.no_pinnekjott.step8.title" = "Serve";
