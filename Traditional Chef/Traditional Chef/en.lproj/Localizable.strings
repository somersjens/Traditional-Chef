"recipe.no_farikal.step1.body" = "Cut %i2 into wedges, keeping enough core attached so the wedges hold together.";
"recipe.no_farikal.step1.title" = "Prepare the cabbage";
"recipe.no_farikal.step2.body" = "Place %i1 in the pot with the fattier pieces at the bottom. Layer the cabbage over it and continue in layers, sprinkling %i3 and %i4 between each layer.";
"recipe.no_farikal.step2.title" = "Layer the pot";
"recipe.no_farikal.step3.body" = "Pour in %i5, set the pot over medium heat, and bring everything steadily to a boil.";
"recipe.no_farikal.step3.title" = "Add water and heat";
"recipe.no_farikal.step4.body" = "Cover with the lid, lower the heat, and let the stew simmer gently until the meat is very tender and nearly falling from the bone.";
"recipe.no_farikal.step4.title" = "Simmer until tender";
"recipe.no_farikal.step5.body" = "Near the end of cooking, boil %i6 in their skins until tender, then drain them.";
"recipe.no_farikal.step5.title" = "Boil the potatoes";
"recipe.no_farikal.step6.body" = "Lift the meat and cabbage carefully onto plates or shallow bowls, spoon over some broth and peppercorns, and serve immediately with the boiled potatoes.";
"recipe.no_farikal.step6.title" = "Serve";
