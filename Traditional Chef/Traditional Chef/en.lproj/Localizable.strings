"recipe.pt_toucinho_do_ceu.drink.body" = "A lightly sweet Moscatel or a tawny-style fortified wine complements the caramel-almond notes and the cinnamon finish without overwhelming the custardy crumb. Non-alcoholic pairing: espresso or strong black coffee, or sparkling water with lemon.";
"recipe.pt_toucinho_do_ceu.drink.summary" = "Moscatel";
"recipe.pt_toucinho_do_ceu.info" = "Toucinho do Ceu is a traditional Portuguese conventual dessert: a rich, moist almond and egg-yolk cake bound with a sugar syrup and a small amount of pork fat, baked until set and finished with a light dusting of cinnamon and sugar. It is typically served in small slices at room temperature, often alongside coffee after a meal or at celebrations.";
"recipe.pt_toucinho_do_ceu.info.summary" = "Convent almond cake";
"recipe.pt_toucinho_do_ceu.name" = "Toucinho do Céu";
"recipe.pt_toucinho_do_ceu.step1.body" = "Line the cake pan with parchment and preheat the oven. Zest %i8 finely and set aside.";
"recipe.pt_toucinho_do_ceu.step1.title" = "Prepare to bake";
"recipe.pt_toucinho_do_ceu.step2.body" = "Bring %i2 and %i3 to a boil and cook until it reaches a light thread stage, then remove from the heat.";
"recipe.pt_toucinho_do_ceu.step2.title" = "Cook the syrup";
"recipe.pt_toucinho_do_ceu.step3.body" = "Whisk %i4 and %i5 until smooth without whipping in much air, then whisk in the lemon zest.";
"recipe.pt_toucinho_do_ceu.step3.title" = "Start the egg mixture";
"recipe.pt_toucinho_do_ceu.step4.body" = "Fold %i1 into the egg mixture, then sift in %i7 and fold until fully combined.";
"recipe.pt_toucinho_do_ceu.step4.title" = "Add almonds and flour";
"recipe.pt_toucinho_do_ceu.step5.body" = "Whisk the warm syrup into the mixture in a steady stream until smooth, then add %i6 and mix until completely emulsified.";
"recipe.pt_toucinho_do_ceu.step5.title" = "Incorporate syrup and fat";
"recipe.pt_toucinho_do_ceu.step6.body" = "Pour the batter into the prepared pan and bake until the cake is set and lightly golden, with a slight wobble in the center.";
"recipe.pt_toucinho_do_ceu.step6.title" = "Bake";
"recipe.pt_toucinho_do_ceu.step7.body" = "Cool in the pan briefly, then turn out onto a wire rack and let it cool completely.";
"recipe.pt_toucinho_do_ceu.step7.title" = "Cool";
"recipe.pt_toucinho_do_ceu.step8.body" = "Dust the top with %i10 and %i9, slice, and serve.";
"recipe.pt_toucinho_do_ceu.step8.title" = "Finish and serve";
