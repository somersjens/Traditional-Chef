"recipe.gr_gemista.step2.title" = "Make the filling base";
"recipe.gr_gemista.step3.body" = "Fill the tomatoes and peppers with the rice mixture, leaving space for the rice to expand. Replace the lids and arrange them in a baking dish with the potato wedges around them.";
"recipe.gr_gemista.step3.title" = "Stuff and arrange";
"recipe.gr_gemista.step4.body" = "Mix %i14 with a little tomato pulp if needed and pour it into the dish. Drizzle the vegetables and potatoes with %i16.";
"recipe.gr_gemista.step4.title" = "Add the liquids";
"recipe.gr_gemista.step5.body" = "Cover and bake until the vegetables soften and the rice starts cooking through.";
"recipe.gr_gemista.step5.title" = "Bake covered";
"recipe.gr_gemista.step6.body" = "Uncover and continue baking until the tops are lightly browned, the rice is tender, and the potatoes are golden.";
"recipe.gr_gemista.step6.title" = "Bake uncovered";
"recipe.gr_gemista.step7.body" = "Serve warm or at room temperature with %i18 and %i19.";
"recipe.gr_gemista.step7.title" = "Serve the gemista";
