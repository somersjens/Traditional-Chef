"recipe.id_soto_ayam.drink.summary" = "Beer (Lager)";
"recipe.id_soto_ayam.info" = "Soto ayam is a traditional Indonesian chicken soup with a fragrant yellow turmeric broth, shredded chicken, and assorted garnishes such as cabbage, bean sprouts, egg, and herbs. It is commonly served as a comforting everyday meal with rice or rice cakes, sambal, lime, and crackers on the side.";
"recipe.id_soto_ayam.info.summary" = "Turmeric chicken soup";
"recipe.id_soto_ayam.name" = "Soto ayam";
"recipe.id_soto_ayam.step1.body" = "Clean the %i1 and prepare the aromatics. Bruise the %i8 and %i9, and slice the %i19, %i22, and %i23 for garnish.";
"recipe.id_soto_ayam.step1.title" = "Prepare the chicken and aromatics";
"recipe.id_soto_ayam.step10.body" = "Ladle the hot yellow broth over the bowls and finish with scallions, celery leaves, and %i24. Serve with %i25, sambal, and %i26 on the side.";
"recipe.id_soto_ayam.step10.title" = "Serve the soto ayam";
"recipe.id_soto_ayam.step2.body" = "Grind the %i3, %i4, %i5, %i6, %i7, %i12, and %i13 into a smooth paste.";
"recipe.id_soto_ayam.step2.title" = "Make the spice paste";
"recipe.id_soto_ayam.step3.body" = "Heat %i16 in a small pan and fry the spice paste until fragrant and cooked through, stirring so it does not scorch.";
"recipe.id_soto_ayam.step3.title" = "Fry the spice paste";
"recipe.id_soto_ayam.step4.body" = "Place the chicken in a pot with %i2, bring to a gentle simmer, then add the fried spice paste, galangal, lemongrass, %i10, %i11, %i14, and %i15. Simmer until the chicken is cooked and the broth is aromatic.";
"recipe.id_soto_ayam.step4.title" = "Simmer the chicken broth";
"recipe.id_soto_ayam.step5.body" = "Lift out the chicken and let it cool briefly, then shred the meat. Return the meat to the broth or reserve it for bowl assembly, and strain the broth if you want a cleaner soup.";
"recipe.id_soto_ayam.step5.title" = "Shred the chicken and strain if needed";
"recipe.id_soto_ayam.step6.body" = "Boil the %i21 until hard-boiled, cool and peel them, and soak or blanch the %i18 until tender, then drain.";
