"recipe.tt_pelau.drink.body" = "A fruit-forward Grenache or Zinfandel complements the caramelized notes and spice, while a cold lager is a classic casual match. For a non-alcoholic option, serve chilled ginger beer or mauby to balance the savory richness.";
"recipe.tt_pelau.drink.summary" = "Red wine (Grenache)";
"recipe.tt_pelau.info" = "Pelau is Trinidad and Tobago’s signature one-pot meal: chicken is browned in caramelized sugar, then simmered with pigeon peas, rice, aromatics, coconut milk, and classic seasonings until the rice is fluffy and deeply flavored. It’s a staple for limes, family Sundays, and beach days, often served with a crisp salad and pepper sauce on the side.";
"recipe.tt_pelau.info.summary" = "One-pot pelau";
"recipe.tt_pelau.name" = "Pelau";
