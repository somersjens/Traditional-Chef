"recipe.kr_doenjang_jjigae.step7.title" = "Season the broth";
"recipe.kr_doenjang_jjigae.step8.body" = "Add the potato and onion and simmer until they begin to soften.";
"recipe.kr_doenjang_jjigae.step8.title" = "Cook the hardy vegetables";
