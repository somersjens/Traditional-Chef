"recipe.sn_thiakry.drink.body" = "A lightly chilled Moscato or other aromatic sweet white pairs nicely with the creamy yogurt and millet. For a non-alcoholic option, serve hot mint tea or chilled bissap (hibiscus drink).";
"recipe.sn_thiakry.drink.summary" = "Sweet wine (Moscato)";
"recipe.sn_thiakry.info" = "Thiakry is a traditional Senegalese dessert of millet couscous folded into sweetened, lightly perfumed yogurt, often served chilled in bowls as a refreshing finish to a meal or as a celebratory sweet.";
"recipe.sn_thiakry.info.summary" = "Millet yogurt sweet";
"recipe.sn_thiakry.name" = "Thiakry";
"recipe.sn_thiakry.step1.body" = "Place the %i1 in a bowl and moisten it with %i2, rubbing between your hands to separate grains.";
"recipe.sn_thiakry.step1.title" = "Moisten the millet";
"recipe.sn_thiakry.step2.body" = "Transfer the millet to a steamer and steam until tender and fluffy, then tip into a bowl.";
"recipe.sn_thiakry.step2.title" = "Steam the millet";
"recipe.sn_thiakry.step3.body" = "Fluff the millet thoroughly to break up clumps and let it cool until just warm so it will not thin the yogurt.";
"recipe.sn_thiakry.step3.title" = "Fluff and cool";
"recipe.sn_thiakry.step4.body" = "Whisk %i3 with %i4, %i5, and %i6 until smooth and the sugar dissolves.";
"recipe.sn_thiakry.step4.title" = "Sweeten the yogurt";
"recipe.sn_thiakry.step5.body" = "Fold the cooled millet into the sweetened yogurt until evenly mixed and spoonable.";
"recipe.sn_thiakry.step5.title" = "Combine";
"recipe.sn_thiakry.step6.body" = "Cover and chill until cold and set, then portion into bowls and serve.";
"recipe.sn_thiakry.step6.title" = "Chill";
