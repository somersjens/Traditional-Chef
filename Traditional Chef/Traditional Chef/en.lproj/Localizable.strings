"recipe.bo_queso_humacha.drink.body" = "A fresh medium-bodied white wine such as unoaked Chardonnay pairs well with the creamy cheese, sweet corn, and yellow chili. A light lager also works well. For a non-alcoholic option, serve hot herbal tea or sparkling water with lime.";
"recipe.bo_queso_humacha.drink.summary" = "White wine (Chardonnay)";
"recipe.bo_queso_humacha.info" = "Queso Humacha is a traditional Bolivian highland dish, especially associated with La Paz and Holy Week, made from fresh cheese, yellow chili, milk, potatoes, broad beans, peas, and corn, finished with huacataya. It is served hot as a hearty meatless main course, most often with boiled potatoes and choclo in the plate.";
"recipe.bo_queso_humacha.info.summary" = "Cheese potato stew";
"recipe.bo_queso_humacha.name" = "Queso humacha";
"recipe.bo_queso_humacha.step1.body" = "Cut %i1 into large cubes, finely chop %i2 and %i3, dice %i4, shell %i10 if needed, and chop %i13.";
"recipe.bo_queso_humacha.step1.title" = "Prepare the ingredients";
"recipe.bo_queso_humacha.step2.body" = "Boil %i14 and %i15 in %i9 until both are tender. Remove them, keep them warm, and reserve some of the cooking liquid.";
"recipe.bo_queso_humacha.step2.title" = "Cook the potatoes and corn";
"recipe.bo_queso_humacha.step3.body" = "Heat %i5 in the skillet and cook the onion and garlic until softened. Add the tomatoes, %i6, and %i7, and cook until the mixture becomes fragrant and lightly thickened.";
"recipe.bo_queso_humacha.step3.title" = "Start the base";
"recipe.bo_queso_humacha.step4.body" = "Add the fava beans and %i11 with a little reserved cooking liquid and simmer until they are tender and the base is saucy.";
"recipe.bo_queso_humacha.step4.title" = "Cook the vegetables";
"recipe.bo_queso_humacha.step5.body" = "Pour in %i8 and bring the sauce to a gentle simmer. Add the cheese and stir carefully so it softens and thickens the sauce without breaking down completely.";
"recipe.bo_queso_humacha.step5.title" = "Add the milk and cheese";
"recipe.bo_queso_humacha.step6.body" = "Add the huacataya and %i12, then simmer briefly so the herb perfumes the sauce while staying fresh.";
"recipe.bo_queso_humacha.step6.title" = "Finish the humacha";
"recipe.bo_queso_humacha.step7.body" = "Serve the queso humacha hot over the boiled potatoes with the corn alongside, making sure each plate gets plenty of cheese, sauce, and vegetables.";
"recipe.bo_queso_humacha.step7.title" = "Serve traditionally";
