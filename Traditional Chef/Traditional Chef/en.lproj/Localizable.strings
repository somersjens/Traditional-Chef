"recipe.gr_saganaki.step2.title" = "Fry the cheese";
"recipe.gr_saganaki.step3.body" = "Squeeze %i4 over the hot cheese and serve immediately with %i5.";
"recipe.gr_saganaki.step3.title" = "Finish and serve";
