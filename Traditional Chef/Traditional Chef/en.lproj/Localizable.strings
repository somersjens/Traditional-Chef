"recipe.tr_sigara_boregi.drink.body" = "A crisp Sauvignon Blanc or dry Riesling cuts through the fried pastry and salty cheese, while a light dry rosé also works. For a non-alcoholic option, serve Turkish tea or ayran alongside.";
"recipe.tr_sigara_boregi.drink.summary" = "White wine (Sauvignon)";
"recipe.tr_sigara_boregi.info" = "Sigara Böreği is a traditional Turkish meze of thin yufka pastry triangles rolled around a savory white-cheese and parsley filling, then fried until crisp and golden. Common on breakfast tables and mezze spreads, it is served hot and crunchy, often alongside tea or as part of a mixed appetizer plate.";
"recipe.tr_sigara_boregi.info.summary" = "Crisp cheese rolls";
"recipe.tr_sigara_boregi.name" = "Cheese börek";
"recipe.tr_sigara_boregi.step1.body" = "Crumble %i1 and finely chop %i2, then mix until evenly combined.";
"recipe.tr_sigara_boregi.step1.title" = "Prepare the filling";
"recipe.tr_sigara_boregi.step2.body" = "Cut %i3 into triangles, place filling near the wide end, roll tightly, fold in the sides, and seal the tip with %i4.";
"recipe.tr_sigara_boregi.step2.title" = "Cut and roll";
"recipe.tr_sigara_boregi.step3.body" = "Heat %i5 in a deep skillet until hot enough to fry steadily.";
"recipe.tr_sigara_boregi.step3.title" = "Heat the frying oil";
"recipe.tr_sigara_boregi.step4.body" = "Fry the rolls in batches until deep golden and crisp, turning so they color evenly, then drain on paper towels.";
"recipe.tr_sigara_boregi.step4.title" = "Fry until crisp";
"recipe.tr_sigara_boregi.step5.body" = "Serve hot and crisp.";
"recipe.tr_sigara_boregi.step5.title" = "Serve";
