"recipe.mu_flan_coco.drink.body" = "Pair with a lightly sweet dessert wine such as Muscat to echo the caramel and coconut without overwhelming the custard. If you prefer something less sweet, a late-harvest Chenin works nicely. Non-alcoholic pairing: strong black tea or chilled coconut water.";
"recipe.mu_flan_coco.drink.summary" = "Dessert wine (Muscat)";
"recipe.mu_flan_coco.info" = "Mauritian flan coco is a silky baked custard perfumed with coconut and set under a deep caramel layer, then unmolded so the caramel coats the top and sides. It is a classic home dessert served well chilled after family meals and celebrations, sliced and spooned with its caramel syrup.";
"recipe.mu_flan_coco.info.summary" = "Coconut caramel flan";
"recipe.mu_flan_coco.name" = "Coconut flan";
