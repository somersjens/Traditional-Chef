"recipe.be_chicons_au_gratin.drink.body" = "Pair with a medium-bodied dry white such as Chardonnay to match the béchamel and melted cheese, or a Belgian blond ale for an easy pub-style match. For a non-alcoholic option, serve sparkling water or an alcohol-free blond beer to keep the meal light.";
"recipe.be_chicons_au_gratin.drink.summary" = "White wine (Chardonnay)";
"recipe.be_chicons_au_gratin.info" = "Chicons au gratin is a Belgian comfort classic: tender braised Belgian endives wrapped in ham, covered with silky béchamel sauce, and baked until bubbling with a golden cheese crust. It is traditionally served hot with mashed potatoes, which soak up the creamy sauce and balance the slight bitterness of the chicons.";
"recipe.be_chicons_au_gratin.info.summary" = "Belgian baked endives";
"recipe.be_chicons_au_gratin.name" = "Chicory gratin";
"recipe.be_chicons_au_gratin.step1.body" = "Trim the base of %i1, remove any damaged outer leaves, and cut out the hard core at the bottom to reduce bitterness.";
"recipe.be_chicons_au_gratin.step1.title" = "Prep the chicons";
"recipe.be_chicons_au_gratin.step2.body" = "Melt part of %i2 in a covered skillet, lay in the endives, season with %i4 and %i5, and sprinkle with %i3. Cover and braise gently, turning once, until tender and most moisture has cooked off.";
"recipe.be_chicons_au_gratin.step2.title" = "Braise the chicons";
"recipe.be_chicons_au_gratin.step3.body" = "Cook %i14 in salted water until very tender. Drain well and let the steam evaporate briefly.";
"recipe.be_chicons_au_gratin.step3.title" = "Boil the potatoes";
"recipe.be_chicons_au_gratin.step4.body" = "Melt %i7 in a saucepan, whisk in %i8, and cook briefly. Whisk in %i9 gradually and cook until smooth and thick. Season with %i10, %i11, and %i12.";
"recipe.be_chicons_au_gratin.step4.title" = "Make the béchamel";
"recipe.be_chicons_au_gratin.step5.body" = "Preheat the oven. Wrap each drained endive in %i6 and place them snugly in a baking dish.";
"recipe.be_chicons_au_gratin.step5.title" = "Wrap and arrange";
"recipe.be_chicons_au_gratin.step6.body" = "Pour the béchamel over the wrapped endives and cover evenly with %i13.";
"recipe.be_chicons_au_gratin.step6.title" = "Sauce and cheese";
"recipe.be_chicons_au_gratin.step7.body" = "Bake until the sauce is bubbling and the top is golden and gratiné.";
"recipe.be_chicons_au_gratin.step7.title" = "Bake until golden";
"recipe.be_chicons_au_gratin.step8.body" = "Mash the hot potatoes, then mix in %i15 and %i16 until creamy. Season with %i17.";
"recipe.be_chicons_au_gratin.step8.title" = "Mash the potatoes";
"recipe.be_chicons_au_gratin.step9.body" = "Serve the chicons au gratin hot with mashed potatoes alongside.";
