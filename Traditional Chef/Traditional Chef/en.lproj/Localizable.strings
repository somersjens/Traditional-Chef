"recipe.cz_svickova_na_smetane.step3.body" = "Refrigerate the beef in the marinade overnight, turning it once so the meat and vegetables season evenly.";
"recipe.cz_svickova_na_smetane.step3.title" = "Marinate overnight";
"recipe.cz_svickova_na_smetane.step4.body" = "Remove the beef from the marinade and pat it dry. Heat %i7 in the Dutch oven, brown the beef on all sides, then add the marinated vegetables and cook until they begin to color.";
"recipe.cz_svickova_na_smetane.step4.title" = "Brown the beef and vegetables";
"recipe.cz_svickova_na_smetane.step5.body" = "Add the marinade liquid and bring to a gentle simmer. Cover and braise until the beef is tender and the vegetables are completely soft.";
"recipe.cz_svickova_na_smetane.step5.title" = "Braise the beef";
"recipe.cz_svickova_na_smetane.step6.body" = "Lift out the beef and keep it warm. Remove the bay leaf and thyme, blend the vegetables and cooking liquid until smooth, then return the sauce to the pot and stir in %i15, %i16, and the remaining %i17.";
"recipe.cz_svickova_na_smetane.step6.title" = "Make the creamy sauce";
