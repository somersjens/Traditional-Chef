"recipe.be_dame_blanche.step3.title" = "Finish the sauce";
"recipe.be_dame_blanche.step4.body" = "Whip %i7 with %i8 and %i9 until it holds soft peaks and can be spooned or piped.";
"recipe.be_dame_blanche.step4.title" = "Whip the cream";
"recipe.be_dame_blanche.step5.body" = "Scoop %i1 into chilled glasses or bowls, working quickly so it stays firm.";
"recipe.be_dame_blanche.step5.title" = "Plate the ice cream";
"recipe.be_dame_blanche.step6.body" = "Ladle the warm chocolate sauce over the ice cream and top generously with whipped cream.";
"recipe.be_dame_blanche.step6.title" = "Add sauce and cream";
"recipe.be_dame_blanche.step7.body" = "Serve right away while the sauce is warm and the ice cream is still cold.";
"recipe.be_dame_blanche.step7.title" = "Serve immediately";
