"recipe.be_carbonnade_flamande.step4.body" = "Stir %i5 into the onions and cook briefly so the raw taste disappears while keeping everything moving.";
"recipe.be_carbonnade_flamande.step4.title" = "Coat with flour";
"recipe.be_carbonnade_flamande.step5.body" = "Pour in %i6 gradually while stirring to smooth the sauce. Add %i9, %i10, %i11, %i14, %i15, %i7, and %i8, and bring to a steady simmer.";
"recipe.be_carbonnade_flamande.step5.title" = "Build the braise";
