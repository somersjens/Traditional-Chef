"recipe.hk_mango_pudding.drink.body" = "This chilled fruit dessert is usually paired with tea rather than wine, especially jasmine tea after dim sum. If serving wine, a lightly sweet Moscato can work, while hot jasmine tea or cold barley water is a classic non-alcoholic pairing.";
"recipe.hk_mango_pudding.drink.summary" = "Jasmine tea";
"recipe.hk_mango_pudding.info" = "A traditional Hong Kong dessert-shop and dim sum pudding made with ripe mango puree, milk, and gelatin, set until softly firm and served cold. It is commonly presented in small bowls or molded portions and finished with a little evaporated milk at the table.";
"recipe.hk_mango_pudding.info.summary" = "Chilled mango pudding";
"recipe.hk_mango_pudding.name" = "Mango pudding";
"recipe.hk_mango_pudding.step1.body" = "Peel and cut the %i1, then blend until very smooth.";
"recipe.hk_mango_pudding.step1.title" = "Prepare the mango puree";
"recipe.hk_mango_pudding.step2.body" = "Sprinkle the %i4 over %i3 in a bowl and stir until fully dissolved and smooth.";
"recipe.hk_mango_pudding.step2.title" = "Dissolve the gelatin";
"recipe.hk_mango_pudding.step3.body" = "Warm the %i2 with a little of the hot gelatin liquid in a saucepan just until dissolved, then combine back with the remaining gelatin mixture.";
"recipe.hk_mango_pudding.step3.title" = "Make the sweet base";
"recipe.hk_mango_pudding.step4.body" = "Whisk the mango puree with %i5, then slowly whisk in the warm gelatin mixture until evenly combined.";
"recipe.hk_mango_pudding.step4.title" = "Combine pudding mixture";
"recipe.hk_mango_pudding.step5.body" = "Pour the mixture through a fine mesh strainer into a jug to remove fibers and bubbles.";
"recipe.hk_mango_pudding.step5.title" = "Strain for smooth texture";
"recipe.hk_mango_pudding.step6.body" = "Ladle the strained mixture into individual serving bowls.";
"recipe.hk_mango_pudding.step6.title" = "Portion the pudding";
"recipe.hk_mango_pudding.step7.body" = "Refrigerate the bowls until the mango pudding is softly firm and fully chilled.";
"recipe.hk_mango_pudding.step7.title" = "Chill until set";
"recipe.hk_mango_pudding.step8.body" = "Pour a little %i6 over each pudding just before serving.";
"recipe.hk_mango_pudding.step8.title" = "Serve with evaporated milk";
