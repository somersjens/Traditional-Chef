"recipe.ma_pastilla.step10.body" = "Spread the chicken-and-egg filling evenly, then add an even layer of the sweet almond mixture. Fold over the overhanging pastry to enclose, add a final buttered pastry layer on top, and tuck edges neatly.";
"recipe.ma_pastilla.step10.title" = "Fill and seal";
"recipe.ma_pastilla.step11.body" = "Bake until the pastilla is deeply golden and crisp. Let it settle briefly so it slices cleanly.";
"recipe.ma_pastilla.step11.title" = "Bake until crisp";
"recipe.ma_pastilla.step12.body" = "Turn out or serve from the pan. Dust with %i21 and %i22 in a traditional pattern, then serve warm.";
"recipe.ma_pastilla.step12.title" = "Finish and serve";
