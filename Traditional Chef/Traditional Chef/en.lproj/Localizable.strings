"recipe.my_sago_gula_melaka.drink.body" = "A lightly sweet Moscato dAsti or a mild wheat beer pairs gently with the caramel notes of gula melaka and coconut. For a non-alcoholic pairing, serve hot pandan tea or unsweetened jasmine tea.";
"recipe.my_sago_gula_melaka.drink.summary" = "Moscato dAsti";
"recipe.my_sago_gula_melaka.info" = "Sago gula melaka is a traditional Malaysian dessert of cooked sago pearls set into soft pudding portions and served with rich coconut milk and a dark palm sugar syrup made from gula melaka. It is commonly served chilled as a light dessert or tea-time sweet in warm weather.";
"recipe.my_sago_gula_melaka.info.summary" = "Sago gula melaka";
"recipe.my_sago_gula_melaka.name" = "Sago gula Melaka";
