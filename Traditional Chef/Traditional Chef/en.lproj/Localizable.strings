"recipe.it_panna_cotta.step3.title" = "Heat gently";
"recipe.it_panna_cotta.step4.body" = "Remove from the heat, discard the vanilla pod, add the softened gelatin, and whisk until fully dissolved.";
"recipe.it_panna_cotta.step4.title" = "Dissolve the gelatin";
"recipe.it_panna_cotta.step5.body" = "Pour the mixture through a fine sieve to ensure a perfectly smooth panna cotta.";
"recipe.it_panna_cotta.step5.title" = "Strain the mixture";
"recipe.it_panna_cotta.step6.body" = "Divide the mixture among ramekins or molds and let them cool briefly at room temperature.";
"recipe.it_panna_cotta.step6.title" = "Fill the molds";
"recipe.it_panna_cotta.step7.body" = "Refrigerate until fully set and chilled.";
"recipe.it_panna_cotta.step7.title" = "Chill to set";
"recipe.it_panna_cotta.step8.body" = "Dip the mold briefly in warm water, loosen the edge, invert onto a plate, and serve cold.";
"recipe.it_panna_cotta.step8.title" = "Unmold and serve";
