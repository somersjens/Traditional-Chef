"recipe.mm_laphet_thoke.drink.body" = "Lahpet thoke is traditionally paired with plain Burmese green tea rather than wine. If serving wine, a very light aromatic white can work. Non-alcoholic pairing: hot Burmese green tea.";
"recipe.mm_laphet_thoke.drink.summary" = "Green tea";
"recipe.mm_laphet_thoke.info" = "Lahpet thoke is a traditional Myanmar fermented tea leaf salad made by combining seasoned pickled tea leaves with crisp vegetables, fried garlic, peanuts, sesame seeds, and crunchy legumes. It is commonly served as a shared salad or snack, especially with tea, and is known for its contrast of bitter, sour, salty, spicy, and crunchy elements.";
"recipe.mm_laphet_thoke.info.summary" = "Fermented tea salad";
"recipe.mm_laphet_thoke.name" = "Lahpet thoke";
"recipe.mm_laphet_thoke.step1.body" = "Finely shred the %i15, dice the %i16, thinly slice the %i17 and %i19, and roughly chop the %i18. Keep the vegetables separate and ready for mixing.";
"recipe.mm_laphet_thoke.step1.title" = "Prepare the fresh vegetables";
"recipe.mm_laphet_thoke.step2.body" = "Finely mince the %i2, %i3, and %i4, then combine with the %i1 in a bowl.";
"recipe.mm_laphet_thoke.step2.title" = "Prepare the tea leaf dressing base";
"recipe.mm_laphet_thoke.step3.body" = "Mix the tea leaves with %i5, %i6, %i7, %i8, and %i9 until evenly seasoned and glossy.";
"recipe.mm_laphet_thoke.step3.title" = "Season the tea leaves";
"recipe.mm_laphet_thoke.step4.body" = "Heat %i14 in a skillet and fry the %i13 until golden, then fry the %i11 until crisp. Toast the %i10 and %i12 lightly and set everything aside to cool.";
"recipe.mm_laphet_thoke.step4.title" = "Fry the crunchy toppings";
"recipe.mm_laphet_thoke.step5.body" = "Place the cabbage, tomato, onion, cilantro, and fresh chili in a large mixing bowl.";
"recipe.mm_laphet_thoke.step5.title" = "Combine the salad base";
"recipe.mm_laphet_thoke.step6.body" = "Add the seasoned tea leaf mixture to the vegetables and top with the peanuts, fried split peas, sesame seeds, and fried garlic.";
"recipe.mm_laphet_thoke.step6.title" = "Assemble the lahpet thoke";
"recipe.mm_laphet_thoke.step7.body" = "Toss the salad thoroughly just before serving so the crunchy toppings stay textured and the tea leaves coat the vegetables evenly.";
"recipe.mm_laphet_thoke.step7.title" = "Toss and taste";
"recipe.mm_laphet_thoke.step8.body" = "Pour hot %i21 over the %i20 in a tea pot and steep until fragrant, then strain for serving.";
"recipe.mm_laphet_thoke.step8.title" = "Brew the green tea";
"recipe.mm_laphet_thoke.step9.body" = "Transfer the lahpet thoke to a platter and serve immediately with hot green tea.";
"recipe.mm_laphet_thoke.step9.title" = "Serve";
