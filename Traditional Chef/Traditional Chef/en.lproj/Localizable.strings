"recipe.es_crema_catalana.drink.body" = "Pair with a sweet Catalan dessert wine such as Moscatel or a small glass of sherry-style Pedro Ximénez for contrast with the burnt sugar. A dry Cava can also work to refresh the palate. Non-alcoholic option: espresso or sparkling water with lemon.";
"recipe.es_crema_catalana.drink.summary" = "Sweet wine (Moscatel)";
"recipe.es_crema_catalana.info" = "Crema catalana is a traditional Catalan custard thickened with starch and egg yolks, gently infused with cinnamon and citrus peel, then chilled in shallow dishes and finished with a glassy, caramelized sugar crust. Served cold with the warm crackle on top, it is a classic Spanish dessert especially associated with Catalonia and festive family meals.";
"recipe.es_crema_catalana.info.summary" = "Catalan burnt custard";
"recipe.es_crema_catalana.name" = "Crema catalana";
"recipe.es_crema_catalana.step1.body" = "Warm the %i1 with %i5 and strips of %i6 peel until steaming and fragrant, then remove from heat to finish infusing.";
"recipe.es_crema_catalana.step1.title" = "Infuse the milk";
"recipe.es_crema_catalana.step2.body" = "Whisk %i3 with %i2 until smooth, then whisk in %i4 until fully dissolved.";
"recipe.es_crema_catalana.step2.title" = "Make the custard mixture";
"recipe.es_crema_catalana.step3.body" = "Whisk the hot infused milk into the yolk mixture gradually, then return to the saucepan. Cook gently while whisking until the custard thickens and becomes silky.";
"recipe.es_crema_catalana.step3.title" = "Temper and thicken";
"recipe.es_crema_catalana.step4.body" = "Strain the custard through a fine sieve into shallow dishes and smooth the tops.";
"recipe.es_crema_catalana.step4.title" = "Strain and portion";
"recipe.es_crema_catalana.step5.body" = "Refrigerate until fully cold and set.";
"recipe.es_crema_catalana.step5.title" = "Chill until set";
"recipe.es_crema_catalana.step6.body" = "Sprinkle %i7 evenly over each custard and caramelize to a hard, glassy crust. Serve immediately.";
"recipe.es_crema_catalana.step6.title" = "Caramelize and serve";
