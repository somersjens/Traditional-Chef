"recipe.ir_bastani_sonnati.step10.title" = "Serve with wafers";
"recipe.ir_bastani_sonnati.step2.body" = "Crush %i6 to a fine powder, then steep it in a small amount of warm water to bloom.";
"recipe.ir_bastani_sonnati.step2.title" = "Prepare saffron";
"recipe.ir_bastani_sonnati.step3.body" = "Warm %i1 and %i2 in a saucepan until steaming. In a bowl, whisk %i3, %i4, and %i5 until smooth.";
"recipe.ir_bastani_sonnati.step3.title" = "Start the custard base";
"recipe.ir_bastani_sonnati.step4.body" = "Slowly whisk the hot dairy into the yolk mixture, then return everything to the saucepan. Cook over medium-low heat, stirring constantly, until the mixture thickens and coats the back of a spoon.";
"recipe.ir_bastani_sonnati.step4.title" = "Temper and thicken";
"recipe.ir_bastani_sonnati.step5.body" = "Strain the hot base through a fine sieve into a clean bowl. Stir in the bloomed saffron, %i7, and %i8 until evenly blended.";
"recipe.ir_bastani_sonnati.step5.title" = "Strain and perfume";
"recipe.ir_bastani_sonnati.step6.body" = "Set the bowl over an ice bath to cool, then refrigerate the base until fully cold.";
"recipe.ir_bastani_sonnati.step6.title" = "Chill thoroughly";
"recipe.ir_bastani_sonnati.step7.body" = "Churn the cold base in an ice cream maker until it reaches a thick, soft-serve consistency.";
"recipe.ir_bastani_sonnati.step7.title" = "Churn the ice cream";
"recipe.ir_bastani_sonnati.step8.body" = "Chop %i9. Scrape the frozen clotted cream into thin shards, then quickly fold the pistachios and cream shards through the churned ice cream.";
"recipe.ir_bastani_sonnati.step8.title" = "Add pistachios and cream flakes";
"recipe.ir_bastani_sonnati.step9.body" = "Pack the ice cream into a freezer-safe container, press the surface smooth, cover tightly, and freeze until scoopable.";
"recipe.ir_bastani_sonnati.step9.title" = "Firm in the freezer";
