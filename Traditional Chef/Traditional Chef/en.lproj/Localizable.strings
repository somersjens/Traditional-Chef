"recipe.pe_picarones.drink.body" = "Pair with a small pour of Pedro Ximénez or a sweet Muscat to echo the molasses-like chancaca syrup and warm spices. A dark stout can also complement the caramel notes. For a non-alcoholic option, serve hot cinnamon tea or black coffee.";
"recipe.pe_picarones.drink.summary" = "Dessert wine (Pedro Ximénez)";
"recipe.pe_picarones.info" = "Picarones are traditional Peruvian fried rings made from a yeast dough of mashed sweet potato and squash, lightly spiced and fried until crisp outside and airy inside. They are served hot and generously drizzled with chancaca syrup scented with cinnamon and cloves, a classic street dessert especially popular in the evenings.";
"recipe.pe_picarones.info.summary" = "Chancaca sweet rings";
"recipe.pe_picarones.name" = "Picarones";
"recipe.pe_picarones.step1.body" = "Boil the %i1 and %i2 in %i3 until completely tender, then drain well.";
"recipe.pe_picarones.step1.title" = "Boil the tubers";
"recipe.pe_picarones.step2.body" = "Mash the sweet potatoes and squash until very smooth, then let the puree cool until warm but not hot.";
"recipe.pe_picarones.step2.title" = "Mash into puree";
"recipe.pe_picarones.step3.body" = "Mix the %i5 with a little warm water and a pinch of %i6 until foamy.";
"recipe.pe_picarones.step3.title" = "Activate the yeast";
"recipe.pe_picarones.step4.body" = "Combine the puree with %i4, sugar, %i7, and the activated yeast, mixing until you have a soft, sticky, elastic dough.";
"recipe.pe_picarones.step4.title" = "Make the dough";
"recipe.pe_picarones.step5.body" = "Cover and let the dough rise until noticeably puffy and airy.";
"recipe.pe_picarones.step5.title" = "Let it rise";
"recipe.pe_picarones.step6.body" = "Simmer the %i8 with %i9, %i10, %i11, and %i12 until melted and slightly thickened, then strain out the spices and peel.";
"recipe.pe_picarones.step6.title" = "Cook the chancaca syrup";
"recipe.pe_picarones.step7.body" = "Heat the %i13 in a deep pot until hot enough that a small bit of dough sizzles and rises immediately.";
"recipe.pe_picarones.step7.title" = "Heat the frying oil";
"recipe.pe_picarones.step8.body" = "With wet hands, form rings of dough and slide them into the hot oil. Fry, turning, until deep golden and cooked through, then drain on paper towels.";
"recipe.pe_picarones.step8.title" = "Fry the picarones";
"recipe.pe_picarones.step9.body" = "Serve the picarones hot and drizzle generously with the warm chancaca syrup.";
"recipe.pe_picarones.step9.title" = "Serve with syrup";
