"recipe.in_shrikhand.drink.body" = "A lightly sweet dessert wine such as Moscato dAsti pairs gently with the creamy saffron-cardamom yogurt and nuts. Masala chai can also work in a small serving. For a non-alcoholic option, serve plain chilled milk or light saffron milk.";
"recipe.in_shrikhand.drink.summary" = "Dessert wine (Moscato dAsti)";
"recipe.in_shrikhand.info" = "Shrikhand is a traditional western Indian dessert made from hung yogurt whisked smooth with sugar, saffron, and cardamom until thick, creamy, and fragrant. It is commonly served chilled for festive meals and special occasions, especially in Maharashtra and Gujarat, often with puri.";
"recipe.in_shrikhand.info.summary" = "Chilled saffron shrikhand";
"recipe.in_shrikhand.name" = "Shrikhand";
"recipe.in_shrikhand.step1.body" = "Line a colander with cloth, add the %i1, gather the cloth, and place it to drain over a bowl.";
"recipe.in_shrikhand.step1.title" = "Prepare the yogurt for draining";
"recipe.in_shrikhand.step10.body" = "Fry the puris one at a time, pressing gently so they puff, then turn and fry briefly until lightly golden.";
"recipe.in_shrikhand.step10.title" = "Fry the puris";
"recipe.in_shrikhand.step11.body" = "Top the chilled shrikhand with sliced almonds and pistachios.";
"recipe.in_shrikhand.step11.title" = "Garnish the shrikhand";
"recipe.in_shrikhand.step12.body" = "Serve the shrikhand chilled with hot puris.";
"recipe.in_shrikhand.step12.title" = "Serve";
"recipe.in_shrikhand.step2.body" = "Hang or rest the yogurt bundle until thick and the whey drains out, leaving a dense hung curd.";
"recipe.in_shrikhand.step2.title" = "Hang the yogurt";
"recipe.in_shrikhand.step3.body" = "Soak the %i4 in %i5 and slice the %i6 and %i7 for garnish.";
"recipe.in_shrikhand.step3.title" = "Prepare saffron and garnish";
"recipe.in_shrikhand.step4.body" = "Transfer the hung curd to a bowl and whisk with %i2, %i3, and saffron milk until very smooth and creamy.";
"recipe.in_shrikhand.step4.title" = "Whisk the shrikhand";
"recipe.in_shrikhand.step5.body" = "Cover and chill the shrikhand so it firms up and the flavors blend.";
"recipe.in_shrikhand.step5.title" = "Chill the shrikhand";
"recipe.in_shrikhand.step6.body" = "Mix %i8, %i9, %i10, and %i11 into a firm dough, then knead until smooth.";
"recipe.in_shrikhand.step6.title" = "Make the puri dough";
"recipe.in_shrikhand.step7.body" = "Cover the dough and let it rest so it rolls evenly.";
"recipe.in_shrikhand.step7.title" = "Rest the dough";
"recipe.in_shrikhand.step8.body" = "Divide the dough into small balls and roll each into small discs of even thickness.";
"recipe.in_shrikhand.step8.title" = "Shape the puris";
